#compdef lazyjournal

_lazyjournal() {
  _arguments \
    '(-u --unit)'{-u,--unit}'=[filter by systemd unit]:unit' \
    '(-b --boot)'{-b,--boot}'=[show messages from specific boot]:boot' \
    '(-p --priority)'{-p,--priority}'=[filter by priority]:priority:(emerg alert crit err warning notice info debug)' \
    '(-S --since)'{-S,--since}'=[show entries since timestamp]:timestamp' \
    '(-U --until)'{-U,--until}'=[show entries until timestamp]:timestamp' \
    '(-g --grep)'{-g,--grep}'=[filter by pattern]:pattern' \
    '(-n --lines)'{-n,--lines}'=[number of lines to show]:lines' \
    '--no-pager[do not pipe output into a pager]' \
    '--user[show user journal]' \
    '--system[show system journal]' \
    '(-f --follow)'{-f,--follow}'[follow new entries]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]'
}

_lazyjournal "$@"
