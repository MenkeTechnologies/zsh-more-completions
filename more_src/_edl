#compdef edl edl.py
# Documentation: https://github.com/bkerler/edl
# Qualcomm Sahara / Firehose EDL client for reading and writing flash

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--loader=[set firehose loader file]:file:_files' \
  '--vid=[set USB vendor id]:vid' \
  '--pid=[set USB product id]:pid' \
  '--lun=[set LUN to read or write]:lun' \
  '--maxpayload=[maximum payload size in bytes]:bytes' \
  '--sectorsize=[sector size in bytes]:bytes' \
  '--pagesperblock=[pages per block]:num' \
  '--memory=[memory type]:memtype:(emmc ufs nand spinor)' \
  '--partitionfilename=[partition filename]:file:_files' \
  '--partitions=[partition names]:partitions' \
  '--skipwrite[do not actually write]' \
  '--skipresponse[do not wait for response]' \
  '--skipstorageinit[skip storage initialization]' \
  '--debugmode[enable debug mode]' \
  '--gpt-num-part-entries=[GPT partition entry count]:num' \
  '--gpt-part-entry-size=[GPT partition entry size]:bytes' \
  '--gpt-part-entry-start-lba=[GPT partition entry start LBA]:lba' \
  '--tcpport=[TCP port for server mode]:port' \
  '--skip=[skip partitions]:partitions' \
  '--genxml[generate rawprogram XML]' \
  '--devicemodel=[device model]:model' \
  '--portname=[serial port name]:port:_files' \
  '--serial[use serial transport]' \
  '--slot=[slot to use]:slot' \
  '--resetmode=[reset mode]:mode' \
  '--serial_number=[device serial number]:serial' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'server[run TCP/IP server]' \
      'printgpt[print GPT partition table]' \
      'gpt[dump and generate GPT files]' \
      'r[read partition to file]' \
      'rl[read all partitions to directory]' \
      'rf[read full flash to file]' \
      'rs[read sectors to file]' \
      'w[write partition from file]' \
      'wl[write all files from directory]' \
      'wf[write raw image to flash]' \
      'ws[write sectors from file]' \
      'e[erase partition]' \
      'es[erase sectors]' \
      'ep[erase by sector range]' \
      'footer[dump crypto footer]' \
      'peek[read memory to file]' \
      'peekhex[read memory as hex]' \
      'peekdword[read 32-bit word from memory]' \
      'peekqword[read 64-bit word from memory]' \
      'memtbl[dump memory table]' \
      'poke[write file to memory]' \
      'pokehex[write hex to memory]' \
      'pokedword[write 32-bit word to memory]' \
      'pokeqword[write 64-bit word to memory]' \
      'memcpy[copy memory region]' \
      'secureboot[display secure boot fuses]' \
      'pbl[dump PBL]' \
      'qfp[dump QFP fuses]' \
      'getstorageinfo[read storage info]' \
      'setbootablestoragedrive[set bootable storage drive]' \
      'getactiveslot[get active slot]' \
      'setactiveslot[set active slot]' \
      'send[send firehose command]' \
      'xml[send XML file]' \
      'rawxml[send raw XML string]' \
      'reset[reboot device]' \
      'nop[no operation]' \
      'modules[run module commands]' \
      'memorydump[dump memory in 0x900E mode]' \
      'provision[provision UFS]' \
      'qfil[flash QFIL package]' && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
