#compdef jsleak
# Documentation: https://github.com/byt3hx/jsleak
# command-line tool to uncover secrets and links in JavaScript files or source code

local ret=1

_arguments -s -S \
  '-h[display help message]' \
  '-t[YAML regex patterns file]:file:_files' \
  '-s[enable secret discovery mode]' \
  '-l[enable link finder functionality]' \
  '-e[complete URL function]' \
  '-c[set concurrency level for scanning multiple URLs]:n' \
  '-k[check HTTP status codes to verify if URLs are active]' && ret=0

return ret
