#compdef grimshot
# Documentation: https://man.archlinux.org/man/extra/sway-contrib/grimshot.1.en
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--notify[show notification when screenshot is taken]' \
  '--cursor[include cursor in screenshot]' \
  '--wait=[wait N seconds before capture]:seconds:' \
  '1:action:->actions' \
  '2:target:->targets' \
  '3:file:_files' && ret=0

case $state in
  (actions)
    local -a actions=(
      'copy:screenshot to clipboard'
      'save:screenshot to file'
      'savecopy:screenshot to file and clipboard'
      'check:verify dependencies are installed'
    )
    _describe -t actions 'action' actions && ret=0
    ;;
  (targets)
    local -a targets=(
      'active:capture active window'
      'screen:capture entire screen'
      'output:capture active output'
      'area:select area to capture'
      'window:select window to capture'
      'anything:select area or window'
    )
    _describe -t targets 'target' targets && ret=0
    ;;
esac

return ret
