#compdef image2fits
# Documentation: https://casacore.github.io/casacore/
# casacore: convert a casacore image to a FITS file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage]' \
  'in=[name of input Image or image expression]:image:_files' \
  'out=[name of output FITS file]:fits file:_files' \
  'debug=[debug level]:level' \
  '*:argument: ' && ret=0

return ret
