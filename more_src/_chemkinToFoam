#compdef chemkinToFoam
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/thermophysical/chemkinToFoam — convert CHEMKIN-format reaction set to OpenFOAM chemistry dict (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-newFormat[read CHEMKIN thermo file in new format]' \
    '-precision+[write precision]:label:_default' \
    '1:CHEMKIN reaction file:_files' \
    '2:CHEMKIN thermodynamics file:_files' \
    '3:CHEMKIN transport file:_files' \
    '4:OpenFOAM chemistry file:_files' \
    '5:OpenFOAM thermodynamics file:_files' \
    && ret=0

return ret
