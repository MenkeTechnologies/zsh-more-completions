#compdef gftools-packager
# Documentation: https://github.com/googlefonts/gftools
# Package a font family and create a pull request on google/fonts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-p --pr)'{-p,--pr}'[open a pull request on google/fonts or a forked repo]' \
  '--base-repo=[repo owner to send pull request (default: google)]:owner' \
  '--head-repo=[repo owner to push branch (default: google)]:owner' \
  '(-l --license)'{-l,--license}'=[licence type for new family]:license:(ofl apache ufl)' \
  '--latest-release[get assets from latest upstream release]' \
  '--build-from-source[download and build fonts from source files]' \
  '--their-venv[use upstream virtual environment when building]' \
  '--log-level=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--show-tracebacks[show tracebacks on error]' \
  '(-i --issue-number)'{-i,--issue-number}'=[issue number to reference in PR]:number' \
  '--skip-tags[skip tagging]' \
  '1:family or METADATA.pb:_files' \
  '2:repo path:_files -/' && ret=0

return ret
