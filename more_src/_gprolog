#compdef gprolog
# Documentation: gprolog --help (GNU Prolog)
# Source: GNU Prolog top-level interpreter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*--consult-file=[consult FILE inside top-level]:file:_files -g "*.(pl|pro|prolog)"' \
    '*--init-goal=[execute GOAL before entering top-level]:goal:' \
    '*--entry-goal=[execute GOAL inside top-level]:goal:' \
    '*--query-goal=[execute GOAL as top-level query]:goal:' \
    && ret=0

return ret
