#compdef trustee-cli
# _trustee-cli — Trustee management CLI (generate a server keypair, launch the bundled Trustee stack)
# upstream: https://github.com/confidential-containers/trustee
# Subcommands + flags from tools/trustee-cli/src/main.rs Cli + Commands on tip (clap); TRUSTEE_HOME env var binds to --home.

_trustee-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--home=[directory for storing Trustee config and data]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                keygen:'generate a new Ed25519 key pair'
                run:'launch Trustee (self-signed HTTPS by default)'
            )
            _describe -t commands 'trustee-cli subcommand' subs
            ;;
        args)
            case $line[1] in
                keygen)
                    _arguments \
                        '-f=[output file for the private key]:file:_files'
                    ;;
                run)
                    _arguments \
                        '--config-file=[Trustee configuration file]:file:_files' \
                        '--allow-all[use built-in allow-all policy (development only)]'
                    ;;
            esac
            ;;
    esac
}

_trustee-cli "$@"
