#compdef psftostroke
# Documentation: https://man.archlinux.org/search?q=psftostroke
# Reference accessed: 2026-05-16

# psftostroke: convert PSF console font glyphs to stroked outlines
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input PSF file:_files -g "*.(psf|psf.gz)"' && ret=0
return ret
