#compdef captool
# _captool — Caesar's Will captool packet-capture management CLI for converting pcap pcapng to ERF NLB ENC formats indexing capture files extracting Layer-3/4 streams filtering by BPF or 5-tuple (cisco team, C); getopt
# upstream: https://github.com/cisco/joy

_captool() {
    local -a sub=(
        'convert:convert capture format'
        'merge:merge captures'
        'split:split capture by interval'
        'filter:filter capture'
        'extract:extract streams'
        'index:build index'
        'info:show info'
        'stats:show statistics'
        'verify:verify integrity'
        'compress:compress capture'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-f+[BPF filter]:str:' \
        '--filter=+[BPF filter]:str:' \
        '-i+[input file]:file:_files -g "*.pcap *.pcapng *.cap *.erf *.dmp *.nlb *.enc"' \
        '--input=+[input file]:file:_files -g "*.pcap *.pcapng *.cap *.erf *.dmp *.nlb *.enc"' \
        '-o+[output file]:file:_files -g "*.pcap *.pcapng *.cap *.erf *.dmp *.nlb *.enc"' \
        '--output=+[output file]:file:_files -g "*.pcap *.pcapng *.cap *.erf *.dmp *.nlb *.enc"' \
        '-F+[output format]:f:(pcap pcapng erf nlb enc)' \
        '--format=+[output format]:f:(pcap pcapng erf nlb enc)' \
        '-c+[N packets]:n:' \
        '--count=+[N packets]:n:' \
        '-s+[snap len]:n:' \
        '--snap=+[snap len]:n:' \
        '-t+[time range]:str:' \
        '--time=+[time range]:str:' \
        '-j+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'captool subcommand' sub ;;
        args)
            case $words[1] in
                extract) _arguments \
                    '--protocol=+[p]:p:(tcp udp icmp arp ip ipv6 sctp gre)' \
                    '--src=+[ip:port]:str:' \
                    '--dst=+[ip:port]:str:' \
                    '*:capture file:_files -g "*.pcap *.pcapng"' ;;
            esac
            ;;
    esac
}

_captool "$@"
