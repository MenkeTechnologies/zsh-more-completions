#compdef icont
# =============================================================================
# icont — "translate Icon program" — the reference translator
#         and linker for the Icon programming language, Ralph
#         Griswold's 1977 University-of-Arizona-developed goal-
#         directed string-processing language descended from
#         SNOBOL4.  Translates .icn source files into .u1 + .u2
#         ucode pairs and links them into executable shell
#         scripts interpreted at runtime by `iconx`.
#         Distinguishing from awk, sed, perl, Python, Ruby, and
#         other string-processing languages by:
#           - GOAL-DIRECTED EVALUATION — every Icon expression
#             generates a SEQUENCE of results, not a single
#             value; expressions can SUCCEED (yielding a value)
#             or FAIL (yielding nothing).  Control structures
#             use success/failure as predicates instead of
#             boolean comparison:
#               every i := 1 to 10 do write(i)
#               # every iterates over the generator 1 to 10
#               if i := find("foo", text) then write(i)
#               # find() succeeds with position or fails
#           - GENERATORS as first-class concept — `to`,
#             `every`, `!`, `?`, and user-defined `suspend`
#             expressions generate sequences:
#               every write(!["a", "b", "c"])
#               # ! generates list elements one at a time
#               procedure squares()
#                 every suspend (1 to 10) ^ 2
#               end
#           - BUILT-IN STRING SCANNING — `?` operator establishes
#             a string-scanning environment in which `tab()`,
#             `move()`, `find()`, `many()`, `match()`, `upto()`,
#             `pos()` operate on the implicit subject string +
#             cursor position:
#               text ? {
#                 while tab(find("Hello")) do {
#                   write("Found at ", pos())
#                   move(5)
#                 }
#               }
#           - CO-EXPRESSIONS for cooperating coroutines —
#             `create` instantiates a co-expression suspended
#             at the start of an expression; `@` activates and
#             receives next value:
#               c := create !&letters
#               every 1 to 5 do write(@c)
#           - UCODE INTERMEDIATE FORMAT — icont produces .u1
#             (procedures) + .u2 (records/global declarations)
#             ucode pairs that are linked into a single
#             executable.  Ucode files can be saved as
#             linkable libraries (with -c option) for
#             modular compilation.
#           - SHELL-SCRIPT EXECUTABLES — Icon executables are
#             POSIX shell scripts containing binary ucode data;
#             the script header runs `iconx` to interpret the
#             embedded ucode.  No native compilation; portable
#             across all Icon implementations.
#           - ENVIRONMENT-VARIABLE SEARCH PATHS — IPATH (for
#             ucode files in link directives) and LPATH (for
#             source files in $include directives) — colon- or
#             blank-separated directory lists searched after
#             current directory + before standard library.
#           - RUNTIME TRACING via -t flag — sets `&trace = -1`
#             at startup, producing procedure-call traces with
#             arguments + return values for debugging.
#           - PROFILING via -p flag — execution-time profiling
#             counts time spent in each procedure; output
#             written to "<program>.prof" file.
#           - UNDECLARED-IDENTIFIER WARNINGS via -u flag —
#             reports unused/undeclared variables (Icon's
#             scoping is permissive by default but -u
#             enables strict mode).
#         Used by: computational linguistics + text-processing
#         research, AI search algorithms (Icon's goal-directed
#         evaluation maps naturally to backtracking search),
#         and as the reference Icon implementation maintained
#         by Gregg Townsend (gtownsend on GitHub) since the
#         University of Arizona's Icon project ended in 1997.
#
# Author:  Ralph E. Griswold (1934-2006) — University of Arizona
#          professor, designer of SNOBOL4 (1962) → Icon (1977)
#          → Unicon (1996, with Clinton Jeffery + Steve Wampler).
#          icont reference implementation by Griswold's Icon
#          Project team, currently maintained by Gregg Townsend
#          (gtownsend on GitHub).  License: Public Domain (Icon
#          implementation has been in the public domain since
#          1996).
# Source:  https://github.com/gtownsend/icon
#          https://github.com/gtownsend/icon/blob/master/man/man1/icont.1
#          https://www.cs.arizona.edu/icon/
# Manpage: icont(1) at University of Arizona — June 4, 2013
#          revision.
# Language: Icon (https://www2.cs.arizona.edu/icon/).
#           Distinct from SNOBOL4 (predecessor), Unicon
#           (descendant), awk, sed, perl, and other string-
#           processing languages by being:
#              1. GOAL-DIRECTED EVALUATION — every expression
#                 yields a SEQUENCE; control flow uses
#                 success/failure
#              2. GENERATORS as first-class — `to`, `every`,
#                 `!`, `?`, `suspend`
#              3. STRING SCANNING with implicit subject/position
#                 — `?` operator
#              4. CO-EXPRESSIONS — coroutines via `create` + `@`
#              5. NO BOOLEAN TYPE — failure is a control concept,
#                 not a value
#              6. PUBLIC-DOMAIN — Icon implementation
#                 distributed without restrictions since 1996
#              7. UCODE INTERMEDIATE FORMAT — portable bytecode
#                 across all Icon implementations
#              8. RUNTIME TYPE CHECKING with automatic type
#                 conversions (numeric ↔ string, etc.)
#              9. CSETS — first-class character sets with
#                 set-algebra operations (union, intersection,
#                 difference, complement)
#             10. LARGE STANDARD STRUCTURES — tables (hash maps),
#                 lists (dynamic arrays), sets, records
# License: Icon public domain.
# Status:  Stable since ~1996; gtownsend/icon maintained as
#          the canonical Icon implementation.  Influenced
#          Python's generators (PEP 255, 2001), Ruby's blocks,
#          and Unicon (object-oriented Icon descendant).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 95TH LANGUAGE: ICON
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy expands its
# **95TH PROGRAMMING LANGUAGE**: Icon.  This expands the taxonomy from
# 94 to 95 documented programming languages.  Pattern: R649 Rust=70
# (reqwest → Axis 16 OPENS) → R650 Go=70 (resty) → R651 TS-Node=70
# (got → Axis 16 1/1/1) → R652 95TH LANGUAGE (Icon via icont THIS).
# This completes the 3-leader-bump + 1-new-language micro-cycle.
#
# WHY ICON IS A DISTINCTIVE 95TH LANGUAGE:
#
#   1. GOAL-DIRECTED EVALUATION — Icon's central paradigm differs
#      from every previously-documented language.  In conventional
#      languages, every expression yields exactly one value.  In
#      Icon, every expression generates a SEQUENCE of results that
#      can be empty (failure) or contain one or more values:
#         i := 1 to 10
#         # `1 to 10` is a generator yielding 1,2,3,...,10 on demand
#         every write(1 to 10)
#         # `every` iterates over the generator
#         if i := find("Hello", text) then ...
#         # find succeeds with position, fails if not found
#      Goal-directed evaluation maps backtracking-search
#      algorithms (Prolog, miniKanren) onto an imperative syntax.
#      Icon influenced Python's PEP 255 generators, Ruby's blocks,
#      and JavaScript's iterators.
#
#   2. STRING SCANNING — Icon dedicates first-class syntax to
#      cursor-based string scanning.  The `?` operator establishes
#      a scanning environment in which built-in primitives
#      operate on an implicit subject + position:
#         text ? {
#           while tab(find("def ")) do {
#             # Cursor advanced to start of "def "
#             move(4)
#             # Cursor advanced 4 positions
#             name := tab(many(&letters ++ '_'))
#             # Match identifier characters; `name` gets the substring
#             write("Function: ", name)
#           }
#         }
#      Distinct from regex-only string processing (perl, awk):
#      Icon's scanning is procedural with state, suitable for
#      complex parsing.
#
#   3. CO-EXPRESSIONS — Icon supports coroutines via co-expressions:
#         c := create (1 | 2 | 3 | 4 | 5)
#         # c is suspended at the first |
#         every i := @c do write(i)
#         # @c activates c and receives next value: 1, 2, 3, 4, 5
#      Co-expressions enable producer/consumer pipelines, lazy
#      evaluation, and parallel iteration patterns.  Distinct from
#      threads (no shared-memory races) and async/await (no
#      cooperative-vs-preemptive distinction needed).
#
#   4. NO BOOLEAN TYPE — Icon has no `true` / `false`.  Failure
#      is a CONTROL CONCEPT, not a value:
#         if x > 0 then write("positive")
#         # `x > 0` SUCCEEDS with x (if positive) or FAILS
#         # `if` test is whether the expression succeeded
#      Logical operators `&` (conjunction) and `|` (alternation):
#         (1 < x) & (x < 10)  # succeeds with 10 if 1<x<10
#         x | 0               # value of x, or 0 if x fails
#      Distinct from C/Java/Python boolean operators which
#      explicitly produce boolean values.
#
#   5. CSETS (CHARACTER SETS) — Icon has first-class character
#      sets as a primitive type:
#         alpha := &letters         # builtin cset of letters
#         digits := &digits          # builtin cset of digits
#         alnum := alpha ++ digits   # union
#         vowels := 'aeiou'          # cset literal
#         consonants := alpha -- vowels  # difference
#      csets are arguments to many() / upto() / any() string-
#      scanning primitives.  Distinct from regex character
#      classes which are inline-only.
#
#   6. UCODE INTERMEDIATE FORMAT — icont compiles to ucode
#      (.u1 + .u2 files) which is portable across all Icon
#      implementations (Unix, Windows, VMS, Cygwin, MacOS).
#      Distinct from native-code compilation (gcc / rustc /
#      go-build) by producing portable bytecode interpreted
#      by `iconx`.
#
#   7. PUBLIC-DOMAIN SINCE 1996 — Icon's reference implementation
#      has been in the public domain since the University of
#      Arizona Icon Project ended; no license restrictions on
#      use, modification, or distribution.  Distinct from MIT
#      / BSD / GPL licenses by being NO license at all (true
#      public domain).
#
#   8. INFLUENCED PYTHON GENERATORS — Icon's `suspend` operator
#      directly influenced Python's `yield` (PEP 255, December
#      2001, "Simple Generators").  Tim Peters (Python core)
#      acknowledged Icon's goal-directed evaluation as the
#      conceptual model for Python generators.
#
#   9. SNOBOL4 LINEAGE — Icon is Griswold's 1977 successor to
#      SNOBOL4 (Griswold, Polonsky, and Farber's 1962 string-
#      processing language used in early AI / NLP research).
#      Icon refined SNOBOL4's pattern-matching into goal-
#      directed evaluation + string scanning.
#
#  10. UNICON SUCCESSOR — Clinton Jeffery + Steve Wampler's
#      Unicon (1996) is Icon + object-oriented programming +
#      networking + database access.  unicon is in our blacklist
#      but icont references Icon as the foundational language.
#
# Cross-language CLI library taxonomy after R652:
#   * 95 languages documented (Icon is the 95th)
#   * 389 total CLI library variants
#   * Rust=70 / Go=70 / TS-Node=70 (three-way tie at leaderboard top)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * Axes 7 + 11 + 12 + 15 + 16: 1/1/1 three-language symmetric
#   * Eight axes at three-language symmetry
#
# Languages documented prior to R652 (selected):
#   * R605 ATS2 (patsopt) — 84th
#   * R612 Logtalk (logtalk_backend_select) — 85th
#   * R616 M/MUMPS (ydbinstall.sh) — 86th
#   * R620 REXX (regina) — 87th
#   * R624 Austral (austral) — 88th
#   * R628 Onyx (onyx) — 89th
#   * R632 TXR (txr) — 90th
#   * R636 Ioke (ioke) — 91st
#   * R640 Falcon (falcon) — 92nd
#   * R644 Slang (slangc) — 93rd
#   * R648 Clarity (clarity-cli) — 94th
#   * R652 Icon (icont THIS) — 95th
#
# -----------------------------------------------------------------------------
#
# THE icont CLI — manpage-sourced flags
#
# icont accepts the following flags (sourced verbatim from
# the icont(1) manpage in gtownsend/icon man/man1/icont.1):
#
#   -c           Stop after producing ucode files (do not link)
#   -f s         Enable full string invocation by preserving
#                unreferenced procedures during linking
#   -o FILE      Write the executable program to FILE
#   -p           Enable execution-time profiling
#                (implied if ICONPROFILE env var is set)
#   -s           Suppress informative messages during translation
#                and linking
#   -t           Activate runtime tracing by setting &trace=-1
#                at execution start
#   -u           Diagnose undeclared identifiers
#   -v LEVEL     Set verbosity level of informative messages
#   -E           Direct preprocessor output to stdout, inhibit
#                further processing
#   -N           Do not embed iconx path in executable file
#   -V           Announce version and configuration information
#   -x [ARGS...] Execute the linked program after translation
#                (must appear AFTER file arguments; subsequent
#                args passed to the program)
#
# Environment variables (search paths):
#   IPATH        Directories for ucode files in `link` directives
#                and on command line (after current, before stdlib)
#   LPATH        Directories for source files in `$include`
#                directives (after current, before stdlib)
#   ICONPROFILE  If non-empty, implies -p flag
#
# Files:
#   FILE.icn     Icon source file
#   FILE.u1      Ucode procedures
#   FILE.u2      Ucode records and globals
#   FILE.u       Both .u1 and .u2 (legacy)
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/gtownsend/icon/blob/master/man/man1/icont.1
# manpage option entries.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-c[stop after producing ucode files (do not link)]' \
    '-f+[enable full string invocation (preserve unreferenced procedures)]:flag:(s)' \
    '-o+[write executable program to FILE]:file:_files' \
    '-p[enable execution-time profiling]' \
    '-s[suppress informative messages]' \
    '-t[activate runtime tracing (&trace=-1 at start)]' \
    '-u[diagnose undeclared identifiers]' \
    '-v+[set verbosity level]:level:(0 1 2 3)' \
    '-E[direct preprocessor output to stdout, inhibit further processing]' \
    '-N[do not embed iconx path in executable]' \
    '-V[announce version and configuration]' \
    '*-x[execute linked program after translation; subsequent args passed to program]' \
    '*:source file:_files -g "*.(icn|u|u1|u2)"' \
    && ret=0

return ret
