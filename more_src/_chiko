#compdef chiko

# felangga/chiko (cobra gRPC client); Homebrew: Formula/c/chiko.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '(-a)'{-a+,--addr=}'[gRPC server address]:host:port:' \
  '(--tls)'--tls'[use TLS]' \
  '*::method or reflection args:_default' && ret=0
return ret
