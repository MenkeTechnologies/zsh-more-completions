#compdef chiko
# Documentation: https://github.com/felangga/chiko/blob/main/internal/controller/flags.go
# Reference accessed: 2026-05-17
# Verified: upstream Go flag definitions at the URL above.

# felangga/chiko - TUI gRPC client (Go flag-based, single dash long flags).
local ret=1
_arguments -s \
  '-plaintext[use plain-text HTTP/2 (no TLS)]' \
  '-insecure[skip server certificate and domain verification]' \
  '-cacert=[trusted root certificates file]:file:_files' \
  '-cert=[client certificate (public key) file]:file:_files' \
  '-key=[client private key file]:file:_files' \
  '-d=[request data contents]:data:' \
  '-allow-unknown-fields[allow unknown fields in JSON request]' \
  '-max-msg-sz=[maximum encoded response message size]:bytes:' \
  '*::host:port:_default' && ret=0
return ret
