#compdef opensearch-cli

# Zsh completion for opensearch-cli - OpenSearch CLI

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'ad:Manage anomaly detection'
  'completion:Generate autocompletion scripts'
  'curl:Execute raw REST API requests'
  'knn:Manage k-NN plugin'
  'help:Help about any command'
  'profile:Manage connection profiles'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --profile)'{-p,--profile}'=[use named profile]:profile' \
  '(-e --endpoint)'{-e,--endpoint}'=[cluster endpoint URL]:url' \
  '(-u --user)'{-u,--user}'=[username]:username' \
  '(-w --password)'{-w,--password}'=[password]:password' \
  '--config=[path to config file]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'opensearch-cli command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      curl)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-X --request)'{-X,--request}'=[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD)' \
          '(-d --data)'{-d,--data}'=[request body]:data' \
          '(-H --headers)'{-H,--headers}'=[additional headers]:header' \
          '--output-format=[output format]:format:(json text yaml)' \
          '--pretty[pretty-print output]' \
          '1:path' && ret=0
        ;;
      ad)
        local -a ad_cmds
        ad_cmds=(
          'create:Create an anomaly detector'
          'delete:Delete an anomaly detector'
          'get:Get an anomaly detector'
          'start:Start an anomaly detector'
          'stop:Stop an anomaly detector'
          'update:Update an anomaly detector'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t ad_cmds 'ad subcommand' ad_cmds && ret=0 ;;
        esac
        ;;
      profile)
        local -a profile_cmds
        profile_cmds=(
          'create:Create a named profile'
          'delete:Delete a named profile'
          'list:List profiles'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t profile_cmds 'profile subcommand' profile_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
