_permit() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'login:login to Permit.io (interactive OAuth or --api-key)'
        'logout:logout from Permit.io'
        'init:initialize a new Permit project'
        'graph:visualize the policy graph (Ink TUI)'
        'api:direct Permit API access (CRUD on users/resources/roles)'
        'env:environment management (create/list/switch)'
        'gitops:GitOps integration (sync policies from git)'
        'opa:OPA-specific commands (policy generation/testing/sync)'
        'pdp:PDP sidecar management (run/query/test)'
        'policy:policy CRUD (create/list/update/delete)'
        'test:policy testing (run policy test suites)'
      )
      _describe -t subcommands 'permit subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        login)
          _arguments -s -S \
            '(-k --api-key)'{-k,--api-key}'[use API key instead of user authentication]:key:' \
            '--workspace[predefined workspace to login to]:workspace:' \
            '(-r --region)'{-r,--region}'[Permit region]:region:(us eu)'
          ;;
      esac
      ;;
  esac
}

_permit "$@"
