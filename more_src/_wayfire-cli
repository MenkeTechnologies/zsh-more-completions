#compdef wayfire-cli
# Documentation: https://man.archlinux.org/search?q=wayfire-cli
# Reference accessed: 2026-05-16

# wayfire-cli: control a running Wayfire (Wayland WM) instance
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'list-views:list managed views'
  'list-outputs:list outputs'
  'output-info:print info for output'
  'view-info:print info for view'
  'focus-view:focus a view'
  'close-view:close a view'
  'workspace-set:set workspace'
  'workspace-grid-set:set workspace grid'
  'execute:execute a wayfire plugin action'
  'reload:reload config'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'wayfire-cli command' commands && ret=0 ;;
esac
return ret
