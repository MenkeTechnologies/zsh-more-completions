#compdef i2cdetect
# _i2cdetect — Linux i2c-tools i2cdetect CLI for scanning an I2C bus for connected devices probing addresses with optional quick-write read-byte SMBus method showing functionality of an adapter (i2c-tools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/utils/i2c-tools/i2c-tools.git

_i2cdetect() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-y[disable interactive confirm]' \
        '-a[allow addresses 0x00-0x07 and 0x78-0x7f]' \
        '-q[use SMBus quick-write commands]' \
        '-r[use SMBus read-byte commands]' \
        '-F+[functionality flag]:str:' \
        '-l[list buses]' \
        '*:i2cbus first last:'
}

_i2cdetect "$@"
