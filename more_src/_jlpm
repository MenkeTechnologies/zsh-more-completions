#compdef jlpm

local -a subcmds

subcmds=(
    'add:Add a dependency'
    'audit:Perform a vulnerability audit'
    'autoclean:Clean and remove unnecessary files'
    'bin:Display the location of the yarn bin folder'
    'cache:Manage the yarn cache'
    'check:Verify package dependencies'
    'config:Manage configuration'
    'create:Create new projects'
    'generate-lock-entry:Generate a lock entry'
    'global:Manage global packages'
    'help:Display help information'
    'import:Generate yarn.lock from existing lockfile'
    'info:Show information about a package'
    'init:Initialize a new package'
    'install:Install all dependencies'
    'licenses:List licenses for installed packages'
    'link:Symlink a package folder'
    'list:List installed packages'
    'login:Login to the npm registry'
    'logout:Logout from the npm registry'
    'outdated:Check for outdated packages'
    'owner:Manage package owners'
    'pack:Create a compressed gzip archive'
    'policies:Set policies for package resolution'
    'publish:Publish a package'
    'remove:Remove a dependency'
    'run:Run a defined script'
    'tag:Manage package tags'
    'team:Manage teams'
    'unlink:Unlink a previously symlinked package'
    'unplug:Temporarily copy a package outside node_modules'
    'upgrade:Upgrade a dependency'
    'upgrade-interactive:Upgrade dependencies interactively'
    'version:Display version info'
    'versions:Display all version info'
    'why:Show why a package is installed'
    'workspace:Run a command in a workspace'
    'workspaces:Show information about workspaces'
)

_arguments -s -S \
    '--cache-folder=[Specify a custom folder for the cache]:directory:_directories' \
    '--check-files[Install will verify files in node_modules]' \
    '--cwd=[Working directory to use]:directory:_directories' \
    '--disable-pnp[Disable Plug-n-Play]' \
    '--emoji[Enable emoji in output]' \
    '--enable-pnp[Enable Plug-n-Play]' \
    '--flat[Only allow one version of a package]' \
    '--focus[Only install dependencies for current workspace]' \
    '--frozen-lockfile[Do not generate a lockfile]' \
    '--global-folder=[Specify a custom folder for global packages]:directory:_directories' \
    '--har[Save HAR output of network requests]' \
    '--https-proxy=[HTTPS proxy]:proxy url' \
    '--ignore-engines[Ignore engines check]' \
    '--ignore-optional[Ignore optional dependencies]' \
    '--ignore-platform[Ignore platform checks]' \
    '--ignore-scripts[Do not execute lifecycle scripts]' \
    '--json[Format output as JSON]' \
    '--link-duplicates[Create hardlinks for repeated modules]' \
    '--link-folder=[Specify a custom folder for linked packages]:directory:_directories' \
    '--modules-folder=[Specify a custom folder for node_modules]:directory:_directories' \
    '--mutex=[Use a mutex to ensure only one instance runs]:mutex' \
    '--network-concurrency=[Maximum number of concurrent network requests]:number' \
    '--network-timeout=[TCP timeout in milliseconds]:timeout' \
    '--no-bin-links[Do not generate bin links]' \
    '--no-default-rc[Prevent loading of default rc files]' \
    '--no-lockfile[Do not generate a lockfile]' \
    '--no-node-version-check[Do not warn for incompatible Node version]' \
    '--no-progress[Disable progress bar]' \
    '--non-interactive[Disable interactive prompts]' \
    '--offline[Trigger offline mode]' \
    '--otp=[One-time password for publish]:otp' \
    '--prefer-offline[Use cached data when possible]' \
    '--preferred-cache-folder=[Specify a custom folder for preferred cache]:directory:_directories' \
    '--prod[Only install production dependencies]' \
    '--production[Only install production dependencies]' \
    '--proxy=[HTTP proxy]:proxy url' \
    '--pure-lockfile[Do not generate a lockfile]' \
    '--registry=[Override configuration registry]:registry url' \
    '-s[Skip all interactive prompts]' \
    '--silent[Skip all interactive prompts]' \
    '--skip-integrity-check[Skip integrity check]' \
    '--strict-semver[Use strict semver]' \
    '--update-checksums[Update package checksums]' \
    '--use-yarnrc=[Specify an alternate yarnrc]:yarnrc file:_files' \
    '--verbose[Show additional logs]' \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'jlpm subcommand' subcmds
        ;;
esac
