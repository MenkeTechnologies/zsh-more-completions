#compdef 3dTcorrelate
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTcorrelate.html
# AFNI: voxel-wise correlation of two 3D+time datasets

local ret=1

_arguments -s -S \
  '-pearson[Pearson correlation (default)]' \
  '-spearman[Spearman rank correlation]' \
  '-quadrant[quadrant correlation]' \
  '-ktaub[Kendall tau_b]' \
  '-covariance[covariance instead of correlation]' \
  '-partial[partial Pearson correlation vs dataset z]:dataset:_files' \
  '-ycoef[least squares coefficient fitting y(t) to x(t)]' \
  '-Fisher[apply arctanh transform to results]' \
  '-polort[remove polynomial trend of order m]:m:' \
  '-ort[detrend using columns from 1D file]:file:_files' \
  '-autoclip[clip low-intensity regions]' \
  '-automask[alias for autoclip]' \
  '-zcensor[omit time points where either volume is all zero]' \
  '-prefix[output dataset prefix (default Tcorr)]:prefix:' \
  '*:dataset:_files' && ret=0

return ret
