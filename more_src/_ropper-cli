#compdef ropper
# Documentation: https://man.archlinux.org/search?q=ropper
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --file)'{-f+,--file=}'[file]:file:_files' \
  '(-c --console)'{-c,--console}'[console mode]' \
  '(--type)--type=[gadget type]:t:(rop jop sys all)' \
  '(--all --no-color)--all[print all]' \
  '(--detailed)--detailed[show detailed]' \
  '(--no-color)--no-color[disable color]' \
  '(--detailed-multiline)--detailed-multiline[multi-line]' \
  '(--info)--info[show info]' \
  '(--imports)--imports[show imports]' \
  '(--symbols)--symbols[show symbols]' \
  '(--sections)--sections[show sections]' \
  '(--segments)--segments[show segments]' \
  '(--dllcharacteristics)--dllcharacteristics[show DLL characteristics]' \
  '(--ppr)--ppr[push pop ret]' \
  '(--inst-count)--inst-count=[max instr]:n:' \
  '(-q --quality)'{-q+,--quality=}'[gadget quality]:n:' \
  '(--cfg-only)--cfg-only[CFG gadgets]' \
  '(--clear-cache)--clear-cache[clear cache]' \
  '(--badbytes)--badbytes=[bad bytes hex]:hex:' \
  '(--search)--search=[search regex]:re:' \
  '(--filter)--filter=[filter regex]:re:' \
  '(-I)*-I+[image base hex]:n:' \
  '(--imagebase)--imagebase=[image base hex]:n:' \
  '(--disasm-address)--disasm-address=[address]:hex:' \
  '(--disassemble-address)--disassemble-address=[address]:hex:' \
  '(--string)--string=[search string]:s:' \
  '(--hex)--hex=[hex bytes]:hex:' \
  '(--int)--int=[search int]:n:' \
  '(--asm)--asm=[asm string]:s:' \
  '(--chain)--chain=[chain generator]:c:(execve mprotect virtualprotect)' \
  '(--jmp)--jmp=[jmp register]:r:' \
  '(--stack-pivot)--stack-pivot[stack pivot gadgets]' \
  '(--single)--single[single chain]' \
  '(--nocolor)--nocolor[no color]' \
  '(--db --db-create --db-import)--db=[load gadget db]:file:_files' \
  '(--db-create)--db-create=[create db]:file:_files' \
  '(--analyze)--analyze[analyze]' \
  '*: :_files' && ret=0

return ret
