#compdef nifi-cli
# Documentation: https://man.archlinux.org/search?q=nifi-cli
# Reference accessed: 2026-05-16

# Zsh completion for nifi-cli

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*:: :_files' && ret=0

return ret
