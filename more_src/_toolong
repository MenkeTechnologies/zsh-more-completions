#compdef tl toolong

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--merge[merge multiple files into a single view]' \
  '--tail[start at the end of the file]' \
  '--no-tail[start at the beginning of the file]' \
  '*:log file:_files' && ret=0

return ret
