#compdef obrms
# Documentation: https://openbabel.org/docs/Command-line_tools.html
# Open Babel: compute the heavy-atom RMSD of identical compound structures

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-o --out)'{-o+,--out=}'[re-oriented test structure output]:output file:_files' \
  '(-f --firstonly)'{-f,--firstonly}'[use only the first structure in the reference file]' \
  '(-m --minimize)'{-m,--minimize}'[compute minimum RMSD]' \
  '(-x --cross)'{-x,--cross}'[compute all n^2 RMSDs between molecules of reference file]' \
  '(-s --separate)'{-s,--separate}'[separate reference file into constituent molecules and report best RMSD]' \
  '(-t --timeout)'{-t+,--timeout=}'[give up matching after N seconds]:seconds' \
  ':reference file:_files' \
  ':test file:_files' && ret=0

return ret
