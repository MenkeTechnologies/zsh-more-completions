#compdef cargo-make makers

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--makefile[the makefile to use]:makefile:_files' \
  '(-t --task)'{-t,--task}'[the task name]:task:->tasks' \
  '(-p --profile)'{-p,--profile}'[the profile name]:profile:' \
  '*'{-e,--env}'[set environment variable]:key=value:' \
  '--env-file[set environment from file]:env file:_files' \
  '--cwd[set working directory]:directory:_files -/' \
  '--no-workspace[disable workspace support]' \
  '--no-on-error[disable on error flow]' \
  '--allow-private[allow invocation of private tasks]' \
  '--skip-init-end-tasks[skip init and end tasks]' \
  '--skip-tasks[skip tasks by name pattern]:pattern:' \
  '--list-all-steps[list all known steps]' \
  '--list-category-steps[list steps for a category]:category:' \
  '--diff-steps[show diff between tasks]' \
  '--disable-check-for-updates[disable update checks]' \
  '--experimental[enable experimental features]' \
  '--print-steps[only print the execution plan]' \
  '--print-time-summary[print time summary at end]' \
  '--output-format[output format]:format:(default short-description autocomplete)' \
  '--output-file[output file]:file:_files' \
  '(-l --loglevel)'{-l,--loglevel}'[log level]:level:(verbose info error off)' \
  '(-v --verbose)'{-v,--verbose}'[set log level to verbose]' \
  '--quiet[set log level to error]' \
  '--time-summary[print time summary]' \
  '--silent[set log level to off]' \
  '--no-color[disable color output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:task:->tasks' && ret=0

case $state in
  (tasks)
    local -a tasks
    local makefile="${opt_args[--makefile]:-Makefile.toml}"
    if [[ -f "$makefile" ]]; then
      tasks=(${(f)"$(sed -n 's/^\[\(.*\)\]/\1/p' "$makefile" 2>/dev/null | grep -v '^tasks\.' | sed 's/^tasks\.//' | grep -v '\.' 2>/dev/null)"})
      # Try to extract task names from [tasks.NAME] sections
      local -a task_names
      task_names=(${(f)"$(sed -n 's/^\[tasks\.\([^].]*\)\]/\1/p' "$makefile" 2>/dev/null)"})
      if (( ${#task_names} )); then
        _describe -t tasks 'task' task_names && ret=0
      fi
    fi
    ;;
esac

return ret
