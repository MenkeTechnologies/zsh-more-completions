#compdef wireproxy
# Documentation: https://github.com/pufferffish/wireproxy
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print version]' \
  '(-c --config)'{-c,--config}'+[path to configuration file]:config file:_files' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '(-d --daemon)'{-d,--daemon}'[run in background]' \
  '(-i --info)'{-i,--info}'+[address and port for exposing health status]:addr:' \
  '(-n --configtest)'{-n,--configtest}'[check configuration file validity only]' && ret=0

return ret
