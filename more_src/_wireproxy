#compdef wireproxy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[path to configuration file]:config file:_files' \
  '--config=[path to configuration file]:config file:_files' \
  '-n+[device name]:name' \
  '--silent[suppress output]' \
  '-d[run as daemon]' \
  '--daemon[run as daemon]' \
  '--info=[expose health/info endpoint]:address' && ret=0

return ret
