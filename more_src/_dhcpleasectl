#compdef dhcpleasectl
# _dhcpleasectl — OpenBSD dhcpleasectl (instruct dhcpleased(8) to request a new DHCP lease on an interface, or list its currently configured lease)
# upstream: https://github.com/openbsd/src (usr.sbin/dhcpleasectl)
# Flags from usr.sbin/dhcpleasectl/dhcpleasectl.8 on tip.

_dhcpleasectl() {
    _arguments \
        '-l[list configured lease instead of requesting new]' \
        '-s+[control socket (default /dev/dhcpleased.sock)]:file:_files' \
        '-w+[max seconds to wait]:seconds:' \
        '1:interface:_net_interfaces'
}

_dhcpleasectl "$@"
