#compdef ddlog
# Documentation: https://github.com/vmware/differential-datalog/blob/master/app/Main.hs
# ddlog - Differential Datalog compiler (compiles .dl programs to Rust)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help message]' \
  '(-v --version)'{-v,--version}'[display DDlog version]' \
  '-i+[DDlog program to compile]:file:_files -g "*.dl"' \
  '--action=-[action to perform]:action:(validate compile)' \
  '*-L+[extra DDlog library directory]:directory:_files -/' \
  '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:directory:_files -/' \
  '--dynlib[generate dynamic library]' \
  '--no-dynlib[do not generate dynamic library (default)]' \
  '--staticlib[generate static library (default)]' \
  '--no-staticlib[do not generate static library]' \
  '(-j --java)'{-j,--java}'[generate Java bindings (implies --rust-flatbuffers)]' \
  '--output-internal-relations[mark all non-input relations as output relations]' \
  '--output-input-relations=-[mirror each input relation into an output relation with prefix]:prefix' \
  '-g[enable debugging hooks]' \
  '--pp-flattened[dump source after flattening pass to PROG.flat.ast]' \
  '--pp-validated[dump source after validation pass to PROG.valid.ast]' \
  '--pp-debug[dump source after debug-hook injection pass]' \
  '--pp-optimized[dump source after optimization pass]' \
  '--re-validate[re-validate after type inference and optimization (developers only)]' \
  '--omit-profile[skip adding a Cargo profile]' \
  '--omit-workspace[skip adding a Cargo workspace]' \
  '--run-rustfmt[run rustfmt on the generated code]' \
  '--rust-flatbuffers[build flatbuffers bindings for Rust]' \
  '--nested-ts-32[use 32-bit instead of 16-bit nested timestamps]' \
  '--d3log[compile to execute in the distributed DDlog (D3log) environment]' \
  '--d3log-dev[compile for D3log with experimental reflective features]' \
  '*:file:_files -g "*.dl"' && ret=0

return ret
