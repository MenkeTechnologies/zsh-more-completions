#compdef kavita
# _kavita — Joseph Milazzo Kavita self-hosted ebook/manga/comic library server with OPDS and Tachiyomi sync (Kareadita team, C#); custom argparse
# upstream: https://github.com/Kareadita/Kavita

_kavita() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config dir]:dir:_files -/' \
        '-c+[config dir]:dir:_files -/' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--base-url=+[base url]:url:_urls' \
        '--ip-addresses=+[bind ips]:str:' \
        '--logging-level=+[level]:l:(Trace Debug Information Warning Error Critical None)' \
        '--token-key=+[jwt token key]:str:' \
        '--accessible-from-anywhere[no IP restriction]' \
        '--allow-stats[opt-in stats]' \
        '--allow-iframe[allow iframe]' \
        '--disable-swagger-ui[disable swagger]' \
        '--enable-opds[enable OPDS]' \
        '--first-install[run first-time setup]' \
        '--migrate[run database migrations]' \
        '--backup-dir=+[backup dir]:dir:_files -/' \
        '--logs-dir=+[logs dir]:dir:_files -/'
}

_kavita "$@"
