#compdef sfpwd
# Documentation: https://www.reproducibility.org/blog/2013/02/09/program-of-the-month-sfpwd/
# Madagascar: 3-D plane wave destruction

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'order=[accuracy order]:order:' \
  'nj1=[antialiasing on first axis]:nj1:' \
  'nj2=[antialiasing on second axis]:nj2:' \
  'n4=[number of fourth-axis components]:n4:' \
  'both=[apply in both directions (y/n)]:both:(y n)' \
  'drift=[use shifted filter (y/n)]:drift:(y n)' \
  '*: :_files' && ret=0

return ret
