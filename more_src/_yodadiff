#compdef yodadiff
# Documentation: https://yoda.hepforge.org/
# yodadiff - compare analysis objects between two YODA files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[write output to the given file]:file:_files' \
  '(-t --tol)'{-t,--tol}'[relative tolerance of numerical difference permitted]:tol:' \
  '(-l --list)'{-l,--list}'[only print paths of mismatching objects]' \
  '(-a --annotations)'{-a,--annotations}'[also compare annotations]' \
  '(-d --dev-histo)'{-d,--dev-histo}'[write deviation histo to the given file]:file:_files' \
  '--normalize[normalize objects before comparing]' \
  '(-m --match)'{-m,--match}'[only write histograms whose path matches this regex]:regex:' \
  '(-M --unmatch)'{-M,--unmatch}'[exclude histograms whose path matches this regex]:regex:' \
  '--ignore-missing[do not complain if an object in file #1 is not found in file #2]' \
  '--ignore-new[do not complain if an object in file #2 is not found in file #1]' \
  '(-q --quiet)'{-q,--quiet}'[print nothing, only express result via return code]' \
  '*:file:_files' && ret=0

return ret
