#compdef sealert setroubleshootd setroubleshoot-server sedispatch
# _setroubleshoot — Fedora SELinux Setroubleshoot D-Bus daemon and sealert CLI for SELinux denial diagnostics (fedora-selinux team, Python); argparse
# upstream: https://github.com/fedora-selinux/setroubleshoot

_setroubleshoot() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l+[lookup alert]:str:' \
        '--lookup-id=+[lookup alert]:str:' \
        '-a+[audit log file]:file:_files -g "*.log"' \
        '--analyze=+[audit log file]:file:_files -g "*.log"' \
        '--fix=+[alert id]:str:' \
        '-b[browser]' \
        '--browser[browser]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-u+[username]:user:_users' \
        '--user=+[username]:user:_users' \
        '-S+[since]:str:' \
        '--since=+[since]:str:' \
        '-U+[until]:str:' \
        '--until=+[until]:str:' \
        '-c+[count]:n:' \
        '--count=+[count]:n:' \
        '--list-uuids[list alert UUIDs]' \
        '--last[show last alert]' \
        '--show=+[N]:n:' \
        '--get-html[get html output]' \
        '--get-plain[get plain text]' \
        '--show-tooltips[show tooltips]'
}

_setroubleshoot "$@"
