#compdef bupstash

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize a bupstash repository'
  'new-key:create a new primary key'
  'new-sub-key:derive a sub key'
  'put:add data to repository'
  'get:fetch data matching a query'
  'restore:restore a snapshot to local directory'
  'list:list repository items'
  'list-contents:list directory snapshot contents'
  'diff:diff snapshot contents'
  'rm:remove repository items'
  'recover-removed:recover items pending GC'
  'gc:reclaim disk space'
  'sync:sync items between repositories'
  'exec-with-locks:exec command holding locks'
  'serve:serve a repository'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bupstash subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (put)
        _arguments \
          '(-r --repository)'{-r,--repository=}'[repository]:repo:' \
          '(-k --key)'{-k,--key=}'[key]:key:_files' \
          '(-e --exec)'{-e,--exec}'[exec mode]' \
          '*--exclude=[exclude pattern]:pattern:' \
          '--exclude-if-present=[exclude if file present]:filename:' \
          '--send-log=[send log path]:file:_files' \
          '--no-send-log[disable send log]' \
          '--no-stat-caching[disable stat caching]' \
          '--compression=[compression]:type:(none lz4 zstd zstd:1 zstd:3 zstd:9 zstd:19)' \
          '--no-default-tags[no default tags]' \
          '--xattrs[store xattrs]' \
          '--ignore-permission-errors[ignore permission errors]' \
          '--one-file-system[stay on one filesystem]' \
          '--indexer-threads=[indexer threads]:n:' \
          '--threads=[threads]:n:' \
          '--print-file-actions[print file actions]' \
          '--print-stats[print stats]' \
          '--no-progress[no progress]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0
        ;;
      (get)
        _arguments \
          '(-r --repository)'{-r,--repository=}'[repository]:repo:' \
          '(-k --key)'{-k,--key=}'[key]:key:_files' \
          '--pick=[pick path]:path:' \
          '--query-cache=[query cache path]:dir:_files -/' \
          '--utc-timestamps[use UTC timestamps]' \
          '--no-progress[no progress]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0
        ;;
      (list)
        _arguments \
          '(-r --repository)'{-r,--repository=}'[repository]:repo:' \
          '(-k --key)'{-k,--key=}'[key]:key:_files' \
          '--query-encrypted[query encrypted index]' \
          '--query-cache=[query cache path]:dir:_files -/' \
          '--format=[output format]:fmt:(human jsonl)' \
          '--utc-timestamps[use UTC timestamps]' \
          '--no-progress[no progress]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0
        ;;
    esac
    ;;
esac

return ret
