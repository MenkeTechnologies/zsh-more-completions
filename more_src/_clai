#compdef clai
# Documentation: https://ai.pydantic.dev/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Pydantic AI (clai)
# https://github.com/pydantic/pydantic-ai

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --model)'{-m,--model}'[specify the model]:model:' \
  '(-a --agent)'{-a,--agent}'[path to custom agent]:agent:' \
  '(-l --list-models)'{-l,--list-models}'[list all available models]' \
  '--no-stream[disable streaming responses]' \
  '--version[show version]' \
  '*:prompt:' && ret=0

return ret
