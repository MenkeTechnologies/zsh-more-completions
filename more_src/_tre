#compdef tre

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  {-a,--all}'[show hidden files]' \
  {-d,--directories}'[list directories only]' \
  '(-l --limit)'{-l,--limit}'[limit depth of tree]:depth' \
  {-s,--simple}'[use simple output without colors]' \
  {-j,--json}'[output as JSON]' \
  {-e,--editor}'[open selected file with editor]:editor:_command_names -e' \
  '--color[when to use color]:when:(auto always never)' \
  '-E[set alias for editor command]:alias' \
  '--portable[generate portable script]' \
  '*:directory:_directories' \
  && ret=0

return ret
