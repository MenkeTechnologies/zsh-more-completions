#compdef rhasspy-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'wav2intent:convert WAV file(s) to intent(s)'
  'text2intent:convert text input to intent'
  'wav2text:convert WAV file(s) to text'
  'text2wav:convert text to WAV using TTS'
  'sentences:list known intent sentences'
  'profile:dump effective profile'
  'set:set a profile value'
  'unknown-words:list unknown words from a sentence'
  'train:train the profile'
  'mic-test-energy:test microphone energy threshold'
  'mic2text:record mic and convert to text'
  'mic2intent:record mic and convert to intent'
  'mic2wav:record mic to a wav file'
  'wav2mqtt:send a WAV file as Hermes audioFrame messages'
  'pronounce:pronounce a word using the configured TTS'
  'tune:tune the speech-to-text model'
  'phonemes:show pronunciation phonemes'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[profile name]:profile:' \
  '--user-profiles-dir=[user profiles directory]:dir:_files -/' \
  '--system-profiles-dir=[system profiles directory]:dir:_files -/' \
  '--debug[debug logging]' \
  '--api-url=[Rhasspy API URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rhasspy-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (wav2intent|wav2text|wav2mqtt)
        _arguments \
          '--handle[handle the intent after recognition]' \
          '*:wav_file:_files -g "*.wav"' && ret=0 ;;
      (text2intent|text2wav|pronounce|unknown-words)
        _arguments \
          '*::text:' && ret=0 ;;
      (mic2text|mic2intent|mic2wav|mic-test-energy)
        _arguments \
          '--seconds=[duration]:n:' && ret=0 ;;
      (set)
        _arguments '*::key_value:' && ret=0 ;;
    esac ;;
esac

return ret
