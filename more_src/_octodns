#compdef octodns-sync octodns-validate octodns-versions octodns-dump octodns-compare octodns-report octodns-spf
# _octodns — Ross McFarland GitHub octoDNS DNS-as-code synchronization tool (octodns team, Python); argparse
# upstream: https://github.com/octodns/octodns

_octodns-sync() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-file=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--doit[apply changes]' \
        '--force[skip too-large guard]' \
        '--all-providers[include all providers]' \
        '--include-provider=+[provider]:str:' \
        '--exclude-provider=+[provider]:str:' \
        '--source=+[source provider]:str:' \
        '--target=+[target provider]:str:' \
        '--zone=+[zone]:str:' \
        '--exclude=+[zone]:str:' \
        '--lenient[lenient validation]' \
        '--quiet[quiet]' \
        '--checksum=+[checksum]:str:' \
        '--plan-output-pattern=+[pattern]:str:' \
        '--log-stream-stdout[log to stdout]' \
        '--debug[debug]' \
        '*:zone:'
}

_octodns-sync "$@"
