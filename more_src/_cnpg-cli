#compdef cnpg-cli cloudnative-pg
# _cnpg-cli — EDB CloudNativePG cnpg-cli CLI kubectl plugin command-line frontend wrapping the CloudNativePG Kubernetes-native operator for running PostgreSQL high-availability clusters managing cluster install upgrade backup restore promote reload restart pgbench fence destroy hibernate maintenance certificate (EDB team, Go); cobra
# upstream: https://cloudnative-pg.io/

_cnpg-cli() {
    local -a sub=(
        'install:install CloudNativePG operator'
        'uninstall:uninstall operator'
        'destroy:destroy cluster'
        'fencing:fence pods'
        'hibernate:hibernate cluster'
        'maintenance:maintenance management'
        'promote:promote replica to primary'
        'reload:reload configuration'
        'report:dump operator report'
        'restart:restart cluster'
        'status:show cluster status'
        'backup:create backup'
        'restore:restore from backup'
        'snapshot:snapshot operations'
        'certificate:certificate management'
        'pgbench:run pgbench job'
        'logs:fetch cluster logs'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--watch-namespace=+[name]:str:' \
        '--instance=+[N]:n:' \
        '--imageCatalog=+[name]:str:' \
        '--image-name=+[image]:str:' \
        '--postgresql-version=+[v]:str:' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cnpg-cli subcommand' sub ;;
        args)
            case $words[1] in
                status|promote|reload|restart|destroy|fencing|hibernate|backup|snapshot) _arguments '*:cluster name:' ;;
                restore) _arguments \
                    '--source=+[backup]:str:' \
                    '*:cluster name:' ;;
            esac
            ;;
    esac
}

_cnpg-cli "$@"
