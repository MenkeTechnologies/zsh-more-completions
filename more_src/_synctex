#compdef synctex

local -a subcmds

subcmds=(
    'view:Get info from PDF to source'
    'edit:Get info from source to PDF'
    'update:Update the synctex file'
    'help:Display help'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'synctex subcommand' subcmds
        ;;
    options)
        case $words[1] in
            view)
                _arguments \
                    '-i[Input specification (line:column:input_file)]:line\:column\:file' \
                    '-o[Output file]:PDF file:_files -g "*.pdf"' \
                    '-d[Output directory]:directory:_directories' \
                    '-x[Horizontal offset]:offset' \
                    '-y[Vertical offset]:offset' \
                    '-h[Display help for view]'
                ;;
            edit)
                _arguments \
                    '-o[Output specification (page:x:y:output_file)]:page\:x\:y\:file' \
                    '-d[Output directory]:directory:_directories' \
                    '-x[Horizontal offset]:offset' \
                    '-y[Vertical offset]:offset' \
                    '-h[Display help for edit]'
                ;;
            update)
                _arguments \
                    '-o[Output file]:synctex file:_files -g "*.synctex*"' \
                    '-m[Magnification]:magnification' \
                    '-x[X offset]:offset' \
                    '-y[Y offset]:offset' \
                    '-h[Display help for update]'
                ;;
        esac
        ;;
esac
