#compdef sfrtoc
# Documentation: https://github.com/ahay/src/blob/master/system/main/rtoc.c
# Madagascar: convert real data to complex (by adding zero imaginary part)

local ret=1

_arguments -s -S \
  'pair=[y - use odd elements for real part and even ones for imaginary part]:pair:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
