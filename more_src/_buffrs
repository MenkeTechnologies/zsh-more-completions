#compdef buffrs
# Documentation: https://github.com/helsing-ai/buffrs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# buffrs - protobuf/gRPC package manager (Helsing AI). Subcommands from upstream README.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'init:initialize a buffrs setup'
  'new:create a new buffrs package in current directory'
  'add:add dependency to manifest file'
  'remove:remove dependency from manifest file'
  'lint:check rule violations for this package'
  'package:export current package into distributable tgz archive'
  'publish:package and upload this API to the registry'
  'install:install dependencies'
  'uninstall:uninstall dependencies'
  'list:list all protobuf files managed by Buffrs'
  'login:log in to a registry'
  'logout:log out from a registry'
  'lock:lockfile related commands'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'buffrs command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
