#compdef buffrs
# Documentation: https://man.archlinux.org/search?q=buffrs
# Reference accessed: 2026-05-16

# buffrs — protobuf/gRPC package manager for Rust (https://github.com/buffrs/buffrs). Subcommands from `buffrs --help`.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'new:initialize buffrs project'
  'init:add buffrs.toml in cwd'
  'package:manage declared package'
  'add:add dependency from registry'
  'remove:remove dependency'
  'publish:publish package'
  'install:vendor protocol buffers'
  'lint:lint manifests and lockfile'
  'format:format TOML manifests'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'buffrs command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
