#compdef mhc
# _mhc — Mail-based Hybrid Calendar CLI (yoshinari-nomura/mhc)
# upstream: https://github.com/yoshinari-nomura/mhc
# Subcommands from bin/mhc (thor).

_mhc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '--debug[set debug flag]' \
        '--profile[set profiler flag]' \
        '--config=[config file path]:file:_files' \
        '--repository=[MHC top directory]:dir:_files -/' \
        '--calendar=[source calendar]:calendar:' \
        '--category=[pick items only in category]:category:' \
        '--format=[output format]:format:(text mail orgtable emacs icalendar calfw howm json html)' \
        '--search=[search by complex expression]:expr:' \
        '--dry-run[no changes performed]' \
        '--verbose[verbose messages]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'help:describe commands'
                'version:show version'
                'cache:dump cache file'
                'todo:list todo entries'
                'compose:create new draft in editor'
                'configuration:show current configuration'
                'add:add event file to repository'
                'init:initialize MHC repository'
                'recurrences:list recurrence names'
                'stuck_recurrences:list stuck recurrences'
                'scan:scan events in date range'
                'server:run as Emacs backend'
                'show:show article by message id'
                'sync:synchronize DBs via sync channel'
                'validate:validate event file'
                'completions:print completions for shell'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                add|validate) _arguments '1:event file:_files' ;;
                init) _arguments '1:directory:_files -/' ;;
                show) _arguments '1:message-id:' ;;
                scan) _arguments '1:date range:' ;;
                sync) _arguments '1:sync channel:' ;;
            esac
            ;;
    esac
}

_mhc "$@"
