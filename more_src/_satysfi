#compdef satysfi

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-o+[set output file]:file:_files -g "*.pdf"' \
  '--output=[set output file]:file:_files -g "*.pdf"' \
  '-b[page-break mode]' \
  '--bytecomp[use bytecode compiler]' \
  '-t[type-check only]' \
  '--type-check-only[type-check only]' \
  '--full-path[display paths in full]' \
  '--debug-show-bbox[show bounding boxes]' \
  '--debug-show-space[show spaces]' \
  '--text-mode=[output text mode]:mode:(csv)' \
  '-C+[add to SATYSFI_LIB_ROOT]:directory:_directories' \
  '1:input file:_files -g "*.saty"' && ret=0

return ret
