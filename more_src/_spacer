#compdef spacer
# Documentation: https://man.archlinux.org/search?q=spacer
# Reference accessed: 2026-05-16

# Zsh completion for spacer - CLI output spacer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --after)'{-a,--after}'[number of blank lines after each line]:count:' \
  '(-b --before)'{-b,--before}'[number of blank lines before each line]:count:' \
  '*:file:_files' && return 0
