#compdef spacer
# Documentation: https://github.com/samwho/spacer
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# spacer: insert visual spacers in CLI output after periods of inactivity

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --after)'{-a+,--after=}'[duration of inactivity (seconds, floating-point allowed) before inserting a spacer]:seconds:' \
  '*:file:_files' && return 0
