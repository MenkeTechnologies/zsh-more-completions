#compdef authz0

# hahwul/authz0 — `cmd/root.go`

local curcontext="$curcontext" ret=1 expl
_arguments -C   '--debug[verbose authorization trace]'   '1: :->cmd'   '*:: :->rest' && ret=0
case $state in
cmd)
  _wanted commands expl 'authz0 command' compadd -- new scan setCred setRole setUrl version
  ;;
rest)
  _normal && ret=0
  ;;
esac
return ret
