#compdef elprof
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss41.html
# KAPPA: create a radial or azimuthal profile of a two-dimensional image

local ret=1

_arguments -s \
  'ANGLIM=[wedge-sector boundary angles]:anglim' \
  'ANGMAJ=[angle of the ellipse major axis]:angmaj' \
  'ESTIMATOR=[method for estimating output values (Mean or Weighted Mean)]:estimator' \
  'IN=[input NDF with the 2D image]:NDF:_files' \
  'MASK=[output NDF showing the bin of each pixel]:NDF:_files' \
  'MTITLE=[title for the mask NDF]:mtitle' \
  'NBIN=[number of radial or azimuthal bins]:nbin' \
  'OUT=[output 1D profile NDF]:NDF:_files' \
  'RADIAL=[radial vs azimuthal profile]:radial:(TRUE FALSE)' \
  'RATIO=[minor to major axis ratio]:ratio' \
  'RMAX=[outer radius of the annulus in pixels]:rmax' \
  'RMIN=[inner radius of the annulus in pixels]:rmin' \
  'TITLE=[title for the output profile NDF]:title' \
  'WIDTH=[bin width]:width' \
  'XC=[x pixel coordinate of the centre]:xc' \
  'YC=[y pixel coordinate of the centre]:yc' \
  '*:NDF:_files' && ret=0

return ret
