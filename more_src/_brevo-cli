#compdef brevo-cli brevo sendinblue-cli sendinblue
# _brevo-cli — Brevo brevo-cli sendinblue-cli CLI command-line frontend wrapping the Brevo formerly Sendinblue customer engagement Email SMS WhatsApp CRM Marketing Automation platform REST API managing contacts lists campaigns templates SMTP transactional senders attributes folders processes deals tasks meetings (Brevo team, Go); cobra
# upstream: https://www.brevo.com/

_brevo-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'contact:contact operations'
        'list:list operations'
        'campaign:campaign operations'
        'template:template operations'
        'transactional:transactional email'
        'smtp:SMTP operations'
        'sender:sender operations'
        'attribute:attribute operations'
        'folder:folder operations'
        'process:process operations'
        'sms:SMS operations'
        'whatsapp:WhatsApp operations'
        'deal:deal operations'
        'task:task operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brevo-cli subcommand' sub ;;
        args)
            case $words[1] in
                contact|list|campaign|template|transactional|smtp|sender|attribute|folder|process|sms|whatsapp|deal|task) _arguments '1:op:(list get create update delete send pause resume archive)' '*:id:' ;;
            esac
            ;;
    esac
}

_brevo-cli "$@"
