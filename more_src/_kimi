#compdef kimi
# Documentation: https://moonshotai.github.io/kimi-cli/en/reference/kimi-command.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# MoonshotAI kimi-cli (Kimi Code CLI). The installed command is `kimi`
# (not `kimi-cli`), so #compdef targets the real command name.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '--verbose[output detailed runtime information]' \
  '--debug[log debug information to ~/.kimi/logs/kimi.log]' \
  '--agent=[agent name]:name:' \
  '--agent-file=[agent file]:path:_files' \
  '--config=[inline config]:config:' \
  '--config-file=[config file]:path:_files' \
  '(-m --model)'{-m,--model=}'[model name]:name:' \
  '(-w --work-dir)'{-w,--work-dir=}'[working directory]:path:_files -/' \
  '*--add-dir=[additional accessible directory]:path:_files -/' \
  '(-C --continue)'{-C,--continue}'[continue the most recent session]' \
  '(-S --session)'{-S,--session=}'[resume session by ID]::id:' \
  '(-r --resume)'{-r,--resume=}'[resume session by ID]::id:' \
  '(-p --prompt)'{-p,--prompt=}'[run a single prompt non-interactively]:text:' \
  '(-c --command)'{-c,--command=}'[pass a user prompt]:text:' \
  '--max-steps-per-turn=[max steps per turn]:n:' \
  '--max-retries-per-step=[max retries per step]:n:' \
  '--max-ralph-iterations=[max ralph iterations]:n:' \
  '--print[non-interactive print mode]' \
  '--quiet[print mode with text output]' \
  '--acp[run as an ACP agent server]' \
  '--wire[wire mode]' \
  '--input-format=[input format]:format:' \
  '--output-format=[output format]:format:' \
  '--final-message-only[print only the final message]' \
  '--mcp-config-file=[MCP servers config file]:path:_files' \
  '--mcp-config=[inline MCP config JSON]:json:' \
  '(-y --yolo)'{-y,--yolo}'[auto-approve all tool calls]' \
  '--yes[auto-approve all tool calls]' \
  '--auto-approve[auto-approve all tool calls]' \
  '--afk[away-from-keyboard mode]' \
  '--plan[start a new session in plan mode]' \
  '--thinking[enable thinking mode]' \
  '--no-thinking[disable thinking mode]' \
  '*--skills-dir=[append additional skills directory]:path:_files -/' \
  '1:command:(acp mcp)' \
  '*::args:_default' && return 0
