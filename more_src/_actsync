#compdef actsync
# Documentation: man actsync(8)
# Source: InterNetNews/inn backends/actsync.c — synchronize active newsgroup files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[follow newsgroup aliases]' \
    '-b+[bad newsgroup name action]:flags:(0 1 2 12 21)' \
    '-d+[default flag handling]:flags:(0 1 2 12 21)' \
    '-g+[max groups]:max:_default' \
    '-i+[ignore file]:file:_files' \
    '-I+[ignore-file action]:flags:(0 1 2 12 21)' \
    '-k[keep alive period]' \
    '-l+[low water mark check]:flags:(0 1 2 12 21)' \
    '-m[merge mode]' \
    '-n+[output server name]:name:_default' \
    '-o+[output type]:type:(a a1 ak1 ax c k1 K1 x)' \
    '-p+[min host1 change percent]:percent:_default' \
    '-q+[quiet flags]:flags:(0 1 2 12 21)' \
    '-s+[max group description size]:size:_default' \
    '-t+[active line type flags]:flags:(0 1 2 12 21)' \
    '-T[print Total elapsed time]' \
    '-v+[verbose level]:level:_default' \
    '-w+[wait timeout seconds]:secs:_default' \
    '-z+[sleep seconds]:secs:_default' \
    '1::host:_hosts' \
    '2::active_file:_files' \
    && ret=0

return ret
