#compdef impala-cli impala-shell2
# _impala-cli — Apache Impala impala-cli CLI command-line frontend wrapping the Apache Impala massively parallel processing MPP analytic SQL engine for Hadoop providing interactive shell-mode batch-mode supporting connect quit help refresh invalidate-metadata describe show-tables select-into output-format kerberos-ldap-pass authentication (Apache Impala team, Python); custom argparse
# upstream: https://impala.apache.org/

_impala-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q+[query]:str:' \
        '--query=+[query]:str:' \
        '-f+[query file]:file:_files -g "*.sql *.q"' \
        '--query-file=+[file]:file:_files -g "*.sql *.q"' \
        '-i+[host:port]:str:' \
        '--impalad=+[host:port]:str:' \
        '-b+[query option]:str:' \
        '--query_option=+[opt]:str:' \
        '-d+[database]:str:' \
        '--database=+[name]:str:' \
        '-c[ignore comments]' \
        '--ignore_query_failure[ignore query failure]' \
        '-r[refresh after connect]' \
        '--refresh_after_connect[refresh after connect]' \
        '-o+[output file]:file:_files' \
        '--output_file=+[file]:file:_files' \
        '-B[delimited output]' \
        '--delimited[delimited output]' \
        '--output_delimiter=+[char]:str:' \
        '-E[show explain]' \
        '--vertical[vertical output]' \
        '-p[show profile]' \
        '--show_profiles[show profiles]' \
        '-O+[fetch row count]:n:' \
        '--cookie_size=+[N]:n:' \
        '--print_header[print header]' \
        '--no_print_header[no header]' \
        '-k[kerberos auth]' \
        '--kerberos[kerberos auth]' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-l[LDAP auth]' \
        '--ldap[LDAP auth]' \
        '--ldap_password_cmd=+[cmd]:str:' \
        '--auth_creds_ok_in_clear[plain text creds ok]' \
        '--use_kerberos_for_jdbc=+[bool]:s:(true false)' \
        '--ssl[use SSL]' \
        '--ca_cert=+[file]:file:_files' \
        '--config_file=+[file]:file:_files' \
        '--protocol=+[p]:p:(beeswax hs2 hs2-http)' \
        '*::'
}

_impala-cli "$@"
