#compdef spaceranger
# _spaceranger — 10x Genomics spaceranger CLI Visium spatial gene expression pipeline for analyzing slides processing FASTQ reads through TENX-Visium spot-barcode counting capture-area image fluorescence H&E feature linking producing matrix BAM cloupe loupe-browser-ready files (10x Genomics team, Go); custom argparse
# upstream: https://www.10xgenomics.com/support/software/space-ranger

_spaceranger() {
    local -a sub=(
        'count:count gene expression from FASTQ'
        'aggr:aggregate analyses across samples'
        'targeted-compare:targeted vs WTA comparison'
        'targeted-depth:targeted-panel depth analysis'
        'mat2csv:convert matrix to CSV'
        'mkfastq:demultiplex BCL files to FASTQ'
        'mkref:build a custom reference'
        'mkgtf:filter a GTF'
        'sitecheck:check system status'
        'testrun:run a small test pipeline'
        'upload:upload diagnostic info'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spaceranger subcommand' sub ;;
        args)
            case $words[1] in
                count) _arguments \
                    '--id=+[id]:str:' \
                    '--description=+[desc]:str:' \
                    '--transcriptome=+[dir]:dir:_files -/' \
                    '--fastqs=+[dir]:dir:_files -/' \
                    '--probe-set=+[file]:file:_files -g "*.csv"' \
                    '--filter-probes=+[bool]:s:(true false)' \
                    '--sample=+[name]:str:' \
                    '--image=+[file]:file:_files -g "*.jpg *.tif *.tiff *.png *.btf"' \
                    '--darkimage=+[file]:file:_files -g "*.jpg *.tif *.tiff *.png"' \
                    '--cytaimage=+[file]:file:_files -g "*.jpg *.tif *.tiff"' \
                    '--colorizedimage=+[file]:file:_files -g "*.jpg *.tif *.tiff"' \
                    '--unknown-slide=+[t]:t:(visium-1 visium-2 visium-2-large auto)' \
                    '--slide=+[slide id]:str:' \
                    '--area=+[area]:str:' \
                    '--reorient-images=+[bool]:s:(true false)' \
                    '--loupe-alignment=+[file]:file:_files -g "*.json"' \
                    '--include-introns=+[bool]:s:(true false)' \
                    '--chemistry=+[c]:c:(SPATIAL3Pv1 SPATIAL3Pv2 SPATIAL3Pv3 SPATIAL3Pv4 SPATIAL3Pv5 auto)' \
                    '--localmem=+[GB]:n:' \
                    '--localcores=+[N]:n:' \
                    '--jobmode=+[m]:m:(local sge slurm lsf)' \
                    '--no-bam[skip BAM output]' \
                    '--no-libraries[no libraries]' ;;
                mkfastq) _arguments \
                    '--run=+[dir]:dir:_files -/' \
                    '--samplesheet=+[file]:file:_files -g "*.csv"' \
                    '--csv=+[file]:file:_files -g "*.csv"' \
                    '--output-dir=+[dir]:dir:_files -/' ;;
                mkref|mkgtf) _arguments \
                    '--genome=+[name]:str:' \
                    '--fasta=+[file]:file:_files -g "*.fa *.fasta"' \
                    '--genes=+[gtf]:file:_files -g "*.gtf *.gff"' ;;
            esac
            ;;
    esac
}

_spaceranger "$@"
