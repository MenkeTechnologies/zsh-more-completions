#compdef tavily
# Documentation: https://github.com/Lag0/tavily-cli
# Reference accessed: 2026-05-23
# Verified: @syxs/tavily-cli npm bin name tavily.

# Zsh completion for tavily - SYXS Tavily CLI (@syxs/tavily-cli)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[JSON output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'tavily command' \
      'search[web search]' \
      'extract[extract URLs]' \
      'crawl[crawl site]' \
      'map[map URLs]' \
      'research[start research]' \
      'research-status[research status]' \
      'login[authenticate]' \
      'logout[logout]' \
      'status[status]' \
      'doctor[diagnostics]' \
      'init[setup]' \
      'setup[integrations]' \
      'env[write .env]' && ret=0
    ;;
  args)
    case $line[1] in
      (search)
        _arguments '--max-results[max results]:n:' ':query:' && ret=0
        ;;
      (extract|crawl|map)
        _arguments '*:url:_urls' && ret=0
        ;;
    esac
    ;;
esac

return ret
