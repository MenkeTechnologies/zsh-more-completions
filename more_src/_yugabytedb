#compdef yugabytedb yugabyted
# Documentation: https://docs.yugabyte.com/preview/reference/configuration/yugabyted/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# yugabyted: utility for deploying and managing YugabyteDB
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'backup:create backups to cloud or network storage'
  'cert:generate TLS/SSL certificates'
  'collect_logs:generate compressed log files'
  'configure:modify universe settings'
  'configure_read_replica:set up read replica clusters'
  'connect:access the database via ysqlsh or ycqlsh'
  'demo:load Northwind sample dataset'
  'destroy:delete a universe'
  'finalize_upgrade:complete version upgrade process'
  'restore:recover databases from backups'
  'start:launch a YugabyteDB universe'
  'status:check universe health'
  'stop:shut down a universe'
  'upgrade:perform major version upgrades'
  'version:display software version'
  'xcluster:configure asynchronous replication'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'yugabyted command' commands && ret=0 ;;
esac
return ret
