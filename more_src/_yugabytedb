#compdef yugabytedb
# Documentation: https://man.archlinux.org/search?q=yugabytedb
# Reference accessed: 2026-05-16

# yugabytedb: YugabyteDB single-binary launcher
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'start:start the database'
  'stop:stop the database'
  'restart:restart the database'
  'status:show status'
  'destroy:destroy local cluster'
  'version:show version'
  'help:show help'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'yugabytedb command' commands && ret=0 ;;
esac
return ret
