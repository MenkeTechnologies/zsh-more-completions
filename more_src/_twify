#compdef twify
# Documentation: https://github.com/tzsk/twify
# Reference accessed: 2026-05-23
# Verified: upstream README create/init commands and flags.

# Zsh completion for twify - Tailwind CSS scaffolding CLI

local curcontext="$curcontext" state line ret=1
local -a frameworks

frameworks=(
  'next:Next.js'
  'remix:Remix'
  'nuxt:Nuxt 2'
  'nuxt3:Nuxt 3'
  'svelte:SvelteKit'
  'laravel:Laravel Vite'
  'vite:Vite'
  'solid:Solid Start'
  'angular:Angular'
  'react:Create React App'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'twify command' \
      'create[scaffold framework with Tailwind]' \
      'init[add Tailwind to existing project]' && ret=0
    ;;
  args)
    case $line[1] in
      (create)
        _arguments '1:framework:->fw' '2:directory:_directories' && ret=0
        case $state in
          fw) _describe -t frameworks framework frameworks && ret=0 ;;
        esac
        ;;
      (init)
        _arguments \
          '(-k --keep)'{-k,--keep}'[keep existing CSS]' \
          '(-i --installer)'{-i+,--installer=}'[package manager]:pm:(npm yarn pnpm)' \
          '(-p --pretty)'{-p,--pretty}'[install Tailwind Prettier plugin]' && ret=0
        ;;
    esac
    ;;
esac

return ret
