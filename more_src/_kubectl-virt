#compdef kubectl-virt
# Documentation: https://github.com/kubevirt/kubevirt/blob/main/pkg/virtctl/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-virt is virtctl invoked as a kubectl plugin.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v+[number for the log level verbosity]:level:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[if present, the namespace scope for this CLI request]:namespace:' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster:' \
  '--user=[the name of the kubeconfig user to use]:user:' \
  '(-s --server)'{-s+,--server=}'[the address and port of the Kubernetes API server]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '--certificate-authority=[path to a cert file for the certificate authority]:file:_files' \
  '--client-certificate=[path to a client certificate file]:file:_files' \
  '--client-key=[path to a client key file]:file:_files' \
  '--insecure-skip-tls-verify[skip server certificate validation]' \
  '--as=[username to impersonate]:user:' \
  '--as-group=[group to impersonate]:group:' \
  '--request-timeout=[length of time before giving up on a single server request]:timeout:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'console:connect to a console of a virtual machine instance'
      'usbredir:redirect a usb device to a virtual machine instance'
      'vnc:open a vnc connection to a virtual machine instance'
      'scp:scp files from/to a virtual machine'
      'ssh:open an ssh connection to a virtual machine'
      'port-forward:forward local ports to a virtualmachine'
      'start:start a virtual machine'
      'stop:stop a virtual machine'
      'restart:restart a virtual machine'
      'migrate:migrate a virtual machine to another node'
      'migrate-cancel:cancel an active VirtualMachineInstanceMigration'
      'guestosinfo:return information about the OS running on the VMI'
      'userlist:return a list of users logged into the VMI'
      'fslist:return a list of filesystems on the VMI'
      'addvolume:dynamically attach a volume to a running VM'
      'removevolume:dynamically detach a volume from a running VM'
      'expand:expand a virtual machine instance'
      'evacuate-cancel:cancel an active evacuation for VirtualMachine'
      'memory-dump:dump memory of a virtual machine'
      'pause:pause a virtual machine'
      'unpause:unpause a virtual machine'
      'soft-reboot:soft reboot a virtual machine instance'
      'reset:reset a virtual machine instance'
      'expose:expose a virtual machine as a new service'
      'version:print client and server versions'
      'image-upload:upload a VM image to a DataVolume/PersistentVolumeClaim'
      'guestfs:start a shell into the libguestfs pod'
      'vmexport:export a VM volume'
      'create:create manifests of KubeVirt API resources'
      'credentials:manage credentials of a virtual machine'
      'adm:administrative commands'
      'objectgraph:retrieve a graph of objects referenced by a VM/VMI'
      'permitted-devices:list permitted devices for vmis'
      'template:operate on templates'
    )
    _describe -t commands 'kubectl-virt command' commands && ret=0
    ;;
esac

return ret
