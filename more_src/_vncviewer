#compdef vncviewer
# _vncviewer — TigerVNC vncviewer (RFB protocol client; -SecurityTypes selects auth, -passwd reads encrypted password from file, -via tunnels through SSH gateway, -ListenMode reverse-VNC, -FullScreen, -Shared keeps existing clients)
# upstream: https://github.com/TigerVNC/tigervnc
# Flags from tigervnc vncviewer/vncviewer.cxx on tip.

_vncviewer() {
    _arguments \
        '-FullScreen[start fullscreen]' \
        '-Shared[do not disconnect existing clients]' \
        '-ViewOnly[disable input]' \
        '-ListenMode[reverse listen mode]' \
        '-RemoteResize[resize remote screen to match local]' \
        '-AutoSelect[auto-pick encoding/depth]' \
        '-NoCursorShape[disable client-side cursor]' \
        '-AcceptClipboard[allow remote->local clipboard]' \
        '-SendClipboard[allow local->remote clipboard]' \
        '-SecurityTypes+[security types]:types:(None VncAuth Plain TLSNone TLSVnc TLSPlain X509None X509Vnc X509Plain)' \
        '-passwd+[encrypted password file]:file:_files' \
        '-via+[SSH gateway]:user@host:_hosts' \
        '-CompressLevel+[0-9]:level:' \
        '-QualityLevel+[0-9]:level:' \
        '-MenuKey+[menu key]:key:(F1 F2 F3 F4 F5 F6 F7 F8 F9 F10 F11 F12)' \
        '1:host[:display]:_hosts'
}

_vncviewer "$@"
