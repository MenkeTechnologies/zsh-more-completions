#compdef fern

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new Fern workspace'
  'check:validate API definition and Fern configuration'
  'upgrade:update Fern CLI and generators'
  'login:authenticate via GitHub/Google/Postman/SSO'
  'logout:clear authentication credentials'
  'token:generate CI/CD authentication token'
  'export:generate OpenAPI spec from API definition'
  'generate:run generators (SDKs and docs)'
  'add:add a new generator to generators.yml'
  'register:register a workspace'
  'api:API definition utilities'
  'docs:documentation utilities'
  'generator:generator utilities'
  'write-overrides:write OpenAPI customizations file'
  'write-definition:emit Fern definition for an OpenAPI'
  'format:format Fern files'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--api=[target a specific API]:api:' \
  '--log-level=[log level]:level:(silly debug info warn error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'fern command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--organization=[org name]:org:' \
          '--docs[scaffold sample docs]' \
          '--openapi=[OpenAPI source URL/file]:openapi:_files' \
          '--mintlify=[Mintlify mint.json]:file:_files' \
          '--readme=[readme.io site URL]:url:' && ret=0 ;;
      (generate)
        _arguments \
          '--group=[generators group]:group:' \
          '--api=[target API]:api:' \
          '--local[run in local docker]' \
          '--keepDocker[keep docker container]' \
          '--preview[publish a preview]' \
          '--docs[build/publish docs]' \
          '--version=[SDK version to publish]:version:' \
          '--instance=[docs instance URL]:url:' \
          '--log-level=[log level]:level:(silly debug info warn error)' && ret=0 ;;
      (check)
        _arguments \
          '--warnings[include warnings]' \
          '--broken-links[check broken links]' && ret=0 ;;
      (api)
        local -a api_cmds=(
          'update:pull latest OpenAPI spec'
          'enrich:merge examples into OpenAPI'
        )
        _describe -t apicmds 'api command' api_cmds && ret=0 ;;
      (docs)
        local -a docs_cmds=(
          'dev:run local docs preview server'
          'diff:visual diffs between preview and prod'
          'preview:manage preview deployments'
          'md:markdown utilities'
          'theme:theme utilities'
        )
        _describe -t docscmds 'docs command' docs_cmds && ret=0
        case $words[2] in
          (dev)
            _arguments \
              '--port=[port]:port:' \
              '--host=[host]:host:_hosts' \
              '--instance=[instance URL]:url:' && ret=0 ;;
          (preview)
            _arguments '*::pcmd:(list delete)' && ret=0 ;;
          (md)
            _arguments '*::mdcmd:(check)' && ret=0 ;;
          (theme)
            _arguments '*::tcmd:(export upload list)' && ret=0 ;;
        esac ;;
      (generator)
        _arguments '*::gcmd:(upgrade list)' && ret=0 ;;
      (login)
        _arguments \
          '--device-code[use device-code flow]' \
          '--token=[provide token directly]:token:' && ret=0 ;;
    esac ;;
esac

return ret
