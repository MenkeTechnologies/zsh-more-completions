#compdef argc

# Zsh completion for argc (command-line argument parser for bash)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build completions for argc scripts'
      'completions:generate shell completions'
      'eval:evaluate argc script arguments'
      'export:export argc script definitions'
      'mangen:generate man pages'
      'parallel:run commands in parallel'
      'run:run an argc script'
    )
    _describe -t commands 'argc command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (completions)
        _arguments \
          '1:shell:(bash elvish fish nushell powershell xonsh zsh)' && ret=0
        ;;
      (eval)
        _arguments \
          '1:script:_files -g "*.sh"' \
          '*:args' && ret=0
        ;;
      (build|export|mangen)
        _arguments \
          '*:script:_files -g "*.sh"' && ret=0
        ;;
      (parallel)
        _arguments \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
          '*:command' && ret=0
        ;;
      (run)
        _arguments \
          '*:script:_files -g "*.sh"' && ret=0
        ;;
    esac
    ;;
esac

return ret
