#compdef rhvoice
# Multilingual speech synthesizer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-p[voice profile]:profile:' \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '-r[speech rate]:rate:' \
  '-v[volume]:volume:' \
  '-t[pitch]:pitch:' \
  '--list-voices[list available voices]' \
  '--data-path[path to voice data]:dir:_files -/' \
  '--config-path[path to config]:dir:_files -/' \
  && return 0
