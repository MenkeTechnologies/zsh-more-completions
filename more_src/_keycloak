#compdef kc.sh kcadm.sh kcreg.sh

# Zsh completion for Keycloak CLI (kc.sh)

_keycloak() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'start:start the server'
    'start-dev:start the server in development mode'
    'build:create an optimized server image'
    'show-config:print the current server configuration'
    'export:export data from the server'
    'import:import data into the server'
    'bootstrap-admin:bootstrap an admin user'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'keycloak command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        start|start-dev)
          _arguments -s -S \
            '--hostname=[hostname for the server]:hostname:_hosts' \
            '--hostname-strict=[only allow requests with matching hostname]:enabled:(true false)' \
            '--hostname-strict-https=[force HTTPS for hostname]:enabled:(true false)' \
            '--hostname-url=[set the base URL]:URL:' \
            '--hostname-admin=[admin console hostname]:hostname:_hosts' \
            '--hostname-admin-url=[admin console URL]:URL:' \
            '--http-enabled=[enable HTTP listener]:enabled:(true false)' \
            '--http-host=[HTTP listener host]:host:_hosts' \
            '--http-port=[HTTP port]:port:' \
            '--http-relative-path=[relative path]:path:' \
            '--https-port=[HTTPS port]:port:' \
            '--https-certificate-file=[server certificate file]:cert file:_files' \
            '--https-certificate-key-file=[server private key file]:key file:_files' \
            '--https-key-store-file=[keystore file]:keystore:_files' \
            '--https-key-store-password=[keystore password]:password:' \
            '--https-key-store-type=[keystore type]:type:(JKS PKCS12)' \
            '--https-trust-store-file=[truststore file]:truststore:_files' \
            '--https-trust-store-password=[truststore password]:password:' \
            '--db=[database vendor]:vendor:(dev-file dev-mem postgres mysql mariadb mssql oracle)' \
            '--db-url=[database JDBC URL]:JDBC URL:' \
            '--db-url-database=[database name]:database:' \
            '--db-url-host=[database host]:host:_hosts' \
            '--db-url-port=[database port]:port:' \
            '--db-username=[database user]:username:' \
            '--db-password=[database password]:password:' \
            '--db-schema=[database schema]:schema:' \
            '--db-pool-initial-size=[initial pool size]:size:' \
            '--db-pool-min-size=[minimum pool size]:size:' \
            '--db-pool-max-size=[maximum pool size]:size:' \
            '--features=[enable features]:features:' \
            '--features-disabled=[disable features]:features:' \
            '--cache=[cache type]:type:(ispn local)' \
            '--cache-config-file=[cache config file]:file:_files' \
            '--cache-stack=[cache transport stack]:stack:(tcp udp kubernetes ec2 azure google)' \
            '--health-enabled=[enable health endpoint]:enabled:(true false)' \
            '--metrics-enabled=[enable metrics endpoint]:enabled:(true false)' \
            '--log=[log handler]:handler:(console file gelf)' \
            '--log-level=[log level]:level:(ALL DEBUG TRACE INFO WARN ERROR FATAL OFF)' \
            '--log-console-color=[enable color for console log]:enabled:(true false)' \
            '--log-console-format=[console log format]:format:' \
            '--log-console-output=[console output format]:format:(default json)' \
            '--log-file=[log file path]:file:_files' \
            '--log-file-format=[log file format]:format:' \
            '--log-file-output=[log file output]:format:(default json)' \
            '--proxy=[proxy mode]:mode:(edge reencrypt passthrough none)' \
            '--proxy-headers=[proxy headers]:headers:(forwarded xforwarded)' \
            '--spi-theme-static-max-age=[static resource cache max-age]:seconds:' \
            '--spi-theme-cache-themes=[cache themes]:enabled:(true false)' \
            '--optimized[use optimized build]' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '-h[display help]' \
            '--help[display help]' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--db=[database vendor]:vendor:(dev-file dev-mem postgres mysql mariadb mssql oracle)' \
            '--features=[enable features]:features:' \
            '--features-disabled=[disable features]:features:' \
            '--cache=[cache type]:type:(ispn local)' \
            '--cache-config-file=[cache config file]:file:_files' \
            '--health-enabled=[enable health endpoint]:enabled:(true false)' \
            '--metrics-enabled=[enable metrics endpoint]:enabled:(true false)' \
            '-h[display help]' \
            '--help[display help]' \
            && ret=0
          ;;
        export)
          _arguments -s -S \
            '--dir=[export directory]:directory:_files -/' \
            '--file=[export file]:file:_files' \
            '--realm=[realm to export]:realm:' \
            '--users=[user export strategy]:strategy:(skip realm_file same_file different_files)' \
            '--users-per-file=[users per file]:count:' \
            '-h[display help]' \
            && ret=0
          ;;
        import)
          _arguments -s -S \
            '--dir=[import directory]:directory:_files -/' \
            '--file=[import file]:file:_files -g "*.json"' \
            '--override=[override existing data]:enabled:(true false)' \
            '-h[display help]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '-h[display help]' \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_keycloak "$@"
