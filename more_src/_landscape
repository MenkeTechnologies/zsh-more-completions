#compdef landscape
# Documentation: https://github.com/coinbase/terraform-landscape/blob/master/lib/terraform_landscape/cli.rb
# Reformat terraform plan output to be easier to read

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--no-color[disable colorized output]' \
  '--trace[show stack traces on parsing errors]' \
  '*:file:_files' && ret=0

return ret
