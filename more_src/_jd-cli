#compdef jd-cli
# Documentation: https://github.com/intoolswetrust/jd-cli
# jd-cli - command line Java decompiler

local ret=1

_arguments -s -S \
  '(-n --displayLineNumbers)'{-n,--displayLineNumbers}'[display line numbers in decompiled classes]' \
  '(-eu --escapeUnicodeCharacters)'{-eu,--escapeUnicodeCharacters}'[escape unicode characters]' \
  '(-oc --outputConsole)'{-oc,--outputConsole}'[output to system output stream]' \
  '(-od --outputDir)'{-od,--outputDir}'=[flat directory output]:dir:_files -/' \
  '(-ods --outputDirStructured)'{-ods,--outputDirStructured}'=[structured directory output]:dir:_files -/' \
  '(-oz --outputZipFile)'{-oz,--outputZipFile}'=[ZIP output]:zip:_files' \
  '(-p --pattern)'{-p,--pattern}'=[regexp pattern the input file must match]:pattern' \
  '(-g --logLevel)'{-g,--logLevel}'=[set CLI log level]:level' \
  '(-sp --serialProcessing)'{-sp,--serialProcessing}"[don't use parallel processing]" \
  '(-sr --skipResources)'{-sr,--skipResources}'[skip processing resources]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
