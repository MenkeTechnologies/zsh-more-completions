#compdef trafilatura

# Zsh completion for trafilatura - web content extraction

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-u --URL)'{-u,--URL}'[URL to process]:URL:' \
  '(-i --input-file)'{-i,--input-file}'[input file containing URLs]:file:_files' \
  '--inputdir[input directory for files to process]:directory:_files -/' \
  '(-o --output-file)'{-o,--output-file}'[output file]:file:_files' \
  '--outputdir[output directory for results]:directory:_files -/' \
  '--backup-dir[backup directory for downloaded pages]:directory:_files -/' \
  '(-b --blacklist)'{-b,--blacklist}'[file containing blacklisted URLs]:file:_files' \
  '--crawl[crawl a website starting from the given URL]' \
  '--explore[explore the given URL for links]' \
  '--feed[look for feeds at the given URL]:URL:' \
  '--sitemap[look for sitemaps at the given URL]:URL:' \
  '--list[return a list of URLs]' \
  '--parallel[number of parallel threads]:threads:' \
  '--archived[use archived copies of pages]' \
  '--url-filter[only process URLs containing this pattern]:pattern:' \
  '(-f --fast)'{-f,--fast}'[fast extraction without fallback]' \
  '--formatting[keep text formatting (bold, italic, etc.)]' \
  '--links[include links in output]' \
  '--images[include image information in output]' \
  '--no-comments[do not extract comments]' \
  '--no-tables[do not extract tables]' \
  '--no-fallback[do not use fallback extraction methods]' \
  '--precision[favor precision over recall]' \
  '--recall[favor recall over precision]' \
  '--target-language[target language for extraction]:language code:' \
  '--deduplicate[remove duplicate documents]' \
  '--config-file[custom configuration file]:file:_files' \
  '--output-format[output format]:format:(txt csv json xml xmltei)' \
  '--csv[shorthand for --output-format csv]' \
  '--json[shorthand for --output-format json]' \
  '--xml[shorthand for --output-format xml]' \
  '--xmltei[shorthand for --output-format xmltei]' \
  '--validate[validate TEI output]' \
  '--with-metadata[include metadata in output]' \
  '(-v --verbose)'{-v,--verbose}'[increase output verbosity]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show version and exit]' && ret=0

return ret
