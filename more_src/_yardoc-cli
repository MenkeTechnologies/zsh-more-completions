#compdef yardoc-cli
# _yardoc-cli — Loren Segal YARD Ruby documentation tool CLI alias (lsegal team, Ruby); custom argparse
# upstream: https://github.com/lsegal/yard

_yardoc-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--load=+[ruby code to load]:file:_files -g "*.rb"' \
        '-e+[ruby code to load]:file:_files -g "*.rb"' \
        '--plugin=+[plugin name]:str:' \
        '--use-cache[use cache]' \
        '-c[use cache]' \
        '--no-cache[no cache]' \
        '--no-yardopts[no yardopts]' \
        '--no-document[no document]' \
        '-n[no document]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--backtrace[show backtrace]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--db=+[db file]:file:_files -g ".yardoc"' \
        '-b+[db file]:file:_files -g ".yardoc"' \
        '--list[list parsed classes]' \
        '-r+[readme file]:file:_files -g "README*"' \
        '--readme=+[readme file]:file:_files -g "README*"' \
        '--files=+[extra files csv]:str:' \
        '--asset=+[asset]:str:' \
        '--locale=+[locale]:str:' \
        '--po-dir=+[po dir]:dir:_files -/' \
        '--charset=+[charset]:c:(utf-8 iso-8859-1)' \
        '--exclude=+[exclude pattern]:str:' \
        '--no-private[skip private]' \
        '--private[include private]' \
        '--protected[include protected]' \
        '--embed-mixins[embed mixins]' \
        '--embed-mixin=+[embed mixin]:str:' \
        '--no-highlight[no highlight]' \
        '--default-return=+[default return type]:str:' \
        '--hide-void-return[hide void return]' \
        '--query=+[query expression]:str:' \
        '--title=+[title]:str:' \
        '-T+[title]:str:' \
        '--template=+[template]:t:(default html dot)' \
        '-t+[template]:t:(default html dot)' \
        '--template-path=+[template path]:dir:_files -/' \
        '-p+[template path]:dir:_files -/' \
        '--format=+[format]:f:(html dot text rdoc)' \
        '-f+[format]:f:(html dot text rdoc)' \
        '--markup=+[markup]:m:(rdoc markdown textile)' \
        '-m+[markup]:m:(rdoc markdown textile)' \
        '--markup-provider=+[provider]:p:(redcarpet kramdown rdiscount maruku bluefeather rdoc rubygems-markdown)' \
        '-M+[provider]:p:(redcarpet kramdown rdiscount maruku bluefeather rdoc rubygems-markdown)' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--main=+[main page]:str:' \
        '--use-cache-file=+[cache file]:file:_files' \
        '*:files:_files -g "*.{rb,c,erb,builder,rhtml,rake,gemspec,ru}"'
}

_yardoc-cli "$@"
