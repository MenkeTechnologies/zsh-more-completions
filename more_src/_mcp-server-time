# Zsh completion for mcp-server-time - MCP time and timezone server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--local-timezone=[override local timezone]:timezone:' \
  '(-h --help)'{-h,--help}'[show help message and exit]' && ret=0

return ret
