#compdef echidna echidna-test

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--contract=[target contract name]:name:' \
  '--config=[YAML config file]:file:_files -g "*.yaml *.yml"' \
  '--format=[output format]:fmt:(text json none)' \
  '--workers=[parallel workers]:n:' \
  '--seed=[RNG seed]:n:' \
  '--corpus-dir=[corpus directory]:dir:_files -/' \
  '--coverage[enable coverage]' \
  '--no-coverage[disable coverage]' \
  '--test-mode=[test mode]:mode:(property assertion dapptest optimization overflow exploration)' \
  '--test-limit=[max test iterations]:n:' \
  '--seq-len=[max transactions per test]:n:' \
  '--shrink-limit=[max shrink iterations]:n:' \
  '--check-asserts[check assertion failures]' \
  '--multi-abi[use ABI from all contracts]' \
  '--solc-args=[args passed to solc]:args:' \
  '--crytic-args=[args passed to crytic-compile]:args:' \
  '--ignore-compile[skip compilation]' \
  '--deployer=[deployer address]:addr:' \
  '--sender=[sender addresses csv]:list:' \
  '--balance-addr=[initial address balance]:n:' \
  '--balance-contract=[initial contract balance]:n:' \
  '--gas-price=[gas price]:n:' \
  '--gas-limit=[gas limit per call]:n:' \
  '--code-size=[max contract code size]:n:' \
  '--rpc-url=[fork URL for on-chain testing]:url:' \
  '--rpc-block=[fork block number]:n:' \
  '*:contract source:_files -g "*.sol"' && ret=0

return ret
