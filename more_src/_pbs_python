#compdef pbs_python
# Documentation: https://docs.open-mpi.org/en/main/
# PBS: run a Python script with the PBS hook module, for debugging hooks

local ret=1

_arguments -s \
  '--hook[enable the PBS Python module via import pbs and debugging options]' \
  '-e+[mask determining which event types are logged]:log event mask' \
  '-i+[text file populating pbs.event() objects]:event input file:_files' \
  '-L+[directory holding the log file]:log dir:_files -/' \
  '-l+[log file for pbs.logmsg() and pbs.logjobmsg() output]:log file:_files' \
  '-o+[hook execution record of changes made after running the hook]:record:_files' \
  '-r+[resourcedef file specifying a custom resource]:resourcedef file:_files' \
  '-s+[site data file describing server, queues, vnodes, and jobs]:site data file:_files' \
  '--version[print version information and exit]' \
  '*:script:_files -g "*.py"' && ret=0

return ret
