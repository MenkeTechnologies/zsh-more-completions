#compdef epr
# Documentation: https://github.com/wustho/epr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for epr EPUB reader (wustho/epr)

local ret=1

_arguments -s -S \
  '-r[print reading history]' \
  '-d[dump EPUB text to stdout]' \
  '(-h --help)'{-h,--help}'[help]' \
  '*:EPUB file or history query:_files -g "*.epub"' && ret=0

return ret
