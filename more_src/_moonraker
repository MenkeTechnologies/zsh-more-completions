#compdef moonraker moonraker.py

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --datapath)'{-d+,--datapath=}'[Moonraker data directory]:dir:_files -/' \
  '(-c --configfile)'{-c+,--configfile=}'[Moonraker configuration file]:file:_files -g "*.conf"' \
  '(-l --logfile)'{-l+,--logfile=}'[Moonraker log file]:file:_files' \
  '(-n --nologfile)'{-n,--nologfile}'[disable log file]' \
  '(-u --unixsocket)'{-u+,--unixsocket=}'[Unix socket address]:file:_files' \
  '-v[verbose logging]' \
  '*::passthrough:' && ret=0

return ret
