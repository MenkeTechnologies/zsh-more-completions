#compdef go-task

# Zsh completion for go-task (taskfile.dev)

_go-task() {
    local curcontext="$curcontext" state line ret=1

    _go-task_complete_tasks() {
        local -a tasks
        if command -v jq &>/dev/null && tasks=(${(f)"$(task --list-all --json 2>/dev/null | jq -r '.tasks[]?.name // empty' 2>/dev/null)"}); then
            _describe -t tasks 'task' tasks && return
        elif [[ -f Taskfile.yml || -f Taskfile.yaml || -f taskfile.yml || -f taskfile.yaml ]]; then
            local tf
            for tf in Taskfile.yml Taskfile.yaml taskfile.yml taskfile.yaml; do
                [[ -f $tf ]] && break
            done
            tasks=(${(f)"$(sed -n '/^tasks:/,$ { /^  [a-zA-Z_-]*:/{ s/^  \([a-zA-Z_][a-zA-Z0-9_-]*\):.*/\1/; p; } }' "$tf" 2>/dev/null)"})
            [[ -n "$tasks" ]] && _describe -t tasks 'task' tasks && return
        fi
    }

    _arguments -s -S \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-l --list)'{-l,--list}'[list tasks with description]' \
        '--list-all[list all tasks]' \
        '--sort=[change the order of tasks when listed]:order:(default alphanumeric none)' \
        '--json[output list as JSON]' \
        '(-t --taskfile)'{-t,--taskfile}'=[choose which Taskfile to run]:file:_files' \
        '(-d --dir)'{-d,--dir}'=[set directory of execution]:directory:_directories' \
        '--dry[dry run mode]' \
        '--summary[show task summary]' \
        '(-f --force)'{-f,--force}'[force execution even when the task is up-to-date]' \
        '(-w --watch)'{-w,--watch}'[enable watch of the given task]' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
        '(-s --silent)'{-s,--silent}'[disable echoing]' \
        '(-y --yes)'{-y,--yes}'[assume yes on all prompts]' \
        '(-p --parallel)'{-p,--parallel}'[execute tasks in parallel]' \
        '(-C --concurrency)'{-C,--concurrency}'=[limit number of concurrent tasks]:number:' \
        '(-o --output)'{-o,--output}'=[set output style]:style:(interleaved group prefixed)' \
        '--color[enable colored output]' \
        '*:task:_go-task_complete_tasks' && ret=0

    return ret
}

_go-task "$@"
