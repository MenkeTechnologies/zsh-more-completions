#compdef arosics
# Documentation: https://danschef.git-pages.gfz-potsdam.de/arosics/doc/cli_reference.html
# AROSICS automatic and robust open-source image co-registration of satellite data

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version information]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

# shared general options for both global and local subcommands
local -a general_opts
general_opts=(
  '-o[target path of the co-registered image]:path:_files'
  '-fmt_out[raster file format for output]:format'
  '-br[band of reference image to be used for matching]:band'
  '-bs[band of shift image to be used for matching]:band'
  '-ws[custom matching window size (X Y)]:xsize'
  '-max_iter[maximum number of iterations for matching]:iterations'
  '-max_shift[maximum shift distance in reference image pixels]:pixels'
  '-rsp_alg_deshift[resampling algorithm for shift correction (0-11)]:alg'
  '-rsp_alg_calc[resampling algorithm during matching (0-11)]:alg'
  '-cor0[map coordinates of data corners within reference image]:coords'
  '-cor1[map coordinates of data corners within image to be shifted]:coords'
  '-calc_cor[calculate true positions of the dataset corners]:flag:(0 1)'
  '-nodata[no-data values for reference and target image]:nodata'
  '-bin_ws[binary search for the optimal window size]:flag'
  '-quadratic_win[force a quadratic matching window]:flag'
  '-mask_ref[path to a mask for the reference image]:file:_files'
  '-mask_tgt[path to a mask for the target image]:file:_files'
  '-mp[enable multiprocessing]:flag:(0 1)'
  '-progress[show progress bars]:flag:(0 1)'
  '-v[verbose mode]:flag:(0 1)'
  '-q[quiet mode]:flag:(0 1)'
  '-ignore_errors[continue batch processing if an image fails]:flag:(0 1)'
  '1:reference image:_files'
  '2:target image:_files'
)

case $state in
  cmds)
    local -a cmds
    cmds=(
      'global:detect and correct global X/Y shifts'
      'local:detect and correct local shifts via a tie point grid'
    )
    _describe -t commands 'arosics command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      global)
        _arguments -s \
          $general_opts \
          '-wp[custom matching window position as map values (X Y)]:position' \
          '-align_grids[align the input coordinate grid to the reference]:flag:(0 1)' \
          '-match_gsd[match the output pixel size to the reference]:flag:(0 1)' \
          '-out_gsd[output pixel size (xgsd ygsd)]:gsd' \
          '-vo[output directory for outputs of verbose mode]:flag:(0 1)' && ret=0
        ;;
      local)
        _arguments -s \
          $general_opts \
          '-max_points[maximum number of points used for shift detection]:points' \
          '-projectDir[project directory]:dir:_files -/' \
          '-tieP_filter_level[level of tie point filtering (0-3)]:level:(0 1 2 3)' \
          '-tieP_random_state[random state for tie point sampling]:state' \
          '-min_reliability[minimum reliability threshold for tie points]:value' \
          '-rs_max_outlier[maximum RANSAC outlier percentage]:percent' \
          '-rs_tolerance[RANSAC tolerance in pixels]:pixels' && ret=0
        ;;
    esac
    ;;
esac

return ret
