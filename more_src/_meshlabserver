#compdef meshlabserver
# Documentation: https://man.archlinux.org/search?q=meshlabserver
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-d+[dump filter list to file]:file:_files' \
  '-l+[log filters to file]:file:_files' \
  '-p+[load MeshLab project file]:file:_files -g "*.mlp"' \
  '-w+[save output project file]:file:_files' \
  '-x[overwrite original 3D model files]' \
  '*-i+[input mesh file]:file:_files -g "*.ply *.stl *.obj *.off *.dae *.x3d *.wrl *.3ds *.gts *.tri *.asc *.ptx *.pts *.xyz *.glb *.gltf"' \
  '*-o+[output mesh file]:file:_files' \
  '-m+[mesh attributes csv]:attrs:(vc vf vq vn vt fc ff fq fn wc wn wt)' \
  '-s+[filter script (.mlx)]:file:_files -g "*.mlx"' && ret=0

return ret
