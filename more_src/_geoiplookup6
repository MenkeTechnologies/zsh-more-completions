#compdef geoiplookup6
# Documentation: geoiplookup6 -h
# Source: look up country for an IPv6 address using a GeoIP database.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-d+[custom GeoIP database directory]:dir:_files -/' \
    '-f+[custom GeoIP database file]:file:_files' \
    '-v[verbose]' \
    '*:address or hostname:_hosts' \
    && ret=0

return ret
