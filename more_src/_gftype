#compdef gftype
# Documentation: gftype --help (TeX Live 2026)
# Source: verify + translate a Metafont Generic-Font (GF) bitmap font to human-readable form.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-images[show characters as pixels]' \
    '-mnemonics[translate all GF commands]' \
    '1:gf font:_files -g "*gf"' \
    && ret=0

return ret
