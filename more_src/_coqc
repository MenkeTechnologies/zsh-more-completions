#compdef coqc

# Zsh completion for coqc - Coq compiler

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[skip loading rcfile]' \
  '-R[recursively map physical path to logical]:physical path:_files -/ logical path' \
  '-Q[map physical path to logical (non-recursive)]:physical path:_files -/ logical path' \
  '-I[add physical path to OCaml include path]:directory:_files -/' \
  '-top[set the toplevel module name]:name' \
  '-topfile[set the toplevel module name from file]:file:_files -g "*.v"' \
  '-noinit[do not load the Init library]' \
  '-nois[do not load the initial state]' \
  '-indices-matter[levels of indices contribute to level of inductive types]' \
  '-impredicative-set[set impredicativity of Set]' \
  '-type-in-type[collapse the universe hierarchy]' \
  '-allow-rewrite-rules[allow rewrite rules]' \
  '-w[configure display of warnings]:warning flags' \
  '-color=[configure use of color]:mode:(on off auto)' \
  '-vos[process file with proofs skipped]' \
  '-vok[process file checking .vos dependencies]' \
  '-native-compiler=[enable native compiler]:option:(yes no ondemand)' \
  '-output-directory=[set output directory for compiled files]:directory:_files -/' \
  '-o[set output file]:file:_files' \
  '-time[display compilation time for each file]' \
  '-profile-ltac[display profiling information for tactics]' \
  '-verbose[display the name of each compiled file]' \
  '-batch[batch mode, exit on first error]' \
  '-boot[boot mode for Coq developers]' \
  '-set[set Coq flag or option]:setting' \
  '-unset[unset Coq flag]:setting' \
  '-bytecode-compiler=[enable bytecode compiler]:option:(yes no)' \
  '-rifrom[require import from specific path]:logical path module' \
  '-rfrom[require from specific path]:logical path module' \
  '-async-proofs=[enable asynchronous proof processing]:mode:(on off lazy)' \
  '-async-proofs-j=[number of workers for async proofs]:workers' \
  '*:Coq source file:_files -g "*.v"'
