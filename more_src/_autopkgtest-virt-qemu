#compdef autopkgtest-virt-qemu
# _autopkgtest-virt-qemu — QEMU virtualisation backend for autopkgtest (Debian/autopkgtest)
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-qemu(1) man page.

_autopkgtest-virt-qemu() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-u --user)'{-u+,--user=}'[user for non-root tests]:user:_users' \
        '(-p --password)'{-p+,--password=}'[password for login on serial port]:password:' \
        '--qemu-architecture=[QEMU architecture]:arch:(x86_64 i386 arm aarch64 ppc64le riscv64 s390x mips mipsel)' \
        '--dpkg-architecture=[dpkg architecture]:arch:(amd64 i386 armhf arm64 ppc64el riscv64 s390x)' \
        '(-q --qemu-command)'{-q+,--qemu-command=}'[QEMU command to run]:command:_command_names -e' \
        '(-o --overlay-dir)'{-o+,--overlay-dir=}'[overlay image dir (default /tmp)]:dir:_files -/' \
        '(-c --cpus)'{-c+,--cpus=}'[number of virtual CPUs (default 1)]:n:' \
        '--ram-size=[VM RAM in MiB (default 2048)]:mib:' \
        '*--shared-dir=[share host dir with guest (src=...,dst=...[,rw])]:spec:' \
        '--timeout-reboot=[reboot wait timeout in seconds]:seconds:' \
        '--show-boot[show serial console boot messages]' \
        '*:VM image:_files -g "*.qcow2"'
}

_autopkgtest-virt-qemu "$@"
