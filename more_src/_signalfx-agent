#compdef signalfx-agent
# SignalFx Smart Agent for collecting metrics, traces and events

local ret=1

_arguments -s -S \
  '-config=[use the given configuration file]:file:_files -g "*.(yaml|yml)"' \
  '-debug[set the log level to debug]' \
  '-version[print the agent version information and quit]' \
  '*:command:(status)' && ret=0

return ret
