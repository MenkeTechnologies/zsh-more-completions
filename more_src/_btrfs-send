#compdef btrfs-send

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-e[if sending multiple subvols, use new end command]' \
  '-p[send an incremental stream from parent snapshot]:parent snapshot:_directories' \
  '*-c[use this snapshot as clone source]:clone source:_directories' \
  '-f[output to file]:output file:_files' \
  '--no-data[send in NO_FILE_DATA mode]' \
  '--proto[send stream protocol version]:protocol:(0 1 2)' \
  '--compressed-data[send compressed data]' \
  {-q,--quiet}'[quiet mode]' \
  {-v,--verbose}'[verbose output]' \
  ':snapshot:_directories' && ret=0

return ret
