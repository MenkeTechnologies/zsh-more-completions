#compdef gfaffix
# _gfaffix — gfaffix GFAffix CLI tool collapsing shared-prefix and shared-suffix sub-paths in a GFA pangenome graph identical multi-edge stretches between branches into single node sequences reducing redundancy in graph-based genomic representations vg odgi pggb gfatools pangenome workflow component (gfaffix team, Rust); clap
# upstream: https://github.com/marschall-lab/GFAffix

_gfaffix() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output GFA]:file:_files -g "*.gfa"' \
        '--output_refined=+[file]:file:_files -g "*.gfa"' \
        '-t+[output transformation]:file:_files' \
        '--output_transformation=+[file]:file:_files' \
        '-c+[output collapsed]:file:_files -g "*.fa"' \
        '--output_collapsed=+[file]:file:_files -g "*.fa"' \
        '-r+[output node ranges]:file:_files' \
        '--output_node_ranges=+[file]:file:_files' \
        '-a+[output affixes]:file:_files' \
        '--output_affixes=+[file]:file:_files' \
        '--check[validate input GFA]' \
        '--threads=+[N]:n:' \
        '--dont_collapse=+[pattern]:str:' \
        '-x+[exclude paths]:str:' \
        '*:gfa file:_files -g "*.gfa *.gfa.gz"'
}

_gfaffix "$@"
