#compdef pt-summary
# Documentation: https://man.archlinux.org/search?q=pt-summary
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:config file:_files' \
  '--read-samples=[read saved samples]:directory:_directories' \
  '--save-samples=[save samples to directory]:directory:_directories' \
  '--sleep=[sleep time for sampling]:seconds:' && ret=0

return ret
