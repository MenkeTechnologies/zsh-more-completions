#compdef pslSpliceJunctions
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: extract splice junctions from a PSL file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  ':psl file:_files' \
  ':genome 2bit:_files -g "*.2bit"' \
  ':junctions tsv:_files' && ret=0

return ret
