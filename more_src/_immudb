#compdef immudb immuclient immuadmin

# Zsh completion for immudb - immutable database

local curcontext="$curcontext" state line ret=1

case ${words[1]} in
  immudb)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--dir=[data directory]:directory:_directories' \
      '-d+[data directory]:directory:_directories' \
      '--address=[bind address]:address' \
      '-a+[bind address]:address' \
      '--port=[port to listen on]:port' \
      '-p+[port to listen on]:port' \
      '--metrics-port=[metrics port]:port' \
      '--web-server[enable web console]' \
      '--web-server-port=[web console port]:port' \
      '--pgsql-server[enable PostgreSQL protocol]' \
      '--pgsql-server-port=[PostgreSQL port]:port' \
      '--auth=[enable authentication]:bool:(true false)' \
      '--admin-password=[admin password]:password' \
      '--maintenance[maintenance mode]' \
      '--signingKey=[signing key]:key:_files' \
      '--synced[synced mode]' \
      '--replication-enabled[enable replication]' \
      '--replication-master-address=[master address]:address' \
      '--replication-master-port=[master port]:port' \
      '--replication-follower-username=[follower username]:user' \
      '--replication-follower-password=[follower password]:password' \
      '--logfile=[log file]:file:_files' \
      '--logformat=[log format]:format:(text json)' \
      '--detached[run in background]' && ret=0
    ;;
  immuclient)
    _arguments -s -S -C \
      '(- *)'{-h,--help}'[show help]' \
      '--immudb-address=[server address]:address' \
      '-a+[server address]:address' \
      '--immudb-port=[server port]:port' \
      '-p+[server port]:port' \
      '--username=[username]:user' \
      '--password=[password]:password' \
      '--database=[database name]:database' \
      '--dir=[state directory]:directory:_directories' \
      '--tokenfile=[token file]:file:_files' \
      '--mtls[enable mutual TLS]' \
      '--certificate=[client certificate]:cert:_files' \
      '--pkey=[client private key]:key:_files' \
      '--clientcas=[client CA certificate]:cert:_files' \
      '1:command:(login logout use get set safeset safeget count scan history zadd zscan txbyid verifiedtxbyid)' && ret=0
    ;;
  immuadmin)
    _arguments -s -S -C \
      '(- *)'{-h,--help}'[show help]' \
      '--immudb-address=[server address]:address' \
      '-a+[server address]:address' \
      '--immudb-port=[server port]:port' \
      '-p+[server port]:port' \
      '1:command:(user database dump stats status hot-backup)' && ret=0
    ;;
esac

return ret
