#compdef yosys-witness
# Documentation: https://man.archlinux.org/search?q=yosys-witness
# Reference accessed: 2026-05-16

# Yosys yosys-witness: viewer/manipulator for AIGER witnesses and YW
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  'display[display witness]' \
  'yw2aiw[convert YW to AIGER witness]' \
  'aiw2yw[convert AIGER witness to YW]' \
  'yw2vcd[convert YW to VCD]' \
  '-o[output file]:file:_files' \
  '*:witness file:_files -g "*.(yw|aiw|vcd)"' && ret=0
return ret
