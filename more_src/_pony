#compdef ponyc

# Zsh completion for ponyc - Pony programming language compiler

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-d,--debug}'[compile with debug information]' \
  '*'{-D,--define}'[define a compile-time name]:name' \
  '--strip[strip debug symbols from output]' \
  '*'{-p,--path}'[add a search path]:path:_directories' \
  {-o,--output}'[set output directory]:directory:_directories' \
  '--library[generate a library instead of an executable]' \
  '--runtimebc[compile with the LLVM bitcode runtime]' \
  '--pic[generate position independent code]' \
  '--nopic[do not generate position independent code]' \
  '--docs[generate documentation]' \
  '--docs-public[generate documentation for public types only]' \
  '--pass=[restrict compilation to a specific pass]:pass:(parse syntax sugar scope import name flatten traits docs verify finaliser serialise reach paint ir bitcode asm obj link all)' \
  '--ast[output the AST]' \
  '--trace[enable runtime tracing]' \
  '--width=[target output width in columns]:columns' \
  '--immerr[report errors immediately]' \
  '--verify[verify LLVM IR]' \
  '--filenames[show source file names in errors]' \
  '--checktree[verify the AST tree]' \
  '--extfun[allow external function calls in the default runtime]' \
  '--stats[print compilation statistics]' \
  '--link-arch=[target architecture for linking]:target' \
  '--linker=[custom linker to use]:linker path:_files' \
  '--link-ldcmd=[linker command to use]:command' \
  '--verbose=[verbosity level]:level:(0 1 2 3 4)' \
  '--cpu=[target CPU]:cpu' \
  '--features=[target CPU features]:features' \
  '--triple=[target triple]:triple' \
  '--abi=[function calling convention]:abi:(default native c cdecl stdcall fastcall thiscall)' \
  '--bin-name=[output binary name]:name' \
  '1:source directory:_directories' && ret=0

return ret
