#compdef 3dcalc
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dcalc.html
# AFNI voxel-by-voxel arithmetic on datasets

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '*-a[read dataset and name its values a..z in expr]:dataset:_files' \
  '-expr[apply expression in quotes to inputs]:expression' \
  '-prefix[output dataset prefix]:prefix' \
  '-session[output session directory]:dir:_files -/' \
  '-datum[coerce output type]:type:(byte short float)' \
  '-float[output in float format]' \
  '-short[output in short format]' \
  '-byte[output in byte format]' \
  '-fscale[force scaling to max integer range]' \
  '-gscale[uniform scaling across sub-bricks]' \
  '-nscale[skip scaling]' \
  '-dt[set time step TR]:tstep' \
  '-TR[set time step TR]:tstep' \
  '-taxis[force time axis with N points]:N' \
  '-verbose[show progress]' \
  '-usetemp[use temp file for intermediates]' \
  '-sort[sort output bricks increasing]' \
  '-SORT[sort output bricks decreasing]' \
  '-isola[remove isolated non-zero voxels]' \
  '-dicom[use DICOM RAI coordinate order]' \
  '-RAI[use RAI coordinate order]' \
  '-SPM[use SPM LPI coordinate order]' \
  '-LPI[use LPI coordinate order]' \
  '-cx2r[complex-to-real method]:method:(REAL IMAG ABS PHASE)' \
  '-rgbfac[collapse RGB with A B C factors]:A:_guard "[0-9.-]#" A' \
  '-dsSTOP[stop at out-of-bounds differential subscript]' \
  '-dsWRAP[wrap out-of-bounds differential subscript]' \
  '-dsZERO[zero out-of-bounds differential subscript]' \
  '*:dataset:_files' && ret=0

return ret
