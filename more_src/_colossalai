#compdef colossalai
# Documentation: https://colossalai.org/docs/basics/launch_colossalai/
# Colossal-AI CLI for launching distributed training jobs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--nproc_per_node=[number of GPUs per node]:n:' \
  '--master_port=[port for the master node]:port:' \
  '--master_addr=[hostname or IP of the master node]:addr:' \
  '--host=[comma separated nodes for multi-node training]:hosts:' \
  '--hostfile=[file listing available node names]:file:_files' \
  '--include=[hosts to include from the hostfile]:hosts:' \
  '--exclude=[hosts to exclude from execution]:hosts:' \
  '--ssh-port=[SSH port shared across nodes]:port:' \
  '1:command:(run check)' \
  '*::arg:_files' && ret=0

return ret
