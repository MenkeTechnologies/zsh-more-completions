#compdef kas
# Documentation: https://kas.readthedocs.io/
# Yocto/BitBake setup tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--version[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build the project'
      'checkout:checkout repos and set up build dir'
      'dump:dump flattened config to stdout'
      'for-all-repos:run command in each repo directory'
      'menu:interactive project configuration'
      'shell:start a shell in the build environment'
    )
    _describe -t commands 'kas command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          '--skip[skip build steps]:steps:' \
          '--target[select target to build]:target:' \
          '--task[select task to run]:task:(build compile configure clean cleansstate fetch populate_sysroot)' \
          '-c[select task to run]:task:(build compile configure clean cleansstate fetch populate_sysroot)' \
          '--cmd[bitbake command]:command:' \
          '--update[update repos]' \
          '--force-checkout[force checkout]' \
          '(-j --jobs)'{-j,--jobs}'[number of build threads]:threads:' \
          '(-t --target)'{-t,--target}'[target recipe]:target:' \
          '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables]' \
          '*:config file:_files -g "*.y(a|)ml"' && ret=0
        ;;
      checkout)
        _arguments -s -S \
          '--update[update repos]' \
          '--force-checkout[force checkout]' \
          '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables]' \
          '*:config file:_files -g "*.y(a|)ml"' && ret=0
        ;;
      dump)
        _arguments -s -S \
          '--resolve-refs[resolve refs to SHAs]' \
          '--format[output format]:format:(json yaml)' \
          '--indent[indentation level]:indent:' \
          '--lock[create lock file]' \
          '--inplace[update config in place]' \
          '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables]' \
          '*:config file:_files -g "*.y(a|)ml"' && ret=0
        ;;
      for-all-repos)
        _arguments -s -S \
          '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables]' \
          ':config file:_files -g "*.y(a|)ml"' \
          ':command:' && ret=0
        ;;
      menu)
        _arguments -s -S \
          '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables]' \
          '*:config file:_files -g "*.y(a|)ml"' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '--update[update repos]' \
          '--force-checkout[force checkout]' \
          '-c[command to run in shell]:command:' \
          '--cmd[command to run in shell]:command:' \
          '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables]' \
          '*:config file:_files -g "*.y(a|)ml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
