#compdef karn

# Zsh completion for karn (git identity manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'list:list configured identities'
      'use:set identity for current repo'
      'add:add a new identity'
      'edit:edit an existing identity'
      'remove:remove an identity'
      'help:show help for a subcommand'
    )
    _describe -t commands 'karn subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      use|edit|remove)
        _message 'identity alias' && ret=0
        ;;
      add)
        _arguments \
          '--alias[identity alias]:alias' \
          '--name[git user name]:name' \
          '--email[git user email]:email' \
          '--ssh-key[SSH key path]:key file:_files' \
          '--gpg-key[GPG key ID]:key ID' && ret=0
        ;;
    esac
    ;;
esac

return ret
