#compdef rotsmoother
# GMT supplements/spotter — compute mean rotations from sets of total reconstruction rotations

local ret=1

_arguments -s \
  '-A[use opening angles as proxy for time]' \
  '-C[compute covariance matrix per mean rotation]' \
  '-N[ensure all poles in northern hemisphere]' \
  '-S[ensure all poles in southern hemisphere]' \
  '-T+[desired groups of ages for reconstruction]:ages:_default' \
  '-W[expect weights in last column]' \
  '-Z[report negative opening angles]' \
  '*-V[verbose (stackable)]' \
  '*:input rotations:_files' \
  && ret=0

return ret
