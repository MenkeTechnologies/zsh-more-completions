#compdef CollectSVEvidence
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/13832690555035-CollectSVEvidence-BETA
# Gathers paired-end, split read, and site depth evidence for structural variant calling

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[BAM/CRAM read file]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-PE --pe-file)'{-PE,--pe-file}'=[output file for paired end evidence]:file:_files' \
  '(-SR --sr-file)'{-SR,--sr-file}'=[output file for split read evidence]:file:_files' \
  '(-SD --sd-file)'{-SD,--sd-file}'=[output file for site depth counts]:file:_files' \
  '(-F --site-depth-locs-vcf)'{-F,--site-depth-locs-vcf}'=[input VCF of SNPs marking loci for site depth]:vcf:_files' \
  '(-RD --depth-evidence-file)'{-RD,--depth-evidence-file}'=[output file for depth evidence]:file:_files' \
  '(-DS --depth-summary-file)'{-DS,--depth-summary-file}'=[output file for depth evidence summary statistics]:file:_files' \
  '(-DI --depth-evidence-intervals)'{-DI,--depth-evidence-intervals}'=[input feature file of depth evidence intervals]:file:_files' \
  '--depth-evidence-min-mapq=[min mapping quality for depth evidence read]:q:' \
  '--site-depth-min-mapq=[min mapping quality for site depth read]:q:' \
  '--site-depth-min-baseq=[min base call quality for site depth SNP]:q:' \
  '--sample-name=[sample name]:name:' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--compression-level=[output compression level]:n:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
