#compdef bap-mc
# Documentation: https://github.com/BinaryAnalysisPlatform/bap
# BAP machine code disassembler for raw instruction encodings

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--show-insn=[display assembly instructions]:mode:(asm adt sexp)' \
  '--show-bil[show the BIL intermediate representation]' \
  '--show-asm[display assembly syntax]' \
  '--show-bytes[show instruction bytes]' \
  '--arch=[specify target architecture]:arch' \
  '--addr=[set memory address]:addr' \
  '--loader=[specify file format parser]:loader' \
  '*:instruction:_files' && ret=0

return ret
