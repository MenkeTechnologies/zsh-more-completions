#compdef arecordmidi
# Documentation: https://manpages.debian.org/arecordmidi.1
# Source: alsa-utils — record incoming MIDI events to a Standard MIDI File (.mid).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print options]' \
    '(- *)'{-V,--version}'[print version]' \
    '(- *)'{-l,--list}'[list possible input ports]' \
    '(-p --port)'{-p+,--port=}'[sequencer port(s) "client:port,..."]:port:' \
    '(-b --bpm)'{-b+,--bpm=}'[tempo in beats per minute]:bpm:' \
    '(-f --fps)'{-f+,--fps=}'[SMPTE resolution (frames per second)]:fps:(24 25 29.97 30)' \
    '(-t --ticks)'{-t+,--ticks=}'[timestamp resolution (ticks)]:ticks:' \
    '(-s --split-channels)'{-s,--split-channels}'[write each MIDI channel to a separate track]' \
    '(-m --metronome)'{-m+,--metronome=}'[play metronome on specified port "client:port"]:port:' \
    '(-i --timesig)'{-i+,--timesig=}'[time signature "numerator:denominator"]:sig:' \
    '*:output .mid file:_files' \
    && ret=0

return ret
