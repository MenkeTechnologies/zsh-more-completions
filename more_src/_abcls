#compdef abcls
# Documentation: https://github.com/alembic/alembic/blob/master/bin/AbcLs/AbcLs.cpp
# Alembic: list the objects and properties of an Alembic archive

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[include property listings]' \
  '-f[show time sampling as 24 fps]' \
  '-l[long listing format]' \
  '-m[show archive metadata]' \
  '-r[list entries recursively]' \
  '-s[show the size of a data property sample]' \
  '-t[show time sampling information]' \
  '-v[show 0th value for all properties]' \
  '*:alembic archive:_files -g "*.abc"' && ret=0

return ret
