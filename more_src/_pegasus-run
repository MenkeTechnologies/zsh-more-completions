#compdef pegasus-run
# Documentation: https://pegasus.isi.edu/documentation/manpages/pegasus-run.html
# pegasus-run - execute a workflow that has been planned using pegasus-plan

local ret=1

_arguments -s -S \
  '*-D[override properties, must be first on the command line]:property=value' \
  '(-c --conf)'{-c,--conf}'=[supply an alternate properties file]:file:_files' \
  '(-d --debug)'{-d,--debug}'=[set debug verbosity level (default 0)]:level' \
  '(-v --verbose)'{-v,--verbose}'[raise debug level by 1 per invocation]' \
  '--grid[enable grid environment checks]' \
  '--nogrid[disable grid environment checks]' \
  '*:rundir:_files -/' && ret=0

return ret
