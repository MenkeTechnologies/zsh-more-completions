#compdef genl-family
# Documentation: https://man.archlinux.org/man/genl.8.en
# genl - generic netlink controller interaction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'genl command' \
      'ctrl[generic netlink controller object]' \
      'list[show registered netlink users]' \
      'monitor[listen for generic netlink notifications]' \
      'get[query controller for a user]' 'help[show help]' \
      'name[query by name]' 'id[query by identifier]' && ret=0
    ;;
esac

return ret
