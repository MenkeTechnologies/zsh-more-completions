#compdef JLinkRemoteServer
# Documentation: https://kb.segger.com/J-Link_Remote_Server
# SEGGER J-Link Remote Server - make a J-Link accessible over IP

local ret=1

_arguments -s -S \
  '-Port[listening port of J-Link Remote Server]:port' \
  '-UseTunnel[use a tunneled connection]' \
  '-TunnelServer[tunnel server to connect to]:host' \
  '-TunnelBySN[identify at tunnel server via J-Link S/N]' \
  '-TunnelByName[identify at tunnel server via custom name]:name' \
  '-TunnelPW[protect the connection with a password]:password' \
  '-TunnelPort[connect to a tunnel server on a specific port]:port' \
  '-TunnelEncrypt[encrypt transferred data of a tunneled connection]' \
  '-USB[connect to a probe over USB]:serial/nickname' \
  '-IP[connect to a probe over TCP/IP]:host' && ret=0

return ret
