#compdef anim_diff
# _anim_diff — compare animated GIF/WebP image files (webmproject/libwebp)
# upstream: https://github.com/webmproject/libwebp
# Flags from examples/anim_diff.c (custom strcmp dispatch).

_anim_diff() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-dump_frames+[dump frame differences to directory]:dir:_files -/' \
        '-min_psnr+[minimum required PSNR]:float:' \
        '-raw_comparison[raw RGBA comparison (no canvas)]' \
        '-max_diff+[max allowed per-pixel difference]:n:' \
        '1:image:_files -g "*.(gif|webp)"' \
        '2:image:_files -g "*.(gif|webp)"'
}

_anim_diff "$@"
