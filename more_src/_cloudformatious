#compdef cloudformatious
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall cloudformatious-cli@0.6.1
# Probed via: completions zsh
# Repository: https://github.com/connec/cloudformatious-cli

autoload -U is-at-least

_cloudformatious() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'--region=[The region to use. Overrides config/env settings]:REGION: ' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_cloudformatious_commands" \
"*::: :->cloudformatious" \
&& ret=0
    case $state in
    (cloudformatious)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cloudformatious-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(apply-stack)
_arguments "${_arguments_options[@]}" \
'*--capabilities=[Capabilities to explicitly acknowledge]:CAPABILITIES: ' \
'--client-request-token=[A unique identifier for this \`apply_stack\` operation]:CLIENT_REQUEST_TOKEN: ' \
'*--notification-arns=[The Simple Notification Service (SNS) topic ARNs to publish stack related events]:NOTIFICATION_ARNS: ' \
'--package-bucket=[The S3 bucket to upload packages to]:PACKAGE_BUCKET: ' \
'--package-prefix=[A prefix for any uploaded packages]:PACKAGE_PREFIX: ' \
'*--parameters=[A list of input parameters for the stack]:KEY=VALUE: ' \
'*--resource-types=[The template resource types that you have permissions to work with for this \`apply_stack\` operation, such as \`AWS\:\:EC2\:\:Instance\`, \`AWS\:\:EC2\:\:*\`, or \`Custom\:\:MyCustomInstance\`]:RESOURCE_TYPES: ' \
'--role-arn=[The Amazon Resource Name (ARN) of an AWS Identity And Access Management (IAM) role that AWS CloudFormation assumes to apply the stack]:ROLE_ARN: ' \
'--stack-name=[The name that is associated with the stack]:STACK_NAME: ' \
'*--tags=[Key-value pairs to associate with this stack]:KEY=VALUE|JSON: ' \
'--template-path=[Path to the template to be applied]:TEMPLATE_PATH:_files' \
'--no-input[A flag to indicate that no input can be obtained]' \
'--quiet[Disable informational output to STDERR]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(delete-stack)
_arguments "${_arguments_options[@]}" \
'--client-request-token=[A unique identifier for this \`delete_stack\` operation]:CLIENT_REQUEST_TOKEN: ' \
'*--retain-resources=[For stacks in the \`DELETE_FAILED\` state, a list of resource logical IDs that are associated with the resources you want to retain. During deletion, AWS CloudFormation deletes the stack but does not delete the retained resources]:RETAIN_RESOURCES: ' \
'--role-arn=[The Amazon Resource Name (ARN) of an AWS Identity And Access Management (IAM) role that AWS CloudFormation assumes to delete the stack]:ROLE_ARN: ' \
'--stack-name=[The name of the stack to delete]:STACK_NAME: ' \
'--no-input[A flag to indicate that no input can be obtained]' \
'--quiet[Disable informational output to STDERR]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
":: :_cloudformatious__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cloudformatious-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(apply-stack)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(delete-stack)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_cloudformatious_commands] )) ||
_cloudformatious_commands() {
    local commands; commands=(
'completions:Write a shell completion script to STDOUT' \
'apply-stack:Apply a CloudFormation template' \
'delete-stack:Delete a CloudFormation stack' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cloudformatious commands' commands "$@"
}
(( $+functions[_cloudformatious__apply-stack_commands] )) ||
_cloudformatious__apply-stack_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious apply-stack commands' commands "$@"
}
(( $+functions[_cloudformatious__help__apply-stack_commands] )) ||
_cloudformatious__help__apply-stack_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious help apply-stack commands' commands "$@"
}
(( $+functions[_cloudformatious__completions_commands] )) ||
_cloudformatious__completions_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious completions commands' commands "$@"
}
(( $+functions[_cloudformatious__help__completions_commands] )) ||
_cloudformatious__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious help completions commands' commands "$@"
}
(( $+functions[_cloudformatious__delete-stack_commands] )) ||
_cloudformatious__delete-stack_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious delete-stack commands' commands "$@"
}
(( $+functions[_cloudformatious__help__delete-stack_commands] )) ||
_cloudformatious__help__delete-stack_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious help delete-stack commands' commands "$@"
}
(( $+functions[_cloudformatious__help_commands] )) ||
_cloudformatious__help_commands() {
    local commands; commands=(
'completions:Write a shell completion script to STDOUT' \
'apply-stack:Apply a CloudFormation template' \
'delete-stack:Delete a CloudFormation stack' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cloudformatious help commands' commands "$@"
}
(( $+functions[_cloudformatious__help__help_commands] )) ||
_cloudformatious__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'cloudformatious help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_cloudformatious" ]; then
    _cloudformatious "$@"
else
    compdef _cloudformatious cloudformatious
fi
