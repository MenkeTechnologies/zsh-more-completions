#compdef dool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[enable CPU stats]' \
  '-C+[include specific CPUs]:CPUs (comma-separated):' \
  '-d[enable disk stats]' \
  '-D+[include specific disks]:disks (comma-separated):' \
  '-g[enable page stats]' \
  '-i[enable interrupt stats]' \
  '-I+[include specific interrupts]:interrupts (comma-separated):' \
  '-l[enable load avg stats]' \
  '-m[enable memory stats]' \
  '-n[enable network stats]' \
  '-N+[include specific interfaces]:interfaces (comma-separated):' \
  '-p[enable process stats]' \
  '-r[enable I/O request stats]' \
  '-s[enable swap stats]' \
  '-S+[include specific swap devices]:swap devices (comma-separated):' \
  '-t[enable time/date output]' \
  '-T[enable epoch time output]' \
  '-y[enable system stats]' \
  '-a[equivalent to -cdngy (default)]' \
  '-f[equivalent to -cdngypmist]' \
  '-v[equivalent to -pmgdchit]' \
  '--bits[force bits for values measured in bytes]' \
  '--bytes[force bytes for values]' \
  '--bw[use black/white output]' \
  '--nocolor[disable colors]' \
  '--noheaders[disable header display]' \
  '--noupdate[disable header updates]' \
  '--float[force float values on screen]' \
  '--integer[force integer values on screen]' \
  '--output+[write CSV output to file]:file:_files' \
  '--csv[alias for --output with timestamped filename]' \
  '--list[list available plugins]' \
  '--version[show version]' \
  '1:delay (seconds):' \
  '2:count:' && ret=0

return ret
