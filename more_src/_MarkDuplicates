#compdef MarkDuplicates
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/markduplicates/MarkDuplicates.java
# Picard: identify duplicate reads in a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output marked file]:file:_files' \
  '(-M --METRICS_FILE)'{-M,--METRICS_FILE}'=[duplication metrics file]:file:_files' \
  '--MAX_FILE_HANDLES_FOR_READ_ENDS_MAP=[max open file handles when spilling to disk]:n:' \
  '--SORTING_COLLECTION_SIZE_RATIO=[memory footprint of sorting collections]:ratio:' \
  '--BARCODE_TAG=[SAM tag for barcodes]:tag:' \
  '--READ_ONE_BARCODE_TAG=[SAM tag for read one barcodes]:tag:' \
  '--READ_TWO_BARCODE_TAG=[SAM tag for read two barcodes]:tag:' \
  '--TAG_DUPLICATE_SET_MEMBERS=[add DS and DI tags to duplicate set members]:b:(true false)' \
  '--REMOVE_SEQUENCING_DUPLICATES=[remove optical duplicates from output]:b:(true false)' \
  '--TAGGING_POLICY=[control DT tag annotation]:policy:(DontTag OpticalOnly All)' \
  '--CLEAR_DT=[clear DT tag from input records]:b:(true false)' \
  '--DUPLEX_UMI=[treat UMIs as duplex stranded]:b:(true false)' \
  '--MOLECULAR_IDENTIFIER_TAG=[SAM tag for molecular identifiers]:tag:' \
  '--REMOVE_DUPLICATES=[remove duplicates from output]:b:(true false)' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:b:(true false)' \
  '--DUPLICATE_SCORING_STRATEGY=[scoring strategy for choosing non-duplicate]:s:(SUM_OF_BASE_QUALITIES TOTAL_MAPPED_REFERENCE_LENGTH RANDOM)' \
  '--OPTICAL_DUPLICATE_PIXEL_DISTANCE=[max pixel distance for optical duplicates]:n:' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--COMPRESSION_LEVEL=[compression level for output]:n:' \
  '--MAX_RECORDS_IN_RAM=[records kept in RAM before spilling]:n:' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--CREATE_MD5_FILE=[create MD5 digest for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' \
  '--QUIET=[suppress job-summary info on stderr]:b:(true false)' && ret=0

return ret
