#compdef ztunnel
# _ztunnel — Istio ambient-mesh L4 sidecar-less node proxy (intercepts pod egress + ingress, terminates HBONE, mTLS-secures intra-mesh traffic)
# upstream: https://github.com/istio/ztunnel
# Source: src/main.rs on tip; first positional is the subcommand. Runtime config comes from env (CONFIG, XDS_ADDRESS, CA_ADDRESS, CLUSTER_ID, NETWORK, ZTUNNEL_*) or the optional CONFIG yaml file.

_ztunnel() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1::subcommand:(proxy version help)'
}

_ztunnel "$@"
