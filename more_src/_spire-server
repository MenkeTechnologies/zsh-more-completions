#compdef spire-server
# Documentation: https://man.archlinux.org/search?q=spire-server
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run the SPIRE server'
  'agent:agent administration commands'
  'entry:registration entry commands'
  'bundle:trust bundle commands'
  'token:join token commands'
  'healthcheck:healthcheck the running server'
  'jwt:JWT helpers'
  'x509:X.509 helpers'
  'localauthority:local authority commands'
  'logger:adjust runtime log level'
  'federation:federation relationship commands'
  'validate:validate a server config file'
  'count:count entities (alias)'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'spire-server command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '-config=[config file]:file:_files -g "*.conf"' \
          '-bindAddress=[bind address]:address:_hosts' \
          '-bindPort=[bind port]:port:' \
          '-dataDir=[data dir]:dir:_files -/' \
          '-trustDomain=[trust domain]:domain:' \
          '-logFile=[log file]:file:_files' \
          '-logFormat=[log format]:format:(text json)' \
          '-logLevel=[log level]:level:(debug info warn error)' \
          '-logSourceLocation[include source file/line]' \
          '-expandEnv[expand env vars in config]' && ret=0 ;;
      (agent)
        _arguments '*::sub:(ban count evict list show purge)' && ret=0 ;;
      (entry)
        _arguments '*::sub:(create update count delete show)' && ret=0 ;;
      (bundle)
        _arguments '*::sub:(count show list set delete)' && ret=0 ;;
      (token)
        _arguments \
          '*::sub:(generate)' \
          '-spiffeID=[SPIFFE ID]:id:' \
          '-ttl=[token TTL]:duration:' && ret=0 ;;
      (healthcheck)
        _arguments \
          '-shallow[shallow check]' \
          '-verbose[verbose output]' && ret=0 ;;
      (federation)
        _arguments '*::sub:(create delete list show update refresh)' && ret=0 ;;
      (jwt)
        _arguments '*::sub:(mint)' && ret=0 ;;
      (x509)
        _arguments '*::sub:(mint)' && ret=0 ;;
      (localauthority)
        _arguments '*::sub:(jwt x509)' && ret=0 ;;
      (logger)
        _arguments '*::sub:(get set reset)' && ret=0 ;;
      (validate)
        _arguments '-config=[config file]:file:_files -g "*.conf"' && ret=0 ;;
    esac ;;
esac

return ret
