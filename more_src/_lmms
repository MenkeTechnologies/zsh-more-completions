#compdef lmms

# Zsh completion for lmms - LMMS music production

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--allowroot[allow running as root]' \
  '--geometry=[set window geometry]:WxH+X+Y' \
  '(-r --render)'{-r,--render}'[render project to file]:output file:_files -g "*.{wav,ogg,mp3,flac}"' \
  '(-o --output)'{-o,--output}'[same as --render]:output file:_files -g "*.{wav,ogg,mp3,flac}"' \
  '(-f --output-format)'{-f,--output-format}'[output format for rendering]:format:(wav ogg mp3 flac)' \
  '(-s --samplerate)'{-s,--samplerate}'[set sample rate for rendering]:rate:(22050 44100 48000 88200 96000 176400 192000)' \
  '(-b --bitrate)'{-b,--bitrate}'[set bitrate for MP3/OGG]:bitrate:(64 80 96 112 128 160 192 224 256 320)' \
  '(-a --float)'{-a,--float}'[render as 32-bit float]' \
  '(-i --interpolation)'{-i,--interpolation}'[set interpolation method]:method:(linear sincfast sincmedium sincbest)' \
  '(-x --oversampling)'{-x,--oversampling}'[set oversampling factor]:factor:(1 2 4 8)' \
  '--loop[render with loop enabled]' \
  '--import=[import MIDI or Hydrogen file]:file:_files -g "*.{mid,midi,h2song}"' \
  '--profile=[load profile]:file:_files' \
  '--config=[use alternate config directory]:dir:_directories' \
  '-d[show debug output on console]' \
  '--dump=[dump XML of compressed file]:file:_files -g "*.mmp"' \
  '*:file:_files -g "*.{mmp,mmpz}"' && ret=0

return ret
