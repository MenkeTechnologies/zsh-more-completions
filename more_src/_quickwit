#compdef quickwit

local curcontext="$curcontext" state line ret=1

_quickwit_commands() {
  local -a commands=(
    'run:Start a Quickwit node'
    'index:Manage indexes'
    'source:Manage sources'
    'split:Manage splits'
    'service:Manage services'
    'tool:Run various tools'
    'completions:Generate shell completions'
  )
  _describe -t commands 'quickwit command' commands
}

_quickwit_index_subcommands() {
  local -a subcmds=(
    'create:Create an index'
    'delete:Delete an index'
    'describe:Describe an index'
    'ingest:Ingest documents into an index'
    'list:List indexes'
    'search:Search an index'
    'clear:Clear an index'
  )
  _describe -t commands 'index subcommand' subcmds
}

_quickwit_source_subcommands() {
  local -a subcmds=(
    'create:Create a source'
    'delete:Delete a source'
    'describe:Describe a source'
    'list:List sources'
    'toggle:Enable or disable a source'
    'reset-checkpoint:Reset a source checkpoint'
  )
  _describe -t commands 'source subcommand' subcmds
}

_quickwit_split_subcommands() {
  local -a subcmds=(
    'list:List splits'
    'describe:Describe a split'
    'mark-for-deletion:Mark splits for deletion'
  )
  _describe -t commands 'split subcommand' subcmds
}

_quickwit_service_subcommands() {
  local -a subcmds=(
    'run:Run a Quickwit service'
  )
  _describe -t commands 'service subcommand' subcmds
}

_quickwit_tool_subcommands() {
  local -a subcmds=(
    'local-ingest:Ingest documents locally'
    'local-search:Search locally'
    'gc:Run garbage collection'
    'merge:Run merge operations'
    'extract-split:Extract a split'
  )
  _describe -t commands 'tool subcommand' subcmds
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  {-c,--config}'[Configuration file path]:config:_files' \
  '--data-dir[Data directory]:directory:_files -/' \
  '--metastore-uri[Metastore URI]:uri' \
  '--cluster-id[Cluster ID]:id' \
  '--node-id[Node ID]:id' \
  '--peer-seeds[Peer seed addresses]:seeds' \
  '1:command:_quickwit_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          {-c,--config}'[Configuration file]:config:_files' \
          '--service[Services to run]:service:(indexer searcher metastore control-plane janitor)' \
          '--data-dir[Data directory]:directory:_files -/' \
          '--metastore-uri[Metastore URI]:uri' \
          '--cluster-id[Cluster ID]:id' \
          '--node-id[Node ID]:id' \
          '--peer-seeds[Peer seed addresses]:seeds' \
          && ret=0
        ;;
      index)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_quickwit_index_subcommands' \
          '*::index-arg:->index-args' \
          && ret=0
        case "$state" in
          index-args)
            case "$words[1]" in
              create)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  '--index-config[Index config file]:file:_files' \
                  '--overwrite[Overwrite existing index]' \
                  && ret=0
                ;;
              delete)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  '--index[Index ID]:index' \
                  '--dry-run[Dry run]' \
                  && ret=0
                ;;
              describe)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  '--index[Index ID]:index' \
                  && ret=0
                ;;
              ingest)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  '--index[Index ID]:index' \
                  '--input-path[Input file path]:file:_files' \
                  '--batch-size-limit[Batch size limit]:size' \
                  && ret=0
                ;;
              list)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  && ret=0
                ;;
              search)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  '--index[Index ID]:index' \
                  '--query[Search query]:query' \
                  '--max-hits[Maximum number of hits]:count' \
                  '--start-offset[Start offset]:offset' \
                  '--search-fields[Fields to search]:fields' \
                  '--start-timestamp[Start timestamp]:timestamp' \
                  '--end-timestamp[End timestamp]:timestamp' \
                  '--sort-by-field[Sort by field]:field' \
                  && ret=0
                ;;
              clear)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[Show help]' \
                  '--index[Index ID]:index' \
                  && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      source)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_quickwit_source_subcommands' \
          && ret=0
        ;;
      split)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_quickwit_split_subcommands' \
          && ret=0
        ;;
      service)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_quickwit_service_subcommands' \
          && ret=0
        ;;
      tool)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_quickwit_tool_subcommands' \
          && ret=0
        ;;
      completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:shell:(bash zsh fish powershell elvish)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
