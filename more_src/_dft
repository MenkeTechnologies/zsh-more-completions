#compdef dft
# ============================================================================
# dft - DataFusion TUI: terminal + CLI + server
#        implementation of Apache DataFusion
#        (Rust, Apache-2.0)
#
# Author : Matthew Turner (matthewmturner)
# Upstream: https://github.com/datafusion-contrib/datafusion-dft
# crates : datafusion-dft (binary: dft)
#
# `dft` is a batteries-included DataFusion CLI +
# TUI + server. DataFusion is Apache Arrow's
# canonical embedded query engine (the engine
# powering InfluxDB IOx + Cube + many other
# Arrow-based analytics systems). dft provides:
#   - Interactive Ratatui-based TUI for SQL
#     exploration over Parquet + CSV + JSON +
#     Avro + Arrow IPC files
#   - One-shot CLI mode for batch query execution
#   - FlightSQL server for serving DataFusion
#     queries over gRPC (via tonic) - the
#     Apache Arrow FlightSQL protocol enables
#     low-latency remote query execution +
#     streaming Arrow IPC results back to clients
#   - HTTP server mode for REST-style queries
#   - TPC-H benchmark generator + runner
#
# Architecture:
#   - DataFusion 51+ as the SQL execution engine
#   - Apache Arrow 57+ for columnar data
#     representation
#   - clap derive for CLI parsing
#   - Ratatui + Crossterm for the TUI (optional
#     "tui" feature)
#   - Axum + Tonic for the HTTP + FlightSQL
#     servers (optional "http" + "flightsql"
#     features)
#   - tokio runtime
#   - color-eyre for error reporting
#
# Use cases:
#   - Ad-hoc Parquet + CSV + JSON exploration
#     (alternative to duckdb-cli or trino-cli)
#   - Self-hosted FlightSQL server for low-
#     latency analytics
#   - DataFusion query plan analysis + EXPLAIN
#     visualization
#   - Benchmark TPC-H queries against custom
#     DataFusion configurations
#   - SQL+Arrow data pipeline development
#
# Usage:
#   dft [global options] [subcommand]
#   dft <SQL file>
#   dft -c "<SQL>"
#
# Global flags (clap derive):
#   -f, --files <path>...          - execute
#                                     commands
#                                     from
#                                     file(s),
#                                     then exit
#                                     (repeatable)
#   -c, --commands <SQL>...        - execute
#                                     SQL
#                                     string(s),
#                                     then exit
#                                     (repeatable)
#       --config <path>            - path to
#                                     config
#                                     file (TOML)
#   -q, --flightsql                - use the
#                                     FlightSQL
#                                     client
#                                     defined
#                                     in config
#                                     (gRPC
#                                     connection)
#       --run-ddl                  - run DDL
#                                     prior to
#                                     executing
#                                     queries
#   -t, --time                     - only show
#                                     how long
#                                     the query
#                                     took to
#                                     run
#   -j, --json                     - output
#                                     query
#                                     results
#                                     as line-
#                                     delimited
#                                     JSON
#   -C, --concat                   - concatenate
#                                     all result
#                                     batches
#                                     into a
#                                     single
#                                     batch
#                                     before
#                                     printing
#   -b, --bench                    - benchmark
#                                     the
#                                     provided
#                                     query
#       --analyze                  - print a
#                                     summary of
#                                     the
#                                     query's
#                                     execution
#                                     plan +
#                                     statistics
#       --run-before <SQL>         - run the
#                                     provided
#                                     query
#                                     before
#                                     running
#                                     the
#                                     benchmark
#       --save <file>              - save the
#                                     benchmark
#                                     results
#                                     to a file
#       --append                   - append the
#                                     benchmark
#                                     results to
#                                     an
#                                     existing
#                                     file
#   -n <n>                         - number of
#                                     benchmark
#                                     iterations
#       --concurrent               - run
#                                     benchmark
#                                     iterations
#                                     concurrently
#       --host <host>              - host
#                                     address
#                                     for
#                                     FlightSQL
#       --header <name=value>      - header for
#                                     FlightSQL
#                                     connection
#                                     (repeatable)
#       --headers-file <path>      - file
#                                     containing
#                                     FlightSQL
#                                     headers
#   -o, --output <path>            - path to
#                                     save
#                                     output to
#                                     (type
#                                     inferred
#                                     from
#                                     suffix)
#   -h, --help                     - print help
#   -V, --version                  - print
#                                     version
#
# Subcommands (cfg-gated by features):
#   serve-http                     - start HTTP
#                                     server
#                                     (requires
#                                     "http"
#                                     feature)
#   serve-flight-sql               - start
#                                     FlightSQL
#                                     gRPC
#                                     server
#                                     (requires
#                                     "flightsql"
#                                     feature)
#   flight-sql <subcommand>        - FlightSQL
#                                     client
#                                     subcommands
#                                     (statement-
#                                     query +
#                                     get-
#                                     catalogs +
#                                     get-db-
#                                     schemas +
#                                     get-
#                                     tables +
#                                     get-
#                                     table-
#                                     types +
#                                     get-sql-
#                                     info +
#                                     get-
#                                     xdbc-
#                                     type-info)
#   generate-tpch                  - generate
#                                     TPC-H
#                                     benchmark
#                                     data
#
# Example invocations:
#   dft                              # launch
#                                     # TUI
#                                     # interactive
#                                     # mode
#   dft -c "SELECT * FROM 'data.parquet'"
#   dft -c "SELECT * FROM 'data.csv'" --json
#   dft query.sql -t                 # time only
#   dft -c "SELECT COUNT(*) FROM t" \
#       --bench -n 100
#   dft serve-flight-sql --port 50051
#   dft -q --host localhost:50051 \
#       flight-sql statement-query \
#       --sql "SELECT 1"
#
# The tonic lane is built on `tonic = "0.14"`
# (declared verbatim at upstream Cargo.toml HEAD
# as an optional dep gated by the "flightsql"
# feature, used by the FlightSQL server +
# client subcommands for Apache Arrow FlightSQL
# protocol implementation via the
# arrow-flight v57 + flight-sql-experimental
# features), the canonical Rust gRPC library
# by Lucio Franco + the hyperium org -
# github.com/hyperium/tonic.
#
# Lucio Franco + hyperium's tonic is the
# de-facto canonical Rust gRPC library:
#   - Pure-Rust gRPC implementation built on
#     hyper (Sean McArthur) + h2 (Carl Lerche at
#     Axis 275) + tokio (Carl Lerche + Alex
#     Crichton)
#   - 8,000+ reverse-deps on crates.io
#   - Used by tikv + lakeFS + Materialize +
#     Lance + DataFusion + many production gRPC
#     services in Rust
#   - prost-based Protocol Buffer codegen
#     (canonical Rust protobuf compilation)
#   - Service trait abstraction (tower-compatible)
#   - Server reflection support
#   - Streaming + bidi-streaming support
#   - Compression support
#   - Load balancing + service discovery
#
# tonic's distinguishing position vs Rust gRPC
# alternatives:
#   - hyperium/tonic (Franco): canonical;
#     hyper + h2 + tokio substrate; THIS AXIS
#   - tikv/grpc-rs: alternative Rust gRPC
#     wrapping the C++ grpc library; cgo-style;
#     mainly used by TiKV
#
# tonic's positioning leverages the entire
# Carl Lerche async-substrate stack (tokio +
# bytes + mio + h2 + tower) from Axis 275 +
# the hyperium HTTP stack (hyper + http +
# http-body). This makes tonic the
# *vertically-integrated gRPC canonical* in
# Rust - every layer below tonic is a Lerche +
# McArthur library.
#
# Lucio Franco's broader Rust ecosystem
# footprint:
#   - hyperium/tonic (canonical Rust gRPC;
#     THIS AXIS)
#   - hyperium org contributor (works with Sean
#     McArthur + Carl Lerche on the broader
#     HTTP stack)
#   - tokio-rs contributor
#
# Franco's role in Rust is *gRPC + protocol-
# buffer canonical infrastructure within the
# hyperium/tokio ecosystem*. He extends the
# foundational-infrastructure canonical-author
# cluster (Tolnay + Crichton + Gallant +
# Reizner + McArthur + Lerche) into the gRPC
# specific vertical.
#
# Multi-axis canonical-Rust author cluster
# extension (now spanning many distinct
# individuals):
#   - + Lucio Franco (hyperium/tonic; THIS
#     AXIS; extends the hyperium org's
#     canonical infrastructure)
#
# Notable that the tonic + hyper + h2 + tokio +
# bytes + tower stack forms a *vertically-
# integrated canonical-author tower* in the
# Rust ecosystem - each layer is authored by
# a different individual in the foundational-
# infrastructure cluster, but all layers are
# designed to work together seamlessly.
#
# dft uses tonic in src/server/flight_sql.rs
# (gated by feature = "flightsql"):
#   ```rust
#   use tonic::transport::Server;
#   use arrow_flight::flight_service_server::
#       FlightServiceServer;
#
#   let addr = "[::1]:50051".parse()?;
#   let service = FlightServiceImpl::new(
#       datafusion_ctx);
#
#   Server::builder()
#       .add_service(FlightServiceServer::new(
#           service))
#       .serve(addr)
#       .await?;
#   ```
# The tonic Server provides gRPC over HTTP/2
# + TLS for the FlightSQL protocol, allowing
# remote clients (e.g., dbt-flight, BI tools,
# Python clients via pyarrow.flight) to query
# the DataFusion engine.
#
# ----------------------------------------------------------------------------
# AXIS 276 :: gRPC protocol libraries (HTTP/2
#              + protocol buffer codegen +
#              service definition + streaming
#              + bidi-streaming + reflection)
# Round 1526 :: Rust slot 1 of 4 :: OPENS Axis 276
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : hyperium/tonic                - Lucio
#                                              Franco +
#                                              hyperium
#                                              org's
#                                              canonical
#                                              Rust gRPC;
#                                              built on
#                                              hyper +
#                                              h2 +
#                                              tokio
#   Go      : grpc/grpc-go                   - Google's
#                                              official
#                                              Go gRPC
#                                              implementation;
#                                              maintained
#                                              by the
#                                              gRPC
#                                              Google
#                                              core
#                                              team
#   TS/Node : grpc/grpc-node                 - Google's
#                                              official
#                                              Node gRPC
#                                              implementation;
#                                              C++-binding
#                                              + pure-JS
#                                              flavors
#
# gRPC is a *spec-bound + Google-driven* axis:
#   - gRPC protocol standardized by Google in
#     2015 (initially internal Stubby, then
#     open-sourced)
#   - Uses HTTP/2 as transport (Axis 275)
#   - Uses Protocol Buffers (protobuf) for
#     interface definition + binary wire format
#   - Streaming support (unary + server-
#     streaming + client-streaming + bidi-
#     streaming)
#   - Service reflection for runtime
#     introspection
#
# Each canonical library provides:
#   - protobuf codegen from .proto files
#   - Service trait + skeleton generation
#   - HTTP/2 + TLS transport
#   - Streaming abstractions
#   - Authentication + interceptors
#   - Compression + flow control
#
# Cross-language interop is fundamental to
# gRPC - all three lanes interoperate with any
# compliant gRPC server/client. This is the
# *primary* design goal of gRPC: polyglot
# microservice communication.
#
# Axis 276 opens with the Rust slot at Franco +
# hyperium's tonic, anchoring the Rust gRPC
# canonical at the intersection of the hyperium
# HTTP stack + the Lerche async substrate.
#
# Use case spectrum for this axis (so far):
#   - dft (Rust, tonic via flightsql feature):
#     DataFusion TUI + FlightSQL gRPC server
#     for remote SQL query execution
# ============================================================================

_dft() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '*'{-f,--files}'[execute commands from file(s)]:file:_files -g "*.(sql|SQL)"' \
        '*'{-c,--commands}'[execute SQL string(s)]:sql:' \
        '--config=[path to config file (TOML)]:file:_files -g "*.toml"' \
        '(-q --flightsql)'{-q,--flightsql}'[use FlightSQL client from config]' \
        '--run-ddl[run DDL prior to executing]' \
        '(-t --time)'{-t,--time}'[only show query duration]' \
        '(-j --json)'{-j,--json}'[output results as line-delimited JSON]' \
        '(-C --concat)'{-C,--concat}'[concatenate all result batches into one]' \
        '(-b --bench)'{-b,--bench}'[benchmark the query]' \
        '--analyze[print execution plan + statistics summary]' \
        '--run-before=[query to run before benchmark]:sql:' \
        '--save=[save benchmark results to file]:file:_files' \
        '--append[append benchmark results to existing file]' \
        '-n+[number of benchmark iterations]:n:' \
        '--concurrent[run benchmark iterations concurrently]' \
        '--host=[host address for FlightSQL]:host:' \
        '*--header=[FlightSQL header (Name: Value)]:header:' \
        '--headers-file=[file containing FlightSQL headers]:file:_files' \
        '(-o --output)'{-o,--output}'[path to save output]:file:_files' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_dft_cmds' \
        '*::arg:->args' \
    && ret=0

    return ret
}

_dft_cmds() {
    local -a cmds
    cmds=(
        'serve-http:start HTTP server'
        'serve-flight-sql:start FlightSQL gRPC server'
        'flight-sql:FlightSQL client subcommands'
        'generate-tpch:generate TPC-H benchmark data'
    )
    _describe -t commands 'dft command' cmds
}

_dft "$@"
