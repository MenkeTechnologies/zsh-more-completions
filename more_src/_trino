#compdef trino

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--server+[Trino server URL]:URL:_urls' \
  '--user+[username for authentication]:username:' \
  '--password[prompt for password]' \
  '--source+[name of source making the query]:source:' \
  '--catalog+[default catalog]:catalog:' \
  '--schema+[default schema]:schema:' \
  '--execute+[execute SQL statement and exit]:SQL:' \
  '--file+[execute SQL from file]:file:_files -g "*.sql(-.)"' \
  '--output-format+[output format for batch mode]:format:(CSV CSV_HEADER CSV_UNQUOTED CSV_HEADER_UNQUOTED TSV TSV_HEADER JSON ALIGNED VERTICAL NULL)' \
  '--debug[enable debug information]' \
  '--log-levels-file+[configure log levels]:file:_files' \
  '--client-info+[extra information about the client]:info:' \
  '--client-tags+[client tags]:tags:' \
  '--client-request-timeout+[client request timeout]:timeout:' \
  '--ignore-errors[continue processing in batch mode]' \
  '--session+[set session property]:property=value:' \
  '--extra-credential+[extra credentials]:credential:' \
  '--external-authentication[use external authentication]' \
  '--access-token+[access token]:token:' \
  '--keystore-path+[keystore path for TLS]:path:_files' \
  '--keystore-password+[keystore password]:password:' \
  '--keystore-type+[keystore type]:type:(JKS PKCS12)' \
  '--truststore-path+[truststore path for TLS]:path:_files' \
  '--truststore-password+[truststore password]:password:' \
  '--truststore-type+[truststore type]:type:(JKS PKCS12)' \
  '--insecure[skip TLS certificate verification]' \
  '--timezone+[session timezone]:timezone:' \
  '--resource-estimate+[resource estimate for query]:estimate:' \
  '--disable-compression[disable HTTP compression]' \
  '--version[show version]' \
  '--help[show help]' && ret=0

return ret
