#compdef darktable-curve-tool

# darktable-curve-tool: derive basecurve / tonecurve from RAW+JPEG pairs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-z[zero curve start]' \
  '-n[number of curve nodes]:n:' \
  '-s[scale curve points]:val:' \
  '-c[output basecurve preset]' \
  '-t[output tonecurve preset]' \
  '-e[output dtstyle file]:file:_files' \
  '-h[show help]' \
  '*:RAW JPEG output:_files' && ret=0
return ret
