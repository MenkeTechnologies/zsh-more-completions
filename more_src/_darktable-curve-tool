#compdef darktable-curve-tool

# darktable-curve-tool: extract base curves from camera JPEGs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '-z[output base curve, not tonecurve]' \
  '-c[curve format presets]:preset:' \
  '-e[output curve nodes count]:n:' \
  '-n[number of nodes in output curve]:n:' \
  '-s[sampling resolution]:n:' \
  '-r[input is raw, jpeg pair]' \
  '*:reference raw / jpeg images:_files -g "*.(cr2|nef|arw|raf|orf|dng|jpg|jpeg|tiff|tif)"' && ret=0
return ret
