#compdef wkg
# Documentation: https://man.archlinux.org/search?q=wkg
# Reference accessed: 2026-05-16

# Zsh completion for wkg (wasm-pkg-tools, bytecodealliance/wasm-pkg-tools).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:view or edit registry configuration'
  'get:download a package from a registry'
  'publish:publish a wasm package to a registry'
  'oci:pull or push components via OCI registries'
  'wit:build, fetch, or update WIT package dependencies'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'wkg command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--default-registry=[set default registry domain]:registry:' \
          '(-e --edit)'{-e,--edit}'[open config file in $EDITOR]' \
          '--config=[config file path]:config file:_files' \
          '--cache=[cache directory]:directory:_files -/' && ret=0 ;;
      (get)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output=}'[output path or directory ending with /]:path:_files' \
          '--format=[output format]:format:(auto wasm wit)' \
          '--check[compare download to existing output file]' \
          '--overwrite[overwrite existing output file]' \
          '--registry=[override registry]:registry:' \
          '--config=[config file path]:config file:_files' \
          '--cache=[cache directory]:directory:_files -/' \
          '1:package spec (namespace\:name\[@version\]):package:' && ret=0 ;;
      (publish)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--registry=[override registry]:registry:' \
          '--package=[package id override]:package spec:' \
          '--config=[config file path]:config file:_files' \
          '--cache=[cache directory]:directory:_files -/' \
          '1:wasm file to publish:_files -g "*.wasm"' && ret=0 ;;
      (oci)
        local -a ocisub
        ocisub=(
          'pull:pull a component from an OCI registry'
          'push:push a Wasm component to an OCI registry'
        )
        if (( CURRENT == 3 )); then
          _describe -t commands 'oci command' ocisub && ret=0
        else
          case $words[3] in
            (pull)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-u --username)'{-u+,--username=}'[registry username]:user:' \
                '(-p --password)'{-p+,--password=}'[registry password]:password:' \
                '--insecure=[http allowed hosts (comma-delimited)]:hosts:' \
                '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
                '1:OCI image reference:reference:' && ret=0 ;;
            (push)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-u --username)'{-u+,--username=}'[registry username]:user:' \
                '(-p --password)'{-p+,--password=}'[registry password]:password:' \
                '--insecure=[http allowed hosts (comma-delimited)]:hosts:' \
                '(-a --author)'{-a+,--author=}'[optional OCI author string]:author:' \
                '*--annotation=[OCI manifest annotation KEY=value]:annotation:' \
                '1:OCI image reference:reference:' \
                '2:component wasm file path:_files -g "*.wasm"' && ret=0 ;;
          esac
        fi ;;
      (wit)
        local -a witsub
        witsub=(
          'build:encode a WIT package and resolve dependencies'
          'fetch:fetch WIT dependencies into deps directory'
          'update:refresh lock file with latest dependencies'
        )
        if (( CURRENT == 3 )); then
          _describe -t commands 'wit command' witsub && ret=0
        else
          case $words[3] in
            (build)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-d --wit-dir)'{-d+,--wit-dir=}'[WIT sources directory]:directory:_files -/' \
                '(-o --output)'{-o+,--output=}'[output .wasm path]:file:_files' \
                '--config=[config file path]:config file:_files' \
                '--cache=[cache directory]:directory:_files -/' && ret=0 ;;
            (fetch|update)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-d --wit-dir)'{-d+,--wit-dir=}'[WIT sources directory]:directory:_files -/' \
                '(-t --type)'{-t+,--type=}'[dependency output type]:type:(wit wasm)' \
                '--config=[config file path]:config file:_files' \
                '--cache=[cache directory]:directory:_files -/' && ret=0 ;;
          esac
        fi ;;
    esac ;;
esac

return ret
