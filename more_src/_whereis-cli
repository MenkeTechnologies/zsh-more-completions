#compdef whereis-cli
# _whereis-cli — util-linux whereis locate the binary, source, and manual page CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_whereis-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[search only for binaries]' \
        '-B+[binary search paths]:dir:_files -/' \
        '-m[search only for manuals and infos]' \
        '-M+[manual search paths]:dir:_files -/' \
        '-s[search only for sources]' \
        '-S+[source search paths]:dir:_files -/' \
        '-u[search only for unusual entries]' \
        '-l[output effective lookup paths]' \
        '-f[terminate dir list]' \
        '-g[interpret name as glob]' \
        '*:commands:_command_names'
}

_whereis-cli "$@"
