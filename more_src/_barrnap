#compdef barrnap
# Documentation: https://github.com/tseemann/barrnap
# barrnap - BAsic Rapid Ribosomal RNA Predictor (rRNA/tRNA/ncRNA gene finder)

local ret=1

_arguments -s -S \
  '(- *)--help[show help and exit]' \
  '(- *)--version[print version and exit]' \
  '(- *)--citation[print citation and exit]' \
  '--debug[write tempfiles and print debug info]' \
  '(- *)--listdb[list installed databases]' \
  '(- *)--updatedb[update databases from internet]' \
  '--dbdir=[use a different DB folder]:dir:_files -/' \
  '--kingdom=[database to use]:kingdom:(bac arc fun)' \
  '--all[only do rRNA scan like versions <1.0]' \
  '--no-rrna[disable rRNA scan]' \
  '--trna[enable tRNA scan]' \
  '--ncrna[enable ncRNA scan]' \
  '--mrna[enable mRNA scan]' \
  '--threads=[number of CPUs to use]:n:' \
  '--fast[use simpler HMMs (faster, less accurate)]' \
  '--evalue=[cut-off for hits to keep]:evalue:' \
  '--quiet[do not print messages to stderr]' \
  '--incseq[include full input sequences in output GFF]' \
  '--incseqreg[include ##sequence-region headers in GFF]' \
  '--outseq=[create FASTA file with hit sequences]:file:_files' \
  '--adids[add unique ID= tags to each GFF3 feature]' \
  '*:fasta file:_files' && ret=0

return ret
