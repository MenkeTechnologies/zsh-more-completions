#compdef vcf2bed
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/conversion/vcf2bed.html
# convert VCF variant calls to sorted BED (bedops)

local ret=1

_arguments -s -S \
  '--keep-header[preserve header data as BED elements named _header]' \
  '--do-not-split-alt-alleles[print one BED element per variant call]' \
  '--snvs[filter for single nucleotide variants]' \
  '--insertions[filter for insertion variants]' \
  '--deletions[filter for deletion variants]' \
  '--do-not-sort[skip sorting the converted output]' \
  '--max-mem[limit sort memory usage]:mem' \
  '--sort-tmpdir[directory for intermediate sort results]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
