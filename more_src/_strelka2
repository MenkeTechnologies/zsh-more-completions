#compdef strelka2

# Strelka2: small-variant caller (Illumina)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--bam=[normal sample BAM]:file:_files -g "*.(bam|cram)"' \
  '--normalBam=[normal sample BAM (somatic mode)]:file:_files -g "*.(bam|cram)"' \
  '--tumorBam=[tumor sample BAM (somatic mode)]:file:_files -g "*.(bam|cram)"' \
  '--referenceFasta=[reference FASTA]:file:_files' \
  '--runDir=[run directory]:dir:_files -/' \
  '--callRegions=[BGZF/Tabix-indexed BED of regions]:file:_files' \
  '--indelCandidates=[indel candidates from Manta]:file:_files -g "*.vcf*"' \
  '--forcedGT=[forced genotypes VCF]:file:_files' \
  '--exome[targeted seq mode]' \
  '--rna[RNA-Seq mode]' \
  '*:options:_files' && ret=0
return ret
