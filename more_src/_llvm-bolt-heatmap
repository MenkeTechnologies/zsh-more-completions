#compdef llvm-bolt-heatmap
# Documentation: https://github.com/llvm/llvm-project/blob/main/bolt/lib/Utils/CommandLineOpts.cpp
# generate code execution heatmap from a BOLT profile

local ret=1

_arguments -s \
  '(-help --help)'{-help,--help}'[show help]' \
  '-help-hidden[show hidden options]' \
  '--version[show version]' \
  '-o=[output file prefix for heatmap]:output:_files' \
  '-data=[profile data file]:data:_files' \
  '-heatmap=[heatmap output file]:file:_files' \
  '-block-size=[size of a heatmap block in bytes]:bytes' \
  '-line-size=[number of blocks per line]:n' \
  '-min-address=[minimum address to include]:address' \
  '-max-address=[maximum address to include]:address' \
  '-print-mappings[print section mappings]' \
  '-v=[verbosity level]:level' \
  '*:input binary:_files' && ret=0

return ret
