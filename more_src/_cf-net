#compdef cf-net
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-net.html
# Source: cfengine/core cf-net/cf-net.c — CFEngine network/protocol diagnostic CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-M --manpage)'{-M,--manpage}'[print man page]' \
    '(-H --host)'{-H+,--host=}'[server hostnames or IPs (comma-separated)]:hosts:_default' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-I --inform)'{-I,--inform}'[enable basic information output]' \
    '(-t --tls-version)'{-t+,--tls-version=}'[minimum TLS version]:version:_default' \
    '(-c --ciphers)'{-c+,--ciphers=}'[TLS ciphers (comma-separated)]:ciphers:_default' \
    '(-p --protocol)'{-p+,--protocol=}'[CFEngine protocol]:proto:(classic tls cookie)' \
    '(-s --stats)'{-s,--stats}'[print rsync performance stats to stderr]' \
    '1:subcommand:(connect stat get opendir getdir help)' \
    '*::args:_files' \
    && ret=0

return ret
