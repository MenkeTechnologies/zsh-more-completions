#compdef cpack
# _cpack — CMake CPack packaging tool (Kitware, C++); generate installers (deb, rpm, dmg, nsis, etc.) from CMake projects
# upstream: https://github.com/Kitware/CMake

_cpack() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-G+[generator]:gen:(7Z DEB DragNDrop External FREEBSD IFW NSIS NuGet OSXX11 PackageMaker productbuild RPM STGZ TBZ2 TGZ TXZ TZ TZST WIX ZIP)' \
        '--config+[config file]:file:_files' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--trace[trace]' \
        '--trace-expand[trace expand]' \
        '-C+[build config]:cfg:(Debug Release RelWithDebInfo MinSizeRel)' \
        '-D+[set variable]:KEY=VAL:' \
        '-P+[project name]:name:' \
        '-R+[project version]:str:' \
        '-B+[output dir]:dir:_files -/' \
        '--vendor+[vendor]:str:' \
        '*:project dir:_files -/'
}

_cpack "$@"
