#compdef dwgsim
# Documentation: https://manpages.debian.org/testing/dwgsim/dwgsim.1.en.html
# dwgsim - whole genome simulator for next-generation sequencing

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-e[per base error rate of first read]:rate' \
  '-E[per base error rate of second read]:rate' \
  '-i[use inner distance instead of outer for pairs]' \
  '-d[outer distance between ends for pairs]:dist' \
  '-s[standard deviation of pair distance]:sd' \
  '-N[number of read pairs]:n' \
  '-C[mean coverage across positions]:cov' \
  '-r[rate of mutations]:rate' \
  '-F[mutation frequency on first strand]:freq' \
  '-R[fraction of mutations that are indels]:frac' \
  '-X[probability an indel is extended]:prob' \
  '-I[minimum length indel]:len' \
  '-y[probability of a random DNA read]:prob' \
  '-n[maximum number of Ns allowed in a read]:n' \
  '-c[platform: 0=Illumina 1=SOLiD 2=Ion Torrent]:platform:(0 1 2)' \
  '-S[strand configuration]:strand:(0 1 2)' \
  '-f[flow order for Ion Torrent data]:order' \
  '-B[use per-base error rate for Ion Torrent]' \
  '-H[haploid mode]' \
  '-z[random seed]:seed' \
  '-M[generate a mutations file only]' \
  '-m[mutations file to recreate]:file:_files' \
  '-b[reference file with candidate mutations]:file:_files' \
  '-v[vcf file of candidate mutations]:file:_files' \
  '-x[regions BED file for coverage]:file:_files' \
  '-P[read prefix to prepend to each read name]:prefix' \
  '-q[fixed base quality character]:qual' \
  '-Q[standard deviation of base quality scores]:sd' \
  '*:reference:_files' && ret=0

return ret
