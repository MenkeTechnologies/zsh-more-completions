#compdef wl-paste
# Documentation: https://man.archlinux.org/search?q=wl-paste
# Reference accessed: 2026-05-16
# Zsh completion for wl-paste (wl-clipboard)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-t --type)'{-t,--type}'[Set MIME type]:mime type:' \
  '(-s --seat)'{-s,--seat}'[Pick seat to work with]:seat:' \
  '(-p --primary)'{-p,--primary}'[Use the primary selection]' \
  '(-n --no-newline)'{-n,--no-newline}'[Do not append trailing newline]' \
  '(-w --watch)'{-w,--watch}'[Run command on each clipboard change]:command:_command_names' \
  '(-l --list-types)'{-l,--list-types}'[List offered MIME types]' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version]' && ret=0
return ret
