#compdef BamIndexStats
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#BamIndexStats
# Picard: report aligned/unaligned read counts per reference from a BAM index

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[a BAM file to process]:bam:_files -g "*.bam"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.bam"' && ret=0

return ret
