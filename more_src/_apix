_apix_commands() {
    local commands; commands=(
'search:Search the registry for APIs' \
'pull:Pull an API vault (or specific version) from the registry' \
'update:Update the local registry' \
'grep:Full-text search within a pulled vault' \
'peek:Show frontmatter + required params only' \
'info:Show API metadata' \
'show:Show full endpoint documentation' \
'call:Execute an API call' \
'import:Import a vault from an OpenAPI spec' \
'completions:Generate shell completion scripts' \
'init:Initialize ~/.apix' \
