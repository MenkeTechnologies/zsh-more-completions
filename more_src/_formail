#compdef formail
# _formail — procmail's mail-(re)formatter (force a stream into mbox format, escape bogus From_ lines, auto-reply generation, header munging, split a mailbox/digest)
# upstream: https://github.com/BuGlessRB/procmail
# Flags from src/formail.c + man/formail.man on tip; option letters from the standard install.

_formail() {
    _arguments \
        '-v[show version and exit]' \
        '-b[do not escape bogus From_ lines]' \
        '-p+[quotation prefix (default >)]:prefix:' \
        '-Y[Berkeley-mbox format (ignore Content-Length:)]' \
        '-c[concatenate continued header fields]' \
        '-z[ensure whitespace separator + trim header fields]' \
        '-f[force pass-through of non-mailbox input]' \
        '-r[generate auto-reply header]' \
        '-k[keep body when extracting / replying]' \
        '-t[trust header sender for reply]' \
        '-s[split: pipe each message to a program]:program:_command_names -e' \
        '-n+[max parallel split processes]:n:' \
        '-e[messages need not be preceded by empty line]' \
        '-d[digest mode (split non-strict mailbox)]' \
        '-q[quiet (no warnings)]' \
        '-l+[log summary folder]:folder:' \
        '-x+[extract field value (printed without name)]:field:' \
        '-X+[extract field with name]:field:' \
        '-a+[add field if missing]:field:' \
        '-A+[add field unconditionally]:field:' \
        '-i+[rename field if present, insert (`X-Old-` prefix)]:field:' \
        '-I+[delete field, insert new]:field:' \
        '-u+[keep only first occurrence of field]:field:' \
        '-U+[keep only last occurrence of field]:field:' \
        '-R+[rename header field (old new)]:rename:' \
        '-D+[duplicate detection: maxlen idcache]:spec:' \
        '-m+[minimum number of fields]:n:'
}

_formail "$@"
