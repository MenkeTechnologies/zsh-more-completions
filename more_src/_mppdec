#compdef mppdec mpcdec

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--silent[silent mode]' \
  '--prev[print prev info]' \
  '--info[print stream info only]' \
  '*:input output:_files -g "*.{mpc,mp+,mpp,wav}"' && ret=0

return ret
