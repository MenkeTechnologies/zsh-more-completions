#compdef sethead
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# sethead: set FITS and IRAF image header keyword values (WCSTools)

local ret=1

_arguments -s -S \
  '-d[replace old FITS date strings with ISO 8601 equivalents]' \
  '-f[reset maximum number of files read from command line]' \
  '-h[add a HISTORY line noting version, date, and keywords set]' \
  '-k[add a SETHEAD keyword noting version, date, and keywords set]' \
  '-l[list names of processed files to STDERR]' \
  '-m[reset maximum number of keyword names read from command line]' \
  '-n[write to a new file instead of overwriting]' \
  '-r[rename existing keywords by prefixing this letter]:letter' \
  '-s[replace this letter in input strings with a space]:letter' \
  '-v[print more information about process]' \
  '*:FITS file or keyword=value:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
