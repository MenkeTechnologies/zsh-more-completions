#compdef apt-mark

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'auto:mark packages as automatically installed'
  'manual:mark packages as manually installed'
  'minimize-manual:minimize the manually-installed set'
  'hold:hold packages from upgrade'
  'unhold:remove hold on packages'
  'showauto:show automatically installed packages'
  'showmanual:show manually installed packages'
  'showhold:show held packages'
  'showholds:show held packages (alias)'
  'install:mark packages as installed'
  'remove:mark packages as removed'
  'deinstall:mark packages as deinstalled'
  'purge:mark packages as purged'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config-file)'{-c,--config-file=}'[config file]:file:_files' \
  '*-o+[set option name=value]:option:' \
  '(-f --file)'{-f,--file=}'[mark file]:file:_files' \
  '-q[quiet]' \
  '-s[simulate]' \
  '-v[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'apt-mark subcommand' subcommands && ret=0
    ;;
esac

return ret
