#compdef deno-check

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--all[type check all modules]' \
  '--remote[type check remote modules]' \
  '--config=[config file]:config:_files -g "deno.json*(-.)"' \
  '--no-config[do not use config file]' \
  '--import-map=[import map file]:file:_files' \
  '--lock=[lock file]:file:_files' \
  '--no-lock[do not use lock file]' \
  '--node-modules-dir[use node_modules directory]' \
  '--reload[reload source code cache]' \
  '*:file:_files -g "*.(ts|tsx|js|jsx|mts|mjs)(-.)"' && return 0
