#compdef iortcw iortcwsp iortcwmp
# Documentation: https://github.com/iortcw/iortcw/blob/master/SP/code/sys/sys_main.c
# Reference accessed: 2026-05-16
# Verified: SP/code/sys/sys_main.c Sys_ParseArgs() (lines 628-645) +
# SP/code/qcommon/common.c Com_ParseCommandLine() (line 462).
# Only -v/--version are real getopt-style flags; the + forms are cbuf-executed
# console commands prefixed with + on the command line.
# Removed from prior file: -h (not in Sys_ParseArgs; only -v/--version).

# iortcw: Return to Castle Wolfenstein open-source engine port
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-v[show version and exit]' \
  '(- *)--version[show version and exit]' \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '+disconnect[disconnect]' \
  '+quit[quit after startup commands]' \
  '*::extra args:_files' && ret=0
return ret
