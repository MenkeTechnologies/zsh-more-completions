#compdef iortcw
# Documentation: https://github.com/iortcw/iortcw
# Reference accessed: 2026-05-16

# iortcw: Return to Castle Wolfenstein open-source engine port
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '+set[set cvar]:cvar value:' \
  '+exec[execute config]:file:_files -g "*.cfg"' \
  '+map[load map]:map:' \
  '+demo[play demo]:name:' \
  '+connect[connect to server]:host:' \
  '*::iortcw args:_files' && ret=0
return ret
