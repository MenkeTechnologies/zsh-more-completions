#compdef cargo-acl
# _cargo-acl — Cackle: per-crate API/feature ACL analyzer for Rust (cackle-rs/cackle)
# upstream: https://github.com/cackle-rs/cackle
# Flags from src/main.rs (clap).

_cargo-acl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--path=[crate directory to analyze]:dir:_files -/' \
        '(-c --cackle-path)'{-c+,--cackle-path=}'[path to cackle.toml]:file:_files -g "*.toml"' \
        '--fail-on-warnings[promote warnings to errors]' \
        '--ignore-newer-config-versions[do not fail on newer config versions]' \
        '--colour=[color output mode]:mode:(auto always never)' \
        '--color=[color output mode]:mode:(auto always never)' \
        '--quiet[reduce output]' \
        '--target=[Rust target triple]:triple:' \
        '--profile=[cargo profile]:profile:(dev release)' \
        '--features=[features to pass to cargo]:features:' \
        '--print-timing[print timing info]' \
        '--debug[enable debug logging]' \
        '--log-file=[log file]:file:_files' \
        '--log-level=[log level]:level:(off error warn info debug trace)' \
        '--ui=[UI kind]:ui:(terminal full none)' \
        '(-n --no-ui)'{-n,--no-ui}'[run without UI]' \
        '--auto-accept-fixes[automatically apply suggested fixes]' \
        '--no-backtrace[suppress backtraces]' \
        '*--package=[package name to focus on]:pkg:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'acl:run ACL analysis on the crate'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                acl) _arguments '*:cargo subcommand:(test run)' ;;
            esac
            ;;
    esac
}

_cargo-acl "$@"
