#compdef diny
# Documentation: https://github.com/dinoDanic/diny
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_diny() {
    local line state
    local -a commands
    commands=(
        'config:Open TUI to edit settings'
        'theme:Preview and select UI color themes'
        'update:Update the tool to the latest version'
    )

    _arguments -C \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'diny command' commands
            ;;
        args)
            # diny mostly uses interactive TUI for subcommands
            ;;
    esac
}

_diny "$@"
