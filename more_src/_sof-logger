#compdef sof-logger
# _sof-logger — Sound Open Firmware DSP log / trace viewer (thesofproject/sof)
# upstream: https://github.com/thesofproject/sof
# Flags from tools/logger/logger.c (getopt).

_sof-logger() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-i+[input file (raw trace) instead of mailbox/DMA trace]:file:_files'
        '-o+[output file (default stdout)]:file:_files'
        '-l+[.ldc dictionary file generated by smex]:file:_files -g "*.ldc"'
        '-p[read input from stdin]'
        '-s+[take a snapshot of named state]:state:'
        '-c+[DSP timestamp clock (MHz)]:mhz:'
        '-u+[input from a UART at this baud rate]:baud:'
        '-t[use DMA "trace" stream instead of "etrace" error mailbox]'
        '-v+[firmware version file]:file:_files'
        '-r[less-formatted raw output for chained log processors]'
        '-d+[dump information about an .ldc dictionary file]:file:_files -g "*.ldc"'
        '-L[hide log source-code locations]'
        '-e+[relative-timestamp mode]:mode:(0 1)'
        '-f+[timestamp precision]:precision:'
        '-g[hide timestamps]'
        '-F+[update trace filter: <level>=<comp>[,<comp>...]]:filter:'
        '-n[do not compare dictionary checksums]'
    )
    _arguments -s $args
}

_sof-logger "$@"
