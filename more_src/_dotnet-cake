#compdef dotnet-cake
# Documentation: https://cakebuild.net/docs/running-builds/runners/dotnet-tool
# dotnet-cake - Cake .NET tool build script runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '--bootstrap[install modules from #module directives without running build]' \
  '(-d --debug)'{-d,--debug}'[launch script in debugging mode]' \
  '--description[show description about tasks]' \
  '--dryrun[perform a dry run]' \
  '(-e --exclusive)'{-e,--exclusive}'[execute a single task without dependencies]' \
  '--info[display additional information about Cake execution]' \
  '--skip-bootstrap[skip bootstrapping when running build]' \
  '--tree[show the task dependency tree]' \
  '(-v --verbosity)'{-v,--verbosity}'=[amount of information to display]:level:(quiet minimal normal verbose diagnostic)' \
  '*:script:_files -g "*.cake"' && ret=0

return ret
