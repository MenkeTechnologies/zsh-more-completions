#compdef wait-on

# Zsh completion for wait-on - wait for files, ports, sockets, and HTTP resources

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '(-d --delay)'{-d,--delay}'=[initial delay in ms]:milliseconds:' \
  '(-i --interval)'{-i,--interval}'=[polling interval in ms]:milliseconds:' \
  '(-l --log)'{-l,--log}'[log output to stdout]' \
  '(-r --reverse)'{-r,--reverse}'[reverse mode, wait for resource removal]' \
  '(-s --simultaneous)'{-s,--simultaneous}'=[max simultaneous resource checks]:count:' \
  '(-t --timeout)'{-t,--timeout}'=[maximum wait time in ms]:milliseconds:' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-w --window)'{-w,--window}'=[stabilization window in ms]:milliseconds:' \
  '(-c --config)'{-c,--config}'=[path to config file]:config file:_files' \
  '--httpTimeout=[HTTP timeout in ms]:milliseconds:' \
  '*:resources:'
