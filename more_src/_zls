#compdef zls

# Zsh completion for zls (Zig Language Server)

_arguments -s -S \
  '--config-path[config file path]:file:_files' \
  '--enable-debug-log[enable debug logging]' \
  '--enable-message-tracing[enable LSP message tracing]' \
  '--override-config[override config options]:config:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && return 0
