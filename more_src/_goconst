#compdef goconst
# Documentation: https://github.com/jgautheron/goconst
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-min-occurrences+[threshold for reporting duplicates (default 2)]:n:' \
  '-min-length+[minimum string length (default 3)]:n:' \
  '-output+[output format]:f:(text json)' \
  '-numbers[include duplicated numeric values]' \
  '-min+[lowest numeric value to consider]:n:' \
  '-max+[highest numeric value to consider]:n:' \
  '-find-duplicates[find constants with identical values]' \
  '-match-constant[match strings against existing constants]' \
  '-eval-const-expr[process constant expressions (e.g. concatenation)]' \
  '-ignore+[ignore files matching regex]:re:' \
  '-ignore-strings+[ignore strings matching regex]:re:' \
  '-ignore-tests[ignore tests (default true)]' \
  '-ignore-calls+[skip string literals in listed function calls (comma-separated)]:calls:' \
  '-set-exit-status[exit with code 2 when issues detected]' \
  '-grouped[display one match per line in text output]' \
  '*: :_files' && ret=0

return ret
