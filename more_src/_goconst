#compdef goconst

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-min-occurrences+[min occurrences]:n:' \
  '-min-length+[min string length]:n:' \
  '-max-length+[max string length]:n:' \
  '-output+[output format]:f:(text json)' \
  '-numbers[also check numbers]' \
  '-min+[min number]:n:' \
  '-max+[max number]:n:' \
  '-find-duplicates[find duplicates]' \
  '-ignore+[ignore regex]:re:' \
  '-ignore-tests[ignore tests]' \
  '-match-constant[match consts]' \
  '*: :_files' && ret=0

return ret
