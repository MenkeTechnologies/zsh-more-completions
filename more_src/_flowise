#compdef flowise
# Documentation: https://man.archlinux.org/search?q=flowise
# Reference accessed: 2026-05-16

# Zsh completion for Flowise CLI
# https://github.com/FlowiseAI/Flowise

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:Start the Flowise server'
  'user:Manage user accounts'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'flowise command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start)
        _arguments -s -S \
          '--port=[server port]:port:' \
          '--database=[database type]:type:(sqlite mysql postgres)' \
          '--username=[app-level username]:username:' \
          '--password=[app-level password]:password:' && ret=0
        ;;
      (user)
        _arguments -s -S \
          '--list[list all users]' \
          '--email=[user email]:email:' \
          '--password=[user password]:password:' \
          '--role=[assign role]:role:(ADMIN USER)' && ret=0
        ;;
    esac
    ;;
esac

return ret
