#compdef gittype
# Documentation: https://man.archlinux.org/search?q=gittype
# Reference accessed: 2026-05-16

# https://github.com/unhappychoice/gittype — typing-practice over git history

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::arguments:_default'
