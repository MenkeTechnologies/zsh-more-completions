#compdef courier-pop courier-pop3d courierpop3d
# Documentation: https://www.courier-mta.org/imap/INSTALL.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# courier-pop / pop3d.rc - Courier MTA POP3 daemon rc script.
# Upstream only documents `start` and `stop`; restart/reload/status are
# common rc-script extensions provided by distro packaging.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start daemon'
  'stop:stop daemon'
  'restart:restart daemon'
  'reload:reload configuration'
  'status:show status'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'courier-pop command' commands && ret=0 ;;
esac

return ret
