#compdef orbstat
# Documentation: https://github.com/orbcode/orbuculum
# orbuculum orbstat — ITM trace statistics producing KCacheGrind/dotty callgraph output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-D --no-demangle)'{-D,--no-demangle}'[switch off C++ symbol demangling]' \
  '(-d --del-prefix)'{-d,--del-prefix}'=[material to delete off front of filenames]:prefix:' \
  '(-e --elf-file)'{-e,--elf-file}'=[ELF file to use for symbols]:file:_files' \
  '(-E --eof)'{-E,--eof}'[terminate at end of file when reading from file]' \
  '(-f --input-file)'{-f,--input-file}'=[take input from specified file]:file:_files' \
  '(-g --trace-chn)'{-g,--trace-chn}'=[ITM channel for trace (default 30)]:channel:' \
  '(-I --interval)'{-I,--interval}'=[time to sample in milliseconds]:ms:' \
  '(-n --itm-sync)'{-n,--itm-sync}'[enforce sync requirement for ITM]' \
  '(-M --no-colour --no-color)'{-M,--no-colour,--no-color}'[suppress colour in output]' \
  '(-O --objdump-opts)'{-O,--objdump-opts}'=[options to pass directly to objdump]:opts:' \
  '(-p --protocol)'{-p,--protocol}'=[protocol to communicate (OFLOW or ITM)]:protocol:(OFLOW ITM)' \
  '(-s --server)'{-s,--server}'=[server:port to use]:server:' \
  '(-t --tag)'{-t,--tag}'=[OFLOW stream tag (normally 1)]:tag:' \
  '(-T --all-truncate)'{-T,--all-truncate}'[truncate prefix off all file references]' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3)' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-y --graph-file)'{-y,--graph-file}'=[dotty filename for callgraph output]:file:_files' \
  '(-z --cache-file)'{-z,--cache-file}'=[profile filename for kcachegrind output]:file:_files' && ret=0

return ret
