#compdef difx2mark4
# Documentation: https://difx.readthedocs.io/en/latest/sources/difx_programs.html
# DiFX: convert DiFX correlator output to Mark4 format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information and exit]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-d --difx)'{-d,--difx}'[run on all .difx files in directory]' \
  '(-k --keep-order)'{-k,--keep-order}'[do not sort the antennas by name]' \
  '--override-version[ignore difx version clashes]' \
  '(-r --raw)'{-r,--raw}'[suppress normalization of amplitudes]' \
  '(-p --pretend)'{-p,--pretend}'[do a dry run]' \
  '(-e --experiment-number)'{-e,--experiment-number}'[set experiment number (4 digit)]:n' \
  '-b[override freq band codes (MHz): code flo fhi]:code:_default' \
  '*:base filename:_files' && ret=0

return ret
