#compdef xfishtank
# Documentation: https://man.archlinux.org/search?q=xfishtank
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug]' \
  '-display+[X display]:disp:' \
  '-fish+[number of fish]:n:' \
  '-speed+[speed factor]:n:' \
  '-pause+[pause ms]:ms:' \
  '-bw+[border width]:n:' \
  '-fg+[fg color]:color:' \
  '-bg+[bg color]:color:' \
  '-rv[reverse video]' && ret=0

return ret
