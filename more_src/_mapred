#compdef mapred
# Documentation: https://hadoop.apache.org/docs/stable/hadoop-mapreduce-client/hadoop-mapreduce-client-core/MapredCommands.html
# Run Hadoop MapReduce user and administration commands

local ret=1

_arguments -s -S \
  '--help[shell script usage information]' \
  '--config[overwrite the default configuration directory]:confdir:_files -/' \
  '--debug[enable shell level configuration debugging information]' \
  '--loglevel[override the log level]:level:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--daemon[execute in daemon mode]:mode:(start stop status)' \
  '--buildpaths[enable developer versions of jars]' \
  '--workers[execute this command on all hosts in the workers file]' \
  '--hostnames[override workers file with space-delimited hostnames]:hostnames' \
  '--hosts[override workers file with an alternative hostname file]:file:_files' \
  '1:command:(pipes job queue classpath distcp archive archive-logs version envvars historyserver hsadmin frameworkuploader)' \
  '*:arg:_default' && ret=0

return ret
