#compdef cargo-bundle-licenses
# Documentation: https://crates.io/crates/cargo-bundle-licenses
# generate a THIRDPARTY file with all licenses in a cargo project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --format)'{-f,--format}'[output format]:format:(toml json yaml)' \
  '(-o --output)'{-o,--output}'[file to write output to (- for STDOUT)]:file:_files' \
  '(-p --previous)'{-p,--previous}'[previous thirdparty file to check against]:file:_files' \
  '(-c --check-previous)'{-c,--check-previous}'[check if new is a strict subset of previous]' \
  '--features[additional features to pull dependencies from]:features' \
  '--prefer[preferred licenses when multiple are found]:licenses' && ret=0

return ret
