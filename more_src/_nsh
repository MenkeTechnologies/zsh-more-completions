_nsh() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    case "$service" in
        nsh-core)
            _arguments \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*: :_files' && ret=0
            return ret
            ;;
    esac

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _nsh_cmds=(
                'init:print shell integration code'
                'query:handle a natural language query (? / ?? alias)'
                'record:record a command execution (preexec/precmd hook)'
                'session:session management'
                'history:search command history'
                'reset:clear session conversation context'
                'config:show/edit configuration'
                'cost:show cost/usage statistics'
                'provider:provider management'
                'chat:interactive chat / REPL mode'
                'export:export conversation history'
                'status:show nsh status'
                'completions:generate shell completions'
                'doctor:check and repair nsh database integrity'
                'heartbeat:update session heartbeat'
                'redact-next:skip capturing the next command output'
                'restart:restart the nsh daemon'
                'autoconfigure:auto-detect API keys and configure nsh'
                'autoconfig:auto-detect API keys (alias)'
                'update:self-update nsh to the latest version'
                'memory:manage persistent memory'
                'daemon-send:send a message to the daemon (thin client)'
                'daemon-read:read data from the daemon (synchronous)'
                'cli-proxy:manage the local CLIProxyAPI sidecar'
                'remote:manage remote access (nsh mobile via iroh P2P)'
            )
            _describe -t commands 'nsh command' _nsh_cmds && ret=0
            ;;
        args)
            case $words[1] in
                init)
                    _arguments \
                        '1:shell:(zsh bash fish powershell pwsh cmd)' \
                        '--hash[print only the hook content hash]' && ret=0
                    ;;
                query)
                    _arguments \
                        '--think[enable thinking/reasoning mode]' \
                        '--private[do not store query/response in history]' \
                        '--json[output structured JSON]' \
                        '*: :_files' && ret=0
                    ;;
                session)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'session action' \
                          '(start end label last-cwd suppressed-exit-codes ignore-exit-code)' && ret=0
                    else
                        _arguments \
                            '--session=[session id]:id:' \
                            '--tty=[tty]:tty:' \
                            '--shell=[shell]:shell:(zsh bash fish powershell)' \
                            '--pid=[pid]:pid:' \
                            '--code=[exit code]:code:' \
                            '*: :_files' && ret=0
                    fi
                    ;;
                history)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'history action' '(search)' && ret=0
                    else
                        _arguments \
                            '1:query:' \
                            '--limit=[result limit (default 20)]:n:' && ret=0
                    fi
                    ;;
                config)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'config action' '(path show edit)' && ret=0
                    else
                        _arguments '--raw[show unredacted config (include full API keys)]' && ret=0
                    fi
                    ;;
                cost)
                    _arguments '1:period:(today week month all)' && ret=0
                    ;;
                provider)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'provider action' '(list-local)' && ret=0
                    fi
                    ;;
                export)
                    _arguments \
                        '--format=[output format]:fmt:(markdown json)' \
                        '--session=[session id]:id:' && ret=0
                    ;;
                completions)
                    _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0
                    ;;
                doctor)
                    if (( CURRENT == 2 )) && [[ $words[2] != -* ]]; then
                        _describe -t sub 'doctor action' '(capture)' && ret=0
                    else
                        _arguments \
                            '--no-prune[skip pruning old data]' \
                            '--no-vacuum[skip vacuum]' \
                            '--prune-days=[override retention period (days)]:n:' && ret=0
                    fi
                    ;;
                heartbeat)
                    _arguments '--session=[session id]:id:' && ret=0
                    ;;
                autoconfigure|autoconfig)
                    _arguments \
                        '(-i --interactive)'{-i,--interactive}'[interactive mode]' && ret=0
                    ;;
                memory)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'memory action' \
                          '(search stats core maintain bootstrap clear decay reflect export telemetry)' && ret=0
                    else
                        _arguments \
                            '1:query:' \
                            '--type=[memory type]:type:' \
                            '--limit=[result limit (default 10)]:n:' \
                            '--format=[output format]:fmt:(markdown json)' && ret=0
                    fi
                    ;;
                daemon-send)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'daemon-send action' \
                          '(record heartbeat capture-mark status cli-proxy-ensure cli-proxy-status cli-proxy-restart check-updates)' && ret=0
                    else
                        _arguments \
                            '--session=[session id]:id:' \
                            '--command=[command]:cmd:' \
                            '--cwd=[working directory]:dir:_files -/' \
                            '--exit-code=[exit code]:code:' \
                            '--started-at=[start timestamp]:ts:' \
                            '--duration-ms=[duration in ms]:ms:' \
                            '--tty=[tty]:tty:' \
                            '--pid=[pid]:pid:' \
                            '--shell=[shell]:shell:(zsh bash fish powershell)' && ret=0
                    fi
                    ;;
                daemon-read)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'daemon-read action' '(capture-read scrollback)' && ret=0
                    else
                        _arguments \
                            '--session=[session id]:id:' \
                            '--max-lines=[maximum lines (default 1000)]:n:' && ret=0
                    fi
                    ;;
                cli-proxy)
                    _arguments '1:action:(ensure status restart check-updates)' && ret=0
                    ;;
                remote)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'remote action' \
                          '(pair status revoke discover connect)' && ret=0
                    else
                        case $words[2] in
                            connect)
                                _arguments \
                                    '1:NodeId or nsh:// URI:' \
                                    '--session=[session id to attach]:id:' \
                                    '--relay-url=[relay URL (default https://relay.iroh.network)]:url:' && ret=0
                                ;;
                            revoke)
                                _arguments '1:NodeId prefix:' && ret=0
                                ;;
                        esac
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_nsh "$@"
