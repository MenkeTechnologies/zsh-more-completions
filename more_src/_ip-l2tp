#compdef ip-l2tp
# Documentation: https://man.archlinux.org/man/ip-l2tp.8.en
# ip l2tp - L2TPv3 static tunnel/session configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip l2tp command' \
      'add[create tunnel or session]' 'del[remove tunnel or session]' \
      'show[display tunnel or session]' \
      'tunnel[tunnel object]' 'session[session object]' \
      'tunnel_id[32-bit tunnel identifier]' 'peer_tunnel_id[peer tunnel identifier]' \
      'session_id[session identifier]' 'peer_session_id[peer session identifier]' \
      'remote[remote peer IP]' 'local[local interface IP]' \
      'encap[encapsulation udp or ip]' 'udp_sport[UDP source port]' \
      'udp_dport[UDP destination port]' 'udp_csum[IPv4 UDP checksum]' \
      'udp6_csum_tx[IPv6 UDP transmit checksum]' 'udp6_csum_rx[IPv6 UDP receive checksum]' \
      'name[network interface name]' 'cookie[session cookie]' \
      'peer_cookie[expected peer cookie]' 'l2spec_type[layer2 header type]' \
      'seq[sequence numbering]' 'offset[data offset]' && ret=0
    ;;
esac

return ret
