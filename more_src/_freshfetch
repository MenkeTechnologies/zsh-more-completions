#compdef freshfetch
# freshfetch - Fresh system information tool written in Rust

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to configuration file]:file:_files' \
  '--no-color[disable colored output]' \
  '--no-bold[disable bold text]' \
  '--no-ascii[disable ASCII art]' \
  '--ascii-distro=[show ASCII art for specified distro]:distro:' \
  && ret=0

return ret
