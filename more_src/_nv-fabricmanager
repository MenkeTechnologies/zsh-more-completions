#compdef nv-fabricmanager

# nv-fabricmanager: NVIDIA Fabric Manager service (NVSwitch)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-r[restart]' \
  '--restart[restart]' \
  '-s[stop]' \
  '--stop[stop]' \
  '-f[force restart even without GPU info]' \
  '*::nv-fabricmanager args:_files' && ret=0
return ret
