#compdef BiocManager
# _BiocManager — Bioconductor BiocManager R package and Rscript wrapper for managing Bioconductor packages (Bioconductor team, R); R function
# upstream: https://github.com/Bioconductor/BiocManager

_BiocManager() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-e+[R expression]:str:' \
        '--expr=+[R expression]:str:' \
        '-i[install package]' \
        '--install[install package]' \
        '-u[update packages]' \
        '--update[update packages]' \
        '-c[check valid]' \
        '--valid[check valid]' \
        '-r+[repository url]:url:_urls' \
        '--repos=+[repository url]:url:_urls' \
        '-V+[Bioconductor version]:str:' \
        '--bioc-version=+[Bioconductor version]:str:' \
        '--lib=+[library path]:dir:_files -/' \
        '--update-old[update old]' \
        '--ask=+[bool]:b:(true false)' \
        '--checkBuilt[check built]' \
        '--force[force install]' \
        '--no-vignettes[no vignettes]' \
        '--site-repository=+[url]:url:_urls' \
        '*:package name:'
}

_BiocManager "$@"
