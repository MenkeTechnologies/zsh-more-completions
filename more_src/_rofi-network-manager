#compdef rofi-network-manager
# _rofi-network-manager — rofi-network-manager CLI shell script frontend invoking nmcli through rofi dmenu-style menu listing scanning available SSIDs wired-LAN connections VPN tunnels toggling enable disable connect disconnect rescan WPA-key prompt for the GNOME NetworkManager from desktop launcher (zbaylin team, shell); getopt
# upstream: https://github.com/zbaylin/rofi-network-manager

_rofi-network-manager() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '--rofi-args=+[args]:str:' \
        '--vpn[show VPN menu]' \
        '--wifi[show WiFi menu]' \
        '--ethernet[show Ethernet menu]' \
        '--theme=+[theme]:file:_files -g "*.rasi"' \
        '*::'
}

_rofi-network-manager "$@"
