#compdef dseditgroup
# Documentation: https://www.unix.com/man-page/osx/8/dseditgroup/
# Source: Apple macOS — Directory Services group editor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o[operation]:op:(read create delete edit checkmember)' \
    '-p[prompt for auth password]' \
    '-q[disable interactive verification]' \
    '-v[verbose logging]' \
    '-m[username (with checkmember)]:user:_users' \
    '-n[directory node]:node:(. /Search /LDAPv3)' \
    '-u[admin username for auth]:user:_users' \
    '-P[auth password]:password:' \
    '-a[name of record to add]:name:' \
    '-d[name of record to delete]:name:' \
    '-t[record type]:type:(user group computer)' \
    '-T[group type]:type:' \
    '-L[also maintain ComputerLists]' \
    '-i[gid to add/replace]:gid:' \
    '-g[GUID to add/replace]:guid:' \
    '-S[SID to add/replace]:sid:' \
    '-r[realname to add/replace]:realname:' \
    '-k[keyword to add]:keyword:' \
    '-c[comment to add/replace]:comment:' \
    '-s[seconds to live]:seconds:' \
    '-f[group format]:fmt:(n l)' \
    '*:groupname:_groups' \
    && ret=0

return ret
