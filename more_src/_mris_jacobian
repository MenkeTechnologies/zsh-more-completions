#compdef mris_jacobian
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mris_jacobian/mris_jacobian.help.xml
# Compute the Jacobian of a surface mapping

local ret=1

_arguments -s -S \
  '-log[output the log of the jacobian]' \
  '-noscale[do not scale by total surface area]' \
  '-invert[invert the jacobian]' \
  '*:surface:_files' && ret=0

return ret
