#compdef condor_token_request_list
# _condor_token_request_list — HTCondor condor_token_request_list (server-side: list IDTOKEN requests currently waiting for administrator approval; each row shows reqid, requested identity, ip address, authz list, lifetime, and remaining-time; -name target daemon, -pool collector address)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_request_list on tip.

_condor_token_request_list() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-name+[daemon name]:name:' \
        '-pool+[collector]:host:_hosts'
}

_condor_token_request_list "$@"
