#compdef matrixNormalize
# UCSC kent: normalize a matrix so its columns or rows sum to one or have unit length

local ret=1

_arguments -s -S \
  '-target=[use this target value instead of one for normalizing]:val' \
  '-serial[disable use of pthreads parallelization]' \
  '1:direction:(row column)' \
  '2:how:(sum length)' \
  '3:input matrix:_files' \
  '4:output matrix:_files' && ret=0

return ret
