#compdef genePredToProt
# UCSC kent: create protein sequences from genePred records

local ret=1

_arguments -s -S \
  '-cdsFa=[output FASTA with CDS used to generate protein]:file:_files' \
  '-protIdSuffix=[add this string to the end of the name for protein FASTA]:str' \
  '-cdsIdSuffix=[add this string to the end of the name for CDS FASTA]:str' \
  '-translateSeleno[assume internal TGA is selenocysteine and translate to U]' \
  '-includeStop[represent a terminal stop codon as a *]' \
  '-starForInframeStops[use * instead of X for in-frame stop codons]' \
  '1:genePred file:_files' \
  '2:genome 2bit:_files -g "*.2bit"' \
  '3:protein fasta out:_files' && ret=0

return ret
