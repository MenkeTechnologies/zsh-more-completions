#compdef paq8px
# _paq8px — experimental high-end lossless compressor (hxim/paq8px)
# upstream: https://github.com/hxim/paq8px
# Flags from README.md "Usage" section.

_paq8px() {
    _arguments \
        '(- *)-help[show detailed help]' \
        '(-d -t -l)-d[decompress an archive]' \
        '(-d -t -l)-t[test an archive (decompress to /dev/null)]' \
        '(-d -t -l)-l[list archive contents]' \
        '-0[no compression (transform/segment only)]' \
        '-0L[LSTM-only compression]' \
        '-1[level 1 (~558 MB)]' \
        '-2[level 2 (~572 MB)]' \
        '-3[level 3 (~602 MB)]' \
        '-4[level 4 (~660 MB)]' \
        '-5[level 5 (~776 MB)]' \
        '-6[level 6 (~1010 MB)]' \
        '-7[level 7 (~1476 MB)]' \
        '-8[level 8 (~2408 MB)]' \
        '-9[level 9 (~4273 MB)]' \
        '-10[level 10 (~8003 MB)]' \
        '-11[level 11 (~15463 MB)]' \
        '-12[level 12 (~29358 MB)]' \
        '-forcebinary[force generic binary mode]' \
        '-forcetext[force text mode]' \
        '-lstmlayers=[LSTM layer count (1-5)]:n:(1 2 3 4 5)' \
        '-savelstm\:text+[save LSTM weights]:file:_files' \
        '-loadlstm\:text+[load LSTM weights]:file:_files' \
        '-v[verbose output]' \
        '-log+[append results to log file]:file:_files' \
        '-simd+[override SIMD detection]:mode:(NONE SSE2 SSE3 SSE41 AVX2 AVX512 NEON)' \
        '1:input file or @filelist:_files' \
        '2:output:_files'
}

_paq8px "$@"
