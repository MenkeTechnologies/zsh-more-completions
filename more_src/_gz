#compdef gz
# Documentation: https://gazebosim.org/docs
# Gazebo command line tool dispatcher

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--force-version=[use a specific library version]:version' \
  '--commands[list all available commands]' \
  '--versions[show available versions for a command]' \
  '1:command:(sim topic service model log sdf fuel launch param plugin msg)' \
  '*::args:_normal' && ret=0

return ret
