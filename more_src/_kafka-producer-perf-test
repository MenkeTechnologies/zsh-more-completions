#compdef kafka-producer-perf-test

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to produce to]:topic:'
    '--num-records[Number of records to send]:count:'
    '--record-size[Record size in bytes]:bytes:'
    '--payload-file[File to read payloads from]:file:_files'
    '--payload-delimiter[Delimiter for payload file]:delimiter:'
    '--throughput[Throttle maximum message throughput per second (-1 for no limit)]:throughput:'
    '--producer-props[Producer properties as key=value pairs]:properties:'
    '--producer.config[Producer config properties file]:file:_files'
    '--print-metrics[Print out metrics at the end of the test]'
    '--transactional-id[Transactional ID for transactional producing]:id:'
    '--transaction-duration-ms[Max age of each transaction in ms]:ms:'
)

_arguments -s -S $arguments
