#compdef uncover

# Zsh completion for ProjectDiscovery Uncover - search engine wrapper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*-q+[search query]:query' \
  '*-e+[search engine]:engine:(shodan censys fofa hunter quake zoomeye netlas criminalip)' \
  '-l+[limit results]:limit' \
  '-o+[output file]:file:_files' \
  '-f+[fields to display]:fields' \
  '-json[output as JSON]' \
  '-raw[show raw API response]' \
  '-silent[show only results]' \
  '-nc[disable colors in output]' \
  '-timeout+[timeout in seconds]:seconds' \
  '-delay+[delay between requests in seconds]:seconds' \
  '-retry+[number of retries]:retries' \
  '-v[show verbose output]' \
  && ret=0

return ret
