#compdef cwb-make
# Documentation: https://cwb.sourceforge.io/documentation.php
# Automated indexing and compression for IMS Corpus Workbench corpora

local ret=1

_arguments -s -S \
  '-r[use registry directory instead of standard registry]:dir:_files -/' \
  '-M[set memory limit in MiB for indexing]:mb' \
  '-V[validate newly created data files]' \
  '-D[activate debugging output]' \
  '-p[set group membership and access permissions of new data files]:perm' \
  '*:corpus:' && ret=0

return ret
