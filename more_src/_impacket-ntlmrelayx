#compdef impacket-ntlmrelayx
# Documentation: https://man.archlinux.org/search?q=impacket-ntlmrelayx
# Reference accessed: 2026-05-16

# impacket-ntlmrelayx: NTLM relay attack server
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -tf[targets file]:file:_files -t[single target]:target: -w[watch hosts] -i[interactive shell on success] -e[execute command]:cmd: -enum-local-admins[enumerate local admins] -of[output file]:file:_files -socks[run a socks proxy] -smb2support[enable SMB2] -port[listen port]:port: -no-multirelay[no multi-relay] -no-acl[no ACL operations] -no-validate-pcaps[skip pcap validation] -delegate-access[delegate access via RBCD] -escalate-user[escalate this user]:user: -add-computer[add computer]:name: \
  '*::impacket-ntlmrelayx args:_files' && ret=0
return ret
