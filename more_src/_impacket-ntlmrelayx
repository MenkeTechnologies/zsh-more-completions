#compdef impacket-ntlmrelayx

# Impacket ntlmrelayx.py: NTLM relay to many target services
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-ts[timestamps]' \
  '-t[single target host]:target:' \
  '-tf[target file]:file:_files' \
  '-w[watch target file for changes]' \
  '-i[install shell on target]' \
  '-l[loot directory]:dir:_files -/' \
  '-of[output file]:file:_files' \
  '-codec[encoding]:codec:' \
  '-smb2support[advertise SMB2]' \
  '-ntlmchallenge[NTLM server challenge]:hex:' \
  '-socks[start SOCKS proxy]' \
  '-http-port[HTTP relay port]:port:' \
  '-smb-port[SMB relay port]:port:' \
  '-wcf-port[WCF relay port]:port:' \
  '-raw-port[raw relay port]:port:' \
  '-rpc-port[RPC relay port]:port:' \
  '-rpc-mode[RPC mode]:mode:' \
  '-c[execute given command on target]:cmd:' \
  '-e[execute given local file on target]:file:_files' \
  '-no-smb-server[disable SMB server]' \
  '-no-http-server[disable HTTP server]' \
  '-no-wcf-server[disable WCF server]' \
  '-no-raw-server[disable raw server]' \
  '-no-rpc-server[disable RPC server]' \
  '-no-multirelay[disable multirelay (single target)]' \
  '-no-da[skip DA enumeration]' \
  '-no-acl[skip ACL enumeration]' \
  '-no-validate-pwd[skip credential validation]' \
  '-escalate-user[user to escalate (LDAP)]:user:' \
  '-add-computer[add new computer account]:name:' \
  '-delegate-access[grant delegated access]' \
  '-machine-account[machine account name (RBCD)]:name:' \
  '-machine-pass[machine account password]:pwd:' \
  '-target-domain[target domain for AD CS]:domain:' \
  '-domain[domain]:domain:' \
  '-ip[network IP to bind]:ip:' \
  '-6[allow IPv6 connections]' \
  '*::ntlmrelayx args:_files' && ret=0
return ret
