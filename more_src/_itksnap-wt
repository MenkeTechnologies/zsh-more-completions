#compdef itksnap-wt
# Documentation: http://www.itksnap.org/pmwiki/pmwiki.php?n=Documentation.CommandLine
# itksnap-wt - ITK-SNAP workspace tool: create and modify .itksnap workspaces

local ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-version[print version information]' \
  '-i[read a workspace file]:workspace:_files -g "*.itksnap"' \
  '-o[write the workspace to a file]:workspace out:_files -g "*.itksnap"' \
  '-dump[dump the workspace registry to stdout]' \
  '-registry-get[get a value from the workspace registry]:key:' \
  '-registry-set[set a value in the workspace registry]:key value:' \
  '-layers-list[list all layers in the workspace]' \
  '-layers-list-files[list layers with their file names]' \
  '-layers-set-main[set the main image layer]:image:_files -g "*.{nii,nii.gz,mhd,mha,img,hdr}"' \
  '-layers-add-anat[add an additional anatomical image layer]:image:_files -g "*.{nii,nii.gz,mhd,mha,img,hdr}"' \
  '-layers-add-seg[add a segmentation image layer]:segmentation:_files -g "*.{nii,nii.gz,mhd,mha,img,hdr}"' \
  '-layers-set-seg[set the segmentation image layer]:segmentation:_files -g "*.{nii,nii.gz,mhd,mha,img,hdr}"' \
  '-layers-add-mesh[add a mesh layer]:mesh:_files -g "*.{vtk,vtp,obj,stl}"' \
  '-layers-pick[select a layer by id for subsequent commands]:layer id:' \
  '-layers-pick-by-tag[select a layer by tag for subsequent commands]:tag:' \
  '-labels-set[set the label description file]:label file:_files' \
  '-labels-add[add labels from a description file]:label file:_files' \
  '-labels-clear[clear all labels]' \
  '-tags-add[add a tag to the selected layer]:tag:' \
  '-tags-add-exclusive[add a tag, removing it from other layers]:tag:' \
  '-tags-delete[delete a tag from the selected layer]:tag:' \
  '-props-get-filename[print the file name of the selected layer]' \
  '-props-rename-file[change the file name of the selected layer]:new name:_files' \
  '-props-set-nickname[set the nickname of the selected layer]:nickname:' \
  '-props-set-colormap[set the colormap of the selected layer]:colormap:' \
  '-props-set-contrast[set the contrast of the selected layer]:contrast:' \
  '-props-set-transform[set the affine transform of the selected layer]:transform:_files' \
  '-props-get-transform[print the affine transform of the selected layer]' \
  '-props-registry-get[get a registry value for the selected layer]:key:' \
  '-props-registry-set[set a registry value for the selected layer]:key value:' \
  '-props-registry-dump[dump the registry of the selected layer]' \
  '-annot-list[list annotations in the workspace]' \
  '-timepoints-list[list time points in the workspace]' \
  '-timepoints-pick-by-name[select a time point by name]:name:' \
  '-timepoints-pick-by-tag[select a time point by tag]:tag:' \
  '-dss-auth[authenticate with a distributed segmentation service]:url:' \
  '-dss-services-list[list available DSS services]' \
  '-dss-services-detail[show details for a DSS service]:service:' \
  '-dss-tickets-create[create a DSS ticket]:service:' \
  '-dss-tickets-list[list DSS tickets]' \
  '-dss-tickets-log[show the log of a DSS ticket]:ticket:' \
  '-dss-tickets-progress[show progress of a DSS ticket]:ticket:' \
  '-dss-tickets-wait[wait for a DSS ticket to complete]:ticket:' \
  '-dss-tickets-download[download results of a DSS ticket]:ticket:' \
  '-dss-tickets-delete[delete a DSS ticket]:ticket:' \
  '*:workspace:_files -g "*.itksnap"' && ret=0

return ret
