#compdef upctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'account:account settings billing permissions tokens'
  'audit-log:export audit logs'
  'database:managed databases'
  'file-storage:file storage resources'
  'gateway:network gateways'
  'host:physical host info'
  'ip-address:IP address assignments'
  'kubernetes:managed Kubernetes clusters'
  'load-balancer:load balancer services'
  'network:virtual networks'
  'network-peering:network peering connections'
  'object-storage:buckets and access keys'
  'partner:partner account management'
  'router:virtual routers'
  'server:cloud servers'
  'server-group:logical server groupings'
  'stack:application stacks'
  'storage:block storage volumes'
  'version:print upctl version'
  'zone:available zones'
)

_arguments -C \
  '--config=[config file]:file:_files' \
  '(-o --output)'{-o,--output=}'[output format]:fmt:(human json yaml)' \
  '--debug[verbose debug logs]' \
  '--wait[wait for operation]' \
  '--client-timeout=[client timeout]:duration:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'upctl subcommand' subcommands && ret=0
    ;;
esac

return ret
