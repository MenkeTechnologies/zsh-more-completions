#compdef extractbb ebb
# Documentation: extractbb --help (TeX Live 2026 dvipdfmx)
# Source: extract bounding box from PDF/PNG/JPEG/JP2/BMP for DVIPDFM(x). `ebb` invokes the same binary.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[output version information]' \
    '-B[PDF pagebox for bounding box]:pagebox:(cropbox mediabox artbox trimbox bleedbox)' \
    '-p[PDF page to extract bounding box]:page number:' \
    '(-v)-q[be quiet]' \
    '(-q)-v[be verbose]' \
    '-O[write output to stdout]' \
    '(-x)-m[output .bb file used in DVIPDFM (default)]' \
    '(-m)-x[output .xbb file used in DVIPDFMx]' \
    '*:image file:_files -g "*.(pdf|png|jpg|jpeg|jp2|bmp)"' \
    && ret=0

return ret
