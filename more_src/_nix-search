#compdef nix-search
# Documentation: https://man.archlinux.org/search?q=nix-search
# Reference accessed: 2026-05-16

# https://github.com/peterldowns/nix-search-cli — client for search.nixos.org

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-c --channel)'{-c,--channel}'=[Nixpkgs channel]:channel:(unstable nixos-unstable nixos-23.11 nixos-24.05 nixos-24.11)' \
  '(-d --details)'{-d,--details}'[expanded details per result]' \
  '(-f --flakes)'{-f,--flakes}'[search flakes index instead of nixpkgs]' \
  '(-j --json)'{-j,--json}'[JSON lines output]' \
  '(-m --max-results)'{-m,--max-results}'=[max results]:count:' \
  '(-n --name)'{-n,--name}'=[filter by package attribute name]:pattern:' \
  '(-p --program)'{-p,--program}'=[filter by installed program name]:pattern:' \
  '(-q --query-string)'{-q,--query-string}'=[Elasticsearch query_string query]:query:' \
  '(-r --reverse)'{-r,--reverse}'[reverse result order]' \
  '(-s --search)'{-s,--search}'=[default search string (web-style)]:query:' \
  '(-v --version)'{-v,--version}'=[filter by version]:version:' \
  '*::free_text_query:' && return 0
