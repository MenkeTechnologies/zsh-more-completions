#compdef tigera-operator
# _tigera-operator — Tigera Operator for Calico (tigera/operator)
# upstream: https://github.com/tigera/operator
# Flags from cmd/main.go on tip.

_tigera-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version information]' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--url-only-kubeconfig=[kubeconfig path used only for apiserver URL]:file:_files' \
        '--print-images=[print default deploy images and exit]:mode:(list)' \
        '--aws-sg-setup[setup AWS Security Groups (OpenShift only)]' \
        '--manage-crds[manage projectcalico.org and operator.tigera.io CRDs]' \
        '--pre-delete[run Helm pre-delete logic then exit]' \
        '--bootstrap-crds[install CRDs and exit]' \
        '--variant=[default product variant]:variant:(Calico Enterprise)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_tigera-operator "$@"
