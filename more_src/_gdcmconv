#compdef gdcmconv
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmconv.cxx — DICOM file converter (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input DICOM file]:file:_files -g "*.{dcm,DCM,dicom}"' \
    '(-o --output)'{-o+,--output=}'[output DICOM file]:file:_files' \
    '(-X --explicit)'{-X,--explicit}'[change TransferSyntax to explicit]' \
    '(-M --implicit)'{-M,--implicit}'[change TransferSyntax to implicit]' \
    '(-U --use-dict)'{-U,--use-dict}'[use dict for VR (public only)]' \
    '--with-private-dict[use private dict for VR]' \
    '(-C --check-meta)'{-C,--check-meta}'[check File Meta Information]' \
    '--root-uid=[Root UID]:uid:_default' \
    '--remove-gl[remove group length (deprecated in DICOM 2008)]' \
    '--remove-private-tags[remove private tags]' \
    '--remove-retired[remove retired tags]' \
    '(-l --apply-lut)'{-l,--apply-lut}'[apply LUT]' \
    '(-8 --apply-lut8)'{-8,--apply-lut8}'[apply LUT/RGB8]' \
    '--decompress-lut[decompress (linearize) segmented LUT]' \
    '(-P --photometric-interpretation)'{-P+,--photometric-interpretation=}'[change Photometric Interpretation]:pi:(MONOCHROME1 MONOCHROME2 PALETTE\ COLOR RGB YBR_FULL YBR_FULL_422 YBR_PARTIAL_422 YBR_PARTIAL_420 YBR_ICT YBR_RCT)' \
    '(-w --raw)'{-w,--raw}'[decompress image]' \
    '(-d --deflated)'{-d,--deflated}'[compress using deflate (gzip)]' \
    '(-J --jpeg)'{-J,--jpeg}'[compress image as JPEG]' \
    '(-K --j2k)'{-K,--j2k}'[compress image as JPEG2000]' \
    '(-L --jpegls)'{-L,--jpegls}'[compress image as JPEG-LS]' \
    '(-R --rle)'{-R,--rle}'[compress image as RLE (lossless)]' \
    '(-F --force)'{-F,--force}'[force decompression/merging before recompression]' \
    '--generate-icon[generate icon]' \
    '--icon-minmax=[icon min,max value]:minmax:_default' \
    '--icon-auto-minmax[auto-compute icon min/max]' \
    '--compress-icon[icon follows main TransferSyntax]' \
    '--planar-configuration=[planar config]:n:(0 1)' \
    '(-Y --lossy)'{-Y,--lossy}'[use lossy compressor (if possible)]' \
    '(-S --split)'{-S+,--split=}'[max fragment size for 2D image]:n:_default' \
    '(-V --verbose)'{-V,--verbose}'[verbose (warning+error)]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '--quiet[suppress stdout]' \
    '(-q --quality)'{-q+,--quality=}'[JPEG quality]:n:_default' \
    '(-e --allowed-error)'{-e+,--allowed-error=}'[JPEG-LS allowed error]:n:_default' \
    '(-r --rate)'{-r+,--rate=}'[J2K rate]:n:_default' \
    '1::input file:_files -g "*.{dcm,DCM,dicom}"' \
    '2::output file:_files' \
    && ret=0

return ret
