#compdef ansible-inventory
# _ansible-inventory — Ansible inventory (display the resolved inventory from any combination of static/dynamic sources; --list dumps full JSON, --graph prints group tree, --host limits to one host's vars, --yaml emits YAML, --vars includes hostvars)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/inventory.py)
# Flags from ansible cli/inventory.py on tip.

_ansible-inventory() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '*-v[verbose]' \
        '-i+[inventory source]:inventory:_files' \
        '--list[dump full inventory as JSON]' \
        '--graph[print group tree]' \
        '--host+[show vars for one host]:host:' \
        '--vars[include host vars]' \
        '--yaml[output YAML]' \
        '--toml[output TOML]' \
        '--output+[write to file]:file:_files' \
        '--export[respect inventory plugin order]' \
        '-l+[limit hosts]:limit:' \
        '-e+[extra vars]:key=value:' \
        '--playbook-dir+[playbook dir]:dir:_files -/'
}

_ansible-inventory "$@"
