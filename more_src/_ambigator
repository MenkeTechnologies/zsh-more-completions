#compdef ambigator
# Documentation: https://www.desy.de/~twhite/crystfel/manual-ambigator.html
# Resolve indexing ambiguities in serial crystallography data (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-o --output)'{-o+,--output=}'[write re-indexed stream to file]:file:_files' \
  '(-y --symmetry)'{-y+,--symmetry=}'[actual symmetry of crystals]:pg:' \
  '-w+[apparent symmetry for ambiguity operator]:pg:' \
  '--operator=[indexing ambiguity operator]:op:' \
  '(-n --iterations)'{-n+,--iterations=}'[number of passes]:n:' \
  '-j+[threads for CC calculation]:n:' \
  '--highres=[high resolution cutoff in Angstroms]:d:' \
  '--lowres=[low resolution cutoff in Angstroms]:d:' \
  '--start-assignments=[read initial assignments]:file:_files' \
  '--end-assignments=[write final assignments]:file:_files' \
  '--fg-graph=[output f and g values for plotting]:file:_files' \
  '--ncorr=[max correlations per crystal]:n:' \
  '--really-random[seed RNG from /dev/urandom]' \
  '--corr-matrix=[write correlation matrices in HDF5]:file:_files' \
  '*:stream:_files' && ret=0

return ret
