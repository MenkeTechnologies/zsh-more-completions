#compdef bashreadline bashreadline-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/bashreadline.py argparse)
# Reference accessed: 2026-05-29
# bashreadline — print bash commands system-wide via readline() uprobe (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-s --shared)'{-s,--shared=}'[location of libreadline.so (default /lib/libreadline.so)]:file:_files -g "*.(so|so.*)"' \
  && ret=0

return ret
