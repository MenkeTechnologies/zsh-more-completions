#compdef muse muse4 muse3 muse2
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/muse.1.html
# Reference accessed: 2026-05-19
# Verified: upstream Ubuntu manpage at the URL above and Arch muse4(1).

# MusE Sequencer: digital audio workstation (MIDI + audio)
local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-v[print version]' \
  '-a[use dummy audio backend instead of real audio I/O]' \
  '-d[debugging mode without real-time threads]' \
  '-D[verbose debugging messages]' \
  '-I[do not load DSSI plugins]' \
  '-l+[force locale (language/country code)]:locale:' \
  '-L[do not use LASH]' \
  '-m[debugging messages about MIDI input events]' \
  '-M[debugging messages about MIDI output events]' \
  '-p[do not load LADSPA plugins]' \
  '-P+[scheduling priority of real-time threads]:prio:' \
  '-s[debugging messages about sync events]' \
  '-V[do not load VST plugins]' \
  '-y[enable Python control support]' \
  '-Y+[force MIDI real-time priority]:prio:' \
  '*:project:_files -g "*.(med|mscz|mscx)"' && ret=0

return ret
