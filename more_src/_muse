#compdef muse muse4 muse3 muse2

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[no audio]' \
  '-A[use ALSA midi]' \
  '-J[use JACK audio]' \
  '-Y+[force JACK device]:dev:' \
  '-y[no JACK]' \
  '-P+[realtime priority]:prio:' \
  '-R[realtime mode]' \
  '-S[start clean]' \
  '-D[debug]' \
  '-d+[debug level]:lvl:' \
  '-i[ignore version]' \
  '-l+[locale]:locale:' \
  '-p[do not load plugins]' \
  '-u[unique title bar]' \
  '*:project:_files -g "*.med"' && ret=0

return ret
