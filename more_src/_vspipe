#compdef vspipe
# Documentation: https://www.vapoursynth.com/doc/output.html
# vspipe — VapourSynth pipe output / script evaluator

local ret=1

_arguments -s -S \
  '(-a --arg)'{-a,--arg}'[argument to pass to the script environment (key=value)]:arg' \
  '(-s --start)'{-s,--start}'[set output frame range first frame]:frame' \
  '(-e --end)'{-e,--end}'[set output frame range last frame]:frame' \
  '(-o --outputindex)'{-o,--outputindex}'[select output index]:index' \
  '(-r --requests)'{-r,--requests}'[number of concurrent frame requests]:n' \
  '(-c --container)'{-c,--container}'[add headers for the specified format]:format:(y4m wav w64)' \
  '(-t --timecodes)'{-t,--timecodes}'[write timecodes v2 file]:file:_files' \
  '(-p --progress)'{-p,--progress}'[print progress to stderr]' \
  '--filter-time[record the time spent in each filter]' \
  '(-i --info)'{-i,--info}'[show video info and exit]' \
  '(-g --graph)'{-g,--graph}'[print output node filter graph in dot format]:type:(simple full)' \
  '(-v --version)'{-v,--version}'[show version info and exit]' \
  '*:file:_files' && ret=0

return ret
