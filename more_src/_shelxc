#compdef shelxc
# Documentation: http://shelx.uni-goettingen.de/shelxc_keywords.php
# SHELXC - prepare experimental phasing data for SHELXD/SHELXE (SAD/MAD/SIR/SIRAS/RIP)

local ret=1

_arguments -s -S \
  '*:keyword:(SAD NAT SIR SIRAS PEAK INFL HREM LREM BEFORE AFTER RIP RIPAS CELL SPAG MAXM DSCA ASCA SMAD RIPW SHEL SFAC ESEL FIND MIND DSUL NTRY REM)' && ret=0

return ret
