#compdef fastANI fastani
# _fastani — Pavel Senin Aleksey Zimin fastANI CLI fast Average Nucleotide Identity ANI computation between bacterial archaeal genome assemblies using Mashmap minimizer-based alignment-free approximate-mapping for 100x speedup over BLAST-based ANIb pairwise many-to-many querytarget mode (Pavel Senin team, C++); getopt
# upstream: https://github.com/ParBLiSS/FastANI

_fastani() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q+[query genome]:file:_files -g "*.fa *.fasta *.fna *.fas"' \
        '--query=+[file]:file:_files -g "*.fa *.fasta *.fna *.fas"' \
        '-r+[reference genome]:file:_files -g "*.fa *.fasta *.fna *.fas"' \
        '--ref=+[file]:file:_files -g "*.fa *.fasta *.fna *.fas"' \
        '--ql+[query list file]:file:_files' \
        '--rl+[reference list file]:file:_files' \
        '-k+[kmer size]:n:' \
        '--kmer=+[N]:n:' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '--fragLen=+[N]:n:' \
        '--minFraction=+[N]:n:' \
        '--matrix[output matrix]' \
        '--visualize[output mash visualization]' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '*::'
}

_fastani "$@"
