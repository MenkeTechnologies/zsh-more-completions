#compdef clipcatd
# Documentation: https://github.com/xrelkd/clipcat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon]' \
  '--no-daemon[do not run as a daemon]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '--grpc-host=[gRPC host address]:host' \
  '--grpc-port=[gRPC port]:port' \
  '--log-level=[set log level]:level:(error warn info debug trace)' \
  '(-r --replace)'{-r,--replace}'[replace running instance]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' && ret=0

return ret
