#compdef arm-none-eabi-strip
# _arm-none-eabi-strip — Arm Limited arm-none-eabi-strip CLI for the bare-metal ARM cross-strip removing debug symbols sections preserving entry points keep-symbol unneeded-symbols suffix output in-place (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-strip() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-I+[input format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '--input-target=+[input format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '-O+[output format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '--output-target=+[output format]:f:(binary ihex srec elf32-littlearm elf32-bigarm)' \
        '-F+[both format]:f:(binary ihex srec elf32-littlearm)' \
        '-K+[symbol]:str:' \
        '--keep-symbol=+[symbol]:str:' \
        '-N+[symbol]:str:' \
        '--strip-symbol=+[symbol]:str:' \
        '-s[strip all]' \
        '--strip-all[strip all]' \
        '-g[strip debug]' \
        '--strip-debug[strip debug]' \
        '-S[strip debug]' \
        '-d[strip debug]' \
        '--strip-unneeded[strip unneeded]' \
        '--only-keep-debug[only keep debug]' \
        '-x[discard all locals]' \
        '--discard-all[discard all locals]' \
        '-X[discard locals]' \
        '--discard-locals[discard locals]' \
        '-R+[section]:str:' \
        '--remove-section=+[section]:str:' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-p[preserve dates]' \
        '--preserve-dates[preserve dates]' \
        '*:input files:_files'
}

_arm-none-eabi-strip "$@"
