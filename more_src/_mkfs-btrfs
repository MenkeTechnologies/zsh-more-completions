#compdef mkfs-btrfs mkfs.btrfs
# _mkfs-btrfs — mkfs.btrfs Btrfs filesystem creation CLI (kdave / Btrfs team, C); custom argparse
# upstream: https://github.com/kdave/btrfs-progs

_mkfs-btrfs() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A+[alloc start]:n:' \
        '--alloc-start=+[alloc start]:n:' \
        '-b+[byte count]:n:' \
        '--byte-count=+[byte count]:n:' \
        '-c+[compress]:c:(zlib lzo zstd no)' \
        '-d+[data profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 single dup)' \
        '--data=+[data profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 single dup)' \
        '-m+[metadata profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 single dup)' \
        '--metadata=+[metadata profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 single dup)' \
        '-M[mixed data/metadata]' \
        '--mixed[mixed data/metadata]' \
        '-l+[leaf size]:n:' \
        '--leafsize=+[leaf size]:n:' \
        '-n+[node size]:n:' \
        '--nodesize=+[node size]:n:' \
        '-s+[sector size]:n:' \
        '--sectorsize=+[sector size]:n:' \
        '-L+[label]:str:' \
        '--label=+[label]:str:' \
        '-K[do not discard]' \
        '--nodiscard[do not discard]' \
        '-r+[populate from rootdir]:dir:_files -/' \
        '--rootdir=+[populate from rootdir]:dir:_files -/' \
        '--shrink[shrink to fit rootdir]' \
        '-O+[features csv]:list:(extref skinny-metadata no-holes free-space-tree raid56 quota mixed-bg compress-zstd raid1c34 no-checksum)' \
        '--features=+[features csv]:list:' \
        '-U+[uuid]:str:' \
        '--uuid=+[uuid]:str:' \
        '-T+[device uuid]:str:' \
        '--device-uuid=+[device uuid]:str:' \
        '--csum=+[checksum]:c:(crc32c xxhash sha256 blake2)' \
        '--checksum=+[checksum]:c:(crc32c xxhash sha256 blake2)' \
        '-f[force]' \
        '--force[force]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-R+[runtime features]:list:' \
        '--runtime-features=+[runtime features]:list:' \
        '*:device:_files'
}

_mkfs-btrfs "$@"
