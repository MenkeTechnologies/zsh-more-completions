#compdef tcaf gmx-tcaf
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-tcaf.html
# gmx tcaf: calculate viscosities of liquids

local ret=1

_arguments -s \
  '-f[full precision trajectory file]:file:_files' \
  '-s[structure+mass(db) file]:file:_files' \
  '-n[index file]:file:_files' \
  '-ot[transverse current output]:file:_files' \
  '-oa[all TCAFs output]:file:_files' \
  '-o[TCAF output]:file:_files' \
  '-of[TCAF fit output]:file:_files' \
  '-oc[cubic TCAF output]:file:_files' \
  '-ov[viscosity vs k-vector output]:file:_files' \
  '-b[first frame time]:time:' \
  '-e[last frame time]:time:' \
  '-dt[frame selection interval]:time:' \
  '-w[view output files]' \
  '-xvg[plot format]:format:(xmgrace xmgr none)' \
  '-mol[calculate molecular TCAF]' \
  '-k34[include k=(3,0,0) and k=(4,0,0)]' \
  '-wt[decay time for fit weights]:real:' \
  '-acflen[ACF length]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[fit function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[fit start time]:real:' \
  '-endfit[fit end time]:real:' && ret=0

return ret
