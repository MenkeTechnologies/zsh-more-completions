#compdef duperemove

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --recurse)'{-r,--recurse}'[recurse into directories]' \
  '(-d --dedupe)'{-d,--dedupe}'[deduplicate extents]' \
  '(-A --partial)'{-A,--partial}'[enable partial extent deduplication]' \
  '--hashfile=[store hashes in file]:file:_files' \
  '-b[block size]:size' \
  '--blocksize=[block size]:size' \
  '--io-threads=[number of I/O threads]:threads' \
  '--cpu-threads=[number of CPU threads]:threads' \
  '--dedupe-options=[dedupe options]:options:(same partial nofiemap nosame noblock)' \
  '-h[human readable sizes]' \
  '--lookup-extents=[lookup extents]:type:(always never auto)' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '-v[verbose output]' \
  '--debug[debug output]' \
  '--help[show help]' \
  '--read-hashes=[read hashes from file]:file:_files' \
  '--write-hashes=[write hashes to file]:file:_files' \
  '--skip-zeroes[skip zero-filled extents]' \
  '--fdupes[read file list like fdupes]' \
  '--batch[batch extent sharing]' \
  '*:file or directory:_files' && ret=0

return ret
