#compdef lxd-to-incus
# Documentation: https://www.mankier.com/1/lxd-to-incus
# convert an existing LXD installation into an Incus one

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--cluster-member[used internally for cluster migrations]' \
  '--ignore-version-check[bypass source version check]' \
  '--version[print version number]' \
  '--yes[migrate without prompting]' && ret=0

return ret
