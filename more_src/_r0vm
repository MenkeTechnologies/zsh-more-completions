#compdef r0vm
# Documentation: https://raw.githubusercontent.com/risc0/risc0/main/risc0/r0vm/src/lib.rs
# Reference accessed: 2026-05-27
# Verified: upstream Cli struct in risc0/r0vm/src/lib.rs (clap attribute list)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '*'{-v,--verbose}'[increase verbosity (repeat for more)]' \
  '--rpc[start an RPC server instead of executing a program]' \
  '--actor-status=[actor allocator RPC port]:port:' \
  '--elf=[path to the guest ELF binary to execute]:file:_files' \
  '--image=[path to a pre-built executable image]:file:_files' \
  '--segment=[path to a pre-recorded segment file]:file:_files' \
  '--config=[path to a configuration file]:file:_files' \
  '--receipt=[output file for the generated receipt]:file:_files' \
  '--hashfn=[hash function used for proof generation]:hashfn:(sha-256 poseidon2)' \
  '--prove-guest-errors[include guest error executions in generated proofs]' \
  '--initial-input=[path to initial input file (stdin if absent)]:file:_files' \
  '*--env=[environment variable for the guest (NAME=value)]:env:' \
  '--pprof-out=[write pprof profiler output to this file]:file:_files' \
  '--receipt-kind=[receipt format kind]:kind:(composite succinct groth16)' \
  '--id=[compute the image_id for the given ELF]' \
  '--kernel-id=[compute the kernel image_id for the given ELF]' \
  '--with-debugger[enable debugger mode]' \
  '--addr=[network connection or listen address]:addr:' \
  '--api=[API server address]:addr:' \
  '--storage=[storage path]:dir:_files -/' \
  '--po2=[power-of-two segment size parameter]:po2:' \
  '--num-gpus=[number of GPUs to use]:n:' && ret=0

return ret
