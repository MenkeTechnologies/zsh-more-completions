#compdef htlatex htxelatex htlualatex mzlatex uhtmex
# Documentation: htlatex / tex4ht launcher script
# Source: TeX tex4ht — LaTeX -> HTML/XML launcher.
# Reference accessed: 2026-06-10
# NOTE: htlatex expects 4 quoted argument strings:
#   FILENAME "tex4ht.sty op" "tex4ht op" "t4ht op" "latex op"

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:LaTeX input file:_files -g "*.tex"' \
    '2:tex4ht.sty options:' \
    '3:tex4ht options:' \
    '4:t4ht options:' \
    '5:latex options:' \
    && ret=0

return ret
