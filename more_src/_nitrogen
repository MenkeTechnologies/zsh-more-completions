#compdef nitrogen

# Zsh completion for nitrogen - X11 wallpaper setter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--force-setter=[force wallpaper setter]:setter:(xwindows xinerama gnome)' \
  '--head=[select head for wallpaper]:head:' \
  '--no-recurse[do not recurse into subdirectories]' \
  '--restore[restore previously saved wallpapers]' \
  '--save[save current wallpaper settings]' \
  '--set-auto=[set wallpaper automatically]:file:_files -g "*.{png,jpg,jpeg,bmp,gif,svg,tiff}"' \
  '--set-centered=[set centered wallpaper]:file:_files -g "*.{png,jpg,jpeg,bmp,gif,svg,tiff}"' \
  '--set-scaled=[set scaled wallpaper]:file:_files -g "*.{png,jpg,jpeg,bmp,gif,svg,tiff}"' \
  '--set-tiled=[set tiled wallpaper]:file:_files -g "*.{png,jpg,jpeg,bmp,gif,svg,tiff}"' \
  '--set-zoom=[set zoom wallpaper]:file:_files -g "*.{png,jpg,jpeg,bmp,gif,svg,tiff}"' \
  '--set-zoom-fill=[set zoom-fill wallpaper]:file:_files -g "*.{png,jpg,jpeg,bmp,gif,svg,tiff}"' \
  '--set-color=[set background color]:color:' \
  '--random[set random wallpaper]' \
  '--sort=[sort files]:order:(alpha rtime time)' \
  '*:directory:_directories'
