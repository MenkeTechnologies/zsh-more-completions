#compdef pvrenderserver
# Documentation: https://man.archlinux.org/search?q=pvrenderserver
# Reference accessed: 2026-05-16

# ParaView pvrenderserver: render-only server (paired with pvdataserver)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--server-port=[listen port]:n:' \
  '--client-host=[reverse client host]:host:' \
  '--reverse-connection[reverse client connection]' \
  '--connect-id=[connect identifier]:id:' \
  '--enable-bt[backtrace on signal]' \
  '--force-offscreen-rendering[force OSMesa rendering]' \
  '--use-offscreen-rendering[use offscreen rendering]' \
  '--displays[display list]:list:' \
  '*::options:_files' && ret=0
return ret
