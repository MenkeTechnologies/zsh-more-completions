#compdef texconfig
# _texconfig — TeX Live texconfig (front-end for editing TeX Live runtime config: papersize/dvi viewer/printer settings; subcommand dvips/xdvi/pdf/font/init/rehash configure individual subsystems; conf/listmaps inspect resolved config)
# upstream: https://tug.org/svn/texlive (Master/texmf-dist/scripts/texconfig)
# Subcommands from texconfig (texlive scripts/texconfig/texconfig) on tip.

_texconfig() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '1:command:(help conf rehash init listmaps mode paper xdvi dvips dvipdfm pdftex font formats hyphen psfonts)' \
        '*::args:'
}

_texconfig "$@"
