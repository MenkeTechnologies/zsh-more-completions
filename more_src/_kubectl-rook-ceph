#compdef kubectl-rook-ceph
# Documentation: https://github.com/rook/kubectl-rook-ceph
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[CephCluster namespace]:namespace:' \
  '(-o --operator-namespace)'{-o+,--operator-namespace=}'[rook operator namespace]:namespace:' \
  '--context=[kubernetes context]:context:' \
  '1:subcommand:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'ceph:run ceph CLI commands'
      'rados:run rados CLI commands'
      'radosgw-admin:run radosgw-admin commands'
      'rbd:run rbd CLI commands'
      'mons:show mon endpoints'
      'health:check cluster health and configuration'
      'operator:manage the rook operator'
      'rook:rook commands (version, status, purge)'
      'maintenance:mon/osd maintenance operations'
      'dr:disaster recovery health checks'
      'subvolume:find and manage stale subvolumes'
      'restore-deleted:recover stuck CRD resources'
      'help:help about any command'
    )
    _describe -t commands 'kubectl-rook-ceph command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
