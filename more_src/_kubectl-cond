#compdef kubectl-cond
# Documentation: https://man.archlinux.org/search?q=kubectl-cond
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[all namespaces]' \
  '*:args:_default'
