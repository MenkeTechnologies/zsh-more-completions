#compdef trimest
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/trimest.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS trimest: remove poly-A tails from nucleotide mRNA sequences
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' \
  '-sequence=[input nucleotide sequence(s)]:file:_files' \
  '-outseq=[output sequence set(s)]:file:_files' \
  '-minlength=[minimum length of a poly-A tail (default 4)]:n:' \
  '-mismatches=[allowed non-A mismatches in tail (default 1)]:n:' \
  '-reverse[reverse-complement when 5-prime poly-T is removed (default yes)]' \
  '-noreverse[do not reverse-complement on 5-prime poly-T removal]' \
  '-tolower[mask poly-A as lowercase instead of removing]' \
  '-fiveprime[inspect 5-prime end for poly-T tails (default yes)]' \
  '-nofiveprime[do not inspect 5-prime end]' \
  '*:sequence:_files' && ret=0

return ret
