#compdef devcontainer-cli @devcontainers/cli
# _devcontainer-cli — Dev Containers reference CLI (devcontainers/cli)
# upstream: https://github.com/devcontainers/cli
# Subcommands from src/spec-node/devContainersSpecCLI.ts (yargs).

_devcontainer-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'up:create and run dev container'
                'set-up:set up an existing container as a dev container'
                'build:build a dev container image'
                'run-user-commands:run user commands'
                'read-configuration:read configuration'
                'outdated:show current and available versions'
                'upgrade:upgrade lockfile'
                'exec:execute a command on a running dev container'
                'features:Features commands'
                'templates:Templates commands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                features)  _arguments '1:subcommand:(test package publish info resolve-dependencies generate-docs)' ;;
                templates) _arguments '1:subcommand:(apply publish metadata generate-docs)' ;;
                exec)      _arguments '*::command:_command_names -e' ;;
                build)     _arguments '*:context path:_files -/' ;;
            esac
            ;;
    esac
}

_devcontainer-cli "$@"
