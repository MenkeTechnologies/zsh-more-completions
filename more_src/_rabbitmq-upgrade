#compdef rabbitmq-upgrade
# Documentation: https://man.archlinux.org/search?q=rabbitmq-upgrade
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:general help'
  'post_upgrade:run post-upgrade tasks'
  'await_online_quorum_plus_one:wait for online quorum'
  'drain:activate maintenance mode'
  'revive:deactivate maintenance mode'
)

_arguments -C \
  '-n+[node name]:node:' \
  '(-q --quiet)'{-q,--quiet}'[reduce messages]' \
  '(-s --silent)'{-s,--silent}'[suppress messages]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '(-l --longnames)'{-l,--longnames}'[FQDN node names]' \
  '--erlang-cookie=[shared secret]:cookie:' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rabbitmq-upgrade subcommand' subcommands && ret=0
    ;;
esac

return ret
