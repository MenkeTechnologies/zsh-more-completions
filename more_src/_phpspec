#compdef phpspec
# Zsh completion for phpspec - PHP BDD testing framework
# https://github.com/phpspec/phpspec

local -a commands=(
  'describe:create a specification for a class'
  'run:run specifications'
  'list:list available commands'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-q[quiet mode]' \
  '-v[increase verbosity (-vv for very verbose, -vvv for debug)]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '-n[do not ask interactive questions]' \
  '-c+[specify config file]:config file:_files -g "*.yml *.yaml(-.)"' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'phpspec command' commands
    ;;
  args)
    case $words[1] in
      describe)
        _arguments '1:class name (e.g. App\\MyClass):'
        ;;
      run)
        _arguments \
          '--format=[output format]:format:(dot progress pretty junit html)' \
          '--no-code-generation[skip code generation]' \
          '--stop-on-failure[stop on first failure]' \
          '--no-rerun[do not rerun failed specs]' \
          '--fake[create fake implementations]' \
          '--bootstrap=[bootstrap file]:file:_files -g "*.php(-.)"' \
          '*:spec file or class:_files -g "*.php(-.)"'
        ;;
    esac
    ;;
esac
