#compdef pcp-tapestat
# _pcp-tapestat — PCP-based tape-device I/O statistics (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/tapestat/pcp-tapestat.1 SYNOPSIS.

_pcp-tapestat() {
    _arguments \
        '(- *)-?[show help]' \
        '-u[unbuffered output]' \
        '-G+[grouping method]:method:(io throughput)' \
        '-P+[output precision]:digits:' \
        '-R+[device regex pattern]:regex:' \
        '-x+[extended stats]:fields:(t h noidle t,h t,noidle h,noidle t,h,noidle)'
}

_pcp-tapestat "$@"
