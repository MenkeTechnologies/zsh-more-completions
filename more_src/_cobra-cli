#compdef cobra-cli

# Zsh completion for cobra-cli (Go Cobra CLI generator)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '-a+[Author name for copyright]:author' \
  '--author=[Author name for copyright]:author' \
  '--config=[Config file]:file:_files' \
  '-l+[License for generated code]:license:(none apache bsd-2 bsd-3 gpl-2 gpl-3 lgpl mit mpl)' \
  '--license=[License for generated code]:license:(none apache bsd-2 bsd-3 gpl-2 gpl-3 lgpl mit mpl)' \
  '--viper[Use Viper for configuration (default true)]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize a Cobra application'
      'add:Add a command to a Cobra application'
      'completion:Generate shell completion scripts'
      'help:Help about any command'
    )
    _describe -t commands 'cobra-cli command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--pkg-name=[Fully qualified package name]:name' \
          '-a+[Author name for copyright]:author' \
          '--author=[Author name for copyright]:author' \
          '-l+[License for generated code]:license:(none apache bsd-2 bsd-3 gpl-2 gpl-3 lgpl mit mpl)' \
          '--license=[License for generated code]:license:(none apache bsd-2 bsd-3 gpl-2 gpl-3 lgpl mit mpl)' \
          '--viper[Use Viper for configuration]' \
          '--config=[Config file]:file:_files' \
          '1:path:_directories' && ret=0
        ;;
      add)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-p+[Parent command for this command]:parent' \
          '--parent=[Parent command for this command]:parent' \
          '-a+[Author name for copyright]:author' \
          '--author=[Author name for copyright]:author' \
          '-l+[License for generated code]:license:(none apache bsd-2 bsd-3 gpl-2 gpl-3 lgpl mit mpl)' \
          '--license=[License for generated code]:license:(none apache bsd-2 bsd-3 gpl-2 gpl-3 lgpl mit mpl)' \
          '--viper[Use Viper for configuration]' \
          '--config=[Config file]:file:_files' \
          '1:command name' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
