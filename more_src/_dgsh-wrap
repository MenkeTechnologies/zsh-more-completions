#compdef dgsh-wrap
# Documentation: https://www.spinellis.gr/sw/dgsh/dgsh-wrap.html
# dgsh-wrap - wrap a non-dgsh program into the directed graph shell

local ret=1

_arguments -s -S \
  '-e[replace <| and >| arg strings with input fd path names]' \
  '-i+[number of input channels (0=none, a=arbitrary)]:channels:(0 a)' \
  '-I[do not include stdin when replacing <| arguments]' \
  '-o+[number of output channels (0=none, a=arbitrary)]:channels:(0 a)' \
  '-O[do not include stdout when replacing >| arguments]' \
  '-S[process flags as shebang interpreter (invocation-supplied name)]' \
  '-s[process flags as shebang interpreter (OS-supplied name)]' \
  '-x[execute command without dgsh negotiation on its behalf]' \
  '*::command:_command_names -e' && ret=0

return ret
