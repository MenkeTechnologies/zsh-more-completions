#compdef mafft-ginsi
# Documentation: http://www.iqtree.org/doc/
# MAFFT G-INS-i accuracy-oriented alignment (mafft wrapper)

local ret=1

_arguments -s -S \
  '--auto[select strategy automatically based on data size]' \
  '--6merpair[use 6mer-based distance calculation]' \
  '--globalpair[Needleman-Wunsch pairwise alignments]' \
  '--localpair[Smith-Waterman pairwise alignments]' \
  '--genafpair[local alignment with generalized affine gap cost]' \
  '--fastapair[FASTA-based pairwise alignments]' \
  '--weighti[weighting factor for the consistency term]:factor:' \
  '--retree[number of guide tree constructions]:number:' \
  '--maxiterate[cycles of iterative refinement]:number:' \
  '--fft[enable FFT approximation]' \
  '--nofft[disable FFT approximation]' \
  '--noscore[skip alignment score checking]' \
  '--memsave[use the Myers-Miller algorithm]' \
  '--parttree[fast tree-building for large datasets]' \
  '--dpparttree[PartTree with DP-based distances]' \
  '--fastaparttree[PartTree with FASTA distances]' \
  '--partsize[partition count in PartTree]:number:' \
  '--groupsize[maximum alignment size]:number:' \
  '--op[gap opening penalty]:penalty:' \
  '--ep[gap extension offset]:offset:' \
  '--lop[local pairwise gap opening penalty]:penalty:' \
  '--lep[local pairwise offset]:offset:' \
  '--lexp[local pairwise extension penalty]:penalty:' \
  '--bl[BLOSUM matrix selection]:matrix:(30 45 62 80)' \
  '--jtt[JTT PAM matrix]:n:' \
  '--tm[transmembrane PAM matrix]:n:' \
  '--aamatrix[custom scoring matrix]:file:_files' \
  '--fmodel[incorporate composition information]' \
  '--clustalout[output in Clustal format]' \
  '--inputorder[preserve input sequence order]' \
  '--reorder[sort output by alignment]' \
  '--treeout[write guide tree to file]' \
  '--quiet[suppress progress reporting]' \
  '--nuc[treat sequences as nucleotides]' \
  '--amino[treat sequences as amino acids]' \
  '--seed[preserve alignment regions]:file:_files' \
  '--thread[number of threads (-1 = auto)]:number:' \
  '--threadtb[threads for progressive alignment]:number:' \
  '--threadit[threads for iterative refinement]:number:' \
  '*:input file:_files' && ret=0

return ret
