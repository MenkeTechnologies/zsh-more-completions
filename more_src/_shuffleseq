#compdef shuffleseq

# EMBOSS shuffleseq: shuffle sequence(s) to randomise position order while
# keeping the same residue composition. Useful for control samples in
# statistical tests of motif/pattern significance.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-shuffle=[number of shuffles per input sequence]:n:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output sequence format]:format:(fasta embl genbank swiss gcg pir nbrf raw msf ace text)' \
  '*:sequence USA:_files' && ret=0

return ret
