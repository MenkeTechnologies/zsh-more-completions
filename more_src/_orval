#compdef orval
# Documentation: https://orval.dev/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output file destination]:path:_files' \
  '(-i --input)'{-i+,--input=}'[input OpenAPI spec (yaml or json)]:file:_files' \
  '(-c --config)'{-c+,--config=}'[override flags via config file]:file:_files' \
  '(-p --project)*'{-p+,--project=}'[focus one or more projects from config]:name:' \
  '(-m --mode)'{-m+,--mode=}'[default mode]:mode:(single split tags tags-split)' \
  '(-w --watch)'{-w,--watch}'[watch mode]' \
  '--client=[default client]:client:(angular axios axios-functions react-query svelte-query vue-query swr zod fetch hono mcp)' \
  '--mock[activate mock generation]' \
  '--clean[clean output directory]' \
  '--formatter=[format generated files]:formatter:(prettier biome oxfmt)' \
  '--tsconfig=[tsconfig.json path]:file:_files' \
  '--verbose[enable verbose logging]' \
  '--fail-on-warnings[exit 1 on warnings]' && ret=0

return ret
