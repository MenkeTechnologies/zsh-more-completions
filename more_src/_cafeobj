# -----------------------------------------------------------------------------
#
# THE cafeobj CLI — Common Lisp argument processing
#
# cafeobj's CLI is implemented in cafeobj/command-top.lisp's
# cafeobj-process-args function.  Uses simple sequential
# argument processing (case-equal pattern matching on
# successive argv tokens; not a generic CLI library).
#
# Flags (sourced from cafeobj-process-args function):
#
# Help + version:
#   -h, -help, --help          show help and exit
#
# Mode flags:
#   -batch                     batch mode (no REPL)
#   -no-banner                 suppress startup banner
#   -q                         skip init file loading
#   -dev                       enable development mode
#
# Debug flags:
#   -debug                     enable general debug
#   -parse-debug               enable parser debug
#   -modexp-debug              enable module-expression debug
#   -import-debug              enable import debug
#   -match-debug               enable matching debug
#   -view-debug                enable view debug
#
# Installation + library paths:
#   -prefix DIR                set install directory (also
#                              updates standard library path)
#   -lib PATHS                 set library paths (colon-separated)
#   -l PATHS                   alias for -lib
#   +lib PATHS                 prepend additional library paths
#   +l PATHS                   alias for +lib
#
# Prelude files:
#   -p, -prelude FILE          set initial prelude file
#                              (loaded before user files)
#   +p, +prelude FILE          set secondary prelude file
#                              (also pre-loaded)
#
# Lisp evaluation (Allegro CL only):
#   -e FORM                    evaluate Lisp form
#
# Common Lisp options:
#   -core FILE                 core image to load (CMU CL
#                              only; ignored by other Lisps)
#
# Positional arguments:
#   [FILE.cafe]...             CafeOBJ source files to load
#                              at startup
#
# File extensions:
#   .cafe                      CafeOBJ source file (preferred)
#   .mod                       alternative extension (legacy)
#
# Environment:
#   CAFEOBJ_HOME               install directory
#   CAFEOBJ_LIB                library search path (colon-sep)
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/CafeOBJ/cafeobj/blob/master/cafeobj/command-top.lisp
# cafeobj-process-args function in CHAOS package.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)'{-h,-help,--help}'[show help and exit]' \
    '-batch[batch mode (no REPL)]' \
    '-no-banner[suppress startup banner]' \
    '-q[skip init file loading]' \
    '-dev[enable development mode]' \
    '-debug[enable general debug]' \
    '-parse-debug[enable parser debug]' \
    '-modexp-debug[enable module-expression debug]' \
    '-import-debug[enable import debug]' \
    '-match-debug[enable matching debug]' \
    '-view-debug[enable view debug]' \
    '-prefix+[set install directory]:directory:_files -/' \
    '(-lib -l)'{-lib+,-l+}'[set library paths (colon-separated)]:paths:_default' \
    '(+lib +l)'{+lib+,+l+}'[prepend additional library paths]:paths:_default' \
    '(-p -prelude)'{-p+,-prelude+}'[set initial prelude file]:file:_files -g "*.cafe"' \
    '(+p +prelude)'{+p+,+prelude+}'[set secondary prelude file]:file:_files -g "*.cafe"' \
    '-e+[evaluate Lisp form (Allegro CL only)]:form:_default' \
    '-core+[Common Lisp core image file (CMU CL only)]:file:_files' \
    '*:CafeOBJ source file:_files -g "*.cafe"' \
    && ret=0

return ret
