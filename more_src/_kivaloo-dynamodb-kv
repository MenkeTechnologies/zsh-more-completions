#compdef kivaloo-dynamodb-kv dynamodb-kv
# _kivaloo-dynamodb-kv — kivaloo proxy serving the LBS protocol from DynamoDB (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from dynamodb-kv/main.c (libcperciva GETOPT).

_kivaloo-dynamodb-kv() {
    _arguments \
        '(- *)--version[print version]' \
        '-s+[daemon listen socket]:socket:' \
        '-r+[DynamoDB region]:region:' \
        '-t+[DynamoDB table]:table:' \
        '-k+[AWS keyfile]:file:_files' \
        '-1[run one request at a time]' \
        '-l+[logfile]:file:_files' \
        '-p+[pidfile]:file:_files'
}

_kivaloo-dynamodb-kv "$@"
