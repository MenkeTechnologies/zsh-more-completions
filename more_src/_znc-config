#compdef znc-config
# Documentation: https://man.archlinux.org/search?q=znc-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '--prefix[install prefix]' \
  '--bindir[bin dir]' \
  '--datadir[data dir]' \
  '--moduledir[module dir]' \
  '--includedir[include dir]' \
  '--libdir[lib dir]' \
  '--modflags[module compile flags]' \
  '--ldflags[ld flags]' \
  '--cxx[cxx compiler]' \
  '--cxxflags[cxx flags]' \
  '--version[show version]' && ret=0

return ret
