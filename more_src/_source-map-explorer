#compdef source-map-explorer
# Documentation: https://github.com/danvk/source-map-explorer
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json=[output as JSON]:output file:_files' \
  '--html=[output as HTML]:output file:_files' \
  '--tsv=[output as TSV]:output file:_files' \
  '(-m --only-mapped)'{-m,--only-mapped}'[exclude unmapped bytes from results]' \
  '--exclude-source-map[remove source map comment size from output]' \
  '--no-root[do not simplify root directory]' \
  '--replace=[find pattern in file paths (regex)]:pattern:' \
  '--with=[replacement string for --replace]:replacement:' \
  '--gzip[calculate gzip file sizes]' \
  '--sort[sort filenames in output]' \
  '--no-border-checks[disable source map border validation]' \
  '--coverage=[path to Chrome code coverage JSON]:file:_files -g "*.json"' \
  '*:files:_files -g "*.{js,mjs,css,map}"' && ret=0

return ret
