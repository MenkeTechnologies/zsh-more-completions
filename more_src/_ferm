#compdef ferm

# Zsh completion for ferm (For Easy Rule Making - iptables frontend)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --noexec)'{-n,--noexec}'[Do not execute iptables commands, just show them]' \
  '(-F --flush)'{-F,--flush}'[Flush all iptables rules and exit]' \
  '(-l --lines)'{-l,--lines}'[Show line numbers when printing rules]' \
  '(-i --interactive)'{-i,--interactive}'[Apply changes interactively, rollback on timeout]' \
  '(-t --timeout)'{-t,--timeout}'=[Timeout for interactive mode in seconds]:seconds' \
  '--fast[Enable fast mode (skip iptables-save)]' \
  '--slow[Enable slow mode]' \
  '--shell[Print a shell script instead of running iptables]' \
  '(-d --domain)'{-d,--domain}'=[Handle only the specified domain]:domain:(ip ip6 arp eb)' \
  '--remote[Generate rules for a remote host]' \
  '(-D --def)'{-D,--def}'=[Define a variable]:name=value' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  ':ferm rules file:_files' && ret=0

return ret
