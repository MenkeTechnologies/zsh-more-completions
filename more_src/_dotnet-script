#compdef dotnet-script

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:scaffold a new script project'
  'exec:execute a compiled DLL'
  'publish:publish CSX as standalone'
  'register:register as .csx file handler'
)

_arguments -C \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '*-s[NuGet package source]:source:' \
  '--no-cache[bypass caches]' \
  '--disable-isolated-load-context[disable isolated load context]' \
  '-i[enter REPL after script]' \
  '(-c --configuration)'{-c,--configuration=}'[build configuration]:cfg:(Debug Release)' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotnet-script subcommand' subcommands
    _files -g '*.csx' && ret=0
    ;;
  (args)
    case $line[1] in
      (publish)
        _arguments \
          '(-o --output)'{-o,--output=}'[output dir]:dir:_files -/' \
          '(-n --name)'{-n,--name=}'[output name]:name:' \
          '--dll[publish as DLL]' \
          '(-r --runtime)'{-r,--runtime=}'[runtime identifier]:rid:' && ret=0
        ;;
    esac
    ;;
esac

return ret
