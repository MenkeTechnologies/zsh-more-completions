#compdef pto_gen

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '-p+[projection (0-3)]:proj:(0 1 2 3)' \
  '-f+[focal length]:mm:' \
  '-c+[crop factor]:val:' \
  '-s[stack]' \
  '*:images:_files -g "*.{jpg,jpeg,tif,tiff,png}"' && ret=0

return ret
