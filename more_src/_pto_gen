#compdef pto_gen
# Documentation: https://wiki.panotools.org/Pto_gen
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pto_gen: generate Hugin .pto project from image files
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto filename]:file:_files -g "*.pto"' \
  '(-p --projection)'{-p+,--projection=}'[projection type number]:number:' \
  '(-f --fov)'{-f+,--fov=}'[horizontal field of view (degrees)]:hfov:' \
  '(-c --crop)'{-c+,--crop=}'[input image crop: left,right,top,bottom]:crop:' \
  '(-s --stacklength)'{-s+,--stacklength=}'[number of images per stack]:n:' \
  '(-l --linkstacks)'{-l,--linkstacks}'[link image positions in stacks]' \
  '--distortion[load distortion data from lens database]' \
  '--vignetting[load vignetting data from lens database]' \
  '--sort[order images alphanumerically before adding]' \
  '*:images:_files -g "*.(jpg|jpeg|JPG|JPEG|tif|tiff|TIF|TIFF|png|PNG)"' && ret=0

return ret
