#compdef crmadmin
# Documentation: https://man.archlinux.org/search?q=crmadmin
# Reference accessed: 2026-05-16

# crmadmin: query Pacemaker controller state
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '-i[list nodes (configured)]' \
  '--nodes[list nodes (configured)]' \
  '-S[print status of node]:node:' \
  '--status=[print status of node]:node:' \
  '-D[print designated controller (DC)]' \
  '--dc_lookup[print designated controller (DC)]' \
  '-K[shut node down]:node:' \
  '--kill=[shut node down]:node:' \
  '-E[health check (no arg = local)]' \
  '--health[health check (no arg = local)]' \
  '-N[show CPG / IPC info]' \
  '--node=[node name]:node:' \
  '-t[command timeout in ms]:ms:' \
  '--timeout=[command timeout in ms]:ms:' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crmadmin args:_files' && ret=0
return ret
