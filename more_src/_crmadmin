#compdef crmadmin

# Pacemaker crmadmin: CRM administration / cluster info queries
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-D --dc_lookup)'{-D,--dc_lookup}'[query the current cluster DC]' \
  '(-N --nodes)'{-N,--nodes}'[list cluster nodes]' \
  '(-S --status)'{-S,--status=}'[show node status]:node:' \
  '(-E --health)'{-E,--health}'[show DC health]' \
  '(-K --kill)'{-K,--kill=}'[stop pacemakerd on node]:node:' \
  '(-t --timeout)'{-t,--timeout=}'[operation timeout msec]:ms:' \
  '(-i --pacemakerd)'{-i,--pacemakerd}'[query pacemakerd]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '*::crmadmin args:_files' && ret=0
return ret
