#compdef crmadmin
# Documentation: https://www.mankier.com/8/crmadmin
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crmadmin: query Pacemaker controller state
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-command[show command options]' \
  '(- *)--help-additional[show additional options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-q --quiet)'{-q,--quiet}'[display only essential query information]' \
  '--output-as=[output format]:fmt:(text xml)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '(-S --status)'{-S+,--status=}'[display status of node]:node:' \
  '(-P --pacemakerd)'{-P,--pacemakerd}'[display status of local pacemakerd]' \
  '(-D --dc_lookup)'{-D,--dc_lookup}'[display the cluster co-ordinator (DC)]' \
  '(-N --nodes)'{-N+,--nodes=}'[list member nodes (optionally filtered by type)]:type:(all member remote)' \
  '(-t --timeout)'{-t+,--timeout=}'[time to wait before failing]:duration:' \
  '(-B --bash-export)'{-B,--bash-export}'[export nodes as shell command statements]' \
  '(-i --ipc-name)'{-i+,--ipc-name=}'[name to use for ipc instead of crmadmin]:name:' && ret=0
return ret
