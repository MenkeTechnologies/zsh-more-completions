#compdef publint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--strict[enable strict mode]' \
  '--level=[message level]:level:(suggestion warning error)' \
  '--pack=[path to packed tarball]:file:_files -g "*.tgz"' \
  '*:package directory:_directories' && ret=0

return ret
