#compdef cu2qu
# _cu2qu — Behdad Esfahbod cu2qu CLI converting cubic Bézier UFO/OTF source font outlines to quadratic Bézier TrueType-compatible curves with tolerance control for high-fidelity TrueType output (fonttools team, Python); argparse
# upstream: https://github.com/fonttools/cu2qu

_cu2qu() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t+[tolerance]:f:' \
        '--tolerance=+[tolerance]:f:' \
        '-o+[output ufo]:file:_files -g "*.ufo *.ufoz"' \
        '--output=+[output ufo]:file:_files -g "*.ufo *.ufoz"' \
        '-j+[N jobs]:n:' \
        '--jobs=+[N jobs]:n:' \
        '-i+[interpolatable]' \
        '--interpolatable[interpolatable]' \
        '-N+[N max points]:n:' \
        '--all-cubic[force all cubic]' \
        '--no-all-cubic[no force all cubic]' \
        '-d[in-place]' \
        '--in-place[in-place]' \
        '-c+[component scale tolerance]:f:' \
        '--component-scale-tolerance=+[tolerance]:f:' \
        '*:UFO files:_files -g "*.ufo *.ufoz"'
}

_cu2qu "$@"
