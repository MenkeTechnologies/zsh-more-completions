#compdef depcruise-wrap-stream-in-html
# Documentation: https://github.com/sverweij/dependency-cruiser/blob/main/doc/cli.md
# depcruise-wrap-stream-in-html - wrap GraphViz dot output in interactive HTML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
