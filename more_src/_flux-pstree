#compdef flux-pstree
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-pstree.html
# display a tree of Flux jobs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[include jobs in all states]' \
  '(-c --count)'{-c,--count=}'[limit output to N jobs per level]:n' \
  '(-f --filter)'{-f,--filter=}'[include jobs with specific state or result]:filter' \
  '(-l --long)'{-l,--long}'[do not truncate long lines]' \
  '(-p --parent-ids)'{-p,--parent-ids}'[prepend jobid to parent labels]' \
  '(-L --level)'{-L,--level=}'[descend only N levels]:n' \
  '(-x --extended)'{-x,--extended}'[print extended details before tree]' \
  '(-d --detail)'{-d,--detail=}'[select named extended details format]:name' \
  '(-n --no-header)'{-n,--no-header}'[do not print header row]' \
  '(-X --no-combine)'{-X,--no-combine}'[disable combination of like jobs]' \
  '(-o --label)'{-o,--label=}'[output format for node labels]:format' \
  '--parent-label=[label tree parents with different format]:format' \
  '--detail-format=[explicit details format]:format' \
  '--skip-root=[skip or force display of enclosing instance]:yesno:(yes no)' \
  '(-C --compact)'{-C,--compact}'[use compact tree connectors]' \
  '--ascii[use ascii tree connectors]' \
  '*:jobid:_default' && ret=0

return ret
