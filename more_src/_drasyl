#compdef drasyl
# Documentation: https://docs.drasyl.org/cli/intro/
# drasyl - command line tool for the drasyl overlay network

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:command:(generate-completion generate-identity generate-pow help node node-rc perf public-key sdon tun tun-rc tunnel version wormhole)' \
  '*::arg:->args' && ret=0

return ret
