#compdef unpermute-stars
# Documentation: http://astrometry.net/doc/build-index.html
# remove the permutation from a star kdtree and its quads

local ret=1

_arguments -s \
  '-h[show help]' \
  '-s+[input star-kdtree filename]:input skdt:_files' \
  '-q+[input quads filename]:input quads:_files' \
  '-S+[output star-kdtree filename]:output skdt:_files' \
  '-Q+[output quads filename]:output quads:_files' \
  '-w[store sweep number in output star kdtree file]' \
  '-c[check values]' \
  '-v[more verbose]' && ret=0

return ret
