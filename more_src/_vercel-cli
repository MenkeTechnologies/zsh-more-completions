#compdef vercel-cli
# Documentation: https://vercel.com/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Alias completion for `vercel-cli` (npm dist tag); see also _vercel.
local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activity:view activity events'
  'alerts:list recent alerts'
  'alias:manage domain aliases'
  'api:make authenticated HTTP requests to Vercel API'
  'bisect:bisect deployments'
  'blob:interact with Vercel Blob storage'
  'build:build the project'
  'buy:purchase Vercel products'
  'cache:manage cache'
  'certs:manage SSL certificates'
  'contract:view contract commitment information'
  'curl:make HTTP requests to deployments'
  'deploy:deploy a project'
  'dev:run dev server'
  'dns:DNS commands'
  'domains:domain commands'
  'env:env var commands'
  'flags:manage feature flags'
  'git:Git provider commands'
  'guidance:enable/disable guidance messages'
  'help:show help'
  'httpstat:HTTP request timing stats'
  'init:initialize project'
  'inspect:inspect deployment'
  'install:install integrations'
  'integration:integration commands'
  'integration-resource:integration resource commands'
  'link:link project to dir'
  'list:list deployments'
  'login:log in'
  'logout:log out'
  'logs:show logs'
  'mcp:MCP client config'
  'metrics:query observability metrics'
  'microfrontends:microfrontends commands'
  'open:open project in dashboard'
  'project:project commands'
  'promote:promote deployment'
  'pull:pull env to local'
  'redeploy:redeploy'
  'redirects:manage redirects'
  'remove:remove deployment'
  'rollback:rollback to deployment'
  'rolling-release:manage rolling releases'
  'routes:manage routing rules'
  'switch:switch teams'
  'target:target commands'
  'teams:team commands'
  'telemetry:telemetry settings'
  'usage:billing usage and costs'
  'webhooks:manage webhooks'
  'whoami:show current user'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--cwd=[cwd]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-Q --global-config)'{-Q,--global-config=}'[global config dir]:dir:_files -/' \
  '(-A --local-config)'{-A,--local-config=}'[local config file]:file:_files' \
  '--no-color[no color]' \
  '(-S --scope)'{-S,--scope=}'[scope]:s:' \
  '(-t --token)'{-t,--token=}'[token]:t:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vercel command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
