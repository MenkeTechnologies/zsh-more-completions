#compdef rem

# kykim/rem — `rem/main.m`

local curcontext="$curcontext" ret=1 expl
_arguments -C   '1: :->cmd'   '*:: :->rest' && ret=0
case $state in
cmd)
  _wanted commands expl 'rem command' compadd -- ls add rm cat done help version orgmode parseorg
  ;;
rest)
  _normal && ret=0
  ;;
esac
return ret
