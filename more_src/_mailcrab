#compdef mailcrab
# _mailcrab — Rust development email server (tweedegolf/mailcrab)
# upstream: https://github.com/tweedegolf/mailcrab
# Configuration is environment-driven (SMTP_HOST, SMTP_PORT, HTTP_HOST, HTTP_PORT, MAILCRAB_PREFIX,
# MAILCRAB_RETENTION_PERIOD, QUEUE_CAPACITY, ENABLE_TLS_AUTH); only --help / --version on the CLI.

_mailcrab() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )
    _arguments -s -S $args
}

_mailcrab "$@"
