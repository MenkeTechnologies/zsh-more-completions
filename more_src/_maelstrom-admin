#compdef maelstrom-admin
# Documentation: source-direct extraction from upstream
# maelstrom-software/maelstrom —
#   crates/maelstrom-admin/src/config.rs lines 6-47 (Config
#     struct: 5 flags, 3 with `hide` attribute)
#   crates/maelstrom-admin/src/lib.rs lines 20-36 (Subcommand
#     enum: 2 variants Status + Stop with `aliases`
#     attribute lists)
#   `#[command(disable_help_subcommand = true)]` at lib.rs:21
#     (disables the auto-injected `help` subcommand)
# Reference accessed: 2026-05-30 via gh api.
#
# maelstrom-admin is the **Maelstrom broker administration
# CLI** — sister to R238 cargo-maelstrom + R239 maelstrom-
# pytest/go-test/run.  Inspects + shuts down the broker
# daemon.  This R240 round + the previous R238/R239 rounds
# complete the corpus's coverage of the **7-binary
# Maelstrom family**:
#   1. cargo-maelstrom  (R238) — Rust test runner
#   2. maelstrom-pytest (R239) — Python test runner
#   3. maelstrom-go-test(R239) — Go test runner
#   4. maelstrom-run    (R239) — standalone job spec runner
#   5. maelstrom-admin  (R240) — broker admin
#   6. maelstrom-broker (R240) — broker daemon
#   7. maelstrom-worker (R240) — worker daemon
#
# Critical extraction note: maelstrom-admin uses two clap-
# derive attributes new to the corpus:
#   1. **`#[command(disable_help_subcommand = true)]`** at
#      lib.rs:21 — DISABLES the auto-injected `help`
#      subcommand that clap normally adds.  Documented as the
#      corpus's first explicit help-subcommand opt-out.
#   2. **`aliases = ["stats", "stat"]`** on Status (lib.rs:25)
#      and `aliases = ["shut-down", "shutdown"]` on Stop
#      (lib.rs:32) — INVISIBLE aliases (do NOT appear in
#      --help).  Compare to `visible_aliases = [...]` which
#      would show them.  Continues R238's `alias = "loop"`
#      single-alias documentation by adding the multi-alias
#      ARRAY syntax.
#
# Critical extraction note: `Status` has 3 forms (`status`,
# `stats`, `stat`) and `Stop` has 3 forms (`stop`, `shut-down`,
# `shutdown`) — completion lists all 6 with the canonical
# form first so users see which is the recommended invocation.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'status:print cluster status and exit (canonical; aliases: stats, stat)'
  'stats:invisible alias for status'
  'stat:invisible alias for status'
  'stop:tell broker to stop (canonical; aliases: shut-down, shutdown)'
  'shut-down:invisible alias for stop'
  'shutdown:invisible alias for stop'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-L --log-level)'{-L+,--log-level=}'[min log level (default info)]:level:(error warn info debug trace)' \
  '(-b --broker)'{-b+,--broker=}'[broker socket address (required if cluster-communication-strategy=tcp; default=tcp)]:sockaddr:' \
  '--cluster-communication-strategy=[(HIDDEN) cluster strategy]:strategy:(tcp github)' \
  '--github-actions-token=[(HIDDEN) ACTIONS_RUNTIME_TOKEN for GitHub strategy]:token:' \
  '--github-actions-url=[(HIDDEN) ACTIONS_RESULTS_URL for GitHub strategy]:url:_urls' \
  '1:subcommand:->subcmd' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'maelstrom-admin subcommand' subcommands && ret=0
    ;;
esac

return ret
