#compdef cuda-checkpoint
# Documentation: https://github.com/NVIDIA/cuda-checkpoint/blob/main/README.md
# cuda-checkpoint - CUDA checkpoint and restore utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '--get-state[print the current checkpoint state of the process]' \
  '--action=[perform action on the process]:action:(lock checkpoint restore unlock)' \
  '--toggle[toggle the CUDA state between running and checkpointed]' \
  '--get-restore-tid[retrieve the CUDA restore thread ID of the process]' \
  '(-p --pid)'{-p,--pid}'=[the pid upon which to perform the operation]:pid' \
  '(-t --timeout)'{-t,--timeout}'=[timeout in ms for the lock action]:ms' && ret=0

return ret
