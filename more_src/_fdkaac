#compdef fdkaac
# Documentation: https://github.com/nu774/fdkaac
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Fraunhofer FDK AAC encoder CLI (nu774/fdkaac).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-p+,--profile=}'[AAC profile]:profile:((2\:AAC-LC 5\:HE-AAC 29\:HE-AAC-v2 23\:AAC-LD 39\:AAC-ELD))' \
  {-b+,--bitrate=}'[target bitrate (CBR)]:bps:' \
  {-m+,--bitrate-mode=}'[bitrate mode]:mode:((0\:CBR 1\:VBR 2\:VBR 3\:VBR 4\:VBR 5\:VBR))' \
  {-w+,--bandwidth=}'[frequency bandwidth in Hz]:hz:' \
  {-a+,--afterburner=}'[afterburner quality enhancement]:b:(0 1)' \
  {-L+,--lowdelay-sbr=}'[configure SBR on AAC ELD]:n:' \
  {-s+,--sbr-ratio=}'[downsampled SBR ratio]:n:' \
  {-f+,--transport-format=}'[output container format]:fmt:((0\:M4A 1\:ADIF 2\:ADTS 6\:LATM-MCP1 7\:LATM-MCP0 10\:LOAS-LATM))' \
  {-C,--adts-crc-check}'[add CRC to ADTS headers]' \
  '--header-period=[config repetition period]:n:' \
  {-o+}'[output filename]:file:_files' \
  {-S,--silent}'[suppress progress messages]' \
  {-R,--raw}'[treat input as raw PCM]' \
  '--raw-channels=[number of input channels]:n:' \
  '--raw-rate=[input sample rate]:hz:' \
  '--raw-format=[input sample format]:spec:' \
  {-I,--ignorelength}'[ignore WAV data chunk length]' \
  '--title=[set title tag]:title:' \
  '--artist=[set artist tag]:artist:' \
  '--album=[set album tag]:album:' \
  '--genre=[set genre tag]:genre:' \
  '--date=[set date tag]:date:' \
  '--composer=[set composer tag]:composer:' \
  '--track=[set track number/total]:n[/total]:' \
  '--disk=[set disc number/total]:n[/total]:' \
  '--tag-from-json=[load tags from JSON]:file:_files -g "*.json"' \
  '*:input file:_files' && return 0
