#compdef arp-cache
# _arp-cache — net-tools arp-cache helper (distro-shipped wrapper around `ip neigh show` that prints / clears the live ARP and NDP cache in a normalised format suitable for monitoring; -i interface, -4 IPv4 only, -6 IPv6 only, -c clear, -n no DNS, -q quiet, -v verbose, -V version; positional argument is an optional host filter)
# upstream: distro-shipped helper (Debian net-tools auxiliary scripts)
# Common flag shape inferred from net-tools arp-cache on tip.

_arp-cache() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-i+[interface]:interface:_net_interfaces' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-c[clear cache]' \
        '-n[no DNS]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '1::host filter:_hosts'
}

_arp-cache "$@"
