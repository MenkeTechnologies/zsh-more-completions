_bard() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:Initialize a new bard project skeleton in this directory'
        'make:Build the current project'
        'watch:Like make, but keep running and rebuild on changes'
        'util:CLI utilities for postprocessing'
        'help:Print help (top-level or for a subcommand)'
    )

    _arguments -C \
        '(-V --version --version-settings --version-ast)'{-V,--version}'[print program version in semver format]' \
        '(-V --version --version-ast)--version-settings[print project settings file version in semver format]' \
        '(-V --version --version-settings)--version-ast[print project template AST version in semver format]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'bard command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init)    _bard_init    && ret=0 ;;
                make)    _bard_make    && ret=0 ;;
                watch)   _bard_make    && ret=0 ;;  # same MakeOpts
                util)    _bard_util    && ret=0 ;;
                help)
                    _describe -t commands 'bard command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# StdioOpts (shared by every subcommand) — src/app.rs lines 19-30
_bard_stdio_opts() {
    print -- \
        '(-v --verbose -q --quiet)'{-v,--verbose}'[be more verbose]' \
        '(-v --verbose -q --quiet)'{-q,--quiet}'[suppress output]' \
        '--color=[whether to use colored output (auto-detected by default)]:bool:(true false)'
}

# `bard init` — src/lib.rs line 95-99
_bard_init() {
    local -a stdio
    stdio=( ${(z)$(_bard_stdio_opts)} )
    _arguments \
        $stdio \
        '(-h --help)'{-h,--help}'[print help]'
}

# `bard make` / `bard watch` — MakeOpts in src/app.rs lines 43-54
_bard_make() {
    local -a stdio
    stdio=( ${(z)$(_bard_stdio_opts)} )
    _arguments \
        '(-p --no-postprocess)'{-p,--no-postprocess}'[do not run post-processing steps (TeX, scripts)]' \
        '*'{-k,--keep}'[keep the TeX file when generating PDF; twice keeps the build dir as well]' \
        $stdio \
        '(-h --help)'{-h,--help}'[print help]'
}

# `bard util` — src/util_cmd.rs UtilCmd enum
_bard_util() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a util_subcmds
    util_subcmds=(
        'sort-lines:alphabetically sort lines of a file in-place (matched by regex)'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '1: :->ucmds' \
        '*::arg:->uargs' && ret=0

    case $state in
        ucmds)
            _describe -t commands 'bard util command' util_subcmds && ret=0
            ;;
        uargs)
            case $line[1] in
                sort-lines)
                    _arguments \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1:regex (capture group is sort key):' \
                        '2:file:_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_bard "$@"
