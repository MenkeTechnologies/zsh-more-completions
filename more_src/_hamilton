#compdef hamilton
# Documentation: https://hamilton.dagworks.io/en/latest/how-tos/cli-reference/
# Hamilton CLI - build/diff/view dataflows (sf-hamilton)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--verbose --no-verbose)--verbose[verbose output]' \
  '(--verbose --no-verbose)--no-verbose[disable verbose output]' \
  '(--json-out --no-json-out)--json-out[emit JSON output]' \
  '(--json-out --no-json-out)--no-json-out[disable JSON output]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '--git-reference=[git reference to diff against]:ref' \
  '(--view --no-view)--view[render visualization]' \
  '(--view --no-view)--no-view[do not render visualization]' \
  '--output-file-path=[output image file path]:file:_files' \
  '1:command:(build diff version view)' \
  '*::modules:_files' && ret=0

return ret
