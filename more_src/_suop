#compdef suop
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/operations/suop.c
# do unary arithmetic operation on segys

local ret=1

_arguments -s -S \
  'op=[operation flag]:op:(abs avg ssqrt sqr ssqr sgn exp sexp slog slog2 slog10 cos sin tan cosh sinh tanh cnorm norm db neg posonly negonly sum diff refl mod2pi inv rmsamp s2v s2vm d2m drv2 drv4 integ spike saf freq lnza mean despike std var nop)' \
  'nw=[number of time samples in window]:nw' \
  '*:file:_files' && ret=0


return ret
