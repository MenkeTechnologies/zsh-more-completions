#compdef paddleocr
# Documentation: https://www.paddleocr.ai/main/en/version3.x/pipeline_usage/OCR.html
# PaddleOCR text detection and recognition CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'=[data to predict (file or directory)]:input:_files' \
  '--save_path=[path to save results]:path:_files' \
  '--ocr_version=[OCR model version]:version:(PP-OCRv3 PP-OCRv4 PP-OCRv5)' \
  '--lang=[OCR model language]:lang' \
  '--text_detection_model_name=[text detection model name]:name' \
  '--text_recognition_model_name=[text recognition model name]:name' \
  '--text_detection_model_dir=[text detection model directory]:dir:_files -/' \
  '--text_recognition_model_dir=[text recognition model directory]:dir:_files -/' \
  '--use_doc_orientation_classify=[enable document orientation classification]:val:(True False)' \
  '--use_doc_unwarping=[enable text image unwarping]:val:(True False)' \
  '--use_textline_orientation=[enable text line orientation]:val:(True False)' \
  '--text_det_limit_side_len=[image side length limit]:len' \
  '--text_det_limit_type=[side limit type]:type:(min max)' \
  '--text_det_thresh=[pixel threshold]:value' \
  '--text_det_box_thresh=[box threshold]:value' \
  '--text_det_unclip_ratio=[expansion coefficient]:value' \
  '--text_rec_score_thresh=[recognition score threshold]:value' \
  '--text_recognition_batch_size=[recognition batch size]:size' \
  '--return_word_box=[return word-level boxes]:val:(True False)' \
  '--device=[device, e.g. cpu gpu:0 npu:0]:device' \
  '--enable_mkldnn=[enable MKL-DNN acceleration]:val:(True False)' \
  '--cpu_threads=[CPU thread count]:threads' \
  '--precision=[computation precision]:precision:(fp32 fp16)' \
  '--use_tensorrt=[enable TensorRT]:val:(True False)' \
  '--paddlex_config=[path to PaddleX config file]:file:_files' && ret=0

return ret
