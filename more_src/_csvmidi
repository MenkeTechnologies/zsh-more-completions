#compdef csvmidi
# Documentation: https://www.fourmilab.ch/webtools/midicsv/
# translate a CSV file into a Standard MIDI File

local ret=1

_arguments -s -S \
  '-u[print how-to-call information]' \
  '-v[print verbose debugging information on standard error]' \
  '-x[disable MIDI compression, emit status byte for all events]' \
  '-z[stop on the first error in CSV input]' \
  '*:csv file:_files -g "*.csv"' && ret=0

return ret
