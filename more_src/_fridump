#compdef fridump
# Documentation: https://github.com/Nightbringer21/fridump
# fridump - Frida-based memory dumping tool

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --out)'{-o+,--out=}'[provide full output directory path (def: dump)]:directory:_files -/' \
  '(-U --usb)'{-U,--usb}'[device connected over usb]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-r --read-only)'{-r,--read-only}'[dump read-only parts of memory]' \
  '(-s --strings)'{-s,--strings}'[run strings on all dump files]' \
  '--max-size=[maximum size of dump file in bytes (def: 20971520)]:bytes' \
  '1:process' && ret=0

return ret
