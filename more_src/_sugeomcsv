#compdef sugeomcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sugeomcsv.c
# SUGEOMCSV - 3D/2D land/OBottom geometry from comma separated or fixed text

local ret=1

_arguments -s -S \
  'rfile=[read a comma separated values text file]:f:_files' \
  'ufile=[update file]:f:_files' \
  'rtype=[record type to read]:r:' \
  'rdelim=[record field delimiter]:r:' \
  'names=[list of field names]:n:' \
  'match=[key names to match input traces]:m:' \
  'setid=[record identifier value]:s:' \
  'action=[action to perform]:a:' \
  'create=[create header key values]:c:' \
  'missing=[value for missing fields]:m:' \
  'maxrecords=[maximum number of records to read]:m:' \
  'nicerecord=[record number to print nicely]:n:' \
  'scalco=[coordinate scale factor]:s:' \
  'scalel=[elevation scale factor]:s:' \
  'spikes=[spike detection values]:s:' \
  'unrepeat=[unrepeat field values]:u:' \
  '*:SU file:_files' && ret=0

return ret
