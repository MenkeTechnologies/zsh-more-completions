#compdef cstor-webhook
# _cstor-webhook — OpenEBS cStor admission webhook server (validates + mutates CSPC / CVC / CVA / CVR resources)
# upstream: https://github.com/openebs/cstor-operators
# Flags from cmd/webhook/main.go on tip.

_cstor-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[webhook server port]:port:' \
        '--tlsCertFile=[x509 TLS certificate file]:file:_files' \
        '--tlsKeyFile=[x509 TLS private key file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_cstor-webhook "$@"
