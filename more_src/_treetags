#compdef treetags
# Source: cargo binstall treetags@0.7.0
# Probed via: completions zsh
# Repository: https://github.com/jha-naman/treetags

autoload -U is-at-least

_treetags() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-f+[Name to be used for the tagfile, should not contain path separator]:TAG_FILE:_default' \
'--append=[Append tags to existing tag file instead of reginerating the file from scratch. Need to pass in list of file names for which new tags are to be generated.]' \
'--workers=[Number of threads to use for parsing files]:WORKERS:_default' \
'*--exclude=[Files/directories matching the pattern will not be used while generating tags]:EXCLUDE:_default' \
'-R+[Recurse into directories encountered in the list of supplied files]' \
'--recurse=[Recurse into directories encountered in the list of supplied files]' \
'--options=[Read additional options from file or directory]:OPTIONS:_default' \
'--sort=[Whether to sort the files or not. Values of '\''yes'\'', '\''on'\'', '\''true'\'', '\''1'\'' set it to true Values of '\''no'\'', '\''0'\'', '\''off'\'', '\''false'\'' set it to false]' \
'--extras=[Enable extra tag information (e.g., +q for qualified tags, +f for file scope)]:EXTRAS:_default' \
'--format=[Value passed in this arg is currently being ignored. Kept for compatibility with \`tagbar\` plugin.]:FORMAT:_default' \
'--excmd=[Value passed in this arg is currently being ignored. Kept for compatibility with \`tagbar\` plugin.]:EXCMD:_default' \
'--fields=[Include selected extension fields (e.g., +l for line numbers, +S for signatures)]:FIELDS:_default' \
'--language-force=[Value passed in this arg is currently being ignored. Kept for compatibility with \`tagbar\` plugin.]:LANGUAGE_FORCE:_default' \
'--kinds-rust=[Rust language specific kinds to generate tags for]:KINDS_RUST:_default' \
'--rust-kinds=[Rust language specific kinds to generate tags for. Deprecated\: \`kinds-rust\` takes precedence if it'\''s present]:RUST_KINDS:_default' \
'--kinds-go=[Go language specific kinds to generate tags for]:KINDS_GO:_default' \
'--go-kinds=[Go language specific kinds to generate tags for. Deprecated\: \`kinds-go\` takes precedence if it'\''s present]:GO_KINDS:_default' \
'--kinds-c++=[C++ language specific kinds to generate tags for]:CPP_KINDS:_default' \
'--kinds-c=[C language specific kinds to generate tags for]:C_KINDS:_default' \
'--kinds-JavaScript=[JavaScript language specific kinds to generate tags for]:KINDS_JAVASCRIPT:_default' \
'--kinds-python=[Python language specific kinds to generate tags for]:KINDS_PYTHON:_default' \
'--kinds-typescript=[TypeScript language specific kinds to generate tags for]:KINDS_TYPESCRIPT:_default' \
'--user-languages-config=[Path to user languages config file. Overrides default config file paths]:USER_LANGUAGES_CONFIG:_files' \
'-h[Print help]' \
'--help[Print help]' \
'::file_names -- List of file names to be processed when `--append` option is passed:_default' \
":: :_treetags_commands" \
"*::: :->treetags" \
&& ret=0
    case $state in
    (treetags)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:treetags-command-$line[2]:"
        case $line[2] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_treetags__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:treetags-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_treetags_commands] )) ||
_treetags_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'treetags commands' commands "$@"
}
(( $+functions[_treetags__completions_commands] )) ||
_treetags__completions_commands() {
    local commands; commands=()
    _describe -t commands 'treetags completions commands' commands "$@"
}
(( $+functions[_treetags__help_commands] )) ||
_treetags__help_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'treetags help commands' commands "$@"
}
(( $+functions[_treetags__help__completions_commands] )) ||
_treetags__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'treetags help completions commands' commands "$@"
}
(( $+functions[_treetags__help__help_commands] )) ||
_treetags__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'treetags help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_treetags" ]; then
    _treetags "$@"
else
    compdef _treetags treetags
fi
