#compdef date-cli
# _date-cli — GNU coreutils date print or set system date and time CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_date-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d+[date string]:str:' \
        '--date=+[date string]:str:' \
        '--debug[debug]' \
        '-f+[file]:file:_files' \
        '--file=+[file]:file:_files' \
        '-I[ISO 8601 format]' \
        '--iso-8601[ISO 8601 format]' \
        '-I+[precision]:p:(date hours minutes seconds ns)' \
        '--iso-8601=+[precision]:p:(date hours minutes seconds ns)' \
        '-R[RFC 2822 format]' \
        '--rfc-2822[RFC 2822 format]' \
        '--rfc-email[RFC 2822 format]' \
        '--rfc-3339=+[precision]:p:(date seconds ns)' \
        '-r+[file]:file:_files' \
        '--reference=+[file]:file:_files' \
        '-s+[time string]:str:' \
        '--set=+[time string]:str:' \
        '-u[UTC]' \
        '--utc[UTC]' \
        '--universal[UTC]' \
        '--resolution[print resolution]' \
        '*:format:'
}

_date-cli "$@"
