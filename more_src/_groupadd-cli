#compdef groupadd-cli groupdel-cli groupmod-cli
# _groupadd-cli — shadow groupadd/groupdel/groupmod create/delete/modify a group CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_groupadd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-f[force]' \
        '--force[force]' \
        '-g+[gid]:n:' \
        '--gid=+[gid]:n:' \
        '-K+[key=value]:str:' \
        '--key=+[key=value]:str:' \
        '-o[non unique]' \
        '--non-unique[non unique]' \
        '-p+[encrypted password]:str:' \
        '--password=+[encrypted password]:str:' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '-r[create system group]' \
        '--system[create system group]' \
        '-R+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '-n+[new name]:str:' \
        '--new-name=+[new name]:str:' \
        '-A+[add user csv]:str:' \
        '--add-users=+[add user csv]:str:' \
        '-D+[delete user csv]:str:' \
        '--delete-users=+[delete user csv]:str:' \
        '-U+[add user]:_users' \
        '--users=+[add user]:_users' \
        '*:group:_groups'
}

_groupadd-cli "$@"
