#compdef marian-scorer
# Documentation: https://marian-nmt.github.io/docs/cmd/marian-scorer/
# Marian neural machine translation scorer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '--version[display version information]' \
  '(-c --config)'{-c,--config}'=[configuration file(s)]:file:_files' \
  '(-w --workspace)'{-w,--workspace}'=[preallocate workspace in MB]:mb' \
  '--log=[log process information to file]:file:_files' \
  '--log-level=[set logging verbosity]:level:(trace debug info warn err critical off)' \
  '--seed=[seed for all random number generators]:seed' \
  '--quiet[suppress stderr logging]' \
  '(-m --model)'{-m,--model}'=[path prefix for model to be saved/resumed]:file:_files' \
  '--type=[model type]:type:(amun nematus s2s multi-s2s transformer)' \
  '--dim-vocabs=[maximum vocabulary size per rank]:n' \
  '--dim-emb=[embedding vector size]:n' \
  '--dim-rnn=[RNN hidden state size]:n' \
  '--enc-depth=[number of encoder layers]:n' \
  '--dec-depth=[number of decoder layers]:n' \
  '--transformer-heads=[number of heads in multi-head attention]:n' \
  '--no-reload[skip loading existing model]' \
  '(-t --train-sets)'{-t,--train-sets}'=[paths to corpora to be scored: source target]:files:_files' \
  '(-o --output)'{-o,--output}'=[output file location]:file:_files' \
  '(-v --vocabs)'{-v,--vocabs}'=[vocabulary file paths]:files:_files' \
  '(-n --normalize)'{-n,--normalize}'[divide translation score by translation length]' \
  '--summary=[only print total cost]:mode:(cross-entropy ce-mean ce-mean-words ce-sum perplexity)' \
  '--alignment=[return word alignments]:mode' \
  '--word-scores[print subword-level scores]' \
  '--max-length=[maximum sentence length]:n' \
  '(-d --devices)'{-d,--devices}'=[GPU IDs to use]:ids' \
  '--mini-batch=[mini-batch size for scoring]:n' \
  '--fp16[mixed precision inference with float16]' \
  '*:file:_files' && ret=0

return ret
