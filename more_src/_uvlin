#compdef uvlin
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvlin.html
# MIRIAD uvlin - continuum subtraction in the uv domain

local ret=1

_arguments -s -S \
  'vis=[input uv dataset name]:vis:_files' \
  'select=[uv selection commands]:select' \
  'line=[uv line type line,nchan,start,width,step]:line' \
  'chans=[channel ranges with line-free continuum]:chans' \
  'out=[output uv dataset name]:out:_files' \
  'order=[polynomial order for continuum fit (0-5)]:order' \
  'offset=[positional offset in arcsec to shift data]:offset' \
  'mode=[output content line/fit/chan0/continuum/ratio]:mode:(line fit chan0 continuum ratio)' \
  'options=[sun,twofit,nowindow,lpropc,relax,nocal,nopass,nopol]:options' \
  '*:visibility data:_files' && ret=0

return ret
