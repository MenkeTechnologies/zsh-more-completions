#compdef thisroot.sh thisroot.csh thisroot.fish thisroot.bat
# Documentation: https://github.com/root-project/root/blob/master/config/thisroot.sh
# Reference accessed: 2026-05-27
# Verified: upstream config/thisroot.sh — sourced shell script that exports
# ROOTSYS / PATH / LD_LIBRARY_PATH / PYTHONPATH / MANPATH. Accepts no flags.

# thisroot.sh is intended to be `source`d, not executed. It parses no arguments
# (no getopts / case "$1" branches in upstream). Offer file completion so
# `source thisroot.sh <TAB>` still works at the shell level if the user types
# a stray argument, but advertise that no flags are accepted.

local curcontext="$curcontext" ret=1

_arguments '*:file:_files' && ret=0

return ret
