#compdef codeswarm
# Documentation: https://github.com/mskutlu/codeswarm
# Reference accessed: 2026-05-22
# Verified: bin/codeswarm.js routing and README CLI reference.

# Zsh completion for codeswarm - multi-agent coding orchestrator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--project[target project directory]:directory:_directories' \
  '--task[task description]:task:' \
  '--prd[PRD file path]:file:_files' \
  '--plan[existing plan file]:file:_files' \
  '--planner[planning agent]:agent:' \
  '--executor[execution agent]:agent:' \
  '--reviewer[review agent(s)]:agents:' \
  '--fe-dev[frontend executor agent]:agent:' \
  '--fe-reviewer[frontend reviewer agent(s)]:agents:' \
  '--max-rounds[max planner rounds]:rounds:' \
  '--max-iterations[max execute-review cycles]:iterations:' \
  '--model[model per agent agent:model]:spec:' \
  '--dashboard[start real-time dashboard]' \
  '--tmux[use tmux for agent terminals]' \
  '--dry-run[print prompts without executing]' \
  '--verbose[show full agent output]' \
  '--context[comma-separated context files]:files:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'codeswarm command' \
      'gsd[Get Shit Done multi-agent mode]' && ret=0
    ;;
  args)
    case $line[1] in
      gsd)
        _values 'gsd action' install run && ret=0
        ;;
    esac
    ;;
esac

return ret
