#compdef pdfplumber
# Documentation: https://github.com/jsvine/pdfplumber/blob/stable/pdfplumber/cli.py
# Plumb a PDF for detailed information and extract text and tables

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--structure[write the structure tree as JSON]' \
  '--structure-text[write the structure tree as JSON including text contents]' \
  '--format=[output format]:format:(csv json text)' \
  '*--types=[object types to include]:types:' \
  '*--include-attrs=[include only these object attributes]:attrs:' \
  '*--exclude-attrs=[exclude these object attributes]:attrs:' \
  '--laparams=[LAParams configuration as JSON string]:json:' \
  '--precision=[output precision]:precision:' \
  '*--pages=[pages to extract, e.g. 1-5]:pages:' \
  '--indent=[indent level for JSON pretty-printing]:indent:' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
