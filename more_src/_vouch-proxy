#compdef vouch-proxy

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-config=[path to configuration file]:file:_files -g "*.{yml,yaml}"' \
  '-document_root=[document root for static files]:dir:_directories' \
  '-loglevel=[log level]:level:(debug info warn error)' \
  '-port=[port to listen on]:port' \
  '-test[test configuration and exit]'
