#compdef lja
# Documentation: https://github.com/AntonBankevich/LJA/blob/main/docs/lja_manual.md
# LJA: genome assembly from PacBio HiFi reads based on de Bruijn graphs

local ret=1

_arguments -s -S \
  '--help[print help message]' \
  '(-o --output-dir)'{-o+,--output-dir=}'[name of output folder]:dir:_files -/' \
  '*--reads=[file containing reads in FASTA or FASTQ]:file:_files' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:threads' \
  '-k+[k (vertex size) for initial error correction]:k' \
  '-K+[k (vertex size) for final error correction]:K' \
  '--diploid[use for diploid genome]' && ret=0

return ret
