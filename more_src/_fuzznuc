#compdef fuzznuc
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/fuzznuc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS fuzznuc: search nucleic acid sequence(s) with a PROSITE pattern
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input DNA sequence(s)]:DNA USA:_files' \
  '-pattern=[search pattern (PROSITE notation, supports gaps and mismatches)]:pattern:' \
  '-complement[also search reverse complement]' \
  '-rformat=[report format]:format:(table excel feattable gff3 listfile motif pir simple swiss tagseq)' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
