#compdef qtiplot
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/qtiplot.1.html
# qtiplot - data analysis and scientific plotting

local ret=1

_arguments -s \
  '--about[show about dialog and exit]' \
  '--default[start QtiPlot with the default settings]' \
  '--help[show command line options]' \
  '--lang=[start QtiPlot in language XX (en, fr, de, ...)]:lang' \
  '--manual[show QtiPlot manual in a standalone window]' \
  '--version[print QtiPlot version and release date]' \
  '--execute[execute the script file given as argument]:file:_files' \
  '*:file:_files' && ret=0

return ret
