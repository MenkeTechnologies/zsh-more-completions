#compdef apt-listbugs
# Documentation: https://manpages.debian.org/testing/apt-listbugs/apt-listbugs.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'apt:read package actions from APT hook fd'
  'list:list bugs for given packages'
  'rss:list bugs in RSS format'
)

_arguments -C \
  '(-s --severity)'{-s,--severity=}'[severity filter]:sev:(critical grave serious important normal minor wishlist all)' \
  '(-T --tag)'{-T,--tag=}'[tag filter]:tags:' \
  '(-S --stats)'{-S,--stats=}'[state filter]:state:(pending forwarded pending-fixed fixed absent done)' \
  '(-B --bugs)'{-B,--bugs=}'[bug numbers]:bugs:' \
  '(-r --distro-release)'{-r,--distro-release=}'[distro release]:release:' \
  '(-D --show-downgrade)'{-D,--show-downgrade}'[show downgrade bugs]' \
  '(-u --url)'{-u,--url=}'[BTS SOAP URL]:url:' \
  '(-H --hostname)'{-H,--hostname=}'[BTS hostname]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[BTS port]:port:' \
  '(-P --pin-priority)'{-P,--pin-priority=}'[pin priority]:n:' \
  '(-E --title)'{-E,--title=}'[RSS title]:title:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress]' \
  '(-C --aptconf)'{-C,--aptconf=}'[APT config]:file:_files' \
  '(-F --force-pin)'{-F,--force-pin}'[auto-pin without prompt]' \
  '(-N --force-no-pin)'{-N,--force-no-pin}'[never auto-pin]' \
  '(-y --force-yes)'{-y,--force-yes}'[assume yes]' \
  '(-n --force-no)'{-n,--force-no}'[assume no]' \
  '(-a --force-default)'{-a,--force-default}'[default replies]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'apt-listbugs subcommand' subcommands && ret=0
    ;;
esac

return ret
