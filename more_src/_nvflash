#compdef nvflash
# Documentation: https://man.archlinux.org/search?q=nvflash
# Reference accessed: 2026-05-16

# nvflash: legacy NVIDIA Tegra flash programmer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--bct=[BCT file]:file:_files' \
  '--bl=[bootloader]:file:_files' \
  '--odmdata=[ODM data hex]:hex:' \
  '--configfile=[config file]:file:_files' \
  '--create[create partition table]' \
  '--write=[write partition]:name file:' \
  '--read=[read partition]:name file:' \
  '--format=[format partition]:name:' \
  '--rcm[recovery mode]' \
  '--rcm-key=[RCM signing key]:file:_files' \
  '--blob=[blob file]:file:_files' \
  '--diskimg=[disk image]:file:_files' \
  '--skipuid[skip uid check]' \
  '--reset[reset]' \
  '*::nvflash args:_files' && ret=0
return ret
