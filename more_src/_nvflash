#compdef nvflash
# Documentation: http://http.download.nvidia.com/tegra-public-appnotes/flashing-tools.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Tool has many product-specific
# flags; this stub lists the commonly documented Tegra subset.

# nvflash: legacy NVIDIA Tegra flash programmer (STUB)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--bct[BCT file]:file:_files' \
  '--setbct[program BCT to device]' \
  '--getbct[read BCT from device]' \
  '--bl[bootloader filename]:file:_files' \
  '--odmdata[ODM data]:hex:' \
  '--configfile[partition config file]:file:_files' \
  '--create[create partitions per config]' \
  '--go[hand off to bootloader after flashing]' \
  '-r[resume; fastboot already running]' \
  '*::nvflash args:_files' && ret=0
return ret
