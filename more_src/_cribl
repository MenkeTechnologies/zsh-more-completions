#compdef cribl

_cribl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_cribl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                start|stop|restart|reload|status)
                    _arguments \
                        '-m[operating mode]:mode:(master worker single)' \
                        '(- *)'{-h,--help}'[show help]' && ret=0
                    ;;
                mode)
                    _arguments \
                        '-m[set operating mode]:mode:(master worker single)' \
                        '(- *)'{-h,--help}'[show help]' && ret=0
                    ;;
                boot-start)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' && ret=0
                    ;;
                diag)
                    _arguments \
                        '--output[output file path]:output file:_files' \
                        '(- *)'{-h,--help}'[show help]' && ret=0
                    ;;
                pack)
                    _arguments \
                        '--output[output file path]:output file:_files' \
                        '(- *)'{-h,--help}'[show help]' \
                        '*:pack directory:_directories' && ret=0
                    ;;
                unpack)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '*:pack file:_files' && ret=0
                    ;;
                auth) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cribl_commands] )) ||
_cribl_commands() {
    local -a commands
    commands=(
        'start:start Cribl Stream'
        'stop:stop Cribl Stream'
        'restart:restart Cribl Stream'
        'reload:reload Cribl Stream configuration'
        'status:show Cribl Stream status'
        'mode:get or set operating mode'
        'boot-start:configure Cribl to start on boot'
        'diag:collect diagnostic information'
        'pack:pack a Cribl pack'
        'unpack:unpack a Cribl pack'
        'auth:manage authentication'
    )
    _describe -t commands 'cribl command' commands
}

_cribl "$@"
