#compdef luacov
# Documentation: https://github.com/lunarmodules/luacov
# generate a coverage report from luacov.stats.out

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message and exit]' \
  '(-c --config)'{-c,--config}'+[use a config file (.luacov by default)]:file:_files' \
  '(-r --reporter)'{-r,--reporter}'+[use a custom reporter in luacov.reporter namespace]:reporter' \
  '*:pattern' && ret=0

return ret
