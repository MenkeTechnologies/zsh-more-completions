#compdef bkmr
# Documentation: https://github.com/sysid/bkmr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# sysid/bkmr bkmr/src/cli/args.rs — global options + Commands enum

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'search:FTS and tag search'
  'hsearch:hybrid semantic + FTS'
  'sem-search:semantic embedding search'
  'open:open bookmark(s)'
  'add:add bookmark'
  'delete:delete bookmarks'
  'update:update bookmark fields'
  'edit:edit bookmark in $EDITOR'
  'show:show bookmark details'
  'surprise:random bookmark'
  'tags:manage tags'
  'create-db:create SQLite database'
  'backfill:embedding backfill'
  'clear-embeddings:clear stored embeddings'
  'load-json:import JSON bookmarks'
  'import-files:import files as bookmarks'
  'info:database metadata'
  'completion:emit shell completion'
  'lsp:LSP server'
  'xxx:experimental hook'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--db[SQLite path]:file:_files' \
  '*'{-d,--debug}'[increase log verbosity]' \
  '--no-color[disable ANSI color]' \
  '--generate-config[print example TOML]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'bkmr command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
