#compdef navidrome
# Documentation: https://www.navidrome.org/docs/usage/admin/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for navidrome - music server

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'inspect:inspect music file tags'
  'scan:run a library scan'
  'backup:manage database backups'
  'bkp:alias for backup'
  'pls:export and list playlists'
  'service:manage OS service lifecycle'
  'svc:alias for service'
  'user:user administration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --configfile)'{-c,--configfile=}'[path to config file]:file:_files' \
  '(-n --nobanner)'{-n,--nobanner}'[suppress startup banner]' \
  '--musicfolder=[path to music folder]:dir:_directories' \
  '--datafolder=[path to data folder]:dir:_directories' \
  '--cachefolder=[path to cache folder]:dir:_directories' \
  '(-l --loglevel)'{-l,--loglevel=}'[log level]:level:(error warn info debug trace)' \
  '--logfile=[log file path]:file:_files' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'navidrome command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (scan)
        _arguments \
          '(-f --full)'{-f,--full}'[full rescan]' \
          '(-t --target)'{-t,--target=}'[target folder]:dir:_directories' \
          '--target-file=[read targets from file]:file:_files' && ret=0
        ;;
      (backup|bkp)
        _arguments '1:subcommand:(create prune restore)' && ret=0
        ;;
      (user)
        _arguments '1:subcommand:(create delete edit list)' && ret=0
        ;;
      (service|svc)
        _arguments '1:subcommand:(install uninstall start stop status execute)' && ret=0
        ;;
    esac
    ;;
esac

return ret
