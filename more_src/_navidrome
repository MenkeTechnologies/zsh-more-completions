#compdef navidrome

# Zsh completion for navidrome - music server CLI

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--configfile=[path to config file]:file:_files' \
  '--musicfolder=[path to music folder]:dir:_directories' \
  '--datafolder=[path to data folder]:dir:_directories' \
  '--cachefolder=[path to cache folder]:dir:_directories' \
  '--loglevel=[log level]:level:(error warn info debug trace)' \
  '--address=[bind address]:address' \
  '--port=[HTTP port]:port' \
  '--baseurl=[base URL path]:url' \
  '--tlscert=[TLS certificate file]:file:_files' \
  '--tlskey=[TLS key file]:file:_files' \
  '--scaninterval=[interval between library scans]:duration' \
  '--sessiontimeout=[session timeout duration]:duration' \
  '--enabletranscodingconfig[enable transcoding configuration in the UI]' \
  '--transcodingcachesize=[transcoding cache max size]:size' \
  '--imagecachesize=[image cache max size]:size' \
  '--autoimportplaylists[auto-import playlists from music folder]' \
  '--enablesharing[enable sharing features]' \
  '--enablestarrating[enable star rating]' \
  '--enablefavourites[enable favourites]' \
  '--enablecoveranimation[enable cover art animation]' \
  '--enablegravatar[enable Gravatar integration]' \
  '--enableexternalservices[enable external services like Last.fm]' \
  '--lastfm.apikey=[Last.fm API key]:key' \
  '--lastfm.secret=[Last.fm secret]:secret' \
  '--lastfm.language=[Last.fm language]:lang' \
  '--spotify.id=[Spotify client ID]:id' \
  '--spotify.secret=[Spotify client secret]:secret' \
  '--reverseproxyuserheader=[header for reverse proxy user]:header' \
  '--reverseproxywhitelist=[trusted reverse proxy IPs]:ips' \
  '--prometheus.enabled[enable Prometheus metrics]' \
  '--prometheus.metricspath=[Prometheus metrics path]:path' \
  && return 0
