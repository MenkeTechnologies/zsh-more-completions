#compdef ipa-client-install

_arguments -s \
  '--domain=[domain]:domain:' \
  '*--server=[server]:host:_hosts' \
  '--realm=[realm name]:realm:' \
  '--fixed-primary[fix primary server]' \
  '(-p --principal)'{-p,--principal=}'[principal]:principal:' \
  '(-w --password)'{-w,--password=}'[password]:pw:' \
  '-W[prompt for join password]' \
  '(-k --keytab)'{-k,--keytab=}'[keytab file]:file:_files' \
  '--mkhomedir[create home directories]' \
  '--hostname=[hostname]:host:_hosts' \
  '--force-join[force join]' \
  '--ntp-server=[NTP server]:host:_hosts' \
  '--ntp-pool=[NTP pool]:pool:' \
  '(-N --no-ntp)'{-N,--no-ntp}'[skip NTP]' \
  '--nisdomain=[NIS domain]:domain:' \
  '--no-nisdomain[no NIS domain]' \
  '--ssh-trust-dns[trust DNS SSHFP]' \
  '--no-ssh[skip SSH config]' \
  '--no-sshd[skip SSHD config]' \
  '--no-sudo[skip sudo config]' \
  '--subid[configure SSSD as subid source]' \
  '--no-dns-sshfp[skip DNS SSHFP]' \
  '--noac[no auth config]' \
  '(-f --force)'{-f,--force}'[force]' \
  '--kinit-attempts=[kinit attempts]:n:' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-U --unattended)'{-U,--unattended}'[unattended]' \
  '--ca-cert-file=[CA cert file]:file:_files' \
  '--request-cert[request cert (deprecated)]' \
  '--automount-location=[automount location]:loc:' \
  '--configure-firefox[configure Firefox]' \
  '--firefox-dir=[Firefox dir]:dir:_files -/' \
  '*--ip-address=[IP address]:ip:' \
  '--all-ip-addresses[use all IP addresses]' \
  '--permit[permit user logins]' \
  '--enable-dns-updates[enable DNS updates]' \
  '--no-krb5-offline-passwords[no offline passwords]' \
  '(-S --no-sssd)'{-S,--no-sssd}'[no SSSD]' \
  '--preserve-sssd[preserve sssd config]' \
  '--pkinit-identity=[PKINIT identity]:id:' \
  '--pkinit-anchor=[PKINIT anchor]:file:_files' \
  '--uninstall[uninstall client]' \
  '(- *)'{-h,--help}'[show help]'
