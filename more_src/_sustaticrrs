#compdef sustaticrrs
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sustaticrrs.c
# elevation static corrections with residual refraction statics

local ret=1

_arguments -s -S \
  'v0=[weathering velocity]:v0' \
  'v1=[subweathering velocity]:v1' \
  'hdrs=[statics flag 0..5]:hdrs:(0 1 2 3 4 5)' \
  'sign=[add (1) or subtract (-1) statics]:sign:(1 -1)' \
  'sou_file=[input file for source statics (ms)]:file:_files' \
  'rec_file=[input file for receiver statics (ms)]:file:_files' \
  'ns=[number of sources]:ns' \
  'nr=[number of receivers]:nr' \
  'no=[number of offsets]:no' \
  'blvl_file=[base of near-surface model file]:file:_files' \
  'refr_file=[horizontal reference datum file]:file:_files' \
  'nsamp=[number of midpoints on line]:nsamp' \
  'fx=[first x location in velocity model]:fx' \
  'dx=[midpoint interval]:dx' \
  'V_r=[replacement velocity]:V_r' \
  'mx=[velocity model samples in lateral direction]:mx' \
  'mz=[velocity model samples in vertical direction]:mz' \
  'dzv=[velocity model depth interval]:dzv' \
  'vfile=[near-surface velocity model file]:file:_files' \
  '*:file:_files' && ret=0


return ret
