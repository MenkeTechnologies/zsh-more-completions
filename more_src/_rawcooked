#compdef rawcooked

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--all[encode all files]' \
  '--no-accept-gaps[do not accept gaps in sequence]' \
  '--check[check encoded file]:file:_files -g "*.mkv"' \
  '--info[show info about encoded file]' \
  '--display-command[display FFmpeg command]' \
  '--output-name[output file name]:file:_files' \
  '--rawcooked-file-name[reversibility data file]:file:_files' \
  '--attachment-max-size[max attachment size]:size:' \
  '--hash[hash format]:format:(md5 none)' \
  '--framemd5[compute per-frame MD5]' \
  '--framemd5-an[audio not included in per-frame MD5]' \
  '--ffmpeg-threads[FFmpeg threads]:threads:' \
  '--encode[encode]:encoder:' \
  '-y[overwrite output files]' \
  '-n[never overwrite output files]' \
  '-framerate[frame rate]:rate:' \
  '*:input:_files' \
  && ret=0

return ret
