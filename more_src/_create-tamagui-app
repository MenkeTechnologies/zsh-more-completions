#compdef create-tamagui-app
# Documentation: https://www.npmjs.com/package/create-tamagui-app
# Reference accessed: 2026-05-24
# Verified: npx create-tamagui-app --help.

# Zsh completion for create-tamagui-app - Tamagui Next/Expo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '--use-npm[use npm as package manager]' \
  '--use-pnpm[use pnpm as package manager]' \
  '(-t --template)'{-t,--template=}'[template name]:template:(next-expo-solito)' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project directory:_directories' && ret=0

return ret
