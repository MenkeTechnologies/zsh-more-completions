#compdef vireo
# Documentation: https://vireosnp.readthedocs.io/en/latest/manual.html
# vireo - donor deconvolution for pooled single-cell data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --cellData)'{-c,--cellData}'=[cell genotype VCF or cellSNP folder]:path:_files' \
  '(-N --nDonor)'{-N,--nDonor}'=[number of donors to demultiplex]:n:' \
  '(-o --outDir)'{-o,--outDir}'=[output directory]:dir:_files -/' \
  '--vartrixData=[cell genotype files in vartrix format]:files:' \
  '(-d --donorFile)'{-d,--donorFile}'=[donor genotype VCF file]:vcf:_files' \
  '(-t --genoTag)'{-t,--genoTag}'=[donor genotype tag]:tag:(GT GP PL)' \
  '--noDoublet[disable doublet checking]' \
  '(-M --nInit)'{-M,--nInit}'=[number of random initializations]:n:' \
  '--extraDonor=[number of extra donor in pre-cluster]:n:' \
  '--extraDonorMode=[method for extra donor search]:mode:(size distance)' \
  '--forceLearnGT[treat donor GT as prior only]' \
  '--ASEmode[enable SNP-specific allelic ratio]' \
  '--noPlot[disable GT distance plotting]' \
  '--randSeed=[seed for random initialization]:seed:' \
  '--cellRange=[range of cells to process]:range:' \
  '--callAmbientRNAs[detect ambient RNAs in each cell]' \
  '(-p --nproc)'{-p,--nproc}'=[number of subprocesses]:n:' \
  '*:file:_files' && ret=0

return ret
