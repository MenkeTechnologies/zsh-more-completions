#compdef king-phisher king-phisher-client king-phisher-server

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-L+[log level]:lvl:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--logger=+[log to file]:file:_files' \
  '--config=+[config file]:file:_files -g "*.yml" -g "*.yaml"' \
  '--no-style[no GTK styling]' \
  '--no-plugins[disable plugins]' && ret=0

return ret
