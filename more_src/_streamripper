#compdef streamripper
# Documentation: https://man.archlinux.org/search?q=streamripper
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-d+[base directory]:dir:_files -/' \
  '-s[no per-stream subdir]' \
  '-D+[output filename pattern]:pattern:' \
  '-r+[run relay server]:port:' \
  '-R+[max relay connections]:n:' \
  '-z[disable port scanning]' \
  '-p+[HTTP proxy]:url:' \
  '-a+[record stream as single file]:pattern:' \
  '-A[skip individual track files]' \
  '-o+[overwrite behavior]:mode:(always never larger version)' \
  '-t[do not overwrite incomplete tracks]' \
  '-T[truncate duplicate files]' \
  '-c[disable auto-reconnect]' \
  '-l+[run for seconds]:secs:' \
  '-M+[stop after MB]:mb:' \
  '-q+[prepend sequence numbers]:start:' \
  '-i[no ID3 tags]' \
  '--with-id3v1[add ID3v1 tags]' \
  '--without-id3v2[no ID3v2 tags]' \
  '-k+[files to keep in incomplete dir]:n:' \
  '-m+[reconnect timeout secs]:secs:' \
  '-u+[user agent]:ua:' \
  '-w+[parse rules file]:file:_files' \
  '-E+[external metadata helper]:cmd:' \
  '--debug[write debug log]' \
  '--quiet[suppress console output]' \
  '--stderr[redirect to stderr]' \
  '--xs_silence_length=[silence threshold]:n:' \
  '--xs_search_window=[silence search window]:n\:n:' \
  '--xs_offset=[splitpoint offset]:n:' \
  '--xs_padding=[padding before/after]:n\:n:' \
  '--xs-none[disable silent-spot search]' \
  '--xs2[alternative silence detection]' \
  '--codeset-filesys=[filename encoding]:codeset:' \
  '--codeset-id3=[ID3 encoding]:codeset:' \
  '--codeset-metadata=[stream metadata encoding]:codeset:' \
  '--codeset-relay=[relay metadata encoding]:codeset:' \
  ':url:'
