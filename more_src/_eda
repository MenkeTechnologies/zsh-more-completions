#compdef eda
# _eda — chipsalliance EDA cli wrapper for invoking open-source Electronic Design Automation flows Yosys nextpnr OpenROAD VPR Verilator Icarus gtkwave covering synthesis place route simulation viewing (chipsalliance team, Python); click
# upstream: https://github.com/chipsalliance/eda

_eda() {
    local -a sub=(
        'synth:run synthesis with Yosys'
        'pnr:run place & route with nextpnr or OpenROAD'
        'sim:run simulation with Verilator or Icarus'
        'view:open waveform with GTKWave or surfer'
        'lint:lint Verilog/VHDL with Verilator'
        'fmt:format Verilog/VHDL with verible-verilog-format'
        'compile:compile design'
        'flash:flash bitstream to board'
        'init:initialize new EDA project'
        'config:show configuration'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '-t+[target]:t:(ice40 ecp5 gowin xilinx-7series xilinx-ultrascale efinix-trion machx02 machx03 nexus titanium)' \
        '--target=+[target]:t:(ice40 ecp5 gowin xilinx-7series xilinx-ultrascale efinix-trion)' \
        '-b+[board]:str:' \
        '--board=+[board]:str:' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'eda subcommand' sub ;;
        args)
            case $words[1] in
                synth|pnr|sim|lint|fmt|compile) _arguments \
                    '*:verilog vhdl sv file:_files -g "*.v *.sv *.vhd *.vhdl *.svh"' ;;
                view) _arguments \
                    '*:wave file:_files -g "*.vcd *.fst *.ghw *.lxt2"' ;;
                flash) _arguments \
                    '*:bitstream file:_files -g "*.bit *.bin *.svf *.fs *.bin.svf *.jam *.jbc *.ttf"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_eda "$@"
