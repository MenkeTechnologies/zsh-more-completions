#compdef abctree
# Documentation: https://github.com/alembic/alembic/blob/master/bin/AbcTree/AbcTree.cpp
# Alembic: print the hierarchy of an Alembic archive as a tree

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[include properties listings]' \
  '-m[print metadata]' \
  '*:alembic archive:_files -g "*.abc"' && ret=0

return ret
