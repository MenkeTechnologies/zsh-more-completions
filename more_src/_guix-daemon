#compdef guix-daemon
# GNU Guix build daemon

local ret=1

_arguments -s -S \
  '--build-users-group=[build users group]:group:_groups' \
  '--no-substitutes[do not use substitutes]' \
  '--substitute-urls=[substitute server URLs]:URLs:' \
  '--no-build-hook[do not use the build hook]' \
  '--cache-failures[cache build failures]' \
  '--rounds=[build derivations N rounds]:rounds:' \
  '--max-build-jobs=[max simultaneous builds]:jobs:' \
  '--max-silent-time=[max silent time before kill]:seconds:' \
  '--timeout=[max build time]:seconds:' \
  '--cores=[number of CPU cores per build]:cores:' \
  '--disable-chroot[disable chroot builds]' \
  '--chroot-directory=[add directory to chroot]:directory:_files -/' \
  '--gc-keep-derivations[keep derivations on GC]' \
  '--gc-keep-outputs[keep outputs on GC]' \
  '--listen=[listen on socket]:socket:_files' \
  '--debug[enable debug output]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
