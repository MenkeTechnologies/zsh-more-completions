#compdef namadac
# Documentation: https://docs.namada.net/users
# namadac - Namada client (transactions and queries)

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'transparent-transfer:transparent token transfer'
  'shielded-transfer:shielded token transfer'
  'shielding-transfer:shielding (transparent->shielded) transfer'
  'unshielding-transfer:unshielding (shielded->transparent) transfer'
  'ibc-transfer:IBC token transfer'
  'osmosis-swap:Osmosis swap'
  'shielded-sync:synchronize the shielded wallet'
  'bond:bond tokens to a validator'
  'unbond:unbond tokens from a validator'
  'withdraw:withdraw unbonded tokens'
  'redelegate:redelegate bonded tokens'
  'claim-rewards:claim staking rewards'
  'init-account:initialize an established account'
  'update-account:update an established account'
  'reveal-pk:reveal a public key on chain'
  'init-proposal:submit a governance proposal'
  'vote-proposal:vote on a governance proposal'
  'become-validator:become a validator'
  'unjail-validator:unjail a validator'
  'tx:submit a custom transaction'
  'epoch:query the current epoch'
  'balance:query a token balance'
  'bonds:query bonds'
  'delegations:query delegations'
  'rewards:query staking rewards'
  'account:query an account'
  'block:query a block'
  'status:query node status'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--node=[ledger RPC address]:url:' \
  '--base-dir=[base directory for files]:dir:_files -/' \
  '--chain-id=[chain id]:id:' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'namadac command' sub && ret=0 ;;
esac

return ret
