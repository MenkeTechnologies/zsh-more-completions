#compdef bean-format
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/bean-format.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-o --output)'{-o,--output}'=[output file]:file:_files'
  '(-c --currency-column)'{-c,--currency-column}'=[currency column position]:column:'
  '(-w --width)'{-w,--width}'=[target width]:width:'
  '--prefix=[number prefix character count]:count:'
  '--indent=[indentation size]:size:'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-h --help)'{-h,--help}'[show help message]'
  '--version[show version]'
  '*:beancount file:_files -g "*.beancount"'
)

_arguments -s -S $arguments
