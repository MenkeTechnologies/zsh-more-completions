#compdef slrnpull
# Documentation: https://man.archlinux.org/search?q=slrnpull
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-h+[NNTP host]:host:_hosts' \
  '-d+[spool dir]:dir:_files -/' \
  '--debug+[debug file]:file:_files' \
  '--logfile+[log file]:file:_files' \
  '--marked-bodies[mark bodies]' \
  '--no-post[no post]' \
  '--no-active[skip active]' \
  '--kill-log+[kill log file]:file:_files' \
  '--rebuild[rebuild .overview]' \
  '--expire[expire only]' \
  '--new-groups[new groups only]' \
  '*: :_files' && ret=0

return ret
