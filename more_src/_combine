#compdef combine
# _combine — moreutils combine (set operations on lines of two files; chooses lines from file1 that satisfy the boolean combination with file2 using and/not/or/xor operators between the two filenames)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Argument shape from moreutils combine.pl on tip.

_combine() {
    _arguments \
        '1:file1:_files' \
        '2:operator:(and not or xor)' \
        '3:file2:_files'
}

_combine "$@"
