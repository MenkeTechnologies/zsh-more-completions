#compdef llm-jq
# Documentation: https://github.com/simonw/llm-jq
# Write and execute jq programs with the help of an LLM

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '(-s --silent)'{-s,--silent}'[do not print the jq program to stderr]' \
  '(-o --output)'{-o,--output}'[output just the jq program, do not run it]' \
  '(-v --verbose)'{-v,--verbose}'[show the prompt sent to the model and the response]' \
  '(-m --model)'{-m,--model}'+[use a model other than the default]:model:' \
  '(-l --length)'{-l,--length}'+[length of the input to use as the example]:length:' \
  '*:description:' && ret=0

return ret
