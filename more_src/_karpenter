#compdef karpenter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--cluster-endpoint[Kubernetes cluster endpoint URL]:url' \
  '--cluster-name[Kubernetes cluster name]:name' \
  '--karpenter-service[Karpenter service name]:service' \
  '--memory-limit[memory limit for the controller]:limit' \
  '--metrics-port[port for metrics endpoint]:port' \
  '--health-probe-port[port for health probe endpoint]:port' \
  '--enable-profiling[enable profiling]' \
  '--batch-max-duration[maximum duration for batching]:duration' \
  '--batch-idle-duration[idle duration before processing a batch]:duration' \
  '*--feature-gates[feature gates to enable]:gate=value' \
  '--log-level[log level]:level:(debug info error)' && ret=0

return ret
