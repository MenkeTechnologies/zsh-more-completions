#compdef karpenter
# Documentation: https://github.com/kubernetes-sigs/karpenter/blob/main/pkg/operator/options/options.go
# Reference accessed: 2026-05-19
# Verified: upstream source (Options.AddFlags fs.*Var calls) at the URL
# above. Removed invented --cluster-endpoint/--cluster-name (env/CRD only,
# not CLI flags); added the real flag set below.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--karpenter-service[Karpenter Service name for the dynamic webhook certificate]:service' \
  '--metrics-port[port the metrics endpoint binds to]:port' \
  '--health-probe-port[port the health probe endpoint binds to]:port' \
  '--kube-client-qps[max QPS to the Kubernetes API server]:qps' \
  '--kube-client-burst[max burst to the Kubernetes API server]:burst' \
  '--enable-profiling[enable pprof profiling]' \
  '--disable-controller-warmup[disable controller warmup]' \
  '--disable-leader-election[disable leader election]' \
  '--disable-cluster-state-observability[disable cluster state observability]' \
  '--leader-election-name[name of the leader election config map]:name' \
  '--leader-election-namespace[namespace of the leader election config map]:ns' \
  '--memory-limit[memory limit for the controller]:limit' \
  '--cpu-requests[CPU requests in millicores for the controller]:millicores' \
  '--log-level[log level]:level:(debug info error)' \
  '--log-output-paths[optional comma-separated list of log output paths]:paths' \
  '--log-error-output-paths[optional comma-separated list of error log output paths]:paths' \
  '--batch-max-duration[maximum duration for batching]:duration' \
  '--batch-idle-duration[idle duration before processing a batch]:duration' \
  '--preference-policy[how the scheduler treats preferences]:policy' \
  '--min-values-policy[minValues policy for scheduling]:policy' \
  '--ignore-dra-requests[ignore Dynamic Resource Allocation requests]' \
  '--feature-gates[feature gates to enable]:gate=value' && ret=0

return ret
