#compdef pweave
# Documentation: https://mpastell.com/pweave/script.html
# Pweave: literate programming tool for scientific reports with Python

local ret=1

_arguments -s -S \
  '(- *)--version[show version and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(tex texminted texpweave texpygments rst pandoc markdown leanpub sphinx html md2html softcover pandoc2latex pandoc2html notebook)' \
  '(-i --input-format)'{-i+,--input-format=}'[input format]:format:(noweb markdown notebook script)' \
  '(-k --kernel)'{-k+,--kernel=}'[Jupyter kernel used to run code]:kernel:' \
  '(-o --output)'{-o+,--output=}'[output file name]:output file:_files' \
  '(-l --list-formats)'{-l,--list-formats}'[list output formats]' \
  '(-m --matplotlib)'{-m,--matplotlib}'[disable matplotlib]' \
  '(-d --documentation-mode)'{-d,--documentation-mode}'[documentation mode: load chunk results from cache]' \
  '(-c --cache-results)'{-c,--cache-results}'[cache results to disk for documentation mode]' \
  '(-F --figure-directory)'{-F+,--figure-directory=}'[directory for matplotlib graphics]:dir:_files -/' \
  '--cache-directory=[directory for cached results]:dir:_files -/' \
  '(-g --figure-format)'{-g+,--figure-format=}'[figure format for matplotlib graphics]:format:' \
  '(-t --mimetype)'{-t+,--mimetype=}'[source document text mimetype]:mimetype:' \
  '*:input file:_files' && ret=0

return ret
