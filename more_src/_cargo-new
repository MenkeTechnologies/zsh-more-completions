#compdef cargo-new
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-new.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for cargo new (create a new Cargo package)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--lib[Use a library template]' \
  '--bin[Use a binary (application) template]' \
  '--edition=[Set the edition]:edition:(2015 2018 2021 2024)' \
  '--name=[Set the resulting package name]:name' \
  '--vcs=[Initialize a new repository for the given version control system]:vcs:(git hg pijul fossil none)' \
  '--registry=[Registry to use]:registry' \
  '(-v --verbose)*'{-v,--verbose}'[Use verbose output (may be specified twice)]' \
  '(-q --quiet)'{-q,--quiet}'[Do not print cargo log messages]' \
  '--color=[Control when colored output is used]:when:(auto always never)' \
  '*--config=[Override a configuration value]:key=value' \
  '-C+[Change working directory before executing]:path:_files -/' \
  '-Z+[Unstable (nightly-only) flags]:flag' \
  '(-h --help)'{-h,--help}'[Print help]' \
  ':path:_files -/' && ret=0

return ret
