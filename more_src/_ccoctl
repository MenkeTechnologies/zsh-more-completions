#compdef ccoctl
# Documentation: https://man.archlinux.org/search?q=ccoctl
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--output-dir=[output directory]:dir:_directories' \
  '--dry-run[emit local artifacts instead of cloud changes]' \
  '1:cloud:(aws azure gcp ibmcloud nutanix)' \
  '*:subcommand and arguments:_default'
