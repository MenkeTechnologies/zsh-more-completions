#compdef ccoctl
# Documentation: https://github.com/openshift/cloud-credential-operator/blob/master/docs/ccoctl.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--output-dir=[output directory]:dir:_directories' \
  '--dry-run[emit local artifacts instead of cloud changes]' \
  '1:cloud:->cloud' \
  '*:: :->args' && ret=0

case $state in
  (cloud)
    local -a clouds=(
      'aws:Amazon Web Services'
      'azure:Microsoft Azure'
      'gcp:Google Cloud Platform'
      'ibmcloud:IBM Cloud'
      'nutanix:Nutanix'
    )
    _describe -t clouds 'cloud provider' clouds && ret=0
    ;;
  (args)
    case $words[1] in
      (aws)
        _arguments -s -S \
          '1:command:(create-key-pair create-identity-provider create-iam-roles create-all delete)' \
          '--name=[base name for created cloud resources]:name:' \
          '--region=[AWS region]:region:' \
          '--public-key-file=[public key path]:file:_files' \
          '--credentials-requests-dir=[CredentialsRequests directory]:dir:_directories' \
          '--identity-provider-arn=[OIDC provider ARN]:arn:' \
          '--create-private-s3-bucket[create a private S3 bucket]' && ret=0
        ;;
      (azure)
        _arguments -s -S \
          '1:command:(create-key-pair create-oidc-issuer create-managed-identities create-all delete)' \
          '--name=[base name]:name:' \
          '--region=[Azure region]:region:' \
          '--subscription-id=[Azure subscription ID]:id:' \
          '--tenant-id=[Azure tenant ID]:id:' \
          '--public-key-file=[public key path]:file:_files' \
          '--credentials-requests-dir=[CredentialsRequests directory]:dir:_directories' \
          '--issuer-url=[OIDC issuer URL]:url:' \
          '--dnszone-resource-group-name=[DNS zone resource group]:group:' \
          '--delete-oidc-resource-group[delete OIDC resource group]' \
          '--user-tags=[user tags]:tags:' && ret=0
        ;;
      (gcp)
        _arguments -s -S \
          '1:command:(create-key-pair create-workload-identity-pool create-workload-identity-provider create-service-accounts create-all delete)' \
          '--name=[base name]:name:' \
          '--region=[GCP region]:region:' \
          '--project=[GCP project ID]:project:' \
          '--public-key-file=[public key path]:file:_files' \
          '--credentials-requests-dir=[CredentialsRequests directory]:dir:_directories' \
          '--workload-identity-pool=[workload identity pool]:pool:' \
          '--workload-identity-provider=[workload identity provider]:provider:' && ret=0
        ;;
      (ibmcloud)
        _arguments -s -S \
          '1:command:(create-service-id refresh-keys delete-service-id)' \
          '--name=[base name]:name:' \
          '--credentials-requests-dir=[CredentialsRequests directory]:dir:_directories' \
          '--resource-group-name=[resource group]:group:' \
          '--kubeconfig=[kubeconfig file]:file:_files' \
          '--create[create keys (refresh-keys)]' && ret=0
        ;;
      (nutanix)
        _arguments -s -S \
          '1:command:(create-shared-secrets)' \
          '--credentials-requests-dir=[CredentialsRequests directory]:dir:_directories' \
          '--credentials-source-filepath=[credentials source file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
