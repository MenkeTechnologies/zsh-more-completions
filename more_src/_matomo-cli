#compdef matomo-cli matomo piwik-cli
# _matomo-cli — Matomo Analytics matomo-cli CLI command-line frontend wrapping the Matomo formerly Piwik open-source web analytics platform managing sites users segments goals dashboards reports widgets events visits actions ecommerce campaigns tag-manager scheduled-reports archive-rebuild plugins core:update database (Matomo team, PHP); custom argparse
# upstream: https://matomo.org/

_matomo-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'site:site management'
        'user:user management'
        'segment:segment management'
        'goal:goal management'
        'dashboard:dashboard management'
        'report:report operations'
        'widget:widget operations'
        'event:event operations'
        'visit:visit operations'
        'action:action operations'
        'ecommerce:ecommerce operations'
        'campaign:campaign management'
        'tag-manager:Tag Manager operations'
        'scheduled-report:scheduled report'
        'archive:archive operations'
        'plugin:plugin operations'
        'core:core operations'
        'database:database operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--matomo-url=+[url]:str:' \
        '--token-auth=+[token]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--site-id=+[id]:str:' \
        '--language=+[lang]:str:' \
        '-c+[config file]:file:_files -g "*.ini *.php"' \
        '--config=+[file]:file:_files -g "*.ini *.php"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table xml tsv html php)' \
        '--format=+[format]:f:(json yaml csv table xml tsv html php)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'matomo-cli subcommand' sub ;;
        args)
            case $words[1] in
                site|user|segment|goal|dashboard|report|widget|event|visit|action|ecommerce|campaign|tag-manager|scheduled-report|plugin) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                archive|core|database) _arguments '1:op:(run optimize backup restore upgrade)' ;;
            esac
            ;;
    esac
}

_matomo-cli "$@"
