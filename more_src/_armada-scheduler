#compdef armada-scheduler
# _armada-scheduler — Armada scheduler (cobra; assigns submitted jobs to executors + tracks queue state)
# upstream: https://github.com/armadaproject/armada
# Subcommands from cmd/scheduler/cmd/{root,main,migrate_database,prune_database}.go on tip.

_armada-scheduler() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"' \
        '1: :->cmd'
    case $state in
        cmd)
            local -a subs=(
                run:'run the scheduler'
                'migrate-database':'migrate the scheduler database to the latest schema'
                'prune-database':'prune the scheduler database of old jobs'
            )
            _describe -t commands 'armada-scheduler subcommand' subs
            ;;
    esac
}

_armada-scheduler "$@"
