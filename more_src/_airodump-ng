#compdef airodump-ng
# _airodump-ng — Aircrack-ng airodump-ng (sniff + capture 802.11 frames; -c channel list, --bssid filter MAC, --essid filter SSID, -w capture file prefix, --ivs only IVS records, --output-format csv,pcap,kismet,gpsx, --write-interval seconds, -d wpa3 only, --wps WPS, --beacons keep all beacons, --gpsd, --ignore-negative-one; positional argument is the monitor-mode interface)
# upstream: https://github.com/aircrack-ng/aircrack-ng
# Flags from aircrack-ng src/airodump-ng.c on tip.

_airodump-ng() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[channels]:channels:' \
        '--channel+[channels]:channels:' \
        '--band+[band]:band:(a b g abg)' \
        '--bssid+[BSSID]:mac:' \
        '--essid+[ESSID]:essid:' \
        '-w+[capture file prefix]:prefix:_files' \
        '--write+[capture file prefix]:prefix:_files' \
        '--ivs[only IVS records]' \
        '--output-format+[output format]:format:(csv pcap kismet gpsx logcsv netxml)' \
        '--write-interval+[seconds]:seconds:' \
        '--beacons[keep all beacons]' \
        '--gpsd[use gpsd]' \
        '--wps[show WPS]' \
        '--ignore-negative-one[ignore -1 channel]' \
        '-N+[show new AP only]:n:' \
        '-x+[shorten beacons]:n:' \
        '*-d+[wpa3 only]:dummy:' \
        '1:interface:_net_interfaces'
}

_airodump-ng "$@"
