#compdef iroh
# Documentation: https://man.archlinux.org/search?q=iroh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--verbose[Increase logging verbosity]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'start:Start the local iroh node'
      'stop:Stop a running node'
      'status:Print status and network info'
      'metrics:Dump metrics'
      'doctor:Run connectivity diagnostics'
      'blob:Interact with blob store'
      'net:Inspect swarm configuration'
      'rpc:Low-level RPC helpers'
      'provide:Announce and serve a path or hash'
      'get:Fetch content by hash'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
