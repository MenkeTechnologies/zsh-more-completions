#compdef pargenes pargenes.py pargenes-hpc.py
# Documentation: https://github.com/BenoitMorel/ParGenes
# ParGenes: parallel per-gene tree inference (RAxML-NG / ModelTest-NG / ASTRAL).

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--dry-run[dry run]' \
  '(-a --alignments-dir)'{-a+,--alignments-dir=}'[directory with fasta files]:dir:_files -/' \
  '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
  '(-c --cores)'{-c+,--cores=}'[number of cores (at least 2)]:cores:' \
  '--seed=[random seed (default 0)]:seed:' \
  '--continue[continue from last checkpoint]' \
  '--msa-filter=[file with msa names to process]:file:_files' \
  '(-d --datatype)'{-d+,--datatype=}'[alignments datatype]:type:(nt aa)' \
  '--scheduler=[scheduler (expert only)]:sched:' \
  '--core-assignment=[per-job core assignment policy]:policy:(low high)' \
  '--valgrind[run scheduler with valgrind]' \
  '--constrain-search[constrain the raxml searches]' \
  '--job-failure-fatal[stop ParGenes when a job fails]' \
  '--per-msa-raxml-parameters=[file with per-msa raxml parameters]:file:_files' \
  '(-s --random-starting-trees)'{-s+,--random-starting-trees=}'[number of random starting trees]:n:' \
  '(-p --parsimony-starting-trees)'{-p+,--parsimony-starting-trees=}'[number of parsimony starting trees]:n:' \
  '(-r --raxml-global-parameters)'{-r+,--raxml-global-parameters=}'[file with raxml parameters]:file:_files' \
  '(-R --raxml-global-parameters-string)'{-R+,--raxml-global-parameters-string=}'[raxml parameters string]:params:' \
  '(-b --bs-trees)'{-b+,--bs-trees=}'[number of bootstrap trees]:n:' \
  '--autoMRE=[stop bootstrap at autoMRE convergence]:max:' \
  '--raxml-binary=[custom raxml-ng path]:file:_files' \
  '--percentage-jobs-double-cores=[fraction of jobs with double cores]:frac:' \
  '(-m --use-modeltest)'{-m,--use-modeltest}'[autodetect model with modeltest]' \
  '--modeltest-global-parameters=[file with modeltest parameters]:file:_files' \
  '--per-msa-modeltest-parameters=[file with per-msa modeltest parameters]:file:_files' \
  '--modeltest-criteria=[modeltest selection criteria]:crit:(BIC AIC AICc)' \
  '--modeltest-perjob-cores=[cores per modeltest job (at least 4)]:n:' \
  '--modeltest-binary=[custom modeltest-ng path]:file:_files' \
  '--use-astral[infer species tree with astral]' \
  '--astral-global-parameters=[file with astral parameters]:file:_files' \
  '--astral-jar=[custom ASTRAL jar path]:file:_files' \
  '--use-aster[infer species tree with aster]' \
  '--aster-global-parameters=[file with aster parameters]:file:_files' \
  '--aster-bin=[aster binary name/path]:bin:' \
  '--experiment-disable-jobs-sorting[disable scheduler sorting (experimental)]' \
  '--retry=[scheduler restart attempts after error]:n:' && ret=0

return ret
