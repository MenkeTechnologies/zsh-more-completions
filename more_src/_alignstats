#compdef alignstats
# Documentation: https://github.com/jfarek/alignstats
# compute alignment, whole genome and capture coverage statistics

local ret=1

_arguments -s -S \
  '-h[display usage information]' \
  '-v[enable verbose output to stderr]' \
  '-n[maximum records to retain in memory]:n' \
  '-p[separate threads for reading and processing]' \
  '-P[number of HTSlib decompression threads]:n' \
  '-i[input SAM/BAM/CRAM file]:file:_files' \
  '-j[input format]:format:(sam bam cram)' \
  '-o[output report file]:file:_files' \
  '-r[BED file of regions to process]:file:_files' \
  '-t[BED file for capture coverage regions]:file:_files' \
  '-m[BED file marking reference N-bases]:file:_files' \
  '-T[indexed FASTA reference for CRAM]:file:_files' \
  '-q[minimum read quality threshold]:n' \
  '-f[include records with FLAG bits set]:flags' \
  '-F[exclude records with FLAG bits set]:flags' \
  '-D[retain duplicate reads in coverage stats]' \
  '-U[include unplaced unmapped reads with -r]' \
  '-A[omit alignment statistics]' \
  '-C[omit capture coverage statistics]' \
  '-W[omit whole genome coverage statistics]' \
  '*:file:_files' && ret=0

return ret
