#compdef meli

# Zsh completion for meli - terminal mail client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'accounts:print account information'
  'create-config:create a sample configuration file with available configuration options'
  'test-config:test a configuration file for syntax issues or missing options'
  'man:print documentation page and exit'
  'install-man:install manual pages to a user-specified directory'
  'compiled-with:print compile-time feature flags'
  'print-app-directories:print the paths used for configuration, cache, etc.'
  'print-config-path:print the computed path of the configuration file'
  'print-default-theme:print default theme in full'
  'print-loaded-themes:print all loaded themes'
  'view:view an email from file without modifying it'
  'help:print this message or the help of the given subcommand(s)'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-c --config)'{-c,--config}'[use specified configuration file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[more verbose output]' \
  '-t[toggle for tick events each tick update]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'meli command' commands && ret=0
    ;;
esac

return ret
