#compdef rrdcgi
# Documentation: https://man.archlinux.org/search?q=rrdcgi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --filter)'{-f,--filter}'[run as filter]' \
  '*:rrd template:_files' && ret=0

return ret
