#compdef rrdcgi
# Documentation: https://oss.oetiker.ch/rrdtool/doc/rrdcgi.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-f --filter)'{-f,--filter}'[run as filter, not as CGI]' \
  '*:rrd template:_files' && ret=0

return ret
