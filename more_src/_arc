#compdef arc

local -a subcommands
subcommands=(
  'diff:Create or update a Differential revision'
  'land:Merge an accepted revision into its target branch'
  'lint:Run static analysis on changes'
  'unit:Run unit tests on changes'
  'browse:Open a URI in a web browser'
  'patch:Apply a Differential revision to the working copy'
  'close-revision:Close a revision that has been committed'
  'cover:Find test coverage for a set of paths'
  'export:Export commits to a file or stdout'
  'feature:Create or switch to a feature branch'
  'get-config:Read a configuration value'
  'help:Show help for a command'
  'install-certificate:Install Conduit API token'
  'liberate:Create or update an Arcanist library'
  'list:List your open revisions'
  'set-config:Set a configuration value'
  'shell-complete:Provide shell completion suggestions'
  'todo:Show pending tasks'
  'upload:Upload a file to Phabricator'
  'version:Show tool version'
  'which:Show Arcanist configuration'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--no-ansi[Disable ANSI output]' \
  '--conduit-uri=[Phabricator install to connect to]:uri:' \
  '--conduit-token=[Conduit API token]:token:' \
  '--trace[Trace underlying commands]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      diff)
        _arguments \
          '--create[Create a new revision]' \
          '--update=[Update an existing revision]:revision:' \
          '--edit[Edit revision information]' \
          '--nounit[Do not run unit tests]' \
          '--nolint[Do not run lint]' \
          '--only[Only generate diff, no lint or unit]' \
          '--preview[Show what would be sent]' \
          '--reviewers=[Add reviewers]:reviewers:' \
          '--verbatim[Use working copy commit message]' \
          '--message=[Use message from command line]:message:'
        ;;
      land)
        _arguments \
          '--onto=[Land onto branch]:branch:' \
          '--hold[Prepare but do not push]' \
          '--keep-branch[Do not delete feature branch]' \
          '--revision=[Land a specific revision]:revision:' \
          '--squash[Squash commits into one]' \
          '--merge[Perform a merge commit]'
        ;;
      lint)
        _arguments \
          '--everything[Lint all files]' \
          '--severity=[Set minimum severity]:severity:(advice autofix warning error disabled)' \
          '--engine=[Use a specific lint engine]:engine:' \
          '--output=[Output format]:format:(summary json compiler full)' \
          '*:files:_files'
        ;;
      patch)
        _arguments \
          '--nobranch[Do not create a branch]' \
          '--force[Force patch even with local changes]' \
          '--update[Update an existing branch]' \
          '1:revision:'
        ;;
    esac
    ;;
esac
