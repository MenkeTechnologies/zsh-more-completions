#compdef rvu
# Documentation: https://www.radiance-online.org/learning/documentation/manual-pages/pdfs/rvu.pdf
# Radiance interactive renderer/viewer

local ret=1

_arguments -s \
  '-n[number of rendering processes]:nproc' \
  '-o[output device]:device' \
  '-b[improve display on greyscale monitors]' \
  '-pe[set initial exposure value]:exposure' \
  '*:octree:_files' && ret=0

return ret
