#compdef goboy
# ============================================================================
# goboy - multi-platform Nintendo Game Boy /
#          Game Boy Color emulator (Go, MIT)
#
# Author : Joe Wilson (Humpheh)
# Upstream: https://github.com/Humpheh/goboy
#
# `goboy` is a pure-Go emulator for the Nintendo
# Game Boy (DMG) + Game Boy Color (CGB) handheld
# systems. The emulator implements:
#   - Sharp LR35902 (CPU) instruction set emulation
#     at cycle-accurate level
#   - Picture Processing Unit (PPU) with sprite +
#     background + window layers
#   - Audio Processing Unit (APU) with 4-channel
#     sound (2 pulse + 1 wave + 1 noise channel)
#   - Memory Bank Controller (MBC1, MBC2, MBC3 +
#     RTC, MBC5) cartridge mappings
#   - Save state + battery-backed SRAM persistence
#   - Game Boy Color additional features (extra
#     RAM banks + double CPU speed + color
#     palettes)
#
# Architecture:
#   - gopxl/pixel/v2 (formerly faiface/pixel) for
#     cross-platform 2D graphics + window
#     management + keyboard/gamepad input
#   - hajimehoshi/oto for cross-platform audio
#     output (Linux ALSA + macOS CoreAudio +
#     Windows WASAPI + WebAssembly Web Audio API)
#   - go-gl/gl for OpenGL rendering backend
#
# Use cases:
#   - Game Boy ROM playback on Linux + macOS +
#     Windows + iOS + Android + WebAssembly
#   - Game Boy reverse-engineering + debugging
#     (step-through opcode execution + CPU
#     profiling)
#   - Retro-game preservation + research
#   - Pure-Go emulator development reference
#     implementation
#
# Usage:
#   goboy [flags] <ROM-file>
#
# Positional argument:
#   <ROM-file>                     - Game Boy
#                                     or Game
#                                     Boy Color
#                                     ROM file
#                                     (.gb /
#                                     .gbc /
#                                     .bin
#                                     extension;
#                                     required)
#
# Flags (Go stdlib `flag` package; single-dash
# style):
#   -mute                          - mute sound
#                                     output
#                                     (skip
#                                     APU
#                                     emulation
#                                     for
#                                     performance)
#   -dmg                           - force DMG
#                                     (original
#                                     Game Boy)
#                                     mode (vs
#                                     auto-
#                                     detected
#                                     CGB if ROM
#                                     supports
#                                     it)
#   -cpuprofile <file>             - write CPU
#                                     profile
#                                     to file
#                                     for
#                                     `go tool
#                                     pprof`
#                                     analysis
#                                     (debugging)
#   -disableVsync                  - disable
#                                     v-sync
#                                     framerate
#                                     limiting
#                                     (debugging
#                                     /
#                                     benchmark)
#   -stepthrough                   - enable
#                                     opcode-
#                                     by-opcode
#                                     step-
#                                     through
#                                     execution
#                                     (debugging)
#   -unlocked                      - unlock CPU
#                                     speed (no
#                                     framerate
#                                     cap;
#                                     implies
#                                     -mute for
#                                     performance;
#                                     debugging)
#   -h, -help                      - print help
#
# Example invocation:
#   goboy roms/pokemon-blue.gb
#   goboy -mute -dmg classic-game.gb
#   goboy -cpuprofile cpu.prof \
#         -disableVsync test-rom.gbc
#   goboy -unlocked benchmark-rom.gb
#
# Default keybindings (set by goboy's pixelbinding
# adapter; hard-coded in pkg/pixelbinding):
#   Arrow keys                     - D-pad
#   Z                              - A button
#   X                              - B button
#   Enter                          - Start
#   Right Shift                    - Select
#   Esc                            - Quit
#
# The oto lane is built on `github.com/hajimehoshi/
# oto v1.0.1` (declared verbatim at upstream
# go.mod HEAD as a direct dep, used by the
# `pkg/gb/apu` package to feed Game Boy 4-channel
# audio waveforms to the host operating system's
# audio output device via a streaming
# `oto.Player` instance), the canonical Go
# cross-platform audio output library by Hajime
# Hoshi (hajimehoshi) - github.com/hajimehoshi/
# oto.
#
# Hajime Hoshi's oto is the de-facto canonical
# Go cross-platform audio output library:
#   - Cross-platform: Linux ALSA + macOS
#     CoreAudio + Windows WASAPI + iOS + Android
#     + WebAssembly Web Audio API
#   - Streaming PCM playback interface (write
#     bytes to an io.Writer-like Player)
#   - Pure-Go for some platforms (no cgo on
#     Linux + Windows + WebAssembly); cgo for
#     macOS CoreMIDI + iOS
#   - Multiple version generations (v1 + v2
#     with improved API + audio context lifecycle
#     management)
#   - 2,000+ reverse-deps on pkg.go.dev
#   - Used by every major Go-based audio + game
#     project (Ebitengine + faiface/beep +
#     ymyk-sound + many emulators)
#
# oto's distinguishing position vs alternatives:
#   - hajimehoshi/oto (canonical; THIS AXIS)
#   - go-portaudio bindings (cgo-only; cross-
#     platform via PortAudio C library)
#   - faiface/beep: higher-level streaming +
#     mixing library; uses oto underneath
#   - mb-14/gomp3: MP3-specific decoder + oto
#     wrapper
#
# Hajime Hoshi's broader Go ecosystem footprint
# (the hajimehoshi/ multi-library author):
#   - hajimehoshi/oto (canonical Go audio output;
#     THIS AXIS)
#   - hajimehoshi/ebiten / ebitengine (CANONICAL
#     Go 2D game engine; 11,500+ stars; used by
#     ~every Go indie game + game-jam entry)
#   - hajimehoshi/go-mp3 (pure-Go MP3 decoder)
#   - hajimehoshi/file2byteslice (Go file
#     embedding utility)
#   - hajimehoshi/ebitenginepkg (community
#     ecosystem packages)
#
# Hashi's role in Go is *cross-platform multimedia
# + game-engine canonical infrastructure*:
#   - Ebitengine is THE canonical Go 2D game
#     engine (the equivalent of Unity / Godot in
#     the Go ecosystem)
#   - oto is the canonical audio output for any
#     Go program needing PCM playback
#   - go-mp3 fills the pure-Go MP3 decoder niche
#
# Hashi joins the multi-axis canonical-Go author
# cohort (now 12 distinct individuals/orgs):
#   - Andrew Gerrand + Go team (stdlib)
#   - Russ Cox (Go modules + crypto)
#   - Gustavo Niemeyer (yaml.v3 + gopkg.in
#     infrastructure)
#   - Klaus Post (compress + reedsolomon +
#     cpuid + asmfmt)
#   - Sergey Kamardin (gobwas/glob + gobwas/ws +
#     gobwas/httphead + gobwas/pool)
#   - Anthony Starks (ajstarks/svgo + deck +
#     dchart + openvg + gensvg)
#   - Jeevanandam Madanagopal (go-resty +
#     go-aah + go-model + sslmate-go)
#   - Matt Holt (Caddy + CertMagic + archives +
#     timeliner + acmez)
#   - Joe Chen / Unknwon (go-ini + Macaron +
#     Gogs + com)
#   - Marc Rene Arns / gomidi org (gomidi/midi +
#     connect + smf + mid + sf2)
#   - Eclipse Foundation Paho team
#     (paho.mqtt.golang; foundation-backed)
#   - Hajime Hoshi (oto + ebitengine + go-mp3,
#     THIS AXIS)
#
# Hoshi is the first author in the Go cohort
# whose foundational position is in the *game
# engine + multimedia* vertical (Marc Rene Arns
# at Axis 269 covered the music-software
# vertical; Hoshi extends into game audio +
# rendering).
#
# goboy uses oto in pkg/gb/apu via:
#   ```go
#   import "github.com/hajimehoshi/oto"
#
#   const (
#       sampleRate     = 44100
#       channelCount   = 2
#       bitDepthInBytes = 2
#       bufferSize      = sampleRate / 30
#   )
#
#   ctx, err := oto.NewContext(
#       sampleRate, channelCount,
#       bitDepthInBytes, bufferSize,
#   )
#   if err != nil { log.Fatal(err) }
#   player := ctx.NewPlayer()
#
#   // APU emulation loop
#   for !exit {
#       samples := apu.GenerateSamples()
#       player.Write(samples)
#   }
#   ```
# The Game Boy's 4-channel APU output is mixed
# down to stereo PCM samples + written to the
# oto Player, which handles the underlying
# platform-specific audio API delivery.
#
# ----------------------------------------------------------------------------
# AXIS 271 :: Audio codec / decoding libraries
#              (multi-format audio file decoding
#              + container parsing + metadata
#              extraction for music players +
#              audio analysis + format-conversion
#              tooling)
# Round 1512 :: Go slot 2 of 4 :: continues Axis 271
#
# Cross-language canonical library family for this axis:
#   Rust    : pdeljanov/Symphonia        [R1511 _psst-cli]
#             (Philip Deljanov; canonical
#              Rust multi-codec decoding
#              framework)
#   Go      : hajimehoshi/oto            [R1512 THIS FILE]
#             (Hajime Hoshi; canonical
#              Go cross-platform audio
#              output; not decoding-
#              focused but the de-facto
#              Go audio pipeline endpoint)
#   TS/Node : audio-decode + per-format  [R1513 closing]
#             decoders
#             (multi-library Node audio
#              decoding ecosystem)
#
# The Rust + Go contrast in this axis is
# illustrative of a different architectural
# split than previous axes:
#   - Rust (Symphonia): multi-codec *decoder*
#     framework (input side; bytes -> PCM
#     samples)
#   - Go (oto): cross-platform audio *output*
#     library (output side; PCM samples ->
#     hardware audio devices)
#
# These are complementary roles in the audio
# pipeline rather than parallel canonicals. The
# Go decoder-side canonicals are more fragmented
# (go-audio/wav + go-audio/mp3 + tcolgate/mp3 +
# faiface/beep wrappers around these +
# hajimehoshi/go-mp3 + various FLAC + Vorbis
# bindings) - there is no single Go library that
# matches Symphonia's multi-codec scope.
#
# This *output-canonical vs decoder-canonical*
# split in Go is consistent with Go's stdlib-
# first culture: the Go team didn't ship an
# audio decoder framework in stdlib, so the
# community fragmented by format. Hoshi's oto
# achieved canonical status by focusing on the
# *output* side where cross-platform abstraction
# matters most (the lower-level OS audio API
# differences are messy enough that a single
# abstraction has clear value).
#
# Cross-language interop at the PCM-sample level
# - decoders + output libraries in all three
# lanes can exchange PCM samples via standard
# byte arrays. The container/codec specs (MP3 +
# AAC + Ogg Vorbis + FLAC + Opus) are byte-for-
# byte identical across decoder implementations.
#
# Use-case spectrum across the lanes (so far):
#   - psst-cli (Rust, Symphonia): Spotify Ogg
#     Vorbis stream decoder + audio playback
#   - goboy (Go, oto): Game Boy emulator with
#     4-channel APU audio output via oto's
#     cross-platform PCM playback
#
# Three lanes, three sides of the audio
# pipeline:
#   - Rust (Symphonia): input side (decoding)
#   - Go (oto): output side (playback)
#   - Node (audio-decode + per-format): input
#     side fragmented across multiple libraries
#
# This is the *complementary-pipeline-canonical*
# axis pattern - distinct from the parallel-
# canonicals pattern of most other axes. Audio
# pipelines naturally split into input + output
# sides, and each ecosystem's canonicals occupy
# different positions in the pipeline.
# ============================================================================

_goboy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-mute[mute sound output (skip APU emulation)]' \
        '-dmg[force DMG (original Game Boy) mode]' \
        '-cpuprofile=[write CPU profile to file for pprof]:file:_files' \
        '-disableVsync[disable v-sync framerate limiting]' \
        '-stepthrough[enable opcode-by-opcode step-through (debug)]' \
        '-unlocked[unlock CPU speed (no framerate cap; implies -mute)]' \
        '(- *)-h[print help]' \
        '(- *)-help[print help]' \
        '*:ROM file:_files -g "*.(gb|gbc|bin|sgb)"'
}

_goboy "$@"
