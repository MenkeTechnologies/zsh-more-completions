#compdef qwik-init
# _qwik-init — Misko Hevery Qwik resumable web framework init CLI alias (QwikDev team, TypeScript); custom argparse
# upstream: https://github.com/QwikDev/qwik

_qwik-init() {
    local -a sub=(
        'add:add Qwik integration to current project'
        'build:build app'
        'dev:start dev server'
        'preview:preview production build'
        'new:create a new Qwik component or route'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qwik subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '1:integration:(adapter-azure-swa adapter-bun-server adapter-cloud-run adapter-cloudflare-pages adapter-deno-server adapter-firebase adapter-netlify-edge adapter-node-server adapter-static adapter-vercel-edge cypress mdx postcss prisma styled-vanilla-extract storybook turso vitest playwright tailwind partytown)' \
                    '--yes[skip prompts]' \
                    '-y[skip prompts]' ;;
                new) _arguments \
                    '1:type:(component route)' \
                    '*:name:' \
                    '--yes[skip prompts]' ;;
                build) _arguments \
                    '--mode=+[mode]:m:(development production)' \
                    '--ssr[ssr]' \
                    '--no-ssr[disable ssr]' \
                    '--client[client only]' \
                    '--server[server only]' \
                    '--static[static]' \
                    '--debug[debug]' ;;
                dev) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--mode=+[mode]:m:(development production)' \
                    '--clearScreen=+[bool]:b:(true false)' ;;
                preview) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--open[open browser]' ;;
            esac
            ;;
    esac
}

_qwik-init "$@"
