#compdef pyspark sparkR spark-shell-rest spark-submit-rest

local curcontext="$curcontext" state line ret=1

case $service in
  (pyspark|sparkR)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '*--master=[master URL]:url:(local local[*] yarn k8s mesos://HOST:PORT spark://HOST:PORT)' \
      '*--deploy-mode=[deploy mode]:m:(client cluster)' \
      '*--name=[app name]:n:' \
      '*--class=[main class]:c:' \
      '*--jars=[jars csv]:list:_files -g "*.jar"' \
      '*--packages=[maven packages csv]:list:' \
      '*--exclude-packages=[exclude packages csv]:list:' \
      '*--repositories=[repos csv]:list:' \
      '*--py-files=[py files csv]:list:_files -g "*.py *.zip *.egg"' \
      '*--files=[files csv]:list:_files' \
      '*--archives=[archives csv]:list:_files' \
      '*--conf=[k=v config]:cfg:' \
      '*--properties-file=[properties file]:file:_files -g "*.properties"' \
      '*--driver-memory=[driver memory]:m:' \
      '*--driver-java-options=[driver java opts]:opts:' \
      '*--driver-library-path=[driver lib path]:p:' \
      '*--driver-class-path=[driver class path]:p:' \
      '*--executor-memory=[executor memory]:m:' \
      '*--proxy-user=[proxy user]:u:_users' \
      '*--driver-cores=[driver cores]:n:' \
      '*--total-executor-cores=[total executor cores]:n:' \
      '*--executor-cores=[cores per executor]:n:' \
      '*--queue=[YARN queue]:q:' \
      '*--num-executors=[num executors]:n:' \
      '*--principal=[Kerberos principal]:p:' \
      '*--keytab=[Kerberos keytab]:file:_files' \
      '*-i+[init script]:file:_files -g "*.py *.scala *.r"' \
      '*-c+[init command]:cmd:' \
      '*: :_files -g "*.py *.r"' && ret=0 ;;
  (spark-shell-rest|spark-submit-rest)
    _arguments '*: :_files' && ret=0 ;;
esac

return ret
