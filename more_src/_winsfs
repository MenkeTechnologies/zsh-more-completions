#compdef winsfs
# Documentation: https://github.com/malthesr/winsfs
# winsfs: window-based estimation of the site frequency spectrum from SAF files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --block-size)'{-b,--block-size}'=[block size]:int' \
  '(-B --blocks)'{-B,--blocks}'=[number of blocks]:int' \
  '(-w --window-size)'{-w,--window-size}'=[window size]:int' \
  '(-l --tolerance)'{-l,--tolerance}'=[stopping criteria tolerance]:float' \
  '--max-epochs=[maximum optimization iterations]:int' \
  '(-t --threads)'{-t,--threads}'=[number of threads]:int' \
  '(-s --seed)'{-s,--seed}'=[reproducibility seed]:int' \
  '-v[print progress information]' \
  '(-o --output)'{-o,--output}'=[output destination]:file:_files' \
  '1:command:((estimate\:"infer the SFS from SAF files" shuffle\:"prepare shuffled files for streaming" view\:"normalize, fold, or convert SFS files"))' \
  '*::args:_files' && ret=0

return ret
