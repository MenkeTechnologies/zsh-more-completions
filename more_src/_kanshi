#compdef kanshi
# Documentation: https://man.archlinux.org/search?q=kanshi
# Reference accessed: 2026-05-16

# Zsh completion for kanshi - dynamic display configuration for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files'
