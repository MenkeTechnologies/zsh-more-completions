#compdef floss

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-n --minimum-length)'{-n,--minimum-length}'=[minimum string length]:length:' \
  '--no-static-strings[do not show static strings]' \
  '--no-decoded-strings[do not show decoded strings]' \
  '--no-stack-strings[do not show stack strings]' \
  '--no-tight-strings[do not show tight strings]' \
  '--only=[only show specific string types]:type:(static decoded stack tight)' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '--functions=[analyze specific functions]:functions:' \
  '--format=[output format]:format:(auto sc16 sc32 sc8s sc16s)' \
  '--shellcode-arch=[shellcode architecture]:arch:(i386 amd64)' \
  '--shellcode-base=[shellcode base address]:address:' \
  '--shellcode-entry-point=[shellcode entry point]:address:' \
  '-s+[signatures file]:file:_files' \
  '*:file:_files' && ret=0

return ret
