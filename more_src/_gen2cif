#compdef gen2cif
# Documentation: https://github.com/dftbplus/dftbplus/blob/main/tools/dptools/src/dptools/scripts/gen2cif.py
# DFTB+ dptools: convert a DFTB+ gen geometry file to CIF format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'+[override the name of the output file]:file:_files' \
  '(-c --cellsize)'{-c,--cellsize}'+[lattice constant for the cubic cell for non-periodic input]:cellsize:' \
  '*:gen input file:_files -g "*.gen"' && ret=0

return ret
