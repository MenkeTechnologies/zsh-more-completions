#compdef bufr_compare
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_compare
# Source: ecmwf/eccodes tools/bufr_compare.cc — compare two BUFR files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b+[blacklist key list]:keys:_default' \
    '-d[write different messages to files]' \
    '-2[enable two-way comparison]' \
    '-c+[key list to compare]:keys:_default' \
    '-S+[first field to process]:start:_default' \
    '-E+[last field to process]:end:_default' \
    '-a[append -c keys to default list]' \
    '-H[compare only headers (bit-by-bit)]' \
    '-R+[absolute error tolerance per key]:tol:_default' \
    '-A+[relative error tolerance per key]:tol:_default' \
    '-t+[multiply tolerance by factor]:factor:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-f[force compare, do not stop at first difference]' \
    '-T+[message type]:type:(T B M A)' \
    '(- *)-V[show version]' \
    '-7[do not fail on wrong message length]' \
    '-v[verbose]' \
    '(- *)-h[show help]' \
    '1:bufr file 1:_files' \
    '2:bufr file 2:_files' \
    && ret=0

return ret
