#compdef kubectl-sigstore
# Documentation: https://github.com/sigstore/k8s-manifest-sigstore
# kubectl plugin for signing and verifying Kubernetes manifest YAML files with sigstore

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filename)'{-f,--filename}'=[file name to sign or verify]:file:_files' \
  '(-i --image)'{-i,--image}'=[signed image name bundling YAML manifests]:image:' \
  '(-k --key)'{-k,--key}'=[path to key or env:// reference (empty for keyless)]:key:_files' \
  '(-c --config)'{-c,--config}'=[path to verification config YAML file]:config:_files' \
  '(-a --annotation)'{-a,--annotation}'=[extra key=value annotation to sign]:annotation:' \
  '(-o --output)'{-o,--output}'=[output file name or format]:output:' \
  '(-A --append-signature)'{-A,--append-signature}'[keep existing signatures]' \
  '--annotation-metadata[update annotation metadata (default true)]' \
  '--replace-signature[replace existing signature]' \
  '--tarball=[whether to make tarball]:tarball:(yes no)' \
  '--disable-default-config[disable default ignore fields config]' \
  '*::command:(sign verify apply-after-verify verify-resource)' && ret=0

return ret
