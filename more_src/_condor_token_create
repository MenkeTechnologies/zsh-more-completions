#compdef condor_token_create
# _condor_token_create — HTCondor condor_token_create (issue a Condor IDTOKEN signing a SciToken-style JWT used for daemon authentication; -identity identity to embed, -key key file (default $POOL_PASSWORD), -lifetime seconds, -authz comma-separated authz list, -id KEY_ID, -file output token file)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_create on tip.

_condor_token_create() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-identity+[identity]:identity:' \
        '-key+[signing key file]:file:_files' \
        '-lifetime+[seconds]:seconds:' \
        '-authz+[authz csv]:authz:(READ WRITE ADMINISTRATOR ADVERTISE_STARTD ADVERTISE_SCHEDD ADVERTISE_MASTER NEGOTIATOR DAEMON)' \
        '-id+[key id]:keyid:' \
        '-file+[output file]:file:_files'
}

_condor_token_create "$@"
