#compdef vmtouch

# Zsh completion for vmtouch - portable file system cache diagnostics and control

_arguments -s -S \
  '-t[touch pages into memory]' \
  '-e[evict pages from memory]' \
  '-l[lock pages into physical memory with mlock]' \
  '-L[lock pages into memory using large pages]' \
  '-d[daemon mode]' \
  '-m+[max file size to process]:max size:' \
  '--max-file-size=[max file size to process]:max size:' \
  '-p+[print page-level residency chart]:pages per char:' \
  '-f[follow symbolic links]' \
  '-F[do not crawl different filesystems]' \
  '-h[humanize byte counts]' \
  '-i+[time to sleep between files]:interval (seconds):' \
  '-b+[batch size for eviction/touch]:batch size:' \
  '-v[verbose output]' \
  '-q[quiet, suppress non-essential output]' \
  '-w[wait for file to appear before proceeding]' \
  '-o+[offset to start at]:offset (bytes):' \
  '*:file:_files'
