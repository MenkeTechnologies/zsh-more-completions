#compdef swatchdog swatch
# Documentation: https://man.archlinux.org/search?q=swatchdog
# Reference accessed: 2026-05-16

_arguments -s \
  '--awk-field-syntax[awk field refs]' \
  '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
  '--daemon[daemon mode]' \
  '(-I --extra-include-dir)'{-I,--extra-include-dir}'=[include dir]:dir:_files -/' \
  '(-M --extra-module)'{-M,--extra-module}'=[module]:module:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--input-record-separator=[regex]:regex:' \
  '(-O --old-style-config)'{-O,--old-style-config}'[old config syntax]' \
  '--pid-file=[pid file]:file:_files' \
  '(-r --restart-time)'{-r,--restart-time}'=[restart time]:time:' \
  '--script-dir=[script dir]:dir:_files -/' \
  '--tail-args=[tail args]:args:' \
  '--tail-program-name=[tail program]:file:_files' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--use-cpan-file-tail[File::Tail]' \
  '--debug=[debug level]:level:' \
  '--dump-script=[dump script]:file:_files' \
  '(-t --tail-file)'{-t,--tail-file}'=[tail file]:file:_files' \
  '(-p --read-pipe)'{-p,--read-pipe}'=[command]:cmd:' \
  '(-f --examine)'{-f,--examine}'=[file]:file:_files'
