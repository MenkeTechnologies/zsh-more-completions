#compdef karma

# Zsh completion for karma - Karma JavaScript test runner

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start the server and run tests'
      'init:initialize a configuration file'
      'run:trigger a test run'
      'completion:output shell completion script'
    )
    _describe -t commands 'karma command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--single-run[run tests once and exit]' \
          '--no-single-run[do not run tests once and exit]' \
          '--auto-watch[auto-watch files for changes]' \
          '--no-auto-watch[do not auto-watch files]' \
          '--log-level=[log level]:level:(disable error warn info debug)' \
          '--colors[use colors in output]' \
          '--no-colors[do not use colors in output]' \
          '--reporters=[reporters to use]:reporter' \
          '--port=[port to listen on]:port' \
          '--browsers=[browsers to launch]:browser:(Chrome ChromeHeadless Firefox FirefoxHeadless Safari PhantomJS)' \
          '--hostname=[hostname to bind to]:hostname' \
          '--fail-on-empty-test-suite[fail if no tests found]' \
          '--no-fail-on-empty-test-suite[do not fail if no tests found]' \
          '--fail-on-failing-test-suite[fail if tests fail]' \
          '--no-fail-on-failing-test-suite[do not fail if tests fail]' \
          '1:config file:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:config file:_files' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port to connect to]:port' \
          '--no-refresh[do not re-glob patterns]' \
          '--fail-on-empty-test-suite[fail if no tests found]' \
          '--no-fail-on-empty-test-suite[do not fail if no tests found]' \
          '--log-level=[log level]:level:(disable error warn info debug)' \
          '1:config file:_files' && ret=0
        ;;
      completion)
        ;;
    esac
    ;;
esac

return ret
