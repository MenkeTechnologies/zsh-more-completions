#compdef azure-cloud-controller-manager
# _azure-cloud-controller-manager — Azure Cloud Controller Manager
# upstream: https://github.com/kubernetes-sigs/cloud-provider-azure
# Flags from cmd/cloud-controller-manager/app/options/options.go (NamedFlagSets) on tip.

_azure-cloud-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[Kubernetes API server URL]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--node-status-update-frequency=[how often to update node status]:dur:' \
        '--node-filter-requirements=[node label selector for CCM management]:selector:' \
        '--cloud-provider=[cloud provider name]:name:(azure)' \
        '--cloud-config=[cloud configuration file]:file:_files' \
        '--cluster-name=[cluster name]:name:' \
        '--cluster-cidr=[cluster pod CIDR]:cidr:' \
        '--allocate-node-cidrs=[allocate Node CIDRs]:bool:(true false)' \
        '--configure-cloud-routes=[configure cloud routes]:bool:(true false)' \
        '--controllers=[csv of controllers to enable (* = all)]:csv:' \
        '--use-service-account-credentials[use per-controller SA credentials]' \
        '--concurrent-service-syncs=[concurrent Service syncs]:n:' \
        '--concurrent-node-syncs=[concurrent Node syncs]:n:' \
        '--node-cidr-mask-size=[node CIDR mask size]:n:' \
        '--node-cidr-mask-size-ipv4=[IPv4 node CIDR mask size]:n:' \
        '--node-cidr-mask-size-ipv6=[IPv6 node CIDR mask size]:n:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--leader-elect-resource-lock=[lease resource lock kind]:kind:(leases configmaps endpoints configmapsleases endpointsleases)' \
        '--leader-elect-resource-namespace=[leader-election lease namespace]:ns:' \
        '--leader-elect-resource-name=[leader-election lease name]:name:' \
        '--secure-port=[secure-serving bind port]:port:' \
        '--cert-dir=[secure-serving cert directory]:dir:_files -/' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--authentication-kubeconfig=[delegated authn kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authz kubeconfig]:file:_files' \
        '--dynamic-reload-config=[enable dynamic cloud-config reload]:bool:(true false)' \
        '--feature-gates=[feature gates]:gates:' \
        '-v[klog verbosity level]:n:'
}

_azure-cloud-controller-manager "$@"
