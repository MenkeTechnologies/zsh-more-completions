#compdef kaiju-addTaxonNames
# Documentation: https://github.com/bioinformatics-centre/kaiju
# Add taxon names to a column in kaiju output

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-t[nodes.dmp taxonomy file]:nodes:_files' \
  '-n[names.dmp taxonomy file]:names:_files' \
  '-i[input kaiju output file]:input:_files' \
  '-o[output file]:output:_files' \
  '-r[taxonomic ranks for full path]:ranks:' \
  '-u[omit unclassified reads]' \
  '-p[print full taxon path]' \
  '*:file:_files' && ret=0

return ret
