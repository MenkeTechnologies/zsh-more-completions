#compdef yadifa
# _yadifa — control utility for the YADIFA name server (yadifa/yadifa)
# upstream: https://github.com/yadifa/yadifa
# Flags from yadifa(8) man page.

_yadifa() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.conf"' \
        '(-s --server)'{-s+,--server=}'[remote server]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[remote server port]:port:' \
        '-K+[key name for controller]:key:' \
        '-y+[TSIG key (alg\:name\:base64)]:key:' \
        '-t[interpret next argument as cmd]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'cfgreload:reload settings from config file'
                'freeze:disable dynamic updates to a zone'
                'freezeall:disable dynamic updates to all zones'
                'loglevel:set log level (0-15)'
                'logreopen:close and reopen all log files'
                'notify:send NOTIFY to slaves'
                'querylog:enable/disable query logging'
                'reload:trigger zone reload if SOA serial changed'
                'shutdown:shut down the server'
                'sync:sync zone data to disk'
                'thaw:re-enable dynamic updates to a zone'
                'thawall:re-enable dynamic updates to all zones'
                'unfreeze:alias for thaw'
                'unfreezeall:alias for thawall'
                'zonecfgreload:reload zone config sections'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_yadifa "$@"
