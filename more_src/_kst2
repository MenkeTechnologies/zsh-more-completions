#compdef kst2
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/kst2.1.html
# kst2 - plots scientific data

local ret=1

_arguments -s \
  '-F[override the datasource indicated in the kstfile]:datasource:_files' \
  '-f[begin plotting at STARTFRAME frames into the data]:startframe' \
  '-n[plot at most NUMFRAMES frames of data]:numframes' \
  '-s[plot every FRAMESPERSAMPLE frames]:framespersample' \
  '-a[average frames (simple mean) when plotting with -s]' \
  '-P[plot all plots in the plot named PLOTNAME]:plotname' \
  '-A[plot all curves in separate plots]' \
  '-d[use points when plotting curves]' \
  '-l[use lines when plotting curves]' \
  '-b[plot as bargraphs]' \
  '-x[use FIELD as the X-axis vector]:field' \
  '-y[plot FIELD as an XY plot]:field' \
  '-e[use FIELD as the magnitude of error bars]:field' \
  '-p[plot FIELD as a power spectrum plot]:field' \
  '-h[plot FIELD as a histogram]:field' \
  '-z[plot FIELD as an image]:field' \
  '--png[render to a png image and quit]:file:_files' \
  '--print[print the plot to file and quit]:file:_files' \
  '--landscape[use landscape orientation for printing]' \
  '--portrait[use portrait orientation for printing]' \
  '--Letter[use US Letter sized paper for printing]' \
  '--A4[use A4 sized paper for printing]' \
  '*:file:_files' && ret=0

return ret
