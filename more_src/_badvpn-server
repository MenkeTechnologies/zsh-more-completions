#compdef badvpn-server
# Documentation: https://github.com/ambrop72/badvpn/blob/master/server/server.c
# badvpn peer-to-peer VPN chat/relay server

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--logger[logging destination]:dest:(stdout syslog)' \
  '--syslog-facility[set syslog facility]:facility:' \
  '--syslog-ident[set syslog identity]:ident:' \
  '--loglevel[logging verbosity level]:level:(0 1 2 3 4 5 none error warning notice info debug)' \
  '--channel-loglevel[per-channel loglevel]:channel:' \
  '--threads[number of threads]:number:' \
  '--use-threads-for-ssl-handshake[offload SSL handshake to threads]' \
  '--use-threads-for-ssl-data[offload SSL data to threads]' \
  '--ssl[enable SSL]' \
  '--nssdb[NSS database string]:nssdb:' \
  '--server-cert-name[server certificate name]:name:' \
  '--listen-addr[address to listen on]:addr:' \
  '--comm-predicate[communication permission predicate]:predicate:' \
  '--relay-predicate[relay permission predicate]:predicate:' \
  '--client-socket-sndbuf[client socket send buffer bytes]:bytes:' \
  '--max-clients[max number of clients]:number:' && ret=0

return ret
