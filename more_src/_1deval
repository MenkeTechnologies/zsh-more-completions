#compdef 1deval
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1deval.html
# Evaluate an expression with columns from text files, write to stdout

local ret=1

_arguments -s -S \
  '-del[step for a single undetermined variable]:d' \
  '-expr[3dcalc-style expression to compute]:expr' \
  '-start[start value for a single undetermined variable]:s' \
  '-num[evaluate the expression n times]:n' \
  '-index[read index column and write as 1st column of output]:file:_files' \
  '-1D:[write output as a single 1D: string]' \
  '*:file:_files' && ret=0

return ret
