#compdef spin
# _spinnaker-cli — Spinnaker spin CLI (Netflix + Spinnaker community, Go); manage Spinnaker applications + pipelines
# upstream: https://github.com/spinnaker/spin

_spinnaker-cli() {
    local -a sub=(
        'account:account commands'
        'application:application commands'
        'canary-config:canary config commands'
        'completion:print shell completion'
        'help:show help'
        'pipeline:pipeline commands'
        'pipeline-template:pipeline template commands'
        'pipeline-templatev2:pipeline template v2 commands'
        'plugin-info:plugin info commands'
        'plugin-publisher:plugin publisher commands'
        'plugin-release:plugin release commands'
        'project:project commands'
        'serverGroup:server group commands'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config+[config file]:file:_files' \
        '--gate-endpoint+[gate endpoint URL]:url:_urls' \
        '--ignore-cert-errors[ignore TLS cert errors]' \
        '--ignore-redirects[ignore HTTP redirects]' \
        '--insecure[skip TLS verify]' \
        '--no-color[no color]' \
        '-k[skip TLS verify]' \
        '--output+[output format]:fmt:(json yaml)' \
        '-o+[output format]:fmt:' \
        '--quiet[quiet]' \
        '--retry+[retries]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spin subcommand' sub ;;
        args)
            case $words[1] in
                application) _arguments '1:application cmd:(delete get list save)' '*:args:' ;;
                pipeline) _arguments '1:pipeline cmd:(delete execute get list save)' '*:args:' ;;
                canary-config) _arguments '1:canary cmd:(delete get list save)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_spinnaker-cli "$@"
