#compdef radclient
# _radclient — FreeRADIUS radclient (send RADIUS Access-Request/Accounting/Status-Server packets and report responses; -c count, -d dictionary dir, -D NAS-Identifier override, -f file with attr=value lines, -h help, -i id, -n parallel requests, -p port, -P proto (udp|tcp), -q quiet, -r retries, -s parallel sessions, -S secret file, -t timeout, -v version, -x debug; positional argument is server[:port] action secret)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radclient.c on tip.

_radclient() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[count]:n:' \
        '-d+[dictionary dir]:dir:_files -/' \
        '-D+[NAS-Identifier]:nas:' \
        '*-f+[file]:file:_files' \
        '-i+[id]:id:' \
        '-n+[parallel requests]:n:' \
        '-p+[port]:port:' \
        '-P+[proto]:proto:(udp tcp)' \
        '-q[quiet]' \
        '-r+[retries]:n:' \
        '-s+[parallel sessions]:n:' \
        '-S+[secret file]:file:_files' \
        '-t+[timeout]:seconds:' \
        '-x[debug]' \
        '-X[double debug]' \
        '1:server[:port]:_hosts' \
        '2:action:(auth acct status disconnect coa)' \
        '3:secret:'
}

_radclient "$@"
