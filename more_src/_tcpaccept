#compdef tcpaccept tcpaccept-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpaccept.py argparse)
# Reference accessed: 2026-05-29
# tcpaccept — trace TCP passive (inbound) accept()s (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --time)'{-T,--time}'[include time column on output (HH\:MM\:SS)]' \
  '(-t --timestamp)'{-t,--timestamp}'[include timestamp on output]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-P --port)'{-P,--port=}'[comma-separated list of local ports to trace]:ports:' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '--cgroupmap=[trace cgroups in this BPF map only]:map:' \
  '--mntnsmap=[trace mount namespaces in this BPF map only]:map:' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
