#compdef sfveltran
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mveltran.c
# Madagascar: hyperbolic Radon (velocity) transform

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'adj=[adjoint flag]:flag:(y n)' \
  'anti=[antialiasing]:value' \
  'nv=[velocity model dimension]:count' \
  'v0=[initial velocity (required in adjoint mode)]:velocity' \
  'dv=[velocity sampling interval (required in adjoint mode)]:value' \
  'nx=[offset dimension]:count' \
  'x0=[offset origin (required in forward mode)]:value' \
  'dx=[offset sampling interval (required in forward mode)]:value' \
  's02=[reference slowness squared (for antialiasing)]:value' \
  'pull=[pull or push operator]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
