#compdef hyde-shell
# Documentation: https://github.com/HyDE-Project/HyDE
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# hyde-shell delegates to dynamic HyDE scripts; only top-level options are stable.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:display help message'
  'reload:reload HyDE'
  'wallbash:execute a wallbash script'
  'version:show version information'
  'release-notes:show release notes'
)

_arguments -C \
  '(- *)'{-h,--help,help}'[display help message]' \
  '(- *)'{-v,--version,version}'[show version information]' \
  '(- *)-r[reload HyDE]' \
  '(- *)reload[reload HyDE]' \
  '--release-notes[show release notes]' \
  '--list-script[list available scripts]' \
  '--list-script-path[list scripts with full paths]' \
  '--completions=[generate shell completions]:shell:(bash zsh fish)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hyde-shell command' commands && ret=0 ;;
esac

return ret
