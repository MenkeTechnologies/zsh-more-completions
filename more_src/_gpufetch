#compdef gpufetch

# Zsh completion for gpufetch - GPU information tool similar to cpufetch

local -a arguments

arguments=(
  '(-c --color)'{-c,--color}'[set custom color scheme]:scheme:'
  '(-s --style)'{-s,--style}'[set logo style]:style:(fancy retro legacy)'
  '(-l --logo)'{-l,--logo}'[set custom logo]:logo:'
  '(-L --list-gpus)'{-L,--list-gpus}'[list available GPUs]'
  '--short[print short output]'
  '--raw[do not print the logo]'
  '--debug[print debug information]'
  '(-g --gpu)'{-g,--gpu}'[GPU index to query]:index:'
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show gpufetch version]'
)

_arguments -s $arguments
