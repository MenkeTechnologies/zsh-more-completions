#compdef wikit
# Documentation: https://github.com/KorySchneider/wikit
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print installed version number]' \
  '(-n --name)'{-n,--name}'[print the name of the program: wikit]' \
  '(-l --lang)'{-l,--lang}'+[specify language (HTML ISO language code)]:langCode:' \
  '(-a --all)'{-a,--all}'[print all sections of the article (the full page)]' \
  '--line[set line wrap length]:num:' \
  '--link[print a link to the full article after the summary]' \
  '-b[open full Wikipedia article in default browser]' \
  '--browser[open article in specific browser application]:browser:' \
  '-d[open disambiguation CLI menu]' \
  '-D[open disambiguation page in browser]' \
  '*:query:' && ret=0

return ret
