#compdef mlr

# Zsh completion for mlr (Miller) - like awk/sed/cut/join/sort for CSV/TSV/JSON

local curcontext="$curcontext" state line ret=1

local -a verbs=(
  'altkv:alternate between field names and values'
  'bar:produce a histogram'
  'bootstrap:randomly sample records with replacement'
  'cat:pass records through unchanged'
  'check:check structure of input data'
  'clean-whitespace:clean whitespace from field names and values'
  'count:count records matching a pattern'
  'count-distinct:count distinct values of a field'
  'count-similar:count similar records'
  'cut:keep or remove fields by name'
  'decimate:pass only 1 in every N records'
  'fill-down:fill missing values with the most recent non-empty value'
  'fill-empty:fill empty strings with a specified value'
  'filter:filter records by expression'
  'flatten:flatten multi-level nested maps into dotted keys'
  'format-values:apply type-specific formatting to field values'
  'fraction:compute fractions of a total'
  'gap:produce gaps in output'
  'grep:select records matching a pattern'
  'group-by:group records by a field'
  'group-like:group records with similar field names'
  'having-fields:select records with certain field names'
  'head:emit the first N records'
  'histogram:produce a histogram of a field'
  'json-parse:parse JSON-encoded strings in field values'
  'json-stringify:convert field values to JSON strings'
  'label:rename all field names'
  'least-frequent:show the least-frequent values of a field'
  'merge-fields:merge field values across namespaced key names'
  'most-frequent:show the most-frequent values of a field'
  'nest:explode/implode certain fields'
  'nothing:pass no records'
  'put:add/modify fields'
  'regularize:reorder record fields into alphabetical order'
  'remove-empty-columns:remove fields with all-empty values'
  'rename:rename one or more fields'
  'reorder:reorder record fields'
  'repeat:duplicate each record N times'
  'reshape:convert between wide and long format'
  'sample:randomly sample records'
  'sec2gmt:convert Unix seconds to GMT'
  'sec2gmtdate:convert Unix seconds to GMT date'
  'seqnum:add a field of sequential record numbers'
  'shuffle:randomly order all records'
  'skip-trivial-records:remove records where all fields are blank'
  'sort:sort records'
  'sort-within-records:sort record fields'
  'stats1:compute 1-variable stats'
  'stats2:compute 2-variable stats'
  'step:compute stepper functions of a field'
  'sub:replace a string using a regular expression'
  'gsub:replace all matching strings using a regular expression'
  'summary:summarize records'
  'tail:emit the last N records'
  'tac:reverse the order of records'
  'tee:write records to a file'
  'top:emit the top N records for each group'
  'unflatten:restore flattened keys to nested maps'
  'uniq:emit unique records by field'
  'unspace:remove spaces from field values'
  'unsparsify:fill missing values across all records'
  'utf8-to-latin1:convert UTF-8 to Latin-1'
  'latin1-to-utf8:convert Latin-1 to UTF-8'
  'label:add labels'
  'cat:concatenate'
  'tee:tee to a file'
  'merge:merge two record streams'
  'join:join two record streams'
)

_arguments -s -S \
  '--csv[use CSV input/output format]' \
  '--csvlite[use CSV-lite input/output format]' \
  '--tsv[use TSV input/output format]' \
  '--tsv-lite[use TSV-lite input/output format]' \
  '--json[use JSON input/output format]' \
  '--json-lines[use JSON Lines input/output format]' \
  '--jsonl[use JSON Lines input/output format]' \
  '--nidx[use NIDX (numbered field) format]' \
  '--dkvp[use DKVP (delimited key-value pairs) format]' \
  '--pprint[use PPRINT (pretty-print) format]' \
  '--xtab[use XTAB (vertical-tabular) format]' \
  '--ocsv[use CSV output format]' \
  '--otsv[use TSV output format]' \
  '--ojson[use JSON output format]' \
  '--ojsonl[use JSON Lines output format]' \
  '--opprint[use PPRINT output format]' \
  '--odkvp[use DKVP output format]' \
  '--oxtab[use XTAB output format]' \
  '--onidx[use NIDX output format]' \
  '--ifs[specify input field separator]:separator:' \
  '--ofs[specify output field separator]:separator:' \
  '--irs[specify input record separator]:separator:' \
  '--ors[specify output record separator]:separator:' \
  '--ips[specify input pair separator]:separator:' \
  '--ops[specify output pair separator]:separator:' \
  '--headerless-csv-output[suppress header line on CSV output]' \
  '--implicit-csv-header[use 1,2,3,... as CSV header]' \
  '--allow-ragged-csv-input[allow different number of fields per record]' \
  '--skip-trivial-records[skip empty records]' \
  '--nr-progress-mod[print progress every N records]:N:' \
  '--from[read from file]:file:_files' \
  '--load[source a Miller DSL file]:file:_files' \
  '-f[specify DSL file]:file:_files' \
  '-e[specify DSL expression]:expression:' \
  '-n[process no input, for put/filter -f only]' \
  '-q[suppress default output]' \
  '-s[key=value]:pair:' \
  '--seed[random seed]:seed:' \
  '--no-auto-unflat[disable auto-unflat]' \
  '--norc[do not load .mlrrc]' \
  '(--help)-h[show help]' \
  '(--help)--help[show help]' \
  '--version[show version]' \
  '*:verb or file:->verb_or_file' && ret=0

case $state in
  verb_or_file)
    _describe -t verbs 'verb' verbs || _files
    ret=0
    ;;
esac

return ret
