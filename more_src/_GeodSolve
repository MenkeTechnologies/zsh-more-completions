#compdef GeodSolve
# Documentation: https://geographiclib.sourceforge.io/C++/doc/GeodSolve.1.html
# GeographicLib: solve direct and inverse geodesic problems

local ret=1

_arguments -s -S \
  '-i[perform an inverse geodesic calculation]' \
  '-L[line mode from lat1 lon1 azi1]:lat1:' \
  '-D[define geodesic line via direct parameters]:lat1:' \
  '-I[define geodesic line via inverse parameters]:lat1:' \
  '-a[toggle arc mode (arc length in degrees)]' \
  '-e[specify ellipsoid via equatorial radius and flattening]:a:' \
  '-u[unroll the longitude]' \
  '-F[fractional mode; inputs are fractional distances]' \
  '-d[output angles as degrees, minutes, seconds]' \
  '-:[like -d but use colons as separators]' \
  '-w[toggle longitude-first flag]' \
  '-b[report back azimuth at point 2]' \
  '-f[full output of 12 quantities]' \
  '-p[set output precision]:prec:' \
  '-E[use exact algorithms based on elliptic integrals]' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
