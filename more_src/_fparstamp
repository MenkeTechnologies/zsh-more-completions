#compdef fparstamp
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fparstamp.txt
# Copy the contents of an FTOOLS .par file into a FITS file as HISTORY

local ret=1

_arguments -s \
  "-h[show help]" \
  "-o[output file]:output:_files" \
  "-t[task name whose .par to copy]:" \
  "*:FITS file:_files" && ret=0

return ret
