#compdef cargo-apk
# Documentation: https://github.com/rust-mobile/cargo-apk
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'build:build the APK'
  'run:run on connected device'
  'check:check the project'
  'clean:clean cargo and APK artifacts'
  'test:run tests in emulator'
  'gdb:run with gdb'
  'install:install APK'
  'uninstall:uninstall APK'
  'apk:apk subcommand (cargo apk apk ...)'
  'package:package APK'
  'rust:rust subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--release)--release[release build]' \
  '(--target)--target=[target triple]:t:(armv7-linux-androideabi aarch64-linux-android i686-linux-android x86_64-linux-android)' \
  '(-p --package)*'{-p+,--package=}'[package]:p:' \
  '(--manifest-path)--manifest-path=[manifest path]:file:_files -g "*.toml"' \
  '(--features)--features=[features csv]:list:' \
  '(--all-features)--all-features[all features]' \
  '(--no-default-features)--no-default-features[no default features]' \
  '(--target-dir)--target-dir=[target dir]:dir:_files -/' \
  '(--lib --bin --example --test --bench)--lib[lib]' \
  '(--bin)--bin=[binary]:b:' \
  '(--example)--example=[example]:e:' \
  '(--test)--test=[test]:t:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cargo-apk command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
