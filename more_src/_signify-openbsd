#compdef signify-openbsd
# Documentation: https://man.archlinux.org/search?q=signify-openbsd
# Reference accessed: 2026-05-16

# signify-openbsd: minimal OpenBSD signature tool (port to Linux)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-C[verify checksum file]' \
  '-G[generate keypair]' \
  '-S[sign a message]' \
  '-V[verify signature]' \
  '-n[no question to overwrite]' \
  '-q[quiet]' \
  '-z[gzip armor signed message]' \
  '-c[checksum list file]:file:_files' \
  '-e[embed message in signature]' \
  '-m[message file]:file:_files' \
  '-p[public key]:file:_files' \
  '-s[private key]:file:_files' \
  '-x[signature file]:file:_files' \
  '-t[key purpose tag]:str:' \
  '*::signify-openbsd args:_files' && ret=0
return ret
