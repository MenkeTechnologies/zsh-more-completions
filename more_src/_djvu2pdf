#compdef djvu2pdf
# Documentation: https://man.archlinux.org/search?q=djvu2pdf
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-q+[JPEG quality (1-100)]:quality' \
  '-r+[resolution in DPI]:dpi' \
  '-d+[output directory]:directory:_directories' \
  '-o+[output file]:output file:_files -g "*.pdf(-.)"' \
  '1:input file:_files -g "*.djvu(-.)"' && return 0
