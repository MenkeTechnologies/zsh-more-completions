#compdef streamlit-cli
# _streamlit-cli — Streamlit data app framework CLI alias (Snowflake / Streamlit, Python); click
# upstream: https://github.com/streamlit/streamlit

_streamlit-cli() {
    local -a sub=(
        'run:run a streamlit script'
        'hello:show example app'
        'config:manage streamlit config'
        'cache:manage cache'
        'docs:open docs'
        'version:show version'
        'activate:activate email'
        'init:scaffold project'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--log_level=+[log level]:level:(error warning info debug)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'streamlit subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--server.address=+[server address]:host:_hosts' \
                    '--server.port=+[server port]:port:' \
                    '--server.baseUrlPath=+[base url path]:str:' \
                    '--server.enableCORS=+[enable CORS]:b:(true false)' \
                    '--server.enableXsrfProtection=+[enable XSRF protection]:b:(true false)' \
                    '--server.maxUploadSize=+[max upload size MB]:n:' \
                    '--server.maxMessageSize=+[max message size MB]:n:' \
                    '--server.headless=+[headless]:b:(true false)' \
                    '--server.runOnSave=+[run on save]:b:(true false)' \
                    '--server.fileWatcherType=+[file watcher]:t:(auto watchdog poll none)' \
                    '--server.allowRunOnSave=+[allow run on save]:b:(true false)' \
                    '--browser.serverAddress=+[browser server address]:host:_hosts' \
                    '--browser.gatherUsageStats=+[gather usage stats]:b:(true false)' \
                    '--theme.base=+[theme base]:t:(light dark)' \
                    '--theme.primaryColor=+[primary color]:c:' \
                    '--theme.backgroundColor=+[bg color]:c:' \
                    '--theme.secondaryBackgroundColor=+[secondary bg color]:c:' \
                    '--theme.textColor=+[text color]:c:' \
                    '--theme.font=+[font]:f:(sans serif serif monospace)' \
                    '--client.toolbarMode=+[toolbar mode]:m:(auto developer viewer minimal)' \
                    '--client.showSidebarNavigation=+[show sidebar nav]:b:(true false)' \
                    '--runner.fastReruns=+[fast reruns]:b:(true false)' \
                    '--runner.magicEnabled=+[magic enabled]:b:(true false)' \
                    '--logger.level=+[logger level]:level:(error warning info debug)' \
                    '--logger.messageFormat=+[message format]:str:' \
                    '*:script:_files -g "*.py"' ;;
                config) _arguments \
                    '1:cmd:(show)' \
                    '*:arg:' ;;
                cache) _arguments \
                    '1:cmd:(clear)' \
                    '*:arg:' ;;
                docs|hello|version|activate|init) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_streamlit-cli "$@"
