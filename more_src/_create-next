#compdef create-next
# Documentation: https://www.npmjs.com/package/create-next
# Reference accessed: 2026-05-24
# Verified: npm view create-next bin; npx create-next --help output.

# Zsh completion for create-next - legacy Next.js utility CLI (app/express/emotion/env)

local curcontext="$curcontext" state line ret=1

_arguments -C   '--baseDir=[base directory]:directory:_directories'   '--help[show help]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' app express emotion env && ret=0
    ;;
  args)
    case $line[1] in
      app)
        _arguments -C           '--baseDir=[base directory]:directory:_directories'           '--help[show help]'           ':Next.js app name:' && ret=0
        ;;
      *)
        _arguments -C '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
