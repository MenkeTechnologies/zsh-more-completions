#compdef chown-cli
# _chown-cli — GNU coreutils chown change owner and group CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_chown-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[report changes]' \
        '--changes[report changes]' \
        '-f[suppress most errors]' \
        '--silent[suppress most errors]' \
        '--quiet[suppress most errors]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--dereference[follow symlinks]' \
        '-h[no follow symlinks]' \
        '--no-dereference[no follow symlinks]' \
        '--from=+[CURRENT_OWNER:CURRENT_GROUP]:str:' \
        '--no-preserve-root[no preserve root]' \
        '--preserve-root[preserve root]' \
        '--reference=+[reference file]:file:_files' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-H[traverse cmd-line symlinks]' \
        '-L[follow each symlink]' \
        '-P[do not follow symlinks]' \
        '*:owner files:_files'
}

_chown-cli "$@"
