#compdef buildctl
# Documentation: https://github.com/moby/buildkit/blob/master/cmd/buildctl/main.go
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug output]' \
  '--addr=[buildkitd address]:address' \
  '--log-format=[log format]:format:(json text)' \
  '--tlsservername=[TLS server name]:name' \
  '--tlscacert=[CA certificate]:file:_files' \
  '--tlscert=[client certificate]:file:_files' \
  '--tlskey=[client key]:file:_files' \
  '--tlsdir=[directory with TLS files]:directory:_directories' \
  '--timeout=[connection timeout in seconds]:seconds' \
  '--wait[block RPCs until connection is available]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'du:show disk usage'
      'build:build a project'
      'prune:clean up build cache'
      'prune-histories:clean up build history'
      'debug:debug utilities'
      'dial-stdio:dial buildkitd via stdio'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments \
          '--frontend=[frontend to use]:frontend:(dockerfile.v0 gateway.v0)' \
          '*--local=[set local source]:name=path' \
          '*--output=[output]:output' \
          '*--opt=[set frontend option]:key=value' \
          '--no-cache[disable cache]' \
          '*--export-cache=[export cache]:cache spec' \
          '*--import-cache=[import cache]:cache spec' \
          '--trace=[trace file]:file:_files' \
          '--progress=[display type]:type:(auto plain tty)' \
          '--metadata-file=[write build metadata to file]:file:_files' \
          '*:context:_files' && ret=0
        ;;
      prune)
        _arguments \
          '--all[prune all cache]' \
          '*--filter=[filter]:filter' \
          '--keep-duration=[keep cache newer than duration]:duration' \
          '--keep-bytes=[keep cache up to size]:bytes' && ret=0
        ;;
    esac
    ;;
esac

return ret
