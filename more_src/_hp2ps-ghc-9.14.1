#compdef hp2ps-ghc-9.14.1

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-b[use large title box]' \
  '-d[sort by standard deviation]' \
  '-ef-[Encapsulated PostScript width (in/mm/pt)]:width:' \
  '-g[output suitable for GHOSTSCRIPT previewer]' \
  '-i+[sort by identifier (+/-)]:flag:(+ -)' \
  '-M[multi-page output]' \
  '-mn+[max bands (max 20, 0=no limit)]:n:' \
  '-p[show percentages]' \
  '-s[shorten labels]' \
  '-tf+[discard small bands]:fraction:' \
  '-y[do not stretch y-axis]' \
  '*:hp file:_files -g "*.hp"' && ret=0

return ret
