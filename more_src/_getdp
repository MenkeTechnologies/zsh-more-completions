#compdef getdp
# Documentation: https://getdp.info/doc/texinfo/getdp.html
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-solve+[solve a resolution]:resolution name:' \
  '-pos+[run post-processing operations]:post-processing name:' \
  '-pre+[run pre-processing]:pre-processing name:' \
  '-cal[use calendar for date/time functions]' \
  '-msh+[specify mesh file]:mesh file:_files -g "*.msh"' \
  '-res+[load result file]:result file:_files -g "*.res"' \
  '-bin[use binary format for output]' \
  '-v+[set verbosity level 0-99]:level:' \
  '-v2[use new log format]' \
  '-setnumber+[set a number parameter]:name value:' \
  '-setstring+[set a string parameter]:name value:' \
  '-gmshread+[read a Gmsh file]:file:_files' \
  '-split[split output files]' \
  '-check[check input file]' \
  '-help[show help]' \
  '-version[show version]' \
  '*:input file:_files -g "*.pro"' && ret=0

return ret
