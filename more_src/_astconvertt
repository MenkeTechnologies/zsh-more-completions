#compdef astconvertt
# astconvertt — convert between image/data formats

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-g --globalhdu)'{-g,--globalhdu}'[use this HDU for all inputs, ignore --hdu]:HDU' \
  '(-u --quality)'{-u,--quality}'[quality of output JPEG image (1-100)]:quality' \
  '(-w --widthincm)'{-w,--widthincm}'[width in centimeters]:width' \
  '(-b --borderwidth)'{-b,--borderwidth}'[border width in points (1/72 inch)]:width' \
  '--bordercolor[color for the border]:color' \
  '(-x --hex)'{-x,--hex}'[hexadecimal encoding in EPS (default: ASCII85)]' \
  '--colormap[color map for single channel input]:colormap' \
  '--rgbtohsv[convert RGB input into HSV in FITS output]' \
  '(-L --fluxlow)'{-L,--fluxlow}'[lower flux truncation value]:value' \
  '(-H --fluxhigh)'{-H,--fluxhigh}'[higher flux truncation value]:value' \
  '(-m --maxbyte)'{-m,--maxbyte}'[maximum byte value for all color channels]:value' \
  '(-A --forcemin)'{-A,--forcemin}'[force --fluxmin even if smaller than minimum]' \
  '(-B --forcemax)'{-B,--forcemax}'[force --fluxmax even if larger than maximum]' \
  '(-c --change)'{-c,--change}'[change pixel values (from:to,...)]:mapping' \
  '(-C --changeaftertrunc)'{-C,--changeaftertrunc}'[first truncate then change pixel values]' \
  '(-i --invert)'{-i,--invert}'[invert values in JPEG and EPS/PDF]' \
  '(-O --mode)'{-O,--mode}'[coordinate mode for marks]:mode:(img wcs)' \
  '--marks[mark information table file]:file:_files' \
  '--markshdu[HDU in marks file if FITS]:HDU' \
  '(-r --markcoords)'{-r,--markcoords}'[columns with coordinates for marks]:columns' \
  '--markshape[column for mark shapes]:column' \
  '--markrotate[column with mark rotation]:column' \
  '--marksize[columns with mark sizes]:columns' \
  '--sizeinpix[size column values are in pixels (WCS mode)]' \
  '--sizeinarcsec[size column values are in arcsec (WCS mode)]' \
  '--sizeinarcmin[size column values are in arcmin (WCS mode)]' \
  '--marklinewidth[column with line width]:column' \
  '--markcolor[column with mark color]:column' \
  '--listcolors[list names and RGB info of all colors]' \
  '--marktext[column with mark text]:column' \
  '--marktextprecision[decimals when text is float column]:number' \
  '--markfont[column with mark font name]:column' \
  '--markfontsize[column with mark font size]:column' \
  '--showfonts[show all fonts in a PDF]' \
  '--listfonts[list names of available fonts]' \
  '*:input files:_files'
