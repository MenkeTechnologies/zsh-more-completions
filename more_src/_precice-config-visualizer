#compdef precice-config-visualizer
# Documentation: https://github.com/precice/config-visualizer/blob/master/README.md
# Visualize a preCICE XML configuration file as a graph

local ret=1
local -a display
display=(full merged hide)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --outfile)'{-o,--outfile}'=[output file (extension picks renderer; omit for dot to stdout)]:file:_files' \
  '--data-access=[verbosity of read/write access between mesh and participant]:level:($display)' \
  '--data-exchange=[verbosity of data exchange between meshes]:level:($display)' \
  '--communicators=[verbosity of communicators]:level:($display)' \
  '--cplschemes=[verbosity of coupling schemes]:level:($display)' \
  '--mappings=[verbosity of mappings]:level:($display)' \
  '--no-watchpoints[do not display watchpoints]' \
  '--no-colors[disable colors in the output]' \
  '--margin=[margin around cluster borders in points]:int' \
  '1:XML configuration file:_files -g "*.xml"' && ret=0

return ret
