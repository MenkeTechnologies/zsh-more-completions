#compdef sfsoftclip
# Documentation: https://ahay.org/RSF/sfsoftclip.html
# Madagascar: soft clipping of the data

local ret=1

_arguments -s \
  'upper=[threshold value for upper clipping]:float:' \
  'lower=[threshold value for lower clipping]:float:' \
  'sharp=[sharpness of the clipping transition]:float:' \
  '*:rsf file:_files' && ret=0

return ret
