#compdef t.list
# GRASS GIS: list space time datasets and maps registered in the temporal database

local ret=1

_arguments -s -S \
  '--help[print usage summary]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--ui[force launching GUI dialog]' \
  '-c[print the column names as first row]' \
  'type=[type of dataset or map]:type:(strds str3ds stvds raster raster_3d vector)' \
  'temporaltype=[temporal type]:type:(absolute relative)' \
  'order=[sort the dataset by category]:order' \
  'columns=[columns to print to stdout]:columns' \
  'where=[WHERE conditions of SQL statement]:where' \
  'separator=[field separator]:sep:(pipe comma space tab newline)' \
  'output=[name for output file]:file:_files' && ret=0

return ret
