#compdef custom-install
# Documentation: https://github.com/ihaveamac/custom-install
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# custom-install: install CIA titles directly to a Nintendo 3DS SD card from a PC.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(-b --boot9)'{-b,--boot9}'[boot9 file]:file:_files' \
  '(-m --movable)'{-m,--movable}'[movable.sed file]:file:_files' \
  '(-s --seeddb)'{-s,--seeddb}'[SeedDB file]:file:_files' \
  '--sd=[SD card root path]:dir:_files -/' \
  '*:CIA file:_files -g "*.cia"' && ret=0

return ret
