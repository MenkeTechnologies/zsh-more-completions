#compdef gitdorker GitDorker.py
# Documentation: https://github.com/obheda12/GitDorker
# OSINT: GitHub dork search tool for finding sensitive information.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dorks)'{-d+,--dorks=}'[dorks file (required)]:file:_files' \
  '(-k --keyword)'{-k+,--keyword=}'[search on a keyword instead of a dork list]:keyword:' \
  '(-q --query)'{-q+,--query=}'[query (required or -q)]:query:' \
  '(-qf --queryfile)'{-qf+,--queryfile=}'[file of queries]:file:_files' \
  '(-ri --recentlyindexed)'{-ri,--recentlyindexed}'[sort results from most recent first]' \
  '(-lb --limitbypass)'{-lb,--limitbypass}'[increase requests per minute with multiple tokens]' \
  '(-pf --patternfilter)'{-pf,--patternfilter}'[filter out noise/test/example key patterns]' \
  '(-u --users)'{-u+,--users=}'[users to search on (comma separated)]:users:' \
  '(-uf --userfile)'{-uf+,--userfile=}'[file containing newline separated users]:file:_files' \
  '(-org --organization)'{-org+,--organization=}'[organization GitHub name]:org:' \
  '(-t --token)'{-t+,--token=}'[your GitHub token]:token:' \
  '(-tf --tokenfile)'{-tf+,--tokenfile=}'[file of newline separated GitHub tokens]:file:_files' \
  '(-e --threads)'{-e+,--threads=}'[maximum number of threads (default 1)]:n:' \
  '(-p --positiveresults)'{-p,--positiveresults}'[display positive results only]' \
  '(-o --output)'{-o+,--output=}'[output file name]:file:_files' && ret=0

return ret
