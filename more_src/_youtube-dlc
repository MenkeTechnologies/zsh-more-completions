#compdef youtube-dlc
# Documentation: https://man.archlinux.org/search?q=youtube-dlc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-U[update to latest version]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[continue on download errors]' \
  '--abort-on-error[abort on errors]' \
  '--list-extractors[list supported extractors]' \
  '--extractor-descriptions[list extractor descriptions]' \
  '--default-search=[default search prefix]:prefix:(ytsearch auto error fixup_error)' \
  '--ignore-config[ignore configs]' \
  '--config-location=[config file location]:file:_files' \
  '--flat-playlist[do not extract videos]' \
  '--mark-watched[mark videos watched]' \
  '--no-mark-watched[do not mark watched]' \
  '--no-color[no color output]' \
  '--proxy=[HTTP/SOCKS proxy URL]:url:' \
  '--socket-timeout=[socket timeout sec]:secs:' \
  '--source-address=[bind source IP]:ip:' \
  '(-4 --force-ipv4)'{-4,--force-ipv4}'[force IPv4]' \
  '(-6 --force-ipv6)'{-6,--force-ipv6}'[force IPv6]' \
  '--geo-verification-proxy=[geo proxy URL]:url:' \
  '--geo-bypass[bypass geo restrictions]' \
  '--no-geo-bypass[do not bypass geo restrictions]' \
  '--geo-bypass-country=[bypass country code]:cc:' \
  '--geo-bypass-ip-block=[bypass IP block CIDR]:cidr:' \
  '--playlist-start=[start at]:n:' \
  '--playlist-end=[end at]:n:' \
  '--playlist-items=[items to download csv]:items:' \
  '--match-title=[regex title match]:re:' \
  '--reject-title=[regex title reject]:re:' \
  '--max-downloads=[max downloads]:n:' \
  '--min-filesize=[min filesize]:size:' \
  '--max-filesize=[max filesize]:size:' \
  '--date=[exact date]:YYYYMMDD:' \
  '--datebefore=[before date]:YYYYMMDD:' \
  '--dateafter=[after date]:YYYYMMDD:' \
  '--min-views=[min view count]:n:' \
  '--max-views=[max view count]:n:' \
  '--match-filter=[generic filter]:filter:' \
  '--no-playlist[only video, not playlist]' \
  '--yes-playlist[download whole playlist]' \
  '--age-limit=[age limit]:years:' \
  '--download-archive=[archive file]:file:_files' \
  '--include-ads[include advertisements]' \
  '(-r --limit-rate)'{-r+,--limit-rate=}'[bandwidth limit]:rate:' \
  '(-R --retries)'{-R+,--retries=}'[retry count]:n:' \
  '--fragment-retries=[fragment retries]:n:' \
  '--skip-unavailable-fragments[skip unavailable fragments]' \
  '--abort-on-unavailable-fragment[abort on unavailable fragment]' \
  '--keep-fragments[keep fragments]' \
  '--buffer-size=[download buffer]:size:' \
  '--no-resize-buffer[no resize buffer]' \
  '(-c --continue)'{-c,--continue}'[resume partial downloads]' \
  '--no-continue[do not resume]' \
  '--no-part[no .part files]' \
  '--no-mtime[no mtime from server]' \
  '--write-description[write description to file]' \
  '--write-info-json[write metadata JSON]' \
  '--write-annotations[write video annotations]' \
  '--load-info-json=[load info JSON]:file:_files' \
  '--cookies=[cookie file]:file:_files' \
  '(-f --format)'{-f+,--format=}'[format selector]:fmt:(best bestvideo bestaudio worst worstvideo worstaudio)' \
  '(-F --list-formats)'{-F,--list-formats}'[list available formats]' \
  '--youtube-skip-dash-manifest[skip DASH manifest]' \
  '--merge-output-format=[merged output format]:fmt:(mkv mp4 ogg webm flv)' \
  '--write-sub[write subtitle]' \
  '--write-auto-sub[write auto subs]' \
  '--all-subs[download all subs]' \
  '--list-subs[list subs]' \
  '--sub-format=[subtitle format]:fmt:(best srt vtt ass lrc)' \
  '--sub-lang=[subtitle languages csv]:langs:' \
  '(-u --username)'{-u+,--username=}'[login username]:user:' \
  '(-p --password)'{-p+,--password=}'[login password]:pw:' \
  '-2[two-factor auth code]:code:' \
  '(-n --netrc)'{-n,--netrc}'[use .netrc auth]' \
  '--video-password=[video password]:pw:' \
  '(-x --extract-audio)'{-x,--extract-audio}'[extract audio]' \
  '--audio-format=[audio format]:fmt:(best aac flac mp3 m4a opus vorbis wav)' \
  '--audio-quality=[audio quality 0-9 or rate]:q:' \
  '--recode-video=[recode to format]:fmt:(mp4 flv ogg webm mkv avi)' \
  '(-k --keep-video)'{-k,--keep-video}'[keep original video]' \
  '--no-post-overwrites[do not overwrite postproc files]' \
  '--embed-subs[embed subs in video]' \
  '--embed-thumbnail[embed thumbnail]' \
  '--add-metadata[add metadata to file]' \
  '--metadata-from-title=[parse metadata from title]:fmt:' \
  '--xattrs[set xattrs from metadata]' \
  '--fixup=[automatic file corrections]:policy:(never warn detect_or_warn)' \
  '--prefer-avconv[prefer avconv over ffmpeg]' \
  '--prefer-ffmpeg[prefer ffmpeg over avconv]' \
  '--ffmpeg-location=[ffmpeg path]:path:_files' \
  '--exec=[command to run after download]:cmd:' \
  '--convert-subs=[convert subs format]:fmt:(srt ass vtt lrc)' \
  '(-o --output)'{-o+,--output=}'[output template]:tmpl:' \
  '--output-na-placeholder=[NA placeholder]:str:' \
  '--autonumber-start=[autonumber start]:n:' \
  '--restrict-filenames[restrict to ASCII filenames]' \
  '(-w --no-overwrites)'{-w,--no-overwrites}'[skip existing files]' \
  '*:URL:' && ret=0

return ret
