#compdef streamlink

# Zsh completion for streamlink - stream extractor and player

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--plugins[print list of installed plugins]' \
  '--can-handle-url=[check if URL is supported]:url:' \
  '(-l --loglevel)'{-l,--loglevel}'[set log level]:level:(none error warning info debug trace)' \
  '(-Q --quiet)'{-Q,--quiet}'[hide all log output]' \
  '(-j --json)'{-j,--json}'[output JSON metadata]' \
  '--auto-version-check=[auto update check]:bool:(yes no)' \
  '--locale=[set locale]:locale:' \
  '--interface=[network interface]:interface:' \
  '(-4 --ipv4)'{-4,--ipv4}'[prefer IPv4]' \
  '(-6 --ipv6)'{-6,--ipv6}'[prefer IPv6]' \
  '(-p --player)'{-p,--player}'[set external player]:player:_command_names' \
  '(-a --player-args)'{-a,--player-args}'[arguments for the player]:args:' \
  '--player-env=[set player environment vars]:vars:' \
  '--player-http[use HTTP for player transport]' \
  '--player-continuous-http[keep HTTP server running between streams]' \
  '--player-passthrough=[player passthrough]:passthrough:(http hls rtmp)' \
  '--player-no-close[do not close player after stream ends]' \
  '(-t --title)'{-t,--title}'[set player window title]:title:' \
  '(-n --player-fifo --fifo)'{-n,--player-fifo,--fifo}'[use named pipe for player]' \
  '(-r --record)'{-r,--record}'[record stream to file]:file:_files' \
  '(-o --output)'{-o,--output}'[write stream to file]:file:_files' \
  '(-f --force)'{-f,--force}'[overwrite existing file]' \
  '--force-progress[show download progress]' \
  '--stream-url[print stream URL only]' \
  '--url=[URL to open]:url:' \
  '--default-stream=[default stream quality]:quality:' \
  '--retry-streams=[retry delay in seconds]:seconds:' \
  '--retry-max=[max retries]:retries:' \
  '--retry-open=[max open retries]:retries:' \
  '--stream-types=[stream types to allow]:types:' \
  '--stream-sorting-excludes=[exclude stream types]:types:' \
  '--http-proxy=[HTTP proxy]:proxy url:' \
  '--https-proxy=[HTTPS proxy]:proxy url:' \
  '--http-cookie=[set HTTP cookie]:cookie:' \
  '--http-header=[set HTTP header]:header:' \
  '--http-query-param=[set HTTP query param]:param:' \
  '--http-timeout=[HTTP timeout]:seconds:' \
  '--ffmpeg-ffmpeg=[path to ffmpeg]:path:_files' \
  '--ffmpeg-fout=[ffmpeg output format]:format:' \
  '--config=[config file]:file:_files' \
  '1:url:' \
  '2:quality:(best worst best-unfiltered worst-unfiltered 1080p 720p 480p 360p 160p audio_only)'
