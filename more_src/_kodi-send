#compdef kodi-send

# Zsh completion for kodi-send - Kodi remote control CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--host[Kodi host address]:host:_hosts' \
  '--port[Kodi port number]:port:' \
  '*--action[send action command]:action:' \
  '*--builtIn[execute built-in function]:built-in function:' \
  && ret=0

return ret
