#compdef plakar
# Documentation: https://man.archlinux.org/search?q=plakar
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-r+[Repository URI]:uri:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:Initialize a repository'
      'backup:Create a new snapshot'
      'restore:Extract files from snapshots diff'
      'dump:Serialize snapshots to archive'
      'ls:List snapshots'
      'cat:Print file contents at revision'
      'diff:Compare snapshots'
      'rm:Delete snapshots'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
