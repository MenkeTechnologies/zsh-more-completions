#compdef devin

_devin() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--model[Set the AI model]:model:'
        '--permission-mode[Set permissions]:mode:(normal accept-edits bypass)'
        '(-c --continue)'{-c,--continue}'[Resume the most recent session]'
        '(-r --resume)'{-r,--resume}'[Resume a specific session by ID]:id:'
        '(-p --print)'{-p,--print}'[Non-interactive mode: print response and exit]'
        '--prompt-file[Load initial prompt from a file]:file:_files'
        '--config[Specify custom configuration path]:file:_files'
        '--json[Output results in raw JSON]'
        '(-h --help)'{-h,--help}'[Display help for command]'
    )

    subcmds=(
        'sessions:Manage development sessions'
        'auth:Manage authentication'
        'mcp:Manage Model Context Protocol servers'
        'rules:Manage agent rules'
        'skills:Manage custom skills'
        'configure:Set up profiles and API tokens'
        'update:Check for and install CLI updates'
        'version:Display current CLI version'
        'acp:Manage Agent Context Protocol settings'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'devin commands' subcmds
            ;;
        args)
            case $line[1] in
                sessions)
                    local -a sessions_subcmds
                    sessions_subcmds=(
                        'create:Create a new session'
                        'list:List recent sessions'
                        'get:Retrieve details for a specific session'
                        'terminate:End the active session'
                    )
                    _describe -t commands 'sessions subcommands' sessions_subcmds
                    ;;
                auth)
                    local -a auth_subcmds
                    auth_subcmds=(
                        'login:Authenticate via browser or manual token'
                        'logout:Clear stored credentials'
                        'status:Check current login status'
                    )
                    _describe -t commands 'auth subcommands' auth_subcmds
                    ;;
                mcp)
                    local -a mcp_subcmds
                    mcp_subcmds=(
                        'add:Add an MCP server'
                        'list:List MCP servers'
                        'remove:Remove an MCP server'
                    )
                    _describe -t commands 'mcp subcommands' mcp_subcmds
                    ;;
            esac
            ;;
    esac
}

_devin "$@"
