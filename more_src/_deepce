#compdef deepce
# Docker container enumeration and escape tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --enum)'{-e,--enum}'[run enumeration checks]' \
  '(-nn --no-network)'{-nn,--no-network}'[skip network checks]' \
  '(-doc --docker)'{-doc,--docker}'[check for Docker socket access]' \
  '(-sk --sk)'{-sk,--sk}'[check for service account tokens]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--install[install required tools]' \
  && return 0
