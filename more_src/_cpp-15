#compdef cpp-15

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-pass-exit-codes[exit with highest error code from a phase]' \
  '(- *)--help[show help]' \
  '--target-help[show target-specific options]' \
  '*--help=[show specific option types]:type:(common optimizers params target warnings)' \
  '*-D+[define macro]:macro[=defn]:' \
  '*-U+[undefine macro]:macro:' \
  '*-I+[add include directory]:dir:_files -/' \
  '-E[preprocess only]' \
  '-P[do not generate line markers]' \
  '-C[keep comments]' \
  '-CC[keep comments including macro expansions]' \
  '-traditional[traditional preprocessing]' \
  '-v[verbose]' \
  '-MD[generate dependency file]' \
  '-MM[print user-include dependencies]' \
  '-MP[add phony targets]' \
  '-MF+[dependency file output]:file:_files' \
  '-o+[output file]:file:_files' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|h|hpp|hxx)"' && ret=0

return ret
