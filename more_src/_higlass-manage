#compdef higlass-manage
# Documentation: https://github.com/higlass/higlass-manage
# HiGlass-Manage - manage local docker instances of HiGlass

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'create:create a superuser in the container'
      'delete:delete a superuser from the container'
      'list:list running instances or tilesets'
      'ingest:ingest a dataset into a running instance'
      'start:start a local higlass instance'
      'stop:stop a running instance'
      'shell:start a shell in a running container'
      'view:view a file in higlass'
      'update_viewconfs:update stored view configs'
      'logs:return the error log for an instance'
      'version:show version'
    )
    _describe -t commands 'higlass-manage command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments -s \
          '(-t --temp-dir)'{-t,--temp-dir=}'[temporary directory]:dir:_files -/' \
          '(-d --data-dir)'{-d,--data-dir=}'[data directory]:dir:_files -/' \
          '(-v --version)'{-v,--version=}'[higlass docker version]:version' \
          '(-p --port)'{-p,--port=}'[port to run on]:port' \
          '(-n --hg-name)'{-n,--hg-name=}'[name for this higlass instance]:name' \
          '(-s --site-url)'{-s,--site-url=}'[host URL for outside access]:url' \
          '(-m --media-dir)'{-m,--media-dir=}'[media directory]:dir:_files -/' \
          '--default-track-options=[JSON file with default track options]:file:_files' \
          '--workers=[number of worker processes]:workers' \
          '--use-redis[enable Redis caching service]' \
          '--redis-dir=[directory to store Redis files]:dir:_files -/' \
          '--hg-repository=[higlass docker repository]:repo' \
          '--redis-repository=[Redis docker repository]:repo' \
          '--redis-tag=[Redis docker tag]:tag' \
          '--redis-port=[Redis port]:port' && ret=0
        ;;
      ingest)
        _arguments -s \
          '--hg-name=[name of the higlass instance]:name' \
          '--filetype=[type of the input file]:filetype' \
          '--datatype=[datatype of the input file]:datatype' \
          '--assembly=[genome assembly]:assembly' \
          '--name=[name to use for this file]:name' \
          '--uid=[uuid to use for this file]:uid' \
          '--no-upload[do not copy the file into the container]' \
          '--chromsizes-filename=[chromsizes file]:file:_files' \
          '--has-header[input file has a header]' \
          '--project-name=[project name]:name' \
          '1:filename:_files' && ret=0
        ;;
      view)
        _arguments -s \
          '(-n --hg-name)'{-n,--hg-name=}'[name of the higlass instance]:name' \
          '--filetype=[type of the input file]:filetype' \
          '--datatype=[datatype of the input file]:datatype' \
          '--tracktype=[track type used to view this file]:tracktype' \
          '--position=[position of the track]:position' \
          '--assembly=[genome assembly]:assembly' \
          '--chromsizes-filename=[chromsizes file]:file:_files' \
          '1:filename:_files' && ret=0
        ;;
      stop)
        _arguments -s '*:name:' && ret=0
        ;;
      shell|logs)
        _arguments -s '*:hg-name:' && ret=0
        ;;
      update_viewconfs)
        _arguments -s \
          '--old-hg-name=[old higlass instance name]:name' \
          '--old-site-url=[old site URL]:url' \
          '--old-port=[old port]:port' \
          '--old-data-dir=[old data directory]:dir:_files -/' \
          '--new-site-url=[new site URL]:url' \
          '--new-port=[new port]:port' \
          '--db-backup-name=[database backup name]:name' && ret=0
        ;;
      list)
        local -a sub
        sub=('tilesets:list datasets in an instance' 'instances:list running instances')
        _describe -t subcommands 'list subcommand' sub && ret=0
        ;;
      create|delete)
        local -a sub
        sub=('superuser:manage a superuser')
        _describe -t subcommands 'subcommand' sub && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
