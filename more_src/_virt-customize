#compdef virt-customize
# _virt-customize — libguestfs virt-customize (post-install per-image customisation for cloud images and templates; -a disk, -d domain, --install pkgs, --update, --uninstall, --run script, --firstboot, --root-password, --hostname, --timezone, --copy-in src:dest, --selinux-relabel)
# upstream: https://github.com/libguestfs/libguestfs (customize)
# Flags from libguestfs customize/customize_main.ml on tip.

_virt-customize() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[trace libguestfs calls]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*--install+[packages]:pkgs:' \
        '*--uninstall+[packages]:pkgs:' \
        '*--update[update all packages]' \
        '*--run+[script]:file:_files' \
        '*--run-command+[shell command]:command:' \
        '*--firstboot+[firstboot script]:file:_files' \
        '*--firstboot-command+[firstboot command]:command:' \
        '--hostname+[hostname]:hostname:' \
        '--timezone+[timezone]:tz:' \
        '--root-password+[password spec]:spec:(file: random disabled lock: password:)' \
        '*--password+[USER:spec]:user_spec:' \
        '*--ssh-inject+[USER[:KEYFILE|STR]]:spec:' \
        '*--copy-in+[src:dst]:src:dst:' \
        '*--copy+[src:dst]:src:dst:' \
        '*--upload+[file:dest]:file:dest:' \
        '*--write+[path:content]:path:content:' \
        '*--append-line+[path:line]:path:line:' \
        '*--mkdir+[dir]:dir:' \
        '--selinux-relabel[relabel SELinux]' \
        '--no-network[disable network during customize]'
}

_virt-customize "$@"
