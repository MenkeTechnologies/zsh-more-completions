#compdef rofimoji
# Documentation: https://github.com/fdw/rofimoji
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --action)'{-a+,--action=}'[action]:action:(type copy clipboard unicode copy-unicode menu print)' \
  '(-f --files)*'{-f+,--files=}'[character file(s)]:file:_files' \
  '(-s --skin-tone)'{-s+,--skin-tone=}'[skin tone]:tone:(neutral light medium-light medium medium-dark dark ask)' \
  '--selector=[selector to use]:selector:(rofi wofi bemenu fuzzel dmenu choose tofi)' \
  '--selector-args=[extra selector args]:args:' \
  '--rofi-args=[args passed to rofi only]:args:' \
  '--wofi-args=[args passed to wofi only]:args:' \
  '--max-recent=[max recent items]:n:' \
  '--no-frecency[disable frecency ordering]' \
  '--hidden-descriptions[hide character descriptions]' \
  '--prompt=[selector prompt]:text:' \
  '--clipboarder=[clipboard tool]:tool:(xclip xsel wl-clipboard)' \
  '--typer=[typer tool]:tool:(xdotool wtype ydotool)' \
  '--keybindings=[custom keybindings]:bindings:' \
  '--input-method=[input method]:method:' \
  '*::passthrough:' && ret=0

return ret
