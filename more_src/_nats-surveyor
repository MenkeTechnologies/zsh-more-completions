#compdef nats-surveyor
# Documentation: https://github.com/nats-io/nats-surveyor
# nats-surveyor - NATS monitoring, simplified - exports metrics to Prometheus

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-s --servers)'{-s,--servers}'[NATS cluster URLs]:urls:' \
  '(-c --count)'{-c,--count}'[expected number of servers]:count:' \
  '--timeout[polling timeout]:duration:' \
  '--server-discovery-timeout[wait time between server responses]:duration:' \
  '--creds[credentials file]:file:_files' \
  '--nkey[NKey seed file]:file:_files' \
  '--jwt[user JWT]:jwt:' \
  '--seed[private key or NKey seed]:seed:' \
  '--user[username or token]:user:' \
  '--password[user password]:password:' \
  '--token-file[bearer token file path]:file:_files' \
  '--tlscert[client certificate for NATS]:file:_files' \
  '--tlskey[client private key for NATS]:file:_files' \
  '--tlscacert[certificate authority for NATS]:file:_files' \
  '--tlsfirst[enable TLS-first connections]' \
  '(-p --port)'{-p,--port}'[listen port]:port:' \
  '(-a --addr)'{-a,--addr}'[network host to listen on]:addr:' \
  '--http-tlscert[server certificate (enables HTTPS)]:file:_files' \
  '--http-tlskey[server private key]:file:_files' \
  '--http-tlscacert[client CA for verification]:file:_files' \
  '--http-user[basic auth username]:user:' \
  '--http-pass[basic auth password]:password:' \
  '--prefix[replace default metric prefix]:prefix:' \
  '--observe[observation statistics directory]:dir:_files -/' \
  '--jetstream[JetStream advisories directory]:dir:_files -/' \
  '--accounts[export per-account metrics]' \
  '--accounts-detailed[granular account metrics]' \
  '--gatewayz[gateway metrics]' \
  '--raftz[raft group metrics]' \
  '--jsz[JetStream metrics]:scope:(all streams consumers)' \
  '--jsz-limit[max returned account JSZ metrics]:n:' \
  '--jsz-leaders-only[leaders-only JSZ metrics]' \
  '--jsz-filter[selected JSZ metrics]:filter:' \
  '--sys-req-prefix[system request subject prefix]:prefix:' \
  '--log-level[logging level]:level:' \
  '--config[config file path]:file:_files' && ret=0

return ret
