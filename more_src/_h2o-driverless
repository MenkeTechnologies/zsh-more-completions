#compdef h2o-driverless h2oai
# _h2o-driverless — H2O.ai h2o-driverless h2oai CLI command-line frontend wrapping the H2O Driverless AI automatic machine learning platform managing experiments datasets projects models deployments connectors recipes interpretations time-series MLI Auto-ML auto-doc autoreport diagnostics-deploy-MOJO-Python-scoring-pipeline (H2O.ai team, Python); click
# upstream: https://h2o.ai/

_h2o-driverless() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'experiment:experiment operations'
        'dataset:dataset operations'
        'project:project operations'
        'model:model operations'
        'deployment:deployment operations'
        'connector:connector operations'
        'recipe:recipe operations'
        'interpretation:interpretation operations'
        'time-series:time-series operations'
        'mli:MLI operations'
        'autodoc:Auto-Doc operations'
        'autoreport:Auto-Report operations'
        'leaderboard:leaderboard operations'
        'mojo:MOJO operations'
        'scoring-pipeline:scoring pipeline'
        'license:license operations'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--address=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--api-key=+[key]:str:' \
        '--config-toml=+[file]:file:_files -g "*.toml"' \
        '--license-file=+[file]:file:_files -g "*.sig *.lic"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'h2o-driverless subcommand' sub ;;
        args)
            case $words[1] in
                experiment|dataset|project|model|deployment|connector|recipe|interpretation|time-series|mli|autodoc|autoreport|leaderboard|mojo|scoring-pipeline) _arguments '1:op:(list get create update delete start stop predict score download upload export import deploy promote retrain re-fit refit feature-store)' '*:id:' ;;
            esac
            ;;
    esac
}

_h2o-driverless "$@"
