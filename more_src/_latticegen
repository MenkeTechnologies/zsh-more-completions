#compdef latticegen
# Documentation: https://github.com/fplll/fplll
# latticegen - generate lattice basis matrices for fplll

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-randseed[set random seed (integer or time)]:seed' \
  '*:type:(r s u n N q t T)' && ret=0

return ret
