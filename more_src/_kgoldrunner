#compdef kgoldrunner
# Documentation: https://docs.kde.org/stable5/en/kgoldrunner/kgoldrunner/index.html
# Reference accessed: 2026-05-16

# KGoldrunner: KDE puzzle/action game (Lode Runner clone)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all help]' \
  '(- *)--help-qt[show Qt help]' \
  '(- *)--help-kde[show KDE help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '*:saved game:_files -g "*.kgr"' && ret=0
return ret
