#compdef kgoldrunner
# Documentation: https://invent.kde.org/games/kgoldrunner/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp uses only KAboutData::setupCommandLine + QCommandLineParser::process
# (no custom addOption calls). Real options are Qt+KAboutData standard set only.
# Removed from prior file: --help-qt, --help-kde (KDE3/4-era flags, not present in KF6 Qt6
# QCommandLineParser). The .kgr saved-game glob is invented (saves are managed internally).

# KGoldrunner: KDE puzzle/action game (Lode Runner clone)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[load specified desktop file]:file:_files -g "*.desktop"' && ret=0
return ret
