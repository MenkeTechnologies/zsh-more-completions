#compdef ldd
# _ldd-bin — print shared library dependencies (glibc); show DSOs required by a binary
# upstream: https://sourceware.org/glibc

_ldd-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '(-d --data-relocs)'{-d,--data-relocs}'[process data relocations]' \
        '(-r --function-relocs)'{-r,--function-relocs}'[process function and data relocations]' \
        '(-u --unused)'{-u,--unused}'[print unused direct deps]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '*:file:_files'
}

_ldd-bin "$@"
