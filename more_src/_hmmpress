#compdef hmmpress
# Documentation: https://man.archlinux.org/search?q=hmmpress
# Reference accessed: 2026-05-16

# HMMER hmmpress: prepare an HMM database for hmmscan
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f[force - overwrite existing binary files]' \
  '*:HMM database file:_files' && ret=0
return ret
