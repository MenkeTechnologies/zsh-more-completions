# HMMER hmmpress: prepare an HMM database for hmmscan
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f[force - overwrite existing binary files]' \
  '*:HMM database file:_files' && ret=0
return ret
