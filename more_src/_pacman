#compdef pacman

# Zsh completion for pacman - Arch Linux package manager

local curcontext="$curcontext" state line ret=1

local -a operations=(
  '-D:modify the package database'
  '-F:query the files database'
  '-Q:query the package database'
  '-R:remove packages'
  '-S:synchronize packages'
  '-U:upgrade or add packages'
  '-V:display version'
  '-h:display help'
)

_arguments -s -S \
  '(-D --database)'{-D,--database}'[modify the package database]' \
  '(-F --files)'{-F,--files}'[query the files database]' \
  '(-Q --query)'{-Q,--query}'[query the package database]' \
  '(-R --remove)'{-R,--remove}'[remove packages]' \
  '(-S --sync)'{-S,--sync}'[synchronize packages]' \
  '(-U --upgrade)'{-U,--upgrade}'[upgrade or add packages]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '--arch[set an alternate architecture]:architecture' \
  '--cachedir[set an alternate package cache location]:directory:_files -/' \
  '--color[specify when to enable coloring]:when:(auto always never)' \
  '--config[set an alternate configuration file]:config file:_files' \
  '--confirm[always ask for confirmation]' \
  '--dbpath[set an alternate database location]:directory:_files -/' \
  '--debug[display debug messages]' \
  '--disable-download-timeout[disable download timeout]' \
  '--gpgdir[set an alternate home directory for GnuPG]:directory:_files -/' \
  '--hookdir[set an alternate hook location]:directory:_files -/' \
  '--logfile[set an alternate log file]:log file:_files' \
  '--noconfirm[do not ask for any confirmation]' \
  '--sysroot[set an alternate system root]:directory:_files -/' \
  '(-b --dbpath)'{-b,--dbpath}'[set an alternate database location]:directory:_files -/' \
  '(-r --root)'{-r,--root}'[set an alternate installation root]:directory:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-c --clean)'{-c,--clean}'[remove old packages from cache / remove unneeded dependencies]' \
  '(-d --deps)'{-d,--deps}'[restrict or skip packages installed as dependencies]' \
  '(-e --explicit)'{-e,--explicit}'[filter or list explicitly installed packages]' \
  '(-g --groups)'{-g,--groups}'[view package groups]' \
  '(-i --info)'{-i,--info}'[view package information]' \
  '(-k --check)'{-k,--check}'[check package files / check available packages]' \
  '(-l --list)'{-l,--list}'[list files owned by queried package / list packages in repo]' \
  '(-m --foreign)'{-m,--foreign}'[filter packages not in sync db]' \
  '(-n --native)'{-n,--native}'[filter packages in sync db]' \
  '(-o --owns)'{-o,--owns}'[query the package that owns file]:file:_files' \
  '(-p --file)'{-p,--file}'[query a package file]:package file:_files' \
  '(-q --quiet)'{-q,--quiet}'[show less information]' \
  '(-s --search)'{-s,--search}'[search package names and descriptions]:search term' \
  '(-t --unrequired)'{-t,--unrequired}'[filter packages not required by any package]' \
  '(-u --upgrades)'{-u,--upgrades}'[list or perform upgrades]' \
  '(-w --downloadonly)'{-w,--downloadonly}'[download packages only]' \
  '(-x --regex)'{-x,--regex}'[enable searching with regular expressions]' \
  '(-y --refresh)'{-y,--refresh}'[download fresh package databases]' \
  '--asdeps[install packages as dependencies]' \
  '--asexplicit[install packages as explicitly installed]' \
  '--cascade[remove packages and dependents]' \
  '--needed[do not reinstall up-to-date packages]' \
  '--nodeps[skip dependency version checks]' \
  '--nosave[remove configuration files]' \
  '--noprogressbar[do not show progress bar]' \
  '--noscriptlet[do not execute install scriptlet]' \
  '--overwrite[overwrite conflicting files]:glob pattern' \
  '--print[print targets instead of performing operation]' \
  '--print-format[specify print format]:format string' \
  '--recursive[remove unnecessary dependencies]' \
  '--unneeded[remove unneeded packages]' \
  '*:package:->packages' && ret=0

case $state in
  packages)
    local -a installed_packages
    if [[ -n ${opt_args[-Q]} || -n ${opt_args[--query]} || -n ${opt_args[-R]} || -n ${opt_args[--remove]} ]]; then
      installed_packages=(${(f)"$(pacman -Qq 2>/dev/null)"})
      _describe -t packages 'installed packages' installed_packages && ret=0
    else
      local -a sync_packages
      sync_packages=(${(f)"$(pacman -Ssq 2>/dev/null)"})
      _describe -t packages 'packages' sync_packages && ret=0
    fi
    ;;
esac

return ret
