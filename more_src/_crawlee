#compdef crawlee
# Documentation: https://man.archlinux.org/search?q=crawlee
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new Crawlee project from template'
  'install-playwright-browsers:install Playwright browsers'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'crawlee command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--template=[project template]:tmpl:(getting-started-js getting-started-ts cheerio-js cheerio-ts puppeteer-js puppeteer-ts playwright-js playwright-ts beautifulsoup-py playwright-py parsel-py)' \
          '--template-name=[npm template name]:name:' \
          '--no-install[do not run npm install]' \
          '--skip-optional-dependencies[skip optional deps]' \
          '*::project_name:' && ret=0 ;;
    esac ;;
esac

return ret
