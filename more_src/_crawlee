#compdef crawlee
# ============================================================================
# crawlee - scalable web scraping + browser
#            automation framework + project
#            scaffolder
#            (TypeScript/Node, Apache-2.0)
#
# Author : Apify
#           (apify.com; Czech web scraping +
#           automation company that
#           open-sourced their internal
#           crawling framework as Crawlee in
#           2022 after rebrand from Apify
#           SDK)
# Upstream: https://github.com/apify/crawlee
# npm pkg : @crawlee/cli (CLI is one of
#           many @crawlee/* workspace
#           packages in the apify/crawlee
#           monorepo)
#
# `crawlee` is the CLI scaffolder + runner
# for projects built on Crawlee, the
# scalable Node.js web scraping + browser
# automation library. The CLI does NOT
# implement scraping itself - it scaffolds
# new projects from templates that exercise
# different crawler types + runs them with
# proper storage management.
#
# Crawler types provided by Crawlee:
#   - **CheerioCrawler** (@crawlee/cheerio):
#     fast HTML scraping via cheerio + CSS
#     selectors; no JS execution; ideal
#     for static HTML
#   - **JSDOMCrawler** (@crawlee/jsdom):
#     DOM-based scraping via jsdom; light
#     JS execution; intermediate cost
#   - **HttpCrawler** (@crawlee/http):
#     raw HTTP requests; minimal
#     overhead; ideal for API scraping
#   - **PuppeteerCrawler** (@crawlee/
#     puppeteer): full Chromium browser
#     control; heavy JS execution; ideal
#     for SPAs
#   - **PlaywrightCrawler** (@crawlee/
#     playwright): multi-browser
#     control (Chromium + Firefox +
#     WebKit); heavy JS execution
#   - **LinkeDOMCrawler** (@crawlee/
#     linkedom): faster JSDOM
#     alternative
#   - **ImpitCrawler** (@crawlee/impit):
#     Rust-based HTTP crawler;
#     experimental
#
# Crawlee handles infrastructure concerns
# the user would otherwise rebuild:
#   - Request queue management (persistent
#     queues stored locally or in cloud
#     storage)
#   - Automatic retries with exponential
#     backoff
#   - Concurrency control (autoscaled
#     pool of crawlers)
#   - Session management (cookie jars +
#     proxy rotation + fingerprinting)
#   - Proxy rotation (with health
#     tracking)
#   - Persistent dataset storage (KV
#     store + named datasets)
#   - Anti-blocking heuristics (TLS
#     fingerprint rotation via impit;
#     User-Agent rotation;
#     header reordering)
#   - Hooks for pre-request + post-
#     response + error handling
#
# Use cases:
#   - Scaffold a new web scraping project
#     from a template
#   - Run existing Crawlee project locally
#     with managed storage (request queue
#     + KV store + dataset)
#   - Install Playwright browser binaries
#     for projects using PlaywrightCrawler
#
# Usage:
#   crawlee <command> [options]
#
# Commands (yargs):
#   create [project-name]          - create a
#                                     new
#                                     Crawlee
#                                     project
#                                     directory
#                                     from a
#                                     selected
#                                     boilerplate
#                                     template
#   run                            - run the
#                                     Crawlee
#                                     project
#                                     in the
#                                     current
#                                     directory
#   install-playwright-browsers    - install
#                                     Playwright
#                                     browser
#                                     dependencies
#                                     (Chromium
#                                     + Firefox
#                                     + WebKit)
#
# `create` flags:
#   -t, --template <name>          - template
#                                     for the
#                                     project
#                                     (if not
#                                     provided,
#                                     command
#                                     prompts
#                                     for
#                                     interactive
#                                     selection)
#
# Available templates (from @crawlee/
# templates package):
#   - getting-started-ts           - basic
#                                     TypeScript
#                                     crawler
#   - getting-started-js           - basic
#                                     JavaScript
#                                     crawler
#   - cheerio-ts                   - CheerioCrawler
#                                     TypeScript
#                                     starter
#                                     (THIS
#                                     AXIS's
#                                     library
#                                     use)
#   - cheerio-js                   - CheerioCrawler
#                                     JavaScript
#                                     starter
#   - puppeteer-ts                 - PuppeteerCrawler
#                                     TypeScript
#                                     starter
#   - puppeteer-js                 - PuppeteerCrawler
#                                     JavaScript
#                                     starter
#   - playwright-ts                - PlaywrightCrawler
#                                     TypeScript
#                                     starter
#   - playwright-js                - PlaywrightCrawler
#                                     JavaScript
#                                     starter
#   - playwright-camoufox-ts       - Playwright
#                                     + Camoufox
#                                     (anti-
#                                     fingerprint
#                                     stealth
#                                     browser)
#   - http-ts                      - HttpCrawler
#                                     TypeScript
#                                     starter
#   - jsdom-ts                     - JSDOMCrawler
#                                     TypeScript
#                                     starter
#   - stagehand-ts                 - Stagehand
#                                     (AI-
#                                     powered
#                                     web
#                                     automation
#                                     by
#                                     Browserbase)
#
# `run` flags:
#       --no-purge                 - disable
#                                     automatic
#                                     purging
#                                     of
#                                     default
#                                     storages
#                                     (request
#                                     queue +
#                                     KV
#                                     store +
#                                     dataset)
#       --purge                    - explicit
#                                     opt-in
#                                     to purge
#                                     (default
#                                     behavior)
#       --script <name>            - npm
#                                     script
#                                     to use
#                                     instead
#                                     of
#                                     `start`
#                                     (e.g.
#                                     `--script
#                                     start:
#                                     prod`)
#
# Standard flags:
#   -h, --help                     - show
#                                     help
#   -v, --version                  - show
#                                     version
#
# Example invocations:
#   # Scaffold a new TypeScript Cheerio
#   # crawler project (interactive template
#   # picker)
#   crawlee create my-scraper
#
#   # Scaffold with explicit template
#   crawlee create my-scraper -t cheerio-ts
#
#   # Scaffold a Playwright project
#   crawlee create my-spa-scraper \
#     --template playwright-ts
#
#   # Install Playwright browsers (after
#   # scaffolding a Playwright project)
#   cd my-spa-scraper
#   crawlee install-playwright-browsers
#
#   # Run the project (purges old storages
#   # by default)
#   crawlee run
#
#   # Run preserving previous storages
#   crawlee run --no-purge
#
#   # Run with custom npm script
#   crawlee run --script start:prod
#
# Project storage layout (created by `run`):
#   ./storage/
#     ├── datasets/            # named result
#     │   └── default/          # datasets
#     ├── key_value_stores/    # JSON state
#     │   └── default/          # storage
#     ├── request_queues/      # persistent
#     │   └── default/          # request
#     │                          # queues
#     └── ...
#
# The cheerio lane is built on `cheerio:
# 1.0.0-rc.12` (declared verbatim at
# upstream packages/cheerio-crawler/package.
# json HEAD as a direct dep of the
# @crawlee/cheerio workspace package, which
# is one of the canonical crawler types
# provided by the framework; the CLI
# scaffolds projects that use @crawlee/
# cheerio via the cheerio-ts + cheerio-js
# templates), the canonical Node HTML
# scraping library by Felix Böhm + Matt
# Mueller + cheeriojs maintainers -
# github.com/cheeriojs/cheerio.
#
# cheeriojs/cheerio is the de-facto
# canonical Node HTML scraping library:
#   - **jQuery-style API** (the original
#     jQuery $ + chained method pattern
#     adapted to Node; the API design
#     that goquery + scraper later
#     adopted - cheerio is the original)
#   - **Built on htmlparser2 / parse5**
#     (configurable parsing backend;
#     parse5 for WHATWG HTML5 spec
#     compliance + htmlparser2 for
#     performance)
#   - **CSS selector support** (via
#     css-select + nth-check)
#   - **Pure JavaScript implementation**
#     (no native bindings; runs in Node
#     + browsers + Deno + Bun)
#   - **DOM traversal API** (find +
#     filter + each + map + children +
#     parent + siblings; identical
#     surface to jQuery's API)
#   - **DOM manipulation API** (append +
#     prepend + remove + replaceWith +
#     wrap + unwrap; for round-trip
#     HTML editing)
#   - **~32,000,000 weekly npm downloads**
#     (one of the highest-volume Node
#     libraries; pulled in by every
#     scraping framework + many static
#     site generators)
#   - 30,000+ stars on github.com/
#     cheeriojs/cheerio
#
# cheeriojs/cheerio's distinguishing
# position vs Node HTML scraping
# alternatives:
#   - cheeriojs/cheerio (Böhm + Mueller +
#     org): canonical; ~32M weekly
#     downloads; THIS AXIS; the
#     original jQuery-on-Node HTML
#     scraping library
#   - JSDOM (jsdom/jsdom): full
#     DOM/browser environment
#     simulation; broader scope; heavier
#     (includes window + document + DOM
#     APIs not just parsing)
#   - linkedom (capricorn86/linkedom):
#     faster JSDOM alternative; smaller
#     bundle; used by some modern
#     scraping pipelines
#   - happy-dom (capricorn86/happy-dom):
#     another faster JSDOM alternative;
#     used by Vitest's DOM environment
#   - htmlparser2 (fb55/htmlparser2):
#     low-level HTML parser; cheerio
#     uses it internally; standalone
#     usage for performance-critical
#     parsing without DOM operations
#
# Felix Böhm (fb55) is the long-time
# primary maintainer of cheerio + many
# foundational Node HTML parsing
# libraries:
#   - **cheeriojs/cheerio** (canonical
#     Node HTML scraping; THIS AXIS)
#   - **fb55/htmlparser2** (canonical
#     low-level Node HTML parser; the
#     parsing backend for cheerio;
#     ~60M weekly downloads)
#   - **fb55/css-select** (CSS selector
#     compiler + matching engine; used
#     by cheerio for $.find() +
#     $.filter() implementations)
#   - **fb55/nth-check** (CSS
#     :nth-child / :nth-of-type
#     selector helper)
#   - **fb55/domhandler** (DOM-style
#     tree representation; used by
#     htmlparser2's tree-building mode)
#   - **fb55/domutils** (DOM tree
#     traversal utilities)
#   - **fb55/parse5** (WHATWG HTML5
#     spec-compliant parser - alternative
#     parsing backend for cheerio when
#     strict spec compliance is needed)
#
# Böhm's role in Node is *foundational
# HTML parsing + CSS selector
# infrastructure*. His library family
# forms the canonical Node HTML
# processing stack:
#   - htmlparser2 (low-level parsing)
#   - domhandler (tree building)
#   - domutils (traversal)
#   - css-select (selector matching)
#   - cheerio (high-level API)
#
# Few canonical-Node authors maintain
# such a complete vertical stack -
# Böhm's stack underlies nearly every
# Node HTML processing tool in
# production (cheerio + many
# scraping frameworks + static site
# generators + Markdown renderers
# via remark + others).
#
# Multi-axis canonical-Node author/org
# cohort extension (now spanning 27
# distinct individuals/orgs after
# R1555):
#   - + Felix Böhm (fb55; cheeriojs/
#     cheerio + fb55/htmlparser2 +
#     fb55/css-select + fb55/
#     domhandler + fb55/domutils +
#     fb55/parse5 + fb55/nth-check;
#     THIS AXIS; canonical Node HTML
#     scraping + foundational
#     vertical stack)
#
# Böhm joining the canonical-Node
# cohort at the *foundational
# vertical-stack canonical author*
# level is structurally distinctive.
# His cross-library presence parallels
# Mathias Buus (Axis 282 Node closer)
# who maintains a similar foundational
# stack in DNS + tar + streams + P2P.
# Both authors maintain the
# foundational primitives that
# higher-level Node libraries depend on.
#
# Notable: the goquery + cheerio +
# scraper convergence on the jQuery-
# style API (documented across R1553 +
# R1554 + this round) is structurally
# distinctive. The jQuery $ + chained
# method pattern - originally
# popularized by John Resig's jQuery
# in 2006 for browser-side DOM
# manipulation - became the de-facto
# API pattern for HTML scraping across
# Node (cheerio, 2012) + Go (goquery,
# 2012) + Rust (scraper, 2015).
#
# This is one of the strongest examples
# of cross-language API convention
# propagation documented in the
# corpus. jQuery's influence on HTML
# scraping API design across all
# three major systems languages is
# structurally distinctive - few API
# design patterns achieve this level
# of cross-language adoption.
#
# Notable: cheerio is the *original*
# jQuery-on-server library; goquery
# (2012, by Angers) and scraper
# (2015, by Pax) explicitly cite
# cheerio as their inspiration. The
# influence vector is jQuery →
# cheerio → goquery + scraper.
#
# crawlee uses cheerio through
# @crawlee/cheerio for:
#   - CheerioCrawler instances
#     (scaffolded by the cheerio-ts +
#     cheerio-js templates)
#   - The CLI's `create` command sets
#     up new projects with cheerio as
#     the HTML processing backend
#     when the user selects a Cheerio
#     template
#   - The cheerio-crawler workspace
#     package exports the Cheerio API
#     wrapped with Crawlee's request
#     queue + concurrency control
#
# This is the canonical use case for
# cheerio in production Node web
# scraping: high-throughput crawling
# pipelines where CSS-selector-based
# extraction is needed at scale +
# JavaScript execution is not
# required (most modern static-HTML
# scraping fits this pattern).
#
# ----------------------------------------------------------------------------
# AXIS 285 :: HTML parsing + scraping
#              libraries
#              (HTML5 spec-compliant
#              parsers + CSS selector
#              engines for web scraping +
#              full-text extraction + DOM
#              manipulation)
# Round 1555 :: TS/Node slot 3 of 4 :: CLOSES Axis 285
#
# Cross-language canonical library family
# for this axis (closed):
#   Rust    : causal-agent/scraper       [R1553 _feedr]
#             (Charles Edward Pax;
#              canonical Rust HTML
#              scraping; built on
#              Mozilla Servo html5ever +
#              selectors)
#   Go      : PuerkitoBio/goquery        [R1554 _subjs]
#             (Martin Angers; canonical
#              Go HTML scraping; jQuery-
#              style API; cascadia-
#              backed; 15,000+ stars)
#   TS/Node : cheeriojs/cheerio          [R1555 THIS FILE]
#             (Felix Böhm + maintainers;
#              canonical Node HTML
#              scraping; ~32M weekly
#              npm downloads; the
#              ORIGINAL jQuery-on-server
#              library; CLOSES Axis 285)
#
# Axis 285 closure = 278th axis closed in
# the corpus. The 3+1 cycle returns to slot
# 1/0/0 for Axis 286 opening at the next
# round.
#
# Reflection across all three lanes:
#   - All three implement WHATWG HTML5
#     spec-compliant parsing
#   - All three support CSS selector
#     matching for extraction
#   - All three converged on the jQuery-
#     style API pattern (chained
#     methods + $-like selection)
#   - The influence direction is
#     historical: jQuery (2006, browser
#     DOM) → cheerio (2012, Node) →
#     goquery (2012, Go) + scraper
#     (2015, Rust)
#
# Architectural pattern: jQuery's API
# design has the broadest cross-
# language adoption of any single API
# pattern documented in the corpus.
# This is consistent with:
#   - jQuery's massive original user
#     base (peak ~80% of web pages used
#     jQuery in early 2010s)
#   - The cognitive familiarity benefit
#     for developers transitioning
#     from web DOM scripting to
#     scraping
#   - The API's natural fit for HTML
#     manipulation (selector → action
#     chains map cleanly to scraping
#     workflows)
#
# Use-case spectrum across Axis 285
# (closed):
#   - feedr (Rust, scraper): RSS reader
#     full-text extraction pipeline
#     (parsing fetched article HTML
#     for main-content isolation)
#   - subjs (Go, goquery): bug bounty +
#     authorized security testing
#     JavaScript file URL extraction
#     from subdomain + URL lists
#   - crawlee (TS-Node, cheerio):
#     scalable web scraping framework
#     CLI for scaffolding + running
#     production crawling projects
#     using cheerio as the HTML
#     processing backend
#
# Use-case spectrum spans:
#   - Single-user reader (feedr:
#     personal RSS consumption)
#   - Security recon (subjs: bug bounty
#     JS file enumeration)
#   - Production scraping framework
#     (crawlee: scalable enterprise
#     scraping pipelines)
#
# Together they cover the canonical
# HTML scraping deployment patterns
# across the polyglot landscape:
# personal content rendering +
# security research + enterprise
# data extraction.
#
# Axis 285 is fully closed with
# coherent cross-language coverage
# of the HTML5 + CSS-selector +
# scraping ecosystem - all three
# lanes inherit from jQuery's API
# design tradition.
# ============================================================================

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
    'create:create a new Crawlee project from template'
    'run:run the project in the current directory'
    'install-playwright-browsers:install Playwright browser dependencies'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' && ret=0

case $state in
    (cmd) _describe -t cmds 'crawlee command' commands && ret=0 ;;
    (args)
        case $line[1] in
            (create)
                _arguments \
                    '(-t --template)'{-t,--template=}'[project template]:tmpl:(getting-started-ts getting-started-js cheerio-ts cheerio-js puppeteer-ts puppeteer-js playwright-ts playwright-js playwright-camoufox-ts http-ts jsdom-ts stagehand-ts)' \
                    '*:project name:' && ret=0
                ;;
            (run)
                _arguments \
                    '--no-purge[disable automatic purging of default storages]' \
                    '--purge[explicit opt-in to purge default storages]' \
                    '--script=[npm script to use instead of start]:script:' && ret=0
                ;;
        esac
        ;;
esac

return ret
