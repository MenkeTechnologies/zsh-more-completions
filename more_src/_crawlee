#compdef crawlee
# Documentation: https://github.com/apify/crawlee/tree/master/packages/cli
# Reference accessed: 2026-05-17
# Verified: upstream packages/cli/src/index.ts and commands at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new Crawlee project from template'
  'run:run the project in the current directory'
  'install-playwright-browsers:install Playwright browser dependencies'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-purge[disable automatic purge of default storages (run)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'crawlee command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '(-t --template)'{-t,--template=}'[project template]:tmpl:' \
          '*::project_name:' && ret=0 ;;
    esac ;;
esac

return ret
