#compdef grdtrend
# Documentation: https://docs.generic-mapping-tools.org/latest/grdtrend.html
# Source: GenericMappingTools/gmt classic-mode grdtrend — fit polynomial trend surface to a grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-N+[model parameter ID (+r robust, +x/+y for 1D)]:opts:_default' \
    '-D+[output residuals grid]:file:_files' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T+[output trend-surface grid]:file:_files' \
    '*-V[verbose (stackable)]' \
    '-W+[weights/uncertainties (+s for sigmas)]:opts:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
