#compdef process_hkl
# Documentation: https://www.desy.de/~twhite/crystfel/manual-process_hkl.html
# Merge serial crystallography intensities by Monte Carlo (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-i --input)'{-i+,--input=}'[input stream file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-y --symmetry)'{-y+,--symmetry=}'[point group for merging]:pointgroup:' \
  '(-g --histogram)'{-g+,--histogram=}'[intensity histogram for reflection]:h,k,l:' \
  '(-z --hist-parameters)'{-z+,--hist-parameters=}'[histogram range and bins]:min,max,nbins:' \
  '--start-after=[skip first n crystals]:n:' \
  '--stop-after=[process only n crystals]:n:' \
  '--even-only[merge only even-numbered crystals]' \
  '--odd-only[merge only odd-numbered crystals]' \
  '--scale[second pass with intensity scaling]' \
  '--no-polarisation[disable polarisation correction]' \
  '--min-measurements=[min reflection occurrences]:n:' \
  '--min-snr=[min signal-to-noise ratio]:n:' \
  '--max-adu=[max detector saturation value]:n:' \
  '--min-res=[min resolution in Angstroms]:n:' \
  '--push-res=[merge beyond resolution limit]:n:' \
  '--min-cc[second pass filtering by model CC]' \
  '--stat[output per-crystal statistics]' && ret=0

return ret
