#compdef soda

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'scan:run a Soda scan'
  'ingest:ingest test results from another tool'
  'test-connection:test a data source connection'
  'update-dro:update distribution reference object'
  'simulate-anomaly-detection:simulate anomaly detection'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'soda subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '(-d --data-source)'{-d,--data-source=}'[data source name]:name:' \
          '(-s --scan-definition)'{-s,--scan-definition=}'[scan definition]:name:' \
          '*'{-v,--variable=}'[variable key=value]:variable:' \
          '(-c --configuration)'{-c,--configuration=}'[config file]:file:_files -g "*.(yml|yaml)"' \
          '(-t --data-timestamp)'{-t,--data-timestamp=}'[data timestamp]:ts:' \
          '(-V --verbose)'{-V,--verbose}'[verbose]' \
          '(-srf --scan-results-file)'{-srf,--scan-results-file=}'[scan results file]:file:_files' \
          '(-T --template-path)'{-T,--template-path=}'[template path]:path:_files' \
          '*:checks:_files -g "*.(yml|yaml)"' && ret=0
        ;;
      (update-dro)
        _arguments \
          '(-d --data-source)'{-d,--data-source=}'[data source name]:name:' \
          '(-c --configuration)'{-c,--configuration=}'[config file]:file:_files' \
          '(-n --name)'{-n,--name=}'[DRO name]:name:' \
          '(-V --verbose)'{-V,--verbose}'[verbose]' && ret=0
        ;;
      (ingest)
        _arguments \
          '(-d --data-source)'{-d,--data-source=}'[data source name]:name:' \
          '(-c --configuration)'{-c,--configuration=}'[config file]:file:_files' \
          '(-V --verbose)'{-V,--verbose}'[verbose]' \
          '--dbt-artifacts=[dbt artifacts]:dir:_files -/' \
          '--dbt-manifest=[dbt manifest path]:file:_files -g "*.json"' \
          '--dbt-run-results=[dbt run results path]:file:_files -g "*.json"' \
          '--dbt-cloud-run-id=[dbt cloud run id]:id:' \
          '--dbt-cloud-job-id=[dbt cloud job id]:id:' && ret=0
        ;;
      (test-connection)
        _arguments \
          '(-d --data-source)'{-d,--data-source=}'[data source name]:name:' \
          '(-c --configuration)'{-c,--configuration=}'[config file]:file:_files' \
          '(-V --verbose)'{-V,--verbose}'[verbose]' && ret=0
        ;;
      (simulate-anomaly-detection)
        _arguments \
          '(-c --configuration)'{-c,--configuration=}'[config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
