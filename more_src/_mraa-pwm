#compdef mraa-pwm
# _mraa-pwm — Intel mraa-pwm CLI command-line wrapper around Intel libmraa I/O abstraction library managing PWM pulse-width-modulation channels enable disable period microseconds duty cycle percentage on Intel Galileo Edison Joule MinnowBoard ARM SBC boards (Intel team, C); custom argparse
# upstream: https://github.com/intel-iot-devkit/mraa

_mraa-pwm() {
    local -a sub=(
        'list:list pwm-capable pins'
        'version:print versions'
        'enable:enable pwm output'
        'disable:disable pwm output'
        'period:set pwm period'
        'period_us:set pwm period in microseconds'
        'period_ms:set pwm period in milliseconds'
        'write:write pwm duty cycle as percentage'
        'write_us:write pwm pulse-width in microseconds'
        'write_ms:write pwm pulse-width in milliseconds'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mraa-pwm subcommand' sub ;;
        args)
            case $words[1] in
                enable|disable) _arguments '1:pin:' ;;
                period|period_us|period_ms|write|write_us|write_ms) _arguments '1:pin:' '2:value:' ;;
            esac
            ;;
    esac
}

_mraa-pwm "$@"
