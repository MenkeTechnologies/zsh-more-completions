#compdef lpc21isp
# Documentation: https://manpages.debian.org/testing/lpc21isp/lpc21isp.1.en.html
# In-system programmer for NXP LPC and Analog Devices ARM microcontrollers

local ret=1

_arguments -s -S \
  '-bin[upload binary file]' \
  '-hex[upload file in intel hex format (default)]' \
  '-term[start terminal after upload]' \
  '-termonly[start terminal without an upload]' \
  '-localecho[local echo in terminal]' \
  '-detectonly[detect only used LPC chiptype (PHILIPSARM only)]' \
  '-debug0[no debug]' \
  '-debug3[progress info only]' \
  '-debug5[full debug]' \
  '-donotstart[do not start MCU after download]' \
  '-wipe[erase entire device before upload]' \
  '-control[control RS232 lines for easier booting]' \
  '-controlswap[swap RS232 control lines]' \
  '-controlinv[invert state of RTS & DTR]' \
  '-verify[verify data in flash after writes to sector]' \
  '-logfile[enable logging of terminal output to lpc21isp.log]' \
  '-halfduplex[use halfduplex serial communication]' \
  '-ADARM[download to an Analog Devices ARM microcontroller]' \
  '-PHILIPSARM[download to an NXP LPC13xx/LPC17xx/LPC2000 family]' \
  '*:file:_files' && ret=0

return ret
