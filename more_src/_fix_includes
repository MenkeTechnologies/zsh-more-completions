#compdef fix_includes fix_includes.py
# Documentation: https://include-what-you-use.org/
# Source: include-what-you-use/include-what-you-use fix_includes.py — apply iwyu suggestions (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-b --blank_lines)'{-b,--blank_lines}'[blank line between primary header and others]' \
    '--noblank_lines[no blank lines]' \
    '--comments[put comments after include lines]' \
    '--nocomments[no comments]' \
    '--update_comments[replace why-comments with iwyu output]' \
    '--noupdate_comments[do not update comments]' \
    '--safe_headers[do not remove includes from headers]' \
    '--nosafe_headers[remove unused includes from headers]' \
    '--reorder[reorder lines relative to others]' \
    '--noreorder[do not reorder]' \
    '(-s --sort_only)'{-s,--sort_only}'[only sort includes]' \
    '(-n --dry_run)'{-n,--dry_run}'[show changes without writing]' \
    '(-m --basedir)'{-m+,--basedir=}'[base directory for relative paths]:dir:_files -/' \
    '*--ignore_re=-[ignore filenames matching regex]:regex:_default' \
    '*--only_re=-[only process filenames matching regex]:regex:_default' \
    '--keep_iwyu_namespace_format[keep iwyu nested-namespace format]' \
    '--nokeep_iwyu_namespace_format[disable nested-namespace format]' \
    '--quoted_includes_first[sort quoted includes first]' \
    '(-p --separate_project_includes)'{-p+,--separate_project_includes=}'[project include prefix to separate]:prefix:_default' \
    '*:source file:_files -g "*.{c,cc,cpp,cxx,c++,h,hh,hpp,hxx,h++}"' \
    && ret=0

return ret
