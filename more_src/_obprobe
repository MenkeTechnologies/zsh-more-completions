#compdef obprobe
# Documentation: https://openbabel.org/docs/Command-line_tools.html
# Open Babel: create an electrostatic probe grid around a molecule

local ret=1

_arguments -s -S \
  '-s+[step size]:step size' \
  '-p+[padding]:padding' \
  ':probe MMFF94 atom type:' \
  ":probe partial charge:" \
  ':molecule file:_files' && ret=0

return ret
