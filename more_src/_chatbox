#compdef chatbox chatbox-server
# _chatbox — Chatbox AI chatbox open-source multi-model AI chat client Electron app and CLI (chatboxai team, TypeScript); custom argparse
# upstream: https://github.com/chatboxai/chatbox

_chatbox() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.json *.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.json *.yaml *.yml"' \
        '--user-data-dir=+[user data dir]:dir:_files -/' \
        '--no-sandbox[no sandbox]' \
        '--disable-gpu[disable GPU]' \
        '--enable-features=+[features csv]:str:' \
        '--disable-features=+[features csv]:str:' \
        '--proxy-server=+[proxy URL]:url:_urls' \
        '--proxy-bypass-list=+[hosts csv]:str:' \
        '--lang=+[locale]:str:' \
        '--theme=+[theme]:t:(light dark system)' \
        '--api-host=+[api host]:url:_urls' \
        '--openai-api-key=+[API key]:str:' \
        '--openai-host=+[openai URL]:url:_urls' \
        '--azure-endpoint=+[Azure URL]:url:_urls' \
        '--azure-api-key=+[Azure key]:str:' \
        '--azure-deployment-name=+[deployment]:str:' \
        '--claude-api-key=+[claude key]:str:' \
        '--claude-host=+[claude URL]:url:_urls' \
        '--gemini-api-key=+[gemini key]:str:' \
        '--google-host=+[google URL]:url:_urls' \
        '--ollama-host=+[ollama URL]:url:_urls' \
        '--lm-studio-host=+[lm-studio URL]:url:_urls' \
        '--no-update-check[no update check]' \
        '--auto-update[auto update]' \
        '--debug[debug logs]' \
        '--cli[cli mode]' \
        '--server[server mode]' \
        '--port=+[server port]:port:_ports' \
        '--host=+[server host]:host:_hosts' \
        '--prompt=+[prompt]:str:' \
        '-p+[prompt]:str:' \
        '--model=+[model name]:str:' \
        '-m+[model name]:str:' \
        '--stream[stream output]' \
        '--no-stream[disable streaming]'
}

_chatbox "$@"
