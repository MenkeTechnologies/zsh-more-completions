#compdef attw arethetypeswrong

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-P[use local packed tarball]' \
  '--pack[use local packed tarball]' \
  '-p+[specific entrypoint to check]:entrypoint' \
  '--entrypoints=[specific entrypoints to check]:entrypoints' \
  '--entrypoints-legacy[include legacy entrypoints]' \
  '--include-entrypoints=[entrypoint patterns to include]:patterns' \
  '--exclude-entrypoints=[entrypoint patterns to exclude]:patterns' \
  '--ignore=[problems to ignore]:problems' \
  '-f+[output format]:format:(table json ascii)' \
  '--format=[output format]:format:(table json ascii)' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--quiet[suppress output on success]' \
  '--config-path=[config file]:file:_files' \
  '1:package name or tarball:_files' && ret=0

return ret
