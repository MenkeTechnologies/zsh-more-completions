#compdef gsa
# Documentation: https://man.archlinux.org/search?q=gsa
# Reference accessed: 2026-05-16

# Zxilly/go-size-analyzer — cmd/gsa/command.go (Kong)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  --verbose'[verbose log output]' \
  '(-f)'{-f+,--format=}'[output format]:format:(text json html svg)' \
  --no-disasm'[skip disassembly pass]' \
  --no-symbol'[skip symbol pass]' \
  --no-dwarf'[skip DWARF pass]' \
  --hide-sections'[text: hide sections]' \
  --hide-main'[text: hide main package]' \
  --hide-std'[text: hide stdlib]' \
  --indent='[json: indent depth]:spaces:' \
  --compact'[json: compact overview]' \
  --width='[svg treemap width]:pixels:' \
  --height='[svg treemap height]:pixels:' \
  --margin-box='[svg margin between boxes]:pixels:' \
  --padding-box='[svg inner padding]:pixels:' \
  --padding-root='[svg outer padding]:pixels:' \
  --web'[inspect in browser UI]' \
  --listen='[web listen address]:addr:' \
  --open'[open browser when using --web]' \
  --update-cache'[refresh embedded web UI cache (dev builds)]' \
  --tui'[terminal UI browser]' \
  --imports'[resolve imports from Go source when possible]' \
  '*'{-o+}'[output path or FORMAT=PATH]:output:' \
  --version'[show build version]' \
  '(- *)'{-h,--help}'[Kong help]' \
  '1:binary or prior JSON result:_files' \
  '2::second binary/JSON for diff:_files' && ret=0

return ret
