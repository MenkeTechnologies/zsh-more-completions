#compdef frozen-bubble
# Documentation: https://github.com/kthakore/frozen-bubble
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--fullscreen[fullscreen mode]' \
  '--no-fullscreen[windowed mode]' \
  '--slow-machine[disable some animations]' \
  '--very-slow-machine[disable most animations]' \
  '--no-sound[disable all sound]' \
  '--no-music[disable music only]' \
  '--no-sfx[disable sound effects only]' \
  '--playlist=[custom music playlist]:file or dir:_files' \
  '--toggle-music[toggle music at runtime]' \
  '--toggle-sound[toggle sound at runtime]' \
  '--solo[single-player mode]' \
  '--direct[skip menu, start 2-player game]' \
  '--level=[start at specific level]:n:' \
  '--levelset=[use named levelset]:name:' \
  '--no-time-limit[disable shot timer]' \
  '--chain-reaction[enable chain reactions]' \
  '--no-instant-death[avoid instant-death malus]' \
  '--player-malus=[adjust left player difficulty]:n:' \
  '--mp-training-difficulty=[multiplayer training speed]:n:' \
  '--gameserver=[connect to game server host[:port]]:host:_hosts' \
  '--my-nick=[set player nickname]:nick:' \
  '--private[do not share location data]' \
  '--master-server=[custom master server URL]:url:' \
  '--no-joysticks[disable joystick detection]' \
  '--joysticks-info[display joystick info]' \
  '--record=[set recording directory]:dir:_files -/' \
  '--auto-record[auto-record games]' \
  '--replay=[playback saved game]:file or URL:_files' \
  '--save-frames=[export frames with replay]:dir:_files -/' \
  '--comment=[add metadata to records]:text:' \
  '--colour-blind[use colorblind-friendly bubbles]' \
  '--no-echo[disable typewriter sound feedback]' && ret=0

return ret
