#compdef frozen-bubble
# Documentation: https://man.archlinux.org/search?q=frozen-bubble
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-fullscreen[fullscreen mode]' \
  '-window[windowed]' \
  '-nosound[disable sound]' \
  '-nofx[disable special effects]' \
  '-server+[server name]:host:_hosts' \
  '-port+[server port]:port:' && ret=0

return ret
