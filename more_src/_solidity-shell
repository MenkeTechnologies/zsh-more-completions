#compdef solidity-shell
# Documentation: https://github.com/tintinweb/solidity-shell/blob/master/README.md
# solidity-shell - an interactive Solidity REPL with remote compiler support

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--fork=[fork url for the internal ganache provider]:url:' \
  '*::ganache args:_default' && ret=0

return ret
