#compdef br
# _br — TiDB/TiKV cluster backup-and-restore tool
# upstream: https://github.com/pingcap/tidb
# Subcommands + common flags from br/cmd/br/cmd.go (DefineCommonFlags) on tip.

_br() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-L --log-level)'{-L,--log-level=}'[log level]:level:(debug info warn error fatal)' \
        '--log-file=[log file path]:file:_files' \
        '--log-format=[log format]:fmt:(text json)' \
        '--redact-log[redact sensitive info (deprecated)]' \
        '--redact-info-log[redact sensitive info]' \
        '--status-addr=[status endpoint bind host\:port]:host\:port:' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'backup:back up a TiDB/TiKV cluster'
                'restore:restore a backup into a TiDB/TiKV cluster'
                'stream:point-in-time stream backup'
                'operator:operator subcommands for ongoing tasks'
                'abort:abort an ongoing backup/restore job'
                'debug:debug subcommands'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_br "$@"
