#compdef sfconjgrad
# Documentation: https://github.com/ahay/src/blob/master/system/main/conjgrad.c
# Madagascar: generic conjugate-gradient solver for linear inversion

local ret=1

_arguments -s -S \
  'niter=[number of iterations]:niter' \
  'mod0=[initial model file]:mod0:_files' \
  'mwt=[model weight file]:mwt:_files' \
  'known=[known model mask file]:known:_files' \
  '*:RSF file:_files' && ret=0

return ret
