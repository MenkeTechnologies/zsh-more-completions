#compdef gator
# Documentation: https://man.archlinux.org/search?q=gator
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'verify:verify resources against constraints'
      'expand:expand mutating policies'
      'test:run gator test suite'
      'version:print version'
    )
    _describe -t commands 'gator command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      verify)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --filename)'{-f,--filename}'=[manifest file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output format]:format:(text json)' \
          '*: : _default' \
          && ret=0
        ;;
      expand|test)
        _arguments -s -S '*: : _default' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
