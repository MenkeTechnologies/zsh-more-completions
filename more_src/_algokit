#compdef algokit

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new project'
  'bootstrap:bootstrap project dependencies'
  'build:build project'
  'deploy:deploy smart contracts'
  'explore:explore Algorand network'
  'generate:generate code from templates'
  'goal:run goal commands against local sandbox'
  'localnet:manage local Algorand network'
  'doctor:check development environment'
  'compile:compile TEAL or smart contracts'
  'dispenser:interact with the TestNet dispenser'
  'task:run operational tasks'
  'project:manage AlgoKit projects'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'algokit command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '-n+[project name]:name' \
          '--name=[project name]:name' \
          '-t+[template name]:template:(python fullstack beaker react playground tealscript)' \
          '--template=[template name]:template:(python fullstack beaker react playground tealscript)' \
          '--template-url=[template URL]:url' \
          '--UNSAFE-SECURITY-accept-template-url[accept any template URL]' \
          '--defaults[use defaults for all prompts]' \
          '--bootstrap[auto-bootstrap after init]' \
          '--no-bootstrap[skip bootstrap after init]' \
          '--git[initialize git repository]' \
          '--no-git[skip git initialization]' \
          '--ide[open in IDE after init]' \
          '--no-ide[do not open in IDE]' \
          '1:directory:_directories' && ret=0
        ;;
      (localnet)
        local -a localnet_cmds=(
          'start:start local network'
          'stop:stop local network'
          'reset:reset local network'
          'status:show network status'
          'explore:open network explorer'
          'console:open Algorand console'
          'logs:view network logs'
        )
        _arguments '1:localnet command:_describe -t localnet-cmds "localnet command" localnet_cmds' && ret=0
        ;;
      (bootstrap)
        local -a bootstrap_cmds=(
          'all:bootstrap all dependencies'
          'env:set up environment'
          'poetry:install poetry dependencies'
          'npm:install npm dependencies'
        )
        _arguments '1:bootstrap command:_describe -t bootstrap-cmds "bootstrap command" bootstrap_cmds' && ret=0
        ;;
      (deploy)
        _arguments \
          '-C+[project directory]:directory:_directories' \
          '--command=[custom deploy command]:command' \
          '--environment=[deployment environment]:environment' && ret=0
        ;;
      (dispenser)
        local -a dispenser_cmds=(
          'fund:fund an account from dispenser'
          'login:login to dispenser'
          'logout:logout from dispenser'
          'refund:refund to dispenser'
          'limit:show funding limits'
        )
        _arguments '1:dispenser command:_describe -t dispenser-cmds "dispenser command" dispenser_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
