#compdef tuir

_arguments -s \
  '(-s --subreddit)'{-s,--subreddit=}'[start subreddit]:name:' \
  '--log=[log HTTP requests]:file:_files' \
  '--config=[config file]:file:_files' \
  '--ascii[ASCII-only mode]' \
  '--monochrome[disable color]' \
  '--theme=[color theme]:theme:' \
  '--list-themes[list themes]' \
  '--non-persistent[forget user on exit]' \
  '--no-autologin[skip auto-auth]' \
  '--clear-auth[remove saved user data]' \
  '--copy-config[copy default config]' \
  '--copy-mailcap[copy example mailcap]' \
  '--enable-media[enable mailcap media]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-flash[disable screen flashing]' \
  '--debug-info[print debug info]' \
  '(- *)'{-h,--help}'[show help]' \
  ':link:'
