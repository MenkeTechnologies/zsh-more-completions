#compdef tuir
# Documentation: https://gitlab.com/ajak/tuir
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: tuir README and manpage not retrievable via WebFetch (404/auth-required);
# avoiding fabrication of flags from prior unverified content.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:link:_message "Reddit URL"' && ret=0
return ret
