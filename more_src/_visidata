#compdef visidata vd
# Documentation: https://www.visidata.org/docs/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and saulpw/visidata
# visidata/main.py + visidata/loaders/*.py master source. VisiData parses
# any `--<vd.option>` registered via vd.option(); only verified options
# and their CLI aliases are listed here.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(-f --filetype)'{-f+,--filetype=}'[force file type (overrides extension)]:filetype:' \
  '(-p --play)'{-p+,--play=}'[replay cmdlog (.vd / .vdj)]:file:_files' \
  '(-b --batch)'{-b,--batch}'[replay in batch mode without UI]' \
  '(-o --output)'{-o+,--output=}'[save final visible sheet to file]:file:_files' \
  '(-O --output_cell)'{-O+,--output_cell=}'[output cursor cell value at exit]:file:_files' \
  '(-P --preplay)'{-P+,--preplay=}'[longnames to preplay before replay]:names:' \
  '(-w --replay_wait)'{-w+,--replay_wait=}'[seconds to wait between replay steps]:secs:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-d --delimiter)'{-d+,--delimiter=}'[default delimiter]:char:' \
  '(-i --interactive)'{-i,--interactive}'[run interactive mode after batch replay]' \
  '(-N --nothing)'{-N,--nothing}'[no config, no plugins, no extra]' \
  '(-g --global)'{-g,--global}'[apply following options globally]' \
  '(-n --nonglobal)'{-n,--nonglobal}'[apply following options to next sheet only]' \
  '--imports=[modules to preload before .visidatarc]:names:' \
  '--s3_anon[run S3 in anonymous mode]' \
  '--debug[exit on error and display stacktrace]' \
  '--profile[enable cProfile profiling]' \
  '--skip=[skip N rows before header]:n:' \
  '--header=[number of header rows]:n:' \
  '--null_value=[value counted as null]:string:' \
  '--safe_error=[error placeholder string]:string:' \
  '--csv_dialect=[csv dialect]:dialect:(excel excel-tab unix)' \
  '--csv_delimiter=[csv delimiter]:char:' \
  '--csv_quotechar=[csv quote character]:char:' \
  '--csv_skipinitialspace[skip whitespace after delimiter]' \
  '--json_indent=[json indent for save]:n:' \
  '*:file:_files'
