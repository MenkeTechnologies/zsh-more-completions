#compdef phoenix-psql phoenix.psql
# Documentation: https://phoenix.apache.org/bulk_dataload.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-t+[target table name]:table:' \
  '-h+[CSV column header override or in-line]:header:' \
  '-d+[CSV delimiter]:char:' \
  '-q+[phrase delimiter (default double-quote)]:char:' \
  '-e+[escape character (default backslash)]:char:' \
  '-a+[array delimiter]:char:' \
  '-s[strict mode - error on parse failure]' \
  '1:zookeeper:_hosts' \
  '*:SQL/CSV file:_files -g "*.(sql|csv)"' && ret=0

return ret
