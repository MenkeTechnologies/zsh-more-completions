#compdef phoenix-psql phoenix.psql

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-t+[target table name]:table:' \
  '-h+[header (comma-separated columns or in-line)]:header:' \
  '-d+[delimiter]:char:' \
  '-q+[character used to quote]:char:' \
  '-e+[escape character]:char:' \
  '-a+[array delimiter]:char:' \
  '-s[strict mode (fail on errors)]' \
  '-b+[bulk load batch size]:n:' \
  '1:zookeeper:_hosts' \
  '*:SQL/CSV file:_files -g "*.(sql|csv)"' && ret=0

return ret
