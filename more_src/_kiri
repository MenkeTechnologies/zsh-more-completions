#compdef kiri
# Documentation: https://docs.grid.space/kiri-moto/apis/
# Kiri:Moto CLI slicer engine (FDM/CAM/laser)

local ret=1

_arguments -s -S \
  '--verbose[enable verbose logging]' \
  '--dir=[root directory for file paths]:dir:_files -/' \
  '--model=[model file to load]:model:_files -g "*.(stl|STL|obj|OBJ)"' \
  '--source=[source file list]:source:_files' \
  '--device=[device definition file (json)]:device:_files -g "*.json"' \
  '--process=[process definition file (json)]:process:_files -g "*.json"' \
  '--controller=[controller definition file (json)]:controller:_files -g "*.json"' \
  '--output=[gcode output file or - for stdout]:output:_files' \
  '--position=[move model to position x,y,z]:position:' \
  '--rotate=[rotate model in radians x,y,z]:rotate:' \
  '--scale=[scale model x,y,z]:scale:' \
  '--move=[move model in millimeters x,y,z]:move:' \
  '*:model file:_files -g "*.(stl|STL|obj|OBJ)"' && ret=0

return ret
