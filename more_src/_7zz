#compdef 7zz 7zip

# Zsh completion for 7-Zip (official Linux build)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'a:add files to archive'
  'b:benchmark'
  'd:delete files from archive'
  'e:extract files from archive (without paths)'
  'h:calculate hash values'
  'i:show information about supported formats'
  'l:list contents of archive'
  'rn:rename files in archive'
  't:test integrity of archive'
  'u:update files in archive'
  'x:extract files with full paths'
)

_arguments -s -S \
  '1:command:->command' \
  '-ai+[include archives]:archive filter:' \
  '-ax+[exclude archives]:archive filter:' \
  '-ao+[set overwrite mode]:overwrite mode:(a s t u)' \
  '-an[disable archive_name field]' \
  '-bb+[set output log level]:level:(0 1 2 3)' \
  '-bd[disable progress indicator]' \
  '-bs+[set output stream]:stream config:' \
  '-bt[show execution time statistics]' \
  '-i+[include filenames]:filter:' \
  '-m+[set compression method]:parameters:' \
  '-mmt+[number of CPU threads]:threads:' \
  '-mx+[compression level]:level:(0 1 3 5 7 9)' \
  '-o+[output directory]:directory:_files -/' \
  '-p+[set password]:password:' \
  '-r-[recurse subdirectories]:mode:(- 0)' \
  '-sa+[archive name mode]:mode:(a e s)' \
  '-scc+[charset for console]:charset:(UTF-8 WIN DOS)' \
  '-scs+[charset for list files]:charset:(UTF-8 UTF-16LE UTF-16BE WIN DOS)' \
  '-scrc+[hash function]:hash:(CRC32 CRC64 SHA1 SHA256 XXH64 BLAKE2sp)' \
  '-sdel[delete files after compression]' \
  '-sfx+[create SFX archive]:module:_files' \
  '-si+[read from stdin]:stream name:' \
  '-slp[set large pages mode]' \
  '-slt[show technical info (for l command)]' \
  '-snh[store hard links as links]' \
  '-snl[store symbolic links as links]' \
  '-so[write to stdout]' \
  '-spd[disable wildcard matching]' \
  '-spe[eliminate root folder duplication]' \
  '-spf[use fully qualified file paths]' \
  '-ssc-[sensitive case mode]:mode:(- "")' \
  '-ssw[compress shared files]' \
  '-stl[set archive timestamp from newest file]' \
  '-t+[archive type]:type:(7z zip gzip bzip2 xz lzma tar cab iso wim zstd)' \
  '-v+[create volumes]:volume size:' \
  '-w+[work directory]:directory:_files -/' \
  '-x+[exclude filenames]:filter:' \
  '-y[assume Yes on all queries]' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
