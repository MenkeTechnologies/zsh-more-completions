#compdef nfs-ganesha

# NFS-Ganesha: user-space NFS server (FSAL plugins for various backends)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-L[log file]:file:_files' \
  '-N[NFS log severity level]:level:(NIV_NULL NIV_FATAL NIV_MAJ NIV_CRIT NIV_WARN NIV_EVENT NIV_INFO NIV_DEBUG NIV_MID_DEBUG NIV_FULL_DEBUG)' \
  '-f[config file]:file:_files' \
  '-p[PID file]:file:_files' \
  '-d[debug mode (foreground)]' \
  '-F[run in foreground]' \
  '-R[remove all entries from cache and restart]' \
  '-T[run all tests and exit]' \
  '-E[explicitly export FSAL]:fsal:' \
  '-x[lock memory pages]' \
  '*::ganesha args:_files' && ret=0
return ret
