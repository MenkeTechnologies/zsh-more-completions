#compdef ganesha.nfsd nfs-ganesha
# Documentation: https://github.com/nfs-ganesha/nfs-ganesha
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; flags cross-checked against
# NFS-Ganesha wiki tutorial and Debian ganesha.nfsd usage examples.

# nfs-ganesha userspace NFS server daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-L[set log file]:file:_files' \
  '-N[set log level]:level:(NIV_NULL NIV_FATAL NIV_MAJ NIV_CRIT NIV_WARN NIV_EVENT NIV_INFO NIV_DEBUG NIV_MID_DEBUG NIV_FULL_DEBUG)' \
  '-f[config file]:file:_files -g "*.conf"' \
  '-p[PID file]:file:_files' \
  '-d[run in detached/daemon mode]' \
  '-F[run in foreground]' \
  '-T[dump config and exit]' \
  '-E[set epoch]:epoch:' \
  '-R[reload config on SIGHUP]' \
  '*::nfs-ganesha args:_files' && ret=0
return ret
