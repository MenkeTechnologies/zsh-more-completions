#compdef rpm-cli
# _rpm-cli — RPM Package Manager CLI alias (RPM project / Red Hat, C); custom argparse
# upstream: https://github.com/rpm-software-management/rpm

_rpm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i[install]' \
        '--install[install]' \
        '-U[upgrade/install]' \
        '--upgrade[upgrade/install]' \
        '-F[freshen only if older installed]' \
        '--freshen[freshen only if older installed]' \
        '-e[erase]' \
        '--erase[erase]' \
        '-q[query]' \
        '--query[query]' \
        '-K[verify package signature]' \
        '-V[verify installed package]' \
        '--verify[verify installed package]' \
        '--checksig[verify package signature]' \
        '--addsign[add signature]' \
        '--delsign[delete signature]' \
        '--initdb[initialize db]' \
        '--rebuilddb[rebuild db]' \
        '--showrc[show rpmrc]' \
        '--whatprovides=+[what provides]:str:' \
        '--whatrequires=+[what requires]:str:' \
        '-l[list package files]' \
        '-c[list config files]' \
        '-d[list doc files]' \
        '-L[show licenses]' \
        '-a[query all installed]' \
        '--all[query all installed]' \
        '-f[query file owner]' \
        '--file[query file owner]' \
        '-p[query package file]' \
        '--package[query package file]' \
        '--specfile[query spec file]' \
        '--queryformat=+[format string]:str:' \
        '--qf=+[format string]:str:' \
        '-R[show requires]' \
        '--requires[show requires]' \
        '--provides[show provides]' \
        '--scripts[show scripts]' \
        '--triggers[show triggers]' \
        '--changelog[show changelog]' \
        '--info[show info]' \
        '-i[show info]' \
        '--last[order by install time]' \
        '--list[list package files]' \
        '--dump[show file details]' \
        '--prefix=+[prefix]:dir:_files -/' \
        '--root=+[root]:dir:_files -/' \
        '-r+[root]:dir:_files -/' \
        '--dbpath=+[db path]:dir:_files -/' \
        '--macros=+[macros]:file:_files' \
        '--rcfile=+[rc file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--nodigest[no digest]' \
        '--nosignature[no signature]' \
        '--nodeps[no deps]' \
        '--nofiledigest[no file digest]' \
        '--nocontexts[no contexts]' \
        '--nocaps[no caps]' \
        '--nofiles[no files]' \
        '--allmatches[remove all matches]' \
        '--justdb[only db update]' \
        '--notriggers[no triggers]' \
        '--noscripts[no scripts]' \
        '--repackage[repackage]' \
        '--test[test]' \
        '--force[force]' \
        '--replacefiles[replace files]' \
        '--replacepkgs[replace packages]' \
        '--ignoresize[ignore size]' \
        '--ignorearch[ignore arch]' \
        '--ignoreos[ignore os]' \
        '--badreloc[bad reloc]' \
        '--noorder[no order]' \
        '--hash[hash]' \
        '--percent[percent]' \
        '--erase[erase]' \
        '*:package:_files -g "*.rpm"'
}

_rpm-cli "$@"
