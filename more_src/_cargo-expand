#compdef cargo-expand

# Zsh completion for cargo-expand - show result of macro expansion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--lib[expand only the lib target]' \
  '--bin=[expand only the specified binary]:binary' \
  '--example=[expand only the specified example]:example' \
  '--test=[expand only the specified test]:test' \
  '--bench=[expand only the specified benchmark]:benchmark' \
  '--ugly[do not attempt to run rustfmt]' \
  '--theme=[set syntax highlighting theme]:theme' \
  '--themes[print available syntax highlighting themes]' \
  '--color=[control color output]:when:(auto always never)' \
  '(-p --package)'{-p,--package}'[package to expand]:package' \
  '--features=[space or comma separated list of features to activate]:features' \
  '--all-features[activate all available features]' \
  '--no-default-features[do not activate the default feature]' \
  '--target=[target triple]:target' \
  '--target-dir=[directory for build artifacts]:directory:_files -/' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
  '--profile=[build with specified profile]:profile:(dev release test bench)' \
  '--release[build in release mode]' \
  '--verbose[use verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:item path' && ret=0

return ret
