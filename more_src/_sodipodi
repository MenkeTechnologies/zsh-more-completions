#compdef sodipodi
# Documentation: https://man.archlinux.org/search?q=sodipodi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --export-area)'{-a,--export-area}'+[export area x0\:y0\:x1\:y1]:area:' \
  '(-A --export-area-page)'{-A,--export-area-page}'[export the page]' \
  '(-D --export-area-drawing)'{-D,--export-area-drawing}'[export the drawing]' \
  '(-b --export-background)'{-b,--export-background}'+[bg color]:color:' \
  '(-y --export-background-opacity)'{-y,--export-background-opacity}'+[bg opacity]:opacity:' \
  '(-d --export-dpi)'{-d,--export-dpi}'+[export DPI]:dpi:' \
  '(-w --export-width)'{-w,--export-width}'+[export width]:px:' \
  '(-h --export-height)'{-h,--export-height}'+[export height]:px:' \
  '(-e --export-png)'{-e,--export-png}'+[export PNG]:file:_files' \
  '(-E --export-eps)'{-E,--export-eps}'+[export EPS]:file:_files' \
  '(-l --export-plain-svg)'{-l,--export-plain-svg}'+[export plain SVG]:file:_files' \
  '(-z --without-gui)'{-z,--without-gui}'[run without GUI]' \
  '*:file:_files -g "*.{svg,svgz}"' && ret=0

return ret
