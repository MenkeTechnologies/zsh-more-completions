#compdef integrit
# Documentation: https://manpages.debian.org/bookworm/integrit/integrit.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm integrit(1) manpage. Short-flag-only; no long
# forms.

# integrit: file integrity verification (tripwire-like)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[configuration file]:file:_files' \
  '-V[show version]' \
  '-h[show brief help]' \
  '-x[XML output]' \
  '-u[do update - create new database snapshot]' \
  '-c[do check - compare current state to database]' \
  '-N[new database override]:file:_files' \
  '-O[old database override]:file:_files' \
  '-q[lower verbosity]' \
  '-v[increase verbosity]' && ret=0
return ret
