#compdef octopress
# Documentation: https://github.com/octopress/octopress/blob/master/README.md
# Octopress blogging framework for Jekyll

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--force[overwrite existing files]' \
  '--template=[template path]:path:_files' \
  '--date=[publish date]:date:' \
  '--slug=[post slug]:slug:' \
  '--dir=[target directory]:dir:_files -/' \
  '--title=[page title]:title:' \
  '--config=[deploy config file]:file:_files' \
  '1:command:(init new publish unpublish isolate integrate deploy)' \
  '*::arg:_files' && ret=0

return ret
