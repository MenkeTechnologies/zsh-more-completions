#compdef bridgetown-cli bridgetown
# _bridgetown-cli — Jared White Bridgetown progressive Ruby SSG CLI alias (bridgetownrb team, Ruby); thor
# upstream: https://github.com/bridgetownrb/bridgetown

_bridgetown-cli() {
    local -a sub=(
        'new:create new bridgetown site'
        'build:build the site'
        'serve:serve the site'
        'start:run dev server with frontend bundler'
        'console:start a console session'
        'apply:apply automation'
        'configure:configure bridgetown bundles'
        'plugins:list:list plugins'
        'plugins:cd:cd into plugin'
        'plugins:cd-internal:cd into internal plugin'
        'plugins:list-source-manifests:list source manifests'
        'webpack:install webpack frontend bundler'
        'esbuild:install esbuild frontend bundler'
        'clean:clean build artifacts'
        'docs:open documentation'
        'help:show help'
        'version:show version'
        'doctor:run doctor diagnostics'
        'deploy:deploy site'
        'tilt:tiltfile commands'
        'migrate:from-jekyll:migrate jekyll site'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bridgetown subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:path:_files -/' \
                    '--apply=+[automation url]:url:_urls' \
                    '-A+[automation url]:url:_urls' \
                    '--force[force overwrite]' \
                    '-f[force overwrite]' \
                    '--skip-bundle[skip bundle install]' \
                    '-B[skip bundle install]' \
                    '--skip-yarn[skip yarn install]' \
                    '-N[skip yarn install]' \
                    '--frontend-bundling-solution=+[bundler]:b:(esbuild webpack vite)' \
                    '-e+[bundler]:b:(esbuild webpack vite)' \
                    '--templates=+[template engine]:t:(erb liquid serbea)' \
                    '-t+[template engine]:t:(erb liquid serbea)' ;;
                build|serve|start) _arguments \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--config=+[config file]:file:_files -g "bridgetown.config.{yml,yaml,toml}"' \
                    '-c+[config file]:file:_files -g "bridgetown.config.{yml,yaml,toml}"' \
                    '--source=+[source dir]:dir:_files -/' \
                    '-s+[source dir]:dir:_files -/' \
                    '--destination=+[destination dir]:dir:_files -/' \
                    '-d+[destination dir]:dir:_files -/' \
                    '--baseurl=+[base url]:str:' \
                    '-b+[base url]:str:' \
                    '--port=+[port]:port:' \
                    '-P+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--bind=+[bind]:str:' \
                    '--ssl-cert=+[ssl cert]:file:_files' \
                    '--ssl-key=+[ssl key]:file:_files' \
                    '--livereload[livereload]' \
                    '-L[livereload]' \
                    '--no-livereload[no livereload]' \
                    '--show-dir-listing[show directory listing]' \
                    '--unpublished[render unpublished]' \
                    '-U[render unpublished]' \
                    '--future[render future-dated posts]' \
                    '--profile[profile build]' \
                    '--trace[show trace]' \
                    '-t[show trace]' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--verbose[verbose]' \
                    '-V[verbose]' ;;
                apply) _arguments '1:automation:' '--swap-current-directory[swap dir]' ;;
                console) _arguments '--verbose[verbose]' '-V[verbose]' '--config=+[config file]:file:_files' ;;
            esac
            ;;
    esac
}

_bridgetown-cli "$@"
