#compdef meg

local -a arguments

arguments=(
  '-c[concurrency level]:concurrency:'
  '-d[delay between requests in ms]:delay:'
  '-H[custom header]:header:'
  '-r[save raw HTTP response]'
  '-s[save only responses with specified status code]:status code:'
  '-v[verbose output]'
  '-X[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)'
  '1:path or paths file:_files'
  '2:host or hosts file:_files'
  '3:output directory:_files -/'
)

_arguments -s -S $arguments
