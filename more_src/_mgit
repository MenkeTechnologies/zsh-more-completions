#compdef mgit
# Documentation: https://github.com/decafjoe/mgit
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: multiple unrelated tools are named "mgit" (decafjoe, marcelfw, jonaz,
# genocem, cattingcat). Flags differ wildly; provide only generic completion.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file or directory]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'config:print configuration as interpreted by mgit'
      'help:print help message or help for given subcommand'
      'pull:fetch from remotes and fast-forward tracking branches'
      'status:print current status of repositories'
    )
    _describe -t commands 'mgit commands' commands && ret=0
    ;;
esac

return ret
