#compdef mgit

# Zsh completion for mgit - multi-repo git tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-j[number of parallel jobs]:jobs:' \
  '--jobs=[number of parallel jobs]:jobs:' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'branch:show or create branches'
      'checkout:checkout branch in all repos'
      'clone:clone all repos'
      'commit:commit in all repos'
      'diff:show diff in all repos'
      'fetch:fetch all repos'
      'grep:grep in all repos'
      'init:initialize mgit configuration'
      'log:show log in all repos'
      'merge:merge in all repos'
      'pull:pull all repos'
      'push:push all repos'
      'rebase:rebase all repos'
      'remote:manage remotes in all repos'
      'stash:stash in all repos'
      'status:show status of all repos'
      'tag:manage tags in all repos'
    )
    _describe -t commands 'mgit commands' commands && ret=0
    ;;
esac

return ret
