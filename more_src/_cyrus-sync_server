#compdef cyrus-sync_server
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/sync_server.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org sync_server(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-sync_server: Cyrus mailstore replication server process
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-p[external SSF security strength factor]:ssf:' && ret=0
return ret
