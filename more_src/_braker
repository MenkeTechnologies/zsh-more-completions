#compdef braker braker.pl braker2 braker3 braker2.pl braker3.pl
# _braker — Katharina Hoff Lars Gabriel BRAKER pipeline for eukaryotic gene prediction combining GeneMark Augustus and TSEBRA (Gaius-Augustus team, Perl); custom argparse
# upstream: https://github.com/Gaius-Augustus/BRAKER

_braker() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--genome=+[genome fasta]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
        '--species=+[species]:str:' \
        '--bam=+[bam file csv]:str:' \
        '--prot_seq=+[protein fasta csv]:str:' \
        '--prot_aln=+[protein alignments csv]:str:' \
        '--hints=+[hints file]:file:_files' \
        '--rnaseq_sets_ids=+[ids csv]:str:' \
        '--rnaseq_sets_dirs=+[dirs csv]:str:' \
        '--workingdir=+[work dir]:dir:_files -/' \
        '--cores=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--epmode[evidence-prefer mode]' \
        '--esmode[ES mode]' \
        '--etpmode[ETP mode]' \
        '--gff3[GFF3 output]' \
        '--makehub[make UCSC track hub]' \
        '--email=+[email]:str:' \
        '--addUTR=+[bool]:b:(on off)' \
        '--useexisting[use existing parameters]' \
        '--gm_max_intergenic=+[N]:n:' \
        '--min_contig=+[N]:n:' \
        '--filterOutShort[filter out short]' \
        '--alternatives-from-evidence=+[bool]:b:(true false)' \
        '--softmasking[softmasking]' \
        '--AUGUSTUS_CONFIG_PATH=+[dir]:dir:_files -/' \
        '--AUGUSTUS_BIN_PATH=+[dir]:dir:_files -/' \
        '--AUGUSTUS_SCRIPTS_PATH=+[dir]:dir:_files -/' \
        '--GENEMARK_PATH=+[dir]:dir:_files -/' \
        '--PROTHINT_PATH=+[dir]:dir:_files -/' \
        '--TSEBRA_PATH=+[dir]:dir:_files -/' \
        '--BAMTOOLS_PATH=+[dir]:dir:_files -/' \
        '--SAMTOOLS_PATH=+[dir]:dir:_files -/' \
        '--DIAMOND_PATH=+[dir]:dir:_files -/' \
        '--JAVA_PATH=+[dir]:dir:_files -/' \
        '--GUSHR_PATH=+[dir]:dir:_files -/' \
        '--rounds=+[N]:n:' \
        '--testMode[test mode]' \
        '--verbosity=+[level]:n:' \
        '--skipAllTraining[skip all training]' \
        '--skipGetAnnoFromFasta[skip getAnnoFromFasta]' \
        '--skipOptimize[skip optimize]' \
        '--skipIterativePrediction[skip iterative prediction]' \
        '--skip_fixing_broken_genes[skip fixing broken genes]'
}

_braker "$@"
