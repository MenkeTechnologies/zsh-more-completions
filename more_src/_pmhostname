#compdef pmhostname
# _pmhostname — print canonical hostname or PMAPI resolution for a host (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmhostname/pmhostname.c (pmgetopt opts).

_pmhostname() {
    _arguments \
        '(- *)-?[show help]' \
        '-D+[debug specification]:spec:' \
        '1:hostname:_hosts'
}

_pmhostname "$@"
