#compdef create-api
# Documentation: https://github.com/CreateAPI/CreateAPI
# Reference accessed: 2026-05-17
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)'{-h,--help}'[help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a subcmd=(
      'generate:generate Swift from an OpenAPI spec'
    )
    _describe -t commands 'create-api command' subcmd && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[help]' \
          '--output=[output directory]:directory:_files -/' \
          '--config=[generator YAML/JSON config]:file:_files' \
          '*--config-option=[option override key=value]:override:' \
          {-v,--verbose}'[verbose logs]' \
          '--watch[watch input for changes and regenerate]' \
          '--strict[treat warnings as errors]' \
          '--allow-errors[continue after generation errors]' \
          {-c,--clean}'[remove output directory before write]' \
          '--single-threaded[disable parallel parsing]' \
          '--measure[log per-operation timings]' \
          '1:OpenAPI spec:_files' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
