#compdef create-api
# Documentation: https://man.archlinux.org/search?q=create-api
# Reference accessed: 2026-05-16

# CreateAPI/CreateAPI — ArgumentParser (CreateAPI.swift + Generate.swift)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)'{-h,--help}'[help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a subcmd=(
      'generate:generate Swift from an OpenAPI spec'
    )
    _describe -t commands 'create-api command' subcmd && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[help]' \
          '--output=[output directory]:directory:_files -/' \
          '--config=[generator YAML/JSON config]:config file:_files' \
          '*'--config-option='[option override key=value]:override:' \
          {-v,--verbose}'[verbose logs]' \
          --strict'[treat warnings as errors]' \
          --allow-errors'[continue after generation errors]' \
          {-c,--clean}'[remove output directory before write]' \
          --single-threaded'[disable parallel parsing]' \
          --measure'[log per-operation timings]' \
          '1:OpenAPI spec:_files' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
