#compdef qwik
# Documentation: https://github.com/QwikDev/qwik/blob/main/packages/qwik/src/cli/run.ts
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for qwik - Qwik framework CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'add:Add an integration to this app'
      'build:Parallelize builds and type checking'
      'new:Create a new component or route'
      'check-client:Verify client bundle matches source'
      'joke:Tell a random dad joke'
      'migrate-v2:Rescope app from @builder.io/* to @qwik.dev/*'
      'help:Display help'
      'version:Show the version number'
    )
    _describe -t commands 'qwik commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      add)
        _arguments -s -S \
          '--help[show help]' \
          '1:integration:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--help[show help]' \
          '1:variant:(preview)' && ret=0
        ;;
      new)
        _arguments -s -S \
          '--help[show help]' \
          '1:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
