#compdef qwik

# Zsh completion for qwik - Qwik framework CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '--force[force operation]' \
  '--install[install dependencies]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'add:Add an integration'
      'build:Build the application'
      'new:Create a new project'
      'dev:Start development server'
    )
    _describe -t commands 'qwik commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      add)
        _arguments -s -S \
          '--help[show help]' \
          '--force[force overwrite]' \
          '--install[install dependencies]' \
          '1:integration:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--help[show help]' && ret=0
        ;;
      new)
        _arguments -s -S \
          '--help[show help]' \
          '--force[force overwrite existing files]' \
          '--install[install dependencies]' \
          '1:project name:' && ret=0
        ;;
      dev)
        _arguments -s -S \
          '--help[show help]' \
          '--port[port to listen on]:port:' \
          '--host[host to bind to]:host:' && ret=0
        ;;
    esac
    ;;
esac

return ret
