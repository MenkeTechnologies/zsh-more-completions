#compdef tfsort
# Documentation: https://man.archlinux.org/search?q=tfsort
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-f --file)'{-f,--file}'=[Terraform file path]:file:_files -g "*.tf(-.)"' \
  '(-r --recursive)'{-r,--recursive}'[Sort .tf files under directory]' \
  '-dry-run[Print result without writing]' \
  '*:paths:_files -g "*.tf(-.)"'
