#compdef ValidateVariants
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/variantutils/ValidateVariants.java
# Validate VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--validation-type-to-exclude -Xtype)'{--validation-type-to-exclude,-Xtype}'[which validation type to exclude from a full strict validation]:value:' \
  '--do-not-validate-filtered-records[skip validation on filtered records]' \
  '--warn-on-errors[just emit warnings on errors instead of terminating the run at the first instance]' \
  '(--validate-GVCF -gvcf)'{--validate-GVCF,-gvcf}'[Validate this file as a GVCF]' \
  '(--fail-gvcf-on-overlap -no-overlaps)'{--fail-gvcf-on-overlap,-no-overlaps}'[Fail if GVCF contains positions that overlap (except two variants overlapping)]' \
  '*:argument:_files' && ret=0

return ret
