#compdef glyr

# Zsh completion for glyr metadata CLI (sahib/glyr)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1:getter:->g' \
  '*::args:->args' && ret=0

case $state in
  g)
    local -a getters=(
      cover lyrics ainfo similphotos photos review biography vendor
      albums related artisturl tracklist events chart webfetch
    )
    _describe -t getters 'glyr getter' getters && ret=0
    ;;
  args)
    _message "URLs or artist/album strings; see glyr --help"
    ret=0
    ;;
esac

return ret
