#compdef gobgp

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'global:global config and state'
  'neighbor:BGP peer operations'
  'vrf:VRF operations'
  'policy:routing policy operations'
  'monitor:monitor BGP events'
  'mrt:MRT format operations'
  'rpki:RPKI operations'
  'bmp:BMP server operations'
  'log-level:set or show log level'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --host)'{-u,--host=}'[gobgpd host]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[gobgpd port]:port:' \
  '--target=[target name]:target:' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-c --gen-cmpl)'{-c,--gen-cmpl}'[generate completion script]' \
  '--bash-cmpl-file=[bash completion file]:file:_files' \
  '(-r --pprof-port)'{-r,--pprof-port=}'[pprof port]:port:' \
  '--tls[use TLS]' \
  '--tls-client-cert-file=[TLS client cert]:file:_files' \
  '--tls-client-key-file=[TLS client key]:file:_files' \
  '--tls-ca-file=[TLS CA file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'gobgp subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (neighbor)
        _values 'neighbor action' \
          'add' 'del' 'all' 'local' 'adj-in' 'adj-out' 'reset' 'softreset' \
          'softresetin' 'softresetout' 'shutdown' 'enable' 'disable' \
          'summary' 'update' 'accepted' 'rejected' && ret=0
        ;;
      (global)
        _values 'global action' \
          'rib' 'as' 'router-id' 'set' 'add' 'del' && ret=0
        ;;
      (vrf)
        _values 'vrf action' 'add' 'del' 'all' && ret=0
        ;;
      (policy)
        _values 'policy action' \
          'add' 'del' 'all' 'set' \
          'prefix' 'neighbor' 'as-path' 'community' 'ext-community' 'large-community' \
          'statement' 'condition' 'action' && ret=0
        ;;
      (mrt)
        _values 'mrt action' 'inject' 'dump' && ret=0
        ;;
      (rpki)
        _values 'rpki action' 'server' 'table' && ret=0
        ;;
      (bmp)
        _values 'bmp action' 'add' 'del' 'all' && ret=0
        ;;
      (log-level)
        _values 'log level' 'panic' 'fatal' 'error' 'warn' 'info' 'debug' 'trace' && ret=0
        ;;
    esac
    ;;
esac

return ret
