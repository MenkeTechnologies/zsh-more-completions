autoload -U is-at-least

_tmux-backup() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-d+[Location of backups]:BACKUP_DIRPATH:_files -/' \
'--dirpath=[Location of backups]:BACKUP_DIRPATH:_files -/' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tmux-backup_commands" \
"*::: :->tmux-backup" \
&& ret=0
    case $state in
    (tmux-backup)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tmux-backup-command-$line[1]:"
        case $line[1] in
            (save)
_arguments "${_arguments_options[@]}" : \
'-s+[]:STRATEGY:((most-recent\:"Apply a most-recent strategy, keeping only n backups"
classic\:"Apply a classic backup strategy"))' \
'--strategy=[]:STRATEGY:((most-recent\:"Apply a most-recent strategy, keeping only n backups"
classic\:"Apply a classic backup strategy"))' \
'-n+[Number of recent backups to keep, for instance 10]:NUMBER:_default' \
'--num-backups=[Number of recent backups to keep, for instance 10]:NUMBER:_default' \
'-i+[Number of lines to ignore during capture if the active command is a shell]:NUMBER:_default' \
'--ignore-last-lines=[Number of lines to ignore during capture if the active command is a shell]:NUMBER:_default' \
'--to-tmux[Print a one-line report in the Tmux status bar, otherwise print to stdout]' \
'--compact[Delete purgeable backups after saving]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(restore)
_arguments "${_arguments_options[@]}" : \
'-s+[]:STRATEGY:((most-recent\:"Apply a most-recent strategy, keeping only n backups"
classic\:"Apply a classic backup strategy"))' \
'--strategy=[]:STRATEGY:((most-recent\:"Apply a most-recent strategy, keeping only n backups"
classic\:"Apply a classic backup strategy"))' \
'-n+[Number of recent backups to keep, for instance 10]:NUMBER:_default' \
'--num-backups=[Number of recent backups to keep, for instance 10]:NUMBER:_default' \
'--to-tmux[Print a one-line report in the Tmux status bar, otherwise print to stdout]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::backup_filepath -- Filepath of the backup to restore, by default, pick latest:_files' \
&& ret=0
;;
(catalog)
_arguments "${_arguments_options[@]}" : \
'-s+[]:STRATEGY:((most-recent\:"Apply a most-recent strategy, keeping only n backups"
classic\:"Apply a classic backup strategy"))' \
'--strategy=[]:STRATEGY:((most-recent\:"Apply a most-recent strategy, keeping only n backups"
classic\:"Apply a classic backup strategy"))' \
'-n+[Number of recent backups to keep, for instance 10]:NUMBER:_default' \
'--num-backups=[Number of recent backups to keep, for instance 10]:NUMBER:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tmux-backup__subcmd__catalog_commands" \
"*::: :->catalog" \
&& ret=0

    case $state in
    (catalog)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tmux-backup-catalog-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
'--only=[List only backups having this status]:ONLY_BACKUP_STATUS:((retainable\:"Retainable backups only"
purgeable\:"Purgeable backups only"))' \
'--details[Add details columns to the table]' \
'--filepaths[Print filepaths instead of the table format]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(compact)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tmux-backup__subcmd__catalog__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tmux-backup-catalog-help-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(compact)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(describe)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':backup_filepath -- Path to the backup file:_files' \
&& ret=0
;;
(generate-completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Shell for which you want completion:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tmux-backup__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tmux-backup-help-command-$line[1]:"
        case $line[1] in
            (save)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(restore)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(catalog)
_arguments "${_arguments_options[@]}" : \
":: :_tmux-backup__subcmd__help__subcmd__catalog_commands" \
"*::: :->catalog" \
&& ret=0

    case $state in
    (catalog)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tmux-backup-help-catalog-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(compact)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(describe)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tmux-backup_commands] )) ||
_tmux-backup_commands() {
    local commands; commands=(
'save:Save the Tmux sessions to a new backup file' \
'restore:Restore the Tmux sessions from a backup file' \
'catalog:Catalog commands' \
'describe:Describe the content of a backup file' \
'generate-completion:Print a shell completion script to stdout' \
'init:Outputs the default tmux plugin config to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tmux-backup commands' commands "$@"
}
(( $+functions[_tmux-backup__subcmd__catalog_commands] )) ||
_tmux-backup__subcmd__catalog_commands() {
    local commands; commands=(
'list:Print a list of backups to stdout' \
'compact:Apply the catalog'\''s compaction strategy\: this deletes all purgable backups' \
'help:Print this message or the help of the given subcommand(s)' \
