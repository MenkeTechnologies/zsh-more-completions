#compdef gftools-fix-nonhinting
# Documentation: https://github.com/googlefonts/gftools
# Fix a non-hinted font by adding a fitting gasp table and a prep table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--no-backup[do not create backup of input ttf]' \
  '(-q --quiet)'{-q,--quiet}'[quiet STDOUT messages]' \
  '1:input font:_files -g "*.(ttf|otf|TTF|OTF)"' \
  '2:output font:_files' && ret=0

return ret
