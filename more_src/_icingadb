#compdef icingadb
# Documentation: https://icinga.com/docs/icinga-db/latest/doc/02-Installation/
# Reference accessed: 2026-05-16
# Verified: upstream Icinga DB docs. The daemon takes only a config flag
# at the command line; everything else lives in the YAML config.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# icingadb: Icinga DB Go daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-config[YAML configuration file path]:file:_files' \
  '--config=[YAML configuration file path]:file:_files' && ret=0
return ret
