#compdef wicd-client
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/wicd-client.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu bionic wicd-client(1) manpage. WICD project dead
# since ~2014 but binary still exists in legacy distros.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --no-notifications and --version flags.

# wicd-client: WICD network manager GUI/tray client (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --tray)'{-t,--tray}'[run tray icon only]' \
  '(-n --no-tray)'{-n,--no-tray}'[run without tray icon]' \
  '(-a --no-animate)'{-a,--no-animate}'[disable network traffic animations]' && ret=0
return ret
