#compdef wicd-client
# Documentation: https://man.archlinux.org/search?q=wicd-client
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-tray[disable system tray]' \
  '--no-animate[disable animations]' \
  '--no-notifications[disable notifications]' \
  '-t[show tray icon]' && ret=0

return ret
