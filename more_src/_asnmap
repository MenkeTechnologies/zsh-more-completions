#compdef asnmap

# Zsh completion for asnmap - quickly map organization network ranges using ASN information

_arguments -s -S \
  '(-a --asn)'{-a,--asn}'[ASN to map]:ASN:' \
  '(-i --ip)'{-i,--ip}'[IP to get ASN info for]:IP:' \
  '(-d --domain)'{-d,--domain}'[domain to get ASN info for]:domain:' \
  '(-o --org)'{-o,--org}'[organization to get ASN info for]:org:' \
  '(-f --file)'{-f,--file}'[input file containing targets]:file:_files' \
  '(-r --resolvers)'{-r,--resolvers}'[file containing list of resolvers]:file:_files' \
  '--output[file to write results]:file:_files' \
  '-json[write results as JSON]' \
  '--json[write results as JSON]' \
  '-csv[write results as CSV]' \
  '--csv[write results as CSV]' \
  '-c[concurrency]:N:' \
  '--concurrency[concurrency]:N:' \
  '-silent[display results only]' \
  '--silent[display results only]' \
  '-verbose[verbose output]' \
  '--verbose[verbose output]' \
  '-no-color[disable output content coloring]' \
  '--no-color[disable output content coloring]' \
  '-version[show version]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
