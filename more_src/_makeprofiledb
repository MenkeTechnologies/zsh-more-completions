#compdef makeprofiledb
# BLAST+ tool to build an RPS-BLAST / DELTA / COBALT profile database from scoremats
# Flags from NCBI BLAST+ Command Line Applications User Manual (NBK279684)

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-in=[input file with list of scoremat files]:file:_files' \
  '-binary[input scoremat files are binary ASN.1]' \
  '-title=[title for the profile database]:title:' \
  '-out=[output database name]:name:' \
  '-dbtype=[type of profile database]:type:(rps cobalt delta)' \
  '-threshold=[lookup table word score threshold]:float:' \
  '-scale=[PSSM scale factor]:float:' \
  '-matrix=[scoring matrix name]:matrix:(BLOSUM45 BLOSUM50 BLOSUM62 BLOSUM80 BLOSUM90 PAM30 PAM70 PAM250)' \
  '-gapopen=[gap opening penalty]:int:' \
  '-gapextend=[gap extension penalty]:int:' \
  '-max_file_sz=[maximum file size for the database files]:size:' \
  '-obsr_threshold=[observations threshold for PSSM construction]:float:' \
  '-exclude_invalid[exclude invalid scoremats from the database]' \
  '-index=[create an index]:bool:(true false)' \
  '-logfile=[file to which the program log is written]:file:_files' && ret=0

return ret
