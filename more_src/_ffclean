#compdef ffclean
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss48.html
# KAPPA: remove defects from a substantially flat one- to three-dimensional NDF

local ret=1

_arguments -s \
  'AXES=[axes spanning the rows or planes to clean]:axes' \
  'BOX=[box sizes for smoothing the image]:box' \
  'CLIP=[standard deviations for the rejection threshold]:clip' \
  'GENVAR=[store noise levels in output variance]:genvar:(TRUE FALSE)' \
  'IN=[input NDF containing the image]:NDF:_files' \
  'OUT=[output cleaned NDF]:NDF:_files' \
  'THRESH=[range of acceptable data values]:thresh' \
  'TITLE=[title for the output NDF]:title' \
  'WLIM=[minimum fraction of good pixels]:wlim' \
  '*:NDF:_files' && ret=0

return ret
