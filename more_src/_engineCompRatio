#compdef engineCompRatio
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/postProcessing/miscellaneous/engineCompRatio — compute IC engine compression ratio from cellSet/cellZone volumes (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-cellSet+[cellSet name for volume]:name:_default' \
    '-cellZone+[cellZone name for volume]:name:_default' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
