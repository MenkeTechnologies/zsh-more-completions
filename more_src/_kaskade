#compdef kaskade
# Documentation: https://github.com/sauljabin/kaskade/blob/main/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for kaskade

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*:: :_files' && ret=0

return ret
