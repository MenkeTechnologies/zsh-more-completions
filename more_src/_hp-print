#compdef hp-print
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/hp-print.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy hp-print(1) manpage.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-print: HPLIP print dialog
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --device)'{-d+,--device=}'[device URI]:uri:' \
  '(-p --printer)'{-p+,--printer=}'[printer name]:printer:_printers' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' \
  '*:file:_files' && ret=0
return ret
