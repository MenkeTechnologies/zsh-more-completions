#compdef ligolo-proxy ligolo-ng-proxy
# Documentation: https://man.archlinux.org/search?q=ligolo-proxy
# Reference accessed: 2026-05-16

_arguments -s \
  '-v[verbose]' \
  '-laddr=[listen address]:host\:port:' \
  '-autocert[Let'\''s Encrypt autocert]' \
  '-selfcert[self-signed cert]' \
  '-certfile=[TLS cert]:file:_files' \
  '-keyfile=[TLS key]:file:_files' \
  '-allow-domains=[allowed domains]:domains:' \
  '-selfcert-domain=[selfcert domain]:domain:' \
  '-version[show version]' \
  '-nobanner[no banner]' \
  '-config=[config file]:file:_files' \
  '-daemon[daemon mode]' \
  '-api-laddr=[API listen]:host\:port:' \
  '-cpuprofile=[CPU profile]:file:_files' \
  '-memprofile=[memory profile]:file:_files' \
  '(- *)'{-h,-help}'[show help]' \
  && return 0
