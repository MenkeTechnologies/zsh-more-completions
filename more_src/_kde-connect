#compdef kdeconnect-cli

# Zsh completion for kdeconnect-cli - KDE Connect CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --list-available)'{-l,--list-available}'[list available (paired and reachable) devices]' \
  '(-a --list-devices)'{-a,--list-devices}'[list all known devices]' \
  '--id-only[only print device IDs with list commands]' \
  '--name-only[only print device names with list commands]' \
  '--id-name-only[only print device IDs and names with list commands]' \
  '(-d --device)'{-d,--device}'[specify device by ID]:device id' \
  '--name[specify device by name]:device name' \
  '--pair[request pairing with specified device]' \
  '--unpair[unpair from specified device]' \
  '--ping[send a ping to the specified device]' \
  '--ping-msg[send a ping with a custom message]:message' \
  '--share[share a file with the specified device]:file:_files' \
  '--share-text[share text with the specified device]:text' \
  '--list-notifications[list notifications on the specified device]' \
  '--lock[lock the specified device]' \
  '--unlock[unlock the specified device]' \
  '--send-sms[send an SMS]:message' \
  '--destination[phone number for SMS]:phone number' \
  '--ring[ring the specified device]' \
  '--photo[request a photo from the specified device]:file:_files' \
  '--list-commands[list available remote commands]' \
  '--execute-command[execute a remote command by key]:command key' \
  '--encryption-info[show encryption info for the specified device]' \
  '--send-keys[send keyboard input to the specified device]:keys' \
  && ret=0

return ret
