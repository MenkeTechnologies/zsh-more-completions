#compdef grain-cli grain2
# _grain-cli — Oscar Spencer Philip Blair Grain Lang grain-cli CLI command-line frontend wrapping the Grain open-source modern strongly typed functional programming language that compiles to WebAssembly written in OCaml originally Oscar Spencer Philip Blair now Grain Lang team brings functional programming to all browsers and the cloud novel language WebAssembly stack-based-VM no-garbage-collection ML-family strongly-typed functional ABI-stable-WebAssembly compiles-Grain-to-WebAssembly-binary build run lsp compile graindoc format doc preprocess type-check version --color --debug --no-bulk-memory --no-elide-type-info --no-zero-memory --no-pinning --no-bulk-memory --memory-base --import --output-dir (Oscar Spencer Philip Blair Grain Lang team, OCaml); cmdliner
# upstream: https://grain-lang.org/

_grain-cli() {
    local -a sub=(
        'build:Compile Grain programs'
        'compile:Compile a Grain file'
        'run:Run a compiled Grain program'
        'doc:Documentation generator'
        'lsp:Start the language server'
        'format:Format Grain source code'
        'preprocess:Preprocess a file'
        'type-check:Type-check a file'
        'graindoc:Documentation generator'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--color=+[c]:c:(auto always never)' \
        '--debug[debug build]' \
        '--no-debug[no debug]' \
        '--release[release build]' \
        '--no-bulk-memory[no bulk memory]' \
        '--no-elide-type-info[no elide type info]' \
        '--no-zero-memory[no zero memory]' \
        '--no-pinning[no pinning]' \
        '--no-tail-call[no tail call]' \
        '--memory-base=+[N]:n:' \
        '--initial-memory-pages=+[N]:n:' \
        '--maximum-memory-pages=+[N]:n:' \
        '--import-memory[import memory]' \
        '--no-export-memory[no export memory]' \
        '--memory-grow-budget=+[N]:n:' \
        '--gc-tuning-warn-mem-percent=+[N]:str:' \
        '--gc-tuning-flush-mem-percent=+[N]:str:' \
        '--gc-tuning-thresh=+[N]:str:' \
        '--gc-tuning-grow=+[N]:str:' \
        '--gc-tuning-num-old=+[N]:n:' \
        '--gc-tuning-throttling-rate=+[N]:str:' \
        '--print-ast[print AST]' \
        '--print-typed-ast[print typed AST]' \
        '--print-anf[print ANF]' \
        '--print-mash[print MASH]' \
        '--no-pervasives[no pervasives]' \
        '--no-stdlib[no stdlib]' \
        '--stdlib=+[dir]:dir:_files -/' \
        '-I+[dir]:dir:_files -/' \
        '*-I+[dir]:dir:_files -/' \
        '--include=+[dir]:dir:_files -/' \
        '*--include=+[dir]:dir:_files -/' \
        '-o+[output]:file:_files -g "*.gr.wasm *.wasm"' \
        '--output=+[file]:file:_files' \
        '--output-dir=+[dir]:dir:_files -/' \
        '-c[compile only]' \
        '--compile-only[compile only]' \
        '--in-place[in place format]' \
        '--check[check format only]' \
        '--graindoc-template=+[file]:file:_files' \
        '--current-section=+[name]:str:' \
        '--page-anchors[page anchors]' \
        '--strict-sequence[strict sequence]' \
        '--no-strict-sequence[no strict sequence]' \
        '--no-static-link[no static link]' \
        '--static-link[static link]' \
        '--use-llvm[use LLVM]' \
        '--no-use-llvm[no use LLVM]' \
        '--no-source-map[no source map]' \
        '--source-map[source map]' \
        '--print-tokens[print tokens]' \
        '--print-warnings[print warnings]' \
        '--print-warnings-only[print warnings only]' \
        '--include-resource=+[file]:_files' \
        '*--include-resource=+[file]:_files' \
        '-r+[runner]:str:' \
        '--runner=+[name]:str:' \
        '--wasmtime[wasmtime runner]' \
        '--wasmer[wasmer runner]' \
        '--node[node runner]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grain subcommand' sub ;;
        args)
            case $words[1] in
                build|compile|run|format|preprocess|type-check|doc|graindoc) _arguments '*:source:_files -g "*.gr *.wasm"' ;;
            esac
            ;;
    esac
}

_grain-cli "$@"
