#compdef mb
# Documentation: https://man.archlinux.org/search?q=mb
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start the mountebank service'
  'stop:stop a running mountebank service'
  'restart:restart the mountebank service'
  'replay:replay imposters from disk in proxy mode'
  'save:save current imposter configuration to a file'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--port=[port to bind on]:port:' \
  '--host=[host to bind on]:host:_hosts' \
  '--socketBacklog=[connection backlog]:n:' \
  '--configfile=[load imposters from config file]:file:_files -g "*.{json,ejs}"' \
  '--noParse[do not parse configfile as EJS]' \
  '--formatter=[formatter for save/restore]:formatter:' \
  '--pidfile=[PID file]:file:_files' \
  '--logfile=[log file path]:file:_files' \
  '--loglevel=[log level]:level:(debug info warn error)' \
  '--nologfile[disable file logging]' \
  '--allowInjection[allow JS injection]' \
  '--allowCORS[allow cross-origin requests]' \
  '--mock[record requests for verification]' \
  '--debug[record matches for debugging]' \
  '--datadir=[directory for data files]:dir:_files -/' \
  '--apikey=[require API key]:key:' \
  '--protofile=[proto/proxy implementation file]:file:_files' \
  '--ipWhitelist=[allowed IPs (pipe-separated)]:list:' \
  '--rcfile=[mb config file]:file:_files' \
  '--origin=[allowed Origin header]:origin:' \
  '--localOnly[only allow local connections]' \
  '--heroku[Heroku deployment mode]' \
  '--removeProxies[remove proxy responses on save]' \
  '--useHTTPS[serve mountebank over HTTPS]' \
  '--cert=[mountebank server cert]:file:_files' \
  '--key=[mountebank server key]:file:_files' \
  '--mutualAuth[enable mutual TLS]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (save)
        _arguments \
          '--savefile=[output file]:file:_files' \
          '--removeProxies[remove proxy responses]' && ret=0 ;;
      (replay)
        _arguments \
          '--configfile=[imposter file]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
