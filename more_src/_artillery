#compdef artillery

# Zsh completion for artillery - cloud-scale load testing framework

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run a test script'
      'quick:run a quick test without a script'
      'report:generate a HTML report from a JSON report'
      'convert:convert test scripts between formats'
      'aws:run tests on AWS'
      'pro:Artillery Pro commands'
    )
    _describe -t commands 'artillery command' commands && ret=0
    ;;
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-t,--target}'=[target base URL]:url' \
          {-o,--output}'=[output report file]:file:_files' \
          {-k,--insecure}'[allow insecure TLS]' \
          '--overrides=[JSON object to override script values]:overrides' \
          '--variables=[JSON object of variables]:variables' \
          {-e,--environment}'=[environment from config]:environment' \
          {-c,--config}'=[config file to load]:file:_files' \
          {-q,--quiet}'[quiet mode]' \
          '--count=[number of VUs]:count' \
          '--tags=[comma-separated list of tags]:tags' \
          '*:test script:_files -g "*.{yml,yaml,json}(-.)"' \
          && ret=0
        ;;
      quick)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--count=[number of VUs]:count' \
          '-n+[number of requests per VU]:requests' \
          {-o,--output}'=[output report file]:file:_files' \
          '*:target URL:' \
          && ret=0
        ;;
      report)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'=[output HTML file]:file:_files' \
          '*:JSON report:_files -g "*.json(-.)"' \
          && ret=0
        ;;
      convert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:input file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
