#compdef xrdfs

# xrdfs: interactive xrootd filesystem client
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'cd:change current dir'
  'ls:list directory'
  'cat:show file contents'
  'tail:show tail of file'
  'head:show head of file'
  'stat:stat object'
  'statvfs:stat virtual filesystem'
  'mv:rename'
  'mkdir:make a directory'
  'rm:remove a file'
  'rmdir:remove a directory'
  'truncate:truncate a file'
  'chmod:change mode'
  'query:server-specific queries'
  'prepare:prepare an object'
  'spaceinfo:show space info'
  'locate:locate a file'
  'whoami:show identity'
  'help:show help'
  'exit:exit'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--no-cwd[do not change cwd]' \
  '-s[run in batch mode]:script:_files' \
  '1:server:_hosts' \
  '*: :->cmd' && ret=0
case $state in
  cmd) _describe -t commands 'xrdfs command' commands && ret=0 ;;
esac
return ret
