#compdef dracut-pre-pivot
# Documentation: https://man.archlinux.org/search?q=dracut-pre-pivot
# Reference accessed: 2026-05-16

# dracut-pre-pivot: hook run in initrd before pivoting to real root
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::extra args:_files' && ret=0
return ret
