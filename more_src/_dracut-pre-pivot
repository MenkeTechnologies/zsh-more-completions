#compdef dracut-pre-pivot
# Documentation: https://github.com/dracut-ng/dracut-ng
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dracut-pre-pivot: hook run in initrd before pivoting to real root
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::extra args:_files' && ret=0
return ret
