#compdef casync

# Zsh completion for casync - content-addressable data sync

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'make:create a .caidx or .caibx index file'
      'extract:extract data from an index file'
      'list:list contents of an index file'
      'digest:calculate digest of a file or directory'
      'mount:mount an index file via FUSE'
      'mkdev:create a block device from an index file'
      'gc:garbage collect unused chunks from a store'
      'stat:show information about an index file'
    )
    _describe -t commands 'casync command' commands && ret=0
    ;;
  args)
    case $line[1] in
      make|extract)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--store=[chunk store path]:store:_directories' \
          '*--seed=[seed file or directory]:seed:_files' \
          '--cache=[cache store path]:cache:_directories' \
          '--rate-limit-bps=[rate limit in bytes per second]:bps' \
          '*--with=[enable feature]:feature:(unix symlinks device-nodes fifos sockets permissions 2bst 16bit-uids 32bit-uids user-names sec-time usec-time nsec-time flag-hidden flag-system flag-archive flag-append flag-noatime flag-compr flag-nocow flag-nodump flag-dirsync flag-immutable flag-sync flag-nocomp flag-projinherit xattrs acl selinux fcaps quota-projid)' \
          '*--without=[disable feature]:feature:(unix symlinks device-nodes fifos sockets permissions 2bst 16bit-uids 32bit-uids user-names sec-time usec-time nsec-time flag-hidden flag-system flag-archive flag-append flag-noatime flag-compr flag-nocow flag-nodump flag-dirsync flag-immutable flag-sync flag-nocomp flag-projinherit xattrs acl selinux fcaps quota-projid)' \
          '--exclude-nodump[exclude files with nodump flag]' \
          '--exclude-submounts[exclude submounts]' \
          '*--exclude-file=[exclude file pattern]:pattern' \
          '--undo-immutable[undo immutable flag on extraction]' \
          '--chunk-size-min=[minimum chunk size]:size' \
          '--chunk-size-avg=[average chunk size]:size' \
          '--chunk-size-max=[maximum chunk size]:size' \
          '--compression=[compression algorithm]:compression:(zstd gzip xz none)' \
          '--seed-output[use output as seed]' \
          '--reflink=[reflink mode]:mode:(auto always never)' \
          '*:file:_files' && ret=0
        ;;
      list|digest|stat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--store=[chunk store path]:store:_directories' \
          '*:file:_files' && ret=0
        ;;
      mount)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--store=[chunk store path]:store:_directories' \
          '*--seed=[seed file or directory]:seed:_files' \
          '1:index file:_files' \
          '2:mount point:_directories' && ret=0
        ;;
      mkdev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--store=[chunk store path]:store:_directories' \
          '*--seed=[seed file or directory]:seed:_files' \
          '1:index file:_files' \
          '2:device path:_files' && ret=0
        ;;
      gc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--store=[chunk store path]:store:_directories' \
          '*:index file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
