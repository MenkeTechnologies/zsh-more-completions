#compdef payload
# Documentation: https://payloadcms.com/docs/database/migrations
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Payload CMS CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build Payload admin panel'
      'dev:start development server'
      'run:run a custom script'
      'generate\:types:generate TypeScript types from the Payload config'
      'generate\:graphQLSchema:generate the GraphQL schema'
      'generate\:importmap:generate import maps for the Payload application'
      'migrate:run all pending migrations'
      'migrate\:create:create a new migration file'
      'migrate\:status:show status of migrations'
      'migrate\:down:roll back the last batch of migrations'
      'migrate\:refresh:roll back all migrations and re-run them'
      'migrate\:reset:roll back all migrations'
      'migrate\:fresh:drop all entities and re-run migrations from scratch'
    )
    _describe -t commands 'payload command' commands && ret=0
    ;;
  args)
    case $line[1] in
      migrate:create)
        _arguments -s -S \
          '--skip-empty[skip the schema changes prompt]' \
          '--force-accept-warning[accept prompts and create blank migration]' \
          '*:migration name:' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
