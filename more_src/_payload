#compdef payload

# Zsh completion for Payload CMS CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build Payload admin panel'
      'dev:start development server'
      'generate:generate resources'
      'migrate:run database migrations'
      'seed:seed the database'
    )
    _describe -t commands 'payload command' commands && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      generate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:type:(types graphQLSchema importMap)' && ret=0
        ;;
      migrate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create status down fresh reset)' && ret=0
        ;;
    esac
    ;;
esac

return ret
