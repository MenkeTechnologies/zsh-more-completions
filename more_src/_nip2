#compdef nip2
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/nip2.1.html
# nip2 — image processing with the VIPS library (GUI/batch)

local ret=1

_arguments -s -S \
  '(-e --expression)'{-e,--expression=}'[start in no-GUI mode; set main = expression]:expression' \
  '(-s --script)'{-s,--script=}'[no-GUI mode; read filename as definitions]:file:_files' \
  '(-o --output)'{-o,--output=}'[write value of main to the named file]:file:_files' \
  '(-b --batch)'{-b,--batch}'[batch (non-GUI) mode]' \
  '(-m --no-load-menus)'{-m,--no-load-menus}'[do not load menus, for faster startup]' \
  '(-a --no-load-args)'{-a,--no-load-args}'[do not load extra command-line arguments]' \
  '(-w --stdin-ws)'{-w,--stdin-ws}'[load stdin as a workspace]' \
  '(-d --stdin-def)'{-d,--stdin-def}'[load stdin as a set of definitions]' \
  '(-p --print-main)'{-p,--print-main}'[print the value of main on exit]' \
  '(-V --verbose)'{-V,--verbose}'[produce verbose error messages]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-i --i18n)'{-i,--i18n}'[output strings from .def files for i18n]' \
  '(-c --benchmark)'{-c,--benchmark}'[benchmark: no GUI, just start up and shut down]' \
  '(-t --time-save)'{-t,--time-save}'[time saves: popup with time after each save]' \
  '(-T --test)'{-T,--test}'[test: start up and exit with error code on error]' \
  '(-x --prefix)'{-x,--prefix=}'[set install prefix]:prefix:_files -/' \
  '*:file:_files' && ret=0

return ret
