#compdef delatex
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/detex.1.html
# delatex - filter to strip TeX/LaTeX commands from a .tex file (detex in LaTeX mode)

local ret=1

_arguments -s \
  '-c[echo arguments of \cite, \ref and \pageref macros]' \
  '-e[comma-separated environment-list to ignore, replacing defaults]:environments:' \
  '-l[force LaTeX mode]' \
  '-n[do not process \input or \include commands]' \
  '-s[insert space between words for spacing]' \
  '-t[force TeX mode]' \
  '-w[output a word list, one word per line]' \
  '*:TeX file:_files -g "*.(tex|ltx|latex)(-.)"' && ret=0

return ret
