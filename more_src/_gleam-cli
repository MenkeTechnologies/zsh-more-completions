#compdef gleam
# Documentation: https://man.archlinux.org/search?q=gleam
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add deps to gleam.toml'
  'build:build the project'
  'check:type check the project'
  'clean:clean build artifacts'
  'compile-package:compile a single package'
  'completion:generate completion'
  'deps:dependency commands'
  'docs:documentation commands'
  'export:export project info'
  'fix:fix code'
  'format:format source'
  'fmt:format source (alias)'
  'help:show help'
  'hex:Hex commands'
  'lsp:run language server'
  'new:create new project'
  'publish:publish to Hex'
  'remove:remove dep from gleam.toml'
  'run:run project'
  'shell:start interactive shell'
  'test:run project tests'
  'update:update deps to latest'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gleam command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build|check|run|test|shell|clean)
        _arguments \
          '(--target -t)'{-t+,--target=}'[target]:t:(erlang javascript)' \
          '(--warnings-as-errors)--warnings-as-errors[warnings as errors]' \
          '(--no-print-progress)--no-print-progress[no progress]' \
          '(--runtime)--runtime=[runtime]:r:(node deno bun nodejs)' \
          '(--module -m)'{-m+,--module=}'[module]:m:' \
          '*: :' && ret=0 ;;
      (add)
        _arguments \
          '(--dev -d)'{-d,--dev}'[dev dep]' \
          '*:package:' && ret=0 ;;
      (remove)
        _arguments \
          '*:package:' && ret=0 ;;
      (publish)
        _arguments \
          '(--replace)--replace[replace existing version]' \
          '(--yes -y)'{-y,--yes}'[yes]' \
          '*: :' && ret=0 ;;
      (docs)
        _arguments \
          '1:subcommand:(build publish remove)' \
          '*: :' && ret=0 ;;
      (deps)
        _arguments \
          '1:subcommand:(download list update)' \
          '*: :' && ret=0 ;;
      (hex)
        _arguments \
          '1:subcommand:(retire unretire)' \
          '*: :' && ret=0 ;;
      (new)
        _arguments \
          '(--name)--name=[name]:n:' \
          '(--description)--description=[description]:d:' \
          '(--template)--template=[template]:t:(lib erlang_lib gleam)' \
          '(--skip-git)--skip-git[skip git init]' \
          '(--skip-github)--skip-github[skip github actions]' \
          '*: :_files -/' && ret=0 ;;
      (format|fmt)
        _arguments \
          '(--check)--check[check only]' \
          '(--stdin)--stdin[read stdin]' \
          '*: :_files -g "*.gleam"' && ret=0 ;;
      (export)
        _arguments \
          '1:subcommand:(erlang-shipment hex-tarball javascript-prelude package-information typescript-prelude)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
