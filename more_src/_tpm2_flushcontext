#compdef tpm2_flushcontext
# _tpm2_flushcontext — tpm2-software tpm2_flushcontext remove all transient or loaded objects sessions from the TPM2 (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_flushcontext() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t[flush all transient objects]' \
        '--transient-object[flush all transient objects]' \
        '-l[flush all loaded sessions]' \
        '--loaded-session[flush all loaded sessions]' \
        '-s[flush all saved sessions]' \
        '--saved-session[flush all saved sessions]' \
        '-Q[do not output anything]' \
        '*:handle or context:'
}

_tpm2_flushcontext "$@"
