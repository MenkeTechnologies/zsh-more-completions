#compdef betterstack-collector
# Documentation: https://man.archlinux.org/search?q=betterstack-collector
# Reference accessed: 2026-05-16

# Zsh completion for Better Stack Collector (log shipping)
# https://betterstack.com

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'status:Check the status of the collector'
  'restart:Restart the collector service'
  'version:Display version information'
)

_arguments -s -S \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'betterstack-collector command' commands && ret=0
    ;;
esac

return ret
