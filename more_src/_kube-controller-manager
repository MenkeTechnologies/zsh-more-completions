#compdef kube-controller-manager
# Documentation: https://man.archlinux.org/search?q=kube-controller-manager
# Reference accessed: 2026-05-16

# kube-controller-manager: Kubernetes controller manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--bind-address=[bind address]:addr:' \
  '--cert-dir=[cert dir]:dir:_files -/' \
  '--client-ca-file=[client CA file]:file:_files' \
  '--cluster-cidr=[cluster CIDR]:cidr:' \
  '--cluster-name=[cluster name]:name:' \
  '--cluster-signing-cert-file=[cluster signing cert]:file:_files' \
  '--cluster-signing-duration=[cluster signing duration]:duration:' \
  '--cluster-signing-key-file=[cluster signing key]:file:_files' \
  '--concurrent-deployment-syncs=[concurrent deployment syncs]:n:' \
  '--concurrent-endpoint-syncs=[concurrent endpoint syncs]:n:' \
  '--concurrent-namespace-syncs=[concurrent namespace syncs]:n:' \
  '--concurrent-replicaset-syncs=[concurrent replicaset syncs]:n:' \
  '--concurrent-resource-quota-syncs=[concurrent resource quota syncs]:n:' \
  '--concurrent-service-syncs=[concurrent service syncs]:n:' \
  '--configure-cloud-routes=[configure cloud routes]:bool:(true false)' \
  '--controllers=[controllers list]:list:' \
  '--feature-gates=[feature gates]:gates:' \
  '--horizontal-pod-autoscaler-downscale-stabilization=[HPA downscale stabilization]:duration:' \
  '--horizontal-pod-autoscaler-sync-period=[HPA sync period]:duration:' \
  '--horizontal-pod-autoscaler-tolerance=[HPA tolerance]:f:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--leader-elect=[enable leader election]:bool:(true false)' \
  '--leader-elect-lease-duration=[leader elect lease duration]:duration:' \
  '--leader-elect-renew-deadline=[leader elect renew deadline]:duration:' \
  '--leader-elect-retry-period=[leader elect retry period]:duration:' \
  '--master=[k8s API URL]:url:' \
  '--node-cidr-mask-size=[node CIDR mask size]:n:' \
  '--node-monitor-grace-period=[node monitor grace period]:duration:' \
  '--node-monitor-period=[node monitor period]:duration:' \
  '--pod-eviction-timeout=[pod eviction timeout]:duration:' \
  '--profiling=[enable profiling]:bool:(true false)' \
  '--root-ca-file=[root CA file]:file:_files' \
  '--service-account-private-key-file=[SA private key]:file:_files' \
  '--service-cluster-ip-range=[service CIDR]:cidr:' \
  '--terminated-pod-gc-threshold=[terminated pod GC threshold]:n:' \
  '--tls-cert-file=[TLS cert]:file:_files' \
  '--tls-private-key-file=[TLS key]:file:_files' \
  '--use-service-account-credentials=[use SA creds]:bool:(true false)' \
  '--v=[log level]:n:' \
  '*::kube-controller-manager args:_files' && ret=0
return ret
