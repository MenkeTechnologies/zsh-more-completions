#compdef blackdoc
# Documentation: https://blackdoc.readthedocs.io/en/latest/options.html
# Run black on code blocks in documentation files

local ret=1

_arguments -s -S \
  '--config=[specify a custom TOML configuration file]:file:_files' \
  '--check[verify formatting without writing changes]' \
  '--diff[output a unified diff of the changes that would have been made]' \
  '--color[colorize diffs]' \
  '--no-color[do not colorize diffs]' \
  '--version[display version information and exit]' \
  '(-t --target-versions)'{-t+,--target-versions=}'[comma-separated Python target versions]:versions' \
  '(-l --line-length)'{-l+,--line-length=}'[character limit per line (default: 88)]:int' \
  '(-S --skip-string-normalization)'{-S,--skip-string-normalization}'[disable string normalization]' \
  '--include=[regex pattern for included files/directories]:regex' \
  '--exclude=[regex pattern for excluded paths]:regex' \
  '--force-exclude=[exclusions applied even to explicitly passed arguments]:regex' \
  '--formats=[comma-separated list of formats to enable]:formats' \
  '--disable-formats=[comma-separated list of formats to disable]:formats' \
  '*:file:_files' && ret=0

return ret
