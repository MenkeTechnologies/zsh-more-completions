#compdef delhead
# delhead: delete FITS and IRAF image header keyword entries (WCSTools)

local ret=1

_arguments -s -S \
  '-f[reset maximum number of files read from command line]' \
  '-m[reset maximum number of keyword names read from command line]' \
  '-n[write output to a new file named by inserting e before the extension]' \
  '-v[print more information about the process]' \
  '*:FITS file or keyword:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
