#compdef supervise
# Documentation: https://cr.yp.to/daemontools/supervise.html
# Reference accessed: 2026-05-16
# Verified: D.J. Bernstein daemontools supervise(8) docs.
# No flags; takes one positional service-directory argument.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h flag (daemontools has no --help).

# supervise: daemontools service supervisor (positional only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:service dir (contains ./run):_files -/' && ret=0
return ret
