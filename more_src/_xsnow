#compdef xsnow
# Documentation: https://man.archlinux.org/search?q=xsnow
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-display+[X display]:disp:' \
  '-bg+[bg color]:color:' \
  '-fg+[fg color]:color:' \
  '-nosanta[no santa]' \
  '-norudolf[no rudolf]' \
  '-notrees[no trees]' \
  '-nosnowflakes[no snowflakes]' \
  '-nokeepsnow[no keep snow]' \
  '-nokeepsbot[no keep snow on bot]' \
  '-snowflakes+[max snowflakes]:n:' \
  '-windowscale+[window scale]:n:' \
  '-screen+[screen]:n:' \
  '-noblowsnow[no blowing snow]' \
  '-blowoff[blow off snow]' \
  '-windtimer+[wind timer sec]:sec:' \
  '-windforce+[wind force]:n:' \
  '-windsave+[wind save]:n:' \
  '-snowspeedfactor+[snow speed]:n:' \
  '-santaspeedfactor+[santa speed]:n:' && ret=0

return ret
