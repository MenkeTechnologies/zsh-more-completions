#compdef xsnow
# Documentation: https://manpages.debian.org/bookworm/xsnow/xsnow.6.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help}'[display help]' \
  '(- *)'{-H,-manpage}'[show man page]' \
  '(- *)'{-v,-version}'[show version]' \
  '-changelog[display change log]' \
  '-selfrep[output tar ball to stdout]' \
  '-display+[X display]:display:' \
  '-screen+[monitor for snow (-1 for all)]:n:' \
  '-outline+[draw outline around snow window]:n:(0 1)' \
  '-vintage[use vintage settings]' \
  '-defaults[skip config file]' \
  '-noconfig[ignore config file entirely]' \
  '-hidemenu[start with hidden menu]' \
  '-nomenu[disable interactive menu]' \
  '-scale+[scale factor (default 100)]:n:' \
  '-doublebuffer+[double buffering]:n:(0 1)' \
  '-transparency+[transparency percentage]:n:' \
  '-theme+[xsnow (1) or system (0) theme]:n:(0 1)' \
  '-checkgtk+[check GTK version]:n:(0 1)' \
  '-id+[snow in specific window]:n:' \
  '-window-id+[snow in specific window]:n:' \
  '-desktop[treat window as desktop]' \
  '-allworkspaces+[use all desktops]:n:(0 1)' \
  '-above[snow above windows]' \
  '-xwininfo[point at target window]' \
  '-stopafter+[stop after seconds]:sec:' \
  '-root[paint on root window]' \
  '-bg+[background file for xscreensaver]:file:_files' \
  '-noisy[write debug info to stdout]' \
  '-cpuload+[system load intensity (default 100)]:n:' \
  '-snowflakes+[flakes per second (default 100)]:n:' \
  '-blowsnow[animate blow-off snow]' \
  '-noblowsnow[disable blow-off animation]' \
  '-sc+[flake color (default #fffafa)]:color:' \
  '-snowspeedfactor+[snow speed multiplier (default 100)]:n:' \
  '-snowsize+[flake size (default 8)]:n:' \
  '-snow[show snow (default)]' \
  '-nosnow[hide snow]' \
  '-nosnowflakes[hide snow]' \
  '-flakecountmax+[maximum active flakes (default 300)]:n:' \
  '-blowofffactor+[blow-off intensity (default 40)]:n:' \
  '-treetype+[tree types (0-7, comma-list, or all)]:types:' \
  '-tc+[vintage tree color (default #7fff00)]:color:' \
  '-notrees[hide trees]' \
  '-showtrees[display trees]' \
  '-trees+[number of trees (default 10)]:n:' \
  '-treefill+[tree growth region percentage (default 30)]:n:' \
  '-treeoverlap[allow tree overlap]' \
  '-notreeoverlap[prevent tree overlap]' \
  '-showsanta[display Santa]' \
  '-nosanta[hide Santa]' \
  '-showrudolph[include Rudolph]' \
  '-norudolph[exclude Rudolph]' \
  '-santa+[Santa size 0-4 (default 3)]:n:(0 1 2 3 4)' \
  '-santaspeedfactor+[Santa speed multiplier (default 100)]:n:' \
  '-wind[enable wind]' \
  '-nowind[disable wind]' \
  '-whirlfactor+[wind intensity (default 100)]:n:' \
  '-windtimer+[wind period in seconds (default 30)]:sec:' \
  '-stars+[number of stars (default 20)]:n:' \
  '-meteors[show meteors]' \
  '-nometeors[hide meteors]' \
  '-meteorfrequency+[meteor frequency 0-100 (default 40)]:n:' \
  '-moon+[show moon]:n:(0 1)' \
  '-moonspeed+[moon speed px/min (default 120)]:n:' \
  '-moonsize+[moon relative size (default 100)]:n:' \
  '-halo+[show moon halo]:n:(0 1)' \
  '-halobrightness+[halo brightness (default 25)]:n:' \
  '-aurora+[show aurora]:n:(0 1)' \
  '-auroraleft[aurora on left]' \
  '-auroramiddle[aurora in middle]' \
  '-auroraright[aurora on right (default)]' \
  '-aurorawidth+[aurora width percentage (default 60)]:n:' \
  '-aurorabase+[aurora base height percentage (default 50)]:n:' \
  '-auroraheight+[aurora height (default 30)]:n:' \
  '-auroraspeed+[aurora speed (default 50)]:n:' \
  '-aurorabrightness+[aurora brightness (default 15)]:n:' \
  '-wsnowdepth+[window snow depth (default 30)]:n:' \
  '-ssnowdepth+[ground snow depth (default 50)]:n:' \
  '-maxontrees+[max flakes on trees (default 200)]:n:' \
  '-keepsnowonwindows[keep window snow]' \
  '-nokeepsnowonwindows[remove window snow]' \
  '-keepsnowonscreen[keep bottom snow]' \
  '-nokeepsnowonscreen[remove bottom snow]' \
  '-keepsnowontrees[keep tree snow]' \
  '-nokeepsnowontrees[remove tree snow]' \
  '-keepsnow[snow sticks everywhere]' \
  '-nokeepsnow[snow does not stick]' \
  '-fluffy[create fluffy effects]' \
  '-nofluffy[disable fluffy effects]' \
  '-offsetx+[X correction (default 4)]:n:' \
  '-offsety+[Y correction (default 0)]:n:' \
  '-offsetw+[width correction (default -8)]:n:' \
  '-offsets+[bottom correction (default 0)]:n:' \
  '-ignoretop+[ignore top windows]:n:' \
  '-ignorebottom+[ignore bottom windows]:n:' \
  '-anarchy+[bird anarchy 0-100 (default 50)]:n:' \
  '-birdscolor+[bird color (default #361A07)]:color:' \
  '-birdsonly+[show only birds]:n:(0 1)' \
  '-birdsspeed+[bird speed 0-300 (default 100)]:n:' \
  '-disweight+[distance preference 0-100 (default 20)]:n:' \
  '-focuscentre+[focus eagerness 0-300 (default 100)]:n:' \
  '-followneighbours+[follow eagerness 0-100 (default 30)]:n:' \
  '-nbirds+[number of birds 0-400 (default 70)]:n:' \
  '-neighbours+[birds watched 0-20 (default 7)]:n:' \
  '-prefdistance+[preferred distance 0-100 (default 40)]:n:' \
  '-showbirds+[show birds]:n:(0 1)' \
  '-showattr+[show attraction point]:n:(0 1)' \
  '-attrspace+[attraction point vertical space (default 40)]:n:' \
  '-followsanta+[birds follow Santa]:n:(0 1)' \
  '-viewingdistance+[viewing distance 0-95 (default 40)]:n:' \
  '-birdsscale+[bird scale factor (default 100)]:n:' && ret=0

return ret
