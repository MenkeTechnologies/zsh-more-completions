#compdef clickhouse-compressor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-d,--decompress}'[decompress (default is compress)]' \
  '--codec=[compression codec]:codec:(LZ4 LZ4HC ZSTD NONE Multiple Delta DoubleDelta Gorilla T64 FPC GCD)' \
  '--level=[compression level]:n:' \
  '--hc[use HC compression for LZ4]' \
  '--zstd[use ZSTD compression]' \
  '--zstd-level=[ZSTD level (1-22)]:level:' \
  '--block-size=[block size in bytes]:bytes:' \
  '--stat[show statistics]' \
  '--offset-in-decompressed-block=[offset in decompressed block]:n:' \
  '*:input file:_files' && ret=0

return ret
