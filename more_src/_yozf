#compdef yozf
# Documentation: https://man.archlinux.org/search?q=yozf
# Reference accessed: 2026-05-16

# Zsh completion for yozf (Homebrew yozefu — Kafka explorer TUI)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-b --brokers)'{-b,--brokers}'[broker list]:brokers' \
  '--topic[topic filter]:topic' && ret=0

return ret
