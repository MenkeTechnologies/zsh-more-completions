#compdef styra
# Documentation: https://docs.styra.com/das/reference/cli
# styra - Styra DAS command-line interface for OPA policy lifecycle management

local ret=1
local -a commands

commands=(
  'link:manage a local Styra DAS project (init, bundle, test, validate, rules, publish)'
  'get:retrieve a resource such as a system'
  'create:create a resource'
  'delete:delete a resource'
  'list:list resources'
  'validate:validate JSON or YAML against system rules'
  'vet:validate JSON or YAML files with your system rules'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'=[output format]:format:(json yaml)' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'styra command' commands && ret=0
    ;;
esac

return ret
