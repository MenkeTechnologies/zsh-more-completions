#compdef autogpt
# Documentation: https://github.com/Significant-Gravitas/AutoGPT/tree/master/classic/original_autogpt
# Reference accessed: 2026-05-22
# Verified: autogpt/app/cli.py click commands run serve config.

# Zsh completion for autogpt - classic AutoGPT agent CLI

local curcontext="$curcontext" state line ret=1

local -a run_opts serve_opts

run_opts=(
  '(-c --continuous)'{-c,--continuous}'[enable continuous mode]'
  '(-l --continuous-limit)'{-l,--continuous-limit}'[continuous run count]:n:'
  '--speak[enable speak mode]'
  '--install-plugin-deps[install third-party plugin dependencies]'
  '--skip-news[suppress startup news]'
  '(-y --skip-reprompt)'{-y,--skip-reprompt}'[skip initial re-prompts]'
  '--ai-name[override AI name]:name:'
  '--ai-role[override AI role]:role:'
  '--constraint[add constraint to prompt]:constraint:'
  '--resource[add resource to prompt]:resource:'
  '--best-practice[add best practice to prompt]:practice:'
  '--override-directives[replace directives instead of append]'
  '--debug[debug logging]'
  '--log-level[log level]:level:'
  '--log-format[log format]:format:'
  '--log-file-format[log file format]:format:'
  '--component-config-file[component config JSON]:file:_files'
  '(-w --workspace)'{-w,--workspace}'[workspace directory]:directory:_directories'
)

serve_opts=(
  '--install-plugin-deps[install third-party plugin dependencies]'
  '--debug[debug logging]'
  '--log-level[log level]:level:'
  '--log-format[log format]:format:'
  '--log-file-format[log file format]:format:'
  '(-w --workspace)'{-w,--workspace}'[workspace directory]:directory:_directories'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'autogpt command' \
      'run[start or resume agent task]' \
      'serve[start Agent Protocol server]' \
      'config[interactive settings browser]' && ret=0
    ;;
  args)
    case $line[1] in
      run) _arguments -C $run_opts && ret=0 ;;
      serve) _arguments -C $serve_opts && ret=0 ;;
      config)
        _arguments \
          '(-e --env-file)'{-e,--env-file}'[path to .env file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
