#compdef sfremap1
# Documentation: http://www.ahay.org/RSF/sfremap1.html
# Madagascar: 1-D ENO interpolation

local ret=1

_arguments -s \
  'pattern=[auxiliary input file name]:file:_files' \
  'n1=[number of output samples]:n1' \
  'd1=[output sampling]:d1' \
  'o1=[output origin]:o1' \
  'order=[interpolation order]:order' \
  '*:rsf file:_files' && ret=0

return ret
