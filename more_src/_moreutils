#compdef sponge ts vidir vipe ifdata ifne pee zrun chronic errno lckdo parallel-moreutils

# Zsh completion for moreutils collection
# Each tool is small, so they are combined here

case "$service" in
  sponge)
    _arguments \
      '-a[append instead of overwrite]' \
      '1:output file:_files'
    ;;
  ts)
    _arguments \
      '-i[incremental timestamps]' \
      '-s[monotonic timestamps since start]' \
      '-m[monotonic clock timestamps]' \
      '-r[convert existing timestamps to relative]' \
      '1:format string:'
    ;;
  vidir)
    _arguments \
      '-v[verbose mode]' \
      '*:files or directories:_files'
    ;;
  vipe)
    _arguments \
      '--suffix=[temp file suffix]:suffix:'
    ;;
  ifdata)
    _arguments \
      '-e[test if interface exists]' \
      '-p[print]' \
      '-pN[print subnet mask in dotted notation]' \
      '-pa[print address]' \
      '-pn[print netmask]' \
      '-pb[print broadcast address]' \
      '-pm[print MTU]' \
      '-ph[print hardware address]' \
      '-si[print input statistics]' \
      '-so[print output statistics]' \
      '-bips[print bytes in per second]' \
      '-bops[print bytes out per second]' \
      '1:interface:'
    ;;
  ifne)
    _arguments \
      '-n[run command if stdin is empty]' \
      '*:command:_command_names -e'
    ;;
  pee)
    _arguments \
      '*:command:'
    ;;
  chronic)
    _arguments \
      '-e[also trigger on stderr output]' \
      '-v[verbose (always show output)]' \
      '*:command:_command_names -e'
    ;;
  errno)
    _arguments \
      '-l[list all errors]' \
      '-s[search by name or description]' \
      '*:error name or number:'
    ;;
esac
