#compdef cline

# Zsh completion for Cline CLI
# https://cline.bot

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:Interactive setup for providers and API keys'
  'history:View and manage task history'
  'config:View/manage settings, rules, workflows, and skills'
  'update:Update the CLI to the latest version'
  'version:Display the current version'
)

_arguments -s -S \
  '(-p --plan)'{-p,--plan}'[Plan Mode: analyze and strategize before acting]' \
  '(-a --act)'{-a,--act}'[Act Mode: execute actions directly (default)]' \
  '(-y --yolo)'{-y,--yolo}'[YOLO Mode: auto-approve all actions]' \
  '(-j --json)'{-j,--json}'[JSON Output: output messages as JSON]' \
  '(-m --model)'{-m,--model}'[specify a model]:model:' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-i --image)'{-i,--image}'[include image files]' \
  '(-t --timeout)'{-t,--timeout}'[max execution time (s)]:seconds:' \
  '1:command:->command' \
  '*:prompt:' && ret=0

case $state in
  (command)
    _describe -t commands 'cline command' commands && ret=0
    ;;
esac

return ret
