#compdef cline
# Documentation: https://docs.cline.bot/cli/cli-reference
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Cline CLI autonomous coding agent.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:Configure authentication with an AI provider'
  'config:Show current configuration'
  'connect:Connect to messaging platforms'
  'mcp:Manage MCP servers'
  'dev:Developer tools and utilities'
  'doctor:Diagnose and fix configuration issues'
  'history:List session history or manage saved sessions'
  'h:List session history (alias)'
  'hook:Handle a hook payload from stdin'
  'plugin:Manage Cline plugins'
  'schedule:Manage scheduled agents'
  'hub:Manage the local hub daemon'
  'update:Check for updates and install if available'
  'version:Show Cline CLI version number'
  'kanban:Launch the kanban app and exit'
)

_arguments -s -S \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-p --plan)'{-p,--plan}'[run in plan mode]' \
  '--json[output messages as JSON instead of styled text]' \
  '--auto-approve=[set tool auto-approval for all tools]:boolean:(true false)' \
  '(-t --timeout)'{-t,--timeout}'[optional timeout in seconds]:seconds:' \
  '(-m --model)'{-m,--model}'[model id for the session]:model-id:' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-c --cwd)'{-c,--cwd}'[working directory]:path:_directories' \
  '--config=[configuration directory]:path:_directories' \
  '--data-dir=[isolated local state directory]:path:_directories' \
  '--thinking=[reasoning effort level]:level:(none low medium high xhigh)' \
  '--retries=[maximum consecutive mistakes before halting]:count:' \
  '--hooks-dir=[additional hooks directory]:path:_directories' \
  '--acp[run in Agent Client Protocol mode]' \
  '(-i --tui)'{-i,--tui}'[open the terminal user interface]' \
  '--id=[resume an existing session by ID]:session-id:' \
  '(-k --key)'{-k,--key}'[API key override for this run]:api-key:' \
  '(-P --provider)'{-P,--provider}'[provider id]:provider:' \
  '(-s --system)'{-s,--system}'[override the default system prompt]:system-prompt:' \
  '(-z --zen)'{-z,--zen}'[run a session in the background hub]' \
  '(-h --help)'{-h,--help}'[display help for command]' \
  '1:command:->command' \
  '*:prompt:' && ret=0

case $state in
  (command)
    _describe -t commands 'cline command' commands && ret=0
    ;;
esac

return ret
