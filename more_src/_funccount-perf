#compdef funccount-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/funccount.8
# count kernel function calls matching specified wildcards (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[total duration of trace in seconds]:secs' \
  '-i+[interval summary in seconds]:secs' \
  '-t+[show top num entries only]:top' \
  '-T[include timestamp, for -i]' \
  '*:function name pattern:' && ret=0

return ret
