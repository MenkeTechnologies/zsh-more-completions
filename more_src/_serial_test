#compdef serial_test
# Documentation: https://man.archlinux.org/search?q=serial_test
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-i+[interface]:interface:' \
  '-v+[USB vendor ID]:vid:' \
  '-p+[USB product ID]:pid:' \
  '-b+[baud rate]:rate:(9600 19200 38400 57600 115200)' \
  '-w-[write pattern]:pattern:' && ret=0

return ret
