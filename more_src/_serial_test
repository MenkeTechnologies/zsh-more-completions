#compdef serial_test
# Documentation: https://github.com/lipro/libftdi/blob/master/examples/serial_test.c
# Reference accessed: 2026-05-21
# Verified: upstream libftdi example serial_test.c (getopt string "i:v:p:b:w::").

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-i+[interface]:interface:' \
  '-v+[USB vendor ID]:vid:' \
  '-p+[USB product ID]:pid:' \
  '-b+[baud rate]:rate:(9600 19200 38400 57600 115200)' \
  '-w-[write pattern]:pattern:' && ret=0

return ret
