#compdef xdg-user-dirs-update
# _xdg-user-dirs-update — XDG xdg-user-dirs-update (regenerate ~/.config/user-dirs.dirs from ~/.config/user-dirs.locale; --force overwrites custom changes, --dummy-output writes to a path, --set updates a single key)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-user-dirs
# Flags from xdg-user-dirs/xdg-user-dirs-update.c on tip.

_xdg-user-dirs-update() {
    _arguments \
        '--help[show help]' \
        '--force[overwrite even if user-modified]' \
        '--dummy-output+[write to file]:file:_files' \
        '--set+[set key]:key value:(DESKTOP DOCUMENTS DOWNLOAD MUSIC PICTURES PUBLICSHARE TEMPLATES VIDEOS)'
}

_xdg-user-dirs-update "$@"
