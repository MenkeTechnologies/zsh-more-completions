#compdef bmake
# _bmake — BSD make portable build automation (NetBSD/FreeBSD + Simon Gerraty, C); BSD make + parallel + .for loops
# upstream: https://www.crufty.net/help/sjg/bmake.html

_bmake() {
    _arguments \
        '-B[compatible mode]' \
        '-C+[change to dir]:dir:_files -/' \
        '-D+[define]:def:' \
        '-d+[debug flags]:flags:' \
        '-e[env-vars override makefile]' \
        '-f+[makefile]:file:_files -g "[Mm]akefile*"' \
        '-I+[include dir]:dir:_files -/' \
        '-i[ignore errors]' \
        '-J+[parent jobs file]:file:_files' \
        '-j+[jobs]:n:' \
        '-k[keep going]' \
        '-m+[search dir for sys mks]:dir:_files -/' \
        '-N[no exec]' \
        '-n[no exec, print commands]' \
        '-q[question]' \
        '-r[no builtin rules]' \
        '-S[stop on error]' \
        '-s[silent]' \
        '-T+[trace file]:file:_files' \
        '-t[touch]' \
        '-V+[print variable]:var:' \
        '-v+[print expanded variable]:var:' \
        '-W[print warnings as warnings]' \
        '-w[print directory name]' \
        '-X[no env-vars from MAKEFLAGS]' \
        '*:target:'
}

_bmake "$@"
