#compdef sortmtz
# CCP4: sort reflections in an MTZ file by HKL indices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN[input MTZ reflection file]:mtz:_files -g "*.mtz"' \
  'HKLOUT[output sorted MTZ reflection file]:mtz:_files' \
  '*:keyword:(ASCEND DESCEND VRSET SORT END)' && ret=0

return ret
