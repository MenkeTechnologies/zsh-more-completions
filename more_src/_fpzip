#compdef fpzip
# _fpzip — lossy/lossless floating-point array compressor (LLNL/fpzip)
# upstream: https://github.com/LLNL/fpzip
# Flags from utils/fpzip.cpp (argv switch-on-strcmp).

_fpzip() {
    _arguments \
        '(- *)-h[show help]' \
        '(-h)-d[decompress (default is compress)]' \
        '-q[quiet operation]' \
        '-i+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '-t+[data type]:type:(float double)' \
        '-p+[precision in bits (0=lossless)]:bits:' \
        '-1+[1D array size NX]:nx:' \
        '-2+[2D array size NX NY]:nx ny:' \
        '-3+[3D array size NX NY NZ]:nx ny nz:' \
        '-4+[4D array size NX NY NZ NF]:nx ny nz nf:'
}

_fpzip "$@"
