#compdef TextureMesh
# Documentation: https://github.com/cdcseacave/openMVS/wiki/Usage
# OpenMVS: compute texture for a reconstructed mesh

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --working-folder)'{-w,--working-folder}'=[working directory]:dir:_files -/' \
  '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
  '--export-type=[export format]:type:(ply obj glb gltf)' \
  '--archive-type=[project archive type]:type:(-1 0 1 2)' \
  '--process-priority=[process priority]:prio' \
  '--max-threads=[max worker threads]:n' \
  '(-v --verbosity)'{-v,--verbosity}'=[verbosity level]:level' \
  '--cuda-device=[CUDA device]:dev' \
  '(-i --input-file)'{-i,--input-file}'=[input scene file]:file:_files' \
  '(-m --mesh-file)'{-m,--mesh-file}'=[mesh file to texture]:file:_files' \
  '(-o --output-file)'{-o,--output-file}'=[output textured mesh]:file:_files' \
  '--decimate=[mesh decimation factor]:n' \
  '--close-holes=[close holes]:n' \
  '--resolution-level=[image downscale iterations]:n' \
  '--min-resolution=[minimum image resolution]:n' \
  '--outlier-threshold=[remove outlier face textures]:n' \
  '--cost-smoothness-ratio=[patch compactness preference]:n' \
  '--virtual-face-images=[virtual face textures from coplanar triangles]:n' \
  '--global-seam-leveling=[uniform texture patch generation]:n' \
  '--local-seam-leveling=[patch border uniformity]:n' \
  '--texture-size-multiple=[texture size multiplier]:n' \
  '--patch-packing-heuristic=[patch placement strategy]:n' \
  '--empty-color=[color for untextured faces]:n' \
  '--sharpness-weight=[texture sharpness intensity]:n' \
  '--orthographic-image-resolution=[ortho projection resolution]:n' \
  '--ignore-mask-label=[mask label to exclude]:n' \
  '--max-texture-size=[limit texture dimensions]:n' \
  '*:scene:_files' && ret=0

return ret
