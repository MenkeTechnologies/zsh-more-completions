#compdef wavefront wf wave wavefront-cli
# _wavefront — VMware Wavefront wf CLI for managing the Wavefront SaaS observability platform alerts dashboards events sources tags integrations users SLO via Wavefront REST API (vmwareSpectrum team, Python); argparse
# upstream: https://github.com/vmware/wavefront-cli

_wavefront() {
    local -a sub=(
        'alert:alert operations'
        'dashboard:dashboard operations'
        'event:event operations'
        'integration:integration operations'
        'maintenance-window:maintenance window operations'
        'metric:metric operations'
        'source:source operations'
        'tag:tag operations'
        'team:team operations'
        'user:user operations'
        'query:run query'
        'config:show or edit config'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.ini *.yml *.yaml *.json"' \
        '--config=+[config file]:file:_files -g "*.ini *.yml *.yaml *.json"' \
        '--profile=+[name]:str:' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wavefront subcommand' sub ;;
        args)
            case $words[1] in
                query) _arguments \
                    '--start=+[ts]:n:' \
                    '--end=+[ts]:n:' \
                    '--granularity=+[g]:g:(s m h d)' \
                    '--summarization=+[s]:s:(MEAN MEDIAN MIN MAX SUM COUNT LAST FIRST)' \
                    '--strict[strict]' \
                    '*:ts expression:' ;;
                alert) _arguments \
                    '1:action:(create get list update delete clone show snooze unsnooze)' \
                    '*:alert id:' ;;
                dashboard) _arguments \
                    '1:action:(create get list update delete clone export import)' \
                    '*:dashboard id:' ;;
            esac
            ;;
    esac
}

_wavefront "$@"
