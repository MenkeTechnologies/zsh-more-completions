#compdef foamToStarMesh
# Reads an OpenFOAM mesh and writes a PROSTAR (v4) bnd/cel/vrt format

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-scale+[geometry scaling factor - default is 1000 ([m] to [mm])]:factor:' \
  '-noBnd[suppress writing a boundary (.bnd) file]' \
  '-time+[specify a single time value to write]:time:' \
  '-latestTime[select the latest time]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
