#compdef eask
# Documentation: https://man.archlinux.org/search?q=eask
# Reference accessed: 2026-05-16

# Emacs Eask — https://github.com/emacs-eask/cli — `eask` manages Cask-like projects; verbs follow `eask <command>` from Clap.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'init:scaffold Eask project'
      'install:install archives'
      'compile:byte-compile elisp'
    'eval:eval Elisp snippet'
    'exec:exec Emacs batch command'
    'autoloads:generate autoloads'
    'package:build ELPA package'
    'clean:remove artifacts'
  'generate:scaffold templates'
  'recipe:resolve dependency recipe'
  'test:run ert/etc'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--global[use user-global space]' \
  '(*)-q[quiet]' \
  '(*)-v[verbose]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'eask' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
