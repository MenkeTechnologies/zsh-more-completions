#compdef mosdepth
# Documentation: https://man.archlinux.org/search?q=mosdepth
# Reference accessed: 2026-05-16

# Mosdepth: fast BAM/CRAM depth calculator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --threads)'{-t,--threads=}'[decompression threads]:n:' \
  '(-c --chrom)'{-c,--chrom=}'[chromosome to restrict to]:chrom:' \
  '(-b --by)'{-b,--by=}'[BED of regions, or fixed window size]:val:' \
  '(-n --no-per-base)'{-n,--no-per-base}'[do not output per-base depth]' \
  '(-f --fasta)'{-f,--fasta=}'[FASTA reference (CRAM)]:file:_files -g "*.(fa|fasta)"' \
  '--d4[output D4 format]' \
  '(-T --thresholds)'{-T,--thresholds=}'[coverage thresholds (comma list)]:list:' \
  '(-Q --mapq)'{-Q,--mapq=}'[minimum mapping quality]:n:' \
  '(-F --flag)'{-F,--flag=}'[exclude reads with these flags]:n:' \
  '(-i --include-flag)'{-i,--include-flag=}'[include only reads with these flags]:n:' \
  '(-q --quantize)'{-q,--quantize=}'[quantize depth into buckets]:val:' \
  '(-x --fast-mode)'{-x,--fast-mode}'[fast mode (skip per-base)]' \
  '--use-median[report median instead of mean]' \
  '--mapq-window=[ratio bias-corrected depth window]:n:' \
  '--read-groups=[only count reads in these RGs]:list:' \
  '*:output prefix and BAM/CRAM:_files' && ret=0
return ret
