#compdef ff2mpv
# Documentation: https://man.archlinux.org/search?q=ff2mpv
# Reference accessed: 2026-05-16

# ff2mpv (browser extension helper) — shell script forwards URLs to mpv/Celluloid; flags are the common `-q` / `--quiet` used in upstream distribute scripts.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-q,--quiet}'[suppress nonessential output]' \
  '*:media URL:_urls' && ret=0

return ret
