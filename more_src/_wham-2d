#compdef wham-2d
# Documentation: https://simbios.stanford.edu/svn/pymbar/misc/wham-grossfield/doc/doc.pdf
# Weighted Histogram Analysis Method, 2D PMF (Grossfield WHAM)

# Usage: wham-2d Px=[0|pi|val] hist_min_x hist_max_x num_bins_x \
#        Py=[0|pi|val] hist_min_y hist_max_y num_bins_y \
#        tol temperature numpad metadatafile freefile use_mask
local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:argument (Px hist_min_x hist_max_x num_bins_x Py hist_min_y hist_max_y num_bins_y tol temperature numpad metadata free use_mask):_files' && ret=0

return ret
