#compdef build-rdeps
# Documentation: https://manpages.debian.org/build-rdeps
# Source: debian/devscripts scripts/build-rdeps.pl — list build-dependent packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-u --update)'{-u,--update}'[update Sources cache before checking]' \
    '(-s --sudo)'{-s,--sudo}'[update via sudo]' \
    '(-m --print-maintainer)'{-m,--print-maintainer}'[print maintainer per package]' \
    '--distribution=-[distribution to check]:dist:_default' \
    '(--only-devel)--only-main[only check main component]' \
    '(--only-main)--only-devel[only check development distributions]' \
    '*--exclude-component=-[exclude component]:component:(main contrib non-free non-free-firmware universe multiverse restricted)' \
    '--origin=-[origin to filter on]:origin:_default' \
    '--host-arch=-[host architecture]:arch:_default' \
    '--build-arch=-[build architecture]:arch:_default' \
    '--no-arch-all[exclude arch:all packages]' \
    '--no-arch-any[exclude arch:any packages]' \
    '--no-ftbfs[skip checking FTBFS bugs]' \
    '--old[use old non-ceve based scanning]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
    '(-d --debug)'{-d,--debug}'[debug mode]' \
    '*:package:_default' \
    && ret=0

return ret
