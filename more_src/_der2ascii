#compdef der2ascii
# Documentation: https://man.archlinux.org/search?q=der2ascii
# Reference accessed: 2026-05-16

# Zsh completion for der2ascii (DER → PEM text)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:DER input:_files' && ret=0

return ret
