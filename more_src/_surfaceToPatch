#compdef surfaceToPatch
# Reads surface and applies surface regioning to a mesh

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-faceSet+[only repatch the faces in specified faceSet]:name:' \
  '-tol+[search tolerance as fraction of mesh size (default 1e-3)]:scalar:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':surface file:_files' && ret=0

return ret
