#compdef amqp-publish

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--usage[show usage]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-S --server)'{-S,--server}'+[broker host[:port]]:server:_hosts' \
  '--port=[broker port]:port:' \
  '(-u --url)'{-u,--url}'+[broker URL amqp[s]://...]:url:' \
  '--vhost=[virtual host]:vhost:' \
  '--username=[username]:user:' \
  '--password=[password]:pw:' \
  '--ssl[use TLS]' \
  '--cacert=[CA certificate]:file:_files' \
  '--cert=[client certificate]:file:_files' \
  '--key=[client key]:file:_files' \
  '--verify[verify peer]' \
  '--heartbeat=[heartbeat seconds]:sec:' \
  '(-e --exchange)'{-e,--exchange}'+[exchange name]:name:' \
  '(-r --routing-key)'{-r,--routing-key}'+[routing key]:key:' \
  '(-b --body)'{-b,--body}'+[message body]:body:' \
  '(-p --persistent)'{-p,--persistent}'[mark message persistent]' \
  '(-C --content-type)'{-C,--content-type}'+[content type]:type:(text/plain application/json application/xml)' \
  '(-E --content-encoding)'{-E,--content-encoding}'+[content encoding]:enc:' \
  '(-H --header)'{-H,--header}'+[message header key=value]:header:' \
  '--reply-to=[reply-to address]:addr:' && ret=0

return ret
