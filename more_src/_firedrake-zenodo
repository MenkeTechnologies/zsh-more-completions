#compdef firedrake-zenodo
# Documentation: https://www.firedrakeproject.org/zenodo.html
# Firedrake Zenodo integration for reproducible science

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'=[output JSON file of component versions]:file:_files' \
  '(-i --input)'{-i,--input}'=[input JSON file describing components to release]:file:_files' \
  '--release[create a Zenodo release from the components]' \
  '--bibtex=[generate a BibTeX entry for the given DOI]:doi' \
  '--bibtex-file=[file to write BibTeX entry to]:file:_files' \
  '--create-meta-release=[create a meta release JSON file]::file:_files' \
  '--list-meta-records[list available meta release records]' \
  '(-t --title)'{-t,--title}'=[title for the Zenodo release]:title' \
  '--info-file=[file with extra information to attach to the release]:file:_files' \
  '--additional-dois=[additional DOIs to relate to this release]:dois' \
  '--new-version-of=[create a new version of an existing record]:record id' \
  '--ignore-existing-records[ignore existing records when releasing]' \
  '--skip-missing[skip components missing from the input]' \
  '--log[write a log of the operations]' && ret=0

return ret
