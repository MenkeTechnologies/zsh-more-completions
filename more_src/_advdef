#compdef advdef
# Zsh completion for advdef
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-z,--recompress}'[recompress deflate streams]' \
  '-0[store (no compression)]' \
  '-1[fast compression]' \
  '-2[compression with 1 iteration]' \
  '-3[compression with 2 iterations]' \
  '-4[compression with 3 iterations (best)]' \
  {-i,--iter}'[number of extra compression iterations]:iterations:' \
  {-f,--force}'[force recompression even if result is larger]' \
  {-q,--quiet}'[quiet mode]' \
  {-v,--verbose}'[verbose mode]' \
  {-k,--shrink-store}'[keep store method if smaller]' \
  '--help[display help]' \
  '--version[display version]' \
  '*:file:_files -g "*.(png|gz|tgz|svgz|mng|deflate)(-.)"' && ret=0
return ret
