#compdef parallel_rspec
# Documentation: https://github.com/grosser/parallel_tests
# run RSpec tests across multiple CPU cores

local ret=1

_arguments -s -S \
  '-n+[number of parallel processes]:processes' \
  '(-m --multiply-processes)'{-m+,--multiply-processes=}'[multiply default process count]:count' \
  '(-p --pattern)'{-p+,--pattern=}'[run tests matching this regex]:pattern' \
  '--exclude-pattern=[skip tests matching this regex]:pattern' \
  '(-s --single)'{-s+,--single=}'[run matching files in the same process]:pattern' \
  '(-i --isolate)'{-i,--isolate}'[run isolated group alone]' \
  '--only-group=[run only specified group numbers]:group' \
  '--group-by=[group tests by strategy]:type:(found steps scenarios filesize runtime default)' \
  '--serialize-stdout[buffer output until all processes finish]' \
  '--prefix-output-with-test-env-number[prefix output lines with env number]' \
  '--combine-stderr[merge stderr into stdout]' \
  '--runtime-log=[path to previously recorded runtimes]:file:_files' \
  '--verbose[show debugging information]' \
  '(-o --test-options)'{-o+,--test-options=}'[pass options to the test runner]:options' \
  '--suffix=[override default file pattern]:pattern' \
  '(-t --type)'{-t+,--type=}'[test framework]:type:(test rspec cucumber spinach)' \
  '--first-is-1[use 1 as first TEST_ENV_NUMBER instead of empty]' \
  '(-e --exec)'{-e+,--exec=}'[run arbitrary command in parallel]:command' \
  '--fail-fast[stop all groups when one fails]' \
  '--highest-exit-status[return highest exit code encountered]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:spec file:_files' && ret=0

return ret
