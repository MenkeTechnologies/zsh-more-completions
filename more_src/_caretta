#compdef caretta
# _caretta — Groundcover's eBPF Kubernetes service-map agent (per-node DaemonSet that traces TCP/UDP flows via kprobes and exports a service graph to Prometheus)
# upstream: https://github.com/groundcover-com/caretta
# Source: cmd/caretta/caretta.go on tip; no CLI flags — runtime config via env vars (PROMETHEUS_PORT, PROMETHEUS_ENDPOINT, POLL_INTERVAL, RESOLVE_DNS, TRAVERSE_UP_HIERARCHY).

_caretta() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_caretta "$@"
