#compdef cpy
# Documentation: https://github.com/sindresorhus/cpy-cli
# cpy - copy files (from cpy-cli)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-overwrite[do not overwrite destination files]' \
  '--ignore-existing[skip files that already exist at destination]' \
  '--update[overwrite only if source is newer or sizes differ]' \
  '--cwd=[working directory for files]:dir:_files -/' \
  '--base=[base mode for destination paths]:mode:(cwd pattern)' \
  '--rename=[rename copied files]:filename:' \
  '--dot[match files that begin with a period]' \
  '--flat[flatten directory structure into a single directory]' \
  '--dry-run[show files that would be copied without copying]' \
  '--concurrency=[number of concurrent copy operations]:n:' \
  '*:path:_files' && ret=0

return ret
