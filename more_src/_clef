#compdef clef devp2p
# Documentation: upstream docs at geth.ethereum.org/docs/tools/{clef,devp2p}
# Reference accessed: 2026-05-30
# Ethereum go-ethereum (geth) sister-binary R39: clef (account signer)
# + devp2p (DNS/discovery/RLPx tooling). Both ship alongside the
# already-covered geth/abigen binaries.

local curcontext="$curcontext" state line ret=1

case $service in

  clef)
    # ethereum/go-ethereum clef — external signer / account manager.
    local -a _subcmds
    _subcmds=(
      'init:initialize the signer, generate secret storage'
      'attest:attest that a js-file is to be used'
      'setpw:store a credential for a keystore file'
      'delpw:remove a credential for a keystore file'
      'newaccount:create a new account'
      'gendoc:generate documentation about json-rpc format'
      'help:show help for a command'
    )
    _arguments -C -s -S \
      '--loglevel=[log level (default 4)]:level:' \
      '--keystore=[keystore directory]:directory:_directories' \
      '--configdir=[clef configuration directory]:directory:_directories' \
      '--chainid=[chain id for signing (default 1)]:N:' \
      '--lightkdf[reduce key-derivation RAM + CPU usage]' \
      '--nousb[disable USB hardware-wallet monitoring]' \
      '--pcscdpath=[smartcard daemon socket path]:path:_files' \
      '--http.addr=[HTTP-RPC server interface (default localhost)]:host:' \
      '--http.vhosts=[comma-separated virtual hostnames]:hosts:' \
      '--ipcdisable[disable the IPC-RPC server]' \
      '--ipcpath=[IPC socket/pipe filename]:file:_files' \
      '--http[enable the HTTP-RPC server]' \
      '--http.port=[HTTP-RPC server port (default 8550)]:port:' \
      '--signersecret=[encrypted master-seed file]:file:_files' \
      '--4bytedb-custom=[file for writing new 4byte-identifiers]:file:_files' \
      '--auditlog=[audit log file (default audit.log)]:file:_files' \
      '--rules=[auto-authorize rule file]:file:_files' \
      '--stdio-ui[use STDIN/STDOUT for external UI]' \
      '--stdio-ui-test[test interface between Clef and UI]' \
      '--advanced[issue warnings instead of rejections for suspicious requests]' \
      '--suppress-bootwarn[suppress boot warning]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'clef subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

  devp2p)
    # ethereum/go-ethereum devp2p — networking + discovery utilities.
    local -a _subcmds
    _subcmds=(
      'enrdump:decode and display Ethereum Node Records (base64)'
      'key:node key management (generate/to-enode)'
      'dns:DNS discovery tree management (sign/sync/to-cloudflare/to-route53)'
      'nodeset:node set utilities (info/filter)'
      'discv4:Discovery v4 protocol (ping/resolve/crawl)'
      'discv5:Discovery v5 protocol (ping/resolve/listen/crawl/test)'
      'rlpx:RLPx protocol tests (eth-test/eth66-test)'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'devp2p subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          key)
            _arguments \
              '1:key action:(generate to-enode)' \
              '-ip+[IP address]:ip:' \
              '-tcp+[TCP port]:port:' \
              '*:file:_files' && ret=0
            ;;
          dns)
            _arguments \
              '1:dns action:(sign sync to-cloudflare to-route53)' \
              '*:directory or URL:_directories' && ret=0
            ;;
          nodeset)
            _arguments \
              '1:nodeset action:(info filter)' \
              '-limit+[max nodes]:N:' \
              '-ip+[ip filter]:ip:' \
              '-min-age+[minimum age]:duration:' \
              '-eth-network[require eth network]' \
              '-les-server[require LES server]' \
              '-snap[require snap protocol]' \
              '*:nodes.json:_files -g "*.json"' && ret=0
            ;;
          discv4)
            _arguments \
              '1:discv4 action:(ping resolve crawl)' \
              '*:enode/ENR or nodes.json:' && ret=0
            ;;
          discv5)
            _arguments \
              '1:discv5 action:(ping resolve listen crawl test)' \
              '-listen1+[first listen address]:ip:' \
              '-listen2+[second listen address]:ip:' \
              '*:ENR or nodes.json:' && ret=0
            ;;
          rlpx)
            _arguments \
              '1:rlpx action:(eth-test eth66-test)' \
              '*:args:_files' && ret=0
            ;;
          enrdump)
            _arguments '1:base64 ENR:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
