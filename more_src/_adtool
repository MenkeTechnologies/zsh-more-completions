#compdef adtool
# Documentation: PBIS adtool
# Source: josephholsten/pbis lwadtool/libadtool/cli.c (master) — PBIS Active Directory CLI (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a actions=(
    'add-to-group:add a user/group to a security group'
    'remove-from-group:remove a user/group from a security group'
    'delete-object:delete an object'
    'delete-cell:delete a cell'
    'disable-computer:disable computer account'
    'disable-user:disable user account'
    'enable-computer:enable computer account'
    'enable-user:enable user account'
    'lookup-object:retrieve object attributes'
    'move-object:move or rename an object'
    'new-computer:create a new computer object'
    'new-group:create a new global security group'
    'new-ou:create a new organizational unit'
    'new-user:create a new user account'
    'reset-computer-password:reset computer password'
    'reset-user-password:reset user password'
    'search-computer:search for computer objects'
    'search-group:search for group objects'
    'search-object:LDAP search any object'
    'search-ou:search organizational units'
    'search-user:search users'
    'set-attr:set or un-set attribute'
    'unlock-account:unlock user or computer account'
)

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-a --action)'{-a+,--action=}'[action]:action:->action' \
    '(-d --domain)'{-d+,--domain=}'[AD domain DNS name]:domain:_default' \
    '(-r --resource)'{-r+,--resource=}'[domain controller]:dc:_hosts' \
    '(-l --logon-as)'{-l+,--logon-as=}'[logon username]:user:_users' \
    '(-x --password)'{-x+,--password=}'[logon password]:password:_default' \
    '(-k --keytab)'{-k+,--keytab=}'[keytab file]:file:_files' \
    '-n+[search base DN]:dn:_default' \
    '-t[print DN only (terse)]' \
    '--no-password-expires[password does not expire]' \
    '--force[force destructive action]' \
    '*::action args:_default' \
    && ret=0

case $state in
    action) _describe -t actions 'adtool action' actions && ret=0 ;;
esac

return ret
