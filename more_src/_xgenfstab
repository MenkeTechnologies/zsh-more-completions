#compdef xgenfstab
# Documentation: https://man.voidlinux.org/xtools.1
# generate an fstab for a given root (xtools)

local ret=1

_arguments -s -S \
  '-p[exclude pseudofs mounts]' \
  '-P[include pseudofs mounts]' \
  '-t[use given source type]:type:' \
  '-L[use labels for source identifiers]' \
  '-U[use UUIDs for source identifiers]' \
  '*:package:' && ret=0

return ret
