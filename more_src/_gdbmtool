#compdef gdbmtool
# Documentation: gdbmtool --help (GNU GDBM)
# Source: examine / modify GDBM databases interactively.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--usage[short usage]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-N --norc)'{-N,--norc}'[do not read .gdbmtoolrc]' \
    '(-T --timing)'{-T,--timing}'[print timing after each command]' \
    '(-b --block-size)'{-b+,--block-size=}'[block size]:bytes:' \
    '(-c --cache-size)'{-c+,--cache-size=}'[cache size]:n:' \
    '(-d --db-descriptor)'{-d+,--db-descriptor=}'[open at given file descriptor]:fd:' \
    '(-f --file)'{-f+,--file=}'[read commands from FILE]:file:_files' \
    '(-l --no-lock)'{-l,--no-lock}'[disable file locking]' \
    '(-m --no-mmap)'{-m,--no-mmap}'[do not use mmap]' \
    '(-n --newdb)'{-n,--newdb}'[create database]' \
    '(-q --quiet)'{-q,--quiet}'[suppress banner]' \
    '(-r --read-only)'{-r,--read-only}'[open read-only]' \
    '(-s --synchronize)'{-s,--synchronize}'[synchronize after each write]' \
    '(-t --trace)'{-t,--trace}'[enable trace mode]' \
    '(-x --extended --numsync)'{-x,--extended,--numsync}'[extended numsync format]' \
    '1:gdbm file:_files' \
    '*:command:' \
    && ret=0

return ret
