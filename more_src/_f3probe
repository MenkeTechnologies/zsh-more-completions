#compdef f3probe

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--time-ops[time operations]' \
  '--no-time-ops[do not time ops]' \
  '--debug-type[debug fake type]' \
  '--min-memory[min memory mode]' \
  '--no-min-memory[no min memory]' \
  '--destructive[destructive test]' \
  '--no-destructive[non-destructive]' \
  '--block-order=+[block order]:n:' \
  '--reset-type=+[reset type]:type:' \
  '--probe-time-limit=+[time limit sec]:sec:' \
  '--show-blocks[show block info]' \
  '--export-path=+[export path]:dir:_files -/' \
  '--import-path=+[import path]:dir:_files -/' \
  '*:device:_files' && ret=0

return ret
