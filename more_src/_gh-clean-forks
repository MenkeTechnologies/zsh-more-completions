#compdef gh-clean-forks
# Documentation: https://man.archlinux.org/search?q=gh-clean-forks
# Reference accessed: 2026-05-16

_gh-clean-forks() {
    _arguments \
        '--dry-run[Preview changes without deleting]' \
        '--force[Delete all forks, including those with open PRs]' \
        '--help[Show help]'
}

_gh-clean-forks "$@"
