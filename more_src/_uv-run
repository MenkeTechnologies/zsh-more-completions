#compdef uv-run
# _uv-run — uv script/tool runner (astral-sh/uv)
# upstream: https://github.com/astral-sh/uv

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--with=[additional package]:package:' \
  '--with-requirements=[requirements file]:file:_files' \
  '--isolated[run in isolated environment]' \
  '--no-project[ignore project requirements]' \
  '--python=[Python version]:version:' \
  '--package=[run from this package]:package:' \
  '--extra=[extra to include]:extra:' \
  '--all-extras[include all extras]' \
  '--no-dev[exclude dev dependencies]' \
  '--frozen[use existing lockfile]' \
  '--locked[assert lockfile is up-to-date]' \
  '--quiet[quiet output]' \
  '--verbose[verbose output]' \
  '*:command:_command_names -e'
