#compdef radcrypt
# _radcrypt — FreeRADIUS radcrypt (small CLI that encrypts a cleartext password the same way the RADIUS server does so administrators can store offline hashes; -e encrypt mode, -c crypt mode, -s salt prefix, -d dictionary dir, -h help, -v version; positional argument is the password to hash)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radcrypt.c on tip.

_radcrypt() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-e[encrypt]' \
        '-c[crypt]' \
        '-s+[salt prefix]:salt:' \
        '-d+[dictionary dir]:dir:_files -/' \
        '1:password:'
}

_radcrypt "$@"
