#compdef crafty
# Documentation: https://craftychess.com/documentation/craftydoc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Crafty chess engine is driven primarily through interactive commands
# (see crafty.doc). The only documented startup argument is "xboard"
# to indicate it is being invoked through xboard(6). Paths come from
# environment variables (CRAFTY_BOOK_PATH etc.) rather than CLI flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*: :(xboard)' && ret=0

return ret
