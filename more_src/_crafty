#compdef crafty
# Documentation: https://man.archlinux.org/search?q=crafty
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[command]:cmd:' \
  '-l+[log file]:file:_files' \
  '-n+[hash table size MB]:mb:' \
  '*:cmd:' && ret=0

return ret
