#compdef compare_octrees
# Documentation: https://github.com/OctoMap/octomap/blob/devel/octomap/src/compare_octrees.cpp
# Compare two OctoMap octrees for accuracy and compression

local ret=1

_arguments -s -S \
  '-h[show help]' \
  ':first octree:_files -g "*.ot"' \
  ':second octree:_files -g "*.ot"' && ret=0

return ret
