#compdef trivy
# _trivy-bin — Trivy comprehensive security scanner (Aqua Security, Go); scan containers, filesystems, repos, IaC for vulns/secrets/misconfigs
# upstream: https://github.com/aquasecurity/trivy

_trivy-bin() {
    local -a sub=(
        'aws:scan AWS account'
        'config:scan IaC config files'
        'convert:convert previous scan report'
        'filesystem:scan local filesystem'
        'fs:alias for filesystem'
        'image:scan container image'
        'i:alias for image'
        'kubernetes:scan k8s cluster'
        'k8s:alias for kubernetes'
        'module:manage Trivy modules'
        'plugin:manage plugins'
        'repository:scan git repo'
        'repo:alias for repository'
        'rootfs:scan rootfs'
        'sbom:scan SBOM'
        'server:run as scanner server'
        'vm:scan VM image'
        'completion:print shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--cache-dir+[cache dir]:dir:_files -/' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--insecure[skip TLS verify]' \
        '--timeout+[scan timeout]:duration:' \
        '--no-progress[no progress]' \
        '--scanners+[scanners]:scanners:(vuln misconfig secret license)' \
        '--severity+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--format+[output format]:fmt:(table json sarif cyclonedx spdx spdx-json github cosign-vuln)' \
        '--output+[output file]:file:_files' \
        '--exit-code+[exit code on vuln]:n:' \
        '--ignorefile+[ignore file]:file:_files' \
        '--ignore-unfixed[ignore unfixed vulns]' \
        '--list-all-pkgs[list all packages]' \
        '--offline-scan[offline scan]' \
        '--skip-db-update[skip db update]' \
        '--db-repository+[trivy-db repo]:repo:' \
        '--show-suppressed[show suppressed]' \
        '--token+[trivy server token]:str:' \
        '--server+[trivy server URL]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trivy subcommand' sub ;;
        args)
            case $words[1] in
                image|i|fs|filesystem|repository|repo|rootfs|sbom|vm) _arguments '*:target:' ;;
                kubernetes|k8s) _arguments \
                    '--namespace+[k8s namespace]:namespace:' \
                    '--include-namespaces+[include namespaces]:str:' \
                    '--exclude-namespaces+[exclude namespaces]:str:' \
                    '--include-kinds+[include kinds]:kinds:' \
                    '--exclude-kinds+[exclude kinds]:kinds:' \
                    '*:resource:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_trivy-bin "$@"
