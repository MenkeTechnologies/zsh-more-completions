#compdef alectryon
# Documentation: source-direct extraction from upstream
# cpitclaudel/alectryon alectryon/cli.py argparse `parser.add_argument(...)`
# calls grouped by `parser.add_argument_group(...)` blocks for
# input/output configuration, cache, HTML output, LaTeX output,
# Coq subprocess args, leanInk subprocess args, warnings, and
# debug.
# Reference accessed: 2026-05-30 via gh api.
# alectryon R139b — Coq/Lean4 literate-programming and proof-state
# visualization tool by Clément Pit-Claudel. Converts annotated Coq
# (Rocq) source files into HTML or LaTeX with interactive
# expandable proof-state goals at each step.

# Frontend / backend enums derived from upstream
# `FRONTEND_CHOICES = sorted(PIPELINES.keys())` and
# `BACKEND_CHOICES = sorted(set(b for _, bs in PIPELINES.items() for b in bs))`
# values - listing the documented current entries; runtime
# additions are accepted by upstream argparse via choices=[...].
local -a _alectryon_frontends
_alectryon_frontends=(coq coq+rst coqdoc rst lean3 lean3+rst lean4 lean4+rst dafny dafny+rst json)
local -a _alectryon_backends
_alectryon_backends=(html latex html-snippets snippets-html snippets-latex rst latex-snippets webpage json json-snippets lint)

_arguments -s -S \
  '--version[print version and exit]' \
  '*:input files:_files' \
  '--stdin-filename=[name of file passed on stdin]:name:' \
  '--frontend=[input frontend (auto-detected from extension by default)]:frontend:('"${_alectryon_frontends[*]}"')' \
  '--backend=[output backend (auto-detected from extension by default)]:backend:('"${_alectryon_backends[*]}"')' \
  '(-o --output)'{-o+,--output=}'[output file (default: computed from INPUT)]:file:_files' \
  '--output-directory=[output directory (default: same as each INPUT)]:dir:_directories' \
  '--copy-assets=[where to copy assets]:mode:(no symlink copy)' \
  '--pygments-style=[Pygments style for syntax highlighting]:style:' \
  '--mark-point=[line column point-marker to insert]:line column:' \
  '--no-header[omit the generated-by-alectryon header]' \
  '--no-version-numbers[omit version-number stamps from output]' \
  '--body-only[emit only the body fragment (for embedding in other documents)]' \
  '--cache-directory=[cache directory (default: same as INPUT)]:dir:_directories' \
  '--cache-compression=[compress cache files]:format:(none gz xz)' \
  '--webpage-style=[HTML webpage style preset]:style:(centered floating windowed plain)' \
  '--html-minification[minify HTML output]' \
  '--html-dialect=[HTML dialect]:dialect:(html4 html5)' \
  '--latex-dialect=[LaTeX engine dialect]:dialect:(pdflatex xelatex lualatex)' \
  '*--sertop-arg=[pass extra argument to sertop (Coq serializer; repeatable)]:arg:' \
  '*--rocq-arg=[pass extra argument to rocq/coqc (repeatable)]:arg:' \
  '*--coqc-arg=[synonym for --rocq-arg]:arg:' \
  '*'{-I+,--ml-include-path=}'[OCaml include path passed to Coq (repeatable)]:dir:_directories' \
  '*'{-Q+,--load-path=}'[Coq load path (logical name = dir; repeatable)]:logical_name=dir:' \
  '*'{-R+,--rec-load-path=}'[Coq recursive load path (repeatable)]:logical_name=dir:' \
  '--lake=[Lake file path for leanInk]:lake-file:_files' \
  '--long-line-threshold=[warn about lines longer than this]:n:' \
  '--expect-unexpected[do not exit non-zero on unexpected output]' \
  '--debug[enable debug logging]' \
  '--traceback[print full Python tracebacks on errors]'
