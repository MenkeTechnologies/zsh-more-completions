#compdef mqbrokercontainer
# Documentation: https://rocketmq.apache.org/docs/4.x/deployment/01deploy/
# Apache RocketMQ shared broker container startup

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-n --namesrvAddr)'{-n,--namesrvAddr}'=[name server address list]:addr' \
  '(-c --configFile)'{-c,--configFile}'=[config file for shared broker]:file:_files' \
  '(-b --brokerConfigFiles)'{-b,--brokerConfigFiles}'=[path of broker config files, split by :]:files:_files' \
  '(-p --printConfigItem)'{-p,--printConfigItem}'[print all config item]' \
  '(-m --printImportantConfig)'{-m,--printImportantConfig}'[print important config item]' && ret=0

return ret
