#compdef noisetorch
# _noisetorch — PulseAudio noise suppression (RNNoise) (noisetorch/NoiseTorch)
# upstream: https://github.com/noisetorch/NoiseTorch
# Flags from cli.go (stdlib flag).

_noisetorch() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-log[print debugging output to stdout]'
        '-s+[source/sink device ID to use]:device:'
        '-i[load suppressor for input]'
        '-o[load suppressor for output]'
        '-u[unload suppressor]'
        '-t+[voice activation threshold (0-95)]:threshold:'
        '-l[list available PulseAudio devices]'
        '-c[check for an available update]'
    )
    _arguments -s $args
}

_noisetorch "$@"
