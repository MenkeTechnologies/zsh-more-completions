#compdef dexter
# Documentation: https://man.archlinux.org/search?q=dexter
# Reference accessed: 2026-05-16

# Zsh completion for dexter PostgreSQL index recommender (ankane/dexter, Slop)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--input-format[input format for log parsing]:format' \
  '--pg-stat-activity[use pg_stat_activity as query source]' \
  '--pg-stat-statements[use pg_stat_statements as query source]' \
  '--stdin[read queries from stdin]' \
  '(-s --statement)'{-s,--statement}'[one-off SQL statement (repeatable)]:sql' \
  '(-d --dbname)'{-d,--dbname}'[database name]:dbname' \
  '(-h --host)'{-h,--host}'[database host]:host' \
  '(-p --port)'{-p,--port}'[database port]:port' \
  '(-U --username)'{-U,--username}'[database user]:user' \
  '--interval[seconds between processing cycles]:seconds' \
  '--min-calls[minimum statement call count]:n' \
  '--min-time[minimum statement time in minutes]:minutes' \
  '--analyze[analyze stale tables]' \
  '--create[create recommended indexes]' \
  '--enable-hypopg[enable HypoPG extension]' \
  '--exclude[table to exclude (repeatable)]:table' \
  '--include[only include tables matching pattern]:pattern' \
  '--tablespace[tablespace for new indexes]:tspc' \
  '--non-concurrently[create indexes without CONCURRENTLY]' \
  '--log-level[log level]:level:(error info debug debug2 debug3)' \
  '--log-sql[log SQL]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--help[show help]' \
  '*:log file or SQL file:_files' && ret=0

return ret
