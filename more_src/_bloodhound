#compdef bloodhound
# Documentation: https://github.com/rsherstnev/zshcompletions/blob/master/_bloodhound
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: https://github.com/rsherstnev/zshcompletions/blob/104351539ca29288a402ade731889a8824bb72aa/_bloodhound
# Repository: rsherstnev/zshcompletions (_bloodhound)

_bloodhound() {
    local state

    _arguments \
        '1: :->command' \
        '*: :->args' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'download:Загрузить Docker Compose файл'
                'update:Обновить Docker Compose файл'
                'create:Создать инфраструктуру (образы, контейнеры, тома, сеть) без запуска'
                'start:Запустить инфраструктуру (образы, контейнеры, тома, сеть)'
                'stop:Остановить инфраструктуру (образы, контейнеры, тома, сеть)'
                'remove:Удалить инфраструктуру (образы, контейнеры, тома, сеть)'
            )
            _describe -t commands 'command' commands
            ;;
        (args)
            case $words[2] in
                (download|update|create|start|stop|remove)
                    # Нет дополнительных аргументов для этих команд
                    ;;
            esac
            ;;
    esac
}

_bloodhound "$@"
