#compdef git-changelog

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-t --template)'{-t,--template}'[template to use]:template:(keepachangelog angular)' \
  '(-s --convention)'{-s,--convention}'[commit message convention]:convention:(conventional angular atom basic)' \
  '(-b --bump)'{-b,--bump}'[bump version]:bump:(auto major minor patch)' \
  '(-r --repository)'{-r,--repository}'[repository path]:path:_directories' \
  '--filter-commits[commit filter pattern]:pattern' \
  '--parse-refs[parse provider references in commit messages]' \
  '--parse-trailers[parse git trailers in commit messages]' \
  '--version-regex[regex to match version tags]:regex' \
  '(-i --in-place)'{-i,--in-place}'[update changelog in-place]' \
  '--bump-to-version[bump to specific version]:version' \
  '(-j --jinja-context)'{-j,--jinja-context}'[additional Jinja2 context]:context' && ret=0

return ret
