#compdef cf

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'login:log in'
  'logout:log out'
  'target:set target org/space'
  'api:set/show CF API endpoint'
  'auth:authenticate non-interactively'
  'passwd:change password'
  'help:show help'
  'version:show version'
  'push:push application'
  'apps:list apps in target space'
  'app:show app health and status'
  'restart:restart app'
  'restage:restage app'
  'rs:alias for restage'
  'stop:stop app'
  'start:start app'
  'restart-app-instance:restart specific instance'
  'scale:change app instance count or memory/disk'
  'logs:tail or view recent app logs'
  'events:show recent app events'
  'files:show files in app container (deprecated)'
  'env:show app environment variables'
  'set-env:set environment variable'
  'unset-env:unset environment variable'
  'restart-app-instance:restart specific instance'
  'delete:delete app'
  'rename:rename app'
  'copy-source:copy source from one app to another'
  'create-app-manifest:create manifest from existing app'
  'apply-manifest:apply manifest to space'
  'marketplace:list available services'
  'm:alias for marketplace'
  'services:list service instances'
  's:alias for services'
  'service:show service instance details'
  'create-service:create service instance'
  'cs:alias for create-service'
  'update-service:update service instance'
  'delete-service:delete service instance'
  'ds:alias for delete-service'
  'rename-service:rename service instance'
  'create-service-key:create service key'
  'delete-service-key:delete service key'
  'service-keys:list service keys'
  'service-key:show service key details'
  'bind-service:bind service to app'
  'bs:alias for bind-service'
  'unbind-service:unbind service from app'
  'us:alias for unbind-service'
  'bind-route-service:bind route service'
  'unbind-route-service:unbind route service'
  'create-user-provided-service:create UPS'
  'cups:alias for create-user-provided-service'
  'update-user-provided-service:update UPS'
  'uups:alias for update-user-provided-service'
  'orgs:list organizations'
  'o:alias for orgs'
  'org:show org details'
  'create-org:create org'
  'delete-org:delete org'
  'rename-org:rename org'
  'org-users:list users in org'
  'set-org-role:assign org role'
  'unset-org-role:remove org role'
  'spaces:list spaces in target org'
  'space:show space details'
  'create-space:create space'
  'delete-space:delete space'
  'rename-space:rename space'
  'space-users:list users in space'
  'set-space-role:assign space role'
  'unset-space-role:remove space role'
  'allow-space-ssh:allow SSH for space apps'
  'disallow-space-ssh:disallow SSH for space apps'
  'space-ssh-allowed:show SSH allowed status for space'
  'enable-ssh:enable SSH for app'
  'disable-ssh:disable SSH for app'
  'ssh:start SSH session into app instance'
  'ssh-enabled:show SSH-enabled status for app'
  'create-shared-domain:create shared domain'
  'create-private-domain:create private domain'
  'delete-shared-domain:delete shared domain'
  'delete-private-domain:delete private domain'
  'domains:list domains'
  'share-private-domain:share private domain'
  'unshare-private-domain:unshare private domain'
  'create-route:create route'
  'map-route:map route to app'
  'unmap-route:unmap route from app'
  'delete-route:delete route'
  'routes:list routes'
  'add-network-policy:add network policy'
  'remove-network-policy:remove network policy'
  'network-policies:list network policies'
  'buildpacks:list buildpacks'
  'create-buildpack:create buildpack'
  'update-buildpack:update buildpack'
  'rename-buildpack:rename buildpack'
  'delete-buildpack:delete buildpack'
  'feature-flag:show feature flag'
  'feature-flags:list feature flags'
  'enable-feature-flag:enable feature flag'
  'disable-feature-flag:disable feature flag'
  'set-label:add metadata label'
  'unset-label:remove metadata label'
  'labels:list metadata labels'
  'curl:make API call'
  'oauth-token:show OAuth token'
  'config:write CLI config option'
  'plugins:list installed plugins'
  'install-plugin:install a plugin'
  'uninstall-plugin:uninstall a plugin'
  'add-plugin-repo:add plugin repository'
  'remove-plugin-repo:remove plugin repository'
  'list-plugin-repos:list plugin repositories'
  'repo-plugins:list plugins in repository'
  'sidecar:manage app sidecar'
  'sidecars:list app sidecars'
  'create-sidecar:create sidecar'
  'delete-sidecar:delete sidecar'
  'isolation-segments:list isolation segments'
  'tasks:list app tasks'
  'run-task:run a one-off task in app'
  'terminate-task:terminate a task'
  'revisions:list app revisions'
  'rollback:roll back to previous revision'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*--no-color[disable color]' \
  '*--verbose[verbose output]' \
  '*--trace=[trace HTTP]:dest:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'cf subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          {-a+,--api=}'[API endpoint]:url:' \
          {-u+,--username=}'[username]:user:_users' \
          {-p+,--password=}'[password]:password:' \
          {-o+,--org=}'[org]:org:' \
          {-s+,--space=}'[space]:space:' \
          '--sso[SSO login]' \
          '--sso-passcode=[SSO passcode]:code:' \
          '--skip-ssl-validation[skip SSL validation]' && ret=0
        ;;
      (push)
        _arguments \
          {-b+,--buildpack=}'[buildpack name]:buildpack:' \
          {-c+,--start-command=}'[start command]:cmd:' \
          {-d+,--domain=}'[domain]:domain:' \
          {-f+,--manifest=}'[manifest file]:file:_files -g "*.(yml|yaml)"' \
          {-i+,--instances=}'[number of instances]:n:' \
          {-k+,--disk=}'[disk limit]:size:' \
          {-m+,--memory=}'[memory limit]:size:' \
          {-n+,--hostname=}'[hostname]:host:' \
          '--no-hostname[skip hostname]' \
          '--no-manifest[skip manifest]' \
          '--no-route[skip route]' \
          '--no-start[do not start after push]' \
          {-p+,--path=}'[path to upload]:path:_files -/' \
          {-s+,--stack=}'[stack name]:stack:' \
          {-t+,--app-start-timeout=}'[start timeout (sec)]:secs:' \
          {-u+,--health-check-type=}'[health check]:type:(port http none process)' \
          {-v+,--vars-file=}'[vars file]:file:_files -g "*.(yml|yaml)"' \
          '--strategy=[deployment strategy]:strategy:(rolling canary)' \
          '--no-wait[do not wait]' \
          '--random-route[random route]' && ret=0
        ;;
      (target)
        _arguments \
          {-o+,--organization=}'[org]:org:' \
          {-s+,--space=}'[space]:space:' && ret=0
        ;;
      (logs)
        _arguments \
          '--recent[show recent logs]' \
          '*:app:' && ret=0
        ;;
      (scale)
        _arguments \
          {-i+,--instances=}'[number of instances]:n:' \
          {-k+,--disk=}'[disk limit]:size:' \
          {-m+,--memory=}'[memory limit]:size:' \
          {-f,--force}'[force restart]' \
          '--process=[process type]:type:' \
          '*:app:' && ret=0
        ;;
      (curl)
        _arguments \
          {-X+,--method=}'[HTTP method]:method:(GET POST PUT DELETE PATCH)' \
          {-H+,--header=}'[HTTP header]:header:' \
          '*-d+[data]:data:' \
          '--output=[output file]:file:_files' \
          '*:URI:' && ret=0
        ;;
    esac
    ;;
esac

return ret
