#compdef pandoc-secnos
# Documentation: https://github.com/tomduck/pandoc-secnos
# pandoc-secnos: a Pandoc filter for numbering sections and section references

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version and exit]' \
  '--pandocversion=[the pandoc version]:version:' \
  '1:format:' && ret=0

return ret
