#compdef dottydoc
# Documentation: https://docs.scala-lang.org/scala3/guides/scaladoc/settings.html
# Scala 3 (Dotty) API documentation generator

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[show help]' \
  '-version[show version]' \
  '-d+[destination for generated documentation]:directory:_files -/' \
  '-classpath+[specify where to find user class files]:classpath:_files' \
  '-project+[the name of the project]:name:' \
  '-project-version+[the current version of your project]:version:' \
  '-project-logo+[the logo of your project]:file:_files' \
  '-project-footer+[the string message that appears in a footer section]:text:' \
  '-comment-syntax+[the styling language used for parsing comments]:syntax:(markdown wiki)' \
  '-revision+[revision (branch or ref) used to build project]:revision:' \
  '-source-links+[mapping between file in documentation and code repository]:mapping:' \
  '-external-mappings+[mapping between regexes and external documentation]:mapping:' \
  '-social-links+[links to social sites]:links:' \
  '-skip-by-id+[identifiers of packages or top-level classes to skip]:id:' \
  '-skip-by-regex+[regexes matching names of packages or classes to skip]:regex:' \
  '-doc-root-content+[file from which the root package documentation should be imported]:file:_files' \
  '-author[add authors from @author annotation to generated documentation]' \
  '-groups[group similar functions together based on the @group annotation]' \
  '-private[show all types and members, not just public and protected]' \
  '-doc-canonical-base-url+[base URL to use as prefix for canonical URLs]:url:' \
  '-siteroot+[directory containing static files for documentation]:directory:_files -/' \
  '-no-link-warnings[suppress warnings for ambiguous or incorrect links]' \
  '-versions-dictionary-url+[URL pointing to a JSON version dictionary]:url:' \
  '-snippet-compiler+[configure snippet type checking]:mode:(compile nocompile fail)' \
  '-scastie-configuration+[additional sbt configuration for Scastie snippets]:config:' \
  '-dynamic-side-menu[generate the side menu dynamically in browser]' \
  '*:tasty file:_files' && ret=0

return ret
