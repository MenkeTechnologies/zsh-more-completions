#compdef scapy3k

# Scapy3k: Python 3 fork of Scapy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c[run a script]:file:_files -g "*.py"' \
  '-C[do not run config file]' \
  '-d[debug level (-d, -dd, -ddd)]' \
  '-H[no startup banner]' \
  '-i[interactive (default)]' \
  '-l[log file]:file:_files' \
  '-P[disable global config files]' \
  '-s[use system installed]' \
  '*::scapy3k args:_files' && ret=0
return ret
