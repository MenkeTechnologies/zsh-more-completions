#compdef karakeep
# Documentation: https://github.com/karakeep-app/karakeep/tree/main/apps/cli/src
# Reference accessed: 2026-05-19
# Verified: upstream CLI source (commander program/commands) at the URL above.

# karakeep: CLI for the Karakeep API (npm @karakeep/cli).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--api-key=[API key to interact with the API]:key:' \
  '--server-addr=[address of the server to connect to]:addr:' \
  '--json[output the result as JSON]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'admin:admin commands'
      'auth:authentication commands'
      'bookmarks:manipulating bookmarks'
      'highlights:manipulating highlights'
      'lists:manipulating lists'
      'tags:manipulating tags'
      'whoami:info about the owner of the API key'
      'migrate:migrate data'
      'wipe:wipe data'
      'dump:dump data'
    )
    _describe -t commands 'karakeep command' commands && ret=0
    ;;
  args)
    case $line[1] in
      bookmarks)
        local -a b=(
          'add:create a new bookmark'
          'get:fetch information about a bookmark'
          'update:update a bookmark'
          'update-tags:update tags on a bookmark'
          'list:list all bookmarks'
          'search:search bookmarks'
          'delete:delete a bookmark'
        )
        _describe -t commands 'bookmarks subcommand' b && ret=0
        ;;
      lists)
        local -a l=(
          'list:list all lists'
          'create:create a list'
          'delete:delete a list'
          'get:get a list'
          'add-bookmark:add a bookmark to a list'
          'remove-bookmark:remove a bookmark from a list'
        )
        _describe -t commands 'lists subcommand' l && ret=0
        ;;
      tags)
        local -a t=(
          'list:list all tags'
          'get:get a tag'
          'merge:merge tags'
          'delete:delete a tag'
        )
        _describe -t commands 'tags subcommand' t && ret=0
        ;;
    esac
    ;;
esac

return ret
