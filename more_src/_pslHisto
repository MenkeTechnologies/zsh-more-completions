#compdef pslHisto
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: collect counts on PSL alignments for making histograms

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-multiOnly[omit queries with only one alignment]' \
  '-nonZero[omit queries with zero values]' \
  ':what:(alignsPerQuery coverSpread idSpread)' \
  ':in psl:_files' \
  ':out histo:_files' && ret=0

return ret
