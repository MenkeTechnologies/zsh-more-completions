#compdef gitbook
# Documentation: https://man.archlinux.org/search?q=gitbook
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'ls:list installed versions'
  'current:show current version'
  'ls-remote:list remote versions'
  'fetch:install a version'
  'alias:set version alias'
  'uninstall:uninstall version'
  'update:update tag'
  'build:build a book'
  'serve:serve as website'
  'install:install plugin deps'
  'parse:parse and debug'
  'init:scaffold book'
  'pdf:build PDF'
  'epub:build EPUB'
  'mobi:build MOBI'
  'help:show help'
)

_arguments -C \
  '(-v --gitbook)'{-v,--gitbook}'=[gitbook version]:version:' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-V --version)'{-V,--version}'[show versions]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'gitbook subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (build|serve|pdf|epub|mobi|init|parse|install)
        _arguments \
          '--log=[log level]:level:(debug info warn error disabled)' \
          '--format=[format]:fmt:(website json ebook)' \
          '--timing[show timings]' \
          '--port=[port]:port:' \
          '--lrport=[livereload port]:port:' \
          '--watch[watch]' \
          '--no-watch[no watch]' \
          '--live[livereload]' \
          '--no-live[no livereload]' \
          '--open[open in browser]' \
          '--no-open[no open]' \
          '--browser=[browser]:browser:' \
          '*:book or output:_files -/' && ret=0 ;;
    esac
    ;;
esac

return ret
