#compdef autokey-run
# Documentation: https://man.archlinux.org/search?q=autokey-run
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)--help[show help]' \
  '(-s --script)'{-s,--script=}'[run script]:name:' \
  '(-p --phrase)'{-p,--phrase=}'[paste phrase]:name:' \
  '(-f --folder)'{-f,--folder=}'[folder popup menu]:name:'
