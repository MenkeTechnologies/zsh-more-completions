#compdef autokey-run
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/autokey-run.1.html
# Reference accessed: 2026-05-17
# Verified: AutoKey upstream autokey-run(1) manpage. Real flags:
# -l/--script=NAME, -p/--phrase=NAME, -f/--folder=NAME, -h/--help.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -s/--script (real short letter is -l, not -s).

local ret=1
_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --script)'{-l+,--script=}'[run script by name]:name:' \
  '(-p --phrase)'{-p+,--phrase=}'[paste phrase by name]:name:' \
  '(-f --folder)'{-f+,--folder=}'[show folder popup menu]:name:' && ret=0
return ret
