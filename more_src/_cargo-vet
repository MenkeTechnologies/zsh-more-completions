#compdef cargo-vet

# Zsh completion for cargo-vet (Rust supply chain auditing)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--store-dir=[directory for vet store]:directory:_directories' \
  '--frozen[require Cargo.lock is up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check that all dependencies are vetted'
      'suggest:suggest audits for unvetted dependencies'
      'init:initialize cargo-vet for this project'
      'inspect:inspect the source of a crate'
      'diff:show diff between two versions of a crate'
      'certify:certify a crate as audited'
      'import:import audits from a peer'
      'trust:trust a publisher for a crate'
      'regenerate:regenerate exemptions and imports'
      'add-exemption:add an exemption entry'
      'record-violation:record a violation for a crate'
      'fmt:format supply-chain directory'
      'prune:remove unused entries'
      'aggregate:fetch and merge audits from multiple sources'
      'dump-graph:dump dependency graph as JSON'
      'gc:garbage collect unused entries'
    )
    _describe -t commands 'cargo-vet command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      certify)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--who=[identity of auditor]:who' \
          '--criteria=[criteria met]:criteria' \
          '--notes=[notes about the audit]:notes' \
          '--dependency-criteria=[criteria for dependencies]:criteria' \
          '--force[override warnings]' \
          '1:crate name' \
          '2:version' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--mode=[diff mode]:mode:(local sourcegraph)' \
          '1:crate name' \
          '2:old version' \
          '3:new version' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--mode=[inspect mode]:mode:(local sourcegraph)' \
          '1:crate name' \
          '2:version' && ret=0
        ;;
    esac
    ;;
esac

return ret
