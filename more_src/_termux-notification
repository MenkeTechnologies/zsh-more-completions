#compdef termux-notification
# Documentation: https://github.com/termux/termux-api-package/blob/master/scripts/termux-notification.in
# Reference accessed: 2026-05-27
# Verified: upstream termux-api-package scripts/termux-notification.in show_usage()/getopts.


# Display a system notification. Content text is specified using -c/--content or read from stdin

_arguments \
  '--action=[action to execute when pressing the notification]:action:' \
  '--alert-once[do not alert when the notification is edited]' \
  '--button1=[text to show on the first notification button]:text:' \
  '--button1-action=[action to execute on the first notification button]:action:' \
  '--button2=[text to show on the second notification button]:text:' \
  '--button2-action=[action to execute on the second notification button]:action:' \
  '--button3=[text to show on the third notification button]:text:' \
  '--button3-action=[action to execute on the third notification button]:action:' \
  '(-c --content)'{-c+,--content=}'[content to show in the notification. Will take precedence over stdin. If content is not passed as an argument or with stdin, then there will be a 3s delay.]:content:' \
  '--channel=[Specifies the notification channel id this notification should be send on. On Android versions lower than 8.0 this is a no-op. Create custom channels with termux-notification-channel. If the channel id is invalid, the notification will not be send.]:channel-id:' \
  '--group=[notification group (notifications with the same group are shown together)]:group:' \
  '(-h --help)'{-h,--help}'[show this help]' \
  '--help-actions[show the help for actions]' \
  '(-i --id)'{-i+,--id=}'[notification id (will overwrite any previous notification with the same id)]:id:' \
  '--icon=[set the icon that shows up in the status bar. View available icons at https\://material.io/resources/icons/ (default icon\: event_note)]:icon-name:' \
  '--image-path=[absolute path to an image which will be shown in the notification]:path:' \
  '--led-color=[color of the blinking led as RRGGBB (default\: none)]:rrggbb:' \
  '--led-off=[number of milliseconds for the LED to be off while it's flashing (default\: 800)]:milliseconds:' \
  '--led-on=[number of milliseconds for the LED to be on while it's flashing (default\: 800)]:milliseconds:' \
  '--on-delete=[action to execute when the the notification is cleared]:action:' \
  '--ongoing[pin the notification]' \
  '--priority=[notification priority (high/low/max/min/default)]:prio:' \
  '--sound[play a sound with the notification]' \
  '(-t --title)'{-t+,--title=}'[notification title to show]:title:' \
  '--vibrate=[vibrate pattern, comma separated as in 500,1000,200]:pattern:' \
  '--type=[notification style to use (default/media)]:type:' \
  '--media-next[action to execute on the media-next button]' \
  '--media-pause[action to execute on the media-pause button]' \
  '--media-play[action to execute on the media-play button]' \
  '--media-previous[action to execute on the media-previous button]'
