#compdef memstat
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/memstat.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# memstat: show running processes & their RSS/VSZ memory use
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-w[wide output]' \
  '-p[pid filter]:pid:' \
  '-u[user filter]:user:_users' \
  '*::memstat args:_files' && ret=0
return ret
