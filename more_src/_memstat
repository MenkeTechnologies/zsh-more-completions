#compdef memstat
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/memstat.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# memstat: identify what's using up virtual memory
local curcontext="$curcontext" ret=1
_arguments -C \
  '-w[wide printout - do not truncate at 80 columns]' \
  '-p[print data only for given pid]:pid:_pids' \
  '-n[print inode info as-is - do not traverse directory trees]' \
  '*::memstat args:_files' && ret=0
return ret
