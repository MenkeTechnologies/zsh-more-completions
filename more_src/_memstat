#compdef memstat
# Documentation: https://man.archlinux.org/search?q=memstat
# Reference accessed: 2026-05-16

# memstat: show running processes & their RSS/VSZ memory use
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-w[wide output]' \
  '-p[pid filter]:pid:' \
  '-u[user filter]:user:_users' \
  '*::memstat args:_files' && ret=0
return ret
