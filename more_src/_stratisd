#compdef stratisd
# _stratisd — Stratis local-storage daemon (stratis-storage/stratisd)
# upstream: https://github.com/stratis-storage/stratisd
# Flags from src/bin/stratisd.rs (clap builder).

_stratisd() {
    local -a args
    args=(
        '--sim[use the simulator engine instead of real block devices]'
        '--log-level=[generate log messages at this level]:level:(trace debug info warn error)'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )
    _arguments -s -S $args
}

_stratisd "$@"
