#compdef ccze-cssdump
# Documentation: ccze-cssdump --help (ccze log colorizer)
# Source: dump the ccze color scheme as CSS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
