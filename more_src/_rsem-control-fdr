#compdef rsem-control-fdr
# Documentation: https://github.com/deweylab/RSEM/blob/master/README.md
# RSEM: report differentially expressed genes/transcripts at an FDR threshold

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--hard-threshold[report genes with PPDE >= 1 - fdr_rate]' \
  '--soft-threshold[report max genes keeping average PPDE >= 1 - fdr_rate]' \
  '1:input file (rsem-run-ebseq output):_files' \
  '2:fdr rate:' \
  '3:output file:_files' && ret=0

return ret
