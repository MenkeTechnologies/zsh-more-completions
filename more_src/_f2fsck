#compdef f2fsck fsck.f2fs
# _f2fsck — Samsung f2fs-tools fsck.f2fs CLI for checking and repairing F2FS Flash-Friendly File System volumes verifying superblock checksums sit nat ssa sit_journal nat_journal node block crashed shutdown recover flagged (kvtools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/jaegeuk/f2fs-tools.git

_f2fsck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[debug level]:n:(0 1 2)' \
        '-f[force check]' \
        '-y[assume yes]' \
        '-n[assume no]' \
        '-p[preen mode]' \
        '-a[automatic repair]' \
        '-q[quiet]' \
        '-t[time-based check]' \
        '-l+[log file]:file:_files' \
        '-D[dump SIT/NAT]' \
        '-s[skip clean check]' \
        '-S+[start block]:n:' \
        '-N+[end block]:n:' \
        '-C+[checkpoint count]:n:' \
        '-A[print all info]' \
        '-c[count files]' \
        '-i[show all info]' \
        '--auto-fix[auto fix]' \
        '--dry-run[dry run]' \
        '--debug-cache[debug cache]' \
        '*:device:_files'
}

_f2fsck "$@"
