#compdef librelane
# Documentation: https://github.com/librelane/librelane/blob/main/librelane/__main__.py
# LibreLane: RTL-to-GDSII ASIC implementation flow

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version information and exit]' \
  '--smoke-test[run a basic LibreLane smoke test]' \
  '--run-example[copy a LibreLane example to current directory and run it]' \
  '--save-views-to=[directory to copy the final views to]:dir:_files -/' \
  '--ef-save-views-to=[copy final views in Efabless format]:dir:_files -/' \
  '(-m --docker-mount --container-mount)'{-m,--docker-mount,--container-mount}'=[mount more directories in dockerized mode]:dir:_files -/' \
  '--docker-tty[allocate virtual terminal for container execution]' \
  '--docker-no-tty[do not allocate virtual terminal]' \
  '--dockerized[run remaining flags using a containerized LibreLane]' \
  '--containerized[run remaining flags using a containerized LibreLane]' \
  '(-f --flow)'{-f,--flow}'=[built-in LibreLane flow to use]:flow' \
  '(-c --override-config)'{-c,--override-config}'=[override a configuration variable]:key=value' \
  '(-i --with-initial-state)'{-i,--with-initial-state}'=[use these JSON files as an initial state]:file:_files' \
  '--design-dir=[top-level directory for your design]:dir:_files -/' \
  '--overwrite[overwrite run if exists]' \
  '--run-tag=[name to use for this particular run]:tag' \
  '--last-run[use the last run as the run tag]' \
  '(-F --from)'{-F,--from}'=[start from a step with this id]:step' \
  '(-T --to)'{-T,--to}'=[stop at a step with this id]:step' \
  '--only=[set both --from and --to to the same value]:step' \
  '(-S --skip)'{-S,--skip}'=[skip these steps]:step' \
  '--reproducible=[create a reproducible for the step matching this id]:step' \
  '--log-level=[a logging level]:level' \
  '--show-progress-bar[show the progress bar]' \
  '--hide-progress-bar[hide the progress bar]' \
  '--condensed[suppress subprocess logs]' \
  '--full[show full logs]' \
  '--volare-pdk[automatically use Ciel for PDK version installation]' \
  '--manual-pdk[disable automatic PDK installation]' \
  '--pdk-root=[override Ciel PDK root folder]:dir:_files -/' \
  '(-p --pdk)'{-p,--pdk}'=[the process design kit to use]:pdk' \
  '(-s --scl)'{-s,--scl}'=[the standard cell library to use]:scl' \
  '--pad=[the standard pad library to use]:pad' \
  '(-j --jobs)'{-j,--jobs}'=[maximum number of threads or processes]:num' \
  '*:config file:_files' && ret=0

return ret
