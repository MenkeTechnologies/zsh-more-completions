#compdef nwg-displays

# Zsh completion for nwg-displays - output management for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --num-ws)'{-n,--num-ws}'[number of workspaces]:number' \
  '(-g --generic-names)'{-g,--generic-names}'[use generic output names]'
