#compdef nwg-displays
# Documentation: https://github.com/nwg-piotr/nwg-displays
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nwg-displays - output management for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-m --monitors_path)'{-m,--monitors_path}'[path to monitors.conf]:file:_files' \
  '(-n --num_ws)'{-n,--num_ws}'[number of workspaces (default: 10)]:number:' \
  '--generic_names[use generic output names]'
