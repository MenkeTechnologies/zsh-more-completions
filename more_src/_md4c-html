#compdef md2html md4c-html
# Documentation: https://man.archlinux.org/search?q=md2html
# Reference accessed: 2026-05-16

_arguments -s \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-f --full-html)'{-f,--full-html}'[output full HTML document]' \
  '(-x --xhtml)'{-x,--xhtml}'[XHTML output]' \
  '(-s --stat)'{-s,--stat}'[print parsing stats]' \
  '--commonmark[CommonMark dialect]' \
  '--github[GitHub Flavored Markdown dialect]' \
  '--fcollapse-whitespace[collapse whitespace]' \
  '--flatex-math[LaTeX math support]' \
  '--fpermissive-atx-headers[permissive ATX headers]' \
  '--fpermissive-url-autolinks[permissive URL autolinks]' \
  '--fpermissive-www-autolinks[permissive www autolinks]' \
  '--fpermissive-email-autolinks[permissive email autolinks]' \
  '--fpermissive-autolinks[permissive autolinks]' \
  '--fhard-soft-breaks[hard soft breaks]' \
  '--fspoilers[spoilers extension]' \
  '--fstrikethrough[strikethrough]' \
  '--fsuperscripts[superscripts]' \
  '--fsubscripts[subscripts]' \
  '--ftables[tables]' \
  '--ftasklists[task lists]' \
  '--funderline[underline]' \
  '--fwiki-links[wiki-style links]' \
  '--fno-html-blocks[disable HTML blocks]' \
  '--fno-html-spans[disable HTML spans]' \
  '--fno-html[disable all HTML]' \
  '--fno-indented-code[disable indented code]' \
  '--fverbatim-entities[verbatim entities]' \
  '--html-title=[HTML title]:title:' \
  '--html-css=[HTML CSS URL]:url:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:input:_files -g "*.(md|markdown)"'
