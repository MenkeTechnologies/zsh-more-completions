#compdef bemoji
# Documentation: https://man.archlinux.org/search?q=bemoji
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t -c -e)'{-t,--type}'[type emoji into focused window]' \
  '(-t -c -e)'{-c,--copy}'[copy emoji to clipboard]' \
  '(-t -c -e)'{-e,--echo}'[echo emoji to stdout]' \
  '(-p --private)'{-p,--private}'[do not record history]' \
  '(-P --hist-limit)'{-P+,--hist-limit=}'[history entries to show]:n:' \
  '(-n --hist-internal-limit)'{-n+,--hist-internal-limit=}'[max history entries to save]:n:' \
  '(-f --file)*'{-f+,--file=}'[custom emoji DB file or URL]:source:_files' \
  '(-D --download)'{-D+,--download=}'[built-in DBs to include]:choices:(all none emoji math nerd)' \
  '(-x --no-randomize-fav)'{-x,--no-randomize-fav}'[keep history order]' \
  '--swaymsg=[run swaymsg with selection]:cmd:' \
  '*::passthrough:' && ret=0

return ret
