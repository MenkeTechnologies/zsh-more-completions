#compdef bemoji
# Documentation: https://github.com/marty-oehme/bemoji
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(-t -c -e)-t[type emoji into focused window]' \
  '(-t -c -e)-c[copy emoji to clipboard]' \
  '(-t -c -e)'{-e,--echo}'[echo emoji to stdout]' \
  {-n,--noline}'[suppress trailing newline]' \
  {-p,--private}'[do not record history]' \
  {-P+,--hist-limit=}'[history entries to show]:n:' \
  '*'{-f+,--file=}'[custom emoji DB file or URL]:source:_files' \
  {-D+,--download=}'[built-in DBs to include]:choices:(all none emoji math nerd)' \
  '*::passthrough:' && ret=0

return ret
