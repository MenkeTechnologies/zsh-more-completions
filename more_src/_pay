#compdef pay
# Documentation: https://github.com/solana-foundation/pay
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pay - let your agents pay for any API (solana-foundation/pay)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:initialize account and configure biometric authorization'
  'whoami:display current account information'
  'topup:replenish account balance'
  'claude:launch Claude with payment handling enabled'
  'codex:run Codex with integrated payment support'
  'curl:wrap curl with payment handling'
  'server:server commands'
  'skills:skills search and discovery'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--sandbox[run against sandbox endpoints]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'pay command' commands && ret=0
    ;;
  args)
    case $words[1] in
      server)
        _arguments \
          '1:subcommand:(start demo)' \
          '*:: :->server-args' && ret=0
        case $state in
          server-args)
            case $words[1] in
              start)
                _arguments \
                  '--debugger=[launch with embedded payment debugger]:spec:_files -g "*.(yml|yaml)"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      skills)
        _arguments \
          '1:subcommand:(search)' \
          '*:query:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
