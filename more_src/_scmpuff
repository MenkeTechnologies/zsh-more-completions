#compdef scmpuff
# scmpuff: numeric shortcuts for common git commands
# https://github.com/mroth/scmpuff

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'init:output shell initialization script'
      'status:show git status with numeric file shortcuts'
      'expand:expand numeric shortcuts to filenames'
    )
    _describe -t commands 'scmpuff command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-s[shell type]:shell:(bash zsh sh)' \
          '--shell=[shell type]:shell:(bash zsh sh)' \
          '--aliases[include command aliases in init]' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-e[expand filepaths (output for machine parsing)]' \
          '--filelist[expand filepaths (output for machine parsing)]' && ret=0
        ;;
      expand)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--relative[output relative paths]' \
          '*:shortcut number' && ret=0
        ;;
    esac
    ;;
esac

return ret
