#compdef kwalify
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/kwalify.1.html
# kwalify: tiny schema validator for YAML and JSON

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show summary of options]' \
  '-v[display version information]' \
  '-s[be silent]' \
  '-t[expand tab characters]' \
  '-l[show linenumber when errored]' \
  '-E[show errors in emacs-style (implies -l)]' \
  '-m[meta-validation mode: validate the schema file]:schema:_files' \
  '-f[schema definition file: validate against schema]:schema:_files' \
  '-a[generate code (genclass-ruby or genclass-java)]:action:(genclass-ruby genclass-java)' \
  '-ha[generate code with properties]:action:(genclass-ruby genclass-java)' \
  '*:document:_files' && ret=0

return ret
