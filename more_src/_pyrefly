#compdef pyrefly

# Zsh completion for Pyrefly (Meta Python type checker)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check Python files'
  'server:run the LSP server'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pyrefly command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (check)
        _arguments \
          '--project[project directory]:dir:_files -/' \
          '--search-path[additional search paths]:dir:_files -/' \
          '--python-version[target Python version]:version:(3.8 3.9 3.10 3.11 3.12 3.13)' \
          '--output-format[output format]:format:(text json)' \
          '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
          '--config[path to config file]:file:_files' \
          '*:file or directory:_files' && ret=0
        ;;
      (server)
        _arguments \
          '--project[project directory]:dir:_files -/' && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
