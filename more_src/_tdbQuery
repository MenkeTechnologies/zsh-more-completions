#compdef tdbQuery
# UCSC kent: query the trackDb system using SQL syntax

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-root=[root directory of the trackDb.ra hierarchy]:dir:_files -/' \
  '-check[check that trackDb is internally consistent]' \
  '-strict[suppress tracks where table does not exist]' \
  '-release=[include trackDb entries with this release tag]:tag:(alpha beta public)' \
  '-noBlank[don'\''t print blank lines separating records]' \
  '-oneLine[print single pipe-separated line per record]' \
  '-noCompSub[subtracks don'\''t inherit fields from parents]' \
  '-shortLabelLength=[complain if shortLabels exceed N chars]:n:' \
  '-longLabelLength=[complain if longLabels exceed N chars]:n:' \
  ':sql statement:' && ret=0

return ret
