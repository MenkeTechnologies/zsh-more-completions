#compdef segger-jtrace JTrace JTracePro JTracePC
# _segger-jtrace — SEGGER Microcontroller JTrace CLI for the SEGGER J-Trace ETM trace ETB ARM Cortex-M Cortex-A profile streaming-trace capture symbol resolve filter file save trace decode ELF (segger team, C++); custom argparse
# upstream: https://www.segger.com/downloads/jtrace/

_segger-jtrace() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-device=+[target device]:str:' \
        '-Device=+[target device]:str:' \
        '-if=+[interface]:i:(SWD JTAG cJTAG)' \
        '-IF=+[interface]:i:(SWD JTAG cJTAG)' \
        '-speed=+[Hz or auto]:str:' \
        '-Speed=+[Hz or auto]:str:' \
        '-tracestrip=+[mode]:m:(off auto on)' \
        '-tracesource=+[s]:s:(etm itm cti)' \
        '-traceprocs=+[file]:file:_files' \
        '-symbolfile=+[ELF]:file:_files -g "*.elf *.axf *.out"' \
        '-cpufreq=+[Hz]:n:' \
        '-tpiufreq=+[Hz]:n:' \
        '-tpiuwidth=+[bits]:n:(1 2 4)' \
        '-Output=+[file]:file:_files -g "*.dat *.dump"' \
        '-RemoteServerPort=+[port]:n:' \
        '-AutoConnect=+[b]:b:(1 0)' \
        '-NoGui[no GUI]' \
        '-Log=+[file]:file:_files' \
        '-Force[force]' \
        '-ExitOnError[exit on error]'
}

_segger-jtrace "$@"
