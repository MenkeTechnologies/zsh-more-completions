#compdef ospfctl
# _ospfctl — OpenBSD ospfctl (control + introspect the running ospfd(8) daemon for IPv4 OSPF; show neighbors/interfaces/database/rib/fib, control FIB coupling, reload, log level)
# upstream: https://github.com/openbsd/src (usr.sbin/ospfctl)
# Flags + commands from usr.sbin/ospfctl/ospfctl.8 on tip.

_ospfctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-s+[control socket (default /var/run/ospfd.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'ospfctl command' \
                '(show:show subsystem state (summary|neighbor|interfaces|database|rib|fib) fib:fib couple/decouple/reload reload:reload ospfd config log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(summary neighbor interfaces database rib fib)' ;;
                fib) _describe -t commands 'fib subcommand' '(couple decouple reload)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_ospfctl "$@"
