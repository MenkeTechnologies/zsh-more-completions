#compdef msgpre

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-i+,--input=}'[input PO file]:file:_files -g "*.po"' \
  {-D+,--directory=}'[input directory]:dir:_files -/' \
  {-o+,--output-file=}'[output PO file]:file:_files -g "*.po"' \
  '--no-translator[do not record translator]' \
  '--no-wrap[do not break long lines into multiple lines]' \
  {-w+,--width=}'[output page width]:n:' \
  '*:input file:_files -g "*.po"' && ret=0

return ret
