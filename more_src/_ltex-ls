#compdef ltex-ls ltex-cli

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--endless[keep server alive after client disconnects]' \
  '--no-endless[exit after client disconnects (default)]' \
  '--server-type=[transport mode]:type:(standard tcpSocket)' \
  '--host=[TCP server host]:host:_hosts' \
  '--port=[TCP server port]:port:' \
  '--client-process-id=[client PID to watch]:pid:' \
  '--input-documents=[documents to check (deprecated)]:files:' \
  '--settings-file=[JSON settings file (deprecated)]:file:_files -g "*.json"' \
  '--client-configuration=[client configuration JSON]:json:' \
  '*::path:_files' && ret=0

return ret
