#compdef phenix.get_pdb_validation_report
# Documentation: https://phenix-online.org/documentation/reference/get_pdb_validation_report.html
# Phenix: fetch a wwPDB validation report for a model via the PDB validation server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'timeout=[how long to wait for the result, in seconds]:sec:' \
  'ping_frequency=[how often to poll PDB for the result, in seconds]:sec:' \
  'session_id=[session ID for a previously submitted job]:id:' \
  'output_xml=[fetch report in XML format]:bool:(True False)' \
  'output.prefix=[output filename prefix]:prefix:' \
  'output.serial=[serial number for output]:n:' \
  'output_dir=[output directory]:dir:_files -/' \
  '*:model or data file:_files -g "*.(cif|ccp4|map|mrc)"' && ret=0

return ret
