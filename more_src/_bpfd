#compdef bpfd
# _bpfd — Linux Foundation eBPF Foundation bpfd CLI command-line frontend to the BPF Daemon Kubernetes-native eBPF program lifecycle management providing load unload list bytecode-OCI-image program-type-XDP-TC-tracepoint-kprobe-uprobe-cgroup-skb-sk-msg-attach-detach-multi-attach-multi-detach-counter-map-pin (eBPF Foundation team, Rust); clap
# upstream: https://github.com/bpfman/bpfman

_bpfd() {
    local -a sub=(
        'load:load a BPF program'
        'unload:unload a BPF program'
        'list:list loaded programs'
        'get:get program info'
        'attach:attach a program'
        'detach:detach a program'
        'image:OCI image operations'
        'tc:TC program operations'
        'xdp:XDP program operations'
        'tracepoint:tracepoint program operations'
        'kprobe:kprobe program operations'
        'uprobe:uprobe program operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--socket=+[file]:file:_files' \
        '--config=+[file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--insecure[skip TLS verify]' \
        '-o+[output]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bpfd subcommand' sub ;;
        args)
            case $words[1] in
                load) _arguments \
                    '--bytecode=+[file]:file:_files -g "*.bpf *.o"' \
                    '--image-url=+[url]:str:' \
                    '--program-name=+[name]:str:' \
                    '--id=+[id]:str:' \
                    '--metadata=+[k=v]:str:' ;;
                unload|get|detach) _arguments '*:program id:' ;;
                xdp|tc|tracepoint|kprobe|uprobe) _arguments \
                    '--iface=+[iface]:_net_interfaces' \
                    '--priority=+[N]:n:' \
                    '--proceed-on=+[N]:str:' \
                    '--position=+[N]:n:' ;;
            esac
            ;;
    esac
}

_bpfd "$@"
