#compdef sloppy

# Sloppy: UCI/Xboard chess engine; protocol on stdin, almost no CLI flags
local curcontext="$curcontext" ret=1

_arguments -C \
  '--help[show help and exit]' \
  '--version[print version]' \
  '--protocol=[force protocol]:protocol:(uci xboard)' \
  '--book=[opening book file]:book:_files -g "*.bin"' \
  '--log=[write engine log to file]:logfile:_files' && ret=0

return ret
