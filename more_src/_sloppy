#compdef sloppy
# Documentation: https://github.com/sloppyio/cli
# Reference accessed: 2026-05-21
# Verified: cmd/commands.go and command/*.go in upstream repository.

# sloppy.io CLI - container-as-a-service deploy tool (repo archived 2023)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'change:change running app properties'
  'console:open a shell to a running app'
  'delete:delete a project/service/app'
  'docker-login:login to a docker registry'
  'docker-logout:logout from a docker registry'
  'logs:show app logs'
  'restart:restart an app'
  'rollback:rollback an app to a previous version'
  'scale:scale an app instance count'
  'show:show projects/services/apps info'
  'start:start a project from JSON file'
  'stats:show resource usage stats'
  'version:show sloppy CLI version'
)

_arguments -C \
  '--version[show version]' \
  '--help[show help]' \
  '--debug[print stack trace on panic]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sloppy command' commands && ret=0 ;;
  (args)
    case ${line[1]} in
      (start)
        _arguments \
          '(-p --project)'{-p+,--project=}'[project name]:name' \
          '*:JSON file:_files -g "*.json"' && ret=0 ;;
      (change)
        _arguments \
          '(-m --memory)'{-m+,--memory=}'[memory in MB]:mb' \
          '(-i --instances)'{-i+,--instances=}'[instance count]:n' \
          '--img=[container image]:image' \
          '--image=[container image]:image' \
          '(-d --domain)'{-d+,--domain=}'[custom domain]:domain' \
          '(-f --force)'{-f,--force}'[skip confirmation]' \
          '(-p --project)'{-p+,--project=}'[project name]:name' \
          '*:app path:' && ret=0 ;;
      (show)
        _arguments \
          '(-r --raw)'{-r,--raw}'[raw JSON output]' \
          '*:target:' && ret=0 ;;
      (stats)
        _arguments \
          '(-a --all)'{-a,--all}'[show all instances]' \
          '*:app path:' && ret=0 ;;
      (logs)
        _arguments \
          '-n+[number of lines]:n' \
          '--from=[start date]:date' \
          '--to=[end date]:date' \
          '*:app path:' && ret=0 ;;
      (delete)
        _arguments \
          '(-f --force)'{-f,--force}'[skip confirmation]' \
          '*:target:' && ret=0 ;;
      (console)
        _arguments \
          '-i[keep STDIN open]' \
          '-t[allocate pseudo-TTY]' \
          '-e+[escape character (default ~)]:char' \
          '*:app path:' && ret=0 ;;
    esac ;;
esac

return ret
