#compdef orval-cli
# _orval-cli — Orval REST client/mocks generator from OpenAPI specs CLI alias (Orval team, TypeScript); commander
# upstream: https://github.com/anymaniax/orval

_orval-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[orval config file]:file:_files -g "orval.config.* *.cjs *.mjs *.ts *.js *.json"' \
        '-c+[orval config file]:file:_files -g "orval.config.* *.cjs *.mjs *.ts *.js *.json"' \
        '--mode=+[mode]:m:(single split tags tags-split)' \
        '-m+[mode]:m:(single split tags tags-split)' \
        '--client=+[client]:c:(axios axios-functions fetch react-query svelte-query vue-query swr angular zod)' \
        '--watch[watch mode]' \
        '-w[watch mode]' \
        '--clean[clean output dir]' \
        '--prettier[run prettier on output]' \
        '--biome[run biome on output]' \
        '--tslint[run tslint on output]' \
        '--input=+[input spec]:file:_files -g "*.yaml *.yml *.json"' \
        '-i+[input spec]:file:_files -g "*.yaml *.yml *.json"' \
        '--output=+[output dir or file]:str:' \
        '-o+[output dir or file]:str:' \
        '--project=+[project name]:str:' \
        '-p+[project name]:str:' \
        '--workspace=+[workspace name]:str:' \
        '--stdout[print generated stdout]' \
        '*:project:'
}

_orval-cli "$@"
