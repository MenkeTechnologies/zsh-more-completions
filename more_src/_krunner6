#compdef krunner6
# Documentation: https://userbase.kde.org/Plasma/Krunner
# Reference accessed: 2026-05-16
# Verified: KCommandLineParser standard options + --replace (documented in
# KDE UserBase). Same flag set for krunner5 (KF5) and krunner6 (KF6).

# krunner: KDE Plasma launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--replace[replace an existing instance]' && ret=0
return ret
