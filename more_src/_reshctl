#compdef reshctl
# Documentation: https://github.com/curusarn/resh/blob/master/cmd/control/cmd/root.go
# reshctl - control command for RESH (context-based shell history)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'version:show RESH version'
      'doctor:check common problems'
      'update:update RESH to the latest version'
    )
    _describe -t commands 'reshctl command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      update)
        _arguments -s \
          '--beta[update to latest version even if it is beta]' && ret=0
        ;;
    esac
    ;;
esac

return ret
