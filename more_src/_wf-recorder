#compdef wf-recorder

# Zsh completion for wf-recorder - screen recorder for wlroots compositors

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --audio)'{-a,--audio}'[enable audio recording]' \
  '--audio-backend[audio backend]:backend:(pipewire pulseaudio)' \
  '(-b --bframes)'{-b,--bframes}'[set max B-frames]:frames' \
  '(-B --buffrate)'{-B,--buffrate}'[set buffer rate]:rate' \
  '(-c --codec)'{-c,--codec}'[set video codec]:codec:(libx264 libx265 libvpx libvpx-vp9 h264_vaapi hevc_vaapi gif)' \
  '(-C --audio-codec)'{-C,--audio-codec}'[set audio codec]:codec:(aac opus flac)' \
  '(-d --device)'{-d,--device}'[set DRM device for vaapi]:device:_files -W /dev/dri' \
  '(-D --no-dmabuf)'{-D,--no-dmabuf}'[disable dmabuf capture]' \
  '(-f --filename)'{-f,--filename}'[output filename]:file:_files' \
  '(-F --filter)'{-F,--filter}'[set ffmpeg filter]:filter string' \
  '(-g --geometry)'{-g,--geometry}'[set capture region]:geometry' \
  '(-l --log)'{-l,--log}'[set log level]:level' \
  '(-m --muxer)'{-m,--muxer}'[set output muxer]:muxer' \
  '(-o --output)'{-o,--output}'[set output name]:output' \
  '(-p --codec-param)'{-p,--codec-param}'[set codec parameter]:param=value' \
  '(-r --framerate)'{-r,--framerate}'[set framerate]:fps' \
  '(-x --pixel-format)'{-x,--pixel-format}'[set pixel format]:format' \
  '--no-hw[disable hardware encoding]'
