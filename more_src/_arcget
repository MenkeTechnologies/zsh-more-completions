#compdef arcget
# Documentation: https://man.archlinux.org/search?q=arcget
# Reference accessed: 2026-05-16

# arcget: retrieve ARC job output
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '--debug=[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '-a[fetch all jobs]' \
  '--all[fetch all jobs]' \
  '-c[cluster URL]:url:' \
  '--cluster=[cluster URL]:url:' \
  '-r[reject cluster]:url:' \
  '--rejectmanagement=[reject cluster]:url:' \
  '-i[index server]:url:' \
  '--index=[index server]:url:' \
  '-D[download dir]:dir:_files -/' \
  '--dir=[download dir]:dir:_files -/' \
  '-J[use jobids from file]:file:_files' \
  '--joblist=[use jobids from file]:file:_files' \
  '-k[keep job after fetching]' \
  '--keep[keep job after fetching]' \
  '-C[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '*:jobid:' && ret=0
return ret
