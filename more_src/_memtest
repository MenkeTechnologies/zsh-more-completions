#compdef memtest
# Documentation: https://memtest.org/readme
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: no canonical "memtest" CLI; users typically run memtester(8) or
# the bootable memtest86+ image. Minimal stub: take memory size +
# iteration count positionals (matching the common memtester-like
# wrapper convention).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1:megabytes:' \
  '2:iterations:' && ret=0
return ret
