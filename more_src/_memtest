#compdef memtest
# Documentation: https://man.archlinux.org/search?q=memtest
# Reference accessed: 2026-05-16

# memtest: simple userspace RAM tester
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1:megabytes:' \
  '2:iterations:' && ret=0
return ret
