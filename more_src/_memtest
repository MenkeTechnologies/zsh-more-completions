#compdef memtest memtester

# memtest: memory tester (memtest86 or memtester)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-p[physical address (memtester)]:addr:' \
  '-d[device file (memtester)]:file:_files' \
  '*:memory size [iterations]:' && ret=0
return ret
