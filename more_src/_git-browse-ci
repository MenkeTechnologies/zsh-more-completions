#compdef git-browse-ci git-paste git-reauthor git-repl git-reset-file git-unlock
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 7. Companion to rounds 150-155 + the pre-existing
# _git-changelog / _git-info / _git-ignore / _git-get / _git-extras /
# _git-standup / _git-sync / _git-undo (via _ugit) standalone files.
# Hunt-skip log this round: git-rscp 404s in master.
# git-sync caught by ^#compdef recheck (pre-existing at more_src/_git-sync).
# This round flushes the long-running tj/git-extras campaign with the
# authoritative 74-subcommand list from upstream Commands.md.

local curcontext="$curcontext" state line ret=1

case $service in

  git-browse-ci)
    # man/git-browse-ci.1 — open the CI page for a remote in browser.
    _arguments -s -S \
      '1:remote (default first remote):__git_remotes' \
      && ret=0
    ;;

  git-paste)
    # man/git-paste.1 — wrapper around git format-patch.
    # All args are passed directly. With no args, defaults to @{u}.
    _arguments -s -S \
      '*:git format-patch argument:' \
      && ret=0
    ;;

  git-reauthor)
    # man/git-reauthor.1 — rewrite author/committer identities.
    _arguments -s -S \
      '(-a --all)-a[rewrite ALL identities in commits and tags]' \
      '(-a --all)--all[rewrite ALL identities in commits and tags]' \
      '(-c --use-config)-c[take default values from user git config]' \
      '(-c --use-config)--use-config[take default values from user git config]' \
      '(-e --correct-email)-e+[new email (empty string allowed)]:email:' \
      '(-e --correct-email)--correct-email=[new email (empty string allowed)]:email:' \
      '(-n --correct-name)-n+[new name (empty string not allowed)]:name:' \
      '(-n --correct-name)--correct-name=[new name (empty string not allowed)]:name:' \
      '(-o --old-email)-o+[match this old email for rewrite]:email:' \
      '(-o --old-email)--old-email=[match this old email for rewrite]:email:' \
      '(-t --type)-t+[which identity type to rewrite]:type:(author committer both)' \
      '(-t --type)--type=[which identity type to rewrite]:type:(author committer both)' \
      && ret=0
    ;;

  git-repl)
    # man/git-repl.1 — interactive git REPL.
    # Recognises bare commands (run as `git <cmd>`),
    # ! prefix (shell command), `ls` (git ls-files),
    # `exit`/`quit` (terminate).
    # No CLI flags — the REPL is entirely stdin-driven.
    _arguments -s -S \
      && ret=0
    ;;

  git-reset-file)
    # man/git-reset-file.1 — reset a single file to a given commit.
    #   git-reset-file [<filename>] commit-hash
    _arguments -s -S \
      '1:filename to reset:_files' \
      '2:commit hash (default HEAD):__git_revisions' \
      && ret=0
    ;;

  git-unlock)
    # man/git-unlock.1 — undo a `git lock` (re-enables tracking of the file).
    _arguments -s -S \
      '1:filename to unlock:_files' \
      && ret=0
    ;;

esac

return ret
