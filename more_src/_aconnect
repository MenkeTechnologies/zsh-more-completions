#compdef aconnect
# Documentation: https://manpages.debian.org/aconnect.1
# Source: alsa-utils — connect/disconnect/list ALSA sequencer ports.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --disconnect)'{-d,--disconnect}'[disconnect the given subscription]' \
    '(-e --exclusive)'{-e,--exclusive}'[connect ports in exclusive mode]' \
    '(-r --real -t --tick)'{-r+,--real=}'[convert event timestamps to real-time queue value]:queue:' \
    '(-r --real -t --tick)'{-t+,--tick=}'[convert event timestamps to tick queue value]:queue:' \
    '(-i --input)'{-i,--input}'[list existing input (readable) ports]' \
    '(-o --output)'{-o,--output}'[list existing output (writable) ports]' \
    '(-a --all)'{-a,--all}'[also list inactive ports]' \
    '(-l --list)'{-l,--list}'[list current connection status]' \
    '(-x --removeall)'{-x,--removeall}'[remove all exported connections]' \
    '*:src then dst port:' \
    && ret=0

return ret
