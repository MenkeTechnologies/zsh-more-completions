#compdef pypeit_show_2dspec
# Documentation: https://pypeit.readthedocs.io/en/release/out_spec2D.html
# View 2D spectral outputs in ginga

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--list[list the extensions only]' \
  '--det=[detector name or number]:det' \
  '--spat_id=[restrict plotting to this slit (PypeIt ID notation)]:spat_id' \
  '--maskID=[restrict plotting to this maskID]:maskid' \
  '*--showmask=[include a channel showing the mask]:mask' \
  '--removetrace[do not overplot traces in skysub/sky_resid/resid channels]' \
  '--embed[upon completion embed in ipython shell]' \
  '--ignore_extract_mask[ignore the extraction mask]' \
  '--channels=[only show a subset of the channels (0-indexed)]:channels' \
  '--prefix=[channel name prefix]:prefix' \
  '--no_clear[do not clear all existing tabs]' \
  '--try_old[attempt to load old datamodel versions]' \
  '*:spec2d file:_files -g "*.fits"' && ret=0

return ret
