#compdef cellranger-atac
# Documentation: https://www.10xgenomics.com/support/software/cell-ranger-atac/latest/analysis/running-pipelines/command-line-arguments
# cellranger-atac - Single Cell ATAC-seq analysis

local ret=1
local -a subcmds

subcmds=(
  'count:count single-library ATAC reads'
  'mkfastq:run bcl2fastq on Single Cell ATAC data'
  'mkref:create a cellranger-atac-compatible reference'
  'aggr:aggregate multiple count runs'
  'reanalyze:re-run secondary analysis on a completed run'
  'testrun:run a tiny pipeline to verify install'
  'upload:upload analysis logs to 10x support'
  'sitecheck:collect system configuration'
)

local -a common
common=(
  '--id=[unique run id and output folder name]:id:'
  '--description=[sample description for output]:text:'
  '--jobmode=[job manager]:mode:(local sge lsf slurm)'
  '--localcores=[max cores for local jobs]:n:'
  '--localmem=[max GB memory for local jobs]:gb:'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- :)--version[print version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'cellranger-atac command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      count)
        _arguments -s -S $common \
          '--reference=[path to ATAC/ARC reference folder]:dir:_files -/' \
          '--fastqs=[folder with FASTQ files]:dir:_files -/' \
          '--sample=[FASTQ filename prefix to select]:prefix:' \
          '--force-cells=[force top N barcodes as cells]:n:' \
          '--dim-reduce=[dimensionality reduction mode]:mode:(lsa pca plsa)' \
          '--project=[project folder name for FASTQ selection]:text:' \
          '--lanes=[selected lane numbers]:lanes:' \
          '--peaks=[custom peaks BED file]:bed:_files' \
          '--subsample-rate=[downsample read fraction]:frac:' \
          '--nosecondary[disable secondary analysis]' \
          '--dry[generate invocation without running]' && ret=0
        ;;
      mkfastq)
        _arguments -s -S $common \
          '--run=[Illumina BCL run folder]:dir:_files -/' \
          '--csv=[sample sheet CSV]:csv:_files' \
          '--samplesheet=[sample sheet]:csv:_files' \
          '--lanes=[comma-delimited lane numbers]:lanes:' \
          '--use-bases-mask=[override read lengths]:mask:' \
          '--output-dir=[custom output location]:dir:_files -/' \
          '--project=[custom project name]:name:' && ret=0
        ;;
      mkref)
        _arguments -s -S \
          '--config=[configuration file]:file:_files' \
          '--ref-version=[version string]:str:' && ret=0
        ;;
      aggr)
        _arguments -s -S $common \
          '--reference=[path to reference folder]:dir:_files -/' \
          '--csv=[enumeration of count outputs]:csv:_files' \
          '--normalize=[depth normalization mode]:mode:(depth none)' \
          '--peaks=[custom peaks BED file]:bed:_files' \
          '--dim-reduce=[dimensionality reduction mode]:mode:(lsa pca plsa)' \
          '--nosecondary[skip secondary analysis]' && ret=0
        ;;
      reanalyze)
        _arguments -s -S $common \
          '--reference=[path to reference folder]:dir:_files -/' \
          '--peaks=[peaks BED file]:bed:_files' \
          '--fragments=[fragments TSV.GZ]:file:_files' \
          '--force-cells=[force top N barcodes as cells]:n:' \
          '--params=[analysis parameters CSV]:csv:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
