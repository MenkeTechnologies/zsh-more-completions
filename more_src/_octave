#compdef octave
# Documentation: https://docs.octave.org/latest/Command-Line-Options.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--built-in-docstrings-file=[docstrings file]:file:_files' \
  '--doc-cache-file=[documentation cache file]:file:_files' \
  '(-x --echo-commands)'{-x,--echo-commands}'[echo commands as executed]' \
  '(-e --eval)'{-e+,--eval=}'[evaluate expression]:expression:' \
  '--exec-path=[set execution path]:path:_directories' \
  '(-g --gui)'{-g,--gui}'[start the GUI]' \
  '(-G --no-gui)'{-G,--no-gui}'[disable the GUI]' \
  '--image-path=[add path for images]:path:_directories' \
  '--info-file=[info file]:file:_files' \
  '--info-program=[info program]:program:_files' \
  '--init-trace[print configuration names during initialization]' \
  '(-i --interactive)'{-i,--interactive}'[force interactive behavior]' \
  '--line-editing[force readline line editing]' \
  '(-H --no-history)'{-H,--no-history}'[do not save command history]' \
  '(-f --no-init-all --norc)'{-f,--no-init-all,--norc}'[do not read any initialization files]' \
  '--no-init-path[do not set default path]' \
  '--no-init-site[do not read site-wide initialization files]' \
  '--no-init-user[do not read user initialization files]' \
  '--no-line-editing[do not use readline]' \
  '(-W --no-window-system)'{-W,--no-window-system}'[disable window system]' \
  '(-p --path)'{-p+,--path=}'[add path to search path]:path:_directories' \
  '--persist[go interactive after running script]' \
  '(-q --quiet --silent)'{-q,--quiet,--silent}'[do not print startup message]' \
  '--texi-macros-file=[texi macros file]:file:_files' \
  '(--traditional --braindead)'{--traditional,--braindead}'[set MATLAB-compatible preferences]' \
  '*:file:_files -g "*.{m,oct}"' && ret=0

return ret
