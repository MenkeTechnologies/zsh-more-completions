#compdef octave

# Zsh completion for octave - GNU Octave numerical computing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--built-in-docstrings-file=[docstrings file]:file:_files' \
  '--debug[enter debug mode on error]' \
  '-d[enter debug mode on error]' \
  '--debug-jit[enable JIT debugging]' \
  '--doc-cache-file=[documentation cache file]:file:_files' \
  '--echo-commands[echo commands as executed]' \
  '-x[echo commands as executed]' \
  '--eval=[evaluate expression]:expression' \
  '--exec-path=[set execution path]:path:_directories' \
  '--experimental-terminal-widget[use experimental terminal widget]' \
  '--force-gui[force graphical user interface]' \
  '--gui[start the GUI]' \
  '--image-path=[add path for images]:path:_directories' \
  '--info-file=[info file]:file:_files' \
  '--info-program=[info program]:program:_files' \
  '--interactive[force interactive behavior]' \
  '-i[force interactive behavior]' \
  '--line-editing[force readline line editing]' \
  '--no-gui[disable GUI]' \
  '--no-history[do not save command history]' \
  '-H[do not save command history]' \
  '--no-init-file[do not read .octaverc]' \
  '-f[do not read .octaverc]' \
  '--no-init-path[do not set default path]' \
  '--no-line-editing[do not use readline]' \
  '--no-site-file[do not read site startup file]' \
  '--no-window-system[disable window system]' \
  '-W[disable window system]' \
  '--norc[do not read any initialization files]' \
  '--path=[add path to search path]:path:_directories' \
  '-p[add path to search path]:path:_directories' \
  '--persist[go interactive after running script]' \
  '--server[start in server mode]' \
  '--silent[do not print startup message]' \
  '-q[do not print startup message]' \
  '--quiet[do not print startup message]' \
  '--texi-macros-file=[texi macros file]:file:_files' \
  '--traditional[set compatibility variables]' \
  '--verbose[enable verbose output]' \
  '-V[enable verbose output]' \
  '*:file:_files -g "*.{m,oct}"' && ret=0

return ret
