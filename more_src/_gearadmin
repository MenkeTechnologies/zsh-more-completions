#compdef gearadmin
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/gearadmin.1.html
# gearadmin - administration tool for the Gearman job server

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-h --host)'{-h,--host}'+[connect to the host]:host:_hosts' \
  '(-p --port)'{-p,--port}'+[port number or service to use]:port:' \
  '--create-function[create a function on the server]:function:' \
  '--drop-function[drop a function from the server]:function:' \
  '--server-version[fetch the version number for the server]' \
  '--server-verbose[fetch the verbose setting for the server]' \
  '--status[status for the server]' \
  '--workers[workers for the server]' \
  '*:arg:' && ret=0

return ret
