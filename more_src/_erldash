#compdef erldash
# =============================================================================
# erldash — a simple, terminal-based Erlang dashboard written in Rust.
#           Connects to a running Erlang VM via the BEAM distribution
#           protocol (the same protocol that `erl -name` and `iex --name`
#           speak) and displays real-time metrics: memory by allocator,
#           process count, scheduler utilization, message queue lengths,
#           ETS table sizes, atom-table pressure, and reduction counts.
#           Supports recording sessions for later replay — useful for
#           offline incident analysis when the production cluster is
#           already cooled down.
#
# Author:  Takeru Ohta (sile)
# Source:  https://github.com/sile/erldash
# CLI:     src/main.rs (uses sile/noargs)
# Library: sile/noargs
#          ("Imperative command-line argument parser library for Rust
#           with no dependencies, no macros, and no implicit I/O")
# License: MIT or Apache-2.0
# Status:  Stable — 174+ stars, used by Erlang/Elixir teams for
#          production monitoring as a lightweight `htop`-style
#          replacement for `observer` (which requires X11).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — RUST CROSSES TO 26 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 26TH Rust CLI library variant.  Rust climbs from 25 to 26 documented
# libraries (noargs via erldash).  New leaderboard: Rust=26 (SOLO LEAD),
# Go=25, TypeScript-Node=25.  Taxonomy now spans 213 cross-language CLI
# library variants across 51 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS noargs AND WHY IS IT A DISTINCT 26TH RUST CLI LIBRARY VARIANT?
#
# noargs (https://github.com/sile/noargs, 32+ stars) is Takeru Ohta's
# (sile, the same author of `erldash`) command-line library for Rust.
# Takeru Ohta is a prolific Erlang/BEAM-Rust ecosystem developer who has
# authored erl_dist (Erlang distribution protocol in Rust), erldash
# (THIS), mpeg2ts (MPEG2-TS parser), sorastats (WebRTC Sora SFU stats),
# mamegrep (interactive git-grep TUI), and many other production-grade
# Rust tools — all using noargs as the CLI parser.
#
# noargs's design tagline is "no DEPENDENCIES, no MACROS, no IMPLICIT I/O"
# — three strict design constraints that combine to make noargs distinct
# from every other documented Rust CLI library:
#
#   1. NO DEPENDENCIES — noargs's `[dependencies]` block in Cargo.toml is
#      completely EMPTY.  Pure stdlib Rust.  Compare to clap which pulls
#      in ~10 transitive dependencies (textwrap, indexmap, anstream,
#      anstyle, strsim, etc.); pico-args has 0 deps but is more limited;
#      lapp R464 has 1 dep (easy_shortcuts); getargs R471 has 0 deps but
#      uses a different iterator approach.
#
#   2. NO MACROS — noargs is a pure BUILDER API with no proc-macros,
#      no derive, no macro_rules!.  Each option is constructed via
#      method-chained builder calls:
#        noargs::opt("name").short('n').ty("FILE").doc("...")
#                            .default("info").take(&mut args)
#                            .then(|o| o.value().parse())?;
#
#   3. NO IMPLICIT I/O — noargs NEVER prints help text, error messages,
#      or anything else to stdout/stderr automatically.  Instead, it
#      returns `noargs::Result<T>` where errors carry descriptive messages
#      that the CALLER decides what to do with.  Compare clap which
#      auto-prints help on `--help` and auto-prints errors on parse
#      failure; noargs hands control to the user code.
#
# noargs is DISTINCT from every other Rust CLI library on FIVE more axes:
#
#   1. IMPERATIVE EXTRACTION ("CONSUMING TAKE") — each `.take(&mut args)`
#      call MUTATES the RawArgs state, REMOVING the matched argv elements
#      from a remaining-args queue.  After all `.take()` calls,
#      `args.finish()?` checks for un-consumed argv (which would indicate
#      typos or unsupported flags) and returns either help text or an
#      error.  This is a fundamentally different parsing MODEL from:
#        * declarative-spec (clap-derive, Kong): spec is data, parser
#          matches argv against the spec exhaustively
#        * iterator-based (getargs, lexopt): parser yields each argv
#          element in order
#        * usage-text-driven (docopt, lapp): parser derives spec from
#          usage text
#      noargs's model is: "for each option you care about, ASK the parser
#      to TAKE it from the argv state."  More similar to pico-args than
#      to any of the above, but with a richer builder API.
#
#   2. BUILT-IN VERSION_FLAG / HELP_FLAG CONSTANTS — pre-defined static
#      values `noargs::VERSION_FLAG` and `noargs::HELP_FLAG` for the
#      universal `--version`/`-V` and `--help`/`-h` patterns.  No need
#      to re-declare these flags per binary.
#
#   3. METADATA SETTING VIA METHOD CHAINS — `args.metadata_mut().app_name
#      = env!("CARGO_PKG_NAME")` and `args.metadata_mut().app_description
#      = env!("CARGO_PKG_DESCRIPTION")`.  Metadata is mutable state on
#      the RawArgs object rather than constructor arguments.
#
#   4. SUBCOMMANDS VIA `noargs::cmd("name")` — subcommand handling is
#      symmetric with option handling: call `noargs::cmd("run").take(args)
#      .is_present()` to check if the subcommand was used, then parse
#      its OWN flags from the same args object.  Subcommands are NOT
#      represented as a separate parser tree; instead the caller
#      orchestrates them with `if/else if` over `is_present()`.
#
#   5. EXPLICIT FALLIBLE CONVERSION via `.then(|o| o.value().parse())?`
#      — typed value conversion is done by the CALLER using closures that
#      return `Result`.  noargs doesn't have built-in `int_opt1` /
#      `bool_opt1` / etc. (lapp R464 does); the caller writes the parse
#      function inline.  This keeps noargs library code minimal at the
#      cost of slightly more caller boilerplate.
#
# THE noargs API SURFACE (verbatim from erldash usage)
#
#   use noargs;
#
#   let mut args = noargs::raw_args();
#   args.metadata_mut().app_name = env!("CARGO_PKG_NAME");
#   args.metadata_mut().app_description = env!("CARGO_PKG_DESCRIPTION");
#
#   // Built-in flags
#   if noargs::VERSION_FLAG.take(&mut args).is_present() { ... }
#   noargs::HELP_FLAG.take_help(&mut args);
#
#   // Boolean flag
#   let verbose: bool = noargs::flag("verbose")
#       .doc("Enable verbose logging")
#       .take(&mut args)
#       .is_present();
#
#   // Value flag with default
#   let level: LogLevel = noargs::opt("loglevel")
#       .doc("Log level")
#       .default("info")
#       .take(&mut args)
#       .then(|o| o.value().parse())?;
#
#   // Value flag without default (Option<T>)
#   let logfile: Option<PathBuf> = noargs::opt("logfile")
#       .ty("FILE")
#       .doc("Log file path")
#       .take(&mut args)
#       .present_and_then(|o| Ok::<_, Infallible>(o.value().into()))?;
#
#   // Positional argument
#   let node: NodeName = noargs::arg("<ERLANG_NODE>")
#       .doc("Target Erlang node name")
#       .example("foo@localhost")
#       .take(&mut args)
#       .then(|a| a.value().parse())?;
#
#   // Subcommand
#   if noargs::cmd("run").doc("Run the dashboard").take(&mut args).is_present() {
#       // Parse run-specific flags from `args` here
#   }
#
#   // Finalize: returns help text if --help, error if leftover args
#   if let Some(help) = args.finish()? {
#       print!("{help}");
#       return Ok(());
#   }
#
# REAL-WORLD noargs USERS (from `noargs = "..."` in Cargo.toml):
#
#   * shiguredo/hisui — recording composition tool
#   * sile/erldash — Erlang dashboard (THIS completion)
#   * sile/mamegrep — interactive git-grep TUI
#   * sile/sorastats — Sora WebRTC SFU statistics viewer
#   * sile/mpeg2ts — MPEG2-TS parser CLI
#   * sile/niho — file utility
#   * shiguredo/v4l2-rs — Video4Linux2 Rust bindings examples
#   * shiguredo/sora-rust-sdk — Sora WebRTC SDK examples
#   * shiguredo/rtmp-rs — RTMP server examples
#   * shiguredo/websocket-rs — WebSocket server examples
#   * NH-RED-TEAM/RustHound — Active Directory enumeration
#   * bluecatengineering/fast_radix_trie — radix trie benchmarks
#   * veltiosoft/vss — static site generator
#   * zztkm/ztb — zztkm tool box
#   * taisan11/lanran — LAN tool
#
# Notably, noargs has become the DEFAULT CLI library for the SHIGUREDO
# ECOSYSTEM (Japanese WebRTC SFU vendor) — every example binary in their
# v4l2-rs, sora-rust-sdk, rtmp-rs, websocket-rs repos uses noargs.
# This makes noargs a DE-FACTO STANDARD in a specific Japanese Rust dev
# community alongside Takeru Ohta's personal projects.
#
# -----------------------------------------------------------------------------
# ERLDASH CLI SURFACE (verbatim from src/main.rs)
# -----------------------------------------------------------------------------
#
# USAGE:
#   erldash [GLOBAL-FLAGS] <SUBCOMMAND> [SUBCOMMAND-ARGS...]
#
# Global flags:
#   --version, -V                Show version and exit
#   --help, -h                   Show help and exit
#   --logfile <FILE>             Log file path
#   --loglevel <LEVEL>           Log level: off|error|warn|info|debug|trace
#                                (default: info)
#   --truncate-log               Truncate log file instead of appending
#
# Subcommand: run <ERLANG_NODE>
#   Run the dashboard against a live Erlang node.
#
#   -i, --polling-interval <SECONDS>
#                                Erlang metrics polling interval
#                                (default: 1)
#   -c, --cookie <COOKIE>        Erlang cookie (default: ~/.erlang.cookie content)
#   --record <FILE>              Record collected metrics to file for later replay
#   -p, --port <PORT>            Port number on which the target node listens
#                                (bypasses EPMD; useful when EPMD is blocked)
#   <ERLANG_NODE>                Target Erlang node name (e.g., foo@localhost)
#
# Subcommand: replay <RECORD_FILE>
#   Replay a previously recorded dashboard session.
#
#   <RECORD_FILE>                Path to the file written via --record
#
# =============================================================================

_erldash() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands log_levels

    subcommands=(
        'run:run the dashboard against a live Erlang node'
        'replay:replay a previously recorded dashboard session'
    )

    log_levels=(
        'off:disable logging'
        'error:errors only'
        'warn:warnings and above'
        'info:informational events (default)'
        'debug:debug events'
        'trace:trace events (verbose)'
    )

    _arguments -C \
        '(-V --version)'{-V,--version}'[show version and exit]' \
        '(-h --help)'{-h,--help}'[show help and exit]' \
        '--logfile[log file path]:logfile:_files' \
        '--loglevel[log level]:level:->loglevel' \
        '--truncate-log[truncate log file instead of appending]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (loglevel)
            _describe -t loglevels 'log level' log_levels && ret=0
            ;;
        (cmd)
            _describe -t subcommands 'erldash subcommand' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (run)
                    _arguments \
                        '(-i --polling-interval)'{-i,--polling-interval}'[Erlang metrics polling interval (seconds)]:seconds:' \
                        '(-c --cookie)'{-c,--cookie}'[Erlang cookie (default ~/.erlang.cookie)]:cookie:' \
                        '--record[record metrics to file for later replay]:record file:_files' \
                        '(-p --port)'{-p,--port}'[port the target Erlang node listens on (bypass EPMD)]:port:_ports' \
                        ':Erlang node name:' \
                        && ret=0
                    ;;
                (replay)
                    _arguments \
                        ':recorded file:_files' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_erldash "$@"
