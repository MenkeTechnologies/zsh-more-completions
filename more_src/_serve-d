#compdef serve-d
# Documentation: https://github.com/Pure-D/serve-d
# serve-d - D LSP server (dlang language server protocol server)

local ret=1

_arguments -s -S \
  '*'{-r,--require}'=[add a required feature set, crash on startup if unknown]:feature' \
  '*'{-p,--provide}'=[features to let the editor handle for better integration]:feature' \
  '(-v --version)'{-v,--version}'[print version of program]' \
  '--logfile=[output all log into the given file instead of stderr]:file:_files' \
  '--loglevel=[change the log level for output logging]:level' \
  '--lang=[change the language of GUI messages]:lang' \
  '--wait[wait for a second before starting, for debugging]' && ret=0

return ret
