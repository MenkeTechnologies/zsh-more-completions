#compdef ansible-builder

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a build context without building'
  'build:build an execution environment image'
  'introspect:introspect collections and dependencies'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '--version[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      build)
        _arguments \
          '(-f --file)'{-f,--file}'[path to execution environment file]:file:_files -g "*.yml"' \
          '(-b --build-arg)'{-b,--build-arg}'[build argument]:key=value' \
          '(-c --context)'{-c,--context}'[build context directory]:directory:_files -/' \
          '(-t --tag)'{-t,--tag}'[image tag]:tag' \
          '--container-runtime=[container runtime]:runtime:(docker podman)' \
          '--build-context=[additional build context]:context' \
          '--no-cache[do not use cache for building]' \
          '--prune-images[prune dangling images after build]' \
          '--squash=[squash layers]:option:(new all off)' \
          '--galaxy-keyring=[Galaxy keyring file]:keyring:_files' \
          '--galaxy-required-valid-signature-count=[required signature count]:count' \
          '--galaxy-ignore-signature-status-codes=[ignore specific GPG status codes]:codes' \
          '(-v --verbosity)'{-v,--verbosity}'[verbosity level]:level:(0 1 2 3)' && ret=0
        ;;
      create)
        _arguments \
          '(-f --file)'{-f,--file}'[path to execution environment file]:file:_files -g "*.yml"' \
          '(-c --context)'{-c,--context}'[build context directory]:directory:_files -/' \
          '--output-filename=[output filename]:filename' \
          '(-v --verbosity)'{-v,--verbosity}'[verbosity level]:level:(0 1 2 3)' && ret=0
        ;;
      introspect)
        _arguments \
          '--sanitize[sanitize and de-duplicate requirements]' \
          '--user-pip=[path to user pip requirements]:file:_files' \
          '--user-bindep=[path to user bindep requirements]:file:_files' \
          '--write-pip=[output pip requirements]:file:_files' \
          '--write-bindep=[output bindep requirements]:file:_files' \
          '(-v --verbosity)'{-v,--verbosity}'[verbosity level]:level:(0 1 2 3)' \
          '1:collection specifier directory:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
