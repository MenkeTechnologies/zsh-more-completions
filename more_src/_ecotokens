_ecotokens_commands() {
    local commands; commands=(
'hook:Intercept a bash command via PreToolUse hook (reads JSON from stdin)' \
'hook-gemini:Intercept a Gemini CLI tool call via BeforeTool hook (reads JSON from stdin)' \
'hook-qwen:Intercept a Qwen Code tool call via PreToolUse hook (reads JSON from stdin)' \
'hook-post:Intercept a native Claude Code tool result via PostToolUse hook (reads JSON from stdin)' \
'hook-post-gemini:Intercept a Gemini CLI tool result via AfterTool hook (reads JSON from stdin)' \
'hook-post-qwen:Intercept a Qwen Code tool result via PostToolUse hook (reads JSON from stdin)' \
'filter:Execute a command, filter its output, record metrics' \
'gain:Show token savings report' \
'install:Install ecotokens hook in ~/.claude/settings.json, ~/.gemini/settings.json, ~/.qwen/settings.json, or ~/.pi/agent/extensions/' \
'uninstall:Remove ecotokens hook from ~/.claude/settings.json, ~/.gemini/settings.json, ~/.qwen/settings.json, or ~/.pi/agent/extensions/' \
'config:Show or update configuration' \
'index:Index a directory for BM25 + symbolic search' \
'outline:List symbols in a file or directory' \
'symbol:Look up a symbol by its stable ID' \
'search:Search the indexed codebase' \
'trace:Trace callers or callees of a symbol' \
'watch:Watch a directory and keep the index up to date automatically' \
'duplicates:Detect code duplications in the indexed codebase and propose refactoring' \
'session-start:Called by Claude Code SessionStart hook — starts watch if auto-watch is enabled' \
'session-end:Called by Claude Code SessionEnd hook — stops watch if auto-watch is enabled' \
'auto-watch:Enable or disable automatic watch on Claude Code session start/end' \
'abbreviations:Enable, disable or inspect the word abbreviations token-saving feature' \
'clear:Delete recorded interceptions (selective or total)' \
'update:Check for and install the latest ecotokens version' \
'mcp-server:Start the MCP server (stdio transport — for Claude Code mcpServers registration)' \
'completions:Generate shell completion script (bash, zsh, fish, powershell, elvish)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'ecotokens commands' commands "$@"
}
