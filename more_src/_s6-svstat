#compdef s6-svstat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u[print whether service is up]' \
  '-U[print whether service is up and ready]' \
  '-d[print whether service is down]' \
  '-D[print whether service is down and ready]' \
  '-w[print whether service wants up]' \
  '-r[print whether service is ready]' \
  '-p[print PID of service]' \
  '-e[print exit info of service]' \
  '-s[print start time of service]' \
  '-o[print uptime or downtime]' \
  '-n[use TAI64N format for timestamps]' \
  '1:service directory:_files -/' && ret=0

return ret
