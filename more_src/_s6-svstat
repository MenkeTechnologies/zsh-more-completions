#compdef s6-svstat
# Documentation: https://skarnet.org/software/s6/s6-svstat.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-o+[comma-separated field list]:fields:_values -s , field up wantedup normallyup ready paused pid pgid exitcode signal signum updownsince readysince updownfor readyfor' \
  '-u[shorthand for -o up]' \
  '-w[shorthand for -o wantedup]' \
  '-N[shorthand for -o normallyup]' \
  '-r[shorthand for -o ready]' \
  '-p[shorthand for -o pid]' \
  '-g[shorthand for -o pgid]' \
  '-e[shorthand for -o exitcode]' \
  '-s[shorthand for -o signal]' \
  '-t[shorthand for -o updownfor]' \
  '-n[print signal numbers instead of names]' \
  '1:service directory:_files -/' && ret=0

return ret
