#compdef getfattr-cli
# _getfattr-cli — attr getfattr get extended attributes of filesystem objects CLI alias (attr team, C); custom argparse
# upstream: https://savannah.nongnu.org/projects/attr

_getfattr-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-d[dump all attrs]' \
        '--dump[dump all attrs]' \
        '-e+[encoding]:e:(text hex base64)' \
        '--encoding=+[encoding]:e:(text hex base64)' \
        '-m+[pattern]:str:' \
        '--match=+[pattern]:str:' \
        '--only-values[only print values]' \
        '-h[no follow symlinks]' \
        '--no-dereference[no follow symlinks]' \
        '--absolute-names[do not strip leading slash]' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-L[follow symlinks]' \
        '--logical[follow symlinks]' \
        '-P[no follow symlinks]' \
        '--physical[no follow symlinks]' \
        '*:files:_files'
}

_getfattr-cli "$@"
