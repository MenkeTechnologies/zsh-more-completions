#compdef bean-doctor

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'lex:dump lexer output'
  'dump-lexer:alias for lex'
  'parse:debug parser'
  'roundtrip:roundtrip test'
  'directories:validate dirs'
  'list-options:list options'
  'print-options:print parsed options'
  'deps:report deps status'
  'checkdeps:alias for deps'
  'context:transaction context'
  'linked:linked transactions'
  'missing-open:missing Open directives'
  'display-context:inferred precision'
  'validate-html:validate HTML'
)

_arguments -C \
  '1: :->subcommand' \
  '2:filename:_files -g "*.beancount"' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'bean-doctor subcommand' subcommands && ret=0 ;;
esac

return ret
