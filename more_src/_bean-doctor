#compdef bean-doctor
# Documentation: https://manpages.debian.org/testing/beancount/bean-doctor.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bean-doctor: Beancount debugging tool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'lex:dump lexer output'
  'dump_lexer:alias for lex'
  'parse:debug parser'
  'roundtrip:roundtrip test on ledger files'
  'directories:verify directory structure matches ledger accounts'
  'list_options:list available options'
  'print_options:print parsed options'
  'deps:report runtime deps status'
  'checkdeps:alias for deps'
  'context:describe transaction application context'
  'linked:list linked transactions'
  'missing_open:generate missing Open directives'
  'display_context:show inferred precision'
  'validate_html:validate HTML files'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '2:filename:_files -g "*.beancount"' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'bean-doctor subcommand' subcommands && ret=0 ;;
esac

return ret
