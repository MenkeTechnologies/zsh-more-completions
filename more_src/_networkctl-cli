#compdef networkctl
# _networkctl-cli — systemd-networkd control client; query and modify networkd state
# upstream: https://github.com/systemd/systemd

_networkctl-cli() {
    local -a sub=(
        'list:list active links'
        'status:show link status'
        'lldp:list LLDP neighbors'
        'label:print acquired DHCP labels'
        'delete:delete a virtual link'
        'up:bring link up'
        'down:bring link down'
        'renew:renew DHCP lease'
        'forcerenew:force renew DHCP lease'
        'reconfigure:reconfigure link'
        'reload:reload networkd config'
        'edit:edit a network file'
        'cat:print a network file'
        'mask:mask a network file'
        'unmask:unmask a network file'
        'persistent-storage:set persistent storage attribute'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--no-pager[no pager]' \
        '--no-legend[no header/footer]' \
        '(-a --all)'{-a,--all}'[show all links incl. unmanaged]' \
        '(-s --stats)'{-s,--stats}'[show link statistics]' \
        '(-l --full)'{-l,--full}'[full output]' \
        '--no-reload[do not reload after edit]' \
        '--drop-in+[drop-in name]:name:' \
        '--runtime[apply in /run not /etc]' \
        '-n+[journal lines]:n:' \
        '--lines+[journal lines]:n:' \
        '--json+[json mode]:mode:(pretty short off)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'networkctl subcommand' sub ;;
        args)
            case $words[1] in
                status|lldp|up|down|renew|forcerenew|reconfigure|delete|persistent-storage) _arguments '*:link:' ;;
                edit|cat|mask|unmask) _arguments '*:network file:_files -g "*.network"' ;;
            esac
            ;;
    esac
}

_networkctl-cli "$@"
