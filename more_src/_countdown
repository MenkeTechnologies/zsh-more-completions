#compdef countdown

# antonmedv/countdown — std flag package (see main.go)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-up[count up from zero]' \
  '-say[announce remaining time via speech]' \
  '-title=[title below timer]:title:' \
  '-h[Go flag package usage]' \
  '-help[Go flag package usage]' \
  '1:duration or clock time:' && ret=0

return ret
