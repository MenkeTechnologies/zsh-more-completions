#compdef countdown
# Documentation: https://github.com/antonmedv/countdown
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# antonmedv/countdown - terminal countdown timer.
# Flags via Go's standard `flag` package; duration or HH:MMam/pm target time.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-up[count up from zero]' \
  '-say[announce remaining time via speech]' \
  '-title=[title below timer]:title:' \
  '-h[Go flag package usage]' \
  '-help[Go flag package usage]' \
  '1:duration or clock time:' && ret=0

return ret
