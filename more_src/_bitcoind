#compdef bitcoind bitcoin-qt bitcoin-node
# Documentation: https://github.com/bitcoin/bitcoin (src/init.cpp SetupServerArgs / CLI bootstrap args)
# Reference accessed: 2026-05-29
# Note: Bitcoin Core accepts hundreds of bitcoin.conf settings as -opt=value; this completion
# covers the canonical CLI bootstrap flags only (network selection, datadir, daemon controls).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '(- *)-help[show help message]' \
  '(- *)-?[show help message]' \
  '(- *)-help-debug[show debugging help]' \
  '-conf=-[path to read-only configuration file]:file:_files' \
  '-datadir=-[data directory]:dir:_directories' \
  '-settings=-[path to dynamic settings data file]:file:_files' \
  '-pid=-[specify pid file]:file:_files' \
  '-testnet[run on testnet3 network]' \
  '-testnet4[run on testnet4 network]' \
  '-signet[run on signet network]' \
  '-regtest[run in regression test mode]' \
  '-chain=-[select chain]:chain:(main test testnet4 signet regtest)' \
  '-daemon[run in the background as a daemon]' \
  '-daemonwait[wait for initialization to finish before exiting]' \
  '-debug=-[output debugging information]:category:' \
  '-debugexclude=-[exclude debugging category]:category:' \
  '-logips[include IP addresses in debug output]' \
  '-logsourcelocations[prepend debug output with file:line]' \
  '-logthreadnames[prepend debug output with thread name]' \
  '-logtimestamps[prepend debug output with timestamps]' \
  '-printtoconsole[print log to console]' \
  '-shrinkdebugfile[shrink debug.log file on client startup]' \
  '*:: :->args' && ret=0

return ret
