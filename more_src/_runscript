#compdef runscript
# Documentation: https://manpages.debian.org/testing/openrc/openrc-run.8.en.html
# Reference accessed: 2026-05-17
# Verified: OpenRC openrc-run(8) Debian manpage. `runscript` is the
# legacy alias for `openrc-run`; same flag surface and SERVICE_SCRIPT
# COMMAND positional grammar.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated positional `log file`, `homedir` (those belong to
# Norton/minicom runscript, not OpenRC's runscript).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-D --nodeps)'{-D,--nodeps}'[ignore dependencies]' \
  '(-s --ifstarted)'{-s,--ifstarted}'[only run if started]' \
  '(-S --ifstopped)'{-S,--ifstopped}'[only run if stopped]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-Z --dry-run)'{-Z,--dry-run}'[dry run]' \
  '(-C --nocolor)'{-C,--nocolor}'[disable color output]' \
  '1:service script:_files' \
  '*:command:(start stop restart status pause condrestart reload zap describe)' && ret=0
return ret
