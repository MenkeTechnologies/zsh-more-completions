#compdef pkg-checker
# Source: cargo binstall pkg-checker@0.8.2
# Probed via: completion zsh
# Repository: https://github.com/jenkinpan/pkg-checker-rs

autoload -U is-at-least

_pkg-checker() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v[显示详细信息]' \
'--verbose[显示详细信息]' \
'-u[只显示有更新的包]' \
'--updates-only[只显示有更新的包]' \
'--no-interactive[非交互模式（默认是交互模式）]' \
'--include-prerelease[包含预发布版本（alpha、beta、rc等）]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_pkg-checker_commands" \
"*::: :->pkg-checker" \
&& ret=0
    case $state in
    (pkg-checker)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pkg-checker-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- 要生成补全脚本的 shell:((bash\:"Bash shell"
zsh\:"Zsh shell"
fish\:"Fish shell"
powershell\:"PowerShell"
elvish\:"Elvish shell"
nushell\:"Nushell"))' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_pkg-checker__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:pkg-checker-help-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_pkg-checker_commands] )) ||
_pkg-checker_commands() {
    local commands; commands=(
'completion:生成 shell 补全脚本' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pkg-checker commands' commands "$@"
}
(( $+functions[_pkg-checker__completion_commands] )) ||
_pkg-checker__completion_commands() {
    local commands; commands=()
    _describe -t commands 'pkg-checker completion commands' commands "$@"
}
(( $+functions[_pkg-checker__help_commands] )) ||
_pkg-checker__help_commands() {
    local commands; commands=(
'completion:生成 shell 补全脚本' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'pkg-checker help commands' commands "$@"
}
(( $+functions[_pkg-checker__help__completion_commands] )) ||
_pkg-checker__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'pkg-checker help completion commands' commands "$@"
}
(( $+functions[_pkg-checker__help__help_commands] )) ||
_pkg-checker__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'pkg-checker help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_pkg-checker" ]; then
    _pkg-checker "$@"
else
    compdef _pkg-checker pkg-checker
fi
