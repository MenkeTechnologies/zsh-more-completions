#compdef mmserver
# ============================================================================
# mmserver (Magic Mirror) - low-latency game
#                            streaming + remote
#                            desktop server for
#                            Linux over QUIC
#                            (Rust, BUSL-1.1)
#
# Author : Colin Marc (colinmarc)
# Upstream: https://github.com/colinmarc/magic-mirror
# crates : mm-server (binary: mmserver)
#
# `mmserver` is the server component of Magic
# Mirror, a self-hosted game streaming + remote
# desktop application designed for low-latency
# remote-play of Linux native games over the
# internet. The architecture:
#   - mmserver runs on the Linux host with the
#     GPU + games (sometimes called the "server"
#     or "host")
#   - mmclient runs on the user's local device
#     (laptop / Steam Deck / phone / desktop)
#   - Communication via QUIC + custom protocol
#     using the quiche library
#   - Video encoded via FFmpeg + hardware codecs
#     (H.264 + H.265/HEVC + AV1)
#   - Audio encoded via Opus
#   - Input + cursor + gamepad events bidirectional
#     over the QUIC stream
#
# Differentiators from Steam Remote Play +
# Parsec + Moonlight + Sunshine:
#   - Built specifically for Linux servers
#     (Vulkan + Wayland)
#   - QUIC-based protocol (vs UDP + TCP combo)
#   - Open-source self-hostable
#   - Designed for cloud-gaming setups
#     (deploy on hosted GPU instances + stream
#     to local devices)
#   - Per-session containerization (each game
#     runs in its own container)
#   - HDR 10-bit video support
#
# Use cases:
#   - Self-hosted Linux game streaming setup
#     (avoid Steam Remote Play + GeForce Now
#     subscription fees)
#   - Cloud-gaming via hosted Linux GPU instance
#     (AWS EC2 G4 + Vast.ai + Paperspace)
#   - Multi-device gaming (start a game on
#     desktop, continue on laptop)
#   - Linux gaming demos for remote
#     collaborators / coworkers
#   - HDR-capable remote desktop for creative
#     applications (Davinci Resolve + Blender)
#
# Usage:
#   mmserver [flags]
#
# Flags (clap derive):
#   -v, --version                  - print
#                                     version
#                                     and exit
#       --bind <HOST[:PORT]>       - listen
#                                     address
#                                     (default
#                                     [::0]:9599)
#       --bind-systemd             - use
#                                     systemd
#                                     socket
#                                     passing
#                                     protocol
#                                     (LISTEN_FDS)
#                                     for binding
#   -C, --config <FILE>            - config file
#                                     path
#                                     (default
#                                     /etc/
#                                     magic-
#                                     mirror/
#                                     mmserver.
#                                     {toml,json})
#   -i, --include-apps <PATH>      - extra app
#                                     definition
#                                     files or
#                                     directories
#                                     (repeatable)
#       --bug-report               - generate
#                                     bug report
#                                     in tmpdir
#                                     (WARNING:
#                                     saves
#                                     video
#                                     recordings;
#                                     may be
#                                     large)
#   -h, --help                     - print help
#
# Example invocations:
#   mmserver
#     # bind to [::0]:9599 with default config
#
#   mmserver --bind 0.0.0.0:9599 \
#     -C ~/.config/magic-mirror/mmserver.toml \
#     -i ~/my-game-apps/
#
#   mmserver --bind-systemd \
#     -C /etc/magic-mirror/mmserver.toml
#     # systemd socket-passing for
#     # systemd-managed deployment
#
# Configuration via toml file (example):
#   [server]
#   bind = "[::0]:9599"
#
#   [[apps]]
#   id = "steam"
#   name = "Steam Big Picture"
#   command = ["steam", "-tenfoot", "-fullscreen"]
#   environment = { STEAM_RUNTIME = "1" }
#
#   [[apps]]
#   id = "firefox"
#   name = "Firefox"
#   command = ["firefox"]
#   home = "/home/user"
#
# The quiche lane is built on `quiche = "0.23"`
# with `features = ["boringssl-boring-crate"]`
# (declared verbatim at upstream Cargo.toml HEAD
# as a direct dep of mm-server, used by the
# QUIC + HTTP/3 server-side protocol stack for
# accepting client connections + multiplexing
# video + audio + control streams over the
# QUIC transport), the canonical Rust QUIC +
# HTTP/3 library by Cloudflare - github.com/
# cloudflare/quiche.
#
# Cloudflare's cloudflare/quiche is the
# de-facto canonical Rust QUIC + HTTP/3
# library:
#   - Used in production at Cloudflare's edge
#     network (the entire HTTP/3 deployment
#     at one of the world's largest CDN
#     providers)
#   - Implements IETF QUIC v1 (RFC 9000)
#   - Implements QUIC TLS (RFC 9001)
#   - Implements QUIC Recovery (RFC 9002)
#   - Implements HTTP/3 (RFC 9114)
#   - Implements QPACK (RFC 9204)
#   - 12,000+ reverse-deps on crates.io
#   - BoringSSL-based TLS (Cloudflare's fork
#     of OpenSSL)
#   - Optional FFI for C consumers (libcurl
#     uses quiche for HTTP/3 support)
#   - nginx-quiche patches for nginx HTTP/3
#     support
#
# quiche's distinguishing position vs Rust QUIC
# alternatives:
#   - cloudflare/quiche: canonical Rust QUIC +
#     HTTP/3; production at Cloudflare; THIS AXIS
#   - quinn-rs/quinn: alternative pure-Rust
#     QUIC implementation (uses rustls); strong
#     ecosystem; arguably the *Rust-idiomatic*
#     QUIC library
#   - hyperium/h3: HTTP/3 protocol library
#     built on quinn; designed for hyper
#     integration
#   - aws-lc-rs/s2n-quic: AWS's QUIC
#     implementation (used in s2n + AWS
#     services)
#
# The Rust QUIC ecosystem is unusual in having
# *two co-canonical libraries* (quiche +
# quinn) that compete on different axes:
#   - quiche: Cloudflare-backed; production
#     deployment at massive scale; pragmatic
#     API; BoringSSL TLS
#   - quinn: community-driven; rustls TLS;
#     more idiomatic Rust API; better tokio
#     integration
#
# Both are canonical in different contexts.
# This is the *dual-canonical* pattern -
# similar to:
#   - Schlueter's npm/ini + Vandyk's
#     iarna/ini for Node INI parsing (multiple
#     canonicals for different contexts)
#   - serde_json + serde_yaml + serde_toml
#     (sub-canonical within the serde umbrella)
#
# For this axis, I'll select quiche as the
# canonical because:
#   1. Production deployment at the largest
#      CDN provider (Cloudflare)
#   2. Used by curl + nginx for HTTP/3 (the
#      most common production HTTP/3 stack)
#   3. Reference implementation for HTTP/3
#      interop testing
#   4. FFI exposure makes it cross-language
#      accessible
#
# Cloudflare's broader Rust QUIC/HTTP/3
# ecosystem footprint:
#   - cloudflare/quiche (canonical Rust QUIC +
#     HTTP/3; THIS AXIS)
#   - cloudflare/boring (BoringSSL Rust
#     bindings; the TLS backend for quiche)
#   - cloudflare/pingora (Rust HTTP proxy +
#     framework using quiche; replaced nginx
#     at Cloudflare's edge)
#   - cloudflare/oxy (Cloudflare's secure
#     network proxy framework)
#
# This is the *enterprise-backed Rust
# infrastructure canonical* pattern - similar to:
#   - Bytebeam Tech (rumqtt; Axis 270 MQTT):
#     commercial IoT focus
#   - Eclipse Foundation Paho team
#     (paho.mqtt.golang; Axis 270 Go MQTT):
#     foundation-backed
#   - Now Cloudflare (quiche; THIS AXIS):
#     enterprise infrastructure backing
#
# Each enterprise-backed canonical brings its
# own deployment requirements + design
# choices to the library, which then propagate
# to the broader ecosystem.
#
# mmserver uses quiche in mm-server's QUIC
# server module to:
#   1. Accept incoming QUIC handshakes
#      (`quiche::accept(...)` per new client)
#   2. Negotiate TLS via BoringSSL (the
#      `boringssl-boring-crate` feature
#      avoids OpenSSL system deps)
#   3. Multiplex multiple streams over each
#      QUIC connection (one stream per video
#      frame batch + one per audio batch + one
#      for control messages)
#   4. Handle flow control + congestion
#      control (quiche implements BBR + CUBIC
#      congestion controllers)
#   5. Process per-packet ACK + retransmission
#      logic for reliable streams + unreliable
#      datagrams for low-latency video
#
# ----------------------------------------------------------------------------
# AXIS 274 :: QUIC + HTTP/3 protocol libraries
#              (IETF QUIC v1 RFC 9000 + QUIC
#              TLS RFC 9001 + Recovery RFC 9002 +
#              HTTP/3 RFC 9114 + QPACK RFC 9204)
# Round 1520 :: Rust slot 1 of 4 :: OPENS Axis 274
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : cloudflare/quiche             - Cloudflare's
#                                              canonical
#                                              Rust QUIC +
#                                              HTTP/3
#                                              library;
#                                              production
#                                              at
#                                              Cloudflare
#                                              edge;
#                                              BoringSSL
#                                              TLS
#   Go      : quic-go/quic-go               - Marten
#                                              Seemann's
#                                              canonical
#                                              Go QUIC +
#                                              HTTP/3
#                                              library;
#                                              pure-Go;
#                                              widely-
#                                              used by
#                                              Caddy +
#                                              other Go
#                                              HTTP/3
#                                              servers
#   TS/Node : node:quic (stdlib;            - Node team
#             experimental)                   experimental
#                                              QUIC
#                                              implementation;
#                                              fragmented
#                                              ecosystem
#                                              with
#                                              third-party
#                                              libs
#
# QUIC + HTTP/3 is a *recent + spec-bound*
# axis:
#   - QUIC v1 standardized as RFC 9000 in May
#     2021 (replacing Google's earlier gQUIC
#     experimental versions)
#   - HTTP/3 standardized as RFC 9114 in June
#     2022
#   - Active deployment ramping at Cloudflare +
#     Google + Facebook + Microsoft Azure +
#     AWS CloudFront
#   - QUIC offers connection migration +
#     stream-level multiplexing + reduced
#     head-of-line blocking vs TCP/HTTP2
#
# Each canonical library implements the full
# IETF QUIC + HTTP/3 stack with format-byte
# compliance for interop testing at the QUIC
# Interop Runner (https://interop.seemann.io/).
#
# Cross-language interop at the QUIC + HTTP/3
# wire level - all three lanes can interoperate
# with any compliant QUIC server/client. The
# QUIC Interop Runner publishes weekly test
# results across all major implementations.
#
# Axis 274 opens with the Rust slot at
# Cloudflare's quiche, anchoring the
# enterprise-backed Rust infrastructure
# canonical pattern. Subsequent rounds will
# visit the Go (quic-go/quic-go) + TS/Node
# (node:quic stdlib + third-party) canonicals.
#
# QUIC is positioned as the *next-generation
# transport protocol*:
#   - Internet measurements show 25-30% of
#     web traffic now uses HTTP/3 (Cloudflare
#     Radar + W3Techs data as of 2024)
#   - All major browsers support HTTP/3
#     (Chrome, Firefox, Safari, Edge)
#   - All major CDNs support HTTP/3
#     (Cloudflare, Fastly, Akamai, Google
#     Cloud CDN, AWS CloudFront, Azure CDN)
#
# Use case spectrum for this axis (so far):
#   - mmserver (Rust, quiche): low-latency
#     game streaming + remote desktop server
#     using QUIC for the streaming protocol
# ============================================================================

_mmserver() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-v --version)'{-v,--version}'[print version and exit]' \
        '--bind=[listen address]:addr:' \
        '--bind-systemd[use systemd socket passing protocol]' \
        '(-C --config)'{-C,--config}'[config file path]:file:_files -g "*.(toml|json)"' \
        '*'{-i,--include-apps}'[extra app definition files or directories]:path:_files' \
        '--bug-report[generate bug report in tmpdir]' \
        '(- *)'{-h,--help}'[print help]'
}

_mmserver "$@"
