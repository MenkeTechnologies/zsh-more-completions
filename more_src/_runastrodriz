#compdef runastrodriz
# Documentation: https://github.com/spacetelescope/drizzlepac/blob/main/drizzlepac/runastrodriz.py
# DrizzlePac pipeline driver: align and combine HST images

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-b[turn off writing headerlets]' \
  '-d[debug mode]' \
  '-a[force alignment]' \
  '-f[force reprocessing]' \
  '-g[do not align to Gaia]' \
  '-i[run in memory]' \
  '-m[make manifest (WFPC2 data)]' \
  '-n+[number of cores]:cores:' \
  '-v+[verify guiding]:value:' \
  '1:input file:_files' \
  '2:new path:_files -/' && ret=0

return ret
