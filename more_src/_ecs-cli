#compdef ecs-cli
# Documentation: https://github.com/aws/amazon-ecs-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'compose:Docker Compose on ECS'
      'configure:configure default cluster/region'
      'up:run task or service'
      'down:stop Compose project'
      'local:local development (deprecated paths check docs)'
      'ps:list tasks or services'
      'images:ECR image helpers'
      'license:license text'
      'version:print version'
    )
    _describe -t commands 'ecs-cli command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      configure)
        _arguments -s -S \
          '--cluster=[default ECS cluster]:cluster' \
          '--region=[default AWS region]:region' \
          '--config-name=[config profile name]:name' \
          '--default-launch-type=[default launch type]:(EC2 FARGATE)' \
          && ret=0
        ;;
      compose)
        _arguments -s -S \
          '2:compose-subcommand:(create up down ps scale service logs)' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
