#compdef byoh byoh-hostagent byoh-hostagent-manager
# _byoh — VMware Cluster API Provider Bring Your Own Host BYOH host agent for managing Linux/Windows machines as Kubernetes nodes (vmware-tanzu team, Go); cobra
# upstream: https://github.com/vmware-tanzu/cluster-api-provider-bringyourownhost

_byoh() {
    local -a sub=(
        'register:register host with management cluster'
        'reset:reset host configuration'
        'status:show host agent status'
        'logs:show host agent logs'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--bootstrap-kubeconfig=+[bootstrap kubeconfig]:file:_files' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--label=+[label]:str:' \
        '--cert-expiry-duration=+[duration]:str:' \
        '--metrics-bind-address=+[addr]:str:' \
        '--health-probe-bind-address=+[addr]:str:' \
        '--leader-elect[enable leader election]' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--downloadpath=+[k8s components dir]:dir:_files -/' \
        '--skip-installation[skip k8s component install]' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--zap-devel[zap devel mode]' \
        '--zap-encoder=+[encoder]:e:(json console)' \
        '--zap-log-level=+[level]:l:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=+[level]:l:(info error panic)' \
        '--zap-time-encoding=+[encoding]:e:(rfc3339nano rfc3339 iso8601 millis nanos)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'byoh subcommand' sub ;;
        args)
            case $words[1] in
                register) _arguments \
                    '--bootstrap-kubeconfig=+[bootstrap kubeconfig]:file:_files' \
                    '--namespace=+[namespace]:str:' \
                    '--name=+[host name]:str:' \
                    '--label=+[label]:str:' ;;
                reset) _arguments \
                    '--namespace=+[namespace]:str:' \
                    '--name=+[host name]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_byoh "$@"
