#compdef trl
# _trl — HuggingFace TRL: transformer reinforcement learning CLI (huggingface/trl)
# upstream: https://github.com/huggingface/trl
# Subcommands from trl/cli/main.py + trl/cli/commands/*.

_trl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_trl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            local -a common
            common=(
                '--model_name_or_path=[base model name or path]:model:'
                '--dataset_name=[HuggingFace hub dataset name]:dataset:'
                '--dataset_train_split=[train split name]:split:(train validation test)'
                '--dataset_test_split=[eval split name]:split:(train validation test)'
                '--output_dir=[directory for checkpoints / logs]:dir:_files -/'
                '--per_device_train_batch_size=[per-device train batch size]:n:'
                '--per_device_eval_batch_size=[per-device eval batch size]:n:'
                '--gradient_accumulation_steps=[gradient accumulation steps]:n:'
                '--learning_rate=[learning rate]:lr:'
                '--num_train_epochs=[number of training epochs]:n:'
                '--max_steps=[total training steps (overrides epochs)]:n:'
                '--bf16[use bf16 mixed precision]'
                '--fp16[use fp16 mixed precision]'
                '--use_peft[enable PEFT (LoRA / QLoRA)]'
                '--lora_r=[LoRA rank]:n:'
                '--lora_alpha=[LoRA alpha]:n:'
                '--lora_dropout=[LoRA dropout]:p:'
                '--load_in_4bit[load model weights in 4-bit (QLoRA)]'
                '--load_in_8bit[load model weights in 8-bit]'
                '--report_to=[experiment-tracking sink (comma-separated)]:trackers:(wandb tensorboard mlflow comet_ml clearml none)'
                '*:trainer config YAML:_files -g "*.(yaml|yml|json)"'
            )
            case $words[1] in
                sft|dpo|kto|grpo|reward|rloo)
                    _arguments $common && ret=0 ;;
                vllm-serve)
                    _arguments \
                        '--model_name_or_path=[base model name or path]:model:' \
                        '--host=[bind host]:host:' \
                        '--port=[bind port]:port:' \
                        '--dtype=[weight dtype]:dtype:(auto float16 bfloat16 float32)' \
                        '--max_model_len=[max sequence length]:n:' \
                        '--tensor_parallel_size=[tensor-parallel world size]:n:' && ret=0 ;;
                env|skills) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_trl_commands] )) ||
_trl_commands() {
    local -a commands
    commands=(
        'sft:supervised fine-tuning'
        'dpo:Direct Preference Optimization training'
        'kto:Kahneman-Tversky Optimization training'
        'grpo:Group Relative Policy Optimization training'
        'reward:train a reward model'
        'rloo:RLOO (REINFORCE Leave-One-Out) training'
        'vllm-serve:serve a model through vLLM for online RL'
        'env:print TRL environment information'
        'skills:print available TRL training skills'
    )
    _describe -t commands 'trl command' commands
}

_trl "$@"
