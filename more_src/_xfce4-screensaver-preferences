#compdef xfce4-screensaver-preferences
# Documentation: https://manpages.debian.org/trixie/xfce4-screensaver/xfce4-screensaver-preferences.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian trixie manpage explicitly states "This program only accepts
# the standard GTK options."

# xfce4-screensaver-preferences: XFCE screensaver preferences GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display to use]:display:' && ret=0
return ret
