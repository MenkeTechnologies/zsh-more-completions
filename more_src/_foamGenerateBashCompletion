#compdef foamGenerateBashCompletion
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/tools/foamGenerateBashCompletion — emit Bash tab-completion functions for OpenFOAM utilities.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-local -l)'{-local,-l}'[use local file instead of project directory path]' \
    && ret=0

return ret
