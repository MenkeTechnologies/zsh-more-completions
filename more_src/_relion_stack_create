#compdef relion_stack_create
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: create a single MRC stack from images listed in a STAR file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file with images (rlnImageName) to save in a stack]:file:_files' \
  '--o=[output rootname]:file:_files' \
  '--split_per_micrograph[write separate stacks for each micrograph]' \
  '--apply_transformation[apply in-plane transformations by interpolation]' \
  '--apply_rounded_offsets_only[apply rounded translations only (recenter)]' \
  '--ignore_optics[ignore optics groups (RELION 3.0 STAR files)]' \
  '--one_by_one[write particles one by one to save memory]' \
  '--float16[write images in 16bit float format]' \
  '*:file:_files' && ret=0

return ret
