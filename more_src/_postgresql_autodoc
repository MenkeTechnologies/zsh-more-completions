#compdef postgresql_autodoc
# Documentation: https://github.com/cbbrowne/autodoc
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-d+[database name]:db:' \
  '-f+[output file prefix]:file:_files' \
  '-h+[database server host]:host:_hosts' \
  '-p+[database server port]:port:' \
  '-u+[database username]:user:_users' \
  '--password=[database password]:pass:' \
  '-l+[path to templates]:dir:_files -/' \
  '-t+[type of output]:type:(html dia neato xml dot zigzag)' \
  '-s+[schema regex]:schema:' \
  '-m+[show only tables matching regex]:regex:' \
  '--table=[tables to export, comma-separated]:tables:' \
  '--statistics[gather statistics via pgstattuple]' \
  '-\?[show help]' \
  '--help[show help]' \
  '*: :' && ret=0

return ret
