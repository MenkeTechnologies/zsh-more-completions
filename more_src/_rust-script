#compdef rust-script
# Documentation: https://man.archlinux.org/search?q=rust-script
# Reference accessed: 2026-05-16

# Zsh completion for rust-script (fornwall/rust-script). Args from src/arguments.rs (clap builder). macOS/Linux only flags.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--clear-cache[remove cached builds and exit if no script]' \
  '(-e --expr -l --loop)'{-e,--expr}'[run script operand as a Rust expression]' \
  '(-e --expr -l --loop)'{-l,--loop}'[run operand as closure over stdin lines]' \
  '(-l --loop)'--count'[with --loop pass (line, line_no) to closure]' \
  '(-b --base-path)'{-b,--base-path=}'[dependency resolution base path]:directory:_directories' \
  '(-c --cargo-output)'{-c,--cargo-output}'[show cargo build output]' \
  '*'{-d,--dep=}'+[add dependency name or name=version]:dep:' \
  '*'{-x,--extern=-}'+[macro_use extern crate for -e/-l modes]:crate:' \
  '*'{-u,--unstable-feature=-}'+[enable #![feature] for -e/-l modes]:feature:' \
  '--debug[build unoptimized binary]' \
  '(-f --force)'{-f,--force}'[rebuild script even if cached]' \
  '(-p --package)'{-p,--package}'[emit generated Cargo package path only]' \
  '--pkg-path=[place generated package at path]:path:_directories' \
  '--test[compile and run tests]' \
  '--bench[compile and run benchmarks]' \
  '(-t --toolchain)'{-t,--toolchain=}'[rustup toolchain for build]:toolchain:' \
  '(-w --wrapper)'{-w,--wrapper=}'[prefix command when running binary]:wrapper:' \
  '1::script or expression:_files -g "*.rs"' \
  '*::script args:_default'
