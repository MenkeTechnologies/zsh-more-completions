#compdef carl
# Documentation: https://man.archlinux.org/search?q=carl
# Reference accessed: 2026-05-16

# codeberg.org/birger/carl — Homebrew: Formula/c/carl.rb (tests: carl --sunday, --monday, --year)

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '(--sunday)'--sunday'[week starts Sunday]' \
  '(--monday)'--monday'[week starts Monday]' \
  '--year[print all months in year]' \
  '*::optional date:_default' && ret=0
return ret
