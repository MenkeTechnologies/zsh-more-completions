#compdef atktopbm
# Documentation: man atktopbm (Netpbm)
# Source: convert an Andrew Toolkit raster object to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:atk file:_files' \
    && ret=0

return ret
