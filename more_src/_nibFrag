#compdef nibFrag
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: extract a part of a .nib file as .fa

local ret=1

_arguments -s -S \
  '-masked[use lower-case characters for bases meant to be masked out]' \
  '-hardMasked[use upper-case for unmasked and N for masked-out bases]' \
  '-upper[use upper-case characters for all bases]' \
  '-name=[use given name after > in output sequence]:name' \
  '-dbHeader=[add full database info to the header]:db' \
  '-tbaHeader=[format header for compatibility with tba]:db' \
  '1:nib file:_files -g "*.nib"' \
  '2:start:' \
  '3:end:' \
  '4:strand:(+ m)' \
  '5:output fasta:_files' && ret=0

return ret
