#compdef virtual-worker
# _virtual-worker — Tinkerbell virtual workflow worker (replays Tinkerbell workflows without driving a real Docker runtime; used for testing the Tink server + workflow engine)
# upstream: https://github.com/tinkerbell/tink
# Flags from cmd/virtual-worker/cmd/root.go on tip (cobra + viper); each flag also reads from the corresponding env var (ID / RETRY_INTERVAL / MAX_RETRY / MAX_FILE_SIZE / TINKERBELL_GRPC_AUTHORITY / TINKERBELL_TLS / TINKERBELL_INSECURE_TLS).

_virtual-worker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-i --id)'{-i,--id}'=[worker id (required; ID env var)]:id:' \
        '--retry-interval=[retry interval (RETRY_INTERVAL env var)]:duration:' \
        '--max-retry=[max retries (MAX_RETRY env var)]:n:' \
        '--max-file-size=[max captured file size in bytes (MAX_FILE_SIZE env var)]:n:' \
        '--capture-action-logs=[capture action-container stdout/stderr in worker logs]:bool:(true false)' \
        '--sleep-min=[minimum sleep during faked docker operations]:duration:' \
        '--sleep-jitter=[jitter added to faked docker operation sleeps]:duration:' \
        '--tinkerbell-grpc-authority=[Tink server gRPC authority]:authority:' \
        '--tinkerbell-tls=[connect to the Tink server over TLS]:bool:(true false)' \
        '--tinkerbell-insecure-tls=[skip TLS verification when talking to the Tink server]:bool:(true false)'
}

_virtual-worker "$@"
