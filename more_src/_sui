#compdef sui

_sui_commands() {
    local -a commands
    commands=(
        'client:Client for interacting with the Sui network'
        'console:Start Sui interactive console'
        'fire-drill:Tool for testing incident response'
        'genesis:Bootstrap and initialize a new Genesis'
        'keytool:Sui keystore tool'
        'move:Tool to build and test Move applications'
        'network:Start Sui network'
        'validator:Tool for validators'
        'start:Start sui network'
    )
    _describe -t commands 'sui command' commands
}

_sui_client_commands() {
    local -a subcommands
    subcommands=(
        'active-address:Obtain the active address'
        'active-env:Obtain the active environment'
        'addresses:Obtain the managed addresses'
        'call:Call Move function'
        'dynamic-field:Query a dynamic field by address'
        'envs:List all Sui environments'
        'execute-signed-tx:Execute a signed transaction'
        'gas:Obtain all gas objects owned by the address'
        'merge-coin:Merge two coins together'
        'new-address:Generate new address and keypair'
        'new-env:Add new Sui environment'
        'object:Get object info'
        'objects:Obtain all objects owned by the address'
        'pay:Pay SUI to recipients'
        'pay-all-sui:Pay all SUI coins to a recipient'
        'pay-sui:Pay SUI coins to recipients'
        'publish:Publish Move modules'
        'split-coin:Split a coin object into multiple coins'
        'switch:Switch active address or environment'
        'transfer:Transfer object'
        'transfer-sui:Transfer SUI and pay gas with the same coin'
        'tx-block:Get the effects of executing the given transaction block'
        'upgrade:Upgrade Move modules'
        'verify-bytecode-meter:Run the bytecode verifier on a package'
        'verify-source:Verify local Move packages against on-chain packages'
    )
    _describe -t commands 'sui client command' subcommands
}

_sui() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '--client.config[Sets the file storing the state of our user accounts and gas objects]:file:_files' \
        '--json[Return command outputs in json format]' \
        '(-h --help)'{-h,--help}'[Print help]' \
        '(-V --version)'{-V,--version}'[Print version]' \
        '1:command:_sui_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                client)
                    _arguments -C \
                        '1:subcommand:_sui_client_commands' \
                        '*::arg:->client_args'
                    ;;
                move)
                    _arguments \
                        '--path[Path to a package]:path:_directories' \
                        '1:action:(build test coverage disassemble prove)' \
                        '*:args:'
                    ;;
                keytool)
                    _arguments \
                        '1:action:(generate import export list show sign decode update)' \
                        '*:args:'
                    ;;
            esac
            ;;
    esac
}

_sui "$@"
