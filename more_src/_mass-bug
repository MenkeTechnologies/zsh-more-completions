#compdef mass-bug
# Documentation: https://manpages.debian.org/mass-bug
# Source: debian/devscripts scripts/mass-bug.pl — mass-file Debian bug reports (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--send)--display[display proposed bug reports]' \
    '(--display)--send[send bug reports]' \
    '--subject=-[subject line]:subject:_default' \
    '--severity=-[severity]:sev:(wishlist minor normal important serious grave critical)' \
    '--tags=-[tags]:tags:_default' \
    '--user=-[user]:user:_default' \
    '--usertags=-[usertags]:usertags:_default' \
    '*--control=-[control message line]:line:_default' \
    '--source[treat packages as source packages]' \
    '--sendmail=-[sendmail-like binary]:cmd:_command_names' \
    '1:template file:_files' \
    '*:package name(s) or pseudo-package(s):_default' \
    && ret=0

return ret
