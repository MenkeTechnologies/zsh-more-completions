#compdef step-ca
# Documentation: https://github.com/smallstep/certificates/blob/master/cmd/step-ca/main.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--password-file=[path to password file]:file:_files' \
  '--issuer-password-file=[path to issuer password file]:file:_files' \
  '--ssh-host-password-file=[path to SSH host password file]:file:_files' \
  '--ssh-user-password-file=[path to SSH user password file]:file:_files' \
  '--resolver=[DNS resolver address]:resolver' \
  '--context=[context name]:context' \
  '1:config file:_files -g "*.json"' && ret=0

return ret
