#compdef nitric

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--ci[run in CI mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'new:create a new Nitric project'
      'start:start the local development server'
      'run:run a Nitric service locally'
      'up:deploy a stack to the cloud'
      'down:tear down a deployed stack'
      'stack:manage deployment stacks'
      'version:print version information'
      'completion:generate shell completions'
    )
    _describe -t commands 'nitric command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--force[overwrite existing project]' \
          '1:project name' && ret=0
        ;;
      (start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '*:service file:_files' && ret=0
        ;;
      (up)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '--ci[run in CI mode]' \
          '-s+[stack name]:stack' \
          '--stack=[stack name]:stack' && ret=0
        ;;
      (down)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '--ci[run in CI mode]' \
          '-s+[stack name]:stack' \
          '--stack=[stack name]:stack' && ret=0
        ;;
      (stack)
        local -a stack_cmds=(
          'new:create a new stack'
          'list:list stacks'
          'update:update a stack configuration'
          'delete:delete a stack'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:stack command:_describe -t stack-cmds "stack command" stack_cmds' \
          '*:arguments' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
