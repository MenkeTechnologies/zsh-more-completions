#compdef lrz

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[ASCII transfer (convert line endings)]' \
  '-b[binary transfer mode]' \
  '-B+[buffer size in bytes]:buffer size:' \
  '-c[request 16-bit CRC]' \
  '-C[request 32-bit CRC]' \
  '-D+[number of files to delete after download]:count:' \
  '-e[force sender to escape all control characters]' \
  '-E[rename incoming files if they already exist]' \
  '-h[print help message]' \
  '-m+[minimum baud rate for downloads]:baud rate:' \
  '-M+[minimum baud rate for uploads]:baud rate:' \
  '-o[disable timeout code]' \
  '-O[disable timeout during ZMODEM receive]' \
  '-p[protect existing files, skip if file exists]' \
  '-q[quiet mode, suppress output]' \
  '-r[resume interrupted file transfer]' \
  '-R[restricted mode, do not overwrite files]' \
  '-s[use YMODEM single-file transfer]' \
  '-S[set command mode baud rate]:baud rate:' \
  '-t+[set timeout in tenths of seconds]:timeout:' \
  '-u[unlink (delete) files after successful transfer]' \
  '-U[disable timeout on first ZMODEM data packet]' \
  '-v[verbose output]' \
  '-vv[very verbose output]' \
  '-w+[set window size for ZMODEM]:window size:' \
  '-X[use XMODEM protocol]' \
  '-y[overwrite existing files without confirmation]' \
  '-Y[overwrite existing files, skip same/newer files]' \
  '-Z[use ZMODEM protocol]' \
  '--version[display version information]' \
  '*:file:_files' \
  && ret=0

return ret
