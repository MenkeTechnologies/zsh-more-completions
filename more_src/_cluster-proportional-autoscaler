#compdef cluster-proportional-autoscaler
# _cluster-proportional-autoscaler — Kubernetes cluster-proportional-autoscaler (CPA)
# upstream: https://github.com/kubernetes-sigs/cluster-proportional-autoscaler
# Flags from cmd/cluster-proportional-autoscaler/options/options.go on tip.

_cluster-proportional-autoscaler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--target=[target to scale (deployment/* | replicationcontroller/* | replicaset/*)]:spec:' \
        '--configmap=[ConfigMap containing scaling parameters]:name:' \
        '--namespace=[namespace for operations]:ns:' \
        '--nodelabels=[node label selectors (csv of k=v)]:csv:' \
        '--version=[print version and exit]:bool:(true false)' \
        '--default-params=[fallback scaling params (JSON)]:json:' \
        '--poll-period-seconds=[poll period (s)]:s:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_cluster-proportional-autoscaler "$@"
