#compdef ganache

# Zsh completion for ganache - Ethereum development blockchain

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-D --detach)'{-D,--detach}'[run as a daemon]' \
  '--server.host=[hostname to listen on]:host' \
  '--server.port=[port to listen on]:port' \
  '--server.ws[enable WebSocket server]' \
  '--chain.chainId=[chain ID]:chain id' \
  '--chain.networkId=[network ID]:network id' \
  '--chain.hardfork=[hardfork to use]:hardfork:(constantinople byzantium petersburg istanbul muirGlacier berlin london arrowGlacier grayGlacier merge shangHai)' \
  '--wallet.totalAccounts=[number of accounts to generate]:count' \
  '--wallet.defaultBalance=[default account balance in ether]:balance' \
  '--wallet.mnemonic=[mnemonic to use for HD wallet]:mnemonic' \
  '--wallet.seed=[seed data for HD wallet]:seed' \
  '--wallet.passphrase=[passphrase for HD wallet]:passphrase' \
  '--wallet.lock[lock available accounts by default]' \
  '*--wallet.unlockedAccounts=[account address or index to unlock]:account' \
  '--database.dbPath=[path to database directory]:directory:_directories' \
  '--logging.quiet[suppress all log output]' \
  '--logging.verbose[increase log output verbosity]' \
  '--logging.debug[enable debug output]' \
  '--miner.blockTime=[block time in seconds for automatic mining]:seconds' \
  '--miner.defaultGasPrice=[default gas price in wei]:gas price' \
  '--miner.blockGasLimit=[block gas limit]:gas limit' \
  '--miner.defaultTransactionGasLimit=[default transaction gas limit]:gas limit' \
  '--miner.difficulty=[block difficulty]:difficulty' \
  '--miner.callGasLimit=[gas limit for eth_call]:gas limit' \
  '--fork.url=[URL of the provider to fork]:url' \
  '--fork.blockNumber=[block number to fork from]:block number' \
  '--fork.username=[username for fork provider auth]:username' \
  '--fork.password=[password for fork provider auth]:password' \
  '--fork.requestsPerSecond=[rate limit for fork provider]:rate' \
  && ret=0

return ret
