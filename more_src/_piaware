#compdef piaware piaware-status piaware-config pirehose
# ============================================================================
#  _piaware — piaware: FlightAware ADS-B data upload client (RPi-deployed
#             aircraft tracking receiver feed software)
#
#  Source-direct extraction from
#    https://github.com/flightaware/piaware/blob/master/programs/piaware/main.tcl
#    https://github.com/flightaware/piaware/blob/master/programs/piaware-status/main.tcl
#    https://github.com/flightaware/piaware/blob/master/programs/piaware-config/main.tcl
#    https://github.com/flightaware/piaware/blob/master/programs/pirehose/main.tcl
#    https://core.tcl-lang.org/tcllib/doc/trunk/embedded/md/tcllib/files/modules/cmdline/cmdline.md
#    (Tcllib cmdline package documentation)
#
#  Maintained by FlightAware LLC (flightaware/piaware).  572 GH stars.
#  piaware is the FlightAware ADS-B (Automatic Dependent Surveillance—
#  Broadcast) feeder client — deployed on tens of thousands of
#  Raspberry Pis worldwide running PiAware OS images, it forwards
#  decoded aircraft transponder data from dump1090 to FlightAware's
#  flight-tracking network.  PiAware receivers contribute to
#  FlightAware's global ADS-B network providing real-time aircraft
#  position data.  Sister tools: dump1090 (the actual SDR decoder,
#  in corpus via _dump1090), dump978 (UAT decoder, in corpus via
#  _dump978), readsb (modern dump1090 fork), faup1090 (FlightAware
#  uplink protocol converter).
#
#  CLI library taxonomy update: 2nd Tcl CLI library — Tcllib's
#  **cmdline** package (the standard Tcl utility for CLI parsing).
#  Tcl ecosystem now has 2 documented CLI libraries.
#
#  Tcllib `cmdline` package is part of the Standard Tcl Library
#  (tcllib) distribution — Andreas Kupries's standard Tcl utility
#  for argv parsing.  Used by piaware (FlightAware's ADS-B feeder),
#  nbsp (NOAAport Broadcast System Processor), wavesurfer (KTH
#  speech analysis tool), nagelfar (Tcl static analyzer), TclPro
#  (ActiveState's Tcl development environment), tcllib's own ftpd /
#  htmlparse / pop3 modules, electric-cloud's dependencyFinder,
#  Xilinx Vivado / Altera Quartus FPGA toolchains, VMD molecular
#  visualization scripts, Hog-CERN's FPGA toolflow, and most Tcl
#  CLI tools that need a structured options parser.
#
#  Tcllib cmdline API:
#    package require cmdline
#
#    set options {
#      {host.arg "localhost" "host to connect to"}
#      {port.arg "8080" "port to connect to"}
#      {verbose "verbose output"}
#      {count.arg "1" "number of times to repeat"}
#      {output.arg "" "output file (default stdout)"}
#      {v "show version and exit"}
#    }
#    set usage ": $::argv0 ?options? args..."
#
#    if {[catch {array set ::params [::cmdline::getoptions argv $options $usage]} err]} {
#      puts stderr $err
#      exit 6
#    }
#
#    if {$::params(v)} {
#      puts "1.0.0"; exit 0
#    }
#
#    # Use $::params(host), $::params(port), $::params(verbose), etc.
#
#  Tcllib cmdline distinctive features:
#    - SHIPS IN tcllib DISTRIBUTION (Standard Tcl Library) — `package
#      require cmdline` available wherever tcllib is installed (most
#      Tcl installations bundle tcllib)
#    - OPTIONS-AS-LIST-OF-LISTS — each option is a Tcl list `{name.TYPE
#      DEFAULT_VALUE DESCRIPTION}` (3 elements) or `{name DESCRIPTION}`
#      (2 elements for boolean flags)
#    - TYPE SUFFIX on option name — `.arg` suffix means option takes a
#      value, NO suffix means boolean flag (e.g. `port.arg` vs `verbose`)
#    - DEFAULT VALUES — second element of option list is the default
#      value (used when option not provided)
#    - DESCRIPTION — third element of option list is the help text
#      shown in usage output
#    - SINGLE-DASH CONVENTION — Tcl uses `-name value` (single dash for
#      both short and long names) following Tcl's historical convention
#      from Tk widget options (`-foreground`, `-background`, etc.)
#    - `::cmdline::getoptions argv $options $usage` — parses argv IN
#      PLACE (modifies the argv variable to remove processed options)
#      and returns a key-value list mappable to a Tcl array via
#      `array set`
#    - `::cmdline::usage $options ?usage?` — generates usage string from
#      options list (used for --help output)
#    - `::cmdline::typedGetoptions` — typed variant with type validation
#    - `::cmdline::getKnownOpt` — older imperative-cursor API
#    - `::cmdline::prefix*` family — for option-name prefix matching
#    - PARSE ERROR via Tcl EXCEPTION — caller catches via `catch` and
#      handles error message
#    - AUTO-ADDED `-help` and `-?` options injected by cmdline (prints
#      auto-generated usage)
#    - NO automatic exit on parse error — caller decides exit code
#    - NO type coercion — caller does its own validation (e.g.
#      `expr {int($::params(port))}`)
#    - NO subcommand support — caller hand-rolls subcommand dispatch
#  Distinct from R293 Tcl stdlib `clock`/`fileutil` ad-hoc parsing or
#  Tk widget-option style parsing (the previous Tcl entry — hand-rolled
#  per-tool), R272 C POSIX getopt (C language, similar getopt semantics
#  but C struct option arrays), R270 Haskell optparse-applicative
#  (functional applicative combinator), R322 JCommander (Java
#  annotations + reflection), R288 Erlang jcomellas/getopt (similar
#  three-tuple `{Name, Spec, Default}` spec style but Erlang language).
#  Tcllib cmdline's approach: OPTIONS-AS-LIST-OF-LISTS with `.arg`
#  TYPE SUFFIX + SINGLE-DASH `-name` CONVENTION (Tcl Tk widget-option
#  style) + `::cmdline::getoptions argv $options $usage` IN-PLACE argv
#  MUTATION + `array set` RESULT MAPPING + AUTO-ADDED `-help`/`-?`
#  options + TCL EXCEPTION on parse error — corpus's **first documented
#  Tcllib-cmdline-package-with-arg-type-suffix CLI library**.  Brings
#  cross-language CLI library taxonomy variant count to 116; Tcl
#  ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from `main.tcl` `set options { ... }` blocks,
#  dispatched per 4-stem binary):
#
#  piaware (programs/piaware/main.tcl):
#    -p FILE                Write our PID to this file
#    -configfile FILE       Additional configuration file to read
#    -cachedir DIR          Cache directory (default /var/cache/piaware)
#    -serverhosts HOSTS     Alternate server hosts (FA internal testing)
#    -serverport PORT       Alternate server port (FA internal testing)
#    -plainlog              Log to stderr without timestamps
#    -debug                 Log to stderr, enable more debugging msgs
#    -debug-tls N           tcltls debug level (0=none, 1=info, 2=all)
#    -logfile FILE          Logfile location
#                           (default /var/log/piaware.log; not used
#                           with -debug or -plainlog)
#    -showtraffic           Emit traffic to stdout for debugging
#    -statusfile FILE       Periodically write JSON status here
#    -v                     Emit version info and exit
#    -help, -?              Show usage (auto-added by cmdline)
#
#  piaware-status (programs/piaware-status/main.tcl):
#    -dump1090 PATH         Path to dump1090 install
#    -dump1090-host HOST    dump1090 host to query
#    -dump1090-port PORT    dump1090 port (typically 30005)
#    -systemd               Use systemd to check service status
#    -showtraffic           Show ADS-B traffic stats
#    -nocolor               Disable ANSI color output
#    -help, -?              Show usage
#
#  piaware-config (programs/piaware-config/main.tcl):
#    -fa-aux                Manipulate FlightAware aux config
#    -all                   Show ALL config (including hidden)
#    -showall               Show all settings (with values)
#    -help, -?              Show usage
#    Subcommands (positional after options):
#      show [KEY]           Show config value(s)
#      set KEY VALUE        Set config key
#      describe KEY         Describe config key
#      reset KEY            Reset config key to default
#
#  pirehose (programs/pirehose/main.tcl):
#    -listen ADDR           Listen address for firehose
#    -port PORT             Listen port for firehose connections
#    -origin ORIGIN         Origin string for firehose
#    -help, -?              Show usage
#
#  Dup-skipped neighbors during hunt (in corpus, also Tcllib cmdline-
#  based, or smaller user bases):
#    - dump1090 / dump978 / readsb (IN CORPUS via _dump1090 / _dump978
#      — sister ADS-B decoder tools; uses C POSIX getopt R272 not
#      Tcllib cmdline)
#    - nbsp / nbsppanic (noaaport — 11 stars, smaller user base)
#    - wavesurfer (cecileherr/wavesurfer-bats — KTH speech analysis,
#      smaller community)
#    - nagelfar (Tcl static analyzer — smaller community)
#    - tclpro / TclPro (ActiveState's defunct Tcl IDE — historical)
#    - tclhttpd (TclHTTPD — historical TCL web server)
#    - tixtools / sqlite-tcl / casstcl (Tcl bindings/extensions —
#      libraries not user-facing CLIs)
# ============================================================================

_piaware() {
  local context state state_descr line
  typeset -A opt_args

  case $service in
    piaware)
      _arguments -s -S \
        '-p=[write our PID to this file]:file:_files' \
        '-configfile=[additional configuration file]:file:_files' \
        '-cachedir=[cache directory (default /var/cache/piaware)]:dir:_directories' \
        '-serverhosts=[alternate server hosts (FA testing)]:hosts' \
        '-serverport=[alternate server port (FA testing)]:port' \
        '-plainlog[log to stderr without timestamps]' \
        '-debug[log to stderr, enable more debugging]' \
        '-debug-tls=[tcltls debug level]:level:(0 1 2)' \
        '-logfile=[logfile location]:file:_files' \
        '-showtraffic[emit traffic to stdout for debugging]' \
        '-statusfile=[periodically write JSON status here]:file:_files' \
        '-v[emit version info and exit]' \
        '-help[show usage]' \
        '-\?[show usage]'
      ;;
    piaware-status)
      _arguments -s -S \
        '-dump1090=[path to dump1090 install]:path:_directories' \
        '-dump1090-host=[dump1090 host to query]:host:_hosts' \
        '-dump1090-port=[dump1090 port (typically 30005)]:port' \
        '-systemd[use systemd to check service status]' \
        '-showtraffic[show ADS-B traffic stats]' \
        '-nocolor[disable ANSI color output]' \
        '-help[show usage]' \
        '-\?[show usage]'
      ;;
    piaware-config)
      _arguments -C -s -S \
        '-fa-aux[manipulate FlightAware aux config]' \
        '-all[show all config (including hidden)]' \
        '-showall[show all settings with values]' \
        '-help[show usage]' \
        '-\?[show usage]' \
        '1: :->subcmd' \
        '*:: :->subargs'

      case $state in
        subcmd)
          local -a verbs=(
            'show:show config value(s)'
            'set:set config key to value'
            'describe:describe config key'
            'reset:reset config key to default'
          )
          _describe -t commands 'piaware-config subcommand' verbs
          ;;
        subargs)
          case $line[1] in
            show|describe|reset) _message 'config key' ;;
            set) _message 'config key and value' ;;
          esac
          ;;
      esac
      ;;
    pirehose)
      _arguments -s -S \
        '-listen=[listen address for firehose]:address' \
        '-port=[listen port for firehose connections]:port' \
        '-origin=[origin string for firehose]:origin' \
        '-help[show usage]' \
        '-\?[show usage]'
      ;;
  esac
}

_piaware "$@"
