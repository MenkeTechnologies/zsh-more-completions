#compdef 3dInvFMRI
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dInvFMRI.html
# AFNI: inverse FMRI; estimate stimulus from activation map and data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-data[3D+time input dataset]:dataset:_files' \
  '-input[3D+time input dataset (synonym)]:dataset:_files' \
  '-map[activation map dataset]:dataset:_files' \
  '-mapwt[weight dataset for map]:dataset:_files' \
  '-mask[mask dataset]:mask:_files' \
  '-base[number of baseline polynomials]:n:' \
  '-polort[polynomial detrend order]:p:' \
  '-out[output 1D filename]:file:_files' \
  '-method[solution method (C or K)]:method:(C K)' \
  '-alpha[regularization parameter]:a:' \
  '-fir5[smooth output with 5-point FIR]' \
  '-median5[smooth output with 5-point median]' \
  '*:dataset:_files' && ret=0

return ret
