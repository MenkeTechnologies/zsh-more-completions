#compdef freshclam-config

# freshclam-config: edit/maintain /etc/clamav/freshclam.conf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--get[get option value]:option:' \
  '--set[set option value]:option value:' \
  '--list[list options]' \
  '*::freshclam-config args:_files' && ret=0
return ret
