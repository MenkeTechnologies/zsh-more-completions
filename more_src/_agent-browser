#compdef agent-browser

# agent-browser npm CLI — use --help for full flag matrix; keep high-signal globals.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '-v[verbose]' \
  '--version[show version]' \
  '--executable-path=[Chromium path]:path:_files' \
  '--isolate[fresh profile]' \
  '--proxy-server=[HTTP(S) proxy]:uri:_urls' \
  '--accept-insecure-certs[tls ignore errors]' \
  '--header=[extra HTTP header]:header:' \
  '--user-agent=[UA string]:ua:' \
  '--viewport=[WxH]:size:' \
  '--timezone=[timezone id]:tz:' \
  '--geolocation=[lat,lon]:geo:' \
  '--lang=[accept-language]:lang:' \
  '1:subcommand:_default' \
  '*::args:_default' && ret=0

return ret
