#compdef ableton-composer
# ============================================================================
# ableton-composer - AI-driven Ableton Live composition CLI (Node, MIT)
#
# Author : delaudio
# Upstream: https://github.com/delaudio/ableton-composer
# npm    : ableton-composer
#
# ableton-composer is a commander.js-based CLI that uses LLMs to
# generate, arrange, and push MIDI content into a running Ableton
# Live session via the Ableton Link / Max for Live bridge, with
# auxiliary subcommands for MusicXML/MIDI roundtripping, audio
# rendering via DAW automation, AI critique passes, instrument
# preset planning, stem separation + scanning, and genre research
# prompts. Total subcommand surface is large (40+ subcommands
# across "generate", "push", "arrange", "split", "compile", "pull",
# "clear", "analyze", "compare", "validate-roundtrip", "critique",
# "revise", "evaluation-pack", "report", "render-plan",
# "render-audio", "convert-audio", "render-stems", "research",
# "plugins", "palette", "expand", "import-xml", "export-xml",
# "import-midi", "transcribe", "separate", "export-midi",
# "snapshot", "stems", and "preset" namespaces).
#
# The MIDI emission lane is built on `@tonejs/midi ^2.0.28`
# (declared verbatim at upstream package.json HEAD), the canonical
# Node MIDI library by the Tone.js org (github.com/Tonejs/Midi,
# 990+ stars). @tonejs/midi parses + writes Standard MIDI File
# (SMF 0/1/2) format end-to-end in pure JavaScript with a typed
# class-based API:
#
#     import { Midi } from '@tonejs/midi';
#
#     const midi = new Midi();
#     const track = midi.addTrack();
#     track.name = 'Lead Synth';
#     track.addNote({
#         midi: 60, time: 0, duration: 0.5, velocity: 0.8
#     });
#     track.controlChanges[7] = [{ ticks: 0, value: 100 }];
#     await fs.writeFile('out.mid', Buffer.from(midi.toArray()));
#
# The library is shipped by the Tone.js audio framework org (the
# Web Audio API toolkit), and is the dependency-of-record for any
# Node program that needs MIDI: AI music generators, web-based
# DAWs, game audio toolchains, sequencer plugins.
#
# ----------------------------------------------------------------------------
# AXIS 204 :: MIDI / STANDARD MIDI FILE (SMF 0/1/2)  [CLOSES]
# Round 1312 :: TS-Node slot 3 of 4 :: CLOSES Axis 204 (197th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : kovaxis/midly                  [R1310 _miditui]
#   Go      : gomidi/midi (v2)               [R1311 _muskel]
#   TS/Node : Tonejs/Midi                    [R1312 THIS FILE]
#
# Cross-lane convergence: all three lanes' consumers are text-input
# composition tools rather than piano-roll GUI DAWs, but they
# diverge on the workflow:
#   - miditui (Rust): terminal piano roll + SoundFont synthesis,
#                     human-in-the-loop composition
#   - muskel  (Go):   text-based sketch DSL (.mskl files), compile
#                     to .mid via gomidi/midi v2, play via live MIDI port
#   - ableton-composer (Node): LLM-driven prompt-to-MIDI, push to
#                     Ableton Live for arrangement / mixing
#
# This is the 2026 shape of the MIDI tooling axis: the Rust opener
# stays in-terminal, the Go middle pairs DSL + live ports, and the
# Node closer wires MIDI into AI workflows. @tonejs/midi closes the
# axis because every modern AI-music project on Node eventually
# routes through it for SMF I/O.
# ============================================================================

_ableton-composer() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_abcomp_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                generate|gen)        _abcomp_generate ;;
                push)                _arguments '(- *)'{-h,--help}'[help]' ;;
                pull)                _arguments '(- *)'{-h,--help}'[help]' ;;
                arrange|split|compile|clear|analyze|compare|critique|revise|expand|snapshot|separate|transcribe|report) _arguments '(- *)'{-h,--help}'[help]' '1:file:_files' ;;
                validate-roundtrip)  _arguments '(- *)'{-h,--help}'[help]' '1:file:_files' ;;
                evaluation-pack|render-plan|render-audio|convert-audio|render-stems) _arguments '(- *)'{-h,--help}'[help]' ;;
                import-midi|export-midi) _arguments '(- *)'{-h,--help}'[help]' '1:file:_files -g "*.mid"' ;;
                import-xml|export-xml)  _arguments '(- *)'{-h,--help}'[help]' '1:file:_files -g "*.(xml|musicxml|mxl)"' ;;
                research|plugins|palette|stems|preset) _arguments '(- *)'{-h,--help}'[help]' '1:subcommand:' '*::arg:->_default' ;;
            esac
            ;;
    esac

    return ret
}

_abcomp_cmds() {
    local -a cmds
    cmds=(
        'generate:Generate a song JSON from a natural-language prompt'
        'gen:Alias for generate'
        'push:Push generated MIDI into Ableton Live'
        'arrange:AI-driven arrangement pass on a song JSON'
        'split:Split song JSON into per-track parts'
        'compile:Compile song JSON to MIDI'
        'pull:Pull MIDI/scene state out of Ableton Live'
        'clear:Clear scenes / clips in Ableton Live'
        'analyze:Analyze song JSON or MIDI structure'
        'compare:Compare two song JSON / MIDI files'
        'validate-roundtrip:Validate MIDI -> JSON -> MIDI roundtrip fidelity'
        'critique:LLM critique pass on the song'
        'revise:LLM revision pass on the song'
        'evaluation-pack:Bundle evaluation artifacts'
        'report:Generate a song report'
        'render-plan:Plan a render pass for the DAW'
        'render-audio:Render audio via DAW automation'
        'convert-audio:Convert audio between formats'
        'render-stems:Render per-track audio stems'
        'research:Research genre conventions via LLM'
        'plugins:Manage AU/VST plugin scanning + matching'
        'palette:Generate timbral palettes'
        'expand:Expand a song with additional material'
        'import-midi:Import MIDI to song JSON'
        'export-midi:Export song JSON to MIDI'
        'import-xml:Import MusicXML to song JSON'
        'export-xml:Export song JSON to MusicXML'
        'transcribe:Transcribe audio to MIDI / song JSON'
        'separate:Source-separate audio into stems'
        'snapshot:Snapshot current Ableton state'
        'stems:Manage stem scanning + setup + Reaper bridge'
        'preset:Manage instrument presets (save/load/list/analyze/generate)'
    )
    _describe -t commands 'ableton-composer command' cmds
}

_abcomp_generate() {
    _arguments \
        '(-t --temperature)'{-t,--temperature}'[LLM sampling temperature]:temp:' \
        '(-m --model)'{-m,--model}'[LLM model]:model:' \
        '(-o --output)'{-o,--output}'[output JSON file]:file:_files -g "*.json"' \
        '(- *)'{-h,--help}'[help]' \
        '1:natural language prompt:'
}

_ableton-composer "$@"
