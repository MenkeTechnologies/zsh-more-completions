#compdef eac3to
# Documentation: https://en.wikibooks.org/wiki/Eac3to/How_to_Use
# Audio/video stream decoder, converter and demuxer. Switches from the eac3to usage reference.

local ret=1

_arguments -s -S \
  '-normalize[gain output to 0 dB (two-pass)]' \
  '-down16[downconvert decoded audio data to 14..23 bit]' \
  '-down6[downmix 7 or 8 channels to 6 channels]' \
  '-downDpl[downmix multichannel audio to stereo (Dolby Pro Logic II)]' \
  '-downStereo[downmix multichannel audio to stereo (simple)]' \
  '-double7[upmix 6.1 to 7.1 (duplicate Back Center)]' \
  '-mono[decode only center channel (left if stereo)]' \
  '-slowdown[reverse PAL speedup (25.000 to 24.000/1.001 fps)]' \
  '-speedup[apply PAL speedup (24.000/1.001 to 25.000 fps)]' \
  '-phaseShift[shift phase of surround channels for stereo downmix]' \
  '-mixlfe[mix LFE in when doing stereo downmixing]' \
  '-decodeHdcd[decode HDCD sources]' \
  '-core[extract DTS or AC3 core from HD formats]' \
  '-demux[extract main video and all audio tracks]' \
  '-check[verify source file integrity]' \
  '-keepDialnorm[disable dialog normalization removal]' \
  '-sonic[force Sonic decoder]' \
  '-nero[force Nero decoder]' \
  '-libav[force libav decoder]' \
  '-arcsoft[force ArcSoft decoder]' \
  '-resampleTo48000[resample to 48000 Hz]' \
  '-lowPriority[run at background priority]' \
  '-progressnumbers[output progress per line]' \
  '-log=[write output log]:logfile:_files' \
  '*:file:_files' && ret=0

return ret
