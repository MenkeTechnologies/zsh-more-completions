#compdef gphelp
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/gphelp.1.html
# external help script for the PARI/GP calculator

local ret=1

_arguments -s -S \
  '-detex[convert the TeX file to readable screen output]' \
  '-raw[use internal format for output (@x markers)]' \
  '-utf8[in detex mode, use UTF-8 encoding for characters]' \
  '-noskip[honor %GPHELPskip markers]' \
  '-k[apropos mode: write list of matching entries to stdout]' \
  '-to_pod[convert file from TeX to POD format]:file:_files' \
  '-ch[color used for general printing]:color' \
  '-color_help[color used for general printing]:color' \
  '-cb[color used for bold]:color' \
  '-color_bold[color used for bold]:color' \
  '-cu[color used for underline]:color' \
  '-color_underline[color used for underline]:color' \
  '*:keyword' && ret=0

return ret
