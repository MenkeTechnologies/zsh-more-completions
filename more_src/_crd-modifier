#compdef crd-modifier
# _crd-modifier — TiDB Operator CRD manifest manipulation tool
# upstream: https://github.com/pingcap/tidb-operator
# Flags from cmd/crd-modifier/main.go on tip.

_crd-modifier() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--dir=[CRD manifests directory]:dir:_files -/' \
        '--chart=[operator Helm chart directory]:dir:_files -/'
}

_crd-modifier "$@"
