#compdef zcash-fetch-params
# _zcash-fetch-params — Electric Coin Company zcash-fetch-params helper CLI for downloading the trusted-setup zk-SNARK parameter files sapling-output sapling-spend sprout-proving sprout-verifying required by zcashd Sapling and Sprout shielded transactions (zcash team, Bash); getopt
# upstream: https://github.com/zcash/zcash

_zcash-fetch-params() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-f[force redownload]' \
        '--force[force redownload]' \
        '--testnet[use testnet params]' \
        '--mainnet[use mainnet params]' \
        '--regtest[use regtest params]' \
        '--params-dir=+[dir]:dir:_files -/' \
        '--proxy=+[url]:str:' \
        '--no-check-hashes[do not verify SHA-256 hashes]' \
        '--no-progress[no progress]' \
        '--list[list available params]' \
        '--check[only check existing params]'
}

_zcash-fetch-params "$@"
