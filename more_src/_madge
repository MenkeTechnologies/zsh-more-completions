#compdef madge

# Zsh completion for madge - module dependency graph tool

_arguments -s -S \
  '--basedir[base directory for resolving paths]:directory:_directories' \
  '--include-npm[include npm packages in dependency graph]' \
  '--file-extensions[comma-separated list of valid file extensions]:extensions' \
  '--exclude[exclude modules matching regex]:regex' \
  '--no-color[disable color output]' \
  '--no-spinner[disable spinner]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '--circular[display circular dependencies]' \
  '--depends[show modules that depend on given module]:module' \
  '--orphans[show modules that have no dependencies and are not depended on]' \
  '--leaves[show modules that have no dependencies]' \
  '--extensions[comma-separated list of valid file extensions]:extensions' \
  '--image[write dependency graph to image]:file:_files' \
  '--dot[output dependency graph as DOT]' \
  '--layout[layout engine for graph]:engine:(dot neato fdp sfdp twopi circo)' \
  '--rankdir[direction of graph layout]:direction:(LR RL TB BT)' \
  '--ts-config[path to TypeScript config file]:file:_files' \
  '--webpack-config[path to webpack config file]:file:_files' \
  '--warning[show warnings about skipped files]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:source:_files' && return 0
