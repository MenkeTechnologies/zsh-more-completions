#compdef madge
# Documentation: https://github.com/pahen/madge
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for madge - module dependency graph tool

_arguments -s -S \
  '(-b --basedir)'{-b,--basedir}'[base directory for resolving paths]:directory:_directories' \
  '(-s --summary)'{-s,--summary}'[show dependency count summary]' \
  '(-c --circular)'{-c,--circular}'[show circular dependencies]' \
  '(-d --depends)'{-d,--depends}'[show module dependents]:module' \
  '(-x --exclude)'{-x,--exclude}'[exclude modules using RegExp]:regex' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-i --image)'{-i,--image}'[write graph to file as an image]:file:_files' \
  '(-l --layout)'{-l,--layout}'[layout engine for graph]:engine:(dot neato fdp sfdp twopi circo)' \
  '--orphans[show modules with no dependents]' \
  '--leaves[show modules with no dependencies]' \
  '--dot[show graph using DOT language]' \
  '--rankdir[direction of graph layout]:direction:(LR RL TB BT)' \
  '--extensions[comma-separated valid file extensions]:extensions' \
  '--require-config[path to RequireJS config]:file:_files' \
  '--webpack-config[path to webpack config]:file:_files' \
  '--ts-config[path to TypeScript config]:file:_files' \
  '--include-npm[include shallow NPM modules]' \
  '--no-color[disable color in output and image]' \
  '--no-spinner[disable progress spinner]' \
  '--no-count[disable circular dependencies counting]' \
  '--stdin[read predefined tree from STDIN]' \
  '--warning[show warnings about skipped files]' \
  '--debug[turn on debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:source:_files' && return 0
