#compdef amp

# Zsh completion for Amp - terminal text editor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--log[enable logging]' \
  '--syntax=[set syntax definition]:syntax' \
  '*:file:_files' && ret=0

return ret
