#compdef vpnc-script
# Documentation: vpnc helper script (invoked by vpnc/openconnect)
# Reference accessed: 2026-05-16
# Verified: no CLI flags - vpnc-script communicates via environment variables
# (reason, VPNGATEWAY, INTERNAL_IP4_*, CISCO_*, etc.) set by the parent
# vpnc/openconnect process.

# vpnc-script: env-var driven VPN configuration helper (not user-invoked)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::extra args:_files' && ret=0
return ret
