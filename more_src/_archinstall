#compdef archinstall

# Zsh completion for archinstall (Arch Linux guided installer)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to JSON config file]:file:_files' \
  '--creds=[path to JSON credentials file]:file:_files' \
  '--disk-layout=[path to disk layout config]:file:_files' \
  '--dry-run[generate configs without installing]' \
  '--silent[run without prompts using config files]' \
  '--script=[script to run]:script:(guided minimal only_hd swiss)' \
  '--mount-point=[mount point for installation]:directory:_directories' \
  '--debug[enable debug output]' \
  '--offline[skip network-related steps]' \
  '--no-pkg-lookups[skip package verification]' \
  '--advanced[show advanced options]' \
  '--plugin=[load plugin module]:plugin'
