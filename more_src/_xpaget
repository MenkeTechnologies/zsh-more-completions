#compdef xpaget
# Documentation: https://github.com/ericmandel/xpa/blob/master/doc/pod/xpaget.pod
# Retrieve data from one or more XPA servers

local ret=1

_arguments -s -S \
  '-h[display help message]' \
  '-i+[access XPA point on a different machine]:nsinet' \
  '-m+[override XPA_METHOD]:method' \
  '-n[skip waiting for status message]' \
  '-s[activate server mode]' \
  '-t+[short,long timeout values]:sval,lval' \
  '-u+[restrict to XPA points from users]:users' \
  '--version[show version information]' \
  '1:template or host\:port:_hosts' \
  '*:paramlist' && ret=0

return ret
