#compdef bom
# _bom-cli — Kubernetes BOM SBOM generator (Kubernetes Release Engineering, Go); generate SPDX SBOMs for source/images/files
# upstream: https://github.com/kubernetes-sigs/bom

_bom-cli() {
    local -a sub=(
        'completion:print shell completion'
        'document:work with SBOMs'
        'generate:generate an SPDX SBOM'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--log-level+[log level]:level:(panic fatal error warning info debug trace)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bom subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '-i+[image]:image:' \
                    '--image+[image]:image:' \
                    '-d+[dir]:dir:_files -/' \
                    '--dirs+[dirs]:dirs:_files -/' \
                    '-f+[file]:file:_files' \
                    '--file+[file]:file:_files' \
                    '-a+[archive file]:file:_files' \
                    '--archive+[archive]:file:_files' \
                    '-n+[namespace]:str:' \
                    '--namespace+[namespace]:str:' \
                    '--license-list-version+[license list version]:str:' \
                    '-l[ignore errors]' \
                    '--ignore-errors[ignore errors]' \
                    '-o+[output file]:file:_files' \
                    '--output+[output file]:file:_files' \
                    '--format+[output format]:fmt:(json tag-value)' \
                    '--name+[document name]:str:' \
                    '--scan-images[scan images]' \
                    '--scan-licenses+[scan licenses]:bool:(true false)' ;;
                document) _arguments '1:doc cmd:(query outline)' '*:sbom file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_bom-cli "$@"
