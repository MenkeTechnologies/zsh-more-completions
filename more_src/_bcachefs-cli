#compdef bcachefs-cli
# _bcachefs-cli — Linux bcachefs next-gen COW filesystem CLI alias (Kent Overstreet / bcachefs team, C/Rust); custom argparse
# upstream: https://github.com/koverstreet/bcachefs-tools

_bcachefs-cli() {
    local -a sub=(
        'format:format devices into a filesystem'
        'show-super:dump superblock'
        'set-fs-option:set filesystem option'
        'reset-counters:reset counters'
        'fs:filesystem commands'
        'device:device commands'
        'data:data commands'
        'subvolume:subvolume commands'
        'snapshot:snapshot commands'
        'fsck:filesystem check'
        'mount:mount filesystem'
        'unlock:unlock encrypted FS'
        'set-passphrase:set passphrase'
        'remove-passphrase:remove passphrase'
        'dump:dump filesystem'
        'list:list metadata trees'
        'list_journal:list journal'
        'kill_btree_node:kill btree node'
        'migrate:migrate from another FS'
        'migrate-superblock:migrate superblock'
        'completions:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bcachefs subcommand' sub ;;
        args)
            case $words[1] in
                format) _arguments \
                    '-L+[label]:str:' \
                    '--label=+[label]:str:' \
                    '-U+[uuid]:str:' \
                    '--uuid=+[uuid]:str:' \
                    '--encrypted[encrypt]' \
                    '--force[force]' \
                    '-f[force]' \
                    '--compression=+[compression]:c:(none gzip lz4 zstd)' \
                    '--background_compression=+[bg compression]:c:(none gzip lz4 zstd)' \
                    '--data_replicas=+[data replicas]:n:' \
                    '--metadata_replicas=+[metadata replicas]:n:' \
                    '--replicas=+[replicas]:n:' \
                    '--encrypted_root_passphrase=+[encrypted root passphrase]:str:' \
                    '--no_passphrase[no passphrase]' \
                    '--str_hash=+[string hash]:h:(crc32c crc64 siphash)' \
                    '--data_checksum=+[data checksum]:c:(none crc32c crc64 xxhash)' \
                    '--metadata_checksum=+[metadata checksum]:c:(none crc32c crc64 xxhash)' \
                    '--bucket=+[bucket size]:str:' \
                    '--block=+[block size]:str:' \
                    '--btree_node=+[btree node size]:str:' \
                    '--discard[discard]' \
                    '--erasure_code[erasure coding]' \
                    '--shard_inode_numbers=+[shard inode numbers]:b:(true false)' \
                    '*:device:_files' ;;
                fs) _arguments \
                    '1:cmd:(usage show-super)' \
                    '*:arg:' ;;
                device) _arguments \
                    '1:cmd:(add remove online offline evacuate set-state resize resize-journal)' \
                    '*:arg:' ;;
                data) _arguments \
                    '1:cmd:(rereplicate scrub)' \
                    '*:arg:' ;;
                subvolume) _arguments \
                    '1:cmd:(create delete snapshot)' \
                    '*:arg:' ;;
                mount) _arguments \
                    '*:device-or-mountpoint:_files' ;;
                fsck) _arguments \
                    '--no-fix[no fix]' \
                    '-n[no fix]' \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '*:device:_files' ;;
                completions) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_bcachefs-cli "$@"
