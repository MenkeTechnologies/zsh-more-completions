#compdef birdfont-autotrace
# Documentation: https://man.archlinux.org/man/birdfont-autotrace.1.en
# Convert raster images to SVG vector graphics

local ret=1

_arguments -s -S \
  '(-c --cutoff)'{-c,--cutoff}'[brightness cutoff, 0.001 to 2 (default 1)]:cutoff:' \
  '(-d --details)'{-d,--details}'[details, 0.001 to 9.999 (default 1)]:details:' \
  '(-h --help)'{-h,--help}'[print help message]' \
  '(-q --quadratic)'{-q,--quadratic}'[use quadratic control points instead of cubic]' \
  '(-s --simplification)'{-s,--simplification}'[path simplification, 0.001 to 1 (default 0.5)]:value:' \
  '*:image:_files' && ret=0

return ret
