#compdef openshot openshot-qt
# Documentation: https://manpages.debian.org/unstable/openshot-qt/openshot-qt.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[debug logging]' \
  '--lang=+[language]:lang:' \
  '--list-lang[list languages]' \
  '*:project:_files -g "*.osp"' && ret=0

return ret
