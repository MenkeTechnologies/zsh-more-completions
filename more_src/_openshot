#compdef openshot openshot-qt

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[debug logging]' \
  '--lang=+[language]:lang:' \
  '--list-lang[list languages]' \
  '*:project:_files -g "*.osp"' && ret=0

return ret
