#compdef openshot openshot-qt
# Documentation: https://man.archlinux.org/search?q=openshot
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[debug logging]' \
  '--lang=+[language]:lang:' \
  '--list-lang[list languages]' \
  '*:project:_files -g "*.osp"' && ret=0

return ret
