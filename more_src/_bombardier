#compdef bombardier
# Documentation: https://github.com/codesenberg/bombardier (args_parser.go kingpin)
# Reference accessed: 2026-05-29
# bombardier — high-performance HTTP benchmarking CLI. Single URL positional argument required.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --connections)'{-c,--connections=}'[max number of concurrent connections]:N:' \
  '(-t --timeout)'{-t,--timeout=}'[socket/request timeout]:duration:' \
  '(-l --latencies)'{-l,--latencies}'[print latency statistics]' \
  '(-m --method)'{-m,--method=}'[HTTP request method (default GET)]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS CONNECT TRACE)' \
  '(-b --body)'{-b,--body=}'[request body]:body:' \
  '(-f --body-file)'{-f,--body-file=}'[file to use as request body]:file:_files' \
  '(-s --stream)'{-s,--stream}'[stream body using chunked transfer encoding]' \
  '--cert=[client TLS certificate]:file:_files' \
  '--key=[client TLS certificate private key]:file:_files' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification]' \
  '(-a --disableKeepAlives)'{-a,--disableKeepAlives}'[disable HTTP keep-alive]' \
  '*'{-H,--header=}'[HTTP header (repeatable; e.g. "User-Agent\: x")]:header:' \
  '(-n --requests)'{-n,--requests=}'[total number of requests]:N:' \
  '(-d --duration)'{-d,--duration=}'[duration of test]:duration:' \
  '(-r --rate)'{-r,--rate=}'[rate limit in requests/sec]:rps:' \
  '(--fasthttp --http1 --http2)--fasthttp[use fasthttp client (default)]' \
  '(--fasthttp --http1 --http2)--http1[use net/http with forced HTTP/1.x]' \
  '(--fasthttp --http1 --http2)--http2[use net/http with HTTP/2.0]' \
  '(-p --print)'{-p,--print=}'[what to output (CSV of: intro, progress, result; default ip-r)]:what:' \
  '(-q --no-print)'{-q,--no-print}'[do not output anything]' \
  '(-o --format)'{-o,--format=}'[output format (default plain-text)]:fmt:(plain-text json)' \
  '1:url:' \
  && ret=0

return ret
