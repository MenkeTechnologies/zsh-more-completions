#compdef aquatone
# Documentation: https://github.com/michenriksen/aquatone
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-chrome-path=[Chrome path]:file:_files' \
  '-debug[debug output]' \
  '-http-timeout=[HTTP timeout ms]:ms:' \
  '-nmap[parse Nmap/Masscan XML]' \
  '-out=[output dir]:dir:_files -/' \
  '-ports=[ports or alias]:ports:(small medium large xlarge)' \
  '-proxy=[proxy URL]:url:' \
  '-resolution=[WxH]:resolution:' \
  '-save-body=[save bodies]:bool:(true false)' \
  '-scan-timeout=[scan timeout ms]:ms:' \
  '-screenshot-timeout=[shot timeout ms]:ms:' \
  '-session=[session JSON]:file:_files' \
  '-silent[silent]' \
  '-template-path=[HTML template]:file:_files' \
  '-threads=[threads]:n:' \
  '-version[show version]'
