#compdef svndumpfilter
# Documentation: https://svnbook.red-bean.com/en/1.8/svn.ref.svndumpfilter.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a subcommands
subcommands=(
    'include:Filter repository to include paths'
    'exclude:Filter repository to exclude paths'
    'help:Show help'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'svndumpfilter subcommand' subcommands
        ;;
    args)
        _arguments \
            '--drop-empty-revs[Remove revisions with no remaining changes]' \
            '--drop-all-empty-revs[Remove all empty revisions]' \
            '--renumber-revs[Renumber remaining revisions]' \
            '--skip-missing-merge-sources[Skip missing merge sources]' \
            '--targets[Read paths from file]:file:_files' \
            '--preserve-revprops[Preserve revision properties]' \
            '--pattern[Treat paths as glob patterns]' \
            '-q[Quiet mode]' \
            '--quiet[Quiet mode]' \
            '*:paths'
        ;;
esac
