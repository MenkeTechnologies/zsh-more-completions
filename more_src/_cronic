#compdef cronic
# _cronic — cure for cron's strident email problem (habnabit/cronic)
# upstream: https://github.com/habnabit/cronic

# cronic is a shell script wrapper with no flags of its own;
# it simply runs the given command and suppresses output unless it fails.

_arguments \
    '1:command:_command_names -e' \
    '*::arguments:_normal'
