#compdef 3dmaskave
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dmaskave.html
# AFNI average voxel values over a mask region

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-mask[mask dataset; average nonzero voxels]:dataset:_files' \
  '-mindex[sub-brick from mask dataset]:miv' \
  '-mrange[restrict mask to values a..b]:a' \
  '-xbox[box mask at xyz location]:x' \
  '-dbox[DICOM box mask]:x' \
  '-nbox[box mask]:x' \
  '-ibox[index box mask]:x' \
  '-xball[sphere mask at xyz]:x' \
  '-dball[DICOM sphere mask]:x' \
  '-nball[sphere mask]:x' \
  '-dindex[specific sub-brick from input]:div' \
  '-drange[include only voxels a..b]:a' \
  '-slices[restrict to slices p through q]:p' \
  '-sigma[also compute standard deviation]' \
  '-sum[calculate sum instead of mean]' \
  '-sumsq[calculate sum of squares]' \
  '-enorm[calculate Euclidean norm]' \
  '-median[calculate median]' \
  '-max[calculate maximum]' \
  '-min[calculate minimum]' \
  '-perc[compute XX-th percentile]:XX' \
  '-dump[print all included voxel values]' \
  '-udump[print unscaled voxel values]' \
  '-indump[print voxel indexes for dumped values]' \
  '(-quiet -q)'{-quiet,-q}'[print only minimal numerical results]' \
  '*:dataset:_files' && ret=0

return ret
