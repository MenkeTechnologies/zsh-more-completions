_arrow2csv() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[print usage guide]' \
    '(-s --schema)'{-s,--schema}'[space-delimited list of column names to include]:columns:' \
    '(-f --file)'{-f,--file}'[Arrow file to read (repeatable)]:file:_files -g "*.arrow"' \
    '--sep[column separator character]:sep:' \
    '--hr[horizontal border character]:hr:' \
    '(-m --metadata)'{-m,--metadata}'[print Schema metadata]' \
    '*:file:_files -g "*.arrow"'
}

_arrow2csv "$@"
