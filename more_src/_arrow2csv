#      pass-through to subprocesses or sub-CLIs
#    - `stopAtFirstUnknown: true` — STOP parsing at the first
#      unknown flag (treat everything after as positional);
#      useful for `mytool [args...] -- subprocess-args`
#      patterns
#    - `caseInsensitive: true` — case-insensitive flag matching
#    - `argv:` option — explicit argv input (default:
#      `process.argv.slice(2)`)
