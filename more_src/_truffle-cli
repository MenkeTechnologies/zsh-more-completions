#compdef trufflehog truffleHog

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'git:scan a Git repository'
  'github:scan GitHub repos/orgs/users'
  'gitlab:scan GitLab projects'
  'filesystem:scan filesystem'
  's3:scan S3 buckets'
  'gcs:scan GCS buckets'
  'syslog:scan syslog'
  'circleci:scan CircleCI'
  'docker:scan Docker image'
  'travis:scan Travis CI'
  'jenkins:scan Jenkins'
  'azure-repos:scan Azure DevOps repos'
  'huggingface:scan HuggingFace'
  'postman:scan Postman workspaces'
  'elasticsearch:scan Elasticsearch'
  'stdin:scan stdin'
  'analyze:analyze a key'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--debug[debug log level]' \
  '*--trace[trace log level]' \
  '*--profile[enable profiling]' \
  '*--json[output JSON]' \
  '*--json-legacy[old JSON format]' \
  '*--github-actions[GitHub Actions output]' \
  '*--concurrency=[concurrency]:n:' \
  '*--no-verification[skip verification]' \
  '*--only-verified[only verified]' \
  '*--allow-verification-overlap[allow verification overlap]' \
  '*--filter-unverified[filter unverified]' \
  '*--filter-entropy=[entropy threshold]:n:' \
  '*--config=[config file]:file:_files -g "*.yaml *.yml"' \
  '*--print-avg-detector-time[print avg time]' \
  '*--no-update[no update]' \
  '*--fail[exit non-zero on findings]' \
  '*--exclude-detectors=[exclude detectors csv]:list:' \
  '*--include-detectors=[include detectors csv]:list:' \
  '*--detector-timeout=[detector timeout]:t:' \
  '*--archive-max-size=[archive max size]:size:' \
  '*--archive-max-depth=[archive max depth]:n:' \
  '*--results=[results filter]:r:(verified unverified filtered_unverified unknown)' \
  '*--user-agent=[user agent]:s:' \
  '*--log-level=[log level]:l:' \
  '*--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'trufflehog command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (git)
        _arguments \
          '*--include-paths=[include paths file]:file:_files' \
          '*--exclude-paths=[exclude paths file]:file:_files' \
          '*--branch=[branch]:branch:' \
          '*--max-depth=[max depth]:n:' \
          '*--since-commit=[since commit]:sha:' \
          '*--bare[bare repo]' \
          '*: :_files' && ret=0 ;;
      (github)
        _arguments \
          '*-u +[org/user/repo]:s:' \
          '*--repo=[repo URL]:url:' \
          '*--org=[org]:s:' \
          '*--token=[GH token]:t:' \
          '*--user=[user]:s:' \
          '*--issue-comments[scan issue comments]' \
          '*--pr-comments[scan PR comments]' \
          '*--gist-comments[scan gist comments]' \
          '*--include-forks[include forks]' \
          '*--include-members[include members]' \
          '*--include-repos=[include repos csv]:list:' \
          '*--exclude-repos=[exclude repos csv]:list:' \
          '*: :' && ret=0 ;;
      (filesystem)
        _arguments \
          '*--include-paths=[include paths file]:file:_files' \
          '*--exclude-paths=[exclude paths file]:file:_files' \
          '*: :_files' && ret=0 ;;
      (s3)
        _arguments \
          '*--bucket=[bucket]:b:' \
          '*--region=[region]:r:' \
          '*--key=[AWS key]:k:' \
          '*--secret=[AWS secret]:s:' \
          '*--session-token=[session token]:t:' \
          '*--role-arns=[assume role]:arns:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
