#compdef konnectivity-agent proxy-agent
# _konnectivity-agent — Konnectivity agent (runs inside each worker cluster; dials home to a konnectivity-server to terminate egress tunnels)
# upstream: https://github.com/kubernetes-sigs/apiserver-network-proxy
# Flags from cmd/agent/app/options/options.go on tip.

_konnectivity-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--agent-cert=[TLS cert for the agent]:file:_files' \
        '--agent-key=[TLS key for the agent]:file:_files' \
        '--ca-cert=[CA used to validate the proxy server]:file:_files' \
        '--proxy-server-host=[hostname of the proxy server]:host:' \
        '--proxy-server-port=[port of the proxy server]:port:' \
        '*--alpn-proto=[additional ALPN protocol to present]:proto:' \
        '--health-server-host=[health server bind address (no port)]:addr:' \
        '--health-server-port=[health server port]:port:' \
        '--admin-server-port=[admin server port]:port:' \
        '--admin-bind-address=[admin server bind address]:addr:' \
        '--enable-profiling[enable pprof at admin-port/debug/pprof]' \
        '--enable-contention-profiling[enable mutex profiling (requires --enable-profiling)]' \
        '--agent-id=[unique agent id (PROXY_AGENT_ID env var)]:id:' \
        '--sync-interval=[initial sync interval]:duration:' \
        '--probe-interval=[probe interval]:duration:' \
        '--sync-interval-cap=[max backoff for SyncInterval]:duration:' \
        '--keepalive-time=[gRPC agent server keepalive]:duration:' \
        '--service-account-token-path=[serviceaccount token used to prove identity to the server]:file:_files' \
        '--agent-identifiers=[URL-encoded identifiers used by the server when choosing an agent]:spec:' \
        '--warn-on-channel-limit[warn when about to push to a full channel]' \
        '--sync-forever[keep syncing even after initial completion]' \
        '--xfr-channel-size=[transfer channel size]:n:' \
        '--count-server-leases[count lease objects to determine the number of proxy servers]' \
        '--lease-namespace=[namespace for lease objects]:ns:' \
        '--lease-label=[label selector for lease objects]:sel:' \
        '--server-count-source=[source for server count]:src:(default leases response)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--kube-api-content-type=[content type for requests to the apiserver]:ct:' \
        '-v[klog verbosity level]:n:'
}

_konnectivity-agent "$@"
