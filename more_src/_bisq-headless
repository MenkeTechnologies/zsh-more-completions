#compdef bisq-headless bisq-daemon bisq-daemon-cli
# _bisq-headless — Bisq Network bisq-headless daemon CLI for the decentralised peer-to-peer Bitcoin exchange running the JVM-based headless trading node Tor onion service market price feed dispute mediation arbitrator BSQ DAO (bisq team, Java); JCommander
# upstream: https://github.com/bisq-network/bisq

_bisq-headless() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--appName=+[name]:str:' \
        '--userDataDir=+[dir]:dir:_files -/' \
        '--appDataDir=+[dir]:dir:_files -/' \
        '--baseCurrencyNetwork=+[net]:n:(BTC_MAINNET BTC_TESTNET BTC_REGTEST BTC_DAO_BETANET BTC_DAO_TESTNET BTC_DAO_REGTEST)' \
        '--bitcoinRegtestHost=+[host:port]:str:' \
        '--btcNodes=+[csv]:str:' \
        '--useTorForBtc[use Tor for BTC]' \
        '--useAllProvidedNodes[use all provided nodes]' \
        '--torControlHost=+[host]:str:' \
        '--torControlPort=+[port]:n:' \
        '--torControlPassword=+[password]:str:' \
        '--externalTorUseSafeCookieAuthentication[use safe cookie auth]' \
        '--torControlCookieFile=+[file]:file:_files' \
        '--torrcFile=+[file]:file:_files' \
        '--torrcOptions=+[options]:str:' \
        '--socks5ProxyBtcAddress=+[host:port]:str:' \
        '--socks5ProxyHttpAddress=+[host:port]:str:' \
        '--httpsBaseUrl=+[url]:str:' \
        '--seedNodes=+[csv]:str:' \
        '--banList=+[csv]:str:' \
        '--myAddress=+[host:port]:str:' \
        '--useDevPrivilegeKeys[use dev privilege keys]' \
        '--useDevMode[use dev mode]' \
        '--bypassMempoolValidation[bypass mempool validation]' \
        '--logLevel=+[level]:l:(off error warn info debug trace)' \
        '--maxMemory=+[MB]:n:' \
        '--maxConnections=+[N]:n:' \
        '--useNativeXyz[use native XYZ]' \
        '--apiPort=+[port]:n:' \
        '--apiPassword=+[password]:str:' \
        '--passwordRequired[password required]' \
        '--daoActivated[DAO activated]' \
        '--genesisBlockHeight=+[N]:n:' \
        '--genesisTxId=+[hex]:str:'
}

_bisq-headless "$@"
