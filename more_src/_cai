#compdef cai
# Documentation: https://github.com/ad-si/cai
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cai: multi-provider LLM CLI (ad-si/cai). Subcommand-based.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'value:answer with the value only, no explanation'
  'short:short focused response'
  'rewrite:fix spelling, grammar, and wording'
  'reply:continue conversation from stdin'
  'run:generate and confirm a shell command'
  'agent:run an agentic loop with tool use'
  'image:generate an image'
  'img:generate an image'
  'photo:generate a photorealistic image'
  'imgedit:edit images'
  'imge:edit images'
  'say:text-to-speech'
  'tts:text-to-speech'
  'svg:generate an SVG'
  'transcribe:audio to text'
  'ocr:extract text from an image'
  'google-ocr:high-resolution image OCR'
  'gocr:high-resolution image OCR'
  'rename:auto-rename files with title and timestamp'
  'changelog:generate a changelog from commits'
  'commit:AI-generated commit message'
  'query:natural-language SQLite query'
  'edit:open editor for prompt composition'
  'all:query every configured provider in parallel'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-r --raw)'{-r,--raw}'[raw response without metadata]' \
  '(-j --json)'{-j,--json}'[JSON output mode]' \
  '--json-schema=[validate against JSON schema]:schema:' \
  '--no-streaming[wait for complete response]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cai subcommand' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
