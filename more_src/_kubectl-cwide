#compdef kubectl-cwide
# Documentation: https://github.com/reborn1867/kubectl-cwide
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:generate YAML template files for discovered resources'
      'get:view customized output using templates'
      'template:manage custom column templates'
      'configmap:share templates via Kubernetes ConfigMaps'
      'marketplace:browse community templates'
      'tree:visualize the relationship hierarchy between resources'
      'list:discover all API resource types in the cluster'
      'alias:manage resource type name shortcuts'
      'config:open configuration file in an editor'
    )
    _describe -t commands 'kubectl-cwide command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      template)
        _arguments -s -S '1:subcommand:(list create edit)' && ret=0
        ;;
      configmap)
        _arguments -s -S '1:subcommand:(push sync)' && ret=0
        ;;
      marketplace)
        _arguments -s -S '1:subcommand:(list search install)' && ret=0
        ;;
      alias)
        _arguments -s -S '1:subcommand:(set list delete)' && ret=0
        ;;
    esac
    ;;
esac

return ret
