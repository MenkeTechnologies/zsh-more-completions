#compdef longshot
# Documentation: https://github.com/pjedge/longshot
# Longshot diploid SNV variant caller for long-read sequencing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-b --bam)'{-b,--bam}'=[sorted indexed BAM/CRAM with error-prone reads]:bam:_files' \
  '(-f --ref)'{-f,--ref}'=[indexed FASTA reference]:fasta:_files' \
  '(-o --out)'{-o,--out}'=[output VCF file with called variants]:vcf:_files' \
  '(-r --region)'{-r,--region}'=[region <chrom> or <chrom:start-stop>]:region:' \
  '(-v --potential_variants)'{-v,--potential_variants}'=[genotype/phase variants in this VCF]:vcf:_files' \
  '(-O --out_bam)'{-O,--out_bam}'=[write new BAM with haplotype tags]:bam:_files' \
  '(-c --min_cov)'{-c,--min_cov}'=[minimum coverage for potential SNV]:int:' \
  '(-C --max_cov)'{-C,--max_cov}'=[maximum coverage for potential SNV]:int:' \
  '(-q --min_mapq)'{-q,--min_mapq}'=[minimum mapping quality to use a read]:int:' \
  '(-a --min_allele_qual)'{-a,--min_allele_qual}'=[minimum Phred allele observation quality]:float:' \
  '(-y --hap_assignment_qual)'{-y,--hap_assignment_qual}'=[minimum read-to-haplotype assignment quality]:float:' \
  '(-Q --potential_snv_cutoff)'{-Q,--potential_snv_cutoff}'=[potential SNV PHRED cutoff]:float:' \
  '(-e --min_alt_count)'{-e,--min_alt_count}'=[minimum alternate alleles]:int:' \
  '(-E --min_alt_frac)'{-E,--min_alt_frac}'=[minimum alternate allele fraction]:float:' \
  '(-L --hap_converge_delta)'{-L,--hap_converge_delta}'=[haplotype iteration convergence delta]:float:' \
  '(-l --anchor_length)'{-l,--anchor_length}'=[indel-free anchor sequence length]:int:' \
  '(-m --max_snvs)'{-m,--max_snvs}'=[cut off variant clusters after this many]:int:' \
  '(-W --max_window)'{-W,--max_window}'=[max padding bases per side of window]:int:' \
  '(-I --max_cigar_indel)'{-I,--max_cigar_indel}'=[discard read-variant if CIGAR indel longer]:int:' \
  '(-B --band_width)'{-B,--band_width}'=[minimum width of alignment band]:int:' \
  '(-D --density_params)'{-D,--density_params}'=[dense cluster flag <n>:<l>:<gq>]:string:' \
  '(-s --sample_id)'{-s,--sample_id}'=[sample ID for output VCF]:string:' \
  '--hom_snv_rate=[homozygous SNV rate prior]:float:' \
  '--het_snv_rate=[heterozygous SNV rate prior]:float:' \
  '--ts_tv_ratio=[transition/transversion rate prior]:float:' \
  '(-P --strand_bias_pvalue_cutoff)'{-P,--strand_bias_pvalue_cutoff}'=[strand bias removal cutoff]:float:' \
  '(-d --variant_debug_dir)'{-d,--variant_debug_dir}'=[write per-step variant info to dir]:dir:_files -/' \
  '(-A --auto_max_cov)'{-A,--auto_max_cov}'[auto-calculate max coverage from mean]' \
  '(-S --stable_alignment)'{-S,--stable_alignment}'[use logspace pair HMM forward algorithm]' \
  '(-F --force_overwrite)'{-F,--force_overwrite}'[delete and overwrite existing output]' \
  '(-x --max_alignment)'{-x,--max_alignment}'[use max scoring alignment instead of HMM]' \
  '(-n --no_haps)'{-n,--no_haps}'[do not call HapCUT2 to phase variants]' \
  '--output-ref[print reference (non-variant) genotypes]' && ret=0

return ret
