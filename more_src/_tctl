#compdef tctl

# Zsh completion for Temporal CLI (tctl)

local curcontext="$curcontext" state line ret=1

local -a tctl_commands
tctl_commands=(
  'activity:operate on activity'
  'admin:operate on admin task'
  'batch:batch operation on a list of workflows'
  'cluster:operate on cluster'
  'completion:output shell completion code'
  'config:operate on tctl configuration'
  'data-converter:operate on data converter'
  'namespace:operate on namespaces'
  'schedule:operate on schedules'
  'search-attribute:operate on search attributes'
  'taskqueue:operate on task queue'
  'workflow:operate on workflows'
)

local -a tctl_global_flags
tctl_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--address=[host:port for Temporal frontend service]:address:'
  '--auth-token=[authorization token]:token:'
  '--auto-confirm[automatically confirm all prompts]'
  '--codec-auth=[authorization header for codec server]:auth:'
  '--codec-endpoint=[codec server endpoint]:endpoint:'
  '--color=[output coloring]:color:(auto always never)'
  '--context-timeout=[timeout for RPC call in seconds]:seconds:'
  '--data-converter-plugin=[data converter plugin]:plugin:'
  '--env=[environment name]:env:'
  '-n=[temporal namespace to operate]:namespace:'
  '--namespace=[temporal namespace to operate]:namespace:'
  '--tls[enable TLS]'
  '--tls-ca-path=[path to TLS CA cert]:ca cert:_files'
  '--tls-cert-path=[path to TLS cert]:cert:_files'
  '--tls-disable-host-verification[disable TLS host verification]'
  '--tls-key-path=[path to TLS private key]:key:_files'
  '--tls-server-name=[TLS server name override]:name:'
)

_arguments -s -S \
  $tctl_global_flags \
  '--version[show version]' \
  '1:command:_describe -t commands command tctl_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      workflow)
        local -a workflow_commands
        workflow_commands=(
          'cancel:cancel a workflow execution'
          'count:count workflow executions'
          'delete:delete a workflow execution'
          'describe:show information about a workflow'
          'execute:start a new workflow and wait for result'
          'list:list workflow executions'
          'observe:observe the progress of a workflow'
          'query:query a workflow execution'
          'reset:reset a workflow execution'
          'reset-batch:reset a batch of workflows'
          'show:show workflow execution history'
          'signal:signal a workflow execution'
          'stack:query workflow stack trace'
          'start:start a new workflow execution'
          'terminate:terminate a workflow execution'
          'trace:trace a workflow execution'
          'update:update a running workflow execution'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:workflow command:_describe -t commands command workflow_commands' \
          '*::workflow args:->workflow_args' && ret=0
        case "$state" in
          workflow_args)
            case "${line[1]}" in
              start|execute)
                _arguments -s -S \
                  $tctl_global_flags \
                  '--cron=[cron schedule]:schedule:' \
                  '--execution-timeout=[workflow execution timeout]:timeout:' \
                  '-i=[input for the workflow]:input:' \
                  '--input=[input for the workflow]:input:' \
                  '--input-file=[input file]:file:_files' \
                  '--id-reuse-policy=[workflow ID reuse policy]:policy:(AllowDuplicate AllowDuplicateFailedOnly RejectDuplicate TerminateIfRunning)' \
                  '--max-field-length=[max length for each attribute field]:length:' \
                  '--memo=[memo key=value pairs]:memo:' \
                  '--memo-file=[file with memo]:file:_files' \
                  '--run-timeout=[single workflow run timeout]:timeout:' \
                  '--search-attribute=[search attribute key=value]:attribute:' \
                  '--task-queue=[task queue]:task queue:' \
                  '-t=[task queue]:task queue:' \
                  '--task-timeout=[workflow task timeout]:timeout:' \
                  '--type=[workflow type name]:type:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $tctl_global_flags \
                  '--archived[list archived workflows]' \
                  '--fields=[fields to display]:fields:(RunId Type StartTime CloseTime ExecutionTime ExecutionDuration Status TaskQueue Memo SearchAttributes)' \
                  '-l=[page size]:limit:' \
                  '--limit=[page size]:limit:' \
                  '-o=[output format]:format:(table json card)' \
                  '--output=[output format]:format:(table json card)' \
                  '-q=[query to filter workflows]:query:' \
                  '--query=[query to filter workflows]:query:' \
                  '--time-format=[time format]:format:(relative iso raw)' && ret=0
                ;;
              describe)
                _arguments -s -S \
                  $tctl_global_flags \
                  '-o=[output format]:format:(table json card)' \
                  '--output=[output format]:format:(table json card)' \
                  '--raw[print raw data]' \
                  '--reset-points[only show auto-reset points]' \
                  '-r=[run ID]:run id:' \
                  '--run-id=[run ID]:run id:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              show)
                _arguments -s -S \
                  $tctl_global_flags \
                  '--follow[follow the workflow history]' \
                  '-l=[page size]:limit:' \
                  '--limit=[page size]:limit:' \
                  '--max-field-length=[max field length]:length:' \
                  '-o=[output format]:format:(table json card)' \
                  '--output=[output format]:format:(table json card)' \
                  '-r=[run ID]:run id:' \
                  '--run-id=[run ID]:run id:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              signal)
                _arguments -s -S \
                  $tctl_global_flags \
                  '-i=[signal input]:input:' \
                  '--input=[signal input]:input:' \
                  '--input-file=[file with signal input]:file:_files' \
                  '--name=[signal name]:name:' \
                  '-r=[run ID]:run id:' \
                  '--run-id=[run ID]:run id:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              query)
                _arguments -s -S \
                  $tctl_global_flags \
                  '-i=[query input]:input:' \
                  '--input=[query input]:input:' \
                  '--input-file=[file with query input]:file:_files' \
                  '--name=[query type]:name:' \
                  '--reject-condition=[reject condition]:condition:(not_open not_completed_cleanly)' \
                  '-r=[run ID]:run id:' \
                  '--run-id=[run ID]:run id:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              cancel|terminate|delete)
                _arguments -s -S \
                  $tctl_global_flags \
                  '--reason=[reason for the operation]:reason:' \
                  '-q=[visibility query]:query:' \
                  '--query=[visibility query]:query:' \
                  '-r=[run ID]:run id:' \
                  '--run-id=[run ID]:run id:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              reset)
                _arguments -s -S \
                  $tctl_global_flags \
                  '-e=[event ID to reset to]:event id:' \
                  '--event-id=[event ID to reset to]:event id:' \
                  '--reason=[reason for reset]:reason:' \
                  '--reapply-type=[reapply type]:type:(All Signal None)' \
                  '--type=[reset type]:type:(FirstWorkflowTask LastWorkflowTask LastContinuedAsNew BuildId)' \
                  '-r=[run ID]:run id:' \
                  '--run-id=[run ID]:run id:' \
                  '-w=[workflow ID]:workflow id:' \
                  '--workflow-id=[workflow ID]:workflow id:' && ret=0
                ;;
              *)
                _arguments -s -S $tctl_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      namespace)
        local -a namespace_commands
        namespace_commands=(
          'create:register a new namespace'
          'delete:delete an existing namespace'
          'describe:describe a namespace'
          'list:list all namespaces'
          'update:update a namespace'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:namespace command:_describe -t commands command namespace_commands' \
          '*::namespace args:' && ret=0
        ;;
      taskqueue)
        local -a taskqueue_commands
        taskqueue_commands=(
          'describe:describe a task queue'
          'get-build-ids:get the build ID assignment rules'
          'get-build-id-reachability:get build ID reachability'
          'list-partition:list task queue partitions'
          'update-build-ids:update build ID assignment rules'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:taskqueue command:_describe -t commands command taskqueue_commands' \
          '*::taskqueue args:' && ret=0
        ;;
      schedule)
        local -a schedule_commands
        schedule_commands=(
          'backfill:backfill a schedule'
          'create:create a schedule'
          'delete:delete a schedule'
          'describe:describe a schedule'
          'list:list schedules'
          'toggle:pause or unpause a schedule'
          'trigger:trigger a schedule'
          'update:update a schedule'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:schedule command:_describe -t commands command schedule_commands' \
          '*::schedule args:' && ret=0
        ;;
      search-attribute)
        local -a sa_commands
        sa_commands=(
          'create:add custom search attributes'
          'list:list search attributes'
          'remove:remove custom search attributes'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:search-attribute command:_describe -t commands command sa_commands' \
          '*::sa args:' && ret=0
        ;;
      batch)
        local -a batch_commands
        batch_commands=(
          'describe:describe a batch operation'
          'list:list batch operations'
          'terminate:stop a batch operation'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:batch command:_describe -t commands command batch_commands' \
          '*::batch args:' && ret=0
        ;;
      cluster)
        local -a cluster_commands
        cluster_commands=(
          'describe:show information about the cluster'
          'health:check cluster health'
          'list:list all clusters'
          'remove:remove a remote cluster'
          'upsert:add or update a remote cluster'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:cluster command:_describe -t commands command cluster_commands' \
          '*::cluster args:' && ret=0
        ;;
      activity)
        local -a activity_commands
        activity_commands=(
          'complete:complete an activity'
          'fail:fail an activity'
        )
        _arguments -s -S \
          $tctl_global_flags \
          '1:activity command:_describe -t commands command activity_commands' \
          '*::activity args:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $tctl_global_flags \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
      *)
        _arguments -s -S $tctl_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
