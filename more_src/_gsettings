#compdef gsettings
# _gsettings — GLib gsettings (read/write GSettings keys against a compiled-in schema; commands cover get/set/reset/reset-recursively/range/describe/monitor/writable/list-* introspection; --schemadir overrides schema search path)
# upstream: https://gitlab.gnome.org/GNOME/glib (gio/gsettings-tool.c)
# Subcommands from glib gio/gsettings-tool.c on tip.

_gsettings() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--schemadir+[schema directory]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gsettings command' '(help get set reset reset-recursively range describe monitor writable list-schemas list-relocatable-schemas list-keys list-children list-recursively)' ;;
        args) _arguments '1:schema:' '2:key:' '3:value:' ;;
    esac
}

_gsettings "$@"
