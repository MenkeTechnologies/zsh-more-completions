#compdef gsettings
# Documentation: https://manpages.debian.org/gsettings
# Source: GNOME/glib gio/gsettings-tool.c — GSettings command-line tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '--help[show help]' \
    '--version[show version]' \
    '--schemadir+[schema directory]:dir:_files -/' \
    '1:command:(help list-schemas list-relocatable-schemas list-keys list-children list-recursively get range describe set reset reset-recursively writable monitor)' \
    '*::command args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            list-schemas) _arguments '--print-paths[also print object paths]' ;;
            list-keys|list-children|list-recursively|get|range|describe|reset|reset-recursively|writable|monitor)
                _arguments '1:SCHEMA:_default' '2::KEY:_default' ;;
            set)
                _arguments '1:SCHEMA:_default' '2:KEY:_default' '3:VALUE:_default' ;;
        esac
        ;;
esac

return ret
