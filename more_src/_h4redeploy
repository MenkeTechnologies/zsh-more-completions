#compdef h4redeploy
# Documentation: https://manpages.debian.org/testing/hdf4-tools/h4redeploy.1.en.html
# Update paths in the h4cc and h4fc HDF4 compiler wrapper scripts

local ret=1

_arguments -s \
  '-help[display usage information]' \
  '-echo[show all the shell commands executed]' \
  '-force[no prompt, just do it]' \
  '-prefix=[prefix directory to find HDF4 lib/ and include/]:dir:_files -/' \
  '-tool=[tool to update (default: h4cc h4fc)]:tool' \
  '-show[show the commands without executing them]' && ret=0

return ret
