#compdef phmmer
# Documentation: https://man.archlinux.org/search?q=phmmer
# Reference accessed: 2026-05-16

# HMMER phmmer: search protein query against sequence database (BLAST-style)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output file]:file:_files' \
  '-A[save MSA of hits]:file:_files' \
  '--tblout[per-target table]:file:_files' \
  '--domtblout[per-domain table]:file:_files' \
  '--pfamtblout[Pfam-style table]:file:_files' \
  '--acc[show accessions]' \
  '--noali[no alignments]' \
  '--popen[gap-open probability]:val:' \
  '--pextend[gap-extend probability]:val:' \
  '--mxfile[scoring matrix file]:file:_files' \
  '--mx[built-in matrix]:matrix:(PAM30 PAM70 PAM120 PAM240 BLOSUM45 BLOSUM50 BLOSUM62 BLOSUM80 BLOSUM90)' \
  '-E[reporting E-value]:Eval:' \
  '-T[reporting score]:bits:' \
  '--domE[domain E-value]:Eval:' \
  '--domT[domain score]:bits:' \
  '--incE[inclusion E-value]:Eval:' \
  '--incT[inclusion score]:bits:' \
  '--incdomE[domain inclusion E-value]:Eval:' \
  '--incdomT[domain inclusion score]:bits:' \
  '--max[no filters]' \
  '--F1[MSV threshold]:val:' \
  '--F2[Vit threshold]:val:' \
  '--F3[Fwd threshold]:val:' \
  '--nobias[no bias filter]' \
  '--seed[random seed]:n:' \
  '--qformat[query format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--tformat[target format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--cpu[CPU threads]:n:' \
  '*:query and target file:_files' && ret=0
return ret
