#compdef sufwatrim
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sufwatrim.c
# FX domain Alpha TRIM

local ret=1

_arguments -s -S \
  'key=[key]:key:' \
  'dx=[dx]:dx:' \
  'keyg=[keyg]:keyg:' \
  'vf=[vf]:vf:' \
  'vmin=[vmin]:vmin:' \
  '*:file:_files' && ret=0

