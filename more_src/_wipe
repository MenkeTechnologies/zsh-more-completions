#compdef wipe

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[do a chmod on write-protected files]' \
  '-D[dereference symlinks]' \
  '-e[use exact file size]' \
  '-f[force wipe without confirmation]' \
  '-F[do not attempt to wipe filenames]' \
  '-i[informational (verbose) mode]' \
  '-k[keep files after wiping]' \
  '-l[set security level (wipe passes)]:level' \
  '-M[set wipe mode]:mode' \
  '-o+[set write offset]:offset' \
  '-p+[set number of passes]:passes' \
  '-P+[set number of PRNG passes]:passes' \
  '-Q+[set number of quick passes]:passes' \
  '-r[recurse into subdirectories]' \
  '-R[recurse into subdirectories (same as -r)]' \
  '-s[silent mode]' \
  '-S[use PRNG seed from /dev/random]' \
  '-t[test mode, do not write]' \
  '-x[do not cross filesystem boundaries]' \
  '-Z[do not attempt to wipe file size]' \
  '*:file:_files' && ret=0

return ret
