#compdef trash-rm
# Documentation: https://github.com/andreafrancia/trash-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs (trashcli/rm/rm_cmd.py).
# trash-rm only accepts a single PATTERN; matches via fnmatch.fnmatchcase.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:pattern' && ret=0

return ret
