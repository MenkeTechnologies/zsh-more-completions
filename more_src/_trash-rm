#compdef trash-rm
# Documentation: https://man.archlinux.org/search?q=trash-rm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--trash-dir=[specify trash directory]:directory:_directories' \
  '*:pattern' && ret=0

return ret
