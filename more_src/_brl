#compdef brl
# Bedrock Linux management tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:apply configuration changes'
  'disable:disable stratum'
  'enable:enable stratum'
  'fetch:fetch new strata'
  'import:import new stratum'
  'list:list strata'
  'remove:remove stratum'
  'rename:rename stratum'
  'repair:repair stratum'
  'report:generate problem report'
  'show:show stratum information'
  'status:show stratum status'
  'strat:run command in stratum'
  'tutorial:run tutorial'
  'update:update Bedrock Linux'
  'version:show version'
  'which:show which stratum provides path'
)

_arguments -s -S \
  '1:command:->command' \
  '-h[show help]' \
  '--help[show help]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'brl command' commands && ret=0
    ;;
esac

return ret
