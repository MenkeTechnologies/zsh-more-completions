#compdef from
# Documentation: from --help (GNU Mailutils)
# Source: display sender and subject of mailbox messages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-c --count --no-count)-c[print only a count of messages]' \
    '--count[print count]' '--no-count[do not print count]' \
    '(-d --debug)'{-d,--debug}'[enable debug output]' \
    '(-f --file)'{-f+,--file=}'[mailbox file]:file:_files' \
    '(-s --sender)'{-s+,--sender=}'[filter by sender substring]:address:' \
    '--debug-level=[Mailutils debug level]:level:' \
    '--debug-line-info[show source info in debug]' \
    '--no-debug-line-info[hide source info]' \
    '--config-file=[config file]:file:_files' \
    '--config-lint[check config syntax and exit]' \
    '--config-verbose[verbose config parsing]' \
    '--no-config[do not load configuration files]' \
    '--no-site-config[no site-wide config]' \
    '--no-user-config[no user config]' \
    '1:user:_users' \
    && ret=0

return ret
