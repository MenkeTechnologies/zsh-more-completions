#compdef dlt
# Documentation: https://man.archlinux.org/search?q=dlt
# Reference accessed: 2026-05-16

_dlt() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Show help message and exit]'
        '--version[Show program version]'
        '--disable-telemetry[Disables anonymous usage telemetry]'
        '--enable-telemetry[Enables anonymous usage telemetry]'
        '--non-interactive[Non-interactive mode]'
        '--debug[Displays full stack traces on exceptions]'
        '--no-pwd[Do not add current working directory to sys.path]'
    )

    subcmds=(
        'init:Creates a new pipeline project from a verified source or a template'
        'pipeline:Operations on pipelines that were run locally'
        'deploy:Creates a deployment package for a pipeline script'
        'schema:Inspects and manages schemas'
        'dashboard:Starts a local Streamlit-based dashboard'
        'telemetry:Shows the current status of telemetry'
        'ai:AI-assisted pipeline generation'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'dlt commands' subcmds
            ;;
        args)
            case $line[1] in
                pipeline)
                    local -a pipeline_subcmds
                    pipeline_subcmds=(
                        'list:Lists all local pipelines'
                        'info:Shows detailed information about a specific pipeline'
                        'failed-jobs:Lists failed load jobs'
                        'sync:Synchronizes pipeline state from the destination'
                        'trace:Shows the execution trace of the last run'
                    )
                    _describe -t commands 'pipeline subcommands' pipeline_subcmds
                    ;;
                schema)
                    local -a schema_subcmds
                    schema_subcmds=(
                        'show:Displays the schema in a readable format'
                        'upgrade:Upgrades the schema to the latest version'
                    )
                    _describe -t commands 'schema subcommands' schema_subcmds
                    ;;
            esac
            ;;
    esac
}

_dlt "$@"
