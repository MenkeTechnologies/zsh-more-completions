#compdef organize
# Documentation: https://man.archlinux.org/search?q=organize
# Reference accessed: 2026-05-16

if (( CURRENT == 1 )); then
  _values 'organize command' run sim new edit check debug show list docs
  return
fi

case $words[1] in
  run|sim)
    _arguments -s -S \
      '(-W --working-dir)'{-W,--working-dir}'=[working directory]:directory:_directories' \
      '(-F --format)'{-F,--format}'=[output format]:format:(default errorsonly jsonl)' \
      '(-T --tags)'{-T,--tags}'=[comma-separated tags to run]:tags:' \
      '(-S --skip-tags)'{-S,--skip-tags}'=[comma-separated tags to skip]:tags:' \
      '--stdin[read config from stdin]' \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[show version]' \
      '::config name or path:_default'
    ;;
  new|edit)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[show version]' \
      '::config:_default'
    ;;
  check|debug)
    _arguments -s -S \
      '--stdin[read config from stdin]' \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[show version]' \
      '::config:_default'
    ;;
  show)
    _arguments -s -S \
      '--path[print config path only]' \
      '--reveal[open config folder]' \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[show version]' \
      '::config:_default'
    ;;
  list|docs)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[help]' \
      '--version[show version]'
    ;;
  *)
    return 1
    ;;
esac
