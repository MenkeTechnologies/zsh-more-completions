#compdef dummyhttp
# Documentation: https://github.com/svenstaro/dummyhttp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all logging]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging (twice for body data)]' \
  '(-p --port)'{-p,--port=}'[port to listen on (default 8080)]:port:' \
  '*'{-H,--headers=}'[headers to send (key:value)]:header:' \
  '(-c --code)'{-c,--code=}'[HTTP status code to send (default 200)]:code:' \
  '(-b --body)'{-b,--body=}'[HTTP body to send (supports Tera templating)]:body:' \
  '(-i --interface)'{-i,--interface=}'[interface to bind to (default 0.0.0.0)]:interface:' \
  '(-d --delay)'{-d,--delay=}'[response delay in milliseconds]:ms:' \
  '--print-completions=[generate shell completions]:shell:(bash fish zsh elvish powershell)' \
  '--print-manpage[generate man page]' \
  '--tls-cert=[TLS certificate to use]:file:_files' \
  '--tls-key=[TLS private key to use]:file:_files' && ret=0

return ret
