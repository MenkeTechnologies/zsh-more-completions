#compdef rsem-tbam2gbam
# Documentation: https://github.com/deweylab/RSEM/blob/master/README.md
# RSEM: convert transcript-coordinate BAM to genomic-coordinate BAM

local ret=1

_arguments -s -S \
  '1:reference name:' \
  '2:unsorted transcript bam input:_files -g "*.bam"' \
  '3:genome bam output:_files' && ret=0

return ret
