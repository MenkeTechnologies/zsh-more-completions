#compdef innxmit
# Documentation: man innxmit(8)
# Source: InterNetNews/inn backends/innxmit.c — transmit articles to NNTP host (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[always rewrite batch file]' \
    '-c[skip CHECK before TAKETHIS]' \
    '-d[debug output]' \
    '-H[headers-only feed (IHAVE/TAKETHIS body skipped)]' \
    '-l[log rejected articles]' \
    '-p[purge mode (rewrite, do not feed)]' \
    '-P+[NNTP port]:port:_default' \
    '-r[do not requeue rejected articles]' \
    '-s[disable streaming]' \
    '-t+[connect timeout seconds]:secs:_default' \
    '-T+[total transmit timeout seconds]:secs:_default' \
    '-v[verbose statistics]' \
    '1:host:_hosts' \
    '2:batch file:_files' \
    && ret=0

return ret
