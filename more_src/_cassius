#
# Cassius is the **Racket-based CSS layout engine
# solver** by uwplse — uses Z3 SMT solver to verify
# CSS layout properties.  Academic research project.
# Pivots from D std.getopt (R289 sdfmt) into the
# **Racket / Scheme language tooling cluster**.
# Sister to Racket itself, raco (Racket's CLI tool
# for packages).  **MAJOR MILESTONE**: corpus's
# **first documented Racket CLI** — adds Racket to
# the cross-language CLI taxonomy (29 library
# variants now).
#
# Critical extraction note: Cassius uses **Racket's
# stdlib `racket/cmdline`** library at `(require
# racket/cmdline)` — corpus's **first documented
# Racket CLI** AND first use of the **Racket macro-
# based CLI DSL**.  `racket/cmdline` is **the**
# standard Racket CLI library — built into Racket
# (no package install needed).  Provides `command-
# line` (single command) and `multi-command-line`
# (with subcommands) MACROS that expand at compile
# time into argument parsing code.  Used by raco
# (Racket's package manager), drracket (Racket IDE),
# and most Racket CLI tooling.  Extends the **cross-
# language CLI taxonomy** to TWENTY-NINE library
# variants: Rust (6), Go (4), Python (3), Crystal
# OptionParser (R269), Haskell optparse-applicative
# (R270), OCaml Cmdliner (R271), C POSIX getopt
# (R272), Java picocli (R276), Kotlin clikt (R277),
# Scala decline (R278), Dart args (R279), Ruby
# OptionParser (R280), Perl Getopt::Long (R281), PHP
# Symfony Console (R282), Swift ArgumentParser (R283),
# F# Argu (R284), Lua argparse (R285), C# System
# .CommandLine (R286), Nim parseopt (R287), Zig std
# .process.argsAlloc (R288), D std.getopt (R289),
# **Racket racket/cmdline** (R290 — NEW).  **MAJOR
# PATTERN MILESTONE**: 29 cross-language CLI library
# variants documented.
#
# Critical extraction note: Cassius uses **Racket
# MACRO-BASED CLI DSL** at run.rkt:178-259 — `multi-
# command-line` is a MACRO (not a function) that
# expands at compile time into argument parsing code.
# The macro accepts a SEXPRESSION DSL with keyword
# arguments (`#:program`, `#:multi`, `#:subcommands`)
# and option specifications.  Documents the **Lisp
# macro-based CLI DSL** — distinct from Java
# picocli's annotations (R276), Kotlin clikt's
# property delegation (R277), and Swift property
# wrappers (R283).  Lisp macros enable the DSL to
# look like a built-in language construct.  Plus the
# action body for each option is PLAIN RACKET CODE
# that runs when the option is seen.  Corpus's
# **first documented Lisp macro-based CLI**.
#
# Critical extraction note: Cassius uses **S-EXPRESSION
# OPTION SPEC** at run.rkt:182-202 — each option is
# a list of the form `[(aliases) help-string body
# ...]` or with value parameter `[(aliases) param
# help-string body ...]`.  Documents the **S-
# expression-based option declaration** — distinct
# from clap derive's struct attributes (R247+),
# Click's decorators (R266 uvicorn), and Symfony's
# constructor calls (R282 peridot).  Racket's
# approach uses LIST STRUCTURE to encode option
# metadata.  Plus the use of QUOTED STRINGS (`"Turn
# on debug mode"`) for help text inside the list is
# idiomatic Racket.  Corpus's **first documented
# S-expression option spec**.
#
# Critical extraction note: Cassius uses **`#:multi`
# vs `#:once-each` SECTION KEYWORDS** at run.rkt:181
# + 229 — Racket cmdline distinguishes options that
# can appear MULTIPLE TIMES (`#:multi`) from those
# that should appear AT MOST ONCE (`#:once-each`).
# `#:once-any` (not used here) restricts options to
# AT MOST ONE from a mutex set.  Documents the
# **declarative occurrence-count sections** —
# distinct from Lua argparse's `:count "N-M"` range
# (R285 luacheck) and clap derive's `Vec<T>` for
# repeatable (R260 dua).  Racket's approach groups
# options BY occurrence-count rather than per-option
# annotation.  Corpus's **first documented section-
# keyword occurrence grouping**.
#
# Critical extraction note: Cassius uses
# **`#:subcommands` with `#:args` positional list**
# at run.rkt:204-259 — each subcommand is a list of
# the form `[name #:args (a b [c "default"]) body
# ...]`.  The `#:args` clause lists POSITIONAL
# PARAMETERS to bind from CLI args; `[c "default"]`
# syntax provides DEFAULT VALUES for optional
# positionals.  Documents the **declarative
# positional-with-defaults pattern** — distinct from
# clap derive's `Option<T>` field type (R260 dua),
# Click's `default=...` kwarg (R266 uvicorn), and
# Python argparse's `nargs='?'` (R267 alembic).
# Racket's approach uses LIST STRUCTURE: bare name
# = required, `[name default]` = optional with
# default.  Plus subcommands can have their OWN
# `#:once-each` sub-option sections (see `dump`
# subcommand at run.rkt:228-233).  Corpus's **first
# documented per-subcommand option sections**.

local curcontext="$curcontext" state line ret=1

# 6 subcommands decoded source-direct from run.rkt
# lines 205-258.
local -a subcommands=(
  'accept:accept a CSS layout problem'
  'minimize:minimize a CSS layout problem'
  'minimize-assertion:minimize an assertion in a problem'
  'dump:dump problem state (with --screenshot option)'
  'render:render the CSS layout'
  'check-proof:check a proof file'
  'assertion:verify an assertion'
)

# Global options decoded source-direct from run.rkt
# lines 182-202 (#:multi section).
local -a global_opts=(
  '(-d --debug)'{-d,--debug}'[turn on debug mode]'
  '*--cache=[cache file for Z3 results]:file:_files'
  '--smt2=[write SMT2 query to file and exit (instead of solving)]:file:_files -g "*.smt2"'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help (racket/cmdline auto-generated)]' \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'cassius subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      accept|minimize|render)
        _arguments \
          '1:problem file:_files -g "*.cmt"' \
          '2:problem name:' && ret=0
        ;;
      minimize)
        _arguments \
          '1:problem file:_files -g "*.cmt"' \
          '2:problem name:' \
          '3:backtracked (default "[]"):' && ret=0
        ;;
      minimize-assertion)
        _arguments \
          '1:assertion file:_files -g "*.cmt"' \
          '2:assertion name:' \
          '3:problem file:_files -g "*.cmt"' \
          '4:problem name:' \
          '5:cache file:_files' && ret=0
        ;;
      dump)
        _arguments \
          '--screenshot=[file with web page screenshot]:file:_files' \
          '1:problem file:_files -g "*.cmt"' \
          '2:problem name:' && ret=0
        ;;
      check-proof)
        _arguments \
          '1:proof file:_files' \
          '2:proof name (optional):' \
          '3:page name (optional):' \
          '4:component name (optional):' && ret=0
        ;;
      assertion)
        _arguments \
          '1:assertion file:_files -g "*.cmt"' \
          '2:assertion name:' \
          '3:problem file:_files -g "*.cmt"' \
          '4:problem name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
