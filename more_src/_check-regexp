#compdef check-regexp
# Documentation: check-regexp --help (GNU Source-highlight 3.1.9)
# Source: test a regex against given strings.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:regular expression:' \
    '*:string:' \
    && ret=0

return ret
