#compdef create-component-template-cli
# Documentation: https://www.npmjs.com/package/create-component-template-cli
# Reference accessed: 2026-05-24
# Verified: npm view create-component-template-cli bin; npm readme parameter table.

# Zsh completion for create-component-template-cli - Vue 3 component skeleton generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--name=[component name in PascalCase]:name:' \
  '--rootPath=[output directory]:directory:_directories' \
  '--templateType=[business template type]:type:(general single-pick multiple-pick)' \
  '--vueTemplateType=[index.vue style]:style:(setup normal)' \
  '--collisionStrategy=[directory conflict strategy]:strategy:(skip overwrite)' \
  '--nonInteractive[fail instead of prompting when required args missing]' && ret=0

return ret
