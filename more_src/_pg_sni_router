#compdef pg_sni_router
# _pg_sni_router — Neon Postgres SNI router (routes incoming TLS Postgres connections to internal hosts via SNI-encoded domain names; ingress-controller-style fronting for compute pods)
# upstream: https://github.com/neondatabase/neon
# Flags from proxy/src/binary/pg_sni_router.rs on tip (clap-builder); --tls-key, --tls-cert, --destination are required.

_pg_sni_router() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-l --listen)'{-l+,--listen=}'[plaintext-to-compute listen address (host:port)]:hostport:' \
        '--listen-tls=[TLS-to-compute listen address (host:port)]:hostport:' \
        '(-k --tls-key)'{-k+,--tls-key=}'[TLS private key path (required)]:file:_files' \
        '(-c --tls-cert)'{-c+,--tls-cert=}'[TLS certificate path (required)]:file:_files' \
        '(-d --destination)'{-d+,--destination=}'[domain zone appended to SNI hostname to compute destination (required)]:zone:'
}

_pg_sni_router "$@"
