#compdef buildpulse-test-reporter
# Documentation: https://github.com/buildpulse/test-reporter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# BuildPulse test reporter — uploads JUnit XML test results to BuildPulse.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'submit:upload test report to BuildPulse'
    )
    _describe -t commands 'buildpulse-test-reporter command' commands && ret=0
    ;;
  args)
    case $words[1] in
      submit)
        _arguments \
          '--account-id=[BuildPulse account identifier]:account-id:' \
          '--repository-id=[BuildPulse repository identifier]:repository-id:' \
          '--repository-dir=[path to repository working directory]:directory:_directories' \
          '--tree=[git tree SHA when no working directory available]:sha:' \
          '--coverage-files=[space-separated coverage file paths]:files:_files' \
          '--tags=[space-separated build tags]:tags:' \
          '--quota-id=[quota identifier]:quota-id:' \
          '*:report path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
