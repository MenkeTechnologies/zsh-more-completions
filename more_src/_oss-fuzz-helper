#compdef oss-fuzz-helper
# _oss-fuzz-helper — helper script for OSS-Fuzz users (google/oss-fuzz)
# upstream: https://github.com/google/oss-fuzz
# Subcommands from infra/helper.py (argparse).

_oss-fuzz-helper() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                generate:'generate files for a new project'
                build_image:'build the docker image for a project'
                build_fuzzers:'build fuzzers for a project'
                fuzzbench_build_fuzzers:'fuzzbench: build fuzzers for a project'
                check_build:'check that fuzzers execute without errors'
                index:'index project'
                run_fuzzer:'run a fuzzer in the emulated environment'
                fuzzbench_run_fuzzer:'fuzzbench: run a fuzzer'
                fuzzbench_measure:'fuzzbench: measure a fuzzer run'
                coverage:'generate code coverage report'
                introspector:'run fuzz introspector on a project'
                download_corpora:'download all corpora for a project'
                reproduce:'reproduce a crash from a testcase'
                shell:'run /bin/bash inside the builder container'
                run_clusterfuzzlite:'run ClusterFuzzLite on a project'
                pull_images:'pull base docker images'
                check_test:'run unit tests inside the project image'
                check_replay:'check that replay reproduces a crash'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_oss-fuzz-helper "$@"
