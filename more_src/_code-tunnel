#compdef code-tunnel

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'status:show tunnel status'
    'rename:rename the tunnel'
    'unregister:unregister the tunnel'
    'kill:kill running tunnel'
    'restart:restart the tunnel'
    'service:manage system service'
    'prune:clean up expired tunnels'
    'user:manage tunnel user'
)

_arguments -s -S \
    '--help[show help]' \
    '-h[show help]' \
    '--version[show version]' \
    '-v[show version]' \
    '--verbose[verbose logging]' \
    '--cli-data-dir=[CLI data directory]:directory:_directories' \
    '--name=[tunnel name]:name' \
    '--accept-server-license-terms[accept license terms]' \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'code-tunnel subcommand' subcommands
        ;;
    args)
        case $words[1] in
            service)
                _arguments \
                    '1:action:(install uninstall log)'
                ;;
            rename)
                _arguments \
                    '1:new name:'
                ;;
            user)
                _arguments \
                    '1:action:(login logout show)'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
