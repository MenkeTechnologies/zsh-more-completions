#compdef gardenlet
# _gardenlet — Gardener gardenlet (seed cluster agent)
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardenlet/app/options.go on tip.

_gardenlet() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[gardenlet config file]:file:_files -g "*.(yaml|yml)"' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardenlet "$@"
