#compdef kubectl-applier
# Documentation: https://github.com/stolostron/applier/tree/main/pkg/cmd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# stolostron/applier (kubectl applier). Applies go text/template files on k8s.

local curcontext="$curcontext" state line ret=1

local -a render_flags=(
  '--values=[the files containing the values]:file:_files'
  '--header=[the files added to each template]:file:_files'
  '*--path=[a template path]:path:_files'
  '*--exclude=[a path to exclude]:path:_files'
  '--output-file=[copy the generated resources to this file]:file:_files'
  '--output-dir=[directory where to write the rendered files]:dir:_directories'
  '--sort-on-kind[sort the files by their kind]'
  '--dry-run[do not apply the resources]'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:apply templated resources to the cluster'
      'render:render templated resources without applying'
      'version:print version'
    )
    _describe -t commands 'kubectl-applier command' commands && ret=0
    ;;
  args)
    case $line[1] in
      apply)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:resource type:(core-resources customresources deployments)' \
          '*::arg:->apply_args' && ret=0
        case $state in
          apply_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              $render_flags && ret=0
            ;;
        esac
        ;;
      render)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          $render_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
