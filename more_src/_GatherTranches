#compdef GatherTranches
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/vqsr/GatherTranches.java
# Gathers scattered VQSLOD tranches into a single file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[scattered tranches file]:tranches:_files' \
  '(-O --output)'{-O,--output}'=[file to output the gathered tranches to]:output:_files' \
  '*--truth-sensitivity-tranche=[truth sensitivity level to slice the data (percent)]:level:' \
  '--mode=[recalibration mode to employ]:mode:(SNP INDEL BOTH)' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:tranches:_files' && ret=0

return ret
