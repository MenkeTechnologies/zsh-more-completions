#compdef c4d
# Documentation: https://sourceforge.net/p/c3d/git/ci/master/tree/doc/c3d.md
# Convert3D: 4D variant (c4d)

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[print version information]' \
  '-o[write image to file]:output file:_files' \
  '(-omc -output-multicomponent)'{-omc,-output-multicomponent}'[output multiple images as single multi-component file]' \
  '-oo[output multiple images to multiple files]:output files:_files' \
  '-oomc[output multiple multi-component images]' \
  '-as[assign last image to a variable]:variable name:' \
  '-push[place named variable on stack]:variable name:' \
  '-pop[remove last image from stack]' \
  '-dup[duplicate last image]' \
  '-clear[clear the stack]' \
  '-foreach[begin loop over images]' \
  '-endfor[end loop over images]' \
  '-accum[begin cumulative operation]' \
  '-endaccum[end cumulative operation]' \
  '-add[add last two images]' \
  '(-multiply -times)'{-multiply,-times}'[multiply last two images]' \
  '-divide[divide last two images]' \
  '-scale[scale image by a constant]:factor:' \
  '-shift[shift image intensity]:amount:' \
  '(-thresh -threshold)'{-thresh,-threshold}'[binary thresholding]' \
  '-clip[clip intensity to a range]' \
  '-smooth[Gaussian smoothing]:sigma:' \
  '-resample[resample to new dimensions]:dimensions:' \
  '-flip[flip image around axis]:axis:' \
  '-slice[extract slices]:axis:' \
  '-split[convert multilabel image to binary images]' \
  '-merge[recombine binary images into multilabel]' \
  '-dilate[morphological dilation]' \
  '-erode[morphological erosion]' \
  '-spacing[set voxel spacing]:spacing:' \
  '-origin[set image origin]:origin:' \
  '-orient[change image orientation]:orientation:' \
  '*:image file:_files' && ret=0

return ret
