#compdef volumeicon
# Documentation: https://man.archlinux.org/search?q=volumeicon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' && ret=0

return ret
