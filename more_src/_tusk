#compdef tusk

_tusk() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-f --file)'{-f,--file}'[Set config file]:config:_files -g "*.yml *.yaml"' \
    '(-q --quiet)'{-q,--quiet}'[Only print command output and errors]' \
    '(-v --verbose)'{-v,--verbose}'[Print verbose output]' \
    '--version[Print version]' \
    '--completion[Generate shell completion]:shell:(bash zsh fish)' \
    '--help[Show help]' \
    '--install-completion[Install shell completion]' \
    '--uninstall-completion[Uninstall shell completion]' \
    '1:task:->tasks' \
    '*::arg:->args'

  case $state in
    tasks)
      local -a tasks
      if [[ -f tusk.yml ]]; then
        tasks=(${(f)"$(tusk --help 2>/dev/null | sed -n '/^Tasks:/,/^$/{ /^  /s/^  \([^ ]*\) *\(.*\)/\1:\2/p }')"})
      fi
      _describe 'task' tasks
      ;;
  esac
}

_tusk "$@"
