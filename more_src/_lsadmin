#compdef lsadmin
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-lsadmin
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# lsadmin: LSF cluster administration
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '*:action:(ckconfig hclose hopen hrestart hshutdown hstartup limrestart limshutdown limstartup limlock limunlock reconfig resrestart resshutdown resstartup help)' && ret=0
return ret
