#compdef lsadmin
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lsadmin.8.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lsadmin(8) reference.

# lsadmin: LSF cluster administration
local curcontext="$curcontext" state line ret=1
local -a actions
actions=(
  'ckconfig:check LSF LIM configuration files'
  'reconfig:restart LIM daemons on all hosts in local cluster'
  'limstartup:start LIM daemons on specified hosts'
  'limshutdown:shut down LIM daemons on specified hosts'
  'limrestart:restart LIM daemons on specified hosts'
  'limlock:lock the local host LIM'
  'limunlock:unlock the local host LIM'
  'resstartup:start RES daemons on specified hosts'
  'resshutdown:shut down RES daemons on specified hosts'
  'resrestart:restart RES daemons on specified hosts'
  'reslogon:turn on RES task logging'
  'reslogoff:turn off RES task logging'
  'limdebug:set LIM debug class/level'
  'resdebug:set RES debug class/level'
  'limtime:set LIM timing level'
  'restime:set RES timing level'
  'showconf:display configured parameters'
  'help:show help on subcommands'
  'quit:exit lsadmin'
)
_arguments -C \
  '(- *)-h[print usage]' \
  '(- *)-V[print version]' \
  '1: :->action' \
  '*::arg:->args' && ret=0
case $state in
  (action) _describe -t actions 'lsadmin subcommand' actions && ret=0 ;;
  (args)
    case $line[1] in
      (limstartup|limshutdown|limrestart|resstartup|resshutdown|resrestart|reslogon|reslogoff)
        _arguments \
          '-f[no confirmation]' \
          '-v[verbose]' \
          '*:host:_hosts' && ret=0
        ;;
      (ckconfig|reconfig)
        _arguments \
          '-f[no confirmation]' \
          '-v[verbose]' && ret=0
        ;;
      (limlock)
        _arguments '-l+[lock for seconds]:seconds:' && ret=0
        ;;
      (showconf)
        _arguments '*:host:_hosts' && ret=0
        ;;
    esac
    ;;
esac
return ret
