#compdef ledis-dump
# Documentation: https://github.com/ledisdb/ledisdb/blob/master/cmd/dump.go
# Dump tool for LedisDB — saves a snapshot to a dump file

local ret=1

_arguments -s -S \
  '-host=[ledis server host]:host:_hosts' \
  '-port=[ledis server port]:port:' \
  '-sock=[ledis unix socket domain]:socket:_files' \
  '-o+[dump file to save]:file:_files' && ret=0

return ret
