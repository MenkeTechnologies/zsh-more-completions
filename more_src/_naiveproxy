#compdef naiveproxy
# Documentation: https://github.com/klzgrad/naiveproxy/blob/master/USAGE.txt
# naiveproxy - make your traffic mimic normal HTTP/2 traffic to evade censorship

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[print version]' \
  '--listen=[listening endpoint URI (socks/http/redir)]:uri' \
  '--proxy=[proxy server chain (http/https/quic/socks)]:proxy' \
  '--insecure-concurrency=[number of concurrent tunnel connections]:n' \
  '--tunnel-timeout=[seconds a tunnel persists before retirement]:seconds' \
  '--idle-timeout=[seconds after which idle tunneled streams are closed]:seconds' \
  '--extra-headers=[extra headers in requests to the proxy server]:headers' \
  '--host-resolver-rules=[statically map domain names to IP addresses]:rules' \
  '--resolver-range=[CIDR range for the builtin DNS resolver]:cidr' \
  '--log=[save log to file at path (empty prints to console)]::file:_files' \
  '--log-net-log=[save NetLog to path]:file:_files' \
  '--ssl-key-log-file=[save SSL keys for Wireshark inspection]:file:_files' \
  '--no-post-quantum[disable post-quantum key agreement]' && ret=0

return ret
