#compdef cdncheck
# Documentation: https://github.com/projectdiscovery/cdncheck
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above. cdncheck uses Go-style
# single-dash flags (e.g. -input, -cdn) as is typical for projectdiscovery
# tools.

_arguments -s -S \
  '(- *)-version[show version]' \
  '-i+[input file with IPs/domains]:file:_files' \
  '-input=[input file with IPs/domains]:file:_files' \
  '-o+[output file]:file:_files' \
  '-cdn[display only CDN matches]' \
  '-waf[display only WAF matches]' \
  '-cloud[display only cloud matches]' \
  '-mcdn=[match CDN providers]:provider:' \
  '-mwaf=[match WAF providers]:provider:' \
  '-mcloud=[match cloud providers]:provider:' \
  '-fcdn=[filter CDN providers]:provider:' \
  '-fwaf=[filter WAF providers]:provider:' \
  '-fcloud=[filter cloud providers]:provider:' \
  '-resp[show resolved IP and response]' \
  '-r+[custom DNS resolvers]:resolver:' \
  '-resolver=[custom DNS resolvers]:resolver:' \
  '-e+[exclude provider]:provider:' \
  '-exclude=[exclude provider]:provider:' \
  '-retry=[max DNS retries]:n:' \
  '-v[verbose output]' \
  '-verbose[verbose output]' \
  '-silent[silent mode]' \
  '-nc[no color]' \
  '-j[JSONL output]' \
  '-jsonl[JSONL output]' \
  '-up[update cdncheck]' \
  '-duc[disable update check]' \
  '*:host:' && return 0
