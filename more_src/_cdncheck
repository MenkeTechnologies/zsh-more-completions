#compdef cdncheck

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-i+[input file with IPs/domains]:input file:_files' \
  '-input=[input file with IPs/domains]:input file:_files' \
  '-o+[output file]:output file:_files' \
  '-output=[output file]:output file:_files' \
  '-v[verbose output]' \
  '-verbose[verbose output]' \
  '-j[JSON output]' \
  '-json[JSON output]' \
  '-cdn[display CDN in use]' \
  '-waf[display WAF in use]' \
  '-cloud[display cloud provider]' \
  '-resp[show response details]' \
  '-exclude[exclude CDN/WAF IPs]' \
  '-match[match CDN/WAF IPs]' \
  '-filter=[filter by provider]:provider' \
  '-resolver=[custom DNS resolver]:resolver' \
  '-silent[silent mode]' \
  '-nc[no color]' \
  '*:host:' && return 0
