#compdef mdedup
# Documentation: https://kdeldycke.github.io/mail-deduplicate/cli-parameters.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: -h here is --hash-header (a header field), not --help; --help has no short form.

local -a _strategies
_strategies=(
  select-older select-oldest select-newer select-newest
  discard-older discard-oldest discard-newer discard-newest
  select-smaller select-smallest select-bigger select-biggest
  discard-smaller discard-smallest discard-bigger discard-biggest
  select-matching-path select-non-matching-path
  discard-matching-path discard-non-matching-path
  select-one select-all-but-one discard-one discard-all-but-one
)

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '(-i --input-format)'{-i+,--input-format=}'[force input mailbox format]:format:(maildir mbox mh babyl mmdf)' \
  '(-u --force-unlock)'{-u,--force-unlock}'[remove mail source lock if present]' \
  '*'{-h+,--hash-header=}'[header field used in the hash]:header:' \
  '(-m --minimal-headers)'{-m+,--minimal-headers=}'[minimum required headers count]:n:' \
  '(-b --hash-body)'{-b+,--hash-body=}'[body hashing method]:mode:(skip raw normalized)' \
  '(-H --hash-only)'{-H,--hash-only}'[only print hashes and exit]' \
  '(-s --strategy)'{-s+,--strategy=}'[duplicate selection strategy]:strategy:($_strategies)' \
  '(-t --time-source)'{-t+,--time-source=}'[time reference for strategies]:source:(date-header ctime)' \
  '(-r --regexp)'{-r+,--regexp=}'[path regexp for path-based strategies]:regexp:' \
  '(-S --size-threshold)'{-S+,--size-threshold=}'[max size delta in bytes]:bytes:' \
  '(-C --content-threshold)'{-C+,--content-threshold=}'[max content delta in bytes]:bytes:' \
  '(-d --show-diff)'{-d,--show-diff}'[display unified diff for content comparisons]' \
  '(-a --action)'{-a+,--action=}'[action on selected mails]:action:' \
  '(-E --export)'{-E+,--export=}'[destination mailbox for export actions]:mailbox:_files -/' \
  '(-e --export-format)'{-e+,--export-format=}'[export mailbox format]:format:(maildir mbox mh babyl mmdf)' \
  '(-n --dry-run)'{-n,--dry-run}'[simulate without making changes]' \
  '--time[measure execution duration]' \
  '--no-time[do not measure execution duration]' \
  '--color[colorize output]' \
  '--no-color[disable colorized output]' \
  '--config=[configuration file]:file:_files' \
  '--show-params[print resolved parameters and exit]' \
  '--verbosity=[logging level]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*:mail sources:_files'
