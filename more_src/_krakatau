#compdef krakatau
# _krakatau — Robert Grosse Krakatau Java bytecode tools CLI alias (Storyyeller team, Python/Rust); custom argparse
# upstream: https://github.com/Storyyeller/Krakatau

_krakatau() {
    local -a sub=(
        'decompile:decompile classes'
        'disassemble:disassemble classes'
        'assemble:assemble classes'
        'roundtrip:disassemble and reassemble'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krakatau subcommand' sub ;;
        args)
            case $words[1] in
                decompile) _arguments \
                    '-out+[output zip]:file:_files -g "*.zip"' \
                    '-r[recursive]' \
                    '-skip[skip errors]' \
                    '-classpath+[classpath]:str:' \
                    '-path+[path]:dir:_files -/' \
                    '*:input files:_files -g "*.{class,jar}"' ;;
                disassemble) _arguments \
                    '-out+[output zip]:file:_files -g "*.zip"' \
                    '-r[recursive]' \
                    '-roundtrip[roundtrip mode]' \
                    '*:input files:_files -g "*.{class,jar}"' ;;
                assemble) _arguments \
                    '-out+[output zip]:file:_files -g "*.zip"' \
                    '-q[quiet]' \
                    '*:input files:_files -g "*.j"' ;;
                roundtrip) _arguments \
                    '-out+[output zip]:file:_files -g "*.zip"' \
                    '*:input files:_files -g "*.{class,jar}"' ;;
            esac
            ;;
    esac
}

_krakatau "$@"
