#compdef pwsh powershell

# Zsh completion for PowerShell (pwsh)

_powershell() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-Command+[execute specified commands]:command string:' \
    '-c+[execute specified commands]:command string:' \
    '-ConfigurationName+[specify configuration endpoint]:configuration name:' \
    '-CustomPipeName+[specify custom named pipe name]:pipe name:' \
    '-EncodedCommand+[accept base-64-encoded string command]:encoded command:' \
    '-e+[accept base-64-encoded string command]:encoded command:' \
    '-ExecutionPolicy+[set execution policy]:policy:(AllSigned Bypass Default RemoteSigned Restricted Unrestricted)' \
    '-File+[run specified script file]:script file:_files -g "*.ps1"' \
    '-f+[run specified script file]:script file:_files -g "*.ps1"' \
    '-InputFormat+[input format]:format:(Text XML)' \
    '-Interactive[start interactive session]' \
    '-i[start interactive session]' \
    '-Login[start as login shell]' \
    '-l[start as login shell]' \
    '-MTA[start using multi-threaded apartment]' \
    '-NoExit[do not exit after running startup commands]' \
    '-noe[do not exit after running startup commands]' \
    '-NoLogo[hide copyright banner at startup]' \
    '-nol[hide copyright banner at startup]' \
    '-NonInteractive[do not present interactive prompt]' \
    '-noni[do not present interactive prompt]' \
    '-NoProfile[do not load PowerShell profile]' \
    '-nop[do not load PowerShell profile]' \
    '-NoProfileLoadTime[hide profile load time at startup]' \
    '-OutputFormat+[output format]:format:(Text XML)' \
    '-o+[output format]:format:(Text XML)' \
    '-SettingsFile+[override system-wide settings file]:settings file:_files -g "*.json"' \
    '-SSHServerMode[used by sshd to run PowerShell as SSH subsystem]' \
    '-STA[start using single-threaded apartment]' \
    '-Version[display version and exit]' \
    '-v[display version and exit]' \
    '-WindowStyle+[set window style]:style:(Normal Minimized Maximized Hidden)' \
    '-w+[set window style]:style:(Normal Minimized Maximized Hidden)' \
    '-WorkingDirectory+[set initial working directory]:directory:_files -/' \
    '-wd+[set initial working directory]:directory:_files -/' \
    '-Help[display help]' \
    '-h[display help]' \
    '-\?[display help]' \
    '*:script file:_files -g "*.ps1"' \
    && ret=0

  return ret
}

_powershell "$@"
