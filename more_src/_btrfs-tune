#compdef btrfs-tune btrfstune
# _btrfs-tune — btrfstune Btrfs FS metadata tweak CLI alias (kdave / Btrfs team, C); custom argparse
# upstream: https://github.com/kdave/btrfs-progs

_btrfs-tune() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-S+[set seeding flag]:n:(0 1)' \
        '-r[enable extended inode refs]' \
        '-x[enable skinny metadata extent refs]' \
        '-n[enable no holes]' \
        '-f[force]' \
        '-u[change fsid]' \
        '-U+[change fsid to value]:uuid:' \
        '-m+[change metadata uuid]:str:' \
        '-M+[change metadata uuid to value]:uuid:' \
        '--csum=+[change checksum algorithm]:c:(crc32c xxhash sha256 blake2)' \
        '*:device:_files'
}

_btrfs-tune "$@"
