#compdef kubeone

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'apply:reconcile cluster from manifest'
      'kubeconfig:download kubeconfig for the cluster'
      'status:check cluster status'
      'reset:reset the cluster'
      'version:print version'
      'config:config helpers'
      'podpins:list image pins for OS packages'
    )
    _describe -t commands 'kubeone command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      apply|kubeconfig|status|reset)
        _arguments -s -S \
          '(-m --manifest)'{-m,--manifest}'=[kubeone manifest]:file:_files' \
          '(-t --tfjson)'{-t,--tfjson}'=[terraform output json]:file:_files' \
          '(-y --auto-approve)'{-y,--auto-approve}'[auto approve plan]' \
          '--kubeconfig=[path to kubeconfig]:file:_files' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
