#compdef eunit
# _eunit — Erlang EUnit test runner shim (Ericsson + community, Erlang); invoke eunit:test/1 from CLI
# upstream: https://github.com/erlang/otp

_eunit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-noshell[no shell]' \
        '-pa+[prepend code path]:dir:_files -/' \
        '-pz+[append code path]:dir:_files -/' \
        '-verbose[verbose]' \
        '-quiet[quiet]' \
        '-detached[detached]' \
        '-config+[config file]:file:_files' \
        '*:module or path:'
}

_eunit "$@"
