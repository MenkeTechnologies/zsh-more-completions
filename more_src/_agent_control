#compdef agent_control

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-l[list available agents]' \
  '-lc[list connected agents only]' \
  '-i+[get agent info by id]:id:' \
  '-u+[force syscheck/rootcheck on agent]:id:' \
  '-R+[restart agent]:id:' \
  '-b+[block agent]:ip:' \
  '-f+[firewall response]:script:' \
  '-r[reload manager configuration]' \
  '-s[show agents in JSON]' \
  '-j[JSON output]' \
  '-x+[execute active response]:command:' \
  '-q[quiet output]' \
  '*::passthrough:' && ret=0

return ret
