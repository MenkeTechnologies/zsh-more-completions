#compdef avn

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'setup:install shell hook and write ~/.avnrc'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'avn subcommand' subcommands && ret=0
    ;;
esac

return ret
