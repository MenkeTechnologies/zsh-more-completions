#compdef porkbun porkbun-cli
# _porkbun — Porkbun DNS/domain registrar CLI alias (community implementations, varies); custom argparse
# upstream: https://porkbun.com/api/json/v3/documentation

_porkbun() {
    local -a sub=(
        'ping:test api connectivity'
        'pricing:get pricing list'
        'domain:list:list domains'
        'domain:create:register domain'
        'domain:delete:delete domain'
        'domain:nameservers:get:get nameservers'
        'domain:nameservers:update:update nameservers'
        'domain:urlforward:get:list url forwards'
        'domain:urlforward:add:add url forward'
        'domain:urlforward:delete:delete url forward'
        'dns:create:create dns record'
        'dns:edit:edit dns record'
        'dns:edit-by-type:edit by name/type'
        'dns:delete:delete dns record'
        'dns:delete-by-type:delete by name/type'
        'dns:retrieve:retrieve all records'
        'dns:retrieve-by-id:retrieve record by id'
        'dns:retrieve-by-type:retrieve by name/type'
        'ssl:retrieve:retrieve ssl bundle'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-key=+[api key]:str:' \
        '--secret-key=+[secret key]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'porkbun subcommand' sub ;;
        args)
            case $words[1] in
                dns:create|dns:edit|dns:edit-by-type) _arguments \
                    '1:domain:' \
                    '--name=+[subdomain]:str:' \
                    '--type=+[record type]:t:(A AAAA MX CNAME ALIAS TXT NS CAA SRV TLSA SSHFP)' \
                    '--content=+[content]:str:' \
                    '--ttl=+[ttl seconds]:n:' \
                    '--prio=+[priority]:n:' \
                    '--id=+[record id]:str:' ;;
                dns:delete|dns:delete-by-type|dns:retrieve-by-id|dns:retrieve-by-type) _arguments \
                    '1:domain:' \
                    '--name=+[subdomain]:str:' \
                    '--type=+[record type]:t:(A AAAA MX CNAME ALIAS TXT NS CAA SRV TLSA SSHFP)' \
                    '--id=+[record id]:str:' ;;
                domain:nameservers:update) _arguments \
                    '1:domain:' \
                    '*:nameserver:_hosts' ;;
                ssl:retrieve) _arguments '1:domain:' ;;
            esac
            ;;
    esac
}

_porkbun "$@"
