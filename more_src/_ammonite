#compdef ammonite

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[execute code]:code' \
  '--code=[execute code]:code' \
  '--home=[Ammonite home directory]:directory:_directories' \
  '--predef-code=[code to execute before script]:code' \
  '--predef=[predef file]:predef file:_files' \
  '--no-home-predef[do not load home predef]' \
  '-s[silent mode]' \
  '--silent[silent mode]' \
  '--color=[enable or disable colored output]:enable:(true false)' \
  '--thin[start Ammonite in thin mode]' \
  '--help-is-exception[throw exception on --help]' \
  '--no-remote-logging[disable remote logging]' \
  '-b+[set banner]:banner' \
  '--banner=[set banner]:banner' \
  '-w[watch for file changes]' \
  '--watch[watch for file changes]' \
  '--bsp[run as BSP server]' \
  '--class-based[use class-based wrapping]' \
  '--no-default-predef[do not load default predefs]' \
  '--short-prompt[use short prompt]' \
  '*:Scala script:_files -g "*.{sc,scala}"' && ret=0

return ret
