#compdef mailx mail Mail
# _mailx — Berkeley mail / mailx (POSIX/Unix message-processing system; send mail from command line or read mbox interactively; reads ~/.mailrc)
# upstream: https://github.com/openbsd/src (usr.bin/mail)
# Flags from usr.bin/mail/main.c getopt + usr.bin/mail/mail.1 on tip.

_mailx() {
    _arguments \
        '(- *)-h[show usage]' \
        '-b+[blind carbon copy (comma-separated list)]:bcc:_email_addresses' \
        '-c+[carbon copy (comma-separated list)]:cc:_email_addresses' \
        '-d[enable debug output]' \
        '-E[do not send empty messages]' \
        '-f+[read this mbox file]:file:_files' \
        '-I[behave as if invoked in interactive mode]' \
        '-i[ignore tty interrupt signals]' \
        '-N[suppress initial header summary]' \
        '-n[do not read /etc/mail.rc]' \
        '-r+[sender envelope address]:from:_email_addresses' \
        '-s+[message subject]:subject:' \
        '-u+[read this user'\''s mailbox]:user:_users' \
        '-v[verbose (pass -v to sendmail)]' \
        '*:to-addr:_email_addresses'
}

_mailx "$@"
