#compdef logflare-cli logflare
# _logflare-cli — Supabase Logflare logflare-cli CLI command-line frontend wrapping the Logflare open-source-acquired-by-Supabase log analytics platform on top of BigQuery formerly Cloudflare Worker provider streaming-log-aggregation BigQuery SQL-queries CloudFlare-Vercel-Heroku-AWS-Erlang-Node-Elixir-Ruby-Python ingestion ingest source endpoint backend rule team user TBA API-key (Supabase Logflare team Chase Granberry, Elixir/Go); cobra
# upstream: https://logflare.app/

_logflare-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'source:source operations'
        'endpoint:endpoint operations'
        'backend:backend operations'
        'rule:rule operations'
        'team:team operations'
        'user:user operations'
        'api-key:API key operations'
        'partner:partner operations'
        'billing:billing operations'
        'plan:plan operations'
        'ingest:ingest log batch'
        'search:search logs'
        'tail:tail logs'
        'query:run query'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--source-token=+[token]:str:' \
        '--source-id=+[id]:str:' \
        '--source-name=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'logflare subcommand' sub ;;
        args)
            case $words[1] in
                source|endpoint|backend|rule|team|user|api-key|partner|billing|plan) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                ingest|search|tail|query) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_logflare-cli "$@"
