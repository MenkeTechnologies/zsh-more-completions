#compdef kubectl-browse-pvc
# Documentation: https://github.com/clbx/kubectl-browse-pvc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cmd/browse-pvc/main.go flags).

# kubectl-browse-pvc (clbx/kubectl-browse-pvc): own flags plus the standard
# genericclioptions ConfigFlags set.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --image)'{-i+,--image=}'[image to mount job to]:image:' \
  '(-u --container-user)'{-u+,--container-user=}'[user ID to run the container as]:uid:' \
  '(-r --read-only)'{-r,--read-only}'[mount the PVC as read-only]' \
  '(-j --job-name)'{-j+,--job-name=}'[override the generated job name]:name:' \
  '(-t --timeout)'{-t+,--timeout=}'[seconds to wait for the browse pod to start]:seconds:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '*:pvc:_default'
