#compdef crabfetch
# Documentation: https://github.com/LivacoNew/CrabFetch
# crabfetch - a fast, configurable system information fetcher written in Rust

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[display the version of CrabFetch and enabled features]' \
  '(-c --config)'{-c,--config}'=[set a custom config file, specify none to use the default]:file:_files' \
  '(-g --generate_config_file)'{-g,--generate_config_file}'[generate a default config file]' \
  '(-d --distro_override)'{-d,--distro_override}'=[override the distro ASCII to another distro]:distro:' \
  '--ignore_custom_ascii[ignore any custom ASCII file]' \
  '--disable_ascii[disable ASCII rendering entirely]' \
  '(-s --suppress_errors)'{-s,--suppress_errors}'[suppress any errors]' \
  '--module_override=[override the modules set in your config file, comma separated]:modules:' \
  '--inline_values[enable the inline values option]' \
  '--benchmark[run in benchmark mode, showing stage and module detection times]' \
  '--benchmark_warn=[set a warning color threshold for the benchmark option in microseconds]:us:' && ret=0

return ret
