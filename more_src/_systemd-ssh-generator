#compdef systemd-ssh-generator
# _systemd-ssh-generator (systemd unit generator that synthesizes sshd@.service instances + sshd.socket from $XDG_CONFIG_HOME/ssh/ + /etc/ssh/sshd_config.d/*.conf for kernel-cmdline systemd.ssh=…; generator binaries are invoked by systemd with three positional dirs (normal_dir, early_dir, late_dir))
# upstream: https://github.com/systemd/systemd (src/ssh-generator)
# Argument shape from systemd src/ssh-generator/ssh-generator.c on tip.

_systemd-ssh-generator() {
    _arguments \
        '1:normal dir:_files -/' \
        '2:early dir:_files -/' \
        '3:late dir:_files -/'
}

_systemd-ssh-generator "$@"
