#compdef helmfile

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apply:apply changes to release'
  'build:output the helmfile for debugging'
  'cache:cache commands'
  'charts:populate chart deps'
  'completion:generate shell completion'
  'deps:update chart deps'
  'destroy:destroy releases'
  'diff:diff between current and desired'
  'fetch:fetch chart deps'
  'init:initialize helmfile'
  'lint:lint chart files'
  'list:list releases'
  'repos:add chart repos'
  'show-dag:show release DAG'
  'status:show status'
  'sync:sync releases'
  'template:render templates'
  'test:run tests'
  'version:show version'
  'write-values:write values'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--allow-no-matching-release[allow no match]' \
  '*--chart=[chart override]:c:' \
  '*--color[color output]' \
  '*--debug[debug]' \
  '*--enable-live-output[live output]' \
  '*--environment=[environment]:e:' \
  '*-e+[environment]:e:' \
  '*--file=[file]:file:_files -g "*.yaml *.yml"' \
  '*-f+[file]:file:_files' \
  '*--helm-binary=[helm path]:file:_files' \
  '*-b+[helm path]:file:_files' \
  '*--interactive[interactive]' \
  '*-i[interactive]' \
  '*--kube-context=[kube context]:c:' \
  '*--kubeconfig=[kubeconfig path]:file:_files' \
  '*--log-level=[log level]:l:(trace debug info warn error)' \
  '*--namespace=[namespace]:ns:' \
  '*-n+[namespace]:ns:' \
  '*--no-color[no color]' \
  '*--quiet[quiet]' \
  '*-q[quiet]' \
  '*--selector=[label selector]:s:' \
  '*-l+[label selector]:s:' \
  '*--state-values-file=[state values file]:file:_files' \
  '*--state-values-set=[state values set]:s:' \
  '*--strip-args-values-on-exit-error=[strip args]:b:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'helmfile command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apply|sync|diff|template|destroy|test|lint|status|fetch)
        _arguments \
          '*--args=[helm args]:a:' \
          '*--auto-approve[auto approve]' \
          '*--cleanup[cleanup]' \
          '*--concurrency=[concurrency]:n:' \
          '*--context=[diff context]:n:' \
          '*--detailed-exitcode[detailed exit]' \
          '*--include-tests[include tests]' \
          '*--reset-values[reset values]' \
          '*--retain-values-files[retain]' \
          '*--set=[helm set values]:s:' \
          '*--skip-deps[skip deps]' \
          '*--skip-needs[skip needs]' \
          '*--include-needs[include needs]' \
          '*--include-transitive-needs[include transitive]' \
          '*--skip-cleanup[skip cleanup]' \
          '*--skip-crds[skip crds]' \
          '*--skip-diff-on-install[skip diff on install]' \
          '*--skip-schema-validation[skip schema validation]' \
          '*--suppress=[suppress kinds csv]:list:' \
          '*--suppress-diff[suppress diff]' \
          '*--suppress-secrets[suppress secrets]' \
          '*--validate[validate]' \
          '*--values=[values file]:file:_files' \
          '*: :_files' && ret=0 ;;
      (init)
        _arguments \
          '*--force[force]' \
          '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (cache)
        _arguments '1:subcommand:(info cleanup show)' '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
