#compdef PeakPickerHiRes
# OpenMS TOPP: pick peaks in high-resolution profile MS data

local ret=1

_arguments -s -S \
  '-in[input profile data file (mzML)]:input file:_files' \
  '-out[output peak file (mzML)]:output file:_files' \
  '-processOption[memory handling]:mode:(inmemory lowmemory)' \
  '-algorithm:signal_to_noise[minimal signal-to-noise ratio]:ratio:' \
  '-algorithm:spacing_difference_gap[peak extension stopping criterion]:value:' \
  '-algorithm:spacing_difference[maximum spacing variance during extension]:value:' \
  '-algorithm:missing[maximum missing points allowed]:n:' \
  '-algorithm:ms_levels[MS levels for peak picking]:levels:' \
  '-algorithm:report_FWHM[include FWHM metadata]:bool:(true false)' \
  '-algorithm:report_FWHM_unit[FWHM unit]:unit:' \
  '-algorithm:allow_missing_flank[permit peaks without flanking data]:bool:(true false)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
