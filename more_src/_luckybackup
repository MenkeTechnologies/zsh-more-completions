#compdef luckybackup
# Documentation: https://manpages.org/luckybackup/8
# Reference accessed: 2026-05-16
# Verified: luckybackup(8) manpage on manpages.org.
# Removed from prior file: fabricated -h/-V single-letter forms and
# bogus man.archlinux.org search URL.

# luckybackup: rsync GUI backup tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--skip-critical[skip tasks with CRITICAL warnings]' \
  '--dry-run[simulation mode]' \
  '--silent[silent mode (tray notification only)]' \
  '-c[console mode (no graphical environment)]' \
  '--no-questions[skip confirmation questions (implies -c)]' \
  '*:profile file:_files' && ret=0
return ret
