#compdef shuffledns

# Zsh completion for shuffledns - DNS brute-force tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --domain)'{-d,--domain}'[target domain]:domain' \
  '(-l -list)'{-l,-list}'[subdomain list file]:subdomain list:_files' \
  '(-r --resolver)'{-r,--resolver}'[resolver file]:resolver file:_files' \
  '(-w --wordlist)'{-w,--wordlist}'[wordlist file]:wordlist:_files' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  '-sw[enable wildcard filtering]' \
  '-wt[wildcard threshold]:threshold' \
  '(-m --massdns)'{-m,--massdns}'[path to massdns binary]:massdns binary:_files' \
  '-directory[temporary directory]:directory:_directories' \
  '-retries[number of retries]:retries' \
  '-strict-wildcard[strict wildcard filtering]' \
  '-raw-input[treat input as raw DNS responses]' \
  '-silent[silent mode]' \
  '-json[output in JSON format]'
