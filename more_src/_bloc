#compdef bloc
# Documentation: https://pub.dev/packages/bloc_tools
# bloc - command-line tools for the bloc state-management library

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[print the current version]' \
  '1:command:(lint new)' \
  '*::args:' && ret=0

return ret
