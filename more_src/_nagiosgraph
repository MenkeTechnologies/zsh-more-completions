#compdef nagiosgraph insert.pl show.cgi showhost.cgi showservice.cgi showgroup.cgi
# Documentation: https://man.archlinux.org/search?q=nagiosgraph
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-v[verbose]' \
  '-l+[log file]:file:_files' && ret=0

return ret
