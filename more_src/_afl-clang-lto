#compdef afl-clang-lto afl-clang-lto++ afl-lto afl-lto++
# Documentation: https://github.com/AFLplusplus/AFLplusplus/blob/stable/src/afl-cc.c
# AFL++ link-time optimization instrumenting clang wrapper

local ret=1

_arguments -s -S \
  '--afl-noopt[behave like a normal compiler (disable instrumentation)]' \
  '--afl-lto[force LTO mode]' \
  '--afl-llvm[force LLVM mode]' \
  '-c[compile only, do not link]' \
  '-o[output file]:output:_files' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|C|h|hpp|o|a)"' && ret=0

return ret
