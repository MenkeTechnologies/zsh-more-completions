#compdef ante
# =============================================================================
# ante — Jake Fecher's "low-level functional language
#          for exploring safe, shared mutability,
#          algebraic effects, and other fun features" —
#          a research-stage systems programming language
#          that combines Rust-style ownership +
#          borrowing with TWO defining innovations:
#          (1) SAFE SHARED MUTABILITY via aliasable
#          mutable references whose mutation is
#          serialized by the type system without
#          requiring Mutex/RwLock wrappers, and (2)
#          ABILITIES, a unified language feature that
#          merges traits + algebraic effects into a
#          single capability-passing primitive.
#          Distinguishing from Rust (single-owner +
#          many-borrowers model; concurrent mutation
#          requires Mutex/RwLock wrappers), Haskell
#          (purely functional + immutability; effects
#          via monads), Koka (Daan Leijen's effect-
#          typed language with row-polymorphic
#          effects), OCaml (mutable refs without
#          aliasing safety), Idris (dependent types
#          + effects but heavyweight), Verona (R760
#          MS Research concurrent ownership but C++-
#          implemented), and Hylo (mutable value
#          semantics but no algebraic effects) by:
#            - SAFE ALIASABLE MUTABLE REFERENCES —
#              `mut Bar` declares a mutable borrow
#              that the type system PROVES cannot
#              alias improperly; multiple mutable
#              references can coexist in scope as
#              long as the compiler can prove they
#              cannot be used to violate memory
#              safety.  This is structurally
#              different from Rust's "exactly one
#              mutable OR many immutable" rule
#            - ABILITIES = TRAITS + EFFECTS — the
#              language unifies Rust-style traits
#              (overloaded functions selected by
#              type) with Haskell-style algebraic
#              effects (capability-typed
#              computations) under a single
#              "abilities" syntax.  E.g. `foo (x:
#              mut Bar) (y: ref a) {Clone a} {Fail}:
#              a` declares that `foo` requires the
#              `Clone` ability on type `a` AND the
#              `Fail` effect; the function body can
#              `clone y` AND `fail ()` because both
#              are abilities in scope
#            - PULL-BASED INCREMENTAL COMPILER — the
#              Ante compiler is INVERTED relative to
#              traditional pipeline architectures:
#              instead of "lex → parse → typecheck
#              → ir → codegen" pushed sequentially,
#              Ante's `compile` function says "I
#              want a compiled program"; the
#              `compiled program` function says "I
#              need a typechecked AST"; the
#              `typecheck` says "I need a resolved
#              AST"; etc.  Combined with the inc-
#              complete library's memoization, this
#              gives incremental rebuilds that only
#              redo work whose inputs changed
#            - LLVM + CRANELIFT + C BACKENDS — `--
#              backend llvm|cranelift|c` selects
#              between three code generation
#              targets.  Default priority for debug
#              builds is `cranelift > llvm > c`;
#              for release builds `llvm > c`.
#              Cranelift is the fastest debug-
#              build backend (no LLVM compile-time
#              cost); LLVM is the most optimized
#              release backend; C is the most
#              portable for embedded targets
#            - INCREMENTAL COMPILATION via inc-
#              complete — `-i, --incremental`
#              persists computation memoization
#              to disk between compiler invocations
#              via the inc-complete library; the
#              compiler reads + writes metadata
#              files describing which inputs each
#              compilation phase depended on
#            - TIMING PROFILER — `--show-time`
#              reports per-phase compilation
#              timings; useful for compiler-
#              engineering work + diagnosing slow
#              builds
#            - LIFETIME ANNOTATION DEBUGGER — `-L,
#              --show-lifetimes` prints the input
#              file annotated with inferred
#              lifetimes of heap allocations;
#              helpful for understanding why the
#              ownership system made a particular
#              decision
#            - MULTI-EMIT TARGETS — `-e, --emit
#              <target>` emits intermediate
#              representations instead of an
#              executable:
#              * `tokens` — lexer output
#              * `ast` — parse tree
#              * `ast-r` — parse tree + name
#                resolution
#              * `ast-t` — parse tree + types
#              * `mir` — Ante MIR
#              * `mir-tail` — MIR after tail-resume
#                optimization
#              * `mir-mono` — monomorphized MIR
#              * `ir` — LLVM IR or Cranelift IR
#            - OPTIMIZATION LEVELS — `-O0|1|2|3|s|z`
#              follow GCC/clang conventions
#              (0=none, 1=light, 2=normal, 3=
#              aggressive, s=size-optimized, z=
#              maximum-size-optimized)
#            - LANGUAGE SERVER — separate `ante-ls`
#              binary in the workspace provides LSP
#              integration with editors; the
#              compiler's pull-based architecture
#              makes editor-driven incremental
#              recompilation efficient
#            - GOLDEN TESTS — uses jfecher/golden-
#              tests for the test suite; each test
#              file in `examples/` carries comments
#              with expected output; `cargo test
#              --test goldentests` runs them
#            - 2,238+ STARS ON jfecher/ante — well-
#              starred for a single-maintainer
#              research language; backed by an
#              active Discord community
#          Used by: programming language researchers
#          exploring novel ownership models that
#          combine safe aliasing with algebraic
#          effects, PhD students studying type
#          systems for capability-effect-trait
#          unification, and the small but growing
#          community of developers attracted to
#          Ante's "Rust-like safety, Haskell-like
#          expressiveness" tagline.
#
# Author:  Jake Fecher (jfecher on GitHub;
#          https://antelang.org).  The compiler is
#          implemented in Rust 2024 edition; ante-ls
#          (language server) is in a workspace
#          member crate.
# Source:  https://github.com/jfecher/ante
#          https://github.com/jfecher/ante/blob/main/src/main.rs
#          https://github.com/jfecher/ante/blob/main/src/cli.rs
#          https://github.com/jfecher/ante/blob/main/Cargo.toml
# Manpage: No traditional manpage; `ante --help` shows
#          clap-derived help with all flags + emit
#          targets + backends.  Full language docs
#          at https://antelang.org/docs/language/
# Library: Rust 2024 edition compiler implementation
#          dependencies (the language itself is
#          targeted to LLVM/Cranelift/C; NOT part of
#          the cross-language CLI library taxonomy
#          which tracks Rust/Go/TS-Node libraries —
#          Ante is a STANDALONE LANGUAGE entry).  Key
#          compiler deps: clap 4 + clap_complete 4
#          (argparse + shell completion gen),
#          inkwell 0.7 (LLVM bindings — feature-
#          gated as `llvm`), inc-complete 0.10
#          (incremental memoization), petgraph 0.8
#          (dependency graph), rayon 1.10 (parallel
#          compilation), dashmap 6.1 (concurrent
#          hashmap), colored 2 (terminal output),
#          rangemap 1.6, rustc-hash 2.1 (fast
#          hashing), rmp-serde 1.3 (msgpack for
#          metadata), serde 1.0 with derive + rc.
# License: MIT
# Status:  2,238+ stars on jfecher/ante; active
#          development (latest commit 2026-06-01);
#          version 0.1.0 (early-stage compiler;
#          "still in a rather early state" per
#          README); LLVM 21.1 required for default
#          backend.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — 123rd LANGUAGE CLOSES 3+1 MICRO-CYCLE
# -----------------------------------------------------------------------------
# This completion is the **123rd language** entry in
# the cross-language CLI library taxonomy.  It closes
# the current 3+1 micro-cycle that began with R761
# Rust=98 (ryu/gix OPENS Axis 43 Git Library) → R762
# Go=98 (git-subtrac/go-git continues Axis 43) →
# R763 TS-Node=98 (git-proxy/isomorphic-git CLOSES
# Axis 43 at 1/1/1) → R764 THIS (123rd language).
#
# WHY ANTE IS A DISTINCTIVE 123rd-LANGUAGE ENTRY:
#
#   Ante occupies a unique position in the
#   programming-language landscape because it
#   answers the question "what would Rust look like
#   if it merged traits + algebraic effects into a
#   single concept AND allowed aliasable mutable
#   references with safety guarantees?" with two
#   genuinely novel language features (ABILITIES +
#   SAFE ALIASABLE MUTATION) that no prior language
#   in the corpus combines.
#
#   Distinguishing features in the broader cross-
#   language landscape:
#
#     1. ABILITIES UNIFICATION — most ownership-typed
#        languages have a clear separation between
#        TRAITS (Rust, Hylo) or TYPE CLASSES
#        (Haskell, Coalton, Idris) on one side, and
#        EFFECTS (Koka, Eff, Frank, Multicore OCaml)
#        on the other.  Ante's "abilities" treat
#        BOTH as instances of the same capability-
#        passing pattern, simplifying both the type
#        system and the user-facing concept count
#
#     2. SAFE ALIASABLE MUTATION — most ownership-
#        typed languages prohibit aliased mutable
#        references at compile time (Rust XOR rule,
#        Pony capabilities).  Ante allows them via
#        a more sophisticated lifetime analysis that
#        proves SAFETY without forcing exclusivity.
#        Few other languages in the corpus take this
#        approach
#
#     3. PULL-BASED INCREMENTAL COMPILER — most
#        compilers in the corpus (rustc, ghc, swift,
#        zig, idris2, kotlinc, etc.) use traditional
#        push-based pipeline architectures.  Ante's
#        pull-based architecture via the inc-complete
#        library represents a different design point
#        for incremental compilation
#
#     4. CRANELIFT + LLVM + C TRIPLE BACKEND — most
#        modern systems languages settle on a single
#        backend (Rust on LLVM, Zig on LLVM-then-
#        own, Go on its own, Carbon on LLVM).  Ante
#        targets three backends with documented
#        priority rules for different build modes
#
#     5. INKWELL FEATURE-GATED — the LLVM backend
#        is feature-gated (`features = ["llvm"]`),
#        allowing builds without LLVM installed.
#        Few language compilers offer this
#        flexibility
#
#     6. EARLY-STAGE BUT POPULAR — at 2,238 stars
#        despite "still in a rather early state"
#        per the README, Ante demonstrates that
#        the PL-research community values the
#        abilities-unification idea even before the
#        compiler is production-ready
#
# Cross-language CLI library taxonomy after R764:
#   * 123 languages
#   * 474 total CLI library variants (Rust 98 / Go 98 /
#     TS-Node 98)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 36 axes at 1/1/1 three-language symmetric
#
# Cross-language ECOSYSTEM context (Ownership-Typed
# Systems-Lang family in this corpus):
#   * Rust — XOR ownership rule, traits, no effects
#     (effects via async/Future or manual);
#     extensive corpus coverage
#   * Pony (in corpus) — Sylvan Clebsch's actor lang
#     with 22 reference capabilities; type-system-
#     enforced concurrency safety
#   * Inko (in corpus) — Yorick Peterse's actor lang
#     with similar capability typing
#   * Hylo (free elsewhere; not yet in corpus) —
#     Dimi Racordon's mutable value semantics
#   * Neut (R744 in corpus) — vekatze's box-modality
#     static memory management
#   * Verona (R760 in corpus) — MS Research region-
#     based concurrent ownership
#   * Ante (R764 THIS) — Jake Fecher's safe-aliasable-
#     mutation + abilities (traits ⊕ effects)
#
# Ante joins this family but is uniquely
# distinguished by its combination of:
#   - Aliasable mutable references (vs Rust's XOR
#     rule)
#   - Abilities-as-unified-traits-and-effects (vs
#     all others which separate them)
#   - Pull-based incremental compilation (vs all
#     others which use push pipelines)
#
# Comparison to other 123rd-language candidates:
#   * Ante (R764 THIS) — Jake Fecher, 2,238 stars,
#     MIT, active, abilities + safe aliasing
#   * Coalton (coalton-lang) — 1,681 stars but
#     embedded in Common Lisp (no standalone binary);
#     fails the "language with own CLI" criterion
#   * Granule (granule-project) — 717 stars but
#     already in corpus as `_gr` + `_grc`
#   * Owl Lisp (owl-lisp/owl) — 383 stars,
#     unmaintained
#   * Onyx (onyx-lang/onyx) — 684 stars, WASM-first
#     lang; strong candidate but more niche
#   * Egel — 84 stars, eager combinator-rewriting
#   * Mlatu — 175 stars, concatenative
#
# Ante is the chosen 123rd-language entry because:
#   - It has a real, installable CLI compiler with
#     rich subcommand-equivalent flags (check/build/
#     release/emit modes + 8 emit targets + 3
#     backends + 6 optimization levels)
#   - The abilities-unification + safe-aliasable-
#     mutation combo is structurally distinct from
#     every prior language entry in the corpus's
#     122 existing slots
#   - 2,238 stars indicates substantial community
#     interest despite "still in a rather early
#     state" disclaimer
#   - The pull-based incremental compiler
#     architecture is itself a teachable example of
#     a non-traditional compiler design — relevant
#     for PL students studying alternatives to push
#     pipelines
#   - Active maintenance by a sole maintainer (Jake
#     Fecher) with consistent commit cadence
#     through 2026
#   - Clean MIT license + clear roadmap at
#     antelang.org/docs/roadmap make it a stable
#     choice for the taxonomy
#
# -----------------------------------------------------------------------------
#
# THE ante CLI
#
# ante is a single-command compiler CLI (no
# subcommands; mode is selected via mutually-
# exclusive flags) built on clap v4 with the derive
# macro + clap_complete for shell-completion
# generation.  Invocation:
#   ante [options] <file...>
#
# Positional arguments:
#   <file...>                         source file paths
#                                     (.an extension by
#                                     convention)
#
# Compile-mode flags (mutually exclusive):
#   -c, --check                       check for errors
#                                     without compiling
#   -b, --build                       build but don't run
#   -r, --release                     build with release
#                                     optimizations
#   -e, --emit <TARGET>               emit intermediate
#                                     representation
#                                     instead of
#                                     executable
#   -d, --delete-binary               delete resulting
#                                     binary after compile
#
# Emit targets (-e):
#   tokens                            lexer output
#   ast                               parse tree
#   ast-r                             parse tree + name
#                                     resolution
#   ast-t                             parse tree + types
#   mir                               Ante MIR
#   mir-tail                          MIR after tail-
#                                     resume optimization
#   mir-mono                          monomorphized MIR
#   ir                                LLVM IR or
#                                     Cranelift IR
#                                     depending on
#                                     --backend
#
# Backends (--backend):
#   cranelift                         debug-only;
#                                     fastest compile
#                                     time
#   llvm                              best optimization;
#                                     requires LLVM
#                                     21.1
#   c                                 portable; emits
#                                     C source
#
# Optimization levels (-O):
#   0                                 no optimization
#                                     (default)
#   1                                 light optimization
#   2                                 normal optimization
#   3                                 aggressive optim.
#   s                                 size-optimized
#   z                                 maximum-size-optim.
#
# Diagnostic flags:
#   -L, --show-lifetimes              print input file
#                                     annotated with
#                                     inferred lifetimes
#   --show-time                       print per-phase
#                                     compilation timings
#   --no-color                        use plain text for
#                                     error locations
#
# Misc:
#   -i, --incremental                 enable incremental
#                                     compilation via
#                                     metadata file
#   --emit-all                        emit all crates
#                                     not just local
#                                     (with -e)
#   --shell-completion <SHELL>        generate shell
#                                     completion script
#                                     (bash | zsh |
#                                     fish | etc.)
#   -h, --help                        show help
#   -V, --version                     show version
#
# Common invocations:
#   # Compile + run hello.an
#   ante hello.an
#
#   # Compile multiple source files
#   ante foo.an bar.an baz.an
#
#   # Type-check only (no codegen)
#   ante --check src/main.an
#   ante -c src/main.an
#
#   # Build binary without running
#   ante --build src/main.an
#   ante -b src/main.an
#
#   # Release build
#   ante --release src/main.an
#   ante -r src/main.an
#
#   # Build with explicit optimization level
#   ante -O3 src/main.an
#   ante -Os src/main.an              # optimize for size
#
#   # Emit LLVM IR for inspection
#   ante --emit ir src/main.an
#   ante -e mir src/main.an
#
#   # Use Cranelift backend (debug; fast compile)
#   ante --backend cranelift src/main.an
#
#   # Emit AST after name resolution
#   ante -e ast-r src/main.an
#
#   # Show inferred lifetimes
#   ante --show-lifetimes src/main.an
#   ante -L src/main.an
#
#   # Profile compilation phases
#   ante --show-time src/main.an
#
#   # Incremental compilation
#   ante -i src/main.an
#   ante --incremental src/main.an
#
#   # Generate zsh completion script
#   ante --shell-completion zsh > _ante
#
# OPTIONS (sourced directly from
# https://github.com/jfecher/ante/blob/main/src/cli.rs):
#
# (See subcommand documentation above for the complete
# flag set.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ante_emit_targets
_ante_emit_targets=(
    'tokens:lexer tokens'
    'ast:parse tree'
    'ast-r:parse tree + name resolution'
    'ast-t:parse tree + types'
    'mir:Ante MIR'
    'mir-tail:MIR after tail-resume optimization'
    'mir-mono:monomorphized MIR'
    'ir:LLVM IR or Cranelift IR'
)

local -a _ante_backends
_ante_backends=(
    'cranelift:fast debug-only backend'
    'llvm:best optimization (requires LLVM 21.1)'
    'c:portable C source emission'
)

local -a _ante_opt_levels
_ante_opt_levels=(
    '0:no optimization (default)'
    '1:light optimization'
    '2:normal optimization'
    '3:aggressive optimization'
    's:size-optimized'
    'z:maximum-size-optimized'
)

local -a _ante_shells
_ante_shells=(
    'bash:Bash shell'
    'zsh:Zsh shell'
    'fish:Fish shell'
    'elvish:Elvish shell'
    'powershell:PowerShell'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)--shell-completion=[generate shell completion script]:shell:->shell' \
    '(-L --show-lifetimes)'{-L,--show-lifetimes}'[print input file annotated with inferred lifetimes]' \
    '(-c --check -b --build -r --release -e --emit -d --delete-binary)'{-c,--check}'[check for errors without compiling]' \
    '(-c --check -b --build -r --release -e --emit -d --delete-binary)'{-b,--build}'[build but do not run]' \
    '(-c --check -b --build -r --release -e --emit -d --delete-binary)'{-r,--release}'[build with release optimizations]' \
    '(-c --check -b --build -r --release -e --emit -d --delete-binary)'{-e,--emit}'=[emit intermediate representation]:target:->emit' \
    '(-c --check -b --build -r --release -e --emit -d --delete-binary)'{-d,--delete-binary}'[delete resulting binary after compiling]' \
    '--emit-all[emit all crates not just local crate]' \
    '--backend=[code generation backend]:backend:->backend' \
    '-O+[optimization level]:level:->optlevel' \
    '--no-color[use plain text for error locations]' \
    '--show-time[print per-phase compilation timings]' \
    '(-i --incremental)'{-i,--incremental}'[enable incremental compilation]' \
    '*:Ante source file:_files -g "*.an"' \
    && ret=0

case $state in
    emit)
        _describe -t emits 'emit target' _ante_emit_targets && ret=0
        ;;
    backend)
        _describe -t backends 'backend' _ante_backends && ret=0
        ;;
    optlevel)
        _describe -t optlevels 'optimization level' _ante_opt_levels && ret=0
        ;;
    shell)
        _describe -t shells 'shell' _ante_shells && ret=0
        ;;
esac

return ret
