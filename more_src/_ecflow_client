#compdef ecflow_client
# Documentation: https://ecflow.readthedocs.io/en/develop/client_api/index.html
# ecflow_client - command line client to communicate with the ecFlow server

local ret=1

_arguments -s -S \
  '(--help)--help[produce help message]' \
  '(--version)--version[show ecflow client version number]' \
  '--host=[server host, defaults to localhost]:host:_hosts' \
  '--port=[server port, defaults to 3141]:port' \
  '--user=[username for server contact, requires --password]:user:_users' \
  '--password=[password for server authentication, requires --user]:password' \
  '--rid=[override ECF_RID, child commands only]:rid' \
  '--ssl[enable SSL for server communication]' \
  '--http[enable HTTP communication between client and server]' \
  '--https[enable HTTPS communication between client and server]' \
  '--debug[display client environment settings and execution details]' \
  '--ping[check if the server is running on the specified host/port]' \
  '--server_version[return the version number of the server]' \
  '--stats[return the server statistics as a string]' \
  '--restart[start job scheduling, communication with jobs, respond to requests]' \
  '--halt[stop server communication with jobs and new job scheduling]' \
  '--shutdown[stop server from scheduling new jobs]' \
  '--terminate[terminate the server]' \
  '--load[check and load definition or checkpoint file into server]:file:_files' \
  '--get[get the suite definition or node tree in re-parseable form]' \
  '--get_state[get state data for the suite definition or individual nodes]' \
  '--replace[replace a node in the server with the given path]' \
  '--delete[delete the specified node(s)]' \
  '--check[check the expression and limits in the server]' \
  '--begin[begin playing the definition in the server]' \
  '--requeue[requeue the specified node(s)]' \
  '--run[ignore triggers, limits, time or date dependencies, just run the task]' \
  '--force[force a node to a given state, or set its event]' \
  '--kill[kill the job associated with the node]' \
  '--status[show the status of a job associated with a task]' \
  '--suspend[suspend the given node]' \
  '--resume[resume the given node]' \
  '--alter[alter the node according to the options]' \
  '--news[return true if state of server definition changed]' \
  '--log[get, clear, flush or create a new log file]' \
  '--order[re-order the nodes held by the server]' \
  '--zombie_get[return the list of zombies from the server]' \
  '--zombie_kill[locate the zombie task and set flags to kill]' \
  '--zombie_adopt[locate the zombie task and set to adopt]' \
  '--reloadwsfile[reload the white list file]' \
  '--check_pt[force or allow server definition persistence to disk]' \
  '*:arg:' && ret=0

return ret
