#compdef agy
# Documentation: https://github.com/google-antigravity/antigravity-cli
# Reference accessed: 2026-05-23
# Verified: https://antigravity.google/docs/cli-overview and agy --version.

# Zsh completion for agy - Google Antigravity CLI (terminal coding agent)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --prompt)'{-p+,--prompt=}'[headless prompt]:prompt:' \
  '(-m --model)'{-m+,--model=}'[model id]:model:' \
  '(-d --directory)'{-d+,--directory=}'[working directory]:directory:_directories' \
  '--output-format[headless output format]:format:(json streaming-json)' \
  '1: :_files' && ret=0

return ret
