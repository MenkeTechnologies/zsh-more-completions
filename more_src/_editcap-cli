#compdef editcap-cli
# _editcap-cli — Wireshark editcap edit/translate captured packets CLI alias (wireshark team, C); custom argparse
# upstream: https://gitlab.com/wireshark/wireshark

_editcap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-a+[frame:comment]:str:' \
        '-A+[start time]:str:' \
        '-B+[end time]:str:' \
        '-c+[packets per file]:n:' \
        '-C+[chop bytes]:str:' \
        '-D+[remove duplicates window]:n:' \
        '-E+[error probability]:str:' \
        '-F+[file format]:f:(pcap pcapng nstrace1 nstrace2 nstrace3 ngsniffer ngsniffer-extended5 logcat-text-brief logcat-text-process logcat-text-tag logcat-text-thread logcat-text-time logcat-text-threadtime logcat-text-long)' \
        '-i+[interval seconds]:n:' \
        '-I+[strip bytes]:n:' \
        '-L+[match all]:str:' \
        '-r[range only]' \
        '-s+[snaplen]:n:' \
        '-S+[time shift]:str:' \
        '-t+[time adjustment]:str:' \
        '-T+[encap type]:str:' \
        '-V[verbose]' \
        '-w+[dup time window]:str:' \
        '--inject-secrets=+[type,file]:str:' \
        '--extract-secrets=+[file]:file:_files' \
        '--discard-all-secrets[discard all secrets]' \
        '--discard-capture-comment[discard comment]' \
        '--capture-comment=+[comment]:str:' \
        '--seed=+[seed]:n:' \
        '--skip-radiotap-header[skip radiotap]' \
        '*:input output:_files -g "*.pcap*"'
}

_editcap-cli "$@"
