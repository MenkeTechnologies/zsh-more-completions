#compdef kueue
# _kueue — Kueue batch queueing controller manager (kubernetes-sigs/kueue)
# upstream: https://github.com/kubernetes-sigs/kueue
# Flags from cmd/kueue/main.go + controller-runtime zap.Options on tip.

_kueue() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[Kueue configuration file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--zap-devel=[enable development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--zap-stacktrace-level=[stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kueue "$@"
