#compdef 3dECM
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dECM.html
# AFNI: eigenvector centrality mapping of voxelwise connectivity

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-full -fecm)-full[full eigenvector centrality computation]' \
  '(-full -fecm)-fecm[fast ECM approximation]' \
  '-thresh[correlation threshold]:r:' \
  '-sparsity[keep only top p% of connections]:p:' \
  '-do_binary[binarize thresholded connections]' \
  '-shift[add shift to correlations]:s:' \
  '-scale[scale correlations]:x:' \
  '-eps[convergence tolerance]:p:' \
  '-max_iter[max power-iteration steps]:i:' \
  '-polort[polynomial detrend order]:m:' \
  '-autoclip[clip out non-brain voxels]' \
  '-automask[create mask from input]' \
  '-mask[mask dataset]:mmm:_files' \
  '-prefix[output dataset prefix]:p:_files' \
  '-memory[gigabytes of memory to use]:G:' \
  '*:dataset:_files' && ret=0

return ret
