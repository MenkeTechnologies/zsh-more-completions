#compdef flagger
# _flagger-cli — Flagger progressive delivery CLI (Flux + Weaveworks, Go); canary deployments on Istio/Linkerd/Nginx
# upstream: https://github.com/fluxcd/flagger

_flagger-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--config+[config file]:file:_files' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--master+[master URL]:url:_urls' \
        '--namespace+[namespace]:namespace:' \
        '--mesh-provider+[mesh provider]:provider:(istio linkerd appmesh contour gloo nginx kuma osm traefik smi)' \
        '--metrics-server+[metrics server]:url:_urls' \
        '--include-label-prefix+[label prefix]:prefix:' \
        '--log-level+[log level]:level:(debug info warn error fatal)' \
        '--port+[port]:port:' \
        '--enable-leader-election[enable leader election]' \
        '--leader-election-namespace+[leader election ns]:ns:' \
        '--cache-resync+[cache resync interval]:duration:' \
        '--threadiness+[threadiness]:n:' \
        '--zap-encoder+[zap log encoder]:encoder:(console json)' \
        '--zap-log-level+[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '*::args:'
}

_flagger-cli "$@"
