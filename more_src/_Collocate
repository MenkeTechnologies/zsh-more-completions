#compdef Collocate
# Documentation: https://github.com/senbox-org/snap-engine/blob/master/snap-collocation/src/main/java/org/esa/snap/collocation/CollocateOp.java
# ESA SNAP gpt Collocate operator - collocate two or more products onto a common grid

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PsourceProductPaths=-[comma-separated list of source product paths]:paths' \
  '-PreferenceProductName=-[name of the reference product]:name' \
  '-PtargetProductName=-[name of the target product]:name' \
  '-PtargetProductType=-[product type string for the target product]:type' \
  '-PcopySecondaryMetadata=-[copy metadata of the secondary products]:bool:(true false)' \
  '-PrenameReferenceComponents=-[rename components of the reference product]:bool:(true false)' \
  '-PrenameSecondaryComponents=-[rename components of the secondary products]:bool:(true false)' \
  '-PreferenceComponentPattern=-[pattern for renaming reference components]:pattern' \
  '-PsecondaryComponentPattern=-[pattern for renaming secondary components]:pattern' \
  '-PresamplingType=-[method to resample secondary grid onto reference grid]:type' \
  '*:source product:_files' && ret=0

return ret
