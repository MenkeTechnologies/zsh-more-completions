#compdef wcsframe
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss206.html
# KAPPA: change the current coordinate Frame in the WCS component of an NDF

local ret=1

_arguments -s \
  'NDF=[NDF whose current Frame is to be modified]:NDF:_files' \
  'FRAME=[the new coordinate Frame]:frame' \
  'EPOCH=[epoch for celestial coordinate systems]:epoch' \
  '*:NDF:_files' && ret=0

return ret
