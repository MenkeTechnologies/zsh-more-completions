#compdef nimph
# Documentation: https://github.com/disruptek/nimph
# nimph - a package manager for the Nim programming language

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(- *)'{-h,--help}'[show help]' \
  '--dry-run[perform a non-destructive evaluation]' \
  '--strict[limit operations to the project dependency tree]' \
  '--git[restrict operations to git repositories]' \
  '--log-level=[set the logging verbosity]:level:(debug info notice warn error fatal none)' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'search:query GitHub for packages'
      'clone:git clone a package into the environment'
      'doctor:evaluate and fix environment issues'
      'path:print the filesystem path to a package'
      'fork:fork an installed dependency to your account'
      'lock:save the current dependency tree to a file'
      'unlock:restore a dependency tree from a file'
      'roll:specify arbitrary package version requirements'
      'upgrade:upgrade dependencies to the latest releases'
      'downgrade:downgrade dependencies to earlier versions'
      'outdated:list dependencies with newer releases'
      'graph:display the dependency tree'
      'run:run a program in dependency roots'
      'refresh:update the official package list'
      'bump:increment version and create a tag'
      'tag:add missing version tags to commits'
      'pull:git pull on dependencies'
      'fetch:git fetch on dependencies'
    )
    _describe -t commands 'nimph command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      path|fork|search|clone)
        _arguments -s '*:package:' && ret=0
        ;;
      lock|unlock)
        _arguments -s '1:lock file:_files' && ret=0
        ;;
      run)
        _arguments -s '*::command:_command_names' && ret=0
        ;;
    esac
    ;;
esac

return ret
