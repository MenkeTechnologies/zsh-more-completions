#compdef codecov-cli
# Documentation: https://github.com/codecov/codecov-cli
# Reference accessed: 2026-05-23
# Verified: codecov-cli docs (see also _codecovcli).

# Zsh completion for codecov-cli - Codecov coverage upload CLI

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'do-upload:upload coverage data'
  'create-commit:notify new commit'
  'create-report:create coverage report'
  'create-report-results:create report results'
  'get-report-results:get report results'
  'send-notifications:send PR notifications'
  'empty-upload:upload empty report'
  'pr-base-picking:select PR base'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--auto-load-params-from=[CI platform]:platform:(github_actions circleci gitlab_ci jenkins bitbucket buildkite drone codebuild semaphore appveyor wercker)' \
  '--codecov-yml-path=[Codecov YAML]:file:_files' \
  '--enterprise-url=[Codecov Enterprise URL]:url:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*:: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'codecov command' subcommands && ret=0
    ;;
esac

return ret
