#compdef telemetrygen
# Documentation: https://github.com/open-telemetry/opentelemetry-collector-contrib/blob/main/cmd/telemetrygen/README.md
# Reference accessed: 2026-05-21
# Verified: upstream README in opentelemetry-collector-contrib/cmd/telemetrygen.

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'traces:generate synthetic OTLP traces'
  'metrics:generate synthetic OTLP metrics'
  'logs:generate synthetic OTLP logs'
  'help:print help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'telemetrygen command' commands && ret=0 ;;
  args)
    _arguments \
      '--otlp-insecure[disable transport security for OTLP]' \
      '--duration=[generation duration (e.g., 5s, inf)]:duration:' \
      '--rate=[generation rate]:rate:' \
      '--timeout=[max wait time]:duration:' \
      '--batch[batch generated telemetry]' \
      '--batch-size=[batch size]:n:' \
      '--traces=[number of traces to generate]:n:' \
      '--metrics=[number of metrics to generate]:n:' \
      '--logs=[number of logs to generate]:n:' && ret=0
    ;;
esac

return ret
