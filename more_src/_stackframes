#compdef stackframes
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss63.html
# SMURF: stack 2d processed frames into time series cube.

local ret=1

_arguments -s -S \
  'IN=[input 2D NDF files]:ndf:_files' \
  'OUT=[output stacked cube NDF]:ndf:_files' \
  'SORT=[time-order sort the frames]:flag:(TRUE FALSE)' \
  'SORTBY=[header item to sort by]:key:' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
