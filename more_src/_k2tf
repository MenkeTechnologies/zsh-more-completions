#compdef k2tf
# Documentation: https://github.com/sl1pm4t/k2tf
# Convert Kubernetes YAML manifests into Terraform HCL

local ret=1

_arguments -s -S \
  '-f[input file or directory]:file:_files' \
  '-o[output file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
