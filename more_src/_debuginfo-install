#compdef debuginfo-install
# Documentation: man debuginfo-install(1)
# Source: rpm-software-management/yum-utils debuginfo-install.py (master) — install debuginfo packages (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--no-debuginfo-plugin[disable automatic yum debuginfo plugin install/update]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-y --assumeyes)'{-y,--assumeyes}'[assume yes for prompts]' \
    '(-c)'{-c+}'[yum config file]:file:_files' \
    '--enablerepo=[enable repository]:repo:_default' \
    '--disablerepo=[disable repository]:repo:_default' \
    '*:package name:_default' \
    && ret=0

return ret
