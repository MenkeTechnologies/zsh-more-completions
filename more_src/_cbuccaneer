#compdef cbuccaneer
# Documentation: https://www.ccp4.ac.uk/html/cbuccaneer.html
# cbuccaneer — automated protein model building from electron density (CCP4)

local ret=1

_arguments -s -S \
  '-mtzin[input work MTZ]:file:_files -g "*.mtz"' \
  '-seqin[input sequence file]:file:_files' \
  '-pdbin[input initial model PDB]:file:_files -g "*.(pdb|ent)"' \
  '-pdbin-mr[MR model PDB]:file:_files -g "*.(pdb|ent)"' \
  '-pdbin-sequence-prior[PDB with known residues]:file:_files -g "*.(pdb|ent)"' \
  '-pdbout[output PDB]:file:_files -g "*.(pdb|ent)"' \
  '-pdbin-ref[reference structure PDB]:file:_files -g "*.(pdb|ent)"' \
  '-mtzin-ref[reference structure MTZ]:file:_files -g "*.mtz"' \
  '-colin-fo[observed F and sigma]:path:' \
  '-colin-hl[HL coefficients]:path:' \
  '-colin-phifom[phase and FOM]:path:' \
  '-colin-fc[initial map coefficients]:path:' \
  '-colin-free[free R set flag]:path:' \
  '-colin-ref-fo[reference F and sigma]:path:' \
  '-colin-ref-hl[reference HL coefficients]:path:' \
  '-find[enable C-alpha finding]' \
  '-grow[enable fragment growing]' \
  '-join[enable fragment joining]' \
  '-link[enable fragment linking]' \
  '-sequence[enable sequencing]' \
  '-correct[enable sequence correction]' \
  '-filter[enable density filtering]' \
  '-ncsbuild[enable NCS building]' \
  '-prune[enable fragment pruning]' \
  '-rebuild[enable side-chain rebuilding]' \
  '-title[job title]:title:' \
  '-resolution[resolution limit]:res:' \
  '-cycles[number of building cycles]:n:' \
  '-fragments[maximum fragment count]:n:' \
  '-fragments-per-100-residues[fragment density]:n:' \
  '-ramachandran-filter[secondary structure type]:type:' \
  '-main-chain-likelihood-radius[main-chain search radius]:r:' \
  '-side-chain-likelihood-radius[side-chain search radius]:r:' \
  '-sequence-reliability[sequence acceptance threshold]:n:' \
  '-new-residue-name[name for built residues]:name:' \
  '-new-residue-type[residue type]:type:' \
  '-fast[use faster methods]' \
  '-anisotropy-correction[correct for anisotropy]' \
  '-build-semet[build selenomethionine]' \
  '-fix-position[preserve input model position]' \
  '-correlation-mode[use correlation target function]' \
  '-known-structure[preserve specified atoms]' \
  '-jobs[CPU count]:n:' \
  '-verbose[verbosity level]:n:' \
  '-stdin[read keywords from standard input]' \
  '*:argument:_files' && ret=0

return ret
