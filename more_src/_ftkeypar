#compdef ftkeypar
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftkeypar.html
# Read a FITS header keyword and write its value to the parameter file

local ret=1

_arguments -s -S \
  'infile=[input FITS file with optional HDU extension]:infile:_files' \
  'keyword=[header keyword to read]:keyword:' \
  'exist=[output: whether keyword was found]:exist:' \
  'value=[output: literal keyword value]:value:' \
  'datatype=[output: keyword data type]:datatype:' \
  'rvalue=[output: real value]:rvalue:' \
  'ivalue=[output: integer value]:ivalue:' \
  'svalue=[output: string value]:svalue:' \
  'bvalue=[output: boolean value]:bvalue:' \
  'comment=[output: keyword comment field]:comment:' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
