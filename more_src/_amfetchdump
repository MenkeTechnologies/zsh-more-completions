#compdef amfetchdump
# _amfetchdump — Zmanda Amanda amfetchdump CLI for selectively retrieving Amanda backup dumps from tape or holding area based on disklist host date level filter spec assembling chunks to disk or stdout (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amfetchdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-p[output to pipe stdout]' \
        '--pipe[output to pipe stdout]' \
        '-c[compress with gzip]' \
        '-O+[directory]:dir:_files -/' \
        '--directory=+[directory]:dir:_files -/' \
        '-l+[label]:str:' \
        '--label=+[label]:str:' \
        '-D+[device]:file:_files' \
        '--device=+[device]:file:_files' \
        '-i+[init]:str:' \
        '-n[no reassemble]' \
        '--no-reassemble[no reassemble]' \
        '-w[wait for tape]' \
        '--wait[wait for tape]' \
        '-s[sort by tape order]' \
        '--sort[sort by tape order]' \
        '-N[restore client-side compress]' \
        '--no-decompress[no decompress]' \
        '-r+[restore-mode]:m:(in-place out-of-place)' \
        '-b+[blocksize]:n:' \
        '-x[extract]' \
        '-o+[option]:str:' \
        '*:config host disk date level:'
}

_amfetchdump "$@"
