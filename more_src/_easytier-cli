#compdef easytier-cli
# Documentation: https://man.archlinux.org/search?q=easytier-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a cmds

_arguments -C -s -S \
  '*-p+[easytier-core RPC portal]:addr:' \
  '-v[Verbose output]' \
  '--verbose[Verbose output]' \
  '*-o+[Output format]:format:(table json)' \
  '*--output=[Output format]:format:(table json)' \
  '--no-trunc[Disable column truncation in tables]' \
  '*-i+[Target instance UUID]:id:' \
  '*--instance-id=[Target instance UUID]:id:' \
  '*-n+[Target instance name]:name:' \
  '*--instance-name=[Target instance name]:name:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    cmds=(
      'peer:Show peers (list, ipv6, list-foreign, list-global-foreign)'
      'connector:Manage connectors (add, remove, list)'
      'mapped-listener:Manage mapped listeners (add, remove, list)'
      'stun:Run STUN diagnostics'
      'route:Show routes (list, dump)'
      'peer-center:Show global peer map'
      'vpn-portal:Show WireGuard portal config'
      'node:Inspect local node (info, config)'
      'service:Manage easytier-core service (install, uninstall, status, start, stop)'
      'proxy:Show TCP/KCP proxy status'
      'acl:ACL statistics (stats)'
      'port-forward:Manage port forward rules (add, remove, list)'
      'whitelist:Manage TCP/UDP whitelists (set-tcp, set-udp, clear-tcp, clear-udp, show)'
      'stats:Statistics (show, prometheus)'
      'logger:Logger (get, set LEVEL)'
      'credential:Temporary credentials (generate, revoke, list)'
      'gen-autocomplete:Print shell completions (bash elvish fish powershell zsh)'
    )
    _describe -t commands 'easytier-cli command' cmds && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
