#compdef fixfiles
# Documentation: man fixfiles(8)
# Source: SELinuxProject/selinux policycoreutils/scripts/fixfiles (main) — relabel mounted filesystems (bash).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '-B[batch (background) mode]' \
    '-N+[only check after a given time]:time:_default' \
    '-C+[compare to previous file_contexts]:prev:_files' \
    '-F[force reset all customizable contexts]' \
    '-f[remove tmp files before restoring]' \
    '-R+[restrict to RPM package]:rpmpkg:_default' \
    '-l+[log file for output]:file:_files' \
    '-v[verbose]' \
    '-M[do not skip mount-tagged paths]' \
    '-T+[number of threads]:N:_default' \
    '1:command:(check restore verify relabel onboot)' \
    '*:path:_files' \
    && ret=0

return ret
