#compdef mindist gmx-mindist
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-mindist.html
# gmx mindist: calculate the minimum distance between two groups

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-od[minimum distance output]:file:_files' \
  '-on[number of contacts output]:file:_files' \
  '-o[generic output file]:file:_files' \
  '-ox[trajectory output]:file:_files' \
  '-or[per-residue minimum distances]:file:_files' \
  '-b[first frame time to read]:time:' \
  '-e[last frame time to read]:time:' \
  '-dt[frame selection interval]:time:' \
  '-tu[time unit]:unit:(fs ps ns us ms s)' \
  '-w[view output files]' \
  '-xvg[XVG plot format]:format:(xmgrace xmgr none)' \
  '-matrix[calculate half matrix of group-group distances]' \
  '-max[calculate maximum instead of minimum distance]' \
  '-d[contact distance threshold]:real:' \
  '-group[count contacts with multiple atoms as one]' \
  '-pi[calculate minimum distance with periodic images]' \
  '-split[split graph at zero time]' \
  '-ng[number of secondary groups]:int:' \
  '-pbc[account for periodic boundary conditions]' \
  '-respertime[write per-residue distances for each timepoint]' \
  '-printresname[include residue names in output]' && ret=0

return ret
