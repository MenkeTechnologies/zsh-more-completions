#compdef josm
# Documentation: https://josm.openstreetmap.de/wiki/Help/CommandLineOptions
# Reference accessed: 2026-05-16
# Verified: upstream JOSM wiki "Command Line Options" page.
# Removed from prior file: fabricated -V/--version (real flag is
# --version only) and bogus man.archlinux.org search URL.

# josm: Java OpenStreetMap Editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--geometry=[window WxH+x+y]:geometry:' \
  '*--download=[download bbox/URL/file]:spec:' \
  '*--downloadgps=[download GPX bbox/URL]:spec:' \
  '--selection=[search string]:query:' \
  '(--no-maximize)--maximize[start maximized]' \
  '(--maximize)--no-maximize[do not start maximized]' \
  '--reset-preferences[reset preferences before start]' \
  '--load-preferences=[load preferences from URL]:url:' \
  '*--set=[set preference key=value]:key=value:' \
  '--language=[language code]:lang:' \
  '--status-report[print status report and exit]' \
  '--debug[debug output]' \
  '--skip-plugins[do not load plugins]' \
  '--offline=[resources to skip in offline mode]:list:' \
  '*:OSM/GPX file:_files -g "*.(osm|osm.bz2|osm.gz|gpx|nmea)(-.)"' && ret=0
return ret
