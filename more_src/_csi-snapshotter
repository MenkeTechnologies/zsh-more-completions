#compdef csi-snapshotter external-snapshotter
# _csi-snapshotter — Kubernetes CSI external-snapshotter sidecar (kubernetes-csi/external-snapshotter)
# upstream: https://github.com/kubernetes-csi/external-snapshotter
# Flags from cmd/csi-snapshotter/main.go + csi-lib-utils/standardflags/flags.go on tip.

_csi-snapshotter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--resync-period=[informer resync interval]:dur:' \
        '--snapshot-name-prefix=[snapshot name prefix]:prefix:' \
        '--snapshot-name-uuid-length=[truncate snapshot UUID to N chars]:n:' \
        '--worker-threads=[concurrent worker threads]:n:' \
        '--timeout=[CSI RPC timeout]:dur:' \
        '--extra-create-metadata[add snapshot metadata to CreateSnapshot parameters]' \
        '--retry-interval-start=[initial retry interval]:dur:' \
        '--retry-interval-max=[max retry interval]:dur:' \
        '--node-deployment[per-node deployment for node-local volumes]' \
        '--groupsnapshot-name-prefix=[VolumeGroupSnapshot name prefix]:prefix:' \
        '--groupsnapshot-name-uuid-length=[truncate group-snapshot UUID to N chars]:n:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '-v[klog verbosity level]:n:'
}

_csi-snapshotter "$@"
