#compdef nhost

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a new Nhost project'
      'up:start local development environment'
      'down:stop local development environment'
      'dev:start development services'
      'deploy:deploy to Nhost cloud'
      'login:authenticate with Nhost'
      'logout:log out from Nhost'
      'list:list projects'
      'link:link local directory to Nhost project'
      'logs:view service logs'
      'run:run Nhost functions locally'
      'secrets:manage project secrets'
      'config:manage configuration'
      'sw:switch between projects'
      'version:show CLI version'
    )
    _describe -t commands 'nhost command' commands && ret=0
    ;;
  args)
    case $line[1] in
      up)
        _arguments \
          '--apply-seeds[apply database seeds]' \
          '--no-browser[do not open browser]' \
          '-p[port]:port' && ret=0
        ;;
      deploy)
        _arguments \
          '--project[project ID]:id' \
          '--branch[branch to deploy]:branch' && ret=0
        ;;
      secrets)
        _arguments '1:action:(create list delete update)' && ret=0
        ;;
      logs)
        _arguments \
          '--service[service name]:service:(auth storage hasura postgres functions)' \
          '-f[follow logs]' && ret=0
        ;;
    esac
    ;;
esac

return ret
