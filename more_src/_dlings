#compdef dlings
# ============================================================================
#  _dlings — dlings: A rustlings clone designed to teach you how to program
#            in D
#
#  Source-direct extraction from
#    https://github.com/iK4tsu/dlings/blob/main/source/app.d
#    https://github.com/andrey-zherikov/argparse (the argparse library)
#
#  Authored by iK4tsu.  24 GH stars.  dlings is the D-language analogue
#  of rustlings — small exercises that teach D programming idioms with
#  a verify/watch loop.  Reads `exercises.toml` to discover exercises +
#  expected outputs.  Sister tools: rustlings (Rust, in corpus), zlings
#  (Zig), pylings (Python), gophercises (Go).
#
#  CLI library taxonomy update: 2nd D CLI library — andrey-zherikov/
#  argparse.  D ecosystem now has 2 documented CLI libraries (R289 +
#  R363 argparse) joining the multi-library leaders.  andrey-zherikov/
#  argparse is the MODERN D CLI library — uses D's USER-DEFINED
#  ATTRIBUTES (UDAs) on struct fields for declarative CLI specs.
#  ~80 GH stars on andrey-zherikov/argparse.
#
#  argparse D API:
#    import argparse;
#
#    @(Command("hint").ShortDescription("Prints the exercise's hint"))
#    struct Hint
#    {
#      @PositionalArgument(0)
#      string exercise;
#    }
#
#    @(Command("run").ShortDescription("Verify a single exercise."))
#    struct Run
#    {
#      @PositionalArgument(0)
#      string exercise;
#    }
#
#    struct DlingsCmdlArgs
#    {
#      @NamedArgument
#      EmojiArgument emoji;
#
#      @NamedArgument
#      auto color = ansiStylingArgument;
#
#      @SubCommands
#      SumType!(Hint, Run, Verify, Watch) cmd;
#    }
#
#    void main(string[] args)
#    {
#      DlingsCmdlArgs cmdlArgs;
#      if (!CLI!DlingsCmdlArgs.parseArgs(cmdlArgs, args[1 .. $]))
#        return;
#      // ... dispatch via cmdlArgs.cmd.match!(...)
#    }
#
#  argparse D distinctive features:
#    - USER-DEFINED ATTRIBUTES (UDAs) on STRUCT FIELDS — D's UDAs
#      are like Rust attributes / Java annotations but with FULL
#      D-LANGUAGE EXPRESSIONS at compile time
#    - `@(Command("name").ShortDescription("X"))` UDA on SUBCOMMAND
#      STRUCT for subcommand registration
#    - `@PositionalArgument(IDX)` UDA on field for POSITIONAL ARGS
#    - `@NamedArgument` UDA on field for FLAG ARGS
#    - `@SubCommands` UDA on `SumType!(A, B, C)` field for VARIANT-
#      BASED subcommand dispatch — uses D's `std.sumtype.SumType`
#      tagged union; caller pattern-matches via `.match!(...)`
#    - `@NamedArgument.Description("X").AllowedValues!(["a", "b"])
#      .NumberOfValues(LO, HI).Parse!(LAMBDA).Action!(LAMBDA)
#      .ActionNoValue!(LAMBDA)` CHAINED UDA MODIFIERS — each method
#      returns a NEW UDA-EXPRESSION with the modifier applied
#    - `CLI!StructType.parseArgs(target, args)` COMPILE-TIME TEMPLATE
#      parse function — `CLI!T` instantiates the parser at compile time
#      for type T; `parseArgs(target, args)` parses argv into target
#    - `alias emoji this` SUBTYPE-ALIAS-THIS — D's struct can act as
#      its single field via `alias FIELD_NAME this`
#  Distinct from R289 D `std.getopt` (stdlib — `getopt(args, "name|n",
#  &dest, "help")` IMPERATIVE METHOD-CHAIN style), R275 Rust clap-derive
#  (Rust struct + proc-macro), R344 google/argh (Rust struct + proc-
#  macro), R338 Odin core:flags (struct tags + RTTI), R322 JCommander
#  (Java field annotations + reflection), R346 mainargs (Scala method
#  annotations).  andrey-zherikov/argparse's approach: D USER-DEFINED
#  ATTRIBUTES (UDAs) on STRUCT FIELDS + `@SubCommands` + `SumType!`
#  TAGGED-UNION DISPATCH + `CLI!T.parseArgs(target, args)` COMPILE-
#  TIME TEMPLATE — corpus's **first documented D-UDA-with-SumType-
#  tagged-union-dispatch CLI pattern**.  Brings cross-language CLI
#  library taxonomy variant count to 102; D ecosystem now has 2
#  documented CLI libraries.
#
#  Surface (verbatim from source/app.d):
#
#  Global flags (on DlingsCmdlArgs struct):
#    --emoji [always|auto|never]    Emoji output (default: auto based
#                                   on NO_EMOJI env var)
#    --color                        ANSI styling (argparse stdlib)
#
#  Subcommands (via @SubCommands SumType! dispatch):
#    hint <exercise>                Print the exercise's hint
#    run <exercise>                 Verify a single exercise
#    verify                         Compile + run all exercises in
#                                   recommended order
#    watch                          Like 'verify' but reruns on file
#                                   modification
#
#  Config file:
#    exercises.toml                 (REQUIRED in cwd) — declares
#                                   exercises + expected outputs
#
#  Dup-skipped neighbors during hunt (smaller surface or unrelated):
#    - andrey-zherikov/argparse demo source files (the library itself)
#    - other D tools probed (D ecosystem is small)
# ============================================================================

_dlings() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '--emoji=[emoji output mode]:mode:(always auto never)' \
    '--color[ANSI styling]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'hint:print the exercise hint'
        'run:verify a single exercise'
        'verify:compile + run all exercises (recommended order)'
        'watch:like verify but reruns on file modification'
      )
      _describe -t commands 'dlings subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        hint|run)
          _message 'exercise name'
          ;;
      esac
      ;;
  esac
}

_dlings "$@"
