#compdef btattach
# _btattach — BlueZ btattach (modern hciattach replacement; attaches a UART HCI transport over a /dev/ttyXXX serial line; -B Bluetooth proto (h4/h5/three-wire/bcsp), -B picks a controller (csr/bcm/intel/etc.), -P set protocol, -S set speed)
# upstream: https://github.com/bluez/bluez (tools/btattach.c)
# Flags from bluez tools/btattach.c on tip.

_btattach() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-B+[Bluetooth transport device]:file:_files -g "/dev/tty*"' \
        '-A+[AMP transport device]:file:_files -g "/dev/tty*"' \
        '-P+[HCI protocol]:proto:(h4 h5 three-wire bcsp ll qca csr intel bcm bcsp)' \
        '-S+[baud]:baud:(9600 19200 38400 57600 115200 230400 460800 921600 1500000 3000000)' \
        '-N[no flow control]' \
        '-T[no tty raw]' \
        '-R[force tty raw]'
}

_btattach "$@"
