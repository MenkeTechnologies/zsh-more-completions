#compdef cling cling-jupyter
# Documentation: https://github.com/root-project/cling/blob/master/include/cling/Interpreter/ClingOptions.td
# Documentation: https://github.com/root-project/cling/blob/master/tools/driver/cling.cpp
# Reference accessed: 2026-05-27
# Verified: upstream ClingOptions.td plus forwarded clang -cc1 driver options

local curcontext="$curcontext" state line ret=1

local -a _std_versions
_std_versions=(
  'c++98:ISO C++ 1998 with amendments'
  'c++03:ISO C++ 2003'
  'c++11:ISO C++ 2011'
  'c++14:ISO C++ 2014'
  'c++17:ISO C++ 2017'
  'c++20:ISO C++ 2020'
  'c++23:ISO C++ 2023'
  'gnu++11:GNU dialect of C++11'
  'gnu++14:GNU dialect of C++14'
  'gnu++17:GNU dialect of C++17'
  'gnu++20:GNU dialect of C++20'
  'gnu++23:GNU dialect of C++23'
)

_arguments -s -S -C \
  '(- *)'{-help,--help}'[print help text]' \
  '(- *)'{-version,--version}'[print compiler version]' \
  '-v[enable verbose output]' \
  '--errorout[do not recover from input errors]' \
  '--nologo[do not show startup banner]' \
  {-noruntime,--noruntime}'[disable runtime support: no null checks, no value printing]' \
  '--ptrcheck[enable injection of pointer validity checks]' \
  '--metastr=-[set the meta command tag, default ".":tag]:tag:' \
  '--metastr+[set the meta command tag, default "."]:tag:' \
  '*-L+[add directory to library search path]:directory:_directories' \
  '*-l+[load library before prompt]:library:' \
  '*-I+[add directory to include search path]:directory:_directories' \
  '*-D+[define macro]:macro[=value]:' \
  '*-U+[undefine macro]:macro:' \
  '-std=-[language standard]:standard:->std' \
  '-stdlib=-[C++ standard library]:stdlib:(libstdc++ libc++)' \
  '-nostdinc[do not search standard system include directories]' \
  '-nostdinc++[do not search standard C++ include directories]' \
  '-nobuiltininc[do not search built-in include directories]' \
  '-fmodules[enable Clang modules]' \
  '-fmodule-name=-[module name]:name:' \
  '-fmodules-cache-path=-[modules cache path]:path:_directories' \
  '-x+[treat input as language type]:language:(c c++ cuda objective-c objective-c++)' \
  '-resource-dir=-[clang resource directory]:dir:_directories' \
  '-isysroot=-[system root for headers and libraries]:sysroot:_directories' \
  '--cuda-path=-[path to CUDA installation]:dir:_directories' \
  '--offload-arch=-[CUDA/HIP offload architecture]:arch:' \
  '--offload-device-only[compile for device only]' \
  '*-Xclang+[pass argument to clang frontend]:arg:' \
  '*-mllvm+[pass argument to LLVM]:arg:' \
  '*:input:_files' && ret=0

case $state in
  (std)
    _describe -t standards 'language standard' _std_versions && ret=0
    ;;
esac

return ret
