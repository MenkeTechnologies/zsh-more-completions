#compdef xmessage
# _xmessage — X11 xmessage (pop up a dialog with a message and a set of buttons; -buttons sets labels (comma list), -default picks initial focus, -nearmouse positions at cursor, -file reads message from file, -print prints picked button, -timeout auto-dismiss seconds)
# upstream: https://gitlab.freedesktop.org/xorg/app/xmessage
# Flags from xmessage src/xmessage.c on tip.

_xmessage() {
    _arguments \
        '-buttons+[button labels comma list]:labels:' \
        '-default+[default button]:label:' \
        '-file+[read message from file]:file:_files' \
        '-nearmouse[position near pointer]' \
        '-center[center on screen]' \
        '-print[print pressed button to stdout]' \
        '-timeout+[auto-dismiss seconds]:seconds:' \
        '*:message:'
}

_xmessage "$@"
