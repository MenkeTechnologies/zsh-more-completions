#compdef ncc
# Documentation: https://github.com/vercel/ncc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for ncc - Vercel's Node.js compiler

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile a .js / .ts file into a single file'
  'run:execute a .js / .ts file without building a file to disk'
  'cache:inspect or clean the cache'
  'help:show help for a subcommand'
  'version:show the ncc version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --version)'{-v,--version}'[show ncc version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ncc command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '(-o --out)'{-o,--out}'[output directory (defaults to dist)]:directory:_files -/' \
          '(-m --minify)'{-m,--minify}'[minify output]' \
          '(-s --source-map)'{-s,--source-map}'[emit a source map]' \
          '--no-source-map-register[do not register source-map-support]' \
          '(-a --asset-builds)'{-a,--asset-builds}'[build nested JS as assets]' \
          '(-e --external)'{-e,--external}'[skip bundling matching package]:module:' \
          '(-q --quiet)'{-q,--quiet}'[disable build summaries / non-error outputs]' \
          '(-w --watch)'{-w,--watch}'[start ncc in watch mode]' \
          '(-t --transpile-only)'{-t,--transpile-only}'[use transpile only mode (no type checks)]' \
          '(-d --debug)'{-d,--debug}'[show debug logs]' \
          '--v8-cache[emit a build using V8 compile cache]' \
          '--license[include licensing information]:file:_files' \
          '--stats-out[write webpack stats to JSON file]:file:_files' \
          '--target[ECMAScript target]:target:(es5 es2015 es2016 es2017 es2018 es2019 es2020 es2021 esnext)' \
          '(-C --no-cache)'{-C,--no-cache}'[skip build cache population]' \
          '1:input file:_files -g "*.(js|ts|cjs|mjs)"' && ret=0
        ;;
      (run)
        _arguments \
          '(-e --external)'{-e,--external}'[skip bundling matching package]:module:' \
          '(-q --quiet)'{-q,--quiet}'[disable build summaries]' \
          '(-t --transpile-only)'{-t,--transpile-only}'[use transpile only mode]' \
          '(-C --no-cache)'{-C,--no-cache}'[skip build cache population]' \
          '1:input file:_files -g "*.(js|ts|cjs|mjs)"' && ret=0
        ;;
      (cache)
        _arguments \
          '1:cache action:(clean dir size)' && ret=0
        ;;
    esac
    ;;
esac

return ret
