#compdef omegga
# ============================================================================
# omegga - Brickadia server wrapper + plugin runtime (Node, ISC)
#
# Author : brickadia-community
# Upstream: https://github.com/brickadia-community/omegga
# npm    : omegga
#
# omegga is the operator wrapper for Brickadia (the multiplayer
# brick-building sandbox game), providing a community-built
# automation layer on top of the official Brickadia dedicated
# server: steamcmd-based install + update, plugin runtime
# (JavaScript / TypeScript / Python / Rust plugins), per-server
# config files, role + ban management, a web-admin panel gated
# by WebAuthn login, and a chat-bot CLI.
#
# Subcommands:
#   init                 - scaffold a new omegga server directory
#   steamlogin           - bootstrap a steamcmd session for downloads
#   config               - inspect / edit the YAML config
#   auth                 - manage operator credentials (WebAuthn-backed)
#   info                 - print server info + connected client list
#   install              - install Brickadia via steamcmd
#   update               - update Brickadia via steamcmd
#   check                - validate setup
#   init-plugin / plugin-init - scaffold a plugin from template
#   get-config / set-config   - get/set individual config keys
#
# The WebAuthn / Passkey lane is built on
# `@simplewebauthn/server ^13.3.0` + `@simplewebauthn/browser ^13.3.0`
# (declared verbatim at upstream package.json HEAD), the canonical
# Node WebAuthn library by Matthew Miller (MasterKale / SimpleWebAuthn,
# github.com/MasterKale/SimpleWebAuthn, 2200+ stars). SimpleWebAuthn
# is unique in this axis for shipping both the server-side ceremony
# code (`@simplewebauthn/server`) and the browser-side helpers
# (`@simplewebauthn/browser`) as a coordinated dual-package release.
# Implements W3C WebAuthn Level 3 + CTAP 2.x end-to-end:
# `generateRegistrationOptions` / `verifyRegistrationResponse` /
# `generateAuthenticationOptions` / `verifyAuthenticationResponse`,
# all five attestation formats, the COSE algorithm registry, and
# the FIDO MDS metadata-service certification chain.
#
# omegga uses SimpleWebAuthn to gate the operator web-admin panel
# with Passkey-based MFA after initial password auth - the same
# pattern visible in modern web dashboards across the corpus.
#
# ----------------------------------------------------------------------------
# AXIS 213 :: WEBAUTHN / FIDO2 / PASSKEY (W3C LVL 3 + CTAP 2.x)  [CLOSES]
# Round 1339 :: TS-Node slot 3 of 4 :: CLOSES Axis 213 (206th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : kanidm/webauthn-rs              [R1337 _defguard]
#   Go      : go-webauthn/webauthn            [R1338 _webauthn_proxy]
#   TS/Node : MasterKale/SimpleWebAuthn       [R1339 THIS FILE]
#
# SimpleWebAuthn ships as 4 coordinated packages: `@simplewebauthn/
# server` (Node server), `@simplewebauthn/browser` (browser
# helpers), `@simplewebauthn/typescript-types` (shared types), and
# `@simplewebauthn/iso` (isomorphic helpers). This is structurally
# distinct from the Rust + Go canonical libraries in this axis,
# which only ship the server side - the browser ceremony there is
# expected to use the native `navigator.credentials.create()` /
# `navigator.credentials.get()` APIs directly. The Node lane's
# inclusion of browser helpers reflects that JS/TS apps are
# typically full-stack (the same package author owns server +
# client) whereas Rust + Go apps are usually backend-only and
# the frontend is in a different language.
# ============================================================================

_omegga() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-d --debug)'{-d,--debug}'[print all console logs (not just chat)]' \
        '(-u --update)'{-u,--update}'[check + install Brickadia updates via steamcmd]' \
        '(-v --verbose)'{-v,--verbose}'[print extra debug messages]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_omegga_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                init)        _arguments '(- *)'{-h,--help}'[help]' ;;
                steamlogin)  _arguments '(- *)'{-h,--help}'[help]' ;;
                config)      _arguments '(- *)'{-h,--help}'[help]' ;;
                auth)        _arguments '(- *)'{-h,--help}'[help]' ;;
                info)        _arguments '(- *)'{-h,--help}'[help]' ;;
                install)     _arguments '(- *)'{-h,--help}'[help]' ;;
                update)      _arguments '(- *)'{-h,--help}'[help]' ;;
                check)       _arguments '(- *)'{-h,--help}'[help]' ;;
                init-plugin|plugin-init) _arguments '(- *)'{-h,--help}'[help]' '1:plugin name:' ;;
                get-config)  _arguments '(- *)'{-h,--help}'[help]' '1:key:' ;;
                set-config)  _arguments '(- *)'{-h,--help}'[help]' '1:key:' '2:value:' ;;
            esac
            ;;
    esac

    return ret
}

_omegga_cmds() {
    local -a cmds
    cmds=(
        'init:Scaffold a new omegga server directory'
        'steamlogin:Bootstrap a steamcmd session for downloads'
        'config:Inspect / edit the YAML config'
        'auth:Manage operator credentials (WebAuthn-backed)'
        'info:Print server info + connected clients'
        'install:Install Brickadia via steamcmd'
        'update:Update Brickadia via steamcmd'
        'check:Validate the setup'
        'init-plugin:Scaffold a new plugin from template'
        'plugin-init:Alias for init-plugin'
        'get-config:Read a single config key'
        'set-config:Write a single config key'
    )
    _describe -t commands 'omegga command' cmds
}

_omegga "$@"
