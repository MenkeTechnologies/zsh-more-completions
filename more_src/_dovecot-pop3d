#compdef dovecot-pop3d dovecot-imapd dovecot-lmtpd dovecot-submission
# _dovecot-pop3d — Dovecot per-service backends (pop3d / imapd / lmtpd / submission daemons launched by dovecot's master process; each accepts only standard Dovecot service flags: -c config file, -F foreground, -p protocol, -o key=value config override, --version, --help; positional arguments are unused — invoked via dovecot.conf service{} blocks)
# upstream: https://github.com/dovecot/core
# Flags from dovecot src/master/master-service.c on tip.

_dovecot-pop3d() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[config file]:file:_files' \
        '-F[foreground]' \
        '-p+[protocol]:proto:(pop3 imap lmtp submission)' \
        '*-o+[KEY=VAL]:setting:'
}

_dovecot-pop3d "$@"
