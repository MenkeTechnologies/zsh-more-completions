#compdef gotd
# Documentation: https://gameoftrees.org/gotd.8.html
# Game of Trees repository server daemon

local ret=1

_arguments -s -S \
  '-d[do not daemonize, send log output to stderr]' \
  '-f[set path to the configuration file]:config file:_files' \
  '-n[configtest mode, only check configuration validity]' \
  '-s[set path to the secrets file]:secrets file:_files' \
  '*-v[verbose mode, repeat to increase verbosity]' && ret=0

return ret
