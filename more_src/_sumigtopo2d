#compdef sumigtopo2d
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/migration_inversion/sumigtopo2d.c
# Kirchhoff Depth Migration of 2D postack/prestack data

local ret=1

_arguments -s -S \
  'infile=[infile]:infile:' \
  'outfile=[outfile]:outfile:' \
  'dt=[dt]:dt:' \
  'ft=[ft]:ft:' \
  'dxm=[dxm]:dxm:' \
  'surf=[surf]:surf:' \
  'fzo=[fzo]:fzo:' \
  'dzo=[dzo]:dzo:' \
  'nzo=[nzo]:nzo:' \
  'fxo=[fxo]:fxo:' \
  'dxo=[dxo]:dxo:' \
  'nxo=[nxo]:nxo:' \
  'off0=[off0]:off0:' \
  'doff=[doff]:doff:' \
  'noff=[noff]:noff:' \
  'fmax=[fmax]:fmax:' \
  'offmax=[offmax]:offmax:' \
  'aperx=[aperx]:aperx:' \
  'angmax=[angmax]:angmax:' \
  'v0=[v0]:v0:' \
  'dvz=[dvz]:dvz:' \
  'ls=[ls]:ls:' \
  'jpfile=[jpfile]:jpfile:' \
  'mtr=[mtr]:mtr:' \
  'ntr=[ntr]:ntr:' \
  '*:file:_files' && ret=0

return ret
