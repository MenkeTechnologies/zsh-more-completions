#compdef s6-svc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u[bring the service up]' \
  '-d[bring the service down]' \
  '-D[bring the service down and remove the down file]' \
  '-U[bring the service up and create the down file]' \
  '-o[send a SIGONCE (run the service once)]' \
  '-O[send a SIGONCE and mark as wanting down]' \
  '-x[exit the supervisor after the service goes down]' \
  '-X[exit the supervisor as soon as possible]' \
  '-r[restart the service]' \
  '-1[send SIGUSR1 to the service]' \
  '-2[send SIGUSR2 to the service]' \
  '-a[send SIGALRM to the service]' \
  '-h[send SIGHUP to the service]' \
  '-i[send SIGINT to the service]' \
  '-q[send SIGQUIT to the service]' \
  '-k[send SIGKILL to the service]' \
  '-t[send SIGTERM to the service]' \
  '-p[send SIGSTOP to the service]' \
  '-c[send SIGCONT to the service]' \
  '-w[wait for service state change]:state:(u d U D r R)' \
  '-T[set timeout for wait]:timeout in milliseconds' \
  '1:service directory:_files -/' && ret=0

return ret
