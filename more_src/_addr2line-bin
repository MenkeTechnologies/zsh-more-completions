#compdef addr2line
# _addr2line-bin — GNU binutils addr2line; map addresses back to source file:line
# upstream: https://sourceware.org/binutils

_addr2line-bin() {
    _arguments \
        '(-b --target)'{-b,--target}'+[BFD target]:target:' \
        '(-C --demangle)'{-C,--demangle}'+[demangle]:style:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '(-e --exe)'{-e,--exe}'+[executable]:file:_files' \
        '(-f --functions)'{-f,--functions}'[show function names]' \
        '(-s --basenames)'{-s,--basenames}'[strip directory]' \
        '(-i --inlines)'{-i,--inlines}'[unwind inline frames]' \
        '(-j --section)'{-j,--section}'+[section]:section:' \
        '(-p --pretty-print)'{-p,--pretty-print}'[pretty print]' \
        '(-a --addresses)'{-a,--addresses}'[show input addresses]' \
        '--llvm[mimic llvm-addr2line]' \
        '--no-recurse-limit[no recursion limit]' \
        '(-H --help)'{-H,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:address:'
}

_addr2line-bin "$@"
