#compdef zookeeper-shell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-server+[ZooKeeper server]:host:port:_hosts' \
  '-r[read-only]' \
  '-readonly[read-only]' \
  '-client-configuration+[client configuration file]:file:_files' \
  '-zk-client-config+[ZK client config]:file:_files' \
  '*:command:(connect close create delete deleteall set get getEphemerals getAcl setAcl ls ls2 stat sync rmr printwatches addauth quit history redo cmd_chk reconfig listquota setquota delquota close addWatch removeWatch whoami)' && ret=0

return ret
