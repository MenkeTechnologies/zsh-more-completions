#compdef transMapPslToGenePred
# UCSC kent: convert PSL alignments of mRNAs to gene annotations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-nonCodingGapFillMax=[fill non-coding gaps up to this many bases]:n:' \
  '-codingGapFillMax=[fill coding gaps up to this many bases]:n:' \
  '-noBlockMerge[don'\''t do any block merging]' \
  '-frameShifts=[write TSV of frame-shifting indel locations]:file:_files' \
  ':source genePred:_files' \
  ':mapped psl:_files' \
  ':mapped genePred:_files' && ret=0

return ret
