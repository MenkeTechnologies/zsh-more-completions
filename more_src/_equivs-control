#compdef equivs-control
# Documentation: https://man.archlinux.org/search?q=equivs-control
# Reference accessed: 2026-05-16

# Zsh completion for equivs-control - Create equivs control file template

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:control file name:_files' && ret=0

return ret
