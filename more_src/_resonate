#compdef resonate
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'serve:start the resonate server'
  'task:manage tasks'
  'promise:manage promises'
  'schedule:manage schedules'
  'lock:manage locks'
  'subscription:manage subscriptions'
  'version:show version information'
)
_arguments -s -S -C \
  '(- *)--help[show help]' \
  '--url=[resonate server URL]:url:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0
case $state in
  command)
    _describe -t commands 'resonate command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '--help[show help]' \
          '--api-url=[API URL]:url:' \
          '--aio-port=[AIO port]:port:' \
          '--api-port=[API port]:port:' && ret=0
        ;;
      promise)
        local -a promise_cmds=(
          'create:create a new promise'
          'resolve:resolve a promise'
          'reject:reject a promise'
          'cancel:cancel a promise'
          'search:search for promises'
          'get:get a promise by ID'
        )
        _arguments -s -S -C \
          '--help[show help]' \
          '1:subcommand:->promise_sub' \
          '*::arg:->promise_args' && ret=0
        case $state in
          promise_sub)
            _describe -t promise_cmds 'promise subcommand' promise_cmds && ret=0
            ;;
        esac
        ;;
      schedule)
        local -a schedule_cmds=(
          'create:create a new schedule'
          'delete:delete a schedule'
          'get:get a schedule by ID'
          'search:search for schedules'
        )
        _arguments -s -S -C \
          '--help[show help]' \
          '1:subcommand:->schedule_sub' \
          '*::arg:->schedule_args' && ret=0
        case $state in
          schedule_sub)
            _describe -t schedule_cmds 'schedule subcommand' schedule_cmds && ret=0
            ;;
        esac
        ;;
      task)
        local -a task_cmds=(
          'create:create a new task'
          'complete:complete a task'
          'claim:claim a task'
          'get:get a task by ID'
        )
        _arguments -s -S -C \
          '--help[show help]' \
          '1:subcommand:->task_sub' \
          '*::arg:->task_args' && ret=0
        case $state in
          task_sub)
            _describe -t task_cmds 'task subcommand' task_cmds && ret=0
            ;;
        esac
        ;;
      lock)
        _arguments -s -S \
          '--help[show help]' \
          '*:args:' && ret=0
        ;;
      subscription)
        _arguments -s -S \
          '--help[show help]' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac
return ret
