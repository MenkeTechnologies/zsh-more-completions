#compdef weston-screenshot
# _weston-screenshot — Weston Wayland weston-screenshot CLI demo client capturing the full output framebuffer of the running weston compositor through the zwp_weston_screenshooter_v1 protocol writing a .png file for screenshots screen recording UI testing automation (Weston team, C); getopt
# upstream: https://gitlab.freedesktop.org/wayland/weston

_weston-screenshot() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-d+[delay sec]:n:' \
        '-o+[output name]:str:' \
        '*:file:_files -g "*.png"'
}

_weston-screenshot "$@"
