#compdef easy_update
# Documentation: https://github.com/fizwit/easy_update
# EasyBuild helper: update exts_list version info in R/Python EasyConfig files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version and exit]' \
  '(-v --verbose)'{-v,--verbose}'[verbose; print lots of extra output]' \
  '--debug[set log level to debug]' \
  '--exts-update[update version info for exts_list in EasyConfig]' \
  '--exts-annotate[annotate all extensions from EasyConfig and dependencies as Markdown]' \
  '--exts-dep-graph[print dependency graph for exts]' \
  '--exts-description[output description for libraries in exts_list]' \
  '--exts-search-cran[output library metadata from CRAN/BioConductor]' \
  '--exts-search-pypi[display library metadata from PyPi]' \
  '*:EasyConfig file:_files -g "*.eb"' && ret=0

return ret
