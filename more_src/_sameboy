#compdef sameboy gambatte gambatte_qt
# Documentation: https://man.archlinux.org/search?q=sameboy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (sameboy)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '*: :_files -g "*.gb *.gbc *.dmg *.cgb *.zip *.7z *.rom"' && ret=0 ;;
  (gambatte|gambatte_qt)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-l --resamplefilter)'{-l+,--resamplefilter=}'[resample filter]:n:(0 1 2)' \
      '(-r --resampler)'{-r+,--resampler=}'[resampler]:n:' \
      '(-s --scale)'{-s+,--scale=}'[scale]:n:' \
      '(-u --upscaler)'{-u+,--upscaler=}'[upscaler]:n:' \
      '(-y --yuv)'{-y,--yuv}'[YUV mode]' \
      '(--gba-cgb)--gba-cgb[GBA-CGB mode]' \
      '(--force-dmg)--force-dmg[force DMG mode]' \
      '(--multicart-compat)--multicart-compat[multicart compat]' \
      '(--full-screen)--full-screen[fullscreen]' \
      '*: :_files -g "*.gb *.gbc *.zip *.7z"' && ret=0 ;;
esac

return ret
