#compdef wxhexeditor

# wxHexEditor: cross-platform wxWidgets hex/disk editor for huge files
# Documentation: https://www.wxhexeditor.org/documentation.php
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:file:_files' && ret=0
return ret
