#compdef wxhexeditor
# Documentation: https://github.com/EUA/wxHexEditor
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: wxHexEditor is a GUI hex editor. README and homepage do not document
# any command-line flags beyond accepting file arguments. -h is the
# wxWidgets-default help switch (built into wxApp::OnInit cmdline parser).

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:file:_files' && ret=0
return ret
