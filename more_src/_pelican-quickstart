#compdef pelican-quickstart

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --path)'{-p,--path=}'[blog directory]:path:_files -/' \
  '(-t --title)'{-t,--title=}'[site title]:title:' \
  '(-a --author)'{-a,--author=}'[author name]:author:' \
  '(-l --lang)'{-l,--lang=}'[default language]:lang:'
