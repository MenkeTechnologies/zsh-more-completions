#compdef crosvm
# Chrome OS virtual machine monitor

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:start a VM'
  'stop:stop all VMs'
  'suspend:suspend a VM'
  'resume:resume a VM'
  'balloon:set balloon size'
  'create_qcow2:create qcow2 disk image'
  'disk:manage disks'
  'snapshot:manage snapshots'
  'usb:manage USB devices'
)

_arguments -s -S \
  '1:command:->command' \
  '--help[show help]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'crosvm command' commands && ret=0
    ;;
esac

return ret
