#compdef tomlq

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-r[output raw strings]' \
  '-R[read raw strings from input]' \
  '-c[compact output]' \
  '-S[sort keys]' \
  '-e[set exit status based on output]' \
  '-j[output as JSON]' \
  '-t[output as TOML]' \
  '-i[edit files in place]' \
  '--arg[pass a string value]:name value:' \
  '--argjson[pass a JSON value]:name value:' \
  '--slurpfile[pass a JSON file]:name file:_files' \
  '--rawfile[pass a raw text file]:name file:_files' \
  '--indent[set indentation level]:level:' \
  '--tab[use tab indentation]' \
  '1:filter expression:' \
  '*:file:_files' && ret=0

return ret
