#compdef kaggle

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'competitions:interact with competitions'
  'datasets:interact with datasets'
  'kernels:interact with kernels'
  'models:interact with models'
  'config:manage configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'kaggle command' commands && ret=0
    ;;
  args)
    case $words[1] in
      competitions)
        local -a comp_cmds=(
          'list:list competitions'
          'files:list competition files'
          'download:download competition files'
          'submit:submit to a competition'
          'submissions:list submissions'
          'leaderboard:get competition leaderboard'
        )
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case $state in
          subcmd) _describe -t commands 'subcommand' comp_cmds && ret=0 ;;
          subargs)
            case $words[1] in
              list)
                _arguments \
                  {-h,--help}'[show help]' \
                  '--group=[search group]:group:(general entered inClass)' \
                  '--category=[category filter]:category:(all featured research recruitment gettingStarted masters playground)' \
                  '--sort-by=[sort field]:sort:(grouped prize earliestDeadline latestDeadline numberOfTeams recentlyCreated)' \
                  '-p+[page number]:page' \
                  '-s+[search term]:search' \
                  '-v[verbose output]' && ret=0
                ;;
              download)
                _arguments \
                  {-h,--help}'[show help]' \
                  '-c+[competition name]:competition' \
                  '-f+[specific file to download]:file' \
                  '-p+[download path]:path:_files -/' \
                  '--force[force download]' \
                  '-q[quiet mode]' && ret=0
                ;;
              submit)
                _arguments \
                  {-h,--help}'[show help]' \
                  '-c+[competition name]:competition' \
                  '-f+[file to submit]:file:_files' \
                  '-m+[submission message]:message' \
                  '-q[quiet mode]' && ret=0
                ;;
              *) _arguments {-h,--help}'[show help]' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      datasets)
        local -a ds_cmds=(
          'list:list datasets'
          'files:list dataset files'
          'download:download dataset files'
          'create:create a new dataset'
          'version:create a new dataset version'
          'init:initialize metadata file'
          'metadata:download metadata'
          'status:check dataset upload status'
        )
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case $state in
          subcmd) _describe -t commands 'subcommand' ds_cmds && ret=0 ;;
          subargs)
            case $words[1] in
              list)
                _arguments \
                  {-h,--help}'[show help]' \
                  '--sort-by=[sort field]:sort:(hottest votes updated active)' \
                  '--size=[size filter]:size:(all small medium large)' \
                  '--file-type=[file type]:type:(all csv sqlite json bigQuery)' \
                  '--license=[license filter]:license:(all cc cc0 gpl other)' \
                  '--tag=[tag filter]:tag' \
                  '-s+[search term]:search' \
                  '-p+[page number]:page' \
                  '--min-size=[minimum size]:size' \
                  '--max-size=[maximum size]:size' \
                  '-v[verbose output]' && ret=0
                ;;
              download)
                _arguments \
                  {-h,--help}'[show help]' \
                  '-d+[dataset owner/name]:dataset' \
                  '-f+[specific file]:file' \
                  '-p+[download path]:path:_files -/' \
                  '--unzip[unzip after download]' \
                  '--force[force download]' \
                  '-q[quiet mode]' && ret=0
                ;;
              *) _arguments {-h,--help}'[show help]' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      kernels)
        local -a kern_cmds=(
          'list:list kernels'
          'init:initialize metadata file'
          'push:push a kernel'
          'pull:pull a kernel'
          'output:download kernel output'
          'status:check kernel status'
        )
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case $state in
          subcmd) _describe -t commands 'subcommand' kern_cmds && ret=0 ;;
          subargs)
            case $words[1] in
              list)
                _arguments \
                  {-h,--help}'[show help]' \
                  '--sort-by=[sort field]:sort:(hotness commentCount dateCreated dateRun scoreAscending scoreDescending relevance voteCount)' \
                  '--language=[language]:lang:(all python r sqlite julia)' \
                  '--kernel-type=[type]:type:(all script notebook)' \
                  '--output-type=[output type]:type:(all visualization data)' \
                  '-s+[search term]:search' \
                  '-p+[page number]:page' \
                  '-v[verbose output]' && ret=0
                ;;
              *) _arguments {-h,--help}'[show help]' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      models)
        local -a model_cmds=(
          'list:list models'
          'get:get model details'
          'init:initialize model metadata'
          'create:create a model'
          'delete:delete a model'
          'update:update a model'
        )
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->subcmd' && ret=0
        case $state in
          subcmd) _describe -t commands 'subcommand' model_cmds && ret=0 ;;
        esac
        ;;
      config)
        local -a config_cmds=(
          'view:view current config'
          'set:set a config value'
          'unset:unset a config value'
        )
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->subcmd' && ret=0
        case $state in
          subcmd) _describe -t commands 'subcommand' config_cmds && ret=0 ;;
        esac
        ;;
    esac
    ;;
esac

return ret
