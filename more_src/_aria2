#compdef aria2

# Zsh completion for aria2 (aria2 wrapper, distinct from aria2c)

_arguments -s -S \
  '(-d --dir)'{-d+,--dir=}'[download directory]:directory:_files -/' \
  '(-o --out)'{-o+,--out=}'[output filename]:filename:' \
  '(-s --split)'{-s+,--split=}'[number of connections per download]:connections:' \
  '(-j --max-concurrent-downloads)'{-j+,--max-concurrent-downloads=}'[max concurrent downloads]:number:' \
  '--max-connection-per-server=[max connections per server]:connections:' \
  '--min-split-size=[min split size]:size:' \
  '(-c --continue)'{-c,--continue}'[continue downloading partially downloaded file]' \
  '(-i --input-file)'{-i+,--input-file=}'[file with download URIs]:input file:_files' \
  '--max-download-limit=[max download speed]:speed:' \
  '--max-upload-limit=[max upload speed]:speed:' \
  '--max-overall-download-limit=[max overall download speed]:speed:' \
  '--max-overall-upload-limit=[max overall upload speed]:speed:' \
  '--file-allocation=[file allocation method]:method:(none prealloc trunc falloc)' \
  '--check-integrity[check file integrity by hash]' \
  '--bt-enable-lpd[enable local peer discovery for BitTorrent]' \
  '--bt-max-peers=[max peers per torrent]:peers:' \
  '--dht-listen-port=[DHT listen port]:port:' \
  '--enable-dht[enable DHT]' \
  '--enable-rpc[enable JSON-RPC/XML-RPC server]' \
  '--rpc-listen-port=[RPC listen port]:port:' \
  '--rpc-listen-all[listen on all interfaces for RPC]' \
  '--rpc-secret=[RPC secret authorization token]:token:' \
  '--seed-ratio=[seed ratio]:ratio:' \
  '--seed-time=[seed time in minutes]:minutes:' \
  '--select-file=[select file indices to download]:indices:' \
  '--follow-torrent=[follow torrent URI]:mode:(true false mem)' \
  '--follow-metalink=[follow metalink]:mode:(true false mem)' \
  '--http-proxy=[HTTP proxy]:proxy url:' \
  '--https-proxy=[HTTPS proxy]:proxy url:' \
  '--all-proxy=[proxy for all protocols]:proxy url:' \
  '--no-proxy=[no proxy domains]:domains:' \
  '--proxy-method=[proxy request method]:method:(get tunnel)' \
  '--http-user=[HTTP username]:username:' \
  '--http-passwd=[HTTP password]:password:' \
  '--ftp-user=[FTP username]:username:' \
  '--ftp-passwd=[FTP password]:password:' \
  '--header=[append header to HTTP request]:header:' \
  '--user-agent=[set user agent]:user agent:' \
  '--referer=[set referer]:url:' \
  '--timeout=[timeout in seconds]:seconds:' \
  '--connect-timeout=[connection timeout in seconds]:seconds:' \
  '--max-tries=[max number of retries]:tries:' \
  '--retry-wait=[seconds to wait between retries]:seconds:' \
  '--daemon[run as daemon]' \
  '--conf-path=[config file path]:config file:_files' \
  '--no-conf[disable loading config file]' \
  '--log=[log file]:log file:_files' \
  '--log-level=[log level]:level:(debug info notice warn error)' \
  '--console-log-level=[console log level]:level:(debug info notice warn error)' \
  '--quiet[quiet mode]' \
  '--human-readable[show file sizes in human readable format]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:URI or file:_files'
