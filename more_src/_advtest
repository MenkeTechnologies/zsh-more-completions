#compdef advtest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/advtest.c
# Source: BlueZ tools/advtest.c — generate LE Resolvable Set Identifier (RSI) advertising data from a 128-bit SIRK.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-i[generate RSI ADV data]:128-bit SIRK:' \
    '(- *)'{-v,--version}'[display version]' \
    && ret=0

return ret
