#compdef stwatchfile
# _stwatchfile — watch a file for content / mtime changes (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stwatchfile/main.go (stdlib flag).

_stwatchfile() {
    _arguments \
        '(- *)-h[show help]' \
        '-period=[sleep period between checks]:duration:' \
        '1:file:_files'
}

_stwatchfile "$@"
