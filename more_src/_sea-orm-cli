#compdef sea-orm-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:generate entity files from database'
      'migrate:migration operations'
    )
    _describe -t commands 'sea-orm-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(entity)' \
          '*::arg:->gen_args' && ret=0
        case $state in
          gen_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '-u+[database URL]:url:' \
              '--database-url=[database URL]:url:' \
              '-s+[database schema]:schema:' \
              '--database-schema=[database schema]:schema:' \
              '-o+[output directory]:directory:_directories' \
              '--output-dir=[output directory]:directory:_directories' \
              '--include-hidden-tables[include hidden tables]' \
              '--compact-format[generate compact format]' \
              '--expanded-format[generate expanded format]' \
              '-t+[tables to generate]:tables:' \
              '--tables=[tables to generate]:tables:' \
              '--ignore-tables=[tables to ignore]:tables:' \
              '--with-serde=[derive serde traits]:mode:(none serialize deserialize both)' \
              '--serde-skip-deserializing-primary-key[skip deserializing primary key]' \
              '--serde-skip-hidden-column[skip hidden column in serde]' \
              '--with-copy-enums[derive Copy for enums]' \
              '--date-time-crate=[date time crate]:crate:(chrono time)' \
              '--lib[generate lib.rs instead of mod.rs]' \
              '--model-extra-derives=[extra derives for model]:derives:' \
              '--model-extra-attributes=[extra attributes for model]:attributes:' && ret=0
            ;;
        esac
        ;;
      migrate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-d+[migration directory]:directory:_directories' \
          '--migration-dir=[migration directory]:directory:_directories' \
          '1:subcommand:->migrate_cmds' && ret=0
        case $state in
          migrate_cmds)
            local -a migrate_commands=(
              'init:initialize migration directory'
              'generate:generate a new migration file'
              'up:apply pending migrations'
              'down:rollback applied migrations'
              'status:check migration status'
              'fresh:drop all tables and reapply migrations'
              'refresh:rollback all and reapply migrations'
              'reset:rollback all applied migrations'
            )
            _describe -t commands 'migrate subcommand' migrate_commands && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
