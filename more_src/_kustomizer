#compdef kustomizer

local -a commands
commands=(
  'apply:apply artifacts from OCI'
  'build:build kustomization'
  'diff:diff live cluster state'
  'inspect:inspect OCI artifact'
  'pull:pull artifact from registry'
  'push:push artifact to registry'
  'tag:tag artifact'
  'version:print version'
)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    _describe -t commands command commands && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
