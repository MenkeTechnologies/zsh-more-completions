  '-v[show version]' \
  '-aa[automatic answer ACK]' \
  '-base_cseq+[base CSeq]:n:' \
  '-bg[background]' \
  '-bind_local[bind local addr]' \
  '-buff_size+[buffer size]:n:' \
  '-call_id_slash_check[CRLF check]' \
  '-cid_str+[Call-ID string]:s:' \
  '-ci+[control ip]:ip:' \
  '-cp+[control port]:port:' \
  '-d+[default scenario duration ms]:ms:' \
  '-deadcall_wait+[dead call wait]:ms:' \
  '-default_behaviors+[behaviors]:b:' \
  '-error_file+[error file]:file:_files' \
  '-error_overwrite+[overwrite]:b:(true false)' \
  '-f+[stat report period]:ms:' \
  '-fd+[freq dump]:ms:' \
  '-i+[local IP]:ip:' \
  '-inf+[CSV input file]:file:_files' \
  '-infindex+[index field]:n:' \
  '-ip_field+[ip field]:n:' \
  '-l+[max simul calls]:n:' \
  '-log_file+[log file]:file:_files' \
  '-screen_file+[screen output file]:file:_files' \
  '-stf+[stat file]:file:_files' \
  '-stat_delimiter+[stat delimiter]:s:' \
  '-trace_calldebug[trace call debug]' \
  '-trace_err[trace error]' \
  '-trace_msg[trace messages]' \
  '-trace_screen[trace screen]' \
  '-trace_logs[trace logs]' \
  '-trace_shortmsg[trace short msg]' \
  '-trace_stat[trace stats]' \
  '-trace_rtt[trace RTT]' \
  '-trace_timeout[trace timeout]' \
  '-trace_rtt[trace rtt]' \
  '-mc[message dump]' \
  '-mi+[media local IP]:ip:' \
