  '-master+[master id]:id:' \
  '-slave+[slave id]:id:' \
  '-slave_cfg+[slave config]:file:_files' \
  '-max_recv_loops+[max recv loops]:n:' \
  '-max_socket+[max socket]:n:' \
  '-mb+[max buffer]:n:' \
  '-min_rtp_port+[min RTP port]:port:' \
  '-max_rtp_port+[max RTP port]:port:' \
  '-min_socket+[min socket]:n:' \
  '-no_call_id_check[no Call-ID check]' \
  '-nostdin[no stdin]' \
  '-nr[no retransmit]' \
  '-nd[default behavior off]' \
  '-p+[local port]:port:' \
  '-pause_msg_ign[pause msg ignore]' \
  '-r+[call rate]:n:' \
  '-rp+[rate period ms]:ms:' \
  '-rate_increase+[rate increase]:n:' \
  '-rate_max+[max rate]:n:' \
  '-rate_scope+[rate scope]:s:(call message)' \
  '-recv_timeout+[recv timeout ms]:ms:' \
  '-send_timeout+[send timeout ms]:ms:' \
  '-reconnect_close+[close connection]:b:(true false)' \
  '-reconnect_sleep+[reconnect sleep ms]:ms:' \
  '-ringbuffer_files+[log ringbuf files]:n:' \
