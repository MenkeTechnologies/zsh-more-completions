#compdef sipp
# Documentation: https://github.com/SIPp/sipp/blob/master/src/sipp.cpp
# Reference accessed: 2026-05-21
# Verified: upstream src/sipp.cpp options_table[].
# Removed from prior file: -no_call_id_check, -call_id_slash_check
# (real flag is -callid_slash_ign), -T (no such flag), -trace_timeout
# (commented out in source), -stat_format (does not exist), duplicate
# -trace_rtt entry, -error_overwrite as (true false) (it is LFOVERWRITE),
# -reconnect_close as (true false) (it is BOOL but values are not
# enumerated upstream).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-v[display version and copyright]' \
  '-bg[launch in background mode]' \
  '-nostdin[disable stdin]' \
  '-plugin+[load a plugin]:plugin file:_files' \
  '-sleep+[sleep at startup (default unit seconds)]:duration:' \
  '-skip_rlimit[skip rlimit tuning of fd limits]' \
  '-buff_size+[send/receive buffer size]:n:' \
  '-sendbuffer_warn+[warn instead of error on SendBuffer failures]:b:' \
  '-lost+[default packet loss percentage]:f:' \
  '-key+[set generic parameter keyword to value]:keyword value:' \
  '-set+[set global variable]:variable value:' \
  '-tdmmap+[TDM circuit map: {0-3}{99}{5-8}{1-31}]:map:' \
  '-dynamicStart+[start offset of dynamic_id variable]:n:' \
  '-dynamicMax+[maximum of dynamic_id variable]:n:' \
  '-dynamicStep+[increment of dynamic_id variable]:n:' \
  '-aa[automatic 200 OK for INFO/NOTIFY/OPTIONS/UPDATE]' \
  '-base_cseq+[start value of [cseq]]:n:' \
  '-cid_str+[Call-ID string (default %u-%p@%s)]:s:' \
  '-d+[default scenario duration ms]:ms:' \
  '-deadcall_wait+[dead call retention time ms]:ms:' \
  '-auth_uri+[force URI for authentication]:uri:' \
  '-au+[authorization username]:user:' \
  '-ap+[authorization password]:pass:' \
  '-s+[request URI username (default service)]:s:' \
  '-default_behaviors+[default behaviors (all|none|bye|abortunexp|pingreply|cseq)]:b:' \
  '-nd[disable all default behaviors]' \
  '-pause_msg_ign[ignore messages during scenario pauses]' \
  '-callid_slash_ign[do not treat triple-slash in Call-ID as SIPp prefix]' \
  '-rxinf+[RX-side CSV input file]:file:_files' \
  '-inf+[CSV input file]:file:_files' \
  '-infindex+[create index on inf file field]:file field:' \
  '-ip_field+[injection-file field carrying local IP]:n:' \
  '-mi+[local media IP]:ip:' \
  '-mb+[RTP echo buffer size]:n:' \
  '-mp+[deprecated alias for -min_rtp_port]:port:' \
  '-min_rtp_port+[min RTP socket port]:port:' \
  '-max_rtp_port+[max RTP socket port]:port:' \
  '-rtp_echo[enable RTP echo]' \
  '-rtp_payload+[default RTP payload type]:n:' \
  '-rtp_threadtasks+[RTP playback tasks per thread]:n:' \
  '-rtp_buffsize+[RTP socket buffer size]:n:' \
  '-rtpcheck_debug[write RTP check debug to file]' \
  '-srtpcheck_debug[write SRTP check debug to file]' \
  '-audiotolerance+[audio error tolerance 0.0-1.0]:f:' \
  '-videotolerance+[video error tolerance 0.0-1.0]:f:' \
  '-random_base_ssrc[use random base SSRC]' \
  '-r+[call rate (cps)]:n:' \
  '-rp+[rate period ms]:ms:' \
  '-rate_scale+[unit scale for +/-/*// keys]:f:' \
  '-rate_increase+[rate increase per interval]:n:' \
  '-rate_max+[stop after rate reaches this]:n:' \
  '-rate_interval+[rate increase interval]:dur:' \
  '-no_rate_quit[do not quit after rate_max]' \
  '-l+[max simultaneous calls]:n:' \
  '-m+[stop after this many calls]:n:' \
  '-users+[fixed user count instead of rate]:n:' \
  '-recv_timeout+[global receive timeout ms]:ms:' \
  '-send_timeout+[global send timeout ms]:ms:' \
  '-timeout+[global timeout (default unit seconds)]:dur:' \
  '-timeout_error[fail SIPp on global timeout]' \
  '-max_retrans+[max UDP retransmissions]:n:' \
  '-max_invite_retrans+[max UDP retransmits for INVITE]:n:' \
  '-max_non_invite_retrans+[max UDP retransmits for non-INVITE]:n:' \
  '-nr[disable UDP retransmissions]' \
  '-rtcheck+[retransmission detection method]:method:(full loose)' \
  '-T2+[global T2 timer ms]:ms:' \
  '-3pcc+[third-party call control IP:port]:addr:' \
  '-master+[3pcc extended master number]:id:' \
  '-slave+[3pcc extended slave number]:id:' \
  '-slave_cfg+[3pcc extended master/slave config file]:file:_files' \
  '-timer_resol+[timer resolution ms]:ms:' \
  '-max_recv_loops+[max messages per recv cycle]:n:' \
  '-max_sched_loops+[max calls per scheduler loop]:n:' \
  '-watchdog_interval+[watchdog interval ms]:ms:' \
  '-watchdog_reset+[watchdog counters reset interval ms]:ms:' \
  '-watchdog_minor_threshold+[minor watchdog threshold ms]:ms:' \
  '-watchdog_major_threshold+[major watchdog threshold ms]:ms:' \
  '-watchdog_minor_maxtriggers+[minor watchdog max trips]:n:' \
  '-watchdog_major_maxtriggers+[major watchdog max trips]:n:' \
  '-f+[on-screen stats report period sec]:s:' \
  '-trace_stat[dump all statistics to CSV]' \
  '-stat_delimiter+[statistics CSV delimiter]:s:' \
  '-stf+[statistics dump file name]:file:_files' \
  '-fd+[dump-log report frequency sec]:s:' \
  '-rfc3339[use timestamps in RFC3339 format]' \
  '-periodic_rtd[reset response-time partitions each log interval]' \
  '-trace_msg[log SIP messages to _messages.log]' \
  '-message_file+[messages log file name]:file:_files' \
  '-message_overwrite+[overwrite messages log file]:b:' \
  '-trace_shortmsg[log SIP messages as CSV to _shortmessages.log]' \
  '-shortmessage_file+[shortmessage log file name]:file:_files' \
  '-shortmessage_overwrite+[overwrite shortmessage log file]:b:' \
  '-trace_counts[dump per-message counts to CSV]' \
  '-trace_err[trace unexpected messages to _errors.log]' \
  '-error_file+[error log file name]:file:_files' \
  '-error_overwrite+[overwrite error log file]:b:' \
  '-trace_error_codes[dump SIP response codes of unexpected msgs]' \
  '-trace_calldebug[dump aborted-call debug to _calldebug.log]' \
  '-calldebug_file+[call debug file name]:file:_files' \
  '-calldebug_overwrite+[overwrite call debug file]:b:' \
  '-trace_screen[dump screen stats to _screens.log on exit]' \
  '-screen_file+[screen log file name]:file:_files' \
  '-screen_overwrite+[overwrite screen log file]:b:' \
  '-trace_rtt[trace response times to _rtt.csv]' \
  '-rtt_freq+[dump RTT every N calls]:n:' \
  '-trace_logs[trace <log> actions to _logs.log]' \
  '-log_file+[log actions log file name]:file:_files' \
  '-log_overwrite+[overwrite log actions log file]:b:' \
  '-ringbuffer_files+[number of rotated log files to keep]:n:' \
  '-ringbuffer_size+[ring-buffer max file size bytes]:n:' \
  '-max_log_size+[max log file size bytes]:n:' \
  '-max_socket+[max simultaneously open sockets]:n:' \
  '-max_reconnect+[max reconnections]:n:' \
  '-reconnect_close+[close calls on reconnect]:b:' \
  '-reconnect_sleep+[ms to sleep between close and reconnect]:ms:' \
  '-rsa+[remote sending address host:port]:addr:' \
  '-tls_cert+[TLS certificate file (default cacert.pem)]:file:_files' \
  '-tls_key+[TLS private key file (default cakey.pem)]:file:_files' \
  '-tls_ca+[TLS CA file]:file:_files' \
  '-tls_crl+[TLS CRL file]:file:_files' \
  '-tls_version+[TLS protocol version]:ver:(1.0 1.1 1.2 1.3)' \
  '-i+[local IP for Contact/Via/From]:ip:' \
  '-p+[local port]:port:' \
  '-ci+[local control IP]:ip:' \
  '-cp+[local control port (default 8888)]:port:' \
  '-bind_local[bind socket to local IP]' \
  '-t+[transport mode]:t:(u1 un ui t1 tn l1 ln s1 sn)' \
  '-sd+[dump default scenario]:s:' \
  '-sf+[scenario file]:file:_files -g "*.xml"' \
  '-rxsf+[receive-side scenario file]:file:_files -g "*.xml"' \
  '-oocsf+[out-of-call scenario file]:file:_files -g "*.xml"' \
  '-oocsn+[out-of-call scenario name]:s:' \
  '-sn+[builtin scenario]:s:(uac uas regexp branchc branchs 3pcc-C-A 3pcc-C-B 3pcc-A 3pcc-B)' \
  '-rxrn+[receive-side builtin scenario]:s:' \
  '*: :' && ret=0

return ret
