#compdef dynamic
# Documentation: https://dasher.wustl.edu/tinker/distribution/doc/sphinx/tinker/_build/html/text/special-features.html
# Tinker: perform NVE, NVT, NPT or NPH molecular dynamics

local ret=1

_arguments -s -S \
  '(-k -key -keyfile)'{-k,-key,-keyfile}'[keyfile to use for the calculation]:keyfile:_files -g "*.key"' \
  '*:Tinker xyz file:_files -g "*.xyz"' && ret=0

return ret
