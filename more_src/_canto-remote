#compdef canto-remote

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'addfeed:add a feed URL'
  'delfeed:remove a feed URL'
  'listfeeds:list all configured feeds'
  'force-update:force an update of one or all feeds'
  'one-config:retrieve one config option'
  'config:list/set config options'
  'help:show help'
  'kill:tell daemon to exit'
  'export:export feed URLs to OPML'
  'import:import feeds from OPML'
  'script:script daemon (advanced)'
  'status:get daemon status'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --dir)'{-D,--dir}'+[config directory]:dir:_files -/' \
  '(-a --address)'{-a,--address}'+[daemon address]:addr:' \
  '(-p --port)'{-p,--port}'+[daemon port]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'canto-remote command' commands && ret=0 ;;
esac

return ret
