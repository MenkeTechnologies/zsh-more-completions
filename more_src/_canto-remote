#compdef canto-remote
# Documentation: https://github.com/themoken/canto-next
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'addfeed:subscribe to a feed (with optional username/password/name)'
  'delfeed:unsubscribe from a feed (by name or index)'
  'listfeeds:list all subscribed feeds'
  'force-update:refetch all feeds regardless of timestamps'
  'one-config:change a single configuration variable'
  'config:list/set config options'
  'help:get help on a specific command'
  'kill:terminate the connected daemon'
  'export:write an OPML formatted list of feeds to stdout'
  'import:import an OPML formatted list of feeds from stdin'
  'script:run testing code (advanced)'
  'status:display unread item counts'
)

_arguments -C \
  '(- *)'{-h,--help}'[print usage help]' \
  '(- *)-V[print version info and exit]' \
  '(-D --dir)'{-D,--dir}'+[change base directory for canto-daemon]:dir:_files -/' \
  '--noplugins[disable all plugins]' \
  '--enableplugins=[enable these plugins]:plugins:' \
  '--disableplugins=[disable these plugins]:plugins:' \
  '(-a --address)'{-a,--address}'+[connect to IP instead of local Unix socket]:addr:' \
  '(-p --port)'{-p,--port}'+[port for -a connection]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'canto-remote command' commands && ret=0 ;;
esac

return ret
