#compdef corosync-cfgtool

# corosync-cfgtool: corosync configuration utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[show ring status]' \
  '-R[reload corosync.conf]' \
  '-r[reset redundant ring statistics]' \
  '-k[kill node]:nodeid:' \
  '-K[kill a node by node id]:nodeid:' \
  '-a[show all addresses for ring]' \
  '-i[show IP addresses on rings]' \
  '-b[show interface stats]' \
  '*::corosync-cfgtool args:_files' && ret=0
return ret
