#compdef corosync-cfgtool

# corosync-cfgtool: corosync runtime configuration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-s[show ring status (signed)]' \
  '-r[reset ring]' \
  '-R[reload corosync config]' \
  '-L[list services loaded]' \
  '-k[shutdown nodeid]:nodeid:' \
  '-a[show IP addresses by nodeid]:nodeid:' \
  '-i[show address ring info]:nodeid:' \
  '-H[shutdown corosync]' \
  '-b[brief output]' \
  '*::corosync-cfgtool args:_files' && ret=0
return ret
