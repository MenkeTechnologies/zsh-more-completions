#compdef corosync-cfgtool
# Documentation: https://manpages.debian.org/testing/corosync/corosync-cfgtool.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[show link status with node details]' \
  '-b[show brief link status]' \
  '-n[show node status and link configuration]' \
  '-R[instruct all corosync instances to reload configuration]' \
  '-L[tell corosync to reopen all logging files]' \
  '-k+[kill a node by node id]:nodeid:' \
  '-a+[display IP addresses of a node]:nodeid:' \
  '-i+[filter by interface IP address or link id]:address or link id:' \
  '-H[clean corosync shutdown]' \
  '--force[force shutdown (used with -H)]' \
  '*::corosync-cfgtool args:_files' && ret=0
return ret
