#compdef cargo-doc
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-doc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cargo doc: build a package's documentation.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --package)'{-p+,--package=}'[package to document]:package' \
  '--all[deprecated alias for --workspace]' \
  '--workspace[document all packages in workspace]' \
  '*--exclude=[exclude packages]:package' \
  '--lib[document only library]' \
  '--bin=[document only specified binary]:binary' \
  '--bins[document all binaries]' \
  '--example=[document only specified example]:example' \
  '--examples[document all examples]' \
  '--no-deps[do not document dependencies]' \
  '--document-private-items[document private items]' \
  '--open[open docs in browser after building]' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:jobs' \
  '--keep-going[keep going on failures]' \
  '(-F --features)'{-F+,--features=}'[features to activate]:features' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '*--target=[target triple]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--ignore-rust-version[ignore rust-version specification]' \
  '--message-format=[diagnostic format]:format:(human short json json-diagnostic-short json-diagnostic-rendered-ansi json-render-diagnostics)' \
  '(-r --release)'{-r,--release}'[build in release mode]' \
  '--profile=[build with specified profile]:profile' \
  '--timings=[output build timing info]:format:(html json)' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '*'{-v,--verbose}'[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[--locked + --offline]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
  '*-Z+[unstable cargo flag]:flag'
