#compdef comet-cli comet2 comet_ml
# _comet-cli — Comet comet-cli CLI command-line frontend wrapping the Comet ML experiment tracking visualization optimization model-registry platform managing experiments projects workspaces models datasets artifacts panels reports optimizer hyperparameter-search check init upload offline sync (Comet team, Python); click
# upstream: https://www.comet.com/

_comet-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'init:initialize a project'
        'check:check setup'
        'upload:upload offline experiments'
        'sync:sync offline runs'
        'workspace:workspace operations'
        'project:project operations'
        'experiment:experiment operations'
        'model:model registry operations'
        'dataset:dataset operations'
        'artifact:artifact operations'
        'panel:panel operations'
        'report:report operations'
        'optimizer:optimizer operations'
        'autolog:autolog operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--workspace=+[name]:str:' \
        '--project=+[name]:str:' \
        '--experiment=+[name]:str:' \
        '--url-override=+[url]:str:' \
        '--api-url-override=+[url]:str:' \
        '--offline-directory=+[dir]:dir:_files -/' \
        '--rest-api-key=+[key]:str:' \
        '--auto-log-co2=+[bool]:s:(true false)' \
        '--auto-log-figures=+[bool]:s:(true false)' \
        '--auto-log-disable=+[bool]:s:(true false)' \
        '-c+[config file]:file:_files -g "*.config *.cfg *.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.config *.cfg *.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'comet-cli subcommand' sub ;;
        args)
            case $words[1] in
                workspace|project|experiment|model|dataset|artifact|panel|report|optimizer) _arguments '1:op:(list get create update delete download upload log archive restore)' '*:id:' ;;
                upload) _arguments '*:directory:_files -/' ;;
            esac
            ;;
    esac
}

_comet-cli "$@"
