#compdef ctfplotter
# Documentation: https://bio3d.colorado.edu/imod/doc/man/ctfplotter.html
# ctfplotter - plot and fit the CTF of a tilt series to estimate defocus

local ret=1

_arguments -s -S \
  '(-input)-input[input image stack to analyze]:file:_files' \
  '(-offset)-offset[mean value that data should be offset to]:value' \
  '(-config)-config[text file specifying the configuration]:file:_files' \
  '(-angleFn)-angleFn[file containing tilt angles for the input stack]:file:_files' \
  '(-single)-single[treat the input as a single tilted image]:angle' \
  '(-invert)-invert[invert the sign of the tilt angles]' \
  '(-taOffset)-taOffset[amount to add to entered tilt angles]:value' \
  '(-aAngle)-aAngle[how much the tilt axis deviates from vertical]:angle' \
  '(-defFn)-defFn[file to store found defocuses (required)]:file:_files' \
  '(-pixelSize)-pixelSize[image pixel size in nanometers]:size' \
  '(-crop)-crop[crop power spectrum to the given pixel size]:size' \
  '(-fitZeros)-fitZeros[find and fit to zero positions when finding phase]' \
  '(-volt)-volt[microscope voltage in kV (required)]:voltage' \
  '(-cs)-cs[microscope spherical aberration in millimeters]:value' \
  '(-ampContrast)-ampContrast[fraction of amplitude contrast]:fraction' \
  '(-degPhase)-degPhase[expected phase shift value in degrees]:degrees' \
  '(-phase)-phase[expected phase shift value]:value' \
  '(-phRange)-phRange[total range of phase shift to search]:range' \
  '(-cuton)-cuton[fixed value for cut-on frequency]:frequency' \
  '(-maxCuton)-maxCuton[maximum frequency to test for cut-on]:frequency' \
  '(-skip)-skip[list of views to leave out of the analysis]:views' \
  '(-bidir)-bidir[number of views in the first half of a bidir series]:count' \
  '(-onlyAP)-onlyAP[skip views in the skip list]' \
  '(-expDef)-expDef[expected defocus at the tilt axis in nanometers]:defocus' \
  '(-scan)-scan[lower and upper defocus values of range to scan]:low,high' \
  '(-tune)-tune[adjust fitting range and spectrum cropping]' \
  '(-assess)-assess[estimate the tilt angle offset on startup]' \
  '(-testInv)-testInv[test for inverted handedness]:value' \
  '(-fpOffset)-fpOffset[focus pair offset]:value' \
  '(-range)-range[range to fit when autofit is not used]:low,high' \
  '(-autoFit)-autoFit[do initial autofitting over the whole tilt series]:step,inc' \
  '(-more)-more[higher number of views to fit above an angle]:value' \
  '(-useDef)-useDef[use the expected defocus value at each angle]' \
  '(-frequency)-frequency[starting and ending frequencies of fitting range]:start,end' \
  '(-extra)-extra[extend the ending frequency of the fitting range]:value' \
  '(-truncate)-truncate[control weighting of some frequencies]:value' \
  '(-vary)-vary[vary exponent of CTF function when fitting]' \
  '(-baseline)-baseline[control baseline fitting]:value' \
  '(-find)-find[find astigmatism, phase, and/or cut-on]:three ints' \
  '(-sAstig)-sAstig[search for astigmatism when fitting]' \
  '(-sPhase)-sPhase[search for phase shift when fitting]' \
  '(-sCuton)-sCuton[search for cut-on frequency when finding phase]' \
  '(-minViews)-minViews[minimum views for finding astigmatism and phase]:two ints' \
  '(-save)-save[save and exit after autofitting]' \
  '(-png)-png[save a PNG image when saving and exiting]:value' \
  '(-tiff)-tiff[save a TIFF image when saving and exiting]:value' \
  '(-snap)-snap[name of file for saving the graph]:file:_files' \
  '(-psRes)-psRes[number of points over which CTF is computed]:count' \
  '(-tileSize)-tileSize[tile size for computing spectra]:size' \
  '(-defTol)-defTol[defocus tolerance defining the strip width]:value' \
  '(-leftTol)-leftTol[defocus tolerance for strips to the left]:value' \
  '(-rightTol)-rightTol[defocus tolerance for strips to the right]:value' \
  '(-cache)-cache[use a cache to speed up computation]:value' \
  '(-hyper)-hyper[ratio of cached spectra points to computed ones]:value' \
  '(-sectors)-sectors[number of sectors for astigmatism analysis]:count' \
  '(-wedge)-wedge[initial angular range and interval]:range,interval' \
  '(-astigMax)-astigMax[maximum astigmatism in microns]:value' \
  '(-ignore)-ignore[skip reading a ctfplotter.info file]' \
  '(-hideTest)-hideTest[hide the left-right difference test button]' \
  '(-colors)-colors[use colors better for color-blindness]' \
  '(-legacy)-legacy[include legacy polynomial fitting options]' \
  '(-dump)-dump[list of wedge spectra to print out]:list' \
  '(-debug)-debug[debug level 0-3]:level' \
  '(-param)-param[read parameter entries from this file]:file:_files' \
  '(-help -h)'{-help,-h}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
