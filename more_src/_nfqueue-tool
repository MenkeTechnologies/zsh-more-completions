#compdef nfqueue
# _nfqueue-tool — netfilter NFQUEUE example tool (libnetfilter_queue examples/nf-queue.c demo userspace verdicter; -q queue number, -d daemonize, -v verbose, -m max packets, -t timeout seconds, -V version, -h help; useful when configuring iptables -j NFQUEUE --queue-num N)
# upstream: https://git.netfilter.org/libnetfilter_queue
# Flags from netfilter/libnetfilter_queue examples/nf-queue.c on tip.

_nfqueue-tool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-q+[queue number]:n:' \
        '-d[daemonize]' \
        '-v[verbose]' \
        '-m+[max packets]:n:' \
        '-t+[timeout seconds]:seconds:'
}

_nfqueue-tool "$@"
