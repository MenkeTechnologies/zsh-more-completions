#compdef lolcrab
# Documentation: https://github.com/mazznoer/lolcrab
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# Zsh completion for lolcrab gradient filter (mazznoer/lolcrab)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-g --gradient)'{-g,--gradient}'[color gradient preset]:gradient:(cividis cool cubehelix fruits inferno magma plasma rainbow rd-yl-gn sinebow spectral turbo viridis warm)' \
  '--presets[show all preset gradients]' \
  '(-c --custom)'{-c,--custom}'[custom gradient in CSS gradient format]:css' \
  '--sharp[sharp gradient]:n' \
  '(-s --scale)'{-s,--scale}'[noise scale 0.01..0.2]:float' \
  '(-S --seed)'{-S,--seed}'[seed]:n' \
  '(-i --invert)'{-i,--invert}'[colorize the background]' \
  '(-r --random-colors)'{-r,--random-colors}'[random colors as custom gradient 1..100]:n' \
  '(-a --animate)'{-a,--animate}'[enable animation mode]' \
  '(-d --duration)'{-d,--duration}'[animation duration]:n' \
  '--speed[animation speed]:n' \
  '*:file:_files' && ret=0

return ret
