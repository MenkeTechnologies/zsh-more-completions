#compdef lolcrab

# Zsh completion for lolcrab gradient filter (mazznoer/lolcrab)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-g --gradient)'{-g,--gradient}'[preset palette]:gradient:(cividis cool cubehelix fruits inferno lolcat magma plasma rainbow rdylgn sinebow spectral turbo viridis warm)' \
  '--presets[list built-in gradients]' \
  '(-c --custom)'{-c,--custom}'[CSS gradient string]:css' \
  '--sharp[sharp gradient steps]:n' \
  '(-s --scale)'{-s,--scale}'[noise scale]:float' \
  '(-S --seed)'{-S,--seed}'[noise seed]:n' \
  '(-i --invert)'{-i,--invert}'[color backgrounds instead of text]' \
  '(-r --random-colors)'{-r,--random-colors}'[random accent count 1-15]:n' \
  '(-L --lolcat)'{-L,--lolcat}'[lolcat-style linear gradient]' \
  '(-a --animate)'{-a,--animate}'[animate colors]' \
  '(-d --duration)'{-d,--duration}'[animation duration 1-30]:n' \
  '--speed[animation speed 30-200]:n' \
  '(-l --linear)'{-l,--linear}'[linear sweep mode]' \
  '(-A --angle)'{-A,--angle}'[linear gradient angle]:degrees' \
  '--spread[linear gradient spread 0-100]:pct' \
  '--offset[linear gradient offset 0-1]:frac' \
  '*:file:_files' && ret=0

return ret
