#compdef manage_agents
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/manage-agents.html
# Wazuh agent key management tool

local ret=1

_arguments -s -S \
  '(- *)-h[show help message]' \
  '(- *)-V[show version and license]' \
  '-j[JSON output]' \
  '-l[list available agents]' \
  '-a+[add new agent by ip]:ip:' \
  '-n+[name for new agent]:name:' \
  '-e+[extract key for agent id]:id:' \
  '-r+[remove agent by id]:id:' \
  '-i+[import authentication key]:id:' \
  '-f+[bulk generate keys from file]:file:_files' \
  '-R+[remove agents with duplicated ip registered since seconds]:seconds:' \
  '-D+[remove agents with duplicated ip disconnected since seconds]:seconds:' \
  '-L[disable agents registration limit]' \
  '*::arg:_files' && ret=0

return ret
