#compdef portal

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'send:send files through the portal'
      'receive:receive files from the portal'
    )
    _describe -t commands 'portal command' commands && ret=0
    ;;
  args)
    case $line[1] in
      send)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--relay[relay server address]:address:' \
          '*:files:_files' && ret=0
        ;;
      receive)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--relay[relay server address]:address:' \
          '--yes[auto-accept incoming files]' \
          '1:password:' && ret=0
        ;;
    esac
    ;;
esac

return ret
