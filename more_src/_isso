#compdef isso
# _isso — Martin Zimmermann Isso self-hosted commenting server CLI (posativ team, Python); argparse
# upstream: https://github.com/posativ/isso

_isso() {
    local -a sub=(
        'run:run isso server'
        'import:import comments from another system'
        'export:export comments'
        'serve:run wsgi server'
        'dbmigrate:run db migrations'
        'list:list threads'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--conf=+[config file]:file:_files -g "*.cfg"' \
        '-c+[config file]:file:_files -g "*.cfg"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'isso subcommand' sub ;;
        args)
            case $words[1] in
                import) _arguments \
                    '1:file:_files' \
                    '--type=+[source type]:t:(disqus wordpress)' \
                    '--empty-id[fill blank thread ids]' \
                    '-e[fill blank thread ids]' \
                    '--dry-run[dry run]' \
                    '-n[dry run]' ;;
                export) _arguments \
                    '--out=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--format=+[format]:f:(xml json)' ;;
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--workers=+[workers]:n:' \
                    '-w+[workers]:n:' ;;
            esac
            ;;
    esac
}

_isso "$@"
