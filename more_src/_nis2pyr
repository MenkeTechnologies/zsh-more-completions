#compdef nis2pyr
# Documentation: https://github.com/vibbits/nis2pyr
# Convert Nikon ND2 files to tiled pyramidal OME-TIFF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version]' \
  '--compression=[compression algorithm]:algo:(zlib)' \
  '--pyramid-levels=[maximum resolution levels]:n' \
  '--tile-size=[square tile width in pixels (multiple of 16)]:size' \
  '1:input file pattern:_files -g "*.nd2"' \
  '2:output pyramid OME-TIFF:_files' && ret=0

return ret
