#compdef chatgpt

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-m+[model name]:model:(gpt-4 gpt-4-turbo gpt-4o gpt-3.5-turbo)' \
  '--model=[model name]:model:(gpt-4 gpt-4-turbo gpt-4o gpt-3.5-turbo)' \
  '-t+[temperature]:temperature' \
  '--temperature=[temperature]:temperature' \
  '-s+[system message]:message' \
  '--system=[system message]:message' \
  '--max-tokens=[max response tokens]:tokens' \
  '-n+[number of completions]:count' \
  '-c[continue previous conversation]' \
  '--continue[continue previous conversation]' \
  '--no-stream[disable streaming]' \
  '-f+[input file]:file:_files' \
  '--file=[input file]:file:_files' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '--api-key=[API key]:key' \
  '--json[JSON output]' \
  '*:prompt:' && return 0
