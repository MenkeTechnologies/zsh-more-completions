#compdef cobaya-grid-create
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: initialize a grid of models using a settings file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--read-only[configure an already-run existing grid]' \
  '--install[install required code and data for the grid using default]' \
  '--install-reqs-at=[install required code and data for the grid in the given folder]:folder:_files -/' \
  '--install-reqs-force[force re-installation of apparently installed packages]' \
  '--show-covmats[show which covmat is assigned to each chain]' \
  '1:grid directory:_files -/' \
  '2:python setting file:_files -g "*.py"' && ret=0

return ret
