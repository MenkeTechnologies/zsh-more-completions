#compdef kwok

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--config+[path to config file]:config file:_files' \
  '--kubeconfig+[path to kubeconfig]:kubeconfig:_files' \
  '-v+[log level verbosity]:verbosity:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'create:create a resource'
      'delete:delete a resource'
      'get:get a resource'
      'hack:tools for hacking'
      'help:help about any command'
      'version:print version information'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (create|delete|get)
        _arguments \
          '1:resource type:(cluster node pod)' \
          '--name+[resource name]:name:' \
          '--namespace+[namespace]:namespace:' && ret=0
        ;;
      (hack)
        _arguments \
          '1:hack command:(get put delete)' && ret=0
        ;;
    esac
    ;;
esac

return ret
