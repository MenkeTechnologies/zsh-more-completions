#compdef pandoc-server
# Documentation: https://man.archlinux.org/search?q=pandoc-server
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '--timeout=[timeout in seconds]:seconds' && ret=0

return ret
