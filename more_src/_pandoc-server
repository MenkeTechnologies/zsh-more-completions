#compdef pandoc-server
# Documentation: https://pandoc.org/pandoc-server.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '--timeout=[timeout in seconds]:seconds' && ret=0

return ret
