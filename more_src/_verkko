#compdef verkko
# Documentation: https://github.com/marbl/verkko
# telomere-to-telomere assembly pipeline for HiFi and Nanopore reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d+[working directory for assembly output]:dir:_files -/' \
  '--hifi[input high-accuracy long reads]:*:file:_files' \
  '--nano[input Oxford Nanopore ultra-long reads]:*:file:_files' \
  '--hap-kmers[enable trio-based phasing with meryl k-mer databases]' \
  '--hic1[Hi-C forward reads]:*:file:_files' \
  '--hic2[Hi-C reverse reads]:*:file:_files' \
  '--porec[PoreC sequencing data]:*:file:_files' \
  '--assembly=[path to existing assembly for consensus]:dir:_files -/' \
  '--paths=[custom GAF-format paths through assembly graph]:file:_files' \
  '--screen[filter specific contaminants]:name' \
  '--screen-human-contaminants[remove rDNA, mitochondria, and EBV sequences]' \
  '--telomere-motif=[specify non-vertebrate telomeric repeat]:motif' \
  '--ref=[reference genome for scaffolding guidance]:file:_files' \
  '--grid[enable SGE, Slurm, LSF, or PBS job submission]' \
  '--snakeopts=[pass custom Snakemake parameters]:options' \
  '--python=[Python interpreter for conda environments]:file:_files' \
  '--haploid[assemble as haploid]' && ret=0

return ret
