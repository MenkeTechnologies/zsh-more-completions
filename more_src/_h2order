local ret=1

_arguments -s \
  '-f[trajectory input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-nm[index file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-o[output xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-d[normal direction on membrane]:dir:(Z Y X)' \
  '-sl[number of slices for order parameter]:int:' && ret=0

return ret
