#compdef arity
# _arity — arity CLI command-line frontend to the Arity Erlang Elixir-flavored multi-paradigm functional language run-time providing project-scaffold-build-test-format-publish-watch-server-shell modes with built-in REPL-prompt elixir-friendly mix-task-runner-interop similar-to-cargo-go-deno polyglot integration (arity authors team, Erlang); custom argparse
# upstream: https://github.com/arity-lang/arity

_arity() {
    local -a sub=(
        'new:create a new project'
        'init:initialize project in current dir'
        'build:build the project'
        'test:run tests'
        'fmt:format source'
        'doc:generate documentation'
        'run:run the project'
        'server:start dev server'
        'shell:start an interactive shell'
        'publish:publish to package registry'
        'install:install a package'
        'add:add dependency'
        'remove:remove dependency'
        'update:update dependencies'
        'audit:audit dependencies'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config=+[file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '--profile=+[name]:p:(dev release test bench)' \
        '--target=+[arch]:str:' \
        '--features=+[list]:str:' \
        '--no-default-features[do not enable default features]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arity subcommand' sub ;;
        args)
            case $words[1] in
                new|init) _arguments '*:name:' ;;
                install|add|remove|update) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_arity "$@"
