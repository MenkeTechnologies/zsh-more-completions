#compdef rsem-prepare-reference
# Documentation: https://deweylab.github.io/RSEM/rsem-prepare-reference.html
# RSEM: prepare transcript/genome reference sequences for expression estimation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--gtf=[use genome with GTF gene annotations]:gtf file:_files' \
  '--gff3=[use GFF3 format annotations]:gff3 file:_files' \
  '--gff3-RNA-patterns=[comma-separated transcript categories to extract]:patterns' \
  '--gff3-genes-as-transcripts[treat genes as transcripts]' \
  '--trusted-sources=[filter transcripts by source list]:sources' \
  '--transcript-to-gene-map=[map transcript IDs to gene IDs]:map file:_files' \
  '--allele-to-gene-map=[allele-specific transcript info]:map file:_files' \
  '--polyA[add poly(A) tails to reference isoforms]' \
  '--polyA-length=[poly(A) tail length]:int' \
  '--no-polyA-subset=[exclude transcripts from poly(A) addition]:file:_files' \
  '--bowtie[build Bowtie indices]' \
  '--bowtie-path=[path to Bowtie executables]:path:_files -/' \
  '--bowtie2[build Bowtie 2 indices]' \
  '--bowtie2-path=[path to Bowtie 2 executables]:path:_files -/' \
  '--star[build STAR indices]' \
  '--star-path=[path to STAR executable]:path:_files -/' \
  '--star-sjdboverhang=[genomic length around junctions]:int' \
  '--hisat2-hca[build HISAT2 transcriptome indices for HCA]' \
  '--prep-pRSEM[prepare files for prior-enhanced RSEM]' \
  '--mappability-bigwig-file=[genome mappability file]:file:_files' \
  '(-p --num-threads)'{-p,--num-threads}'=[thread count for STAR indexing]:int' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging output]' \
  '*:reference fasta or name:_files' && ret=0

return ret
