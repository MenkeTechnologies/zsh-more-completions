#compdef hackernews_tui
# Documentation: https://man.archlinux.org/search?q=hackernews_tui
# Reference accessed: 2026-05-16

# Zsh completion for hackernews_tui (aome510/hackernews-TUI). Binary name follows Cargo package hackernews_tui.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --auth)'{-a,--auth=}'[hn-auth.toml path]:file:_files' \
  '(-c --config)'{-c,--config=}'[hn-tui.toml path]:file:_files' \
  '(-l --log)'{-l,--log=}'[log output directory]:dir:_directories' \
  '(-i)-i=[HN story id to open first]:item id:'
