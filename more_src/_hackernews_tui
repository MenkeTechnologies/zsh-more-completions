#compdef hackernews_tui
# Documentation: https://github.com/aome510/hackernews-TUI
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Binary name follows Cargo package hackernews_tui.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --auth)'{-a+,--auth=}'[hn-auth.toml path]:file:_files' \
  '(-c --config)'{-c+,--config=}'[hn-tui.toml path]:file:_files' \
  '(-l --log)'{-l+,--log=}'[log output directory]:dir:_directories'
