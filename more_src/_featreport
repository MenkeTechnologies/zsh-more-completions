#compdef featreport
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/featreport.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS featreport: read and write a feature table as a structured report
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence]:sequence USA:_files' \
  '-features=[input feature table]:USA:_files' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(table excel feattable gff3 listfile pir simple swiss tagseq motif)' \
  '*:sequence USA:_files' && ret=0
return ret
