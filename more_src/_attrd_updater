#compdef attrd_updater

# Pacemaker attrd_updater: read/write per-node transient attributes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-?)-?[show help]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[print no output]' \
  '(-n --name)'{-n,--name=}'[attribute name]:name:' \
  '(-N --node)'{-N,--node=}'[node name]:node:' \
  '(-D --delete)'{-D,--delete}'[delete attribute]' \
  '(-Q --query)'{-Q,--query}'[query attribute value]' \
  '(-U --update)'{-U,--update=}'[set attribute value]:value:' \
  '(-y --update-both)'{-y,--update-both=}'[set value and modifier]:val:' \
  '(-W --update-delay)'{-W,--update-delay=}'[set update delay]:msec:' \
  '(-d --delay)'{-d,--delay=}'[delay before writing (msec)]:msec:' \
  '(-s --set)'{-s,--set=}'[set name]:set:' \
  '(-l --lifetime)'{-l,--lifetime=}'[attribute lifetime]:lifetime:(forever reboot)' \
  '(-p --private)'{-p,--private}'[do not store in CIB]' \
  '(-R --refresh)'{-R,--refresh}'[force attrd refresh]' \
  '(-Y --type)'{-Y,--type=}'[attribute type]:type:(none reboot lazy permanent transient)' \
  '*::attrd_updater args:_files' && ret=0
return ret
