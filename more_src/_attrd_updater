#compdef attrd_updater

# attrd_updater: update / query / refresh attributes via pacemaker-attrd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-q[query attribute value]' \
  '--query[query attribute value]' \
  '-U[update attribute value]:value:' \
  '--update=[update attribute value]:value:' \
  '-D[delete attribute]' \
  '--delete[delete attribute]' \
  '-R[refresh all attribute values]' \
  '--refresh[refresh all attribute values]' \
  '-B[update both attribute value and dampening]:value:' \
  '--update-both=[update both attribute value and dampening]:value:' \
  '-Y[query/update delay (dampening)]:delay:' \
  '--update-delay=[query/update delay (dampening)]:delay:' \
  '-n[attribute name]:name:' \
  '--name=[attribute name]:name:' \
  '-N[node name]:node:' \
  '--node=[node name]:node:' \
  '-A[for all attributes]' \
  '--all[for all attributes]' \
  '-l[print all node values]' \
  '--lifetime=[lifetime]:lifetime:(reboot forever)' \
  '-d[set dampening]:delay:' \
  '--delay=[set dampening]:delay:' \
  '-s[attribute set name]:set:' \
  '--set=[attribute set name]:set:' \
  '-p[use private (non-persistent) attribute]' \
  '--private[use private (non-persistent) attribute]' \
  '*::attrd_updater args:_files' && ret=0
return ret
