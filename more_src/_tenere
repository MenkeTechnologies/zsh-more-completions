#compdef tenere

# Zsh completion for tenere - TUI interface for LLMs (ChatGPT, llama.cpp, Ollama, etc.)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--config[config file path]:file:_files' && ret=0

return ret
