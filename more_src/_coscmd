#compdef coscmd
# Documentation: https://cloud.tencent.com/document/product/436/10976
# Tencent Cloud COS (Cloud Object Storage) command line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show program version]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-s --silence)'{-s,--silence}'[silence mode]' \
  '(-b --bucket)'{-b,--bucket}'+[specify bucket]:bucket:' \
  '(-r --region)'{-r,--region}'+[specify region]:region:' \
  '(-c --config_path)'{-c,--config_path}'+[specify config file path]:file:_files' \
  '(-l --log_path)'{-l,--log_path}'+[specify log file path]:file:_files' \
  '--log_size=[max log size in MB]:size:' \
  '--log_backup_count=[log backup number]:count:' \
  '*:command:(config upload download delete copy move list info restore signurl createbucket deletebucket putobjectacl getobjectacl putbucketacl getbucketacl putbucketversioning getbucketversioning abort listparts probe)' && ret=0

return ret
