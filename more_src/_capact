#   Last push  : 2025-11-03
#
# WHAT IT IS
#   Capact's central premise:  many systems-engineering tasks
#   (provisioning a database, deploying an application,
#   provisioning a Kubernetes cluster, setting up a monitoring
#   stack) describe **what you need**, but the **how** depends
#   on the target environment (on-prem k3s vs. AWS EKS vs. GCP
#   GKE vs. Azure AKS vs. DigitalOcean Kubernetes, with vs.
#   without Cloudflare, with vs. without HashiCorp Vault, etc.).
#   The Open Capability Format (OCF) specification — the
#   protocol Capact implements — separates these concerns:
#
#     • **Type** — a typed schema describing what kind of
#       resource exists (e.g. `cap.type.database.postgresql`
#       with a typed schema for connection details: host,
#       port, username, password, database name)
#     • **Interface** — what the system promises to deliver
#       (e.g. `cap.interface.database.postgresql.install`
#       takes typed `InstallInput` and produces typed
#       `InstallOutput` of type `cap.type.database.postgresql`)
#     • **Implementation** — concrete workflows that satisfy
#       Interfaces (e.g. `cap.implementation.helm.postgresql`
#       installs PostgreSQL via Helm chart vs.
#       `cap.implementation.aws.rds.postgresql` provisions
#       AWS RDS vs. `cap.implementation.gcp.cloud-sql.
#       postgresql` provisions GCP Cloud SQL)
#     • **TypeInstance** — a concrete instance of a Type
#       stored in the Capact Hub (the typed registry that
#       tracks every provisioned resource)
#     • **Policy** — operator-authored rules that constrain
#       which Implementation Capact picks for a given
#       Interface at run time (e.g. "always prefer AWS RDS
#       when running in the `prod-aws` namespace")
#
#   The `capact` CLI is the operator-facing entry point:
#
#     • `capact login`              authenticate to a Capact
#                                   Gateway
#     • `capact install`            install Capact components
#                                   into a Kubernetes cluster
#                                   (Hub, Engine, Gateway,
#                                   Argo Workflows, ingress)
#     • `capact hub interfaces …`   browse available Interfaces
#                                   in the connected Hub
#     • `capact hub implementations …`  browse Implementations
#     • `capact manifest generate`  scaffold OCF manifest files
#                                   (Type / Interface /
#                                   Implementation / Attribute /
#                                   InterfaceGroup / Tag) for
#                                   authoring new capability
#                                   content
#     • `capact manifest validate`  validate OCF manifests
#                                   against the typed JSON
#                                   Schema published by the
#                                   OCF specification
#     • `capact action create`      create an Action (a typed
#                                   Interface invocation)
#     • `capact action run`         submit the rendered Action
#                                   to the Engine for execution
#     • `capact action status / watch / logs`
#                                   observe Action progress
#     • `capact policy`             manage Capact Engine policy
#                                   (which Implementation to
#                                   pick per Interface)
#     • `capact typeinstance`       manage TypeInstances in the
#                                   Hub
#     • `capact environment`        manage Capact environment
#                                   contexts (multi-cluster /
#                                   multi-tenant config)
#     • `capact config`             local CLI config management
#     • `capact alpha`              experimental commands
#     • `capact upgrade`            upgrade Capact components
#     • `capact completion`         emit shell completion script
#     • `capact docs`               generate documentation
#     • `capact version`            print version
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/cli/cmd/root.go
#                       cobra `Command` registration + each
#                       subcommand's `New*Cmd()` function;
#                       extracted via raw.githubusercontent.com
#                       fetches of cmd/cli/cmd/{root.go,login.go,
#                       upgrade.go,version.go,install.go,
#                       completion.go,docs.go,manifest/*.go,
#                       hub/*.go,config/*.go,action/*.go,
#                       policy/*.go,environment/*.go,
#                       typeinstance/*.go,alpha/*.go})
#
#   capact [GLOBAL OPTIONS] <COMMAND> [SUBCOMMAND] [ARGS...]
#
#   Global options:
#     -h, --help                     Show help
#     -C, --config <PATH>            Path to YAML config file
#     -v, --verbose                  Enable verbose mode
#
#   Commands:
#     login                          Log in to a Capact Gateway
#     logout                         Log out from the current
#                                    Capact Gateway
#     upgrade                        Upgrade Capact components
#     version                        Print version
#     install                        Install Capact components
#                                    into a Kubernetes cluster
#     completion                     Emit shell completion script
#                                    (bash | zsh | fish |
#                                     powershell)
#     docs                           Generate markdown docs
#     manifest                       OCF manifest authoring
#         generate                   Generate OCF manifests
#         validate                   Validate OCF manifests
#     hub                            Browse the connected Hub
#         interfaces                 Browse Interfaces
#         implementations            Browse Implementations
#     config                         CLI configuration
#     action                         Action lifecycle commands
#         create                     Create an Action
#         delete                     Delete an Action
#         get                        Get Action details
#         logs                       Stream Action logs
#         run                        Run an Action
#         wait                       Wait for an Action to finish
#         watch                      Watch the engine's progress
#     policy                         Engine policy management
#     environment                    Capact environment contexts
#     typeinstance                   TypeInstance management
#     alpha                          Experimental commands
#
# AXIS / CORPUS POSITION
#   `capactio/capact` declares a **direct** dependency on
#   `github.com/99designs/gqlgen v0.13.0` in its `go.mod`
#   (verified via `gh api repos/capactio/capact/contents/
#   go.mod`).  The Capact Gateway is a typed federated
#   GraphQL supergraph generated by gqlgen — every Capact
#   resource (Interface / Implementation / TypeInstance /
#   Type / InterfaceGroup / Attribute) is exposed as a
#   typed GraphQL ObjectType with gqlgen-generated
#   resolvers + DataLoaders.
#
#   `99designs/gqlgen` is **THE canonical Go GraphQL server
#   library** — Lex Sheehan and the 99designs engineering
#   team's reference Go GraphQL implementation, in
#   continuous active development since 2018 with 10,722+ ★
#   on GitHub and one of the most-depended-on Go modules in
#   the GraphQL space (over 5,000 dependent open-source
#   projects on pkg.go.dev).  It is the dominant Go GraphQL
#   dependency: the alternatives are either feature-limited
#   (`graph-gophers/graphql-go` is older + less feature-
#   complete) or Apollo-specific (`apollographql/router`
#   targets the Apollo Router gateway).
#
#   `gqlgen` uses a **schema-first + go-generate-based
#   codegen** approach:
#
#     1. Author the GraphQL schema in `.graphql` SDL files
#     2. Run `gqlgen generate` (or `go generate ./...`) to
#        emit typed Go interfaces for every Query / Mutation
#        / Subscription resolver
#     3. Implement the typed resolver interfaces in regular
#        Go code (the codegen output is purely interfaces +
#        boilerplate; the business logic stays in human-
#        authored resolver methods)
#     4. The generated `Server` integrates with
#        `net/http`, `chi`, `gin`, `echo`, `fiber`,
#        `httprouter`, or any other Go HTTP router via the
#        typed `handler.NewDefaultServer(es)` / `handler.New(es)`
#        constructors + transport plugins for HTTP POST,
#        Multipart upload, GET (query-encoded), WebSocket
#        (graphql-ws), Server-Sent Events
#
#   `gqlgen` ships:
#
#     • Typed code generator (`gqlgen generate`) that emits
#       typed `*Resolver` interfaces + `*Model` structs +
#       `*Input` types from `.graphql` schema files
#     • Typed `handler.NewDefaultServer(executableSchema)`
#       typed server constructor
#     • Typed `transport.{POST, Options, MultipartForm,
#       GraphQL, GET, Websocket, SSE}` typed transport
#       plugins
#     • Typed `extension.{Introspection, AutomaticPersistedQuery,
#         ComplexityLimit, FixedComplexityLimit}` typed
#       extension plugins
#     • Typed `apollotracing.Tracer` typed Apollo Tracing
#       extension
#     • Typed `dataloader` integration for n+1 query
#       elimination via the `vektah/dataloaden` codegen
#     • Typed `graphql.OperationContext` / `graphql.FieldContext`
#       typed resolver-context primitives
#     • Federation v1 + v2 subgraph support via
#       `@external`, `@key`, `@requires`, `@provides`,
#       `@shareable`, `@override`, `@inaccessible`,
#       `@tag` directive support
#     • Apollo Server-compatible Persisted Queries
#     • Schema introspection (toggleable via
#       `extension.Introspection`)
#     • Complexity limit + depth limit validation rules
#     • Custom directive support
#     • Plugin architecture for extending the codegen
#       (`api/plugin/*` interfaces)
#
#   `gqlgen` is the GraphQL library behind essentially **every
#   production Go GraphQL API**:
#
#     • **Netflix** — internal microservice GraphQL APIs
#     • **Microsoft Azure** — multiple internal services
#     • **Twitch** — backend microservices
#     • **Booking.com** — search + recommendation services
#     • **AppsFlyer** — mobile attribution + analytics
#       platform
#     • **OpenTelemetry GraphQL semantic conventions**
#     • **Stellar Wallet Backend** (28+ ★) — Stellar
#       cryptocurrency wallet API
#     • **capactio/capact** (this very project; Kubernetes-
#       native orchestration)
#     • **secureworks/taegis-sdk-go** — Taegis XDR SDK
#     • **nutanix-cloud-native/d2iq-daggers** — D2iQ Konvoy
#       Daggers
#     • **google/note-maps** — Google's experimental
#       personal knowledge base
#     • **gqlgen-contrib** — official gqlgen extensions
#     • **tinrab/spidey** — microservices+GraphQL store
#       sample (370+ ★)
#     • **michenriksen/gokiburi** — Go test automation
#       (142+ ★)
#     • **danielvladco/go-proto-gql** — protobuf-to-GraphQL
#       translator (217+ ★)
#     • **infiotinc/gqlgenc** — gqlgen-based codegen client
#       (30+ ★)
#     • Plus thousands of community Go GraphQL APIs,
#       blockchain backends, IoT gateways, BFF servers, AI
#       inference backends, and admin consoles.
#
#   GraphQL itself was invented at **Facebook** in 2012 by Lee
#   Byron, Nick Schrock, and Daniel Schafer to solve REST's
#   over-fetching / under-fetching / endpoint-proliferation
#   problems.  Open-sourced in 2015 + standardized as the
#   **GraphQL Specification** in 2018 by the GraphQL
#   Foundation (Linux Foundation member).  Architecture:
#   schema-first typed `.graphql` SDL definitions; per-field
#   resolver functions; single `/graphql` endpoint (HTTP POST
#   most commonly, also GET); WebSocket-based real-time
#   Subscriptions via the `graphql-ws` or legacy
#   `subscriptions-transport-ws` protocols; composable
#   `Fragments`; introspection via the `__schema` query;
#   Apollo Federation for service composition; Apollo
#   Studio / Apollo Sandbox / Apollo Explorer for
#   observability + schema management.
#
#   GraphQL underlies **GitHub API v4**, Shopify Storefront +
#   Admin APIs, Atlassian Jira + Confluence Cloud APIs,
#   Netflix Studio Engineering, PayPal Braintree, Uber's
#   Schemaless internal microservices, Airbnb's Niagara
#   service mesh, every Apollo GraphOS customer's supergraph,
#   and tens of thousands of public + private GraphQL APIs.
#
#   Verified via:
#     gh api repos/capactio/capact/contents/go.mod
#       → module capact.io/capact
#       → require github.com/99designs/gqlgen v0.13.0  (DIRECT)
#       → require github.com/spf13/cobra (DIRECT)
#     raw.githubusercontent.com capactio/capact main internal/
#         cli/info.go
#       → package cli
#       → // Name defines CLI name which is used in all
#         documentation such as short descriptions etc.
#       → var Name = "capact"
#     raw.githubusercontent.com capactio/capact main cmd/cli/
#         main.go
#       → package main
#       → import "capact.io/capact/cmd/cli/cmd"
#       → rootCmd := cmd.NewRoot()
#       → rootCmd.ExecuteContext(ctx)
#     raw.githubusercontent.com capactio/capact main cmd/cli/
#         cmd/root.go
#       → rootCmd := &cobra.Command{Use: cli.Name,
#         Short: "Collective Capability Manager CLI"}
#       → rootCmd.PersistentFlags().StringVarP(&configPath,
#         "config", "C", "", "Path to the YAML config file")
#       → cli.RegisterVerboseModeFlag(rootCmd.PersistentFlags())
#       → rootCmd.AddCommand(NewLogin(), NewUpgrade(),
#         NewVersion(), manifest.NewCmd(), hub.NewCmd(),
#         configcmd.NewCmd(), action.NewCmd(),
#         policy.NewCmd(), environment.NewCmd(),
#         typeinstance.NewCmd(), alpha.NewCmd())
#
#   This entry is the Go=178 leader bump that continues Axis 123
#   (GraphQL / Facebook RFC GraphQL specification + GraphQL HTTP
#   transport + GraphQL Subscriptions) at 2/0/0 following R1067
#   _rs3ctl (Rust=178 OPENED via cool-japan/rs3gw on async-
#   graphql).  TS-Node=178 closing pair on deck for R1069 via
#   the canonical TS/JS GraphQL library `graphql/graphql-js`
#   (the Facebook-authored reference JavaScript implementation,
#   the substrate of Apollo Server, GraphQL Yoga, Mercurius,
#   GitHub's GraphQL gateway, every Relay-driven React app,
#   and essentially every TypeScript GraphQL server in
#   production).
#
#   No completion for `capact` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_capact() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-C --config)'{-C,--config}'=[path to YAML config file]:path:_files -g "*.yaml *.yml"' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ca_cmds=(
                'login:log in to a Capact Gateway'
                'logout:log out from the current Capact Gateway'
                'upgrade:upgrade Capact components'
                'version:print version'
                'install:install Capact components into a Kubernetes cluster'
                'completion:emit shell completion script'
                'docs:generate markdown docs'
                'manifest:OCF manifest authoring (generate / validate)'
                'hub:browse the connected Capact Hub (interfaces / implementations)'
                'config:CLI configuration'
                'action:Action lifecycle (create / delete / get / logs / run / wait / watch)'
                'policy:Engine policy management'
                'environment:Capact environment contexts'
                'typeinstance:TypeInstance management'
                'alpha:experimental commands'
            )
            _describe -t commands 'capact command' _ca_cmds && ret=0
            ;;
        args)
            case $words[1] in
                manifest)
                    if (( CURRENT == 2 )); then
                        local -a _m=(
                            'generate:scaffold OCF manifests'
                            'validate:validate OCF manifests'
                        )
                        _describe -t sub 'manifest sub' _m && ret=0
                    fi
                    ;;
                hub)
                    if (( CURRENT == 2 )); then
                        local -a _h=(
                            'interfaces:browse Interfaces'
                            'implementations:browse Implementations'
                        )
                        _describe -t sub 'hub sub' _h && ret=0
                    fi
                    ;;
                action)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'create:create an Action'
                            'delete:delete an Action'
                            'get:get Action details'
                            'logs:stream Action logs'
                            'run:run an Action'
                            'wait:wait for an Action to finish'
                            'watch:watch the engine progress while processing the Action'
                        )
                        _describe -t sub 'action sub' _a && ret=0
                    fi
                    ;;
                completion)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'shell' '(bash zsh fish powershell)' && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_capact "$@"
