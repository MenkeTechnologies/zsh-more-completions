#compdef impacket impacket-examples
# _impacket — Fortra SecureAuth impacket helper CLI dispatching to impacket-examples scripts smbexec wmiexec psexec atexec smbpasswd secretsdump GetADUsers GetUserSPNs Kerberos AS-REP Asreproast (fortra team, Python); argparse
# upstream: https://github.com/fortra/impacket

_impacket() {
    local -a sub=(
        'addcomputer:add machine account'
        'atexec:remote exec via Task Scheduler'
        'changepasswd:change password via SMB'
        'dpapi:DPAPI key recovery'
        'esentutl:Esent database utility'
        'GetADUsers:enumerate AD users'
        'GetNPUsers:Kerberos AS-REP roasting'
        'GetUserSPNs:Kerberoasting'
        'getArch:remote architecture'
        'getPac:get PAC'
        'getST:get Service Ticket'
        'getTGT:get TGT'
        'goldenPac:generate Golden Ticket'
        'karmaSMB:malicious SMB server'
        'kintercept:Kerberos interceptor'
        'lookupsid:SID enumeration'
        'mimikatz:port of mimikatz'
        'mqtt_check:MQTT broker auth check'
        'mssqlclient:MSSQL client'
        'mssqlinstance:MSSQL instance enumeration'
        'netview:list shares and sessions'
        'ntfs-read:read NTFS volume'
        'ntlmrelayx:NTLM relay attack'
        'ping:network ping helper'
        'psexec:remote exec via SVC'
        'rdp_check:RDP credential check'
        'reg:remote registry editor'
        'rpcdump:RPC interface enumeration'
        'rpcmap:RPC mapping enumeration'
        'sambaPipe:Samba pipe enumeration'
        'samrdump:SAMR enumeration'
        'secretsdump:secrets/hash dump'
        'services:remote services management'
        'smbclient:SMB shell client'
        'smbexec:semi-interactive SMB shell'
        'smbserver:malicious SMB server'
        'sniff:network sniffer'
        'sniffer:network sniffer'
        'split:pcap splitter'
        'ticketConverter:Kerberos ticket converter'
        'ticketer:Kerberos ticketer'
        'tstool:Terminal Services tool'
        'wmiexec:remote exec via WMI'
        'wmipersist:WMI persistence'
        'wmiquery:WMI query'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'impacket subcommand' sub ;;
        args)
            case $words[1] in
                psexec|smbexec|wmiexec|atexec|secretsdump) _arguments \
                    '-hashes=+[lm:nt]:str:' \
                    '-no-pass[no password]' \
                    '-k[use kerberos]' \
                    '-dc-ip=+[ip]:str:' \
                    '-target-ip=+[ip]:str:' \
                    '*:domain/user@target:' ;;
                GetUserSPNs|GetNPUsers) _arguments \
                    '-request[request]' \
                    '-outputfile=+[file]:file:_files' \
                    '-dc-ip=+[ip]:str:' \
                    '*:domain/user[:password]:' ;;
            esac
            ;;
    esac
}

_impacket "$@"
