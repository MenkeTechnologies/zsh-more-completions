#compdef cowbuilder

# Zsh completion for cowbuilder (pbuilder with COW filesystem)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--create[create a new base COW image]' \
  '--update[update the base COW image]' \
  '--build[build a package]:dsc file:_files -g "*.dsc(N)"' \
  '--login[login to the chroot]' \
  '--execute[execute a command in the chroot]:command' \
  '--dumpconfig[dump current configuration]' \
  '--debuild[build using pdebuild]' \
  '--basepath[path to base COW image]:path:_files -/' \
  '--buildplace[path for build area]:directory:_files -/' \
  '--buildresult[directory for build results]:directory:_files -/' \
  '--mirror[mirror URL]:URL' \
  '--othermirror[additional mirror lines]:mirror specification' \
  '--distribution[target distribution]:distribution:(stable testing unstable sid bookworm trixie bullseye buster)' \
  '--architecture[target architecture]:architecture:(amd64 i386 arm64 armhf armel)' \
  '--components[archive components]:components' \
  '--debootstrap[debootstrap implementation]:program:(debootstrap cdebootstrap mmdebstrap)' \
  '--debootstrapopts[additional debootstrap options]:options' \
  '--hookdir[directory with hook scripts]:directory:_files -/' \
  '--extrapackages[additional packages to install]:packages' \
  '--aptcache[apt cache directory]:directory:_files -/' \
  '--configfile[configuration file]:file:_files' \
  '--override-config[override saved configuration]' \
  '--bindmounts[directories to bind mount]:directories' \
  '--debbuildopts[options to pass to dpkg-buildpackage]:options' \
  '--logfile[write log to file]:file:_files' \
  '--pkgname-logfile[use package name in log filename]' \
  '--save-after-login[save chroot after login session]' \
  '--save-after-exec[save chroot after exec]' \
  '--help[show help]' && ret=0

return ret
