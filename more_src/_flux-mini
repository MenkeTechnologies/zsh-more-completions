#compdef flux-mini
# _flux-mini — Flux Framework minimal job-submission front-end; submit/run/bulksubmit/batch/alloc jobs without writing a jobspec, mirrors flux submit/flux run
# upstream: https://github.com/flux-framework/flux-core

_flux-mini() {
    local -a sub=(
        'submit:enqueue a job (return jobid)'
        'run:enqueue and attach (interactive)'
        'bulksubmit:submit many jobs with cartesian args'
        'batch:submit a batch jobspec file'
        'alloc:allocate resources and run new flux instance'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flux-mini subcommand' sub ;;
        args)
            _arguments \
                '(-N --nodes)'{-N,--nodes}'+[nodes]:n:' \
                '(-n --ntasks)'{-n,--ntasks}'+[tasks]:n:' \
                '(-c --cores-per-task)'{-c,--cores-per-task}'+[cores per task]:n:' \
                '(-g --gpus-per-task)'{-g,--gpus-per-task}'+[gpus per task]:n:' \
                '(-t --time-limit)'{-t,--time-limit}'+[time limit]:duration:' \
                '(-o --setopt)'{-o,--setopt}'+[set option]:option:' \
                '(-S --setattr)'{-S,--setattr}'+[set attribute]:attr:' \
                '(--env)--env+[env var]:var:_parameters -g "*export*"' \
                '(--input)--input+[stdin file]:file:_files' \
                '(--output)--output+[stdout file]:file:_files' \
                '(--error)--error+[stderr file]:file:_files' \
                '(--label-io)--label-io[label per-task output]' \
                '(--cwd)--cwd+[working dir]:dir:_files -/' \
                '*::command:_command_names -e'
            ;;
    esac
}

_flux-mini "$@"
