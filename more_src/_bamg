#compdef bamg
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/bamg.1.html
# anisotropic 2D mesh generator (Bidimensional Anisotropic Mesh Generator)

local ret=1

_arguments -s -S \
  '-g[input geometry file (bamgcad format)]:file:_files' \
  '-o[output mesh file (bamg DB format)]:file:_files' \
  '-b[input background mesh]:file:_files' \
  '-r[input mesh file]:file:_files' \
  '-M[input metric file]:file:_files' \
  '-Mbb[input solution file (bb) for metric computation]:file:_files' \
  '-MBB[input solution file (BB) for metric computation]:file:_files' \
  '-rbb[input solution file (bb) for interpolation]:file:_files' \
  '-rBB[input solution file (BB) for interpolation]:file:_files' \
  '-wbb[output reinterpolated solution (bb)]:file:_files' \
  '-wBB[output reinterpolated solution (BB)]:file:_files' \
  '-oM[output metric file]:file:_files' \
  '-hmax[maximal edge size]:size' \
  '-hmin[minimal edge size]:size' \
  '-hminaniso[minimal edge size in anisotropic mode]:size' \
  '-errg[relative error on geometry boundary (default 0.1)]:err' \
  '-nbv[maximal number of vertices (default 50000)]:n' \
  '-thetamax[angular limit for curved corners in degrees]:deg' \
  '-NbSmooth[mesh smoothing iterations (default 3)]:n' \
  '-omega[smoothing relaxation parameter (default 1.8)]:val' \
  '-RelError[compute metric with relative error]' \
  '-AbsError[compute metric with absolute error]' \
  '-coef[multiplicative coefficient on mesh size (default 1)]:val' \
  '-err[P1 interpolation error level (default 0.01)]:val' \
  '-CutOff[cut-off value for relative error (default 1e-5)]:val' \
  '-power[Hessian power parameter (default 1)]:val' \
  '-NbJacobi[smoothing iterations during metric construction]:n' \
  '-ratio[prescribed metric smoothing ratio (default 0)]:val' \
  '-anisomax[mesh anisotropy bound (default 1e6)]:val' \
  '-maxsubdiv[maximal edge subdivision (max 10)]:val' \
  '-aniso[enforce anisotropic metric]' \
  '-iso[use isotropic metric]' \
  '-KeepBackVertices[retain old vertices]' \
  '-noKeepBackVertices[create all vertices from scratch]' \
  '-splitpbedge[split internal edges with both vertices on boundary]' \
  '-nosplitpbedge[do not split boundary edges]' \
  '-2[divide mesh size by two]' \
  '-2q[convert triangles to quadrilaterals]' \
  '-thetaquad[angle range for quad merging]:deg' \
  '-NoRescaling[do not rescale solution before metric computation]' \
  '-Rescaling[rescale solution to 0..1]' \
  '-oamdba[output AMDBA format]:file:_files' \
  '-oftq[output FTQ format]:file:_files' \
  '-omsh[output MSH format (FreeFEM3)]:file:_files' \
  '-oam_fmt[output AM_FMT format]:file:_files' \
  '-oam[output AM format]:file:_files' \
  '-onopo[output NOPO format]:file:_files' \
  '-v[verbosity level 0-10 (default 1)]:level' && ret=0

return ret
