#compdef bypass4netns
# Documentation: https://github.com/rootless-containers/bypass4netns/blob/master/README.md
# bypass4netns - bypass slirp4netns for better network throughput

local ret=1

_arguments -s -S \
  '--socket=[socket file]:file:_files' \
  '--com-socket=[socket file for communication with bypass4netns]:file:_files' \
  '--pid-file=[pid file]:file:_files' \
  '--log-file=[output logs to file]:file:_files' \
  '--multinode-etcd-address=[etcd address for multinode communication]:addr:' \
  '--multinode-host-address=[host address for multinode communication]:addr:' \
  '--ready-fd=[file descriptor to notify when ready]:fd:' \
  '--exit-fd=[file descriptor for terminating bypass4netns]:fd:' \
  '*--ignore=[subnets to ignore (or auto)]:subnet:' \
  '*'{-p,--publish}'=[publish container port(s) to the host]:portspec:' \
  '--handle-c2c-connections[handle connections between containers]' \
  '--tracer[enable connection tracer]' \
  '--multinode[enable multinode communication]' \
  '--ignore-bind[disable bypassing bind]' \
  '--debug[enable debug mode]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
