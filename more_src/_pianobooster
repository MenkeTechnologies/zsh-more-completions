#compdef pianobooster PianoBooster
# Documentation: https://man.archlinux.org/search?q=pianobooster
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug-options)'{-d,--debug-options}'+[debug flags]:flags:' \
  '(-q --quick-start)'{-q,--quick-start}'[quick start]' \
  '(-s --skin)'{-s,--skin}'+[skin]:skin:' \
  '*:midi file:_files -g "*.{mid,midi}"' && ret=0

return ret
