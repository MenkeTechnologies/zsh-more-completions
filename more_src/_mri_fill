#compdef mri_fill
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_fill
# FreeSurfer: fill the interior of white matter surfaces

local ret=1

_arguments -s -S \
  '-T[fill_holes threshold (default 1)]:threshold' \
  '-xform[use transform destination offset]:xformname:_files' \
  '-segmentation[aseg volume used to perform fill]:filename:_files' \
  '-atlas[atlas to use for auto-filling]:filename:_files' \
  '-fillven[fill ventricles]' \
  '-C[talairach coords of corpus callosum seed]:x y z' \
  '-P[talairach coords of pons seed]:x y z' \
  '-lh[talairach coords of left hemi WM seed]:x y z' \
  '-rh[talairach coords of right hemi WM seed]:x y z' \
  '-CV[voxel coords of corpus callosum seed]:x y z' \
  '-PV[voxel coords of pons seed]:x y z' \
  '*:volume:_files' && ret=0

return ret
