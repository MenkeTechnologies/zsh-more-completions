#compdef snippy
# snippy — rapid bacterial SNP calling and core genome alignment

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[display help and exit]' \
  '(- *)--version[print version and exit]' \
  '(- *)--citation[print citation info]' \
  '(- *)--check[check all dependencies are installed]' \
  '--reference=[reference genome (FASTA/GenBank/EMBL)]:ref file:_files' \
  '--ref=[reference genome (FASTA/GenBank/EMBL)]:ref file:_files' \
  '--R1=[paired-end forward reads]:R1 file:_files' \
  '--pe1=[paired-end forward reads]:R1 file:_files' \
  '--left=[paired-end forward reads]:R1 file:_files' \
  '--R2=[paired-end reverse reads]:R2 file:_files' \
  '--pe2=[paired-end reverse reads]:R2 file:_files' \
  '--right=[paired-end reverse reads]:R2 file:_files' \
  '--se=[single-end reads]:SE file:_files' \
  '--single=[single-end reads]:SE file:_files' \
  '--ctgs=[assembled contigs instead of reads]:contigs file:_files' \
  '--contigs=[assembled contigs instead of reads]:contigs file:_files' \
  '--peil=[paired-end interleaved reads]:interleaved file:_files' \
  '--bam=[pre-aligned BAM file]:BAM file:_files' \
  '--targets=[BED file to restrict variant calling]:BED file:_files' \
  '--subsample=[subsample proportion of reads]:proportion' \
  '--outdir=[output folder]:output dir:_files -/' \
  '--prefix=[prefix for output files]:prefix' \
  '--report[generate HTML report per variant]' \
  '--cleanup[remove intermediate files]' \
  '--unmapped[keep unmapped reads in FASTQ]' \
  '--force[overwrite existing output folder]' \
  '--cpus=[max CPU cores to use]:cpus' \
  '--ram=[target RAM usage in GB]:ram GB' \
  '--tmpdir=[location for temporary storage]:temp dir:_files -/' \
  '--quiet[suppress screen output]' \
  '--mapqual=[minimum read mapping quality]:quality' \
  '--basequal=[minimum base quality]:quality' \
  '--mincov=[minimum site depth to call allele]:depth' \
  '--minfrac=[minimum proportion for variant call]:fraction' \
  '--minqual=[minimum VCF QUAL value]:quality' \
  '--maxsoft=[maximum soft-clipped bases]:bases' \
  '--rgid=[read group ID / sample name]:RGID' \
  '--bwaopt=[extra options for bwa mem]:options' \
  '--fbopt=[extra options for freebayes]:options' \
  && ret=0

return ret
