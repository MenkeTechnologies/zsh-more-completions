#compdef dura

# Zsh completion for dura (background git commit saver)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'serve:start background watcher process'
      'watch:watch a repository for changes'
      'unwatch:stop watching a repository'
      'kill:stop the background process'
      'help:show help for a subcommand'
    )
    _describe -t commands 'dura subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      watch|unwatch)
        _directories && ret=0
        ;;
      help)
        local -a subcmds=(serve watch unwatch kill help)
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
