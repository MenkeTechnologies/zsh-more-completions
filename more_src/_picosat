#compdef picosat picomus

local curcontext="$curcontext" state line ret=1

case $service in
  (picosat)
    _arguments -C \
      '-h[show help]' \
      '--help[show help]' \
      '-v[verbose]' \
      '-V[version]' \
      '--version[show version]' \
      '-f[ignore comments]' \
      '-n[do not print satisfying assignment]' \
      '-p[partial assignment only]' \
      '-a+[force assumption]:lit:' \
      '-c+[trace cores file]:file:_files' \
      '-T+[trace file]:file:_files' \
      '-r+[RUP trace file]:file:_files' \
      '-s+[seed]:n:' \
      '-i+[turn on internal assignment phase]:n:(0 1 2 3)' \
      '-l+[propagation limit]:n:' \
      '-G+[global default phase]:n:' \
      '-o+[output file]:file:_files' \
      '*: :_files -g "*.cnf *.dimacs"' && ret=0 ;;
  (picomus)
    _arguments -C \
      '-h[show help]' \
      '-v[verbose]' \
      '-V[version]' \
      '*: :_files -g "*.cnf *.dimacs"' && ret=0 ;;
esac

return ret
