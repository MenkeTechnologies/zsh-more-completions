#compdef hbase-master hbase
# _hbase-master — Apache HBase master / shell launcher (hbase script dispatches to all per-role processes: shell, master, regionserver, zookeeper, rest, thrift, thrift2, hbck, hbtop, snapshot, version, classpath; --config alt conf dir, daemons accept start/stop/foreground; positional argument is the subcommand)
# upstream: https://github.com/apache/hbase
# Subcommands from Apache HBase bin/hbase on tip.

_hbase-master() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--config+[config dir]:dir:_files -/' \
        '1: :->role' \
        '*::arg:->args'
    case $state in
        role) _describe -t commands 'hbase role' '(shell master regionserver zookeeper rest thrift thrift2 hbck hbtop snapshot version classpath canary completebulkload ltt mapredcp pe org.apache.hadoop.hbase.snapshot.ExportSnapshot procedure)' ;;
        args)
            case $line[1] in
                master|regionserver|rest|thrift|thrift2|zookeeper) _describe -t commands 'daemon op' '(start stop foreground decommission)' ;;
                hbck) _arguments '--help[show help]' '-j+[hbck1 jar]:file:_files' '*::arg:' ;;
            esac
            ;;
    esac
}

_hbase-master "$@"
