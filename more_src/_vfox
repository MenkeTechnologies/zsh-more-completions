#compdef vfox

_vfox_cmds() {
    local -a commands=(
        'add:add a plugin'
        'remove:remove a plugin'
        'update:update a plugin'
        'info:show plugin info'
        'available:list available plugins'
        'search:search available versions'
        'install:install a version'
        'uninstall:uninstall a version'
        'use:set a version as active'
        'list:list installed versions'
        'current:show current version'
        'cd:launch shell in SDK directory'
        'env:show environment variables for a version'
        'activate:activate vfox in shell'
        'upgrade:upgrade vfox'
        'config:manage vfox configuration'
        'help:print help information'
    )
    _describe -t commands 'vfox command' commands
}

_vfox() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '--debug[enable debug mode]' \
        '1:command:_vfox_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                add)
                    _arguments \
                        '--source=[plugin source URL]:url' \
                        '--alias=[plugin alias]:alias' \
                        '1:plugin-name'
                    ;;
                remove|update|info)
                    _arguments '1:plugin-name'
                    ;;
                search)
                    _arguments '1:plugin-name'
                    ;;
                install)
                    _arguments \
                        '1:plugin-name@version'
                    ;;
                uninstall)
                    _arguments '1:plugin-name@version'
                    ;;
                use)
                    _arguments \
                        '(-g --global)'{-g,--global}'[set globally]' \
                        '(-p --project)'{-p,--project}'[set for project]' \
                        '(-s --session)'{-s,--session}'[set for session]' \
                        '1:plugin-name@version'
                    ;;
                list)
                    _arguments '1:plugin-name'
                    ;;
                current)
                    _arguments '1:plugin-name'
                    ;;
                cd)
                    _arguments '1:plugin-name'
                    ;;
                env)
                    _arguments \
                        '(-s --shell)'{-s,--shell}'=[shell type]:shell:(bash zsh fish powershell)' \
                        '1:plugin-name'
                    ;;
                config)
                    _arguments \
                        '1:action:(list get set unset)' \
                        '2:key' \
                        '3:value'
                    ;;
                activate)
                    _arguments \
                        '1:shell:(bash zsh fish powershell)'
                    ;;
            esac
            ;;
    esac
}

_vfox "$@"
