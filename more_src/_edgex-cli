#compdef edgex-cli
# Documentation: https://docs.edgexfoundry.org/2.3/getting-started/tools/Ch-CommandLineInterface/
# EdgeX Foundry command line interface

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-j --json)'{-j,--json}'[JSON formatted output]' \
  '(-c --command)'{-c,--command}'[use core-command service endpoint]' \
  '(-d --data)'{-d,--data}'[use core-data service endpoint]' \
  '(-m --metadata)'{-m,--metadata}'[use core-metadata service endpoint]' \
  '(-n --notifications)'{-n,--notifications}'[use support-notifications service endpoint]' \
  '(-s --scheduler)'{-s,--scheduler}'[use support-scheduler service endpoint]' \
  '1:command:(command config device deviceprofile deviceservice event help interval intervalaction metrics notification ping provisionwatcher reading subscription transmission version)' \
  '*::arg:->args' && ret=0

return ret
