#compdef xc

_xc() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-f --file)'{-f,--file}'[Markdown file]:file:_files -g "*.md"' \
    '(-s --short)'{-s,--short}'[Short list output]' \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '--no-color[Disable colored output]' \
    '1:task:->tasks' \
    '*::arg:->args'

  case $state in
    tasks)
      local -a tasks
      local mdfile="${opt_args[-f]:-${opt_args[--file]:-README.md}}"
      if [[ -f "$mdfile" ]]; then
        tasks=(${(f)"$(xc -s 2>/dev/null)"})
      fi
      _describe 'task' tasks
      ;;
  esac
}

_xc "$@"
