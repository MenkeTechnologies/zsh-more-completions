#compdef postmark-cli postmark
# _postmark-cli — Wildbit Postmark postmark-cli CLI command-line frontend wrapping the Postmark transactional email service REST API managing servers templates messages stats bounces inbounds domains sender-signatures-streams broadcast bulk-API-Server-token Account-token-suppressions outbound (Wildbit team, Go); cobra
# upstream: https://postmarkapp.com/

_postmark-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'server:server management'
        'template:template management'
        'email:send email'
        'batch:send batch'
        'inbound:inbound message operations'
        'bounce:bounce operations'
        'message:message operations'
        'stats:stats operations'
        'domain:domain operations'
        'sender:sender signature operations'
        'suppression:suppression list'
        'broadcast:broadcast operations'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server-token=+[token]:str:' \
        '--account-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'postmark-cli subcommand' sub ;;
        args)
            case $words[1] in
                server|template|inbound|bounce|message|domain|sender|suppression|broadcast|webhook) _arguments '1:op:(list get create update delete enable disable test bulk-import)' '*:id:' ;;
                email|batch) _arguments \
                    '--from=+[address]:str:' \
                    '--to=+[address]:str:' \
                    '--subject=+[text]:str:' \
                    '--html-body=+[file]:file:_files -g "*.html"' \
                    '--text-body=+[file]:file:_files -g "*.txt"' \
                    '--template-id=+[id]:str:' \
                    '--template-model=+[json]:str:' \
                    '*:payload:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_postmark-cli "$@"
