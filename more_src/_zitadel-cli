#compdef zitadel-cli zctl
# _zitadel-cli — Zitadel zitadel-cli zctl CLI command-line frontend wrapping the Zitadel open-source self-hosted Identity Access Management IAM platform providing user organization project application IDP authentication policies key user-grant action SAML OIDC OAuth2 password-policy multi-tenancy delegation management (Zitadel team, Go); cobra
# upstream: https://zitadel.com/

_zitadel-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user operations'
        'org:organization operations'
        'project:project operations'
        'app:application operations'
        'idp:identity provider operations'
        'policy:policy operations'
        'action:action operations'
        'instance:instance operations'
        'audit:audit log'
        'metadata:metadata operations'
        'key:key operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--token=+[token]:str:' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--key-file=+[file]:file:_files -g "*.json *.pem"' \
        '--instance-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zitadel-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|org|project|app|idp|policy|action|instance|key|metadata) _arguments '1:op:(list get create update delete enable disable assign unassign)' '*:id:' ;;
            esac
            ;;
    esac
}

_zitadel-cli "$@"
