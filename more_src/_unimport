#compdef unimport

_arguments -s \
  '--color=[output color]:when:(auto always never)' \
  '--check[print files with unused imports]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '--disable-auto-discovery-config[disable auto config discovery]' \
  '--include=[file include pattern]:regex:' \
  '--exclude=[file exclude pattern]:regex:' \
  '--gitignore[exclude .gitignore patterns]' \
  '--ignore-init[ignore __init__.py]' \
  '--include-star-import[include star imports]' \
  '(-d --diff)'{-d,--diff}'[print diff]' \
  '(-r --remove)'{-r,--remove}'[remove unused imports]' \
  '(-p --permission)'{-p,--permission}'[ask permission]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:path:_files -g "*.py"'
