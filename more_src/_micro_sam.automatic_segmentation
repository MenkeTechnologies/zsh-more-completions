#compdef micro_sam.automatic_segmentation
# Documentation: https://computational-cell-analytics.github.io/micro-sam/micro_sam.html
# Segment Anything for Microscopy automatic segmentation CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input_path)'{-i,--input_path}'[input image path]:input:_files' \
  '(-o --output_path)'{-o,--output_path}'[output path]:output:_files' \
  '(-m --model_type)'{-m,--model_type}'[model type]:model:' \
  '(-c --checkpoint)'{-c,--checkpoint}'[checkpoint path]:checkpoint:_files' \
  '(-d --device)'{-d,--device}'[compute device]:device:(cpu cuda mps)' \
  '--pattern[file glob pattern]:pattern:' \
  '--tile_shape[tile shape]:tile shape:' \
  '--halo[tile halo]:halo:' \
  '--ndim[image dimensionality]:ndim:(2 3)' \
  '--mode[segmentation mode]:mode:(amg ais apg)' \
  '*:arg:_files' && ret=0

return ret
