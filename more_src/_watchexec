#compdef watchexec
# Documentation: https://github.com/watchexec/watchexec/blob/main/doc/watchexec.1.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for watchexec (file watcher/executor)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '*'{-w+,--watch=}'[Watch a specific file or directory]:path:_files' \
  '*'{-W+,--watch-non-recursive=}'[Watch a path but don'\''t recurse]:path:_files' \
  '*--watch-file=[Load paths to watch from file]:file:_files' \
  '-c[Clear screen before executing command]' \
  '--clear=[Clear screen before executing command]:mode:(clear reset)' \
  '-o+[How to handle currently-running command on update]:mode:(queue do-nothing restart signal)' \
  '--on-busy-update=[How to handle currently-running command on update]:mode:(queue do-nothing restart signal)' \
  '-r[Restart the process if it is still running]' \
  '--restart[Restart the process if it is still running]' \
  '*'{-s+,--signal=}'[Send a signal to the process when it is still running]:signal' \
  '--stop-signal=[Signal to send to stop the command]:signal' \
  '--stop-timeout=[Timeout for the stop signal]:timeout' \
  '*--map-signal=[Translate signals from one to another]:map' \
  '-d+[Debounce time]:duration' \
  '--debounce=[Debounce time]:duration' \
  '--stdin-quit[Exit when stdin closes]' \
  '--no-vcs-ignore[Skip auto-loading of VCS ignore files]' \
  '--no-project-ignore[Skip auto-loading of project-level ignore files]' \
  '--no-global-ignore[Skip auto-loading of global-level ignore files]' \
  '--no-default-ignore[Skip auto-loading of default ignore files]' \
  '--no-discover-ignore[Skip auto-detection of ignore files]' \
  '--ignore-nothing[Do not ignore anything at all]' \
  '-p[Wait until first change before running command]' \
  '--postpone[Wait until first change before running command]' \
  '--delay-run=[Sleep before running command]:duration' \
  '--poll=[Poll for changes at given interval]:duration' \
  '--project-origin=[Set the project origin]:path:_directories' \
  '--workdir=[Set the working directory]:path:_directories' \
  '*'{-e+,--exts=}'[Filename extensions to filter to]:extensions' \
  '*'{-f+,--filter=}'[Filename patterns to filter to]:pattern' \
  '*--filter-file=[Load a filter file]:file:_files' \
  '*-j+[Filter programs (jaq)]:program' \
  '*--filter-prog=[Filter programs (jaq)]:program' \
  '*'{-i+,--ignore=}'[Filename patterns to ignore]:pattern' \
  '*--ignore-file=[Load an ignore file]:file:_files' \
  '--fs-events=[Filesystem events to watch for]:events:(access create remove rename modify metadata)' \
  '--no-meta[Do not emit fs events for metadata changes]' \
  '--print-events[Print events that trigger actions]' \
  '--shell=[Use a different shell]:shell' \
  '-n[Shell-less mode (equivalent to --shell=none)]' \
  '*'{-E+,--env=}'[Add env vars to the command]:var=value' \
  '--emit-events-to=[How to emit events]:target:(environment stdio file json-stdio json-file none)' \
  '--only-emit-events[Only emit events, do not run command]' \
  '-N[Alert when command completes]' \
  '--notify[Alert when command completes]' \
  '--color=[When to use terminal colours]:when:(auto always never)' \
  '--timings[Print debug timings]' \
  '--timeout=[Maximum command runtime before being killed]:duration' \
  '-q[Suppress output from watchexec]' \
  '--quiet[Suppress output from watchexec]' \
  '--bell[Ring terminal bell on command completion]' \
  '--exit-on-error[Exit when an error occurs while running command]' \
  '--no-process-group[Do not use a process group]' \
  '--wrap-process=[How to wrap the command in a process group]:mode:(group session none)' \
  '-i[Treat command as interactive]' \
  '--interactive[Treat command as interactive]' \
  '--socket=[Listen on socket and pass FD to command]:spec' \
  '--completions=[Generate shell completions]:shell:(bash elvish fish nu powershell zsh)' \
  '*-v[Increase log verbosity]' \
  '*--verbose[Increase log verbosity]' \
  '--log-file=[Write diagnostic logs to file]:file:_files' \
  '--manual[Show the manual page]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '*::command:_command_names -e' && ret=0

return ret
