#compdef watchexec

# Zsh completion for watchexec (file watcher/executor)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-w+[Watch a specific file or directory]:path:_files' \
  '--watch=[Watch a specific file or directory]:path:_files' \
  '-W[Wait for command to finish before re-executing on change]' \
  '--watch-when-idle[Wait for command to finish before re-executing on change]' \
  '-c[Clear screen before executing command]' \
  '--clear[Clear screen before executing command]' \
  '-r[Restart the process if it is still running]' \
  '--restart[Restart the process if it is still running]' \
  '-s+[Send a signal to the process when it is still running]:signal:(SIGHUP SIGINT SIGQUIT SIGTERM SIGKILL SIGUSR1 SIGUSR2)' \
  '--signal=[Send a signal to the process when it is still running]:signal:(SIGHUP SIGINT SIGQUIT SIGTERM SIGKILL SIGUSR1 SIGUSR2)' \
  '--stop-signal=[Signal to send to stop the command]:signal:(SIGHUP SIGINT SIGQUIT SIGTERM SIGKILL SIGUSR1 SIGUSR2)' \
  '--stop-timeout=[Timeout for the stop signal]:timeout' \
  '-d+[Debounce time in milliseconds]:ms' \
  '--debounce=[Debounce time in milliseconds]:ms' \
  '--stdin-quit[Exit when stdin closes]' \
  '--no-vcs-ignore[Skip auto-loading of VCS ignore files]' \
  '--no-project-ignore[Skip auto-loading of project-level ignore files]' \
  '--no-global-ignore[Skip auto-loading of global-level ignore files]' \
  '--no-default-ignore[Skip auto-loading of default ignore files]' \
  '--no-discover-ignore[Skip auto-detection of ignore files]' \
  '--ignore-nothing[Do not ignore anything at all]' \
  '-p+[Set the project origin]:path:_directories' \
  '--project-origin=[Set the project origin]:path:_directories' \
  '--workdir=[Set the working directory]:path:_directories' \
  '-e+[Filename extensions to filter to]:extensions' \
  '--exts=[Filename extensions to filter to]:extensions' \
  '-f+[Filename patterns to filter to]:pattern' \
  '--filter=[Filename patterns to filter to]:pattern' \
  '--filter-file=[Load a filter file]:file:_files' \
  '-i+[Filename patterns to ignore]:pattern' \
  '--ignore=[Filename patterns to ignore]:pattern' \
  '--ignore-file=[Load an ignore file]:file:_files' \
  '--fs-events=[Filesystem events to watch for]:events:(access create remove rename modify metadata)' \
  '--no-meta[Do not emit fs events for metadata changes]' \
  '--print-events[Print events that trigger actions]' \
  '--shell=[Use a different shell]:shell:(default none bash zsh fish powershell cmd)' \
  '-n[Do not use a shell]' \
  '--no-shell-long[Do not use a shell]' \
  '-E+[Add env vars to the command]:var=value' \
  '--env=[Add env vars to the command]:var=value' \
  '--no-environment[Do not set WATCHEXEC_* environment variables]' \
  '--emit-events-to=[Where to emit events]:target:(environment stdin file json-stdin none)' \
  '--only-emit-events[Only emit events, do not run command]' \
  '-N[Alert when command completes]' \
  '--notify[Alert when command completes]' \
  '--color=[When to use terminal colours]:when:(auto always never)' \
  '--timings[Print debug timings]' \
  '-q[Suppress output from watchexec]' \
  '--quiet[Suppress output from watchexec]' \
  '--bell[Ring terminal bell on command completion]' \
  '--completions=[Generate shell completions]:shell:(zsh bash fish powershell elvish)' \
  '-v[Increase log verbosity]' \
  '--verbose[Increase log verbosity]' \
  '--log-file=[Write diagnostic logs to file]:file:_files' \
  '--manual[Show the manual page]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '*::command:_command_names -e' && ret=0

return ret
