#compdef newrelic-cli2
# _newrelic-cli2 — New Relic newrelic-cli2 CLI command-line frontend wrapping the New Relic One observability platform CLI providing apm browser synthetics infrastructure mobile logs-in-context applications agent install profile workload nrql alerts policy condition channel events nrdb dashboards entity diagnose org user license-keys api-key NRQL-query NRDB-event-streaming (New Relic team, Go); cobra
# upstream: https://github.com/newrelic/newrelic-cli

_newrelic-cli2() {
    local -a sub=(
        'agent:agent operations'
        'alerts:alerts operations'
        'apiAccess:API access management'
        'apm:APM operations'
        'completion:generate shell completion'
        'config:config operations'
        'decode:decode an entity GUID'
        'diagnose:diagnose connection'
        'edge:edge operations'
        'entity:entity operations'
        'events:events operations'
        'install:install integrations'
        'logs:logs operations'
        'nerdgraph:run a NerdGraph query'
        'nerdstorage:nerdstorage operations'
        'nrql:NRQL operations'
        'org:organization'
        'profile:profile operations'
        'reporting:reporting'
        'synthetics:synthetics operations'
        'user:user operations'
        'utils:utility'
        'workload:workload operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--trace[trace]' \
        '--accountId=+[id]:n:' \
        '-a+[accountId]:n:' \
        '--profile=+[name]:str:' \
        '-p+[profile]:str:' \
        '--format=+[fmt]:f:(JSON YAML Plain Text)' \
        '-f+[format]:f:(JSON YAML Plain Text)' \
        '--plain[plain output]' \
        '--region=+[name]:r:(US EU Staging)' \
        '--apiKey=+[key]:str:' \
        '--insightsInsertKey=+[key]:str:' \
        '--licenseKey=+[key]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'newrelic-cli subcommand' sub ;;
        args)
            case $words[1] in
                alerts|apm|entity|events|nrql|profile|synthetics|workload|user|org) _arguments '1:op:(list get create update delete describe query search)' '*:arg:' ;;
                install) _arguments '*:integration:' ;;
            esac
            ;;
    esac
}

_newrelic-cli2 "$@"
