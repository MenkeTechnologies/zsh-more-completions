#compdef svg-term
# Documentation: https://github.com/marionebl/svg-term-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--at=[frame timestamp ms]:ms:' \
  '--cast=[asciinema cast id]:id:' \
  '--command=[command to record]:cmd:' \
  '--from=[start ms]:ms:' \
  '--to=[end ms]:ms:' \
  '--height=[lines]:n:' \
  '--width=[cols]:n:' \
  '--help[show help]' \
  '--in=[input json]:file:_files' \
  '--out=[output file]:file:_files' \
  '--padding=[padding]:n:' \
  '--padding-x=[x padding]:n:' \
  '--padding-y=[y padding]:n:' \
  '--profile=[profile file]:file:_files' \
  '--term=[terminal type]:term:(iterm2 xrdb xresources terminator konsole terminal remmina termite tilda xcfe)' \
  '--window[window decorations]' \
  '--no-cursor[no cursor]' \
  '--no-optimize[no SVGO]' \
  '--version[show version]'
