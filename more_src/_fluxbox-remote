#compdef fluxbox-remote

# fluxbox-remote: send commands to a running Fluxbox WM
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:fluxbox command:(reload restart quit minimizeall raiseall lowerall stickall arrangewindows nextworkspace prevworkspace rightworkspace leftworkspace upworkspace downworkspace exec)' && ret=0
return ret
