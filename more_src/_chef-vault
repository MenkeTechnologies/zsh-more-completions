#compdef chef-vault
# _chef-vault — Chef chef-vault CLI for managing encrypted Chef data bags using shared client keys storing secrets with per-node ACL access list rotate decrypt update create destroy refresh-keys (chef-vault team, Ruby); Thor
# upstream: https://github.com/chef/chef-vault

_chef-vault() {
    local -a sub=(
        'create:create new vault'
        'decrypt:decrypt vault item'
        'delete:delete vault or item'
        'edit:edit vault item'
        'isvault:check if data bag is a vault'
        'itemtype:show item type'
        'list:list vaults'
        'remove:remove client from vault'
        'rotate:rotate vault keys'
        'show:show vault item'
        'update:update vault'
        'refresh:refresh vault'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[knife.rb file]:file:_files -g "*.rb knife.rb"' \
        '--config=+[knife.rb file]:file:_files -g "*.rb knife.rb"' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-k+[user key file]:file:_files -g "*.pem"' \
        '--key=+[user key file]:file:_files -g "*.pem"' \
        '-s+[server URL]:str:' \
        '--server-url=+[server URL]:str:' \
        '--no-color[no color]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'chef-vault subcommand' sub ;;
        args)
            case $words[1] in
                create|edit|update|decrypt|show|delete|rotate|remove|isvault|itemtype) _arguments \
                    '--search=+[query]:str:' \
                    '-S+[query]:str:' \
                    '--admins=+[csv]:str:' \
                    '-A+[csv]:str:' \
                    '--clients=+[csv]:str:' \
                    '--mode=+[m]:m:(client solo)' \
                    '--json=+[file]:file:_files -g "*.json"' \
                    '-J+[file]:file:_files -g "*.json"' \
                    '*:vault item:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_chef-vault "$@"
