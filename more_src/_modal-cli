#compdef modal-cli modal2
# _modal-cli — Modal modal-cli CLI command-line frontend wrapping the Modal serverless cloud Python compute platform managing apps containers volumes secrets functions jobs queues nfs notebooks shell run deploy logs ls cluster gpu environment image cron lambda token-set profile config (Modal team, Python); typer
# upstream: https://modal.com/

_modal-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'token:token operations'
        'profile:profile operations'
        'app:app operations'
        'run:run a function'
        'deploy:deploy an app'
        'serve:serve an app'
        'shell:open shell in a function'
        'logs:fetch logs'
        'list:list resources'
        'kill:kill a function'
        'volume:volume operations'
        'secret:secret operations'
        'environment:environment operations'
        'nfs:network filesystem operations'
        'queue:queue operations'
        'dict:dict operations'
        'image:image operations'
        'gpu:GPU operations'
        'cron:cron operations'
        'notebook:notebook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token-id=+[id]:str:' \
        '--token-secret=+[secret]:str:' \
        '--workspace=+[name]:str:' \
        '--profile=+[name]:str:' \
        '--environment=+[name]:str:' \
        '--app-id=+[id]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'modal-cli subcommand' sub ;;
        args)
            case $words[1] in
                run|deploy|serve|shell|logs|kill|list) _arguments '*:python file or function:_files -g "*.py"' ;;
                volume|secret|environment|nfs|queue|dict|image|gpu|cron|notebook|app|token|profile) _arguments '1:op:(list get create update delete put put-file get-file rm-file)' '*:name:' ;;
            esac
            ;;
    esac
}

_modal-cli "$@"
