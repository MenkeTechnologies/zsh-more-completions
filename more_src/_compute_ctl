#compdef compute_ctl
# _compute_ctl — Neon compute control sidecar (manages the per-endpoint Postgres process: install, configure, start, monitor, expose HTTP control API)
# upstream: https://github.com/neondatabase/neon
# Flags from compute_tools/src/bin/compute_ctl.rs on tip (clap-derive); --pgdata, --connstr, --compute-id are required.

_compute_ctl() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-b --pgbin)'{-b+,--pgbin=}'[path to postgres binary (env POSTGRES_PATH)]:file:_files' \
        '(-r --remote-ext-base-url)'{-r+,--remote-ext-base-url=}'[remote extension storage proxy base URL]:url:_urls' \
        '--external-http-port=[external HTTP port (client-facing)]:port:' \
        '--internal-http-port=[internal HTTP port (neon ext + local_proxy)]:port:' \
        '--http-port=[legacy alias of --external-http-port (Hadron)]:port:' \
        '(-D --pgdata)'{-D+,--pgdata=}'[Postgres data directory (required)]:dir:_files -/' \
        '(-C --connstr)'{-C+,--connstr=}'[Postgres connection string for control (required)]:connstr:' \
        '--privileged-role-name=[privileged role name (default neon_superuser)]:role:' \
        '--cgroup=[cgroup name (Linux only)]:cgroup:' \
        '--filecache-connstr=[file-cache connection string (Linux only)]:connstr:' \
        '--vm-monitor-addr=[VM monitor address (Linux only)]:addr:' \
        '--resize-swap-on-bind[resize swap when compute binds]' \
        '--set-disk-quota-for-fs=[filesystem path to apply disk quota to]:dir:_files -/' \
        '(-c --config)'{-c+,--config=}'[startup spec config file]:file:_files' \
        '(-i --compute-id)'{-i+,--compute-id=}'[compute id (required)]:id:' \
        '(-p --control-plane-uri)'{-p+,--control-plane-uri=}'[control-plane API base URL]:url:_urls' \
        '--installed-extensions-collection-interval=[interval for collecting installed ext stats (sec)]:sec:' \
        '--dev[development mode (skip VM-specific operations)]' \
        '--pg-init-timeout=[Postgres init timeout (sec)]:sec:' \
        '--lakebase-mode=[run in lakebase mode]:bool:(true false)'
}

_compute_ctl "$@"
