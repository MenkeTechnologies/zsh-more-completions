#compdef kgoss
# Documentation: https://github.com/goss-org/goss/blob/master/extras/kgoss/kgoss
# kgoss - Kubernetes wrapper for goss container testing

local ret=1

_arguments -s -S \
  '-i[container image url:tag]:image:' \
  '*-d[additional directory to copy to container]:directory:_files -/' \
  '*-e[environment variable KEY=value]:env:' \
  '-p[pause container on entry]' \
  '-c[custom entrypoint command]:command:' \
  '-a[arguments to pass to entrypoint]:args:' \
  '1:command:(run edit)' && ret=0

return ret
