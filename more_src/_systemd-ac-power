#compdef systemd-ac-power
# _systemd-ac-power (systemd power-state probe; returns success when the system is running on AC mains, failure when on battery; --low returns true only when the battery level is below the configured low-power threshold; useful in ConditionACPower= unit gating)
# upstream: https://github.com/systemd/systemd (src/ac-power)
# Flags from systemd src/ac-power/ac-power.c on tip.

_systemd-ac-power() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--low[low-battery threshold check]'
}

_systemd-ac-power "$@"
