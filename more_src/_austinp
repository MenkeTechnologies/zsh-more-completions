#compdef austinp
# _austinp — native-aware Python frame-stack sampler (P403n1x87/austin built with NATIVE)
# upstream: https://github.com/P403n1x87/austin
# Flags from src/argparse.c (argp_option options[]).

_austinp() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--usage[show usage]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-i --interval)'{-i+,--interval=}'[sampling interval (us/ms/s)]:dur:' \
        '(-t --timeout)'{-t+,--timeout=}'[startup wait (ms/s)]:dur:' \
        '(-c --cpu)'{-c,--cpu}'[on-CPU stacks only]' \
        '(-m --memory)'{-m,--memory}'[profile memory usage]' \
        '(-f --full)'{-f,--full}'[full metric set (time +mem -mem)]' \
        '(-p --pid)'{-p+,--pid=}'[attach to PID]:pid:_pids' \
        '(-w --where)'{-w+,--where=}'[dump all threads of PID]:pid:_pids' \
        '(-o --output)'{-o+,--output=}'[output samples file]:file:_files' \
        '(-C --children)'{-C,--children}'[attach to child processes]' \
        '(-x --exposure)'{-x+,--exposure=}'[sample for N seconds only]:secs:' \
        '(-P --pipe)'{-P,--pipe}'[pipe mode (no buffering)]' \
        '(-g --gc)'{-g,--gc}'[sample garbage-collector state]' \
        '(-k --kernel)'{-k,--kernel}'[sample kernel call stack (native only)]' \
        '*::command:_command_names -e'
}

_austinp "$@"
