#compdef sourmash
# _sourmash — Titus Brown sourmash CLI MinHash sketch-based comparison search compare gather tool for genomic and metagenomic DNA RNA protein data computing k-mer signatures producing Jaccard containment dataset-search index-based taxonomy classification GTDB NCBI Mash-screen-compatible (Titus Brown team, Python); click
# upstream: https://sourmash.readthedocs.io/

_sourmash() {
    local -a sub=(
        'sketch:compute signatures'
        'compare:compare two or more signatures'
        'search:search a signature against a database'
        'gather:gather composition of a metagenome'
        'index:build a database index from signatures'
        'compute:legacy compute signatures'
        'plot:plot a distance matrix'
        'lca:LCA classification operations'
        'tax:taxonomic analysis operations'
        'multigather:gather many queries'
        'prefetch:lightweight prefetch'
        'sig:operations on signatures'
        'storage:operations on storage'
        'categorize:categorize signatures'
        'watch:realtime search'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sourmash subcommand' sub ;;
        args)
            case $words[1] in
                sketch) _arguments \
                    '1:type:(dna protein translate fromfile)' \
                    '-p+[params]:str:' \
                    '-o+[output]:file:_files -g "*.sig *.sig.gz *.zip *.sqldb"' \
                    '--name=+[name]:str:' \
                    '*:input:_files -g "*.fa *.fasta *.fq *.fastq *.gz"' ;;
                search|gather|prefetch) _arguments \
                    '*:query+db:_files -g "*.sig *.sig.gz *.zip *.sqldb"' ;;
                index) _arguments \
                    '-k+[k]:n:' \
                    '*:output index+signatures:_files' ;;
                lca|tax|sig) _arguments '*:args:_files' ;;
            esac
            ;;
    esac
}

_sourmash "$@"
