#compdef dmimgcalc
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmimgcalc.html
# Perform arithmetic operations on one or two images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file or files]:infile:_files' \
  'infile2=[second input file or none]:infile2:_files' \
  'outfile=[output file name]:outfile:_files' \
  'operation=[arithmetic operation]:operation:(add sub mul div tst)' \
  'weight=[multiply infile before operation]:weight:' \
  'weight2=[multiply infile2 before operation]:weight2:' \
  'lookupTab=[header merging lookup table]:lookupTab:_files' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
