#compdef agentop
# Documentation: https://man.archlinux.org/search?q=agentop
# Reference accessed: 2026-05-16
# Source: cargo binstall agentop@1.0.0
# Probed via: --generate-completions zsh
# Repository: https://github.com/leboiko/claude-codex-pid-inspector

autoload -U is-at-least

_agentop() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--generate-completions=[Print a shell-completion script to stdout and exit]:SHELL:((bash\:"Bash shell completions"
zsh\:"Zsh shell completions"
fish\:"Fish shell completions"
powershell\:"PowerShell completions"
elvish\:"Elvish shell completions"))' \
'--json[Print a JSON snapshot to stdout and exit]' \
'--pretty[Indent the \`--json\` output (4 spaces). Ignored without \`--json\`]' \
'--list[Print a plain-text process table to stdout and exit]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_agentop_commands] )) ||
_agentop_commands() {
    local commands; commands=()
    _describe -t commands 'agentop commands' commands "$@"
}

if [ "$funcstack[1]" = "_agentop" ]; then
    _agentop "$@"
else
    compdef _agentop agentop
fi
