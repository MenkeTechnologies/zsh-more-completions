#compdef mesos-master

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--work_dir=[work directory]:dir:_files -/' \
  '--zk=[ZooKeeper URL]:url:' \
  '--quorum=[Raft quorum size]:n:' \
  '--ip=[bind IP]:addr:' \
  '--port=[bind port]:port:' \
  '--hostname=[hostname]:host:_hosts' \
  '--cluster=[cluster name]:name:' \
  '--credentials=[credentials file]:file:_files' \
  '--acls=[ACLs JSON]:json:' \
  '--rate_limits=[rate limit JSON]:json:' \
  '--firewall_rules=[firewall rules JSON]:json:' \
  '--allocation_interval=[allocation interval]:duration:' \
  '--allocator=[allocator class]:name:' \
  '--authenticate_agents=[require agent auth]:flag:(true false)' \
  '--authenticate_frameworks=[require framework auth]:flag:(true false)' \
  '--authenticate_http_frameworks=[require HTTP framework auth]:flag:(true false)' \
  '--authenticate_http_readonly=[require HTTP readonly auth]:flag:(true false)' \
  '--authenticate_http_readwrite=[require HTTP readwrite auth]:flag:(true false)' \
  '--authenticators=[authenticator list]:list:' \
  '--authorizers=[authorizer]:authorizer:' \
  '--http_authenticators=[HTTP authenticator list]:list:' \
  '--log_dir=[log directory]:dir:_files -/' \
  '--logbufsecs=[log buffer seconds]:secs:' \
  '--logging_level=[log level]:level:(INFO WARNING ERROR)' \
  '--max_completed_frameworks=[max completed frameworks]:n:' \
  '--max_completed_tasks_per_framework=[max completed tasks/framework]:n:' \
  '--max_unreachable_tasks_per_framework=[max unreachable tasks/framework]:n:' \
  '--registry=[registry persistence]:type:(in_memory replicated_log)' \
  '--registry_fetch_timeout=[registry fetch timeout]:duration:' \
  '--registry_store_timeout=[registry store timeout]:duration:' \
  '--registry_strict=[strict registry mode]:flag:(true false)' \
  '--roles=[whitelist of valid roles]:roles:' \
  '--weights=[role weights]:weights:' \
  '--webui_dir=[webui directory]:dir:_files -/' \
  '--master_contender=[master contender module]:name:' \
  '--master_detector=[master detector module]:name:' \
  '--ssl=[enable SSL]:flag:(true false)' \
  '--zk_session_timeout=[ZK session timeout]:duration:' && ret=0

return ret
