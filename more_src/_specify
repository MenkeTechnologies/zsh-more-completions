#compdef specify
# Documentation: https://man.archlinux.org/search?q=specify
# Reference accessed: 2026-05-16

# Zsh completion for specify CLI (GitHub Spec Kit)
# https://github.com/github/spec-kit

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:Initialize Spec Kit in a directory'
  'check:Verify required tools are installed'
  'version:Show version information'
  'help:Show help message'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'specify command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '--integration=[tailor setup for a specific agent]:agent:(claude cursor copilot gemini)' \
          '1:directory:_directories' && ret=0
        ;;
      (check|version|help)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
