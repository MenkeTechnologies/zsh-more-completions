#compdef halp
# Documentation: https://github.com/orhun/halp
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*--check=[test a custom argument]:arg:' \
  '--no-version[skip version checking]' \
  '--no-help[skip help checking]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '(-t --timeout)'{-t+,--timeout=}'[command timeout in seconds (default 5)]:seconds:' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      'plz:access manual pages and cheat sheets'
    )
    _alternative \
      'subcommands:command:_describe -t commands "halp command" cmds' \
      'binaries:command:_command_names -e' && ret=0
    ;;
  (args)
    case ${words[1]} in
      (plz)
        _arguments -s -S \
          '(-m --man-cmd)'{-m+,--man-cmd=}'[custom man command]:cmd:' \
          '--cheat-sh-url=[custom cheat.sh URL]:url:' \
          '(-p --pager)'{-p+,--pager=}'[pager application]:pager:' \
          '--no-pager[disable pager]' \
          '*:command:_command_names -e' && ret=0
        ;;
    esac
    ;;
esac

return ret
