#compdef tsresync
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsresync.cpp
# tsresync - resynchronize a corrupted transport stream file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --continue)'{-c,--continue}'[continue resynchronizing after loss of synchronization]' \
  '--header-size=[size of extra data preceding each packet]:bytes:' \
  '(-k --keep)'{-k,--keep}'[keep TS packet size from input to output file]' \
  '(-m --min-contiguous)'{-m,--min-contiguous}'=[min size of contiguous valid packets]:bytes:' \
  '(-p --packet-size)'{-p,--packet-size}'=[expected TS packet size in bytes]:bytes:' \
  '(-o --output)'{-o,--output}'=[output file name]:file:_files' \
  '(-s --sync-size)'{-s,--sync-size}'=[initial bytes to analyze to find sync]:bytes:' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
