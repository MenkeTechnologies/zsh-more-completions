#compdef bonk
# Documentation: https://github.com/elliot40404/bonk
# Source: https://github.com/elliot40404/bonk/blob/main/src/main.rs
# Reference accessed: 2026-06-01
# Rust touch+mkdir hybrid; trailing slash in arg creates directory.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '*:file or dir/:_files' \
    && ret=0

return ret
