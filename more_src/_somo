#compdef somo
# Documentation: https://github.com/theopfr/somo
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a _somo_sort

_somo_sort=(proto local_port remote_address remote_port program pid state)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-k --kill)'{-k,--kill}'[interactive killing of processes]' \
  '(-t --tcp)'{-t,--tcp}'[include TCP connections]' \
  '(-u --udp)'{-u,--udp}'[include UDP connections]' \
  '--ip=[filter connections by remote IP address]:address:' \
  '--remote-port=[filter connections by remote port]:port:' \
  '(-p --port)'{-p+,--port=}'[filter connections by local port]:port:' \
  '--program=[filter connections by program name]:name:' \
  '--pid=[filter connections by PID]:pid:' \
  '--format=[custom output formatting]:format:' \
  '--json[output in JSON]' \
  '(-o --open)'{-o,--open}'[filter by open connections]' \
  '(-l --listen)'{-l,--listen}'[filter by listening connections]' \
  '(-e --established)'{-e,--established}'[filter by established connections]' \
  '(-4 --ipv4)'{-4,--ipv4}'[display IPv4 connections only]' \
  '(-6 --ipv6)'{-6,--ipv6}'[display IPv6 connections only]' \
  '(-c --compact)'{-c,--compact}'[compact table view]' \
  '(-r --reverse)'{-r,--reverse}'[reverse order of the table]' \
  '(-s --sort)'{-s+,--sort=}"[sort by column name]:field:($_somo_sort)" \
  '--config-file[display config file path]' \
  '--no-config[ignore configuration file]' \
  '(-a --annotate-remote-port)'{-a,--annotate-remote-port}'[annotate remote ports with service names]' \
  '--no-pager[disable automatic paging]' \
  '1:subcommand:(generate-completions generate-config-file help)' && ret=0

return ret

