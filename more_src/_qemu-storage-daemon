#compdef qemu-storage-daemon
# _qemu-storage-daemon — QEMU qemu-storage-daemon (standalone block-layer daemon exposing virtual disks via NBD/qmp/vhost-user-blk; --blockdev backend, --export NBD export, --monitor QMP socket, --nbd-server addr, --object backing object, --chardev, --pidfile, -V version)
# upstream: https://gitlab.com/qemu-project/qemu (qemu-storage-daemon)
# Flags from qemu storage-daemon/qemu-storage-daemon.c on tip.

_qemu-storage-daemon() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '*--blockdev+[blockdev spec]:spec:' \
        '*--export+[export spec]:spec:' \
        '*--object+[object spec]:spec:' \
        '*--monitor+[monitor spec]:spec:' \
        '*--chardev+[chardev spec]:spec:' \
        '*--nbd-server+[nbd-server spec]:spec:' \
        '--pidfile+[pidfile]:file:_files' \
        '--daemonize[daemonize]' \
        '-T+[trace spec]:spec:' \
        '--trace+[trace spec]:spec:'
}

_qemu-storage-daemon "$@"
