#compdef edje_decc

# edje_decc: decompile .edj into source .edc
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-current-dir[extract in current dir]' \
  '-o[output dir]:dir:_files -/' \
  '--output-dir=[output dir]:dir:_files -/' \
  '*:file:_files -g "*.edj"' && ret=0
return ret
