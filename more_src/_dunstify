#compdef dunstify
# Documentation: https://github.com/dunst-project/dunst/blob/master/docs/dunstify.1.pod
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dunstify - dunst notification tool

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --appname)'{-a,--appname}'[application name]:name' \
  '(-u --urgency)'{-u,--urgency}'[urgency level]:level:(low normal critical)' \
  '(-t --timeout)'{-t,--timeout}'[timeout in milliseconds]:ms' \
  '(-i --icon)'{-i,--icon}'[icon]:icon path:_files' \
  '(-I --raw_icon)'{-I,--raw_icon}'[path to raw icon]:file:_files' \
  '(-c --capabilities)'{-c,--capabilities}'[print server capabilities]' \
  '(-s --serverinfo)'{-s,--serverinfo}'[print server info]' \
  '(-p --printid)'{-p,--printid}'[print notification ID]' \
  '(-r --replace)'{-r,--replace}'[replace notification with ID]:id' \
  '(-C --close)'{-C,--close}'[close notification by ID]:id' \
  '(-b --block)'{-b,--block}'[block until action invoked or closed]' \
  '(-A --action)'{-A,--action}'[add action]:action,label' \
  '1:summary' \
  '2:body'
