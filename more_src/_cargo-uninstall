#compdef cargo-uninstall
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-uninstall.html

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --package)'{-p+,--package=}'[package to uninstall]:package' \
  '*--bin=[only uninstall specified binary]:binary' \
  '--root=[directory to uninstall packages from]:directory:_directories' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '*'{-v,--verbose}'[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
  '*-Z+[unstable cargo flag]:flag' \
  '*:crate'
