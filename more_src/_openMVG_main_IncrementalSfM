#compdef openMVG_main_IncrementalSfM
# Documentation: https://github.com/openMVG/openMVG/blob/develop/docs/sphinx/rst/software/SfM/SfM.rst
# openMVG: incremental Structure from Motion pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input_file)'{-i,--input_file}'[input SfM_Data scene]:file:_files' \
  '(-m --match_dir)'{-m,--match_dir}'[matches directory]:dir:_files -/' \
  '(-M --match_file)'{-M,--match_file}'[match file to use]:file:_files' \
  '(-o --output_dir)'{-o,--output_dir}'[output directory]:dir:_files -/' \
  '(-s --sfm_engine)'{-s,--sfm_engine}'[SfM engine]:engine:(INCREMENTAL INCREMENTALV2)' \
  '(-f --refine_intrinsic_config)'{-f,--refine_intrinsic_config}'[intrinsic refinement option]:cfg' \
  '(-e --refine_extrinsic_config)'{-e,--refine_extrinsic_config}'[extrinsic refinement option]:cfg' \
  '(-P --prior_usage)'{-P,--prior_usage}'[use motion priors]' \
  '(-a --initial_pair_a)'{-a,--initial_pair_a}'[first image of initial pair]:image:_files' \
  '(-b --initial_pair_b)'{-b,--initial_pair_b}'[second image of initial pair]:image:_files' \
  '(-c --camera_model)'{-c,--camera_model}'[camera model for unknown intrinsics]:model' \
  '(-t --triangulation_method)'{-t,--triangulation_method}'[triangulation method]:method' \
  '(-r --resection_method)'{-r,--resection_method}'[resection method]:method' \
  '(-S --sfm_initializer)'{-S,--sfm_initializer}'[SfM initializer method]:init' \
  '*:arg:_files' && ret=0

return ret
