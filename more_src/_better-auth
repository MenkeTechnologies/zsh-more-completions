#compdef better-auth
# Documentation: https://www.better-auth.com/docs/concepts/cli
# Reference accessed: 2026-05-23
# Verified: npm view @better-auth/cli bin; Better Auth CLI docs at the URL above.

# Zsh completion for better-auth - Better Auth project CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize Better Auth in your project'
  'migrate:apply Better Auth schema to the database'
  'generate:generate Better Auth schema for your ORM'
  'secret:generate a secret key'
  'info:display diagnostic information'
  'login:demo device authorization flow'
  'mcp:add Better Auth MCP server to MCP clients'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'better-auth command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -C           '--name=[application name]:name:'           '--framework=[framework]:framework:(Next.js)'           '--plugins=[plugins]:plugins:'           '--database=[database]:database:(SQLite)'           '--package-manager=[package manager]:manager:(npm pnpm yarn bun)' && ret=0
        ;;
      (migrate|generate)
        _arguments -C           '--config=[Better Auth config path]:file:_files'           '--yes[skip confirmation prompt]'           '--output=[schema output path]:file:_files' && ret=0
        ;;
      (info)
        _arguments -C           '--config=[Better Auth config path]:file:_files'           '--json[output as JSON]' && ret=0
        ;;
      (login|mcp)
        _arguments '*::args:' && ret=0
        ;;
      (*)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
