#compdef genePredHisto
# UCSC kent: get data for generating histograms from a genePred file

local ret=1

_arguments -s -S \
  '-ids[output a second column with the gene name, useful for finding outliers]' \
  '1:what:' \
  '2:genePred file:_files' \
  '3:histogram output:_files' && ret=0

return ret
