#compdef prm

_prm_commands() {
  local -a commands=(
    'add:Add a new project'
    'edit:Edit a project'
    'list:List all projects'
    'remove:Remove a project'
    'start:Start a project'
    'stop:Stop a project'
    'rename:Rename a project'
    'active:Show active project'
    'help:Show help'
  )
  _describe 'command' commands
}

_prm_projects() {
  local -a projects
  projects=(${(f)"$(prm list 2>/dev/null | grep -v '^\s*$')"})
  _describe 'project' projects
}

_prm() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:command:_prm_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        start|stop|edit|remove|rename)
          _arguments \
            '1:project:_prm_projects'
          ;;
        add)
          _arguments \
            '1:project name'
          ;;
      esac
      ;;
  esac
}

_prm "$@"
