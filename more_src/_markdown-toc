#compdef markdown-toc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--append=[append a string to the end of the TOC]:string' \
  '--bullets=[bullets to use for each heading level]:bullets' \
  '--maxdepth=[use headings up to this depth]:depth:(1 2 3 4 5 6)' \
  '--firsth1[include the first h1-level heading]' \
  '--no-firsth1[exclude the first h1-level heading]' \
  '--stripHeadingTags[strip HTML tags from headings]' \
  '-i[edit the file in place]' \
  '--indent=[indentation to use]:indent' \
  '--json[output as JSON]' \
  '*:file:_files -g "*.md"' && ret=0

return ret
