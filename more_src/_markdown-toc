#compdef markdown-toc
# Documentation: https://github.com/jonschlinkert/markdown-toc
# Reference accessed: 2026-05-19
# Verified: jonschlinkert/markdown-toc README CLI section.
# Removed from prior file: bogus man.archlinux.org URL; --firsth1
# (only --no-firsth1 documented); --stripHeadingTags (real is
# --no-stripHeadingTags).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--append=[append a string to the end of the TOC]:string' \
  '*--bullets=[bullets to use for each heading level]:bullets' \
  '--maxdepth=[use headings up to this depth]:depth:(1 2 3 4 5 6)' \
  '--no-firsth1[exclude the first h1-level heading]' \
  '--no-stripHeadingTags[preserve HTML tags in headings]' \
  '-i[edit the input file in place]' \
  '--indent=[indentation to use]:indent' \
  '--json[output as JSON]' \
  '*:file:_files -g "*.(md|markdown)(-.)"' && ret=0

return ret
