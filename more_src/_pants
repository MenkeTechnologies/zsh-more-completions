#compdef pants

# Zsh completion for pants - build system

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show version]'
  '--pants-version[set the pants version]:version:'
  '--pants-config-files[set config files]:files:_files'
  '--pants-workdir[set the work directory]:dir:_files -/'
  '--pythonpath[set additional Python paths]:dirs:'
  '--backend-packages[set backend packages]:packages:'
  '--plugins[set plugins]:plugins:'
  '(-l --level)'{-l,--level}'[set log level]:level:(trace debug info warn error)'
  '--show-log-target[show log target]'
  '--colors[enable colored output]'
  '--no-colors[disable colored output]'
  '--tag[filter by tag]:tags:'
  '--exclude-target-regexp[exclude targets matching regexp]:regex:'
  '--spec-files[read targets from spec files]:files:_files'
  '(-k --filter)'{-k,--filter}'[filter targets]:filter:'
  '--changed-since[act on files changed since ref]:ref:'
  '--changed-dependents[include dependents of changed targets]:mode:(none direct transitive)'
  '--process-total-child-memory-usage[track total child memory usage]'
  '--process-per-child-memory-usage[track per-child memory usage]'
  '--remote-cache-read[enable remote cache reading]'
  '--remote-cache-write[enable remote cache writing]'
  '--remote-execution[enable remote execution]'
  '--remote-store-address[set remote store address]:addr:'
  '--remote-execution-address[set remote execution address]:addr:'
  '--print-stacktrace[print full stacktrace on errors]'
  '--native-options-validation[enable native options validation]'
  '(-d --logdir)'{-d,--logdir}'[set log directory]:dir:_files -/'
  '--loop[run in a loop, re-executing when files change]'
  '--pantsd[enable the pants daemon]'
  '--no-pantsd[disable the pants daemon]'
)

local -a subcommands=(
  'check:run type checking'
  'count-loc:count lines of code'
  'export:export project data'
  'export-codegen:export generated code'
  'fix:auto-fix source files'
  'fmt:auto-format source files'
  'generate-lockfiles:generate lockfiles'
  'generate-snapshots:generate test snapshots'
  'lint:run linters'
  'list:list targets'
  'package:create distributable packages'
  'publish:publish packages'
  'repl:open a REPL'
  'run:run a target'
  'tailor:auto-generate BUILD file targets'
  'test:run tests'
  'update-build-files:update BUILD files'
  'version:show version information'
  'help:show help'
  'help-advanced:show advanced help'
  'help-all:show all help'
  'roots:list source roots'
  'peek:display BUILD file target info as JSON'
  'paths:show dependency paths between targets'
  'dependents:list targets that depend on the given targets'
  'dependencies:list target dependencies'
  'filedeps:list files that targets depend on'
  'filter:filter targets by predicates'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'pants subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (run)
        _arguments -s -S \
          $global_opts \
          '--args[arguments to pass to the target]:args:' \
          '--debug-adapter[run under a debug adapter]' \
          '--cleanup[clean up the chroot after run]' \
          '--no-cleanup[do not clean up the chroot after run]' \
          '*:target:_files' && ret=0
        ;;
      (test)
        _arguments -s -S \
          $global_opts \
          '--debug[run tests sequentially in an interactive process]' \
          '--debug-adapter[run tests under a debug adapter]' \
          '--force[force running tests even if cached]' \
          '--open-coverage[open the coverage report in a browser]' \
          '--use-coverage[generate a coverage report]' \
          '*:target:_files' && ret=0
        ;;
      (fmt|fix|lint)
        _arguments -s -S \
          $global_opts \
          '--only[only run the specified tool]:tool:' \
          '*:target:_files' && ret=0
        ;;
      (package|check)
        _arguments -s -S \
          $global_opts \
          '*:target:_files' && ret=0
        ;;
      (*)
        _arguments -s -S $global_opts '*:target:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
