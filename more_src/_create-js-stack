#compdef create-js-stack
# Documentation: https://www.npmjs.com/package/create-js-stack
# Reference accessed: 2026-05-23
# Verified: npm view create-js-stack bin; npm readme Usage and Agent-Focused Commands.

# Zsh completion for create-js-stack - end-to-end type-safe TypeScript stack scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[use default configuration]' \
  '--template=[stack template]:template:(mern pern t3 uniwind none)' \
  '--database=[database type]:database:(none sqlite postgres mysql mongodb)' \
  '--orm=[ORM type]:orm:(none drizzle prisma mongoose)' \
  '--dry-run[validate configuration without writing files]' \
  '--auth=[authentication provider]:auth:(better-auth clerk none)' \
  '--payments=[payments provider]:payments:(polar none)' \
  '--frontend=[frontend types; repeatable]:frontend:(tanstack-router react-router tanstack-start next nuxt svelte solid astro native-bare native-uniwind native-unistyles none)' \
  '--addons=[addons; repeatable]:addon:(pwa tauri electrobun starlight biome lefthook husky mcp turborepo nx fumadocs ultracite oxlint opentui wxt skills none)' \
  '--examples=[examples; repeatable]:example:(todo ai none)' \
  '--git[initialize git repository]' \
  '--no-git[skip git initialization]' \
  '--package-manager=[package manager]:manager:(npm pnpm bun)' \
  '--install[install dependencies]' \
  '--no-install[skip dependency installation]' \
  '--db-setup=[database setup]:db-setup:(turso d1 neon supabase prisma-postgres planetscale mongodb-atlas docker none)' \
  '--web-deploy=[web deployment]:web-deploy:(cloudflare none)' \
  '--server-deploy=[server deployment]:server-deploy:(cloudflare none)' \
  '--backend=[backend framework]:backend:(hono express fastify elysia convex self none)' \
  '--runtime=[runtime]:runtime:(bun node workers none)' \
  '--api=[API type]:api:(trpc orpc none)' \
  '--directory-conflict=[directory conflict strategy]:strategy:(merge overwrite increment error)' \
  '--manual-db[skip automatic database setup prompts]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' create-json add-json schema mcp && ret=0
    ;;
  args)
    case $line[1] in
      create-json|add-json)
        _arguments -C \
          '--input=[JSON payload for agent workflows]:json:' && ret=0
        ;;
      schema)
        _arguments -C \
          '--name=[schema to emit]:name:(all createInput addInput addonOptions dbSetupOptions cli)' && ret=0
        ;;
      mcp)
        _arguments -C && ret=0
        ;;
      *)
        _arguments -C \
          '(-y --yes)'{-y,--yes}'[use default configuration]' \
          '--template=[stack template]:template:(mern pern t3 uniwind none)' \
          '--database=[database type]:database:(none sqlite postgres mysql mongodb)' \
          '--orm=[ORM type]:orm:(none drizzle prisma mongoose)' \
          '--dry-run[validate without writing files]' \
          '--auth=[authentication provider]:auth:(better-auth clerk none)' \
          '--backend=[backend framework]:backend:(hono express fastify elysia convex self none)' \
          '--package-manager=[package manager]:manager:(npm pnpm bun)' \
          '--no-install[skip dependency installation]' \
          ':project directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
