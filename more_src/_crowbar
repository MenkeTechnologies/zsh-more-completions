#compdef crowbar
# _crowbar — galkan crowbar CLI brute force tool stitching wrappers around openvpn rdesktop ssh vnc with arbitrary IP wordlist supporting OpenVPN RDP SSH-private-key auth VNC-RFB password guessing efficiently parallel multi-host enumeration producing structured pass-or-fail credential discoveries (galkan team, Python); argparse
# upstream: https://github.com/galkan/crowbar

_crowbar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-b+[brute service]:b:(openvpn rdp sshkey vnckey vmauthd)' \
        '--brute=+[service]:b:(openvpn rdp sshkey vnckey vmauthd)' \
        '-s+[target]:_hosts' \
        '--server=+[ip]:_hosts' \
        '-S+[server file]:file:_files' \
        '--server-file=+[file]:file:_files' \
        '-u+[user]:str:' \
        '--username=+[user]:str:' \
        '-U+[user file]:file:_files' \
        '--username-file=+[file]:file:_files' \
        '-c+[password]:str:' \
        '--passwd=+[password]:str:' \
        '-C+[password file]:file:_files' \
        '--passwd-file=+[file]:file:_files' \
        '-k+[key file]:file:_files' \
        '--keyfile=+[file]:file:_files' \
        '-K+[keys dir]:dir:_files -/' \
        '--keyfile-directory=+[dir]:dir:_files -/' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--log=+[file]:file:_files' \
        '-d+[discover only]:str:' \
        '--discover=+[true/false]:s:(true false)' \
        '-m+[config file]:file:_files' \
        '--config=+[file]:file:_files' \
        '-n+[no progress]' \
        '*::'
}

_crowbar "$@"
