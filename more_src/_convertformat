#compdef convertformat
# Documentation: https://man.archlinux.org/search?q=convertformat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:output file:_files' \
  '3::format:(BMP JPEG PNG TIFF TIFFG4 PNM GIF WEBP JP2)' && ret=0

return ret
