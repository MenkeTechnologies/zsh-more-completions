#compdef convertformat
# Documentation: http://www.leptonica.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above; positional args from
# `convertformat` usage output (leptonica 1.87.0).
# Syntax: convertformat filein fileout [format]

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:output file:_files' \
  '3::format:(BMP JPEG PNG TIFF TIFFG4 PNM GIF WEBP JP2)' && ret=0

return ret
