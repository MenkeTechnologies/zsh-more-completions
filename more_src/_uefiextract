#compdef uefiextract UEFIExtract
# Documentation: https://manpages.debian.org/unstable/uefitool-cli/UEFIExtract.1
# UEFI firmware image parsing and extraction utility

local ret=1

_arguments -s -S \
  '-o[output file for GUID extraction mode]:file:_files' \
  '-m[mode: all body unc_data header info file]:mode:(all body unc_data header info file)' \
  '-t[section type or FF to ignore]:type:' \
  '1:image:_files' \
  '*::command:(all unpack dump report guids)' && ret=0

return ret
