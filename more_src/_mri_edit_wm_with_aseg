#compdef mri_edit_wm_with_aseg
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_edit_wm_with_aseg
# FreeSurfer: edit a white matter volume using an aseg segmentation

local ret=1

_arguments -s -S \
  '-fillven[fill ventricles]' \
  '-keep[keep edits as found in output volume]' \
  '-keep-in[keep edits as found in input volume]' \
  '-debug_voxel[debug specific voxel coordinates]:Gx Gy Gz' \
  '*:argument:_files' && ret=0

return ret
