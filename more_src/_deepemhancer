#compdef deepemhancer
# Documentation: https://hpc.nih.gov/apps/DeepEMhancer.html
# deepemhancer - deep learning post-processing of cryo-EM maps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --inputMap)'{-i,--inputMap}'[input map or unmasked half-map 1]:file:_files' \
  '(-i2 --halfMap2)'{-i2,--halfMap2}'[second half map]:file:_files' \
  '(-o --outputMap)'{-o,--outputMap}'[output post-processed map]:file:_files' \
  '(-p --processingType)'{-p,--processingType}'[model: wideTarget tightTarget highRes]:type:(wideTarget tightTarget highRes)' \
  '(-s --samplingRate)'{-s,--samplingRate}'[sampling rate in Angstrom/voxel]:apix' \
  '--noiseStats[noise mean and std for normalization]:stats' \
  '(-m --binaryMask)'{-m,--binaryMask}'[binary mask for normalization]:file:_files' \
  '--deepLearningModelPath[directory with non-default models]:dir:_files -/' \
  '--cleaningStrengh[remove small connected components (0-1, -1 disable)]:val' \
  '(-g --gpuIds)'{-g,--gpuIds}'[GPU ids (-1 for CPU)]:gpus' \
  '(-b --batch_size)'{-b,--batch_size}'[number of cubes processed at once]:n' \
  '--download[download default models to a location]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
