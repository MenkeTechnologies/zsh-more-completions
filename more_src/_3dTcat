#compdef 3dTcat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTcat.html
# AFNI concatenate sub-bricks from multiple datasets

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '(-prefix -output)'{-prefix,-output}'[output dataset prefix]:prefix' \
  '-session[output session directory]:dir:_files -/' \
  '-glueto[append bricks to existing dataset]:dataset:_files' \
  '-dry[dry run; print what would be done]' \
  '-verb[show progress information]' \
  '-rlt[remove linear trends per voxel separately]' \
  '-relabel[replace sub-brick labels with dataset names]' \
  '-tpattern[output slice timing pattern]:pattern' \
  '-tr[output TR in seconds]:tr' \
  '*:dataset:_files' && ret=0

return ret
