#compdef reth
# Documentation: https://reth.rs/cli/reth/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'node:start the node'
  'init:initialise database from genesis file'
  'init-state:initialise database from state dump'
  'import:sync RLP encoded blocks from file(s)'
  'import-era:sync ERA encoded blocks from directory'
  'export-era:export blocks to era1 files'
  'dump-genesis:dump genesis JSON to stdout'
  'db:database debugging utilities'
  'download:download public node snapshots'
  'snapshot-manifest:generate snapshot manifest from local archives'
  'stage:manipulate individual stages'
  'p2p:p2p debugging utilities'
  'config:write config to stdout'
  'prune:prune according to config'
  're-execute:re-execute blocks in parallel for verification'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbosity)*'{-v,--verbosity}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[silence logging]' \
  '--datadir=[data directory]:dir:_files -/' \
  '--chain=[chain name or spec file]:chain:(mainnet sepolia holesky hoodi dev)' \
  '--instance=[instance number]:n:' \
  '--log.stdout.format=[stdout log format]:fmt:(json log-fmt terminal)' \
  '--log.stdout.filter=[stdout log filter]:filter:' \
  '--log.file.format=[file log format]:fmt:(json log-fmt terminal)' \
  '--log.file.filter=[file log filter]:filter:' \
  '--log.file.directory=[log dir]:dir:_files -/' \
  '--log.file.max-files=[max files]:n:' \
  '--log.file.max-size=[max file MB]:mb:' \
  '--config=[config file]:file:_files' \
  '--color=[color]:mode:(always auto never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'reth command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (node)
        _arguments \
          '--metrics=[metrics endpoint]:addr:' \
          '--http[enable HTTP-RPC]' \
          '--http.addr=[HTTP RPC bind addr]:addr:' \
          '--http.port=[HTTP RPC port]:port:' \
          '--http.api=[enabled HTTP APIs csv]:apis:' \
          '--http.corsdomain=[CORS domains]:domains:' \
          '--ws[enable WS-RPC]' \
          '--ws.addr=[WS bind addr]:addr:' \
          '--ws.port=[WS port]:port:' \
          '--ws.api=[enabled WS APIs csv]:apis:' \
          '--ws.origins=[WS allowed origins]:origins:' \
          '--ipcdisable[disable IPC RPC]' \
          '--ipcpath=[IPC socket path]:path:_files' \
          '--authrpc.addr=[engine API addr]:addr:' \
          '--authrpc.port=[engine API port]:port:' \
          '--authrpc.jwtsecret=[JWT secret file]:file:_files' \
          '--port=[P2P listen port]:port:' \
          '--discovery.port=[discovery port]:port:' \
          '--max-outbound-peers=[max outbound peers]:n:' \
          '--max-inbound-peers=[max inbound peers]:n:' \
          '--bootnodes=[bootnodes csv]:list:' \
          '--trusted-peers=[trusted peers csv]:list:' \
          '--no-discovery[disable discovery]' \
          '--full[run full node]' \
          '--engine.experimental[enable experimental engine]' \
          '*:: :' && ret=0 ;;
      (init|init-state|import|import-era|export-era|dump-genesis|prune|re-execute)
        _arguments '*:: :_files' && ret=0 ;;
      (db|stage|p2p|config|download|snapshot-manifest)
        _arguments '*:: :' && ret=0 ;;
    esac ;;
esac

return ret
