#compdef lsinfo
# Documentation: https://man.archlinux.org/search?q=lsinfo
# Reference accessed: 2026-05-16

# lsinfo: show LSF cluster info (types, models, resources)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-t[show host types]' \
  '-m[show host models]' \
  '-r[show resource names]' \
  '-l[long format]' \
  '*::lsinfo args:_files' && ret=0
return ret
