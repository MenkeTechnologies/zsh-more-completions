#compdef dspam
# Documentation: https://manpages.debian.org/dspam.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dspam: Bayesian spam filter daemon / CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--user[user]:user:_users' \
  '--mode=[operation mode]:mode:(toe teft tum noise)' \
  '--feature=[feature]:feat:' \
  '--source=[source]:src:(corpus error inoculation)' \
  '--class=[class]:class:(spam innocent)' \
  '--client[run in client mode]' \
  '--daemon[run as daemon]' \
  '--nofork[do not fork]' \
  '--profile=[user profile]:name:' \
  '--rcpt-to=[recipient]:rcpt:' \
  '--debug[debug]' \
  '--stdout[output to stdout]' \
  '--deliver=[delivered status]:status:(innocent spam)' \
  '*::dspam args:_files' && ret=0
return ret
