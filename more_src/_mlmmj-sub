#compdef mlmmj-sub
# Documentation: https://mlmmj.org/mlmmj-sub.html
# Reference accessed: 2026-05-30
# mlmmj-sub — subscribe an email address to an mlmmj mailing list. If already subscribed to a
# different version (normal/digest/nomail), the subscription is SWITCHED to that version.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-L+[full path to list directory (REQUIRED)]:dir:_directories' \
  '-a+[email address to subscribe]:email:' \
  '-m+[moderation string]:str:' \
  '(-d -n)-d[subscribe to digest version (periodic delivery)]' \
  '(-d -n)-n[subscribe to nomail version (no postings received)]' \
  '(-c -C)-c[send welcome mail (unless confirmation requested)]' \
  '(-c -C)-C[request mail confirmation (unless switching versions)]' \
  '-f[force subscription without moderation]' \
  '-q[do not notify owner about subscription]' \
  '-s[silent if already subscribed (do not send mail)]' \
  '-r[behave as if request arrived via email (internal use)]' \
  '-R[behave as if confirmation arrived via email (internal use)]' \
  '-U[do not switch to list directory owner UID]' \
  && ret=0

return ret
