#compdef packet
# _packet — Packet Host packet bare-metal cloud CLI legacy of Equinix Metal predecessor to metal command (packethost team, Go); cobra
# upstream: https://github.com/packethost/packet-cli

_packet() {
    local -a sub=(
        'init:initialize authentication'
        'admin:admin subcommands'
        'capacity:show available capacity'
        'config:configuration subcommands'
        'device:device subcommands'
        'event:event subcommands'
        'facilities:show facilities'
        'ip:ip subcommands'
        'organization:organization subcommands'
        'os:show operating system list'
        'plan:show server plans'
        'project:project subcommands'
        'ssh-key:SSH key subcommands'
        'two-factor-auth:2FA subcommands'
        'user:user subcommands'
        'vlan:VLAN subcommands'
        'volume:volume subcommands'
        'bgp:BGP subcommands'
        'envtemplate:env template subcommands'
        'spotmarketrequest:spot market request subcommands'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--token=+[api token]:str:' \
        '-o+[format]:f:(table json yaml)' \
        '--output=+[format]:f:(table json yaml)' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'packet subcommand' sub ;;
        args)
            case $words[1] in
                device) _arguments '1:device cmd:(create get list update delete reboot reinstall power-on power-off rescue actions)' ;;
                project|organization|user|ssh-key|ip|vlan|volume|envtemplate|spotmarketrequest) _arguments '1:cmd:(create get list update delete)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                bgp) _arguments '1:bgp cmd:(enable disable get list update sessions)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_packet "$@"
