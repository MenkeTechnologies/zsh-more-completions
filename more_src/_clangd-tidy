#compdef clangd-tidy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-p+,--compile-commands-dir=}'[path to compile_commands.json directory]:dir:_files -/' \
  {-j+,--jobs=}'[parallel jobs]:n:' \
  '--clangd-executable=[path to clangd]:path:_files' \
  '*--allow-extensions=[allowed source extensions]:ext:' \
  '--fail-on-severity=[severity to fail on]:severity:(error warning info hint)' \
  {-q,--quiet}'[suppress non-essential output]' \
  {-v,--verbose}'[verbose output]' \
  '--color=[color output]:mode:(auto always never)' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|m|mm|h|hpp|hxx)"' && ret=0

return ret
