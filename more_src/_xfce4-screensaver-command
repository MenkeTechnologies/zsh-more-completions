#compdef xfce4-screensaver-command
# Documentation: https://github.com/xfce-mirror/xfce4-screensaver/blob/master/src/xfce4-screensaver-command.c
# Reference accessed: 2026-05-21
# Verified: GOptionEntry table in xfce4-screensaver-command.c.

local curcontext="$curcontext" ret=1
_arguments -C \
  '--exit[cause the screensaver to exit gracefully]' \
  '(-q --query)'{-q,--query}'[query the state of the screensaver]' \
  '(-t --time)'{-t,--time}'[query the length of time the screensaver has been active]' \
  '(-l --lock)'{-l,--lock}'[tell the running screensaver to lock the screen immediately]' \
  '(-c --cycle)'{-c,--cycle}'[switch to another graphics demo if screensaver is active]' \
  '(-a --activate)'{-a,--activate}'[turn the screensaver on (blank the screen)]' \
  '(-d --deactivate)'{-d,--deactivate}'[deactivate the screensaver if it is active]' \
  '(-p --poke)'{-p,--poke}'[poke the running screensaver to simulate user activity]' \
  '(-i --inhibit)'{-i,--inhibit}'[inhibit the screensaver from activating]' \
  '(-n --application-name)'{-n+,--application-name=}'[inhibiting application name]:name:' \
  '(-r --reason)'{-r+,--reason=}'[reason for inhibiting]:reason:' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
