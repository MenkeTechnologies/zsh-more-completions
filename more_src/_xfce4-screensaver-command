#compdef xfce4-screensaver-command
# Documentation: https://manpages.debian.org/trixie/xfce4-screensaver/xfce4-screensaver-command.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian trixie xfce4-screensaver-command(1) manpage OPTIONS section.

# xfce4-screensaver-command: control xfce4-screensaver daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '--exit[cause screensaver to exit gracefully]' \
  '(-q --query)'{-q,--query}'[query screensaver state]' \
  '(-t --time)'{-t,--time}'[query active time]' \
  '(-l --lock)'{-l,--lock}'[lock screen immediately]' \
  '(-c --cycle)'{-c,--cycle}'[switch to another graphics demo]' \
  '(-a --activate)'{-a,--activate}'[turn screensaver on (blank screen)]' \
  '(-d --deactivate)'{-d,--deactivate}'[deactivate if active]' \
  '(-p --poke)'{-p,--poke}'[simulate user activity]' \
  '(-i --inhibit)'{-i,--inhibit}'[inhibit screensaver]' \
  '(-n --application-name)'{-n,--application-name=}'[inhibiting application name]:name:' \
  '(-r --reason)'{-r,--reason=}'[reason for inhibiting]:reason:' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
