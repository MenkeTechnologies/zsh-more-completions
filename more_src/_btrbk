#compdef btrbk

# Zsh completion for btrbk - btrfs snapshot and backup manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'run:perform snapshot, backup and clean actions'
  'dryrun:show what would be done'
  'snapshot:create snapshots only'
  'resume:resume backups only'
  'prune:prune snapshots and backups'
  'archive:archive backups to offline storage'
  'clean:delete incomplete backups'
  'list:list configured and existing snapshots/backups'
  'usage:show disk usage of configured subvolumes'
  'origin:show origin information for subvolumes'
  'diff:show differences between two subvolumes'
  'config:print parsed configuration'
  'help:display help information'
)

local -a common_flags=(
  '(-c --config)'{-c,--config}'=[configuration file]:file:_files'
  '(-n --dry-run)'{-n,--dry-run}'[do not write anything, show what would be done]'
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]'
  '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]'
  '(-S --print-schedule)'{-S,--print-schedule}'[print snapshot/backup retention schedule]'
  '--format=[output format]:format:(table raw long)'
  '(-h --help)'{-h,--help}'[display help message]'
  '(-V --version)'{-V,--version}'[display version information]'
)

_arguments -s -S \
  $common_flags \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run|dryrun|snapshot|resume|prune|archive|clean)
        _arguments -s -S \
          $common_flags \
          '*:filter:' && ret=0
        ;;
      list)
        _arguments -s -S \
          $common_flags \
          ':what:(snapshots backups latest all)' \
          '*:filter:' && ret=0
        ;;
      usage|origin|diff|config)
        _arguments -s -S \
          $common_flags \
          '*:filter:' && ret=0
        ;;
    esac
    ;;
esac

return ret
