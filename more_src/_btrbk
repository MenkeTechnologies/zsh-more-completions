#compdef btrbk
# Documentation: https://github.com/digint/btrbk/blob/master/doc/btrbk.1.asciidoc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for btrbk - btrfs snapshot and backup manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'run:perform snapshot, backup and clean actions'
  'dryrun:show what would be done'
  'snapshot:create snapshots only'
  'resume:resume backups only'
  'prune:prune snapshots and backups'
  'archive:archive backups to offline storage'
  'clean:delete incomplete backups'
  'stats:print statistics'
  'list:list configured and existing snapshots/backups'
  'usage:show disk usage of configured subvolumes'
  'origin:show origin information for subvolumes'
  'diff:show differences between two subvolumes'
  'extents:show extents/space usage'
  'ls:list subvolumes recursively'
  'config:print parsed configuration'
)

local -a common_flags=(
  '(-c --config)'{-c,--config}'=[configuration file]:file:_files'
  '(-n --dry-run)'{-n,--dry-run}'[do not write anything, show what would be done]'
  '(-p --preserve)'{-p,--preserve}'[preserve all snapshots and backups]'
  '--preserve-snapshots[preserve all snapshots]'
  '--preserve-backups[preserve all backups]'
  '--exclude=[exclude filter]:filter:'
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]'
  '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]'
  '(-l --loglevel)'{-l,--loglevel}'=[log level]:level:(error warn info debug trace)'
  '(-t --table)'{-t,--table}'[table output]'
  '(-L --long)'{-L,--long}'[long output]'
  '(-1 --single-column)'{-1,--single-column}'[single column output]'
  '--format=[output format]:format:(table long raw col)'
  '--pretty[pretty output]'
  '(-S --print-schedule)'{-S,--print-schedule}'[print snapshot/backup retention schedule]'
  '--progress[show progress bar]'
  '--lockfile=[lock file]:file:_files'
  '--override=[override config option]:key=value:'
  '(-h --help)'{-h,--help}'[display help message]'
  '--version[display version information]'
)

_arguments -s -S \
  $common_flags \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run|dryrun|snapshot|resume|prune|archive|clean|stats)
        _arguments -s -S \
          $common_flags \
          '*:filter:' && ret=0
        ;;
      list)
        _arguments -s -S \
          $common_flags \
          ':what:(snapshots backups latest config source target volume)' \
          '*:filter:' && ret=0
        ;;
      usage|origin|diff|extents|config)
        _arguments -s -S \
          $common_flags \
          '*:filter:' && ret=0
        ;;
      ls)
        _arguments -s -S \
          $common_flags \
          '*:path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
