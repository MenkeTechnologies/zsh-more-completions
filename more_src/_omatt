#compdef omatt
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omatt/node8.html
# Convert an OM source list from detector coordinates to sky coordinates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--set=[OM image filename from previous OM tasks]:file:_files' \
  '--sourcelistset=[OM OSW source list filename]:file:_files' \
  '--ppsoswset=[PPS OM OSW FITS sky image file]:file:_files' \
  '--usecat=[enable USNO-SA 1 catalog for astrometric calibration]:bool:(yes no)' \
  '--catfile=[path to USNO catalog FITS file]:file:_files' \
  '--maxradecerr=[maximum allowed RA/dec error in arcsecs]:value' \
  '--maxrmsres=[maximum allowed rms residual in arcsecs]:value' \
  '--tolerance=[tolerance for source-matching in arcsecs]:value' \
  '--rotateimage=[generate the rotated sky-image output]:bool:(yes no)' \
  '*:param=value:_default' && ret=0

return ret
