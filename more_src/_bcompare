#compdef bcompare
# _bcompare — Scooter Software Beyond Compare (commercial cross-platform diff/merge tool with file/folder/text/hex/image/registry sessions; -fv specifies session view, -ro read only, -ml/-mr load left/right, -title overrides window title, @script runs a BC script)
# upstream: https://www.scootersoftware.com/ (closed source GUI)
# Flags from Beyond Compare official documentation (current version) on tip.

_bcompare() {
    _arguments \
        '-fv+[force view]:view:(Folder File Text Hex MP3 Picture Registry Version)' \
        '-ro[read-only mode]' \
        '-ro1[left side read-only]' \
        '-ro2[right side read-only]' \
        '-ro3[center side read-only]' \
        '-ml+[load left file]:file:_files' \
        '-mr+[load right file]:file:_files' \
        '-mc+[load center file]:file:_files' \
        '-mt+[load target output]:file:_files' \
        '-title1+[left title]:title:' \
        '-title2+[right title]:title:' \
        '-title3+[center title]:title:' \
        '-leftreadonly[left read-only]' \
        '-rightreadonly[right read-only]' \
        '-centerreadonly[center read-only]' \
        '-expandall[expand all folders]' \
        '-automerge[auto-merge with no UI]' \
        '-silent[no prompts]' \
        '-solo[run as solo instance]' \
        '-closescript[close after script]' \
        '*:file/dir:_files'
}

_bcompare "$@"
