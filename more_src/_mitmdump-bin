#compdef mitmdump
# _mitmdump-bin — mitmproxy headless dumper (Aldo Cortesi et al, Python); CLI-only HTTPS interceptor for scripting
# upstream: https://github.com/mitmproxy/mitmproxy

_mitmdump-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(--version)--version[show version]' \
        '--mode+[proxy mode]:mode:(regular transparent socks5 reverse upstream)' \
        '--listen-host+[listen host]:host:_hosts' \
        '--listen-port+[listen port]:port:' \
        '--scripts+[load script]:file:_files' \
        '-s+[load script]:file:_files' \
        '--set+[option=value]:str:' \
        '--ssl-insecure[skip TLS verify]' \
        '-r+[read flows from file]:file:_files' \
        '-w+[write flows to file]:file:_files' \
        '--client-replay+[replay client requests]:file:_files' \
        '--server-replay+[replay server responses]:file:_files' \
        '--server-replay-killextra[kill extra server requests]' \
        '--allow-hosts+[allow hosts regex]:regex:' \
        '--ignore-hosts+[ignore hosts regex]:regex:' \
        '--tcp-hosts+[tcp hosts regex]:regex:' \
        '-q[quiet]' \
        '-v[verbose]' \
        '--flow-detail+[verbosity]:n:' \
        '--anticache[disable cache]' \
        '--showhost[show host header]' \
        '--upstream-auth+[upstream auth]:str:' \
        '--proxyauth+[proxy auth]:str:' \
        '*::script args:'
}

_mitmdump-bin "$@"
