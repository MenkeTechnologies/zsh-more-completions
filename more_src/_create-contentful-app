#compdef create-contentful-app
# Documentation: https://www.npmjs.com/package/create-contentful-app
# Reference accessed: 2026-05-24
# Verified: npx create-contentful-app --help.

# Zsh completion for create-contentful-app - Contentful app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--npm[use npm as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  '--yarn[use Yarn as package manager]' \
  '-ts[use TypeScript template]' \
  '--typescript[use TypeScript template]' \
  '-js[use JavaScript template]' \
  '--javascript[use JavaScript template]' \
  '(-e --example)'{-e,--example=}'[example app name]:example:' \
  '(-s --source)'{-s,--source=}'[template source repository]:url:' \
  '(-f --function)'{-f,--function=}'[function template name]:template:' \
  '--skip-ui[clone function template without UI]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':app name:' && ret=0

return ret
