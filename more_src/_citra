#compdef citra
# Documentation: (none - project was DMCA'd from GitHub 2024-03; no Debian manpage)
# Reference accessed: 2026-05-16
# Verified: manpages.debian.org/{bookworm,sid}/citra/citra.6.en.html return 404;
# manpages.ubuntu.com/manpages/jammy/man6/citra.6.html returns 404; original
# GitHub source has been DMCA'd. Tool kept per "do not delete files" directive
# with conservative completion - only standard Qt flags from QCommandLineParser.

# Citra: discontinued Nintendo 3DS emulator (project ended 2024-03)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*:3DS ROM:_files -g "*.(3ds|cci|cxi|3dsx|elf|app)"' && ret=0
return ret
