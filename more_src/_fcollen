#compdef fcollen
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fcollen.txt
# Modify the vector length of a column in a binary table

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "colname=[name of column to modify]:" \
  "collen=[new vector length]:" \
  "*:FITS file:_files" && ret=0

return ret
