#compdef scryer-prolog

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '-g=[Run query goal before interactive loop]:goal:' \
  '--no-add-history[Disable readline history]' \
  '1:first Prolog file:_files -g "*.pl(-.)"' \
  '*::Prolog boot files:_files -g "*.pl(-.)"'
