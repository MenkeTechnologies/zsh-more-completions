#compdef scryer-prolog
# Documentation: https://github.com/mthom/scryer-prolog
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[display help message]' \
  '(- *)'{-v,--version}'[print version information and exit]' \
  '(-g --goal)'{-g+,--goal=}'[run query goal after consulting files]:goal:' \
  '-f[fast startup, do not load init file (~/.scryerrc)]' \
  '--no-add-history[prevent adding input to history file]' \
  '*:Prolog file:_files -g "*.pl(-.)"'
