#compdef dialign-tx dialign_t
# Documentation: https://dialign.gobics.de/
# DIALIGN-TX: greedy and progressive segment-based multiple alignment

local ret=1

_arguments -s -S \
  '(-h -H)'{-h,-H}'[show help]' \
  '-D[process DNA sequences]' \
  '-T[translate DNA to amino acids (full length)]' \
  '-L[compare longest open reading frame only]' \
  '-O[translate DNA using longest ORF per sequence]' \
  '-P[output amino acids without DNA retranslation]' \
  '-f[minimum fragment length]:length:' \
  '-g[global minimum fragment length]:length:' \
  '-r[threshold weight for fragment consideration]:weight:' \
  '-l[sensitivity mode (0-2)]:mode:(0 1 2)' \
  '-t[low score threshold]:threshold:' \
  '-n[max consecutive low-scoring positions]:n:' \
  '-m[score matrix filename]:file:_files' \
  '-p[probability distribution filename]:file:_files' \
  '-w[minimum weight formula value]:value:' \
  '-v[value added to scores]:value:' \
  '-a[max characters per FASTA input line]:n:' \
  '-c[max characters per output line]:n:' \
  '-s[maximum input sequences]:n:' \
  '-u[use reduced neighbor stripe for speed]' \
  '-F[fast mode]' \
  '-d[debug mode (0-5)]:level:(0 1 2 3 4 5)' \
  '-A[optional anchor file]:file:_files' \
  '*:conf-directory or fasta file:_files' && ret=0

return ret
