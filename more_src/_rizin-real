#compdef rizin rz-bin rz-asm rz-ax rz-hash rz-find rz-diff rz-gg rz-run
# Documentation: https://man.archlinux.org/search?q=rizin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (rizin)
    _arguments -C \
      '-h[help]' \
      '-hh[advanced help]' \
      '-v[version]' \
      '-V[core/io versions]' \
      '-q[quiet]' \
      '-q0[quiet, no banner]' \
      '-c+[command to run]:cmd:' \
      '*-i+[script file]:file:_files -g "*.rz"' \
      '-I+[script before opening]:file:_files' \
      '-A[analyze all symbols]' \
      '-AA[deep analysis]' \
      '-w[write mode]' \
      '-d[debugger]' \
      '-D+[debugger backend]:b:' \
      '-e+[k=v config]:cfg:' \
      '-N[no user config]' \
      '-Q[quit after -c]' \
      '-l+[plugin]:p:' \
      '-L[list io plugins]' \
      '-o+[file at offset]:n:' \
      '-p+[load project]:p:' \
      '-s+[start at addr]:addr:' \
      '-z[no strings]' \
      '-zz[load all strings]' \
      '-bs+[block size]:n:' \
      '*: :_files' && ret=0 ;;
  (rz-bin)
    _arguments -C \
      '-A[show all]' \
      '-c[classes]' \
      '-e[entrypoints]' \
      '-E[exports]' \
      '-h[help]' \
      '-H[hashes]' \
      '-i[imports]' \
      '-I[binary info]' \
      '-j[json output]' \
      '-l[linked libs]' \
      '-L[list bin plugins]' \
      '-r[rizin commands]' \
      '-R[relocs]' \
      '-s[symbols]' \
      '-S[sections]' \
      '-z[strings]' \
      '*: :_files' && ret=0 ;;
  (rz-asm)
    _arguments -C \
      '-a+[arch]:a:' \
      '-b+[bits]:n:' \
      '-c+[cpu]:c:' \
      '-d[disassemble]' \
      '-D[disasm verbose]' \
      '-e[big endian]' \
      '-f+[input file]:file:_files' \
      '-h[help]' \
      '-l+[length]:n:' \
      '-L[list arch plugins]' \
      '-o+[start addr]:n:' \
      '-O+[output file]:file:_files' \
      '-p[binary opcode]' \
      '-q[quiet]' \
      '-r[rizin cmds]' \
      '*: :' && ret=0 ;;
  (rz-ax)
    _arguments -C \
      '-h[help]' \
      '-V[version]' \
      '*: :' && ret=0 ;;
  (rz-hash)
    _arguments -C \
      '-h[help]' \
      '-a+[algo]:a:' \
      '-b+[block size]:n:' \
      '-L[list algos]' \
      '-q[quiet]' \
      '-s+[hash string]:s:' \
      '*: :_files' && ret=0 ;;
  (rz-find|rz-diff|rz-gg|rz-run)
    _arguments '*: :_files' && ret=0 ;;
esac

return ret
