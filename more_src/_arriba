#compdef arriba arriba_v2 draw_fusions.R
# _arriba — Sebastian Uhrig Arriba fast and accurate RNA-Seq gene fusion detection tool for STAR aligned reads (suhrig team, C++); getopt
# upstream: https://github.com/suhrig/arriba

_arriba() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-x+[STAR Chimeric.out.junction]:file:_files -g "*.junction"' \
        '-c+[STAR Chimeric.out.sam]:file:_files -g "*.sam *.bam"' \
        '-s+[STAR splicing.junction]:file:_files' \
        '-g+[GTF annotation]:file:_files -g "*.gtf *.gff *.gff3"' \
        '-G+[gene annotation]:file:_files' \
        '-i+[ignore reads with mapq < N]:n:' \
        '-a+[reference genome fasta]:file:_files -g "*.fa *.fasta *.fna"' \
        '-b+[blacklist]:file:_files' \
        '-k+[known fusions]:file:_files' \
        '-t+[tags file]:file:_files' \
        '-p+[protein domains gff3]:file:_files' \
        '-o+[output fusions]:file:_files' \
        '-O+[discarded fusions]:file:_files' \
        '-d+[structural variants]:file:_files' \
        '-D+[discovered fusion candidates output]:file:_files' \
        '-T+[fragment length]:n:' \
        '-S+[strand]:s:(auto yes reverse no)' \
        '-l+[max E-value]:f:' \
        '-L+[fragment length library]:n:' \
        '-m+[max homopolymer length]:n:' \
        '-M+[max kmer length]:n:' \
        '-K+[max read length]:n:' \
        '-A+[max anchor length]:n:' \
        '-r+[min anchor length]:n:' \
        '-R+[min fragment count]:n:' \
        '-e+[max e-value]:f:' \
        '-q+[min quality]:n:' \
        '-Q+[max blacklist hits]:n:' \
        '-u+[ignore duplicates]' \
        '-z+[no internal tandem duplications]' \
        '-f+[filter csv]:str:' \
        '-F+[disable filters csv]:str:' \
        '-Y+[no chimera]' \
        '-X+[no extra annotation]' \
        '-P+[print fragments without alignments]' \
        '-I+[include duplicates]' \
        '-E+[exclude breakpoints near]:str:' \
        '-U+[max imbalance]:f:' \
        '-W+[min split reads]:n:' \
        '-N+[no filter]'
}

_arriba "$@"
