#compdef tldraw tldraw-cli
# Documentation: https://man.archlinux.org/search?q=tldraw
# Reference accessed: 2026-05-16

_tldraw() {
    local line state
    local -a commands
    commands=(
        'export:Export a local .tldr file or tldraw.com URL to an image'
        'open:Open a .tldr file or URL in the browser'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'tldraw command' commands
            ;;
        args)
            case $line[1] in
                export)
                    _arguments \
                        '--format[Output format]:format:(svg png tldr)' \
                        '--output[Output path or directory]:file:_files' \
                        '--frames[Export frames as individual images]' \
                        '--transparent[Export with transparent background]' \
                        '--padding[Padding around the export]:number:' \
                        '--scale[Scale factor for raster exports]:number:' \
                        '--theme[Theme for the export]:theme:(light dark)' \
                        '--help[Show help]' \
                        '*:tldraw file or URL:_files -g "*.tldr"'
                    ;;
                open)
                    _arguments \
                        '--local[Open using a local instance of tldraw]' \
                        '--port[Port for local instance]:number:' \
                        '--help[Show help]' \
                        '*:tldraw file or URL:_files -g "*.tldr"'
                    ;;
            esac
            ;;
    esac
}

_tldraw "$@"
