#compdef nuwro
# Documentation: https://nuwro.github.io/user-guide/getting-started/running/
# nuwro - NuWro Monte Carlo neutrino event generator

local ret=1

_arguments -s -S \
  '-i[path to input parameters file (default params.txt)]:file:_files' \
  '-o[output ROOT file path]:outfile:_files' \
  '*-p[override a single parameter (parameter name = value)]:param:' \
  '*: :_files' && ret=0

return ret
