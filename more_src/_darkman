#compdef darkman

# Zsh completion for darkman (dark/light mode daemon for Linux desktops)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:Run the darkman daemon'
  'set:Set the current mode'
  'get:Get the current mode'
  'toggle:Toggle between dark and light mode'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-v --version)'{-v,--version}'[Print version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'darkman command' commands && ret=0
    ;;
  args)
    case $words[1] in
      set)
        _arguments '1:mode:(dark light)' && ret=0
        ;;
    esac
    ;;
esac

return ret
