#compdef ansible
# _ansible — Ansible CLI (run an ad-hoc module against an inventory pattern; -m module, -a args, -i inventory, -l limit, -b/--become privilege escalation, -K/-k ask pass; -C check, --diff, -D show diffs, -e extra vars)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/adhoc.py)
# Flags from ansible cli/adhoc.py on tip.

_ansible() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose (repeat for more)]' \
        '*-v[verbose]' \
        '-m+[module name]:module:' \
        '-a+[module args]:args:' \
        '-i+[inventory]:inventory:_files' \
        '-l+[limit hosts]:limit:' \
        '-f+[parallel forks]:forks:' \
        '-T+[connection timeout]:seconds:' \
        '-u+[remote user]:user:_users' \
        '-c+[connection type]:connection:(local ssh paramiko docker kubectl)' \
        '-b[become]' \
        '--become[become]' \
        '-K[ask become pass]' \
        '-k[ask remote ssh pass]' \
        '--become-method+[method]:method:(sudo su pbrun pfexec doas dzdo ksu runas machinectl)' \
        '--become-user+[user]:user:_users' \
        '-C[check mode (dry run)]' \
        '--check[check mode]' \
        '--diff[show diffs]' \
        '-D[show diffs]' \
        '*-e+[extra vars]:key=value:' \
        '--vault-id+[vault id]:vault_id:' \
        '--vault-password-file+[file]:file:_files' \
        '--ask-vault-pass[ask vault pass]' \
        '-o[one-line output]' \
        '--one-line[one-line output]' \
        '-t+[per-task log tree]:dir:_files -/' \
        '-B+[seconds backgrounded]:seconds:' \
        '-P+[poll interval]:seconds:' \
        '*--limit+[limit]:limit:' \
        '*--tags+[only run tags]:tags:' \
        '*--skip-tags+[skip tags]:tags:' \
        '1:host pattern:'
}

_ansible "$@"
