#compdef cataclysm-dda cataclysm
# Documentation: https://github.com/CleverRaven/Cataclysm-DDA/blob/master/doc/c%2B%2B/COMMAND-LINE.md
# Reference accessed: 2026-05-16

# Cataclysm: Dark Days Ahead - post-apocalyptic roguelike
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--basepath=[base path]:dir:_files -/' \
  '--shared-path=[shared data path]:dir:_files -/' \
  '--userdir=[user dir]:dir:_files -/' \
  '--datadir=[data dir]:dir:_files -/' \
  '--memorialdir=[memorial dir]:dir:_files -/' \
  '--savedir=[save dir]:dir:_files -/' \
  '--worldmenu[start in world menu]' \
  '--world=[world name]:world:' \
  '--check-mods[check mods]:list:' \
  '--mods=[load mods]:list:' \
  '--dump-stats=[dump stats]:list:' \
  '--seed=[RNG seed]:n:' \
  '--lang=[language]:lang:' \
  '*::cataclysm-dda args:_files' && ret=0
return ret
