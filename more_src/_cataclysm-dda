#compdef cataclysm-dda cataclysm
# Documentation: https://github.com/CleverRaven/Cataclysm-DDA/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp parse_commandline() arg_handler vectors
# Removed from prior file: -h (no short form), --shared-path (real is --shared),
# --mods (invented), --dump-stats (invented), --lang (invented).

# Cataclysm: Dark Days Ahead - post-apocalyptic roguelike
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--seed=[RNG seed string]:seed:' \
  '--jsonverify[check the CDDA json files and exit]' \
  '--check-mods=[check json for given mod(s) and exit]:mod:' \
  '--noverify[skip JSON verification]' \
  '--world=[load first save in this world on startup]:world:' \
  '--basepath=[base data path]:dir:_files -/' \
  '--shared[map-sharing mode]' \
  '--username=[map-sharing username]:user:_users' \
  '--addadmin=[map-sharing: add admin]:user:_users' \
  '--adddebugger=[map-sharing: add debugger]:user:_users' \
  '--competitive[competitive map-sharing mode]' \
  '--userdir=[user data root]:dir:_files -/' \
  '--disable-ascii-art[disable ASCII art (accessibility)]' \
  '--worldmenu[start in world menu]' \
  '--datadir=[data directory name]:name:' \
  '--savedir=[save directory name]:name:' \
  '--configdir=[config directory name]:name:' \
  '--memorialdir=[memorial directory name]:name:' \
  '--optionfile=[options file]:file:_files' \
  '--keymapfile=[keymap file]:file:_files' \
  '--autopickupfile=[autopickup file]:file:_files' \
  '--motdfile=[MOTD file]:file:_files' \
  '*::extra args:_files' && ret=0
return ret
