#compdef oxenstored

# oxenstored: OCaml-based xenstore daemon (Xen)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--no-domain-init[do not init domain]' \
  '--config-file=[config file]:file:_files' \
  '--pidfile=[PID file]:file:_files' \
  '-N[no fork]' \
  '--no-fork[no fork]' \
  '--reraise-top-level[reraise top-level exceptions]' \
  '--restart[restart by retrieving existing state]' \
  '--disable-socket[disable unix socket]' \
  '*::oxenstored args:_files' && ret=0
return ret
