#compdef mc
# _mc-bin — Midnight Commander twin-pane file manager (Miguel de Icaza et al, C); curses Norton Commander clone for UNIX
# upstream: https://github.com/MidnightCommander/mc

_mc-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --stickchars)'{-a,--stickchars}'[disable ACS chars]' \
        '(-b --nocolor)'{-b,--nocolor}'[force black/white]' \
        '(-c --color)'{-c,--color}'[force color]' \
        '(-C --colors)'{-C,--colors}'+[color spec]:spec:' \
        '(-d --nomouse)'{-d,--nomouse}'[no mouse]' \
        '(-D --debuglevel)'{-D,--debuglevel}'+[VFS debug level]:n:' \
        '(-e --edit)'{-e,--edit}'+[edit file]:file:_files' \
        '(-f --datadir)'{-f,--datadir}'[print compiled-in paths]' \
        '(-F --datadir-info)'{-F,--datadir-info}'[print compile paths with extra]' \
        '(-g --oldmouse)'{-g,--oldmouse}'[normal tracking mouse]' \
        '(-G --xterm)'{-G,--xterm}'[force xterm mouse]' \
        '(-K --konsole)'{-K,--konsole}'[konsole tweaks]' \
        '(-l --ftplog)'{-l,--ftplog}'+[ftpfs log file]:file:_files' \
        '(-P --printwd)'{-P,--printwd}'+[print wd on exit]:file:_files' \
        '(-S --skin)'{-S,--skin}'+[skin]:skin:' \
        '(-t --termcap)'{-t,--termcap}'[use termcap]' \
        '(-T --resetsoft)'{-T,--resetsoft}'[reset softkeys]' \
        '(-u --nosubshell)'{-u,--nosubshell}'[disable subshell]' \
        '(-U --subshell)'{-U,--subshell}'[force subshell]' \
        '(-v --view)'{-v,--view}'+[view file]:file:_files' \
        '(-X --no-x11)'{-X,--no-x11}'[no X11 clipboard]' \
        '*:dir:_files -/'
}

_mc-bin "$@"
