#compdef condor_gpu_discovery
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_gpu_discovery.html
# output ClassAd attributes describing the GPU devices on a machine

local ret=1

_arguments -s -S \
  '-help[print usage information and exit]' \
  '-properties[display GPU property information]' \
  '-nested[display common properties in a Common nested ClassAd]' \
  '-not-nested[display common properties as a prefixed attribute]' \
  '-extra[display extra attributes about the GPUs]' \
  '-dynamic[display NVIDIA attributes that change as the GPU works]' \
  '-mixed[assume a heterogeneous set of GPUs]' \
  '-device[display properties only for GPU device N]:N' \
  '-tag[redefine the DetectedGPUs attribute name]:string' \
  '-prefix[prefix string to use for attribute naming]:string' \
  '-by-index[use the prefix and device index as the device identifier]' \
  '-short-uuid[use the first 8 chars of the NVIDIA uuid as identifier]' \
  '-uuid[use the full NVIDIA uuid as the device identifier]' \
  '-simulate[assume N devices of type D were detected]:spec' \
  '-cuda[use CUDA detection and not OpenCL]' \
  '-hip[use HIP 6 for detection and not OpenCL]' \
  '-opencl[detect via OpenCL rather than CUDA or HIP]' \
  '-config[output in HTCondor configuration syntax]' \
  '-repeat[repeat listed GPUs N times]:N' \
  '-divide[like repeat but also divide GlobalMemoryMb by N]:N' \
  '-packed[repeat each GPU N times, not the whole list]' \
  '-cron[suppress the DetectedGpus attribute for startd cron use]' \
  '-verbose[output extra information showing detection progress]' \
  '-diagnostic[show diagnostic information]' \
  '-nvcuda[diagnostic only, use CUDA driver library]' \
  '-cudart[diagnostic only, use CUDA runtime]' \
  '-dirty-environment[do not cleanse GPU library environment variables]' && ret=0

return ret
