#compdef arangorestore

# Zsh completion for arangorestore - ArangoDB data restore utility

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--server.endpoint=[server endpoint]:endpoint' \
  '--server.database=[database name]:database' \
  '--server.username=[username]:user' \
  '--server.password=[password]:password' \
  '--server.authentication=[enable authentication]:enable:(true false)' \
  '--server.connection-timeout=[connection timeout in seconds]:seconds' \
  '--server.request-timeout=[request timeout in seconds]:seconds' \
  '--ssl.protocol=[SSL protocol]:protocol:(1 2 3 4 5 6 9)' \
  '--ssl.cafile=[CA certificate file]:file:_files' \
  '--input-directory=[input directory with dump files]:directory:_files -/' \
  '--all-databases[restore all databases]' \
  '--include-collection=[collection to include in restore]:collection' \
  '--include-system-collections[include system collections]' \
  '--create-database[create the target database if it does not exist]' \
  '--create-collection=[create collections]:enable:(true false)' \
  '--import-data=[import document data]:enable:(true false)' \
  '--overwrite=[overwrite existing data]:enable:(true false)' \
  '--force[continue on errors]' \
  '--number-of-shards=[override number of shards]:count' \
  '--replication-factor=[override replication factor]:factor' \
  '--threads=[number of restore threads]:count' \
  '--batch-size=[batch size for data transfer]:bytes' \
  '--cleanup-duplicate-attributes[clean up duplicate attributes in data]' \
  '--force-same-database[use server database name]' \
  '--progress=[show progress]:enable:(true false)' \
  '--log.level=[log level]:level:(fatal error warning info debug trace)' \
  '--configuration=[configuration file]:file:_files'
