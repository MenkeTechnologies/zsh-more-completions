#compdef omnictl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'apply:create or update resource using YAML file'
  'audit-log:read audit log from Omni'
  'cluster:cluster-related operations'
  'completion:generate shell autocompletion script'
  'config:manage client configuration file'
  'delete:delete specific resources'
  'download:download installer media'
  'get:retrieve resources'
  'infraprovider:manage infrastructure providers'
  'jointoken:manage join tokens'
  'kubeconfig:download cluster admin kubeconfig'
  'machine-logs:get machine logs'
  'serviceaccount:manage service accounts'
  'support:download cluster support bundle'
  'talosconfig:download admin talosconfig'
  'user:user management'
)

_arguments -C \
  '--context=[context]:context:' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '--omniconfig=[omniconfig file]:file:_files' \
  '--siderov1-keys-dir=[siderov1 keys dir]:dir:_files -/' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'omnictl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cluster)
        _values 'cluster action' \
          'delete' 'import' 'kubernetes' 'lock' 'machine' \
          'status' 'template' 'unlock' && ret=0
        ;;
      (serviceaccount)
        _values 'serviceaccount action' 'create' 'destroy' 'list' 'renew' && ret=0
        ;;
    esac
    ;;
esac

return ret
