_tauraroc() {
    _arguments -s \
        '(- *)--version[print version and exit]' \
        '(- *)'{-h,--help}'[show help]' \
        '--verbose[show all pipeline phases]' \
        '--emit=[stop after the named pipeline stage]:stage:(c ast mir)' \
        '--run[compile and immediately execute]' \
        '--check[run semantic analysis only (no codegen)]' \
        '--backend=[codegen backend]:backend:(c llvm)' \
        '-o+[output executable name]:path:_files' \
        '-O0[no optimization]' \
        '-O1[mild optimization]' \
        '-O2[full optimization (default)]' \
        '-O3[aggressive optimization]' \
        '-Os[optimize for size]' \
        '*--link=[link an additional file by path (.c .o .a .dll .lib .so)]:path:_files -g "*.c *.o *.a *.dll *.lib *.so"' \
        '*-l+[link a library by name]:lib:' \
        '--static[statically link the output binary]' \
        '--target=[cross-compile target]:target:(android-arm64 android-arm32 android-x86_64 android-x86 ios ios-sim linux-arm64 linux-arm32 linux-x86_64 linux-riscv64 windows-x64 windows-arm64 macos-arm64 macos-x86_64 embedded-arm embedded-arm64 embedded-riscv32 embedded-riscv64 wasm wasm-wasi)' \
        '--sysroot=[override sysroot for the cross-compiler]:path:_files -/' \
        '*:Tauraro source file:_files -g "*.tr"'
}

_tauraroc "$@"
