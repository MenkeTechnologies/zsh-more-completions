#compdef sumo-otel-distro otelcol-sumo
# Documentation: https://opentelemetry.io/docs/collector/configuration/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: SumoLogic distro inherits the upstream OpenTelemetry Collector CLI.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'validate:validate a configuration file'
  'components:list available components'
  'print-config:print final merged configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--config=[config file or URI]:file:_files' \
  '*--set=[override settings (key::path::leaf=value)]:kv:' \
  '*--feature-gates=[enable/disable feature gates]:gates:' \
  '1: :->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'subcommand' commands && ret=0 ;;
  (args)
    case $line[1] in
      (print-config)
        _arguments \
          '--mode=[output mode]:mode:(redacted unredacted)' \
          '--format=[output format]:format:(json)' && ret=0 ;;
    esac ;;
esac

return ret
