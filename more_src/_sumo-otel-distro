#compdef sumo-otel-distro

# sumo-otel-distro: Sumo Logic distribution of OpenTelemetry Collector
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file/URI]:file:_files' \
  '--feature-gates=[feature gates]:gates:' \
  '--set=[override config key=value]:kv:' \
  '*::sumo-otel-distro args:_files' && ret=0
return ret
