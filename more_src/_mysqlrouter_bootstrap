#compdef mysqlrouter_bootstrap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-B+,--bootstrap=}'[bootstrap connection URI]:uri:' \
  '--bootstrap-socket=[socket for bootstrap]:socket:_files' \
  {-d+,--directory=}'[directory for router files]:dir:_files -/' \
  '--name=[router instance name]:name:' \
  '--account=[user account for runtime]:account:' \
  '--account-create=[account creation policy]:policy:(always if-not-exists never)' \
  '--account-host=[host for runtime account]:host:_hosts' \
  '--conf-base-port=[base port for listening]:port:' \
  '--conf-bind-address=[address for listening]:addr:' \
  '--conf-use-sockets[use sockets in addition to TCP]' \
  '--conf-skip-tcp[disable TCP listening]' \
  '--conf-use-gr-notifications=[enable Group Replication notifications]:flag:(0 1)' \
  '--conf-target-cluster=[target cluster]:cluster:(default current)' \
  '--connect-timeout=[connect timeout in seconds]:seconds:' \
  '--read-timeout=[read timeout in seconds]:seconds:' \
  '--ssl-mode=[SSL mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
  '--ssl-ca=[CA certificate file]:file:_files' \
  '--ssl-capath=[CA cert directory]:dir:_files -/' \
  '--ssl-cert=[client certificate]:file:_files' \
  '--ssl-key=[client key]:file:_files' \
  '--ssl-cipher=[allowed ciphers]:ciphers:' \
  '--master-key-reader=[command to read master key]:command:' \
  '--master-key-writer=[command to write master key]:command:' \
  '--strict[fail on warnings during bootstrap]' \
  '--force[overwrite existing config]' \
  '--force-password-validation[validate password]' \
  '--password-retries=[password retries]:n:' \
  '--report-host=[report host name]:host:_hosts' && ret=0

return ret
