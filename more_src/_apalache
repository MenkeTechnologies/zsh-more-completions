#compdef apalache apalache-mc
# Documentation: source-direct extraction from upstream
# apalache-mc/apalache mod-tool/src/main/scala/at/forsyte/apalache/
# tla/tooling/opt/*.scala - {ApalacheCommand,AbstractCheckerCmd,
# CheckCmd,ConfigCmd,ParseCmd,ServerCmd,SimulateCmd,TestCmd,
# TraceeCmd,TranspileCmd,TypeCheckCmd}.scala
# `opt[T](name = "<long>", description = "<help>", default = ...)`
# declarations using the org.backuity.clist Scala CLI parser
# (NOT scopt or scallop). Subcommand list extracted from the 8
# *Cmd.scala files (AbstractCheckerCmd is a base class, not a
# subcommand).
# Reference accessed: 2026-05-30 via gh api.
# apalache-mc R139a — TLA+ model checker (symbolic + bounded) from
# Informal Systems. Companion to TLC (already covered in the corpus
# as `tlc`). Ships the wrapper script `apalache-mc` as the primary
# binary name; `apalache` is the same binary under an older alias.

# Common base flags from ApalacheCommand.scala (applied to ALL
# subcommands via inheritance).
local -a _apalache_base_opts
_apalache_base_opts=(
  '--config-file=[config to read from (JSON or HOCON; overrides .apalache.cfg)]:file:_files'
  '--debug[extensive logging in detailed.log and log.smt]'
  '--smtprof[profile SMT constraints in profile.csv]'
  '--profiling[write profiling data to profile-rules.txt]'
  '--out-dir=[where output files will be written (default ./_apalache-out)]:dir:_directories'
  '--run-dir=[additional directory for this-run output (default none)]:dir:_directories'
  '--write-intermediate[write intermediate output files to --out-dir]'
  '--features=[enable experimental features (comma-separated)]:features:'
)

# AbstractCheckerCmd shared flags (used by check, simulate, test).
local -a _apalache_checker_opts
_apalache_checker_opts=(
  '--cinit=[name of the constant-init operator (default: undefined)]:op:'
  '--config=[the TLA+ configuration file (default: <SPEC>.cfg)]:file:_files'
  '--init=[name of the init operator (default Init)]:op:'
  '--inv=[name of the invariant operator]:op:'
  '--length=[maximum symbolic-execution depth in steps (default 10)]:n:'
  '--next=[name of the next operator (default Next)]:op:'
  '--temporal=[name of the temporal-property operator]:op:'
)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '1:subcommand:((check\:bounded-symbolic-model-check parse\:parse-the-TLA-spec server\:run-as-language-server simulate\:randomized-symbolic-simulation test\:run-TLA+-tests tracee\:replay-counter-example-trace transpile\:compile-TLA+-to-intermediate-form typecheck\:type-check-only config\:show-effective-configuration))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      check)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          "${_apalache_checker_opts[@]}" \
          '--algo=[search algorithm]:algo:(offline incremental remote)' \
          '--smt-encoding=[SMT encoding]:encoding:(oopsla19 arrays funArrays)' \
          '--smt-solver=[SMT solver]:solver:(z3 cvc5)' \
          '--tuning-options-file=[tuning options file]:file:_files' \
          '--tuning-options=[tuning options (comma-separated key=value)]:opts:' \
          '--discard-disabled[discard disabled transitions]' \
          '--no-deadlock[do not check for deadlocks]' \
          '--max-error=[continue searching after up to N errors]:n:' \
          '--view=[state view to use with --max-error=n]:op:' \
          '--output-traces[save an example trace per symbolic run]' \
          '--timeout-smt=[per-SMT-query timeout in seconds (default 0=unlimited)]:sec:' \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      simulate)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          "${_apalache_checker_opts[@]}" \
          '--max-run=[maximum number of simulation runs (default 100)]:n:' \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      test)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          "${_apalache_checker_opts[@]}" \
          '--action=[name of the action operator under test]:op:' \
          '--assertion=[name of the assertion operator]:op:' \
          '--before=[name of the precondition operator]:op:' \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      parse)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          '--output=[output file for the parsed AST (JSON or TLA+)]:file:_files' \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      typecheck)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          '--infer-poly[infer polymorphic types]' \
          '--output=[output file for type-annotated TLA+]:file:_files' \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      transpile)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      tracee)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          '--expressions=[comma-separated list of expressions to evaluate at each step]:exprs:' \
          '1:TLA+ spec file:_files -g "*.tla"' && ret=0
        ;;
      server)
        _arguments -s -S "${_apalache_base_opts[@]}" && ret=0
        ;;
      config)
        _arguments -s -S \
          "${_apalache_base_opts[@]}" \
          '--enable-stats=[opt in/out of anonymous usage statistics collection]:bool:(true false)' && ret=0
        ;;
    esac
    ;;
esac

return ret
