#compdef mfscgiserv
# Documentation: https://moosefs.com/manpages/mfscgiserv
# Reference accessed: 2026-05-19
# Verified: upstream MooseFS man page at the URL above.
# mfscgiserv: simple HTTP server for the MooseFS CGI UI.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show usage and exit]' \
  '-H+[bind host (default any)]:host:_hosts' \
  '-P+[bind port (default 9425)]:port:' \
  '-R+[document root (default CGIDIR)]:dir:_files -/' \
  '-D+[data directory (default /var/lib/mfs)]:dir:_files -/' \
  '-t+[lockfile wait seconds (default 60)]:secs:' \
  '-f[run in foreground]' \
  '-v[log requests to stderr]' \
  '*:action:(start stop restart test)' && ret=0
return ret
