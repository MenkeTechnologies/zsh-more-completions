#compdef mfscgiserv

# mfscgiserv: simple HTTP server for the MooseFS CGI UI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-H[bind host]:host:_hosts' \
  '-P[bind port]:port:' \
  '-R[document root]:dir:_files -/' \
  '-D[data root]:dir:_files -/' \
  '-v[verbose]' \
  '*:action:(start stop restart status)' && ret=0
return ret
