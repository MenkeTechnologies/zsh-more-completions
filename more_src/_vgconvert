#compdef vgconvert
# _vgconvert — LVM2 vgconvert convert VG metadata format CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_vgconvert() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-M+[metadata format]:f:(1 2 lvm1 lvm2)' \
        '--metadatatype=+[metadata format]:f:(1 2 lvm1 lvm2)' \
        '--metadatacopies=+[metadata copies]:n:(0 1 2 all)' \
        '--pvmetadatacopies=+[pv metadata copies]:n:(0 1 2)' \
        '--metadatasize=+[metadata size]:str:' \
        '--bootloaderareasize=+[bootloader area size]:str:' \
        '--labelsector=+[label sector]:n:' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--config=+[config string]:str:' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '*:vg:'
}

_vgconvert "$@"
