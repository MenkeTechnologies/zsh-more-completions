#compdef invert
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/invert.html
# MIRIAD invert - make maps and beams from visibility data

local ret=1

_arguments -s -S \
  'vis=[input visibility data files]:vis:_files' \
  'map=[output map/image file name]:map:_files' \
  'beam=[output beam/PSF file name]:beam:_files' \
  'imsize=[size of output dataset]:imsize' \
  'cell=[image cell size in arcsec]:cell' \
  'offset=[sky position shift to image center]:offset' \
  'fwhm=[Gaussian taper FWHM applied to visibility]:fwhm' \
  'sup=[sidelobe suppression area in arcsec]:sup' \
  'robust=[Briggs robustness parameter (-2 to 2)]:robust' \
  'line=[line type channel/wide/velocity/frequency selection]:line' \
  'ref=[reference channel line type]:ref' \
  'select=[uv data subset selection]:select' \
  'stokes=[polarization/Stokes selection]:stokes' \
  'mode=[imaging algorithm fft/dft/median]:mode:(fft dft median)' \
  'slop=[tolerance for bad channels in cubes]:slop' \
  'options=[nocal,nopol,nopass,double,systemp,fsystemp,mfs,sdb,mosaic,imaginary,amplitude,phase,sin,ncp,radial,taper,radfft]:options' \
  '*:visibility data:_files' && ret=0

return ret
