#compdef protontricks
# Documentation: https://github.com/Matoking/protontricks
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for protontricks - winetricks wrapper for Proton

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-s --search)'{-s+,--search+}'[search for a game by name]:name:' \
  '(-S --search-all)'{-S,--search-all}'[search for games across all Steam installations]' \
  '(-l --list)'{-l,--list}'[list games in a single Steam installation]' \
  '(-L --list-all)'{-L,--list-all}'[list games across all Steam installations]' \
  '(-c --command)'{-c+,--command+}'[run a command in the prefix]:command:' \
  '--no-bwrap[disable bubblewrap containerization]' \
  '--no-runtime[disable Steam runtime]' \
  '--background-wineserver[run wineserver in the background]' \
  '--no-background-wineserver[do not run wineserver in the background]' \
  '--gui[launch the protontricks GUI]' \
  '--cli[launch the winetricks CLI]' \
  '--no-term[disable launching a new terminal window]' \
  '1:app id or action:' \
  '*::action:'
