#compdef npm-check

# Zsh completion for npm-check (check for outdated/incorrect/unused npm packages)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-u --update)'{-u,--update}'[interactive update]' \
  '(-y --update-all)'{-y,--update-all}'[update all without prompting]' \
  '(-g --global)'{-g,--global}'[check global packages]' \
  '(-s --skip-unused)'{-s,--skip-unused}'[skip check for unused packages]' \
  '(-p --production)'{-p,--production}'[skip devDependencies]' \
  '(-d --dev-only)'{-d,--dev-only}'[check only devDependencies]' \
  '(-i --ignore)'{-i,--ignore}'[ignore packages matching pattern]:pattern' \
  '(-E --save-exact)'{-E,--save-exact}'[save exact versions]' \
  '--no-color[disable color output]' \
  '--no-emoji[disable emoji in output]' \
  '--debug[show debug information]' \
  '--spinner[show spinner while checking]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:path:_files -/' && ret=0

return ret
