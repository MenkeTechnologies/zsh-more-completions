#compdef sericumcc
# ============================================================================
#  _sericumcc — sericumcc: Sericum's C compiler — front-end for
#               the Sericum experimental LLVM-like compiler
#               infrastructure written in Rust
#               (maekawatoshiki / Toshiki Maekawa — sericum
#               compiler-infrastructure research project)
#
#  Source-direct extraction from
#    https://github.com/maekawatoshiki/sericum/blob/master/sericumcc/src/main.rs
#    https://github.com/maekawatoshiki/sericum/blob/master/sericumcc/Cargo.toml
#    https://github.com/tanakh/argopt (the argopt library by
#    tanakh / Hideyuki Tanaka — Japanese Rust developer, author
#    of "Rust Programming" book and many Rust crates)
#
#  Maintained by maekawatoshiki (Toshiki Maekawa — Japanese
#  PhD researcher in compiler infrastructure).  sericum has
#  402 GH stars on the parent repo.  Sericum is a "(Toy)
#  Compiler Infrastructure influenced by LLVM written in Rust"
#  — an academic/research project for studying compiler-IR
#  design, register allocation, instruction selection, and SSA
#  optimization in Rust.  Includes a C-language front-end
#  (`sericumcc`), an x86_64 code generator, and the `minilang`
#  toy-language front-end for testing compiler passes.  Not a
#  production compiler — designed for compiler-construction
#  education and research.  Compilation pipeline: C source →
#  Sericum IR (LLVM-IR-like) → optimization passes → x86_64
#  machine code.  Sister tools: rustc (in corpus via _rustc +
#  STOCK in Rust toolchain), clang (in corpus + STOCK on macOS/
#  many Linux), gcc (in corpus + STOCK on Linux), tcc (in corpus
#  via _tcc — Tiny C Compiler), 8cc (Rui Ueyama's experimental
#  C compiler in C), chibicc (Rui Ueyama's tutorial C compiler),
#  cproc (Q. Ueyama-style compiler), zig-cc (Zig's wrapped C
#  compiler).
#
#  CLI library taxonomy update: 16th Rust CLI library — Hideyuki
#  "tanakh" Tanaka's **argopt** (tanakh/argopt).  Rust ecosystem
#  now has 16 documented CLI libraries — TYING WITH GO at the
#  top of the cross-language taxonomy ahead of TypeScript-Node
#  (15).  🎉 Rust RE-TIES with Go at 16.
#
#  argopt (tanakh/argopt, 35 stars) is Hideyuki Tanaka's PROC-
#  MACRO-DRIVEN CLI builder that converts ORDINARY RUST FUNCTIONS
#  into CLI parsers via `#[cmd]` attribute macros.  Distinguishing
#  philosophy: the FUNCTION SIGNATURE IS THE SCHEMA — function
#  parameters become CLI arguments (positionals by default,
#  flags when annotated with `#[opt(short, long, default_value_t
#  = X)]`).  Doc-comments above parameters become the `--help`
#  text for each arg.  Built on TOP of clap (via structopt
#  internally — argopt is essentially a function-shaped wrapper
#  over structopt/clap_derive's struct-shaped derive).  Used by
#  maekawatoshiki/sericum (compiler-infrastructure research 402
#  stars; uses argopt in sericumcc/src/main.rs), tanakh/super-
#  sabicom (SNES emulator, tanakh's own project), fuqinho/
#  icfpc2023 (ICFP contest 2023 entry), genya0407/minutus
#  (Ruby-Rust interop tool 26 stars), eiel/github_pull_request_
#  summary, taka231/lunalang (Luna language compiler 2 stars),
#  and many other small Rust tools that prefer function-shape
#  CLI declaration over struct-derive.
#
#  argopt API:
#    use argopt::{cmd, cmd_group, opt};
#
#    // SIMPLE: function args → CLI args
#    #[cmd]
#    fn main(host: String, port: u16) {
#      // host and port come from CLI argv as positional args
#      // — usage: ./binary <HOST> <PORT>
#    }
#
#    // WITH PER-ARG opt() ATTRIBUTES → flags instead of positionals
#    /// Sample program description
#    #[cmd]
#    fn main(
#      /// Host name documentation (becomes --help text)
#      #[opt(short = 'h', long = "host")]
#      host: String,
#
#      /// Port number
#      #[opt(short, long, default_value_t = 80)]
#      port: u16,
#
#      /// Verbose output (boolean flag)
#      #[opt(short, long)]
#      verbose: bool,
#
#      /// Optional config file
#      #[opt(short = 'c', long, default_value = "config.toml")]
#      config: String,
#    ) {
#      // ...
#    }
#
#    // BUILT-IN VERBOSITY: #[cmd(verbose)] auto-registers
#    // -v/-vv/-vvv/-q flags + env_logger initialization
#    #[cmd(verbose)]
#    fn main() {
#      error!("This is error");
#      warn!("This is warn");
#      info!("This is info");
#      debug!("This is debug");
#      trace!("This is trace");
#    }
#
#    // SUBCOMMANDS via #[cmd_group(commands = [hello, world])]
#    #[cmd]
#    fn hello(name: String) {
#      println!("Hello, {}!", name);
#    }
#
#    #[cmd]
#    fn world(planet: String) {
#      println!("World of {}!", planet);
#    }
#
#    #[cmd_group(commands = [hello, world])]
#    fn main() {}
#
#  argopt distinctive features:
#    - FUNCTION-AS-CLI proc-macro — `#[cmd]` on a function turns
#      it into a CLI parser; function parameters become CLI args
#    - DOC-COMMENT-AS-HELP — `/// Description` doc-comments above
#      parameters become per-arg --help text; doc-comment above
#      the function becomes the program description
#    - DEFAULT BEHAVIOR — parameters with NO `#[opt(...)]`
#      attribute become REQUIRED POSITIONAL arguments (uppercase
#      converted naming: `host` → `<HOST>`)
#    - `#[opt(short, long)]` — marks parameter as a FLAG
#      (`--name`/`-n`) instead of positional
#    - `#[opt(short = 'X')]` — explicit short flag char
#    - `#[opt(long = "name")]` — explicit long flag name override
#    - `#[opt(default_value_t = 80)]` — typed default value
#      (uses Rust type inference on the parameter's type)
#    - `#[opt(default_value = "string")]` — default as string
#      literal (parsed via FromStr)
#    - `Vec<T>` parameter type → REPEATABLE flag (each occurrence
#      appends)
#    - `Option<T>` parameter type → optional flag (no error if
#      missing)
#    - `bool` parameter type → boolean flag (presence = true)
#    - `#[cmd(verbose)]` — argument-less variant that auto-
#      registers `-v/-vv/-vvv` verbosity flags + initializes
#      env_logger to match
#    - `#[cmd_group(commands = [fn1, fn2, ...])]` — SUBCOMMAND
#      dispatch with each listed function as a separate
#      subcommand; the wrapped main() function never runs (the
#      subcommand routing replaces it)
#    - BUILT ON STRUCTOPT/clap_derive internally — argopt is
#      essentially a function-signature-to-struct transformer
#      that delegates to structopt's derive macro for the actual
#      parsing; inherits clap's full feature set (color output,
#      auto-help, suggest-similar-flag, etc.)
#    - INSPIRED BY Python's Click (Armin Ronacher) — same
#      function-decorator philosophy where the function signature
#      IS the schema; argopt is the Rust attribute-macro
#      equivalent
#  Distinct from R275 Rust clap-derive (proc-macro
#  `#[derive(Parser)]` on a STRUCT — opposite philosophy:
#  struct-shaped schema where each field is an arg; argopt is
#  function-shaped where each parameter is an arg), R330 Rust
#  bpaf (functional applicative combinator), R344 Rust google/
#  argh (Google Fuchsia-OS derive-on-struct), R347 Rust
#  RazrFalcon/pico-args (LOW-LEVEL imperative pull parser), R404
#  Rust matklad/xflags (declarative MACRO block syntax), R407
#  Rust blyxxyz/lexopt (MINIMAL iterator-based pull parser),
#  R410 Rust murarth/gumdrop (zero-dep derive-macro), R413 Rust
#  docopt/docopt.rs (USAGE-STRING-IS-SPEC), R416 Rust rust-lang/
#  getopts (OFFICIAL POSIX-getopt(3) port), R420 Rust ksk001100/
#  seahorse (Cobra-for-Rust chained-builder).  Rust documented
#  libraries so far: clap-derive, bpaf, argh, pico-args, xflags,
#  lexopt, gumdrop, docopt.rs, getopts, seahorse, argopt (this
#  round) plus older clap-builder, structopt (deprecated, now
#  clap_derive)... 16 total.  argopt's distinguishing feature
#  vs all other Rust libs: argopt is the ONLY Rust CLI library
#  in the corpus that uses the FUNCTION-AS-CLI proc-macro
#  pattern.  Conceptually similar to Python's Click (`@click.
#  command()` decorator + function signature as schema) but in
#  Rust's attribute-macro syntax.  argopt's approach: FUNCTION-
#  AS-CLI proc-macro with `#[cmd]` attribute on function + auto-
#  derived positionals from function params (or `#[opt(short,
#  long, default_value_t)]` per-param attributes for flag
#  conversion) + DOC-COMMENT-AS-HELP (/// above params and fn) +
#  `#[cmd(verbose)]` shorthand for -v/-vv/-vvv + env_logger
#  integration + `#[cmd_group(commands = [...])]` subcommand
#  dispatch + Vec<T> → repeatable, Option<T> → optional, bool →
#  flag + BUILT ON STRUCTOPT/clap_derive internally (inherits
#  clap's full feature set: color, auto-help, suggest-flag) +
#  INSPIRED BY Python Click — corpus's **first documented
#  function-as-CLI proc-macro Rust CLI library**.  Brings cross-
#  language CLI library taxonomy variant count to 166; Rust
#  ecosystem now has 16 documented CLI libraries — TYING WITH
#  GO at the top of the cross-language taxonomy ahead of
#  TypeScript-Node (15).
#
#  Surface (verbatim from `sericumcc/src/main.rs` argopt `#[cmd]`
#  function signature):
#
#  Usage:
#    sericumcc [options] [files...]
#
#  Positional:
#    files...                       Input files (*.c) — C source
#                                   files to compile to x86_64
#                                   machine code via the Sericum
#                                   compiler pipeline
#
#  Options (auto-generated by argopt → structopt → clap):
#    -h, --help                     Print help information
#    -V, --version                  Print version information
#
#  Examples:
#    sericumcc hello.c                          # Compile single C file
#    sericumcc file1.c file2.c file3.c          # Compile multiple files
#    sericumcc --help                           # Show help
#    sericumcc --version                        # Show version
#
#  Notes:
#    - sericumcc's CLI surface is INTENTIONALLY MINIMAL — this
#      is an experimental compiler-infrastructure research
#      project, not a production tool.  Most options that DMD/
#      clang/gcc expose (-O0/-O1/-O2/-c/-S/-o/-g/-I/-L) are NOT
#      exposed by sericumcc — they're hardcoded to a default
#      compile-and-link pipeline.
#    - The actual Sericum IR optimization passes and codegen
#      options are not flag-controllable from this CLI — they're
#      compile-time decisions in the sericum crate.
#    - For more usage, see Sericum's parent repo's docs-ja/
#      (Japanese documentation).
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also argopt users):
#    - super-sabicom (tanakh/super-sabicom 25 stars — SNES
#      emulator; tanakh's own project; uses argopt in examples/
#      *.rs scripts not main binary; FUTURE candidate if standalone
#      binaries are added)
#    - minutus (genya0407/minutus 26 stars — Ruby-Rust interop;
#      FUTURE candidate)
#    - lunalang (taka231/lunalang 2 stars — too niche)
#    - github_pull_request_summary (eiel — too niche)
#    - scan-rust (genya0407 — too niche)
#    - argopt repo itself (tanakh/argopt 35 stars — library not CLI)
# ============================================================================

_sericumcc() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[print help information]' \
    '(-V --version)'{-V,--version}'[print version information]' \
    '*:file:_files -g "*.c"'
}

_sericumcc "$@"
