#compdef arfgen
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/arfgen/node34.html
# XMM-Newton SAS: create an OGIP-compliant Ancillary Response File (ARF)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--spectrumset=[input spectrum dataset name]:file:_files' \
  '--arfset=[output ancillary response dataset name]:file:_files' \
  '--withrmfset=[use RMF dataset to define ARF energy grid]:flag:(yes no)' \
  '--rmfset=[input response dataset name]:file:_files' \
  '--detmaptype=[detector map origin]:type:(dataset flat psf)' \
  '--detmaparray=[detector map dataset and array]:array:' \
  '--withdetbounds=[use parameters for detector map bounds]:flag:(yes no)' \
  '--detxoffset=[half-width of detector map (DET coords)]:offset:' \
  '--detyoffset=[half-height of detector map (DET coords)]:offset:' \
  '--withdetbins=[use parameters for detector map binning]:flag:(yes no)' \
  '--detxbins=[number of bins along x-axis]:bins:' \
  '--detybins=[number of bins along y-axis]:bins:' \
  '--psfenergy=[PSF model energy in keV]:energy:' \
  '--filterdss=[filter detector map using DSS info]:flag:(yes no)' \
  '--withfilteredset=[write filtered detector map to file]:flag:(yes no)' \
  '--filteredset=[output filtered detector map name]:file:_files' \
  '--withsourcepos=[manually specify source position]:flag:(yes no)' \
  '--sourcecoords=[source position coordinate system]:coords:' \
  '--sourcex=[source x-position]:x:' \
  '--sourcey=[source y-position]:y:' \
  '--extendedsource=[identify if source is extended]:flag:(yes no)' \
  '--useodfatt=[use full attitude file from OAL]:flag:(yes no)' \
  '--withbadpixcorr=[apply CCD gap and bad pixel corrections]:flag:(yes no)' \
  '--badpixlocation=[bad pixel location file]:file:_files' \
  '--badpixelresolution=[resolution for encircled energy calc]:res:' \
  '--badpixmaptype=[bad pixel correction map type]:type:' \
  '--ignoreoutoffov=[exclude off-axis areas]:flag:(yes no)' \
  '--modeleffarea=[include effective area calibration data]:flag:(yes no)' \
  '--modelquantumeff=[include quantum efficiency data]:flag:(yes no)' \
  '--modelfiltertrans=[include filter transmission data]:flag:(yes no)' \
  '--modelee=[apply encircled energy correction]:flag:(yes no)' \
  '--psfmodel=[PSF model selection]:model:' \
  '--modelootcorr=[apply out-of-time correction]:flag:(yes no)' \
  '--applyxcaladjustment=[adjust effective areas for consistency]:flag:(yes no)' \
  '--applyabsfluxcorr=[adjust to absolute flux reference]:flag:(yes no)' \
  '--eegridfactor=[oversampling factor for energy correction]:factor:' \
  '--setbackscale=[set BACKSCAL to calculated region area]:flag:(yes no)' \
  '--keeparfset=[retain or delete calculated ARF file]:flag:(yes no)' \
  '--crossregionarf=[calculate cross-region ARF]:flag:(yes no)' \
  '--crossreg_spectrumset=[spectrum containing input region]:file:_files' \
  '*:spectrum file:_files' && ret=0

return ret
