#compdef wakeuptime wakeuptime-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/wakeuptime.py argparse)
# Reference accessed: 2026-05-29
# wakeuptime — sample task waker stacks during block time (BCC/eBPF). Flame-graph-ready.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --useronly)'{-u,--useronly}'[user threads only (no kernel threads)]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-v --verbose)'{-v,--verbose}'[show raw addresses]' \
  '(-f --folded)'{-f,--folded}'[output folded format (for flame graphs)]' \
  '--stack-storage-size=[number of unique stack traces stored (default 16384)]:N:' \
  '(-m --min-block-time)'{-m,--min-block-time=}'[min time in microseconds over which to store traces (default 1)]:us:' \
  '(-M --max-block-time)'{-M,--max-block-time=}'[max time in microseconds under which to store traces (default U64_MAX)]:us:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:duration (seconds, default unlimited):' \
  && ret=0

return ret
