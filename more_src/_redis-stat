#compdef redis-stat
# Documentation: https://github.com/junegunn/redis-stat
# Reference accessed: 2026-05-16
# Verified: upstream junegunn/redis-stat README. Ruby gem; unmaintained but
# flag set is stable.
# Removed from prior file: fabricated -V flag (real flag is --version
# only) and bogus man.archlinux.org search URL.

# redis-stat: Redis monitoring tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-a --auth)'{-a+,--auth=}'[password]:password:' \
  '(-v --verbose)'{-v,--verbose}'[show more info]' \
  '--style=[output style]:style:(unicode ascii)' \
  '--no-color[suppress ANSI color codes]' \
  '--csv=[save results in CSV format]:file:_files' \
  '--es=[send results to Elasticsearch URL]:url:' \
  '--server=-[launch web server (default port 63790)]:port:' \
  '--daemon[daemonize (requires --server)]' \
  '*:host\:port[/pass] or interval or count:' && ret=0
return ret
