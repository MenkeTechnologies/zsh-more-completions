#compdef jack_freewheel
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/tools/freewheel.c
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above.
# Note: prior file invented -h and -s flags and wrong "on off" enum;
# real usage is "jack_freewheel y|n" — single positional, no options.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:mode:(y n)' && ret=0

return ret
