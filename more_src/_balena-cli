#compdef balena
# _balena — balena CLI (manage balenaCloud fleets, devices, releases, OS images; subcommands: login/logout/whoami, fleet/device/release/api-key/os, push/build/deploy/preload, ssh/tunnel/scan/logs, organization, env, support, util)
# upstream: https://github.com/balena-io/balena-cli
# Subcommands from balena-cli src/commands index on tip.

_balena() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'balena command' \
                '(login logout whoami help fleet device release tag note ssh tunnel scan logs push deploy build preload os env block organization config api-key support util)'
            ;;
        args)
            case $line[1] in
                fleet|device|release|api-key|os|env|block|organization|tag|note) _describe -t commands 'subcommand' '(list create rename rm restart shutdown reboot move pin track purge identify deactivate)' ;;
                login) _describe -t commands 'login method' '(web token credentials)' ;;
                push|build|deploy) _arguments '*:dir:_files -/' ;;
            esac
            ;;
    esac
}

_balena "$@"
