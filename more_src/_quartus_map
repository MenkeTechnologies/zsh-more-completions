#compdef quartus_map
# _quartus_map — Intel Altera Quartus quartus_map CLI for the analysis and synthesis stage of the Quartus Prime FPGA flow performing HDL elaboration logic synthesis technology mapping into Intel FPGA device atoms LUT FF DSP RAM (Intel team, C++); custom argparse
# upstream: https://www.intel.com/content/www/us/en/products/details/fpga/development-tools/quartus-prime.html

_quartus_map() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--rev=+[revision]:str:' \
        '--revision=+[revision]:str:' \
        '--write_settings_files[write settings files]' \
        '--no_write_settings_files[no write settings files]' \
        '--family=+[family]:f:(Cyclone10LP Cyclone10GX CycloneIV CycloneV Arria10 ArriaV ArriaII Stratix10 StratixV StratixIV MAX10 MAXII MAXV)' \
        '--device=+[device]:str:' \
        '--source=+[hdl file]:file:_files -g "*.v *.sv *.vhd *.vhdl"' \
        '--read_settings_files[read settings files]' \
        '--list-extensions[list extensions]' \
        '--archive=+[file]:file:_files -g "*.qar"' \
        '--64bit[64-bit mode]' \
        '--effort=+[e]:e:(auto fast standard high)' \
        '*:project name:_files -g "*.qpf *.qsf"'
}

_quartus_map "$@"
