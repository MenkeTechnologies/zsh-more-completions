#compdef alacritty-cli2 alacritty2
# _alacritty-cli2 — Joe Wilm Alacritty alacritty-cli2 CLI command-line frontend wrapping the Alacritty fast cross-platform OpenGL terminal emulator open-source written in Rust originally Joe Wilm now Alacritty community simple minimal terminal emulator GPU accelerated true color support OSC52 24bit hi-DPI Vi mode regex search Daemon mode no tabs no panes no tmux-like multiplexer integration only-pure-emulator window-config window-class window-title font-family font-size colors-toml colors-yaml config-file scroll history-vi-mode keybindings scroll-lines clear-region scroll-half-page scroll-page msg create-window socket migrate (Joe Wilm Alacritty community team, Rust); clap
# upstream: https://alacritty.org/

_alacritty-cli2() {
    local -a sub=(
        'msg:Send a message to a running Alacritty instance'
        'migrate:Migrate the config to the new format'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--print-events[print events]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-qq[more quiet]' \
        '--ref-test[reference test]' \
        '-e+[command]:_command_names' \
        '*-e+[command]:_command_names' \
        '--command=+[cmd]:_command_names' \
        '*--command=+[cmd]:_command_names' \
        '--working-directory=+[dir]:dir:_files -/' \
        '--config-file=+[file]:file:_files -g "alacritty.toml *.toml *.yml *.yaml"' \
        '-T+[title]:str:' \
        '--title=+[title]:str:' \
        '--class=+[name]:str:' \
        '--name=+[name]:str:' \
        '--instance=+[name]:str:' \
        '--embed=+[xid]:str:' \
        '--option=+[k=v]:str:' \
        '*--option=+[k=v]:str:' \
        '-o+[k=v]:str:' \
        '*-o+[k=v]:str:' \
        '--socket=+[file]:_files' \
        '-s+[socket]:_files' \
        '--hold[hold open]' \
        '--position=+[X,Y]:str:' \
        '--dimensions=+[cols,lines]:str:' \
        '--no-startup-notification[no startup notification]' \
        '--daemon[run as daemon]' \
        '-d[daemon]' \
        '--print-config[print config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alacritty subcommand' sub ;;
        args)
            case $words[1] in
                msg) _arguments '1:op:(create-window config get-config)' '*:arg:' ;;
                migrate) _arguments '*:config:_files' ;;
            esac
            ;;
    esac
}

_alacritty-cli2 "$@"
