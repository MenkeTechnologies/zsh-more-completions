#compdef ebuild
# Documentation: https://man.archlinux.org/search?q=ebuild
# Reference accessed: 2026-05-16

local -a phases

phases=(
  help setup clean fetch digest manifest unpack prepare configure compile
  test install preinst instprep postinst qmerge merge unmerge prerm postrm
  config package rpm
)

_arguments -s \
  '--debug[debug output]' \
  '--color[colorize output]:yn:(y n)' \
  '--force[force]' \
  '--ignore-default-opts[ignore EMERGE_DEFAULT_OPTS]' \
  '--skip-manifest[skip manifest check]' \
  '1:ebuild file:_files -g "*.ebuild"' \
  "*:phase:($phases)"
