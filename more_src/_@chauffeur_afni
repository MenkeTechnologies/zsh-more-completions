#compdef @chauffeur_afni
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@chauffeur_afni.html
# Generate montage images of neuroimaging data for QC and visualization

local ret=1

_arguments -s -S \
  '-ulay[underlay dataset (required); 3D or 4D]:dset:_files' \
  '-olay[overlay dataset (optional)]:dset:_files' \
  '-prefix[prefix for output files (required)]:prefix' \
  '-mode_4D[view single slice across all 4D volumes]' \
  '-olay_off[explicitly indicate no overlay dataset]' \
  '-ulay_range[min/max display range for underlay]:umin' \
  '-ulay_range_nz[set range using non-zero voxels only]:umin' \
  '-ulay_range_am[set range using automasked voxels only]:umin' \
  '-func_range[upper value for overlay colorbar mapping]:fr' \
  '-func_range_perc_nz[overlay range via percentile of non-zero values]:frp' \
  '-cbar[specify colorbar]:ccc' \
  '-opacity[overlay opacity factor (0-9, 9=opaque)]:oo' \
  '-blowup[increase spatial resolution by factor (1-8)]:bb' \
  '-montx[image columns in montage (default 3)]:mx' \
  '-monty[image rows in montage (default 3)]:my' \
  '-montgap[border pixels between montage panels (default 0)]:mg' \
  '-set_subbricks[subbricks for underlay, overlay, threshold]:i' \
  '-set_ijk[set controller coordinates by index]:ii' \
  '-set_dicom_xyz[set controller coordinates in DICOM RAI]:xx' \
  '-thr_olay[threshold overlay at specified value]:thr' \
  '-thr_olay_p2stat[threshold overlay using p-value conversion]:pp' \
  '-thr_olay_pside[sidedness for p-to-stat]:ss:(bisided 2sided 1sided)' \
  '-box_focus_slices[focus montage slices using autoboxed reference]:ref:_files' \
  '-delta_slices[slice spacing for sag, cor, axi views]:ds' \
  '-no_cor[omit coronal slice views]' \
  '-no_axi[omit axial slice views]' \
  '-no_sag[omit sagittal slice views]' \
  '-olay_alpha[apply opacity fading to overlay]:val:(No Yes Linear Quadratic)' \
  '-olay_boxed[draw box around supra-threshold voxels]:val:(No Yes)' \
  '-clusterize[apply 3dClusterize options to overlay]:opts' \
  '*:dataset:_files' && ret=0

return ret
