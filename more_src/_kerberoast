#compdef kerberoast kerberoast.py
# _kerberoast — skelsec kerberoast Python tool to request kerberos service tickets for offline cracking (skelsec team, Python); argparse
# upstream: https://github.com/skelsec/kerberoast

_kerberoast() {
    local -a sub=(
        'tgt:request a TGT'
        'tgs:request a TGS'
        'asreproast:asreproast brute force user list'
        'spnroast:request all SPN-bound user TGS for offline cracking'
        'brute:brute-force valid usernames'
        'changepw:change password'
        's4u:s4u2self s4u2proxy'
        'ldap:ldap subcommand'
        'auto:auto roast common targets'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kerberoast subcommand' sub ;;
        args)
            case $words[1] in
                tgt|tgs|s4u) _arguments \
                    '*:credentials url:' ;;
                asreproast) _arguments \
                    '--realm=+[realm]:str:' \
                    '-r+[realm]:str:' \
                    '--dc-ip=+[dc ip]:host:_hosts' \
                    '-d+[dc ip]:host:_hosts' \
                    '--user-file=+[users file]:file:_files' \
                    '-u+[users file]:file:_files' \
                    '--out-file=+[output]:file:_files' \
                    '-o+[output]:file:_files' \
                    '*:user:_users' ;;
                spnroast) _arguments \
                    '--out-file=+[output]:file:_files' \
                    '-o+[output]:file:_files' \
                    '*:credentials url:' ;;
                brute) _arguments \
                    '--realm=+[realm]:str:' \
                    '--dc-ip=+[dc ip]:host:_hosts' \
                    '--user-file=+[users file]:file:_files' \
                    '*:user:_users' ;;
                changepw) _arguments \
                    '--new-password=+[new password]:str:' \
                    '*:credentials url:' ;;
                ldap) _arguments '1:ldap cmd:(connect users computers groups dump spns)' ;;
                auto) _arguments \
                    '*:credentials url:' ;;
            esac
            ;;
    esac
}

_kerberoast "$@"
