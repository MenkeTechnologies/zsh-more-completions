#compdef drfindname
# Documentation: https://man.archlinux.org/search?q=drfindname
# Reference accessed: 2026-05-16

# EMBOSS drfindname: find DRCAT data resources by name
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-outfile=[output file]:file:_files' \
  '-sensitive[also search descriptions]' \
  '-outformat=[output format]:format:(drcat list text excel xml tagseq)' \
  '*:resource name:' && ret=0
return ret
