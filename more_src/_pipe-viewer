#compdef pipe-viewer
# Documentation: https://github.com/trizen/pipe-viewer
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-sv --search-videos)'{-sv,--search-videos}'[search for videos (default)]' \
  '(-sc --channels)'{-sc,--channels}'[search for channels]' \
  '(-sp --search-pl)'{-sp,--search-pl}'[search for playlists]' \
  '(-sm --movies)'{-sm,--movies}'[search for movies]' \
  '(-uv --uploads)'{-uv,--uploads=}'[list channel uploads]:channel:' \
  '(-us --streams)'{-us,--streams=}'[list livestreams]:channel:' \
  '--shorts=[list short videos]:channel:' \
  '(-pv --popular)'{-pv,--popular=}'[popular videos from channel]:channel:' \
  '(-up --playlists)'{-up,--playlists=}'[list channel playlists]:channel:' \
  '(-lp --local-playlists)'{-lp,--local-playlists}'[display local playlists]' \
  '--pid=[access playlist by ID]:id:' \
  '(-id --videoids)'{-id,--videoids=}'[play videos by IDs]:ids:' \
  '(-rv --related)'{-rv,--related=}'[show related videos]:video:' \
  '(-d --download)'{-d,--download}'[activate download mode]' \
  '(-i --info)'{-i,--info=}'[display video information]:video:' \
  '(-e --extract)'{-e,--extract=}'[extract metadata from videos]:video:' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen playback]' \
  '(-n --novideo)'{-n,--novideo}'[audio-only mode]' \
  '--player=[select media player]:player:_command_names' \
  '(-A --all)'{-A,--all}'[play all results sequentially]' \
  '(-B --backwards)'{-B,--backwards}'[reverse playback order]' \
  '--order=[sort order]:order:(relevance rating date views)' \
  '--duration=[filter by video length]:duration:(short long)' \
  '--time=[filter by publication period]:time:(hour today week month year)' \
  '--results=[results per page (max 50)]:count:' \
  '--page=[starting page number]:page:' \
  '--config=[config file]:file:_files' \
  '--update-config[regenerate config file]' \
  '*:search terms:' && ret=0

return ret
