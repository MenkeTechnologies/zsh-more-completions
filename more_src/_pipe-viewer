#compdef pipe-viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-n+[number of results]:count:' \
  '--results=[number of results]:count:' \
  '-r+[resolution]:resolution:(best 1080p 720p 480p 360p 240p 144p audio worst)' \
  '--resolution=[resolution]:resolution:(best 1080p 720p 480p 360p 240p 144p audio worst)' \
  '-f[fullscreen mode]' \
  '--fullscreen[fullscreen mode]' \
  '-d[download mode]' \
  '--download[download mode]' \
  '--download-dir=[download directory]:directory:_directories' \
  '-4[prefer IPv4]' \
  '--ipv4[prefer IPv4]' \
  '-6[prefer IPv6]' \
  '--ipv6[prefer IPv6]' \
  '--player=[video player]:player:_command_names' \
  '--player-args=[player arguments]:args:' \
  '--comments[show comments]' \
  '--no-video-info[do not show video info]' \
  '--raw-urls[show raw URLs]' \
  '--info[show video info only]' \
  '--really-raw-urls[show really raw URLs]' \
  '--cookie-file=[cookie file]:cookie file:_files' \
  '--dash[prefer DASH streams]' \
  '--no-dash[do not use DASH streams]' \
  '--custom-layout=[terminal layout]:layout:' \
  '-C+[config directory]:directory:_directories' \
  '--config-dir=[config directory]:directory:_directories' \
  '*:search terms or video URLs:' && ret=0

return ret
