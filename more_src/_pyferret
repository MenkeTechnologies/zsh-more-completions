#compdef pyferret
# Documentation: https://ferret.pmel.noaa.gov/Ferret/documentation/pyferret/pyferret-quick-start-notes
# pyferret - PyFerret data visualization and analysis tool

local ret=1

_arguments -s \
  '(-help -h)'{-help,-h}'[show help on command-line switches]' \
  '-version[display version information]' \
  '-memsize[set data cache size in Megawords]:megawords' \
  '-nojnl[start without a journal file]' \
  '-noverify[disable command verification mode]' \
  '-secure[prevent execution of SPAWN commands]' \
  '-server[run in server mode]' \
  '-script[run script then exit (must be last)]:journal file:_files -g "*.(jnl|py)"' \
  '-nodisplay[do not display to console; save via FRAME command]' \
  '-quiet[do not display the startup header]' \
  '-python[start at the Python prompt instead of the Ferret prompt]' \
  '-gif[alias for -nodisplay]' \
  '-unmapped[alias for -nodisplay]' \
  '-batch[batch mode (not recommended; use -nodisplay)]' \
  '*:file:_files' && ret=0

return ret
