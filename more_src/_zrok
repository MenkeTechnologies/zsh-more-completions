#compdef zrok

_zrok_cmds() {
    local -a commands=(
        'invite:generate an invite token'
        'enable:enable zrok environment'
        'disable:disable zrok environment'
        'share:share a resource'
        'access:access a shared resource'
        'reserve:reserve a share token'
        'release:release a reserved share'
        'status:show environment status'
        'config:manage configuration'
        'modpolicy:manage policies'
        'overview:show account overview'
        'copy:copy files to a share'
        'md:host a markdown browsing site'
        'test:built-in test utilities'
        'admin:administration commands'
        'controller:run the zrok controller'
        'frontend:run the zrok frontend'
        'version:print version'
        'completion:generate shell completions'
        'help:print help information'
    )
    _describe -t commands 'zrok command' commands
}

_zrok() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '--panic-instead-of-exit[panic instead of exit on error]' \
        '(-V --verbose)'{-V,--verbose}'[enable verbose logging]' \
        '1:command:_zrok_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                enable)
                    _arguments \
                        '--description=[environment description]:description' \
                        '1:token'
                    ;;
                share)
                    _arguments \
                        '1:mode:(public private reserved)' \
                        '--backend-mode=[backend mode]:mode:(proxy web tcpTunnel udpTunnel caddy drive socks)' \
                        '--headless[headless mode]' \
                        '--insecure[skip TLS verification]' \
                        '--closed[require authentication]' \
                        '--basic-auth=[basic auth credentials]:user\:pass' \
                        '--oauth-provider=[OAuth provider]:provider:(github google)' \
                        '--oauth-email-domains=[allowed email domains]:domains' \
                        '--oauth-check-interval=[OAuth check interval]:duration' \
                        '--frontends=[frontends to use]:frontends' \
                        '--force-chosen-frontends[force chosen frontends]' \
                        '--unique-name=[unique share name]:name' \
                        '*:target'
                    ;;
                access)
                    _arguments \
                        '1:mode:(private)' \
                        '--bind=[local bind address]:address' \
                        '--headless[headless mode]' \
                        '--auto[auto-start access]' \
                        '--response-headers=[custom response headers]:headers' \
                        '2:share-token'
                    ;;
                reserve)
                    _arguments \
                        '--backend-mode=[backend mode]:mode:(proxy web tcpTunnel udpTunnel caddy drive socks)' \
                        '--unique-name=[unique share name]:name' \
                        '--closed[require authentication]' \
                        '--basic-auth=[basic auth credentials]:user\:pass' \
                        '--oauth-provider=[OAuth provider]:provider:(github google)' \
                        '--oauth-email-domains=[allowed email domains]:domains' \
                        '*:target'
                    ;;
                release)
                    _arguments '1:share-token'
                    ;;
                config)
                    _arguments \
                        '1:action:(set get unset)' \
                        '2:key:(apiEndpoint defaultFrontend)' \
                        '3:value'
                    ;;
                invite)
                    _arguments \
                        '--token=[invite token]:token'
                    ;;
                copy)
                    _arguments \
                        '*:source:_files' \
                        ':target'
                    ;;
                admin)
                    _arguments \
                        '1:action:(create delete list update bootstrap)'
                    ;;
                controller)
                    _arguments \
                        '--config=[controller config file]:file:_files'
                    ;;
                frontend)
                    _arguments \
                        '--config=[frontend config file]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_zrok "$@"
