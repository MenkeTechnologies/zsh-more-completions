#
# WHAT IS debug AND WHY IS IT THE 55TH TS-NODE CLI LIBRARY?
#
# debug (https://github.com/debug-js/debug, 11200+ stars) is
# **TJ Holowaychuk's "tiny JavaScript debugging utility modelled
# after Node.js core's debugging technique"** — the FOUNDATIONAL
# NODE.JS DEBUG-LOGGING LIBRARY since 2011.  TJ created debug as
# part of the Express.js ecosystem at a time when Node.js core
# had no debug-logging convention.  The DEBUG=namespace
# environment-variable pattern that debug introduced became
# UBIQUITOUS across the Node ecosystem.
#
# debug's distinguishing characteristics:
#
#   1. NAMESPACE-FILTERED LOGGING (not level-filtered) —
#      debug's CENTRAL design departure from level-based loggers
#      (logrus/winston/pino): every log call belongs to a
#      NAMED NAMESPACE, and filtering is by NAMESPACE PATTERN
#      via DEBUG environment variable:
#
#          import Debug from 'debug';
#
#          const debugApp = Debug('myapp:server');
#          const debugDB = Debug('myapp:database');
#          const debugAuth = Debug('myapp:auth');
#
#          debugApp('listening on port %d', 3000);
#          debugDB('connected to %s', dbHost);
#          debugAuth('user %s authenticated', username);
#
#          // Run with:
#          //   DEBUG=myapp:server node app.js
#          //     -> only server logs visible
#          //   DEBUG=myapp:*  node app.js
#          //     -> all myapp:* namespaces
#          //   DEBUG=*  node app.js
#          //     -> all namespaces from all libraries
#          //   DEBUG=*,-express:router node app.js
#          //     -> all EXCEPT express:router
#
#      Compare:
#         * winston: level-based filtering (Debug/Info/Warn/Error)
#         * pino: level-based filtering
#         * consola: level-based filtering
#         * debug: NAMESPACE-PATTERN filtering via env var
#      FIRST documented Node.js logger with namespace-based
#      filtering (predates env_logger's RUST_LOG by ~3 years;
#      influenced env_logger's design).
#
#   2. PRINTF-STYLE FORMATTING WITH CUSTOM FORMATTERS — debug
#      uses Node's `util.format()` printf semantics:
#
#          debug('user %s purchased %d items for $%f',
#                username, qty, price);
#          // Output: myapp:cart user alice purchased 3 items for $99.99 +5ms
#
#      Custom formatters are registered via `debug.formatters`:
#
#          debug.formatters.h = (v) =>
#              `0x${v.toString(16)}`;
#
#          debug('addr is %h', 0xdeadbeef);
#          // Output: myapp:mem addr is 0xdeadbeef
#
#      Built-in formatters: %s/%d/%i/%f/%j/%J/%c/%o/%O
#      Compare:
#         * winston: format functions via .format()
#         * pino: object-based fields (no printf)
#         * debug: PRINTF + custom %X formatters
#      FIRST documented Node.js logger with printf-style
#      formatting + extensible custom formatters.
#
#   3. AUTOMATIC ELAPSED-TIME TRACKING — Each `debug()` call
#      automatically appends the elapsed time since the
#      previous call IN THAT SAME NAMESPACE:
#
#          const dbg = Debug('app:work');
#          dbg('step 1 starting');
#          // ...time passes...
#          dbg('step 1 done');     // shows +15ms
#          // ...
#          dbg('step 2 done');     // shows +42ms
#
#      Output:
#          app:work step 1 starting +0ms
#          app:work step 1 done +15ms
#          app:work step 2 done +42ms
#
#      Per-namespace elapsed-time tracking is ALWAYS-ON (no
#      configuration).  Built-in for "how long did X take"
#      micro-profiling without manual timestamping.
#      Compare:
#         * winston: requires explicit profile() / endTimer()
#         * pino: no built-in elapsed
#         * debug: ALWAYS-ON per-namespace elapsed time
#      FIRST documented Node.js logger with automatic always-on
#      elapsed-time tracking per namespace.
#
#   4. ZERO-COST WHEN DISABLED — When the namespace is NOT
#      enabled via DEBUG env var, the returned function is a
#      no-op that short-circuits immediately:
#
#          const dbg = Debug('disabled-by-default');
#          dbg('this string is %j',
#              expensiveSerialize());
#          // Without DEBUG=disabled-by-default, the no-op
#          // function returns immediately WITHOUT evaluating
#          // arguments — expensiveSerialize() is NOT called
#
#      Wait, actually that's NOT true — JS evaluates args
#      eagerly.  But the FORMATTING is skipped.  For zero-cost
#      arg evaluation, debug provides a `.enabled` check:
#
#          if (dbg.enabled) dbg('this %j', expensiveSerialize());
#
#      Compare:
#         * winston: similar — no-op when level disabled, but
#                     args evaluated
#         * pino: similar
#         * debug: `.enabled` check for guarded expensive args
#      FIRST documented Node.js logger with `.enabled` property
#      for guarded-expensive-arg pattern.
#
#   5. NODE-CORE-CULTURE FOUNDATIONAL PROVENANCE — debug is
#      one of the OLDEST + MOST-DOWNLOADED Node.js packages.
#      Created by TJ Holowaychuk (also creator of Express +
#      commander + mocha + jade + koa + n) when Node.js was 1
#      year old.  Major adopters:
#         * Express.js (every middleware uses DEBUG=express:*)
#         * Mocha test framework
#         * Socket.io
#         * body-parser
#         * send (HTTP file serving)
#         * Connect
#         * Cookie + cookie-parser
#         * Mongoose ORM
#         * Sequelize ORM
#         * Pug (Jade)
#         * Stylus
#         * sqip (THIS — SQIP image placeholder generator)
#         * Cypress test framework
#         * Tens of thousands of other npm packages
#      1.7B+ weekly npm downloads (top-50 most-downloaded
#      package).  Influenced:
#         * Rust's env_logger RUST_LOG syntax (debug→
#                                                 env_logger ~2014)
#         * Python's structlog debugging patterns
#         * Go's stdlib log/slog Level filtering
#      Compare every other documented Node.js logger — only
#      stdlib console has comparable historical reach, but
#      debug introduced the namespace-pattern + DEBUG=*
#      env-var pattern that influenced multiple languages.
#      FIRST documented Node.js logger with cross-language-
#      influencing 2011-era foundational provenance.
#
# debug's relationship to other documented TS-Node libraries:
#
#   * Like consola/winston/pino — all are Node.js loggers
#   * Unlike consola/winston/pino — namespace-based filtering
#                                    (not level-based);
#                                    automatic elapsed-time
#                                    tracking;
#                                    printf-style formatting
#   * Closest cross-language analogs:
#         * Rust: env_logger (R582) — DEBUG-pattern env-var
#                  filtering INHERITED from debug-js (debug
#                  came first in 2011; env_logger ~2014)
#         * Go: glog (Google's defunct Go logger) — namespace-
#                pattern filtering via --vmodule flag
#         * Python: stdlib `logging` module with named loggers
#                    + dotted-namespace propagation
#     debug is the FIRST documented Node.js logger with
#     namespace-based filtering + DEBUG=*-syntax env-var pattern
#     (the design that influenced env_logger's RUST_LOG syntax).
#
# -----------------------------------------------------------------------------
#
# THE sqip CLI — command-line-args + command-line-usage + debug
#
# sqip's argv parsing in packages/sqip-cli/src/sqip-cli.ts uses
# `command-line-args` (R561) + `command-line-usage`; debug logging
# uses TJ's debug module:
#
#     import commandLineArgs from 'command-line-args'
#     import commandLineUsage from 'command-line-usage'
#     import Debug from 'debug'
#     import { sqip, resolvePlugins } from 'sqip'
#
#     const debug = Debug('sqip-cli')
#
#     const defaultOptionList = [
#         { name: 'help', alias: 'h', description: 'Show help' },
#         { name: 'version', description: 'Show version number' },
#         { name: 'plugins', alias: 'p', type: String, multiple: true,
#           description: 'One or more plugins. E.g. "-p primitive blur"' },
#         { name: 'input', alias: 'i', type: String, required: true },
#         { name: 'output', alias: 'o', type: String,
#           description: 'Output file path (default: guessed)' },
#         { name: 'width', alias: 'w', type: Number, defaultValue: 300,
#           description: 'Output width (negative/0 = original)' },
#         { name: 'silent', type: Boolean, defaultValue: false,
#           description: 'Suppress all output' },
#         { name: 'parseable-output', type: Boolean, defaultValue: false,
#           description: 'Ensure output is parseable (no preview/borders)' },
#         { name: 'print', type: Boolean, defaultValue: false,
#           description: 'Print resulting SVG to stdout' }
#     ]
#
#     // Run with DEBUG=sqip-cli npm sqip ... to see internal logs
#
# Five-axis distinctness from every other documented TS-Node logger:
#
#   1. NAMESPACE-FILTERED (not level-filtered) — Every other
#      documented Node.js logger uses level-based filtering
#      (Debug/Info/Warn/Error).  debug uses namespace-pattern
#      filtering via DEBUG env var.
#
#   2. PRINTF-STYLE FORMATTING WITH CUSTOM FORMATTERS — Every
#      other documented Node.js logger uses object-based
#      structured fields.  debug uses printf-style format
#      strings with extensible custom %X formatters.
#
#   3. AUTOMATIC ELAPSED-TIME TRACKING — Every other documented
#      Node.js logger requires explicit timer setup.  debug
#      includes ALWAYS-ON per-namespace elapsed-time deltas.
#
#   4. `.enabled` GUARD-PROPERTY PATTERN — Every other documented
#      Node.js logger evaluates args even when filtered out.
#      debug exposes `.enabled` property for explicit
#      guarded-arg evaluation.
#
#   5. 2011-ERA NODE-FOUNDATIONAL PROVENANCE — Every other
#      documented Node.js logger emerged 2017+.  debug is from
#      Node.js's first year (2011) — predates and influenced
#      env_logger's RUST_LOG syntax by ~3 years.  Foundational
#      transitive dep of Express + Mocha + Socket.io ecosystem.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/axe312ger/sqip/blob/main/packages/sqip-cli/src/sqip-cli.ts
# `defaultOptionList` array in command-line-args format.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version number]' \
    '*'{-p+,--plugins=}'[one or more plugins (e.g. -p primitive blur)]:plugins:(primitive blur color data-uri svgo)' \
    '(-i --input)'{-i+,--input=}'[input file path (required)]:file:_files -g "*.(jpg|jpeg|png|webp|gif)"' \
    '(-o --output)'{-o+,--output=}'[output file path (default: guessed)]:file:_files' \
    '(-w --width)'{-w+,--width=}'[output width (default 300; 0 or negative = original)]:width:' \
    '--silent[suppress all output]' \
    '--parseable-output[ensure output is parseable (no preview/borders)]' \
    '--print[print resulting SVG to stdout]' \
    && ret=0

return ret
