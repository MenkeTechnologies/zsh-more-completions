#compdef cometbft

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--home=[Node home directory]:directory:_directories' \
  '--log_level=[Logger level filter]:level:' \
  '--trace[Route INFO logs to STDERR]' \
  '--log_format=[Log output format]:format:(plain json)' \
  '--genesis=[Genesis file path]:file:_files' \
  '--priv_validator_key=[Validator private key path]:file:_files' \
  '--node=[Remote CometBFT RPC address]:url:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:Initialize CometBFT configuration'
      'node:Run the Comet node'
      'light:Run a light client'
      'reindex-event:Re-index ABCI events'
      'replay:Replay messages from WAL'
      'reset:Reset blockchain state'
      'show:Inspect node state'
      'testnet:Scaffold multi-validator testnet'
      'version:Print version and build info'
      'gen_validator:Generate validator keypair'
      'unsafe_reset_all:Remove blockchain data'
      'unsafe_reset_priv_validator:Rotate priv_validator state'
      'inspect:Inspect blocks and txs'
      'keys:Manage light client keys'
      'config:Generate config templates'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
