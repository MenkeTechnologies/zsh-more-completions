#compdef ovnkube-trace
# _ovnkube-trace — OVN-Kubernetes pod-to-pod / pod-to-service tracer (ovn-kubernetes/ovn-kubernetes)
# upstream: https://github.com/ovn-kubernetes/ovn-kubernetes
# Flags from go-controller/cmd/ovnkube-trace/ovnkube-trace.go on tip.

_ovnkube-trace() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-ovn-config-namespace=[namespace holding ovn-config configmap]:ns:' \
        '-src-namespace=[source pod namespace]:ns:' \
        '-dst-namespace=[destination pod namespace]:ns:' \
        '-src=[source pod name]:pod:' \
        '-dst=[destination pod name]:pod:' \
        '-service=[destination Service name]:svc:' \
        '-dst-ip=[destination IP (off-cluster targets)]:ip:' \
        '-dst-port=[destination port]:port:' \
        '-tcp[use TCP transport]' \
        '-udp[use UDP transport]' \
        '-addr-family=[IP address family]:fam:(ip4 ip6)' \
        '-skip-detrace[skip the ovn-detrace step]' \
        '-dump-udn-vrf-table-ids[print per-node UDN VRF table IDs]' \
        '-loglevel=[klog verbosity]:n:(0 1 2 3 4 5)'
}

_ovnkube-trace "$@"
