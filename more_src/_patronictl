#compdef patronictl

# Zsh completion for patronictl - Patroni PostgreSQL HA cluster management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dsn:generate DSN for a member'
  'edit-config:edit cluster configuration'
  'failover:manual failover to a replica'
  'flush:discard scheduled events'
  'history:show failover/switchover history'
  'list:list cluster members'
  'pause:disable auto failover'
  'query:query a member'
  'reinit:reinitialize a cluster member'
  'reload:reload cluster member configuration'
  'remove:remove a cluster from DCS'
  'restart:restart a cluster member'
  'resume:resume auto failover'
  'scaffold:create a structure for the cluster in DCS'
  'show-config:show cluster configuration'
  'switchover:planned switchover to a replica'
  'topology:show cluster topology'
  'version:show patronictl version'
)

_arguments -s -S \
  '(-c --config-file)'{-c,--config-file}'[configuration file]:file:_files -g "*.{yml,yaml}"' \
  '(-d --dcs)'{-d,--dcs}'[DCS connect URL]:url' \
  '(-k --insecure)'{-k,--insecure}'[allow insecure SSL connections]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'patronictl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (list|topology)
        _arguments -s -S \
          '(-e --extended)'{-e,--extended}'[show extended information]' \
          '(-t --timestamp)'{-t,--timestamp}'[show timestamp of status]' \
          '(-W --watch)'{-W,--watch}'[auto-refresh at interval]:seconds' \
          '(-f --format)'{-f,--format}'[output format]:format:(pretty tsv json yaml)' \
          '1:cluster name' && ret=0
        ;;
      (switchover|failover)
        _arguments -s -S \
          '--master=[current master name]:master' \
          '--leader=[current leader name]:leader' \
          '--candidate=[candidate name]:candidate' \
          '--scheduled=[schedule at time]:time' \
          '--force[do not ask for confirmation]' \
          '1:cluster name' && ret=0
        ;;
      (restart)
        _arguments -s -S \
          '--role=[restart only members with given role]:role:(master replica leader)' \
          '--any[restart any single member]' \
          '--scheduled=[schedule restart at time]:time' \
          '--pg-version=[restart only if PostgreSQL version is less than]:version' \
          '--pending[restart only members with pending restart]' \
          '--force[do not ask for confirmation]' \
          '--timeout=[operation timeout]:seconds' \
          '1:cluster name' \
          '2:member name' && ret=0
        ;;
      (reinit)
        _arguments -s -S \
          '--force[do not ask for confirmation]' \
          '--wait[wait for reinit to complete]' \
          '1:cluster name' \
          '2:member name' && ret=0
        ;;
      (reload)
        _arguments '1:cluster name' '2:member name' && ret=0
        ;;
      (pause|resume)
        _arguments '1:cluster name' && ret=0
        ;;
      (remove)
        _arguments '1:cluster name' && ret=0
        ;;
      (edit-config|show-config)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(pretty json yaml)' \
          '1:cluster name' && ret=0
        ;;
      (query)
        _arguments -s -S \
          '--role=[query members with given role]:role:(master replica any leader)' \
          '--member=[query specific member]:member' \
          '--delimiter=[set column delimiter]:delimiter' \
          '--command=[SQL command to execute]:command' \
          '--file=[SQL file to execute]:file:_files -g "*.sql"' \
          '--username=[database user]:user' \
          '--password[prompt for password]' \
          '--dbname=[database name]:database' \
          '1:cluster name' && ret=0
        ;;
      (dsn)
        _arguments -s -S \
          '--role=[member role]:role:(master replica any leader)' \
          '--member=[specific member]:member' \
          '1:cluster name' && ret=0
        ;;
      (flush)
        _arguments -s -S \
          '1:cluster name' \
          '2:target:(restart switchover)' && ret=0
        ;;
      (history)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(pretty tsv json yaml)' \
          '1:cluster name' && ret=0
        ;;
    esac
    ;;
esac

return ret
