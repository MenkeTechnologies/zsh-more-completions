#compdef labplot2
# Documentation: https://manpages.ubuntu.com/manpages/oracular/man1/labplot2.1.html
# labplot2 - KDE application for interactive graphing and analysis of scientific data

local ret=1

_arguments -s \
  '--help[show help about command line options]' \
  '--version[show version information]' \
  '--no-splash[do not show the splash screen]' \
  '--presenter[start in the presenter mode]' \
  '*:project:_files -g "*.lml(|.gz|.bz2|.xz)"' && ret=0

return ret
