#compdef suricata-update
# Documentation: https://github.com/OISF/suricata-update/blob/master/suricata/update/parsers.py
# Reference accessed: 2026-05-21
# Verified: upstream argparse definitions in parsers.py (global_arg, update_arg)
# and subparser registrations.

# suricata-update: Suricata IDS rule updater
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a subcommands=(
  'update:download and update rulesets (default)'
  'update-sources:fetch the master index from the OISF hosts'
  'list-sources:list available rule sources'
  'list-enabled-sources:list currently enabled sources'
  'add-source:add a custom rule source'
  'enable-source:enable a rule source'
  'disable-source:disable an enabled source'
  'remove-source:remove a source'
  'check-versions:check Suricata vs suricata-update version compatibility'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[be more verbose]' \
  '(-q --quiet)'{-q,--quiet}'[warning and error messages only]' \
  '(-D --data-dir)'{-D,--data-dir=}'[data directory (default /var/lib/suricata)]:dir:_files -/' \
  '(-c --config)'{-c,--config=}'[config file (default /etc/suricata/update.yaml)]:file:_files' \
  '--suricata-conf=[Suricata config file]:file:_files' \
  '--suricata=[path to Suricata binary]:file:_files' \
  '--suricata-version=[override Suricata version]:version:' \
  '--user-agent=[custom user-agent string]:string:' \
  '--no-check-certificate[disable server SSL/TLS cert verification]' \
  '(-s --show-advanced)'{-s,--show-advanced}'[show advanced options]' \
  '(-o --output)'{-o,--output=}'[directory to write rules to]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[force operations]' \
  '--yaml-fragment=[output YAML fragment]:file:_files' \
  '*--url=[rule URL (repeatable)]:url:' \
  '*--local=[local rule file or directory (repeatable)]:path:_files' \
  '--sid-msg-map=[generate sid-msg.map file]:file:_files' \
  '--sid-msg-map-2=[generate v2 sid-msg.map file]:file:_files' \
  '--disable-conf=[disable filter file]:file:_files' \
  '--enable-conf=[enable filter file]:file:_files' \
  '--modify-conf=[modify filter file]:file:_files' \
  '--drop-conf=[drop filter file]:file:_files' \
  '*--ignore=[filenames to ignore (repeatable)]:pattern:' \
  '--no-ignore[disable ignore option]' \
  '--threshold-in=[threshold input template]:file:_files' \
  '--threshold-out=[threshold output file]:file:_files' \
  '--dump-sample-configs[dump sample configs to current dir]' \
  '--etopen[use ET-Open rules (default)]' \
  '--reload-command=[command to run after update]:cmd:' \
  '--no-reload[disable reload]' \
  '(-T --test-command)'{-T,--test-command=}'[test command for Suricata config]:cmd:' \
  '--no-test[disable rule testing]' \
  '--no-merge[do not merge rules into single file]' \
  '--offline[use cached rules]' \
  '--fail[strictly fail on error]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'suricata-update command' subcommands && ret=0 ;;
  args) _files && ret=0 ;;
esac

return ret
