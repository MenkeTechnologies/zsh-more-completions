#compdef suricata-update
# Documentation: https://manpages.debian.org/bookworm/suricata-update/suricata-update.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm suricata-update(1) manpage.

# suricata-update: Suricata IDS rule updater
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-D --data-dir)'{-D,--data-dir=}'[data directory]:dir:_files -/' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '--suricata-conf=[Suricata config file]:file:_files' \
  '--suricata=[path to Suricata binary]:file:_files' \
  '--suricata-version=[override Suricata version]:version:' \
  '--user-agent=[custom user-agent string]:string:' \
  '--no-check-certificate[disable SSL/TLS cert verification]' \
  '(-o --output)'{-o,--output=}'[output directory for rules]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '--yaml-fragment[output YAML fragment]' \
  '*--url=[rule URL (repeatable)]:url:' \
  '*--local=[local rule file or directory]:path:_files' \
  '--sid-msg-map=[generate sid-msg.map file]:file:_files' \
  '--sid-msg-map-2=[generate v2 sid-msg.map file]:file:_files' \
  '--disable-conf=[disable filter file]:file:_files' \
  '--enable-conf=[enable filter file]:file:_files' \
  '--modify-conf=[modify filter file]:file:_files' \
  '--drop-conf=[drop filter file]:file:_files' \
  '--ignore=[filenames to ignore]:pattern:' \
  '--no-ignore[disable ignore option]' \
  '--threshold-in=[threshold input file]:file:_files' \
  '--threshold-out=[threshold output file]:file:_files' \
  '--dump-sample-configs[dump sample configs]' \
  '--etopen[use ET-Open rules (default)]' \
  '--reload-command=[command after update]:cmd:' \
  '--no-reload[disable reload]' \
  '(-T --test-command)'{-T,--test-command=}'[test command for Suricata config]:cmd:' \
  '--no-test[disable rule testing]' \
  '--no-merge[do not merge rules into single file]' \
  '--offline[use cached rules]' \
  '--fail[strictly fail on error]' \
  '*::subcommand args:_files' && ret=0
return ret
