#compdef evans

# Zsh completion for evans (gRPC client)

local curcontext="$curcontext" state line ret=1

_evans_connection_flags=(
  '--host[gRPC server host]:host'
  '--port[gRPC server port]:port'
  '*--header[add header key=value]:header'
  '(-r --reflection)'{-r,--reflection}'[use gRPC reflection]'
  '*--proto[proto file]:file:_files -g "*.proto"'
  '*--path[proto import path]:path:_files -/'
  '--package[default package]:package'
  '--service[default service]:service'
  '--tls[use TLS]'
  '--cacert[CA certificate file]:file:_files'
  '--cert[client certificate file]:file:_files'
  '--certkey[client certificate key file]:file:_files'
  '--servername[TLS server name override]:name'
  '(- *)--help[show help]'
)

_evans() {
  local -a commands=(
    'cli:CLI mode'
    'repl:REPL mode'
  )

  _arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'evans command' commands && ret=0
      ;;
    args)
      case $words[1] in
        cli)
          _arguments -s \
            "${_evans_connection_flags[@]}" \
            '--edit[edit request in editor]' \
            '--enrich[enrich response output]' \
            '--output[output format]:format:(json table)' \
            '--call[call method]:method' \
            '--file[input file]:file:_files' && ret=0
          ;;
        repl)
          _arguments -s \
            "${_evans_connection_flags[@]}" && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_evans "$@"
