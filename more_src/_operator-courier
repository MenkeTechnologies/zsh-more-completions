#compdef operator-courier

# operator-courier: legacy Operator Framework upload/validation tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'verify:verify an operator bundle'
  'flatten:flatten an operator bundle'
  'push:push an operator bundle to App Registry'
  'nest:nest operator bundle directory'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--validation-output=[validation output file]:file:_files' \
  '--ui-validate-io[validate UI data]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'operator-courier command' commands && ret=0 ;;
esac
return ret
