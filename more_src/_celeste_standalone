#compdef celeste_standalone
# Documentation: https://hugin.sourceforge.io/docs/manual/Celeste_standalone.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[input Hugin PTO file]:file:_files -g "*.pto"' \
  '-o+[output Hugin PTO file]:file:_files -g "*.pto"' \
  '-d+[SVM model file]:file:_files' \
  '-s+[maximum image dimension prior to processing (default 800)]:int:' \
  '-t+[SVM threshold 0..1 (default 0.5)]:float:' \
  '-m+[create masks when processing (1 or 0)]:flag:(0 1)' \
  '-f+[mask file format]:fmt:(PNG JPEG BMP GIF TIFF)' \
  '-r+[filter radius (1 or 0)]:flag:(0 1)' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
