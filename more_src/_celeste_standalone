#compdef celeste_standalone
# Documentation: https://man.archlinux.org/search?q=celeste_standalone
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[image input]:file:_files' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '-d+[svm model file]:file:_files' \
  '-s+[gabor filter scale]:scale:' \
  '-t+[svm threshold]:val:' \
  '-v[verbose]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
