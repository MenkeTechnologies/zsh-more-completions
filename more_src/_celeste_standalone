#compdef celeste_standalone

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[image input]:file:_files' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '-d+[svm model file]:file:_files' \
  '-s+[gabor filter scale]:scale:' \
  '-t+[svm threshold]:val:' \
  '-v[verbose]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
