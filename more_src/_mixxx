#compdef mixxx
# Documentation: https://man.archlinux.org/search?q=mixxx
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--resourcePath=+[resource directory]:dir:_files -/' \
  '--settingsPath=+[settings dir]:dir:_files -/' \
  '--pluginPath=+[plugin search path]:dir:_files -/' \
  '--locale=+[locale]:locale:' \
  '--developer[enable developer mode]' \
  '--safeMode[start in safe mode]' \
  '--debugAssertBreak[break on debug assert]' \
  '--no-keyboardShortcuts[disable keyboard shortcuts]' \
  '--logLevel=+[log level]:lvl:(critical warning info debug trace)' \
  '--logFlushLevel=+[log flush level]:lvl:(critical warning info debug trace)' \
  '--controllerDebug[controller debug]' \
  '*:audio file:_files -g "*.{mp3,wav,flac,ogg,aiff,opus,m4a,mp4}"' && ret=0

return ret
