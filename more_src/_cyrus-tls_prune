#compdef cyrus-tls_prune
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/tls_prune.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org tls_prune(8) reference manpage. Only one
# documented flag.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-tls_prune: prune expired entries from Cyrus TLS sessions cache
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' && ret=0
return ret
