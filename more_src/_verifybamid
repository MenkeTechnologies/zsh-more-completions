#compdef verifyBamID verifybamid
# Documentation: https://genome.sph.umich.edu/wiki/VerifyBamID
# verifyBamID - detect sample contamination and swaps in BAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--vcf=[VCF file with genotypes]:file:_files' \
  '--bam=[BAM file to check]:file:_files' \
  '--bai=[BAM index file]:file:_files' \
  '--subset=[subset of individuals]:file:_files' \
  '--smID=[sample ID]:id' \
  '--minMapQ=[minimum mapping quality]:q' \
  '--maxDepth=[maximum depth]:depth' \
  '--minQ=[minimum base quality]:q' \
  '--maxQ=[maximum base quality]:q' \
  '--precise[calculate likelihood in log-scale]' \
  '--ignoreRG[ignore read groups]' \
  '--ignoreOverlapPair[ignore overlapping pairs]' \
  '--noEOF[do not check EOF marker]' \
  '--out=[output file prefix]:prefix' \
  '--verbose[verbose output]' \
  '*:file:_files' && ret=0

return ret
