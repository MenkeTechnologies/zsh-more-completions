#compdef bccmd
# _bccmd — BlueZ bccmd (CSR Bluetooth chip control over BCSP; -t selects transport (hci/h4/h5/3wire), -d device (hciX or /dev/ttyXXX), -b baud rate, -B brcm fw upload, --revinfo prints firmware revision, --buildname prints build name; second positional is the command (psget/psset/coldreset/warmreset/pskeysize/pslist))
# upstream: https://github.com/bluez/bluez (tools/bccmd.c)
# Subcommands from bluez tools/bccmd.c on tip.

_bccmd() {
    _arguments \
        '-h[show help]' \
        '-d+[hciX or serial device]:device:' \
        '-t+[transport]:transport:(hci bcsp h4 h5 3wire usb)' \
        '-b+[baud rate]:baud:' \
        '-B+[brcm fw upload]:file:_files' \
        '1:command:(coldreset warmreset chiprev buildname stop start panic faultargs psread psset psget pslist pscompact psclr psload psget pscheck setbaud reset)' \
        '*::arg:'
}

_bccmd "$@"
