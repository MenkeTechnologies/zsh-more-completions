#compdef jpeg2yuv
# Documentation: https://manpages.debian.org/testing/mjpegtools/jpeg2yuv.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: -A is a sample aspect ratio string (not
# a 1-4 enum); -L is the interlace field mode (0|1), not loop count;
# loop count is -l (lowercase); added -R rescale option.
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-I+[interlacing mode]:mode:(p t b)' \
  '-f+[frame rate of the stream]:fps:' \
  '-A+[sample aspect ratio]:ratio:' \
  '-n+[number of frames to process]:n:' \
  '-b+[frame offset (skip first num frames)]:n:' \
  '-j+[input JPEG filename pattern]:pattern:' \
  '-L+[field interleave mode]:mode:(0 1)' \
  '-l+[number of loops]:n:' \
  '-R+[rescale YUV color values 0-255 to 16-235]:flag:(0 1)' \
  '-v+[verbosity level]:level:(0 1 2)' && ret=0

return ret
