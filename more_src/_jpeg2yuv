#compdef jpeg2yuv

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-I+[interlace mode]:mode:(p t b)' \
  '-f+[frames per second]:fps:' \
  '-A+[aspect ratio]:ratio:(1 2 3 4)' \
  '-n+[number of frames]:n:' \
  '-b+[start frame]:n:' \
  '-j+[input file pattern]:pattern:' \
  '-L+[loop count]:n:' \
  '-v+[verbosity]:level:(0 1 2)' && ret=0

return ret
