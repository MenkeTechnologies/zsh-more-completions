#compdef force-procmask
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/procmask.html
# FORCE: generate a processing mask from continuous data

local ret=1

_arguments -s -S \
  '(-s)-s[pixel resolution of cubed data (default 10)]:resolution:' \
  '(-l)-l[input layer / band number (default 1)]:layer:' \
  '(-d)-d[input datacube directory]:dir:_files -/' \
  '(-o)-o[output directory]:dir:_files -/' \
  '(-b)-b[output basename without extension]:basename:' \
  '(-j)-j[number of jobs]:jobs:' \
  '1:input basename:' \
  '2:calc expression (e.g. A>2500):' && ret=0

return ret
