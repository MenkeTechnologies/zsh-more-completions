#compdef create-react-app
# Documentation: https://github.com/facebook/create-react-app/blob/main/packages/create-react-app/createReactApp.js
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--verbose[print additional logs]' \
  '--info[print environment debug info]' \
  '--scripts-version=[alternative react-scripts version]:version' \
  '--template=[specify a template]:template' \
  '--use-npm[use npm instead of yarn]' \
  '--use-pnp[use Plug'\''n'\''Play for yarn]' \
  '1:project directory:_directories' && ret=0

return ret
