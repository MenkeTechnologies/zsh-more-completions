#compdef create-react-app
# Documentation: https://man.archlinux.org/search?q=create-react-app
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--verbose[print additional logs]' \
  '--info[print environment debug info]' \
  '--scripts-version=[alternative react-scripts version]:version' \
  '--template=[specify a template]:template' \
  '--use-npm[use npm instead of yarn]' \
  '--use-pnp[use Plug'\''n'\''Play for yarn]' \
  '1:project directory:_directories' && ret=0

return ret
