#compdef namdcuda
# Documentation: https://www.ks.uiuc.edu/Research/namd/2.14/ug/node12.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# NAMD CUDA build: GPU-accelerated NAMD
local curcontext="$curcontext" ret=1
_arguments -C \
  '+p[number of CPU cores]:n:' \
  '+devices[GPU device list]:list:' \
  '+pemap[CPU affinity]:map:' \
  '+ignoresharing[ignore GPU sharing warnings]' \
  '+stdout[redirect per-rank stdout]:prefix:' \
  '+restart[restart filename]:file:_files' \
  '+replicas[replica count]:n:' \
  '+ofi[OFI network layer]' \
  '*::NAMD config file:_files -g "*.(conf|namd|inp)"' && ret=0
return ret
