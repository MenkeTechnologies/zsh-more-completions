#compdef cabextract-cli
# _cabextract-cli — Stuart Caie cabextract Microsoft cabinet file extractor CLI alias (kyz team, C); custom argparse
# upstream: https://www.cabextract.org.uk/

_cabextract-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[output dir]:dir:_files -/' \
        '--directory=+[output dir]:dir:_files -/' \
        '-f[fix broken cabinets]' \
        '--fix[fix broken cabinets]' \
        '-F+[filter pattern]:str:' \
        '--filter=+[filter pattern]:str:' \
        '-l[list contents]' \
        '--list[list contents]' \
        '-L[lowercase filenames]' \
        '--lowercase[lowercase filenames]' \
        '-p[pipe extracted files to stdout]' \
        '--pipe[pipe extracted files to stdout]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[show only single-cabinet info]' \
        '--single[show only single-cabinet info]' \
        '-t[test integrity]' \
        '--test[test integrity]' \
        '*:cabinet files:_files -g "*.cab"'
}

_cabextract-cli "$@"
