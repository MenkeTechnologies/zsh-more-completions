#compdef wiretap
# Documentation: https://github.com/sandialabs/wiretap
# wiretap - transport layer VPN for proxying into a target network

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(configure serve status add expose ping)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      configure)
        _arguments -s \
          '--endpoint=[server connection address]:endpoint:' \
          '--routes=[IP ranges to route]:cidrs:' \
          '--port=[client listening port]:port:' \
          '--outbound-endpoint=[client initiates connection]:endpoint:' \
          '--sport=[server listening port for outbound]:port:' \
          '--simple[traditional single-client VPN mode]' \
          '--localhost-ip=[enable localhost redirection]:ipv4:' \
          '--disable-ipv6[IPv4-only mode]' && ret=0
        ;;
      serve)
        _arguments -s '-f[load from configuration file]:file:_files' && ret=0
        ;;
      status)
        _arguments -s '--network-info[include interface and CIDR details]' && ret=0
        ;;
      add)
        _arguments -s \
          '1:target:(server client)' \
          '--server-address=[existing server API address]:addr:' \
          '--endpoint=[connection address]:endpoint:' \
          '--routes=[accessible IP ranges]:cidrs:' \
          '--port=[listening port]:port:' && ret=0
        ;;
      expose)
        _arguments -s \
          '--local=[local machine port]:port:' \
          '--remote=[remote exposed port]:port:' \
          '--dynamic[enable SOCKS5 mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
