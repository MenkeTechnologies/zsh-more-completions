#compdef kpack-build-init
# _kpack-build-init — kpack build initialization helper (clones source, fetches blobs)
# upstream: https://github.com/buildpacks-community/kpack
# Flags from cmd/build-init/main.go on tip.

_kpack-build-init() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--imageTag=[tag of image created by the lifecycle]:tag:' \
        '--runImage=[base image for application images]:image:' \
        '--git-url=[Git repository URL]:url:' \
        '--git-revision=[Git revision to use as HEAD]:rev:' \
        '--git-initialize-submodules=[initialize submodules during clone]:bool:(true false)' \
        '--blob-url=[source blob URL]:url:' \
        '--blob-auth=[authenticate to blob URL]:bool:(true false)' \
        '--strip-components=[strip N leading dirs when extracting blob]:n:' \
        '--registry-image=[OCI registry image with source code]:image:' \
        '--source-sub-path=[subpath inside source to use as workspace]:path:' \
        '--build-changes=[JSON build changes + reasons]:json:' \
        '--project-descriptor-path=[project descriptor file path]:file:_files' \
        '--builder-image=[builder image to use]:image:' \
        '--builder-name=[builder name]:name:' \
        '--builder-kind=[builder kind]:kind:(Builder ClusterBuilder)' \
        '--insecure-ssh-trust-unknown-hosts=[trust unknown SSH hosts]:bool:(true false)' \
        '*--basic-git=[git basic auth: secret=domain]:spec:' \
        '*--ssh-git=[git SSH auth: secret=domain]:spec:' \
        '*--blob=[blob auth: secret=domain]:spec:' \
        '*--basic-docker=[docker basic auth: secret=domain]:spec:' \
        '*--dockercfg=[path to dockercfg credential]:path:_files' \
        '*--dockerconfig=[path to docker config.json credential]:path:_files' \
        '*--imagepull=[builder image pull credential path]:path:_files'
}

_kpack-build-init "$@"
