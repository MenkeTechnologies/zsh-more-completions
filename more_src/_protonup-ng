#compdef protonup-ng
# Documentation: https://man.archlinux.org/search?q=protonup-ng
# Reference accessed: 2026-05-16

# Zsh completion for ProtonUp-ng (Proton-GE and Wine-GE installer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --dir)'{-d,--dir=}'[installation directory]:directory:_files -/' \
  '(-t --tag)'{-t,--tag=}'[version tag to install]:tag:' \
  '(-l --list)'{-l,--list}'[list available versions]' \
  '--list-installed[list installed versions]' \
  '--remove=[remove a specific version]:version:' \
  '-y[skip confirmation prompts]' \
  '--steam[use Steam default path]' \
  '--lutris[use Lutris default path]' && ret=0

return ret
