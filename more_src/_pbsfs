#compdef pbsfs
# Documentation: https://www.altair.com/pbs-works-documentation/
# PBS: manage and display the scheduler fairshare usage data

local ret=1

_arguments -s \
  '-c[compare two fairshare entities]:entity 1: :entity 2' \
  '-g+[detailed listing for the given entity including its tree path]:entity' \
  '-I+[scheduler whose data is to be manipulated or shown]:scheduler name' \
  '-p[print the fairshare tree as a table]' \
  '-t[print the fairshare tree in hierarchical format]' \
  '-d[decay the fairshare tree by the configured decay factor]' \
  '-e[trim the tree to the entities in the resource_group file]' \
  '-s[set an entity usage value]:entity: :usage value' \
  '--version[print PBS version information and exit]' && ret=0

return ret
