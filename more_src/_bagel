#compdef bagel

# boostsecurityio/bagel — cmd/bagel/*.go

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config=[config file]:file:_files' \
  '(-v)'{-v,--verbose}'[verbose logging]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'scan:scan workstation posture'
      'scrub:redact secrets from logs/history'
      'version:print version'
    )
    _describe -t commands 'bagel command' cmds && ret=0
    ;;
  (rest)
    case $line[1] in
      (scan)
        _arguments -s -S \
          '(-f)'{-f+,--format=}'[output format]:format:(json table)' \
          '(-o)'{-o+,--output=}'[output file (default stdout)]:file:_files' \
          '--strict[exit 2 if findings]' \
          '--no-cache[rebuild file index]' \
          '--no-progress[disable progress bars]' && ret=0
        ;;
      (scrub)
        _arguments -s -S \
          '(-y)'{-y,--yes}'[apply without prompting]' \
          '--dry-run[report only]' \
          '--grace-minutes=[skip recent files N minutes]:minutes:' \
          '--file=[scrub single file]:file:_files' && ret=0
        ;;
      (version) _nothing && ret=0 ;;
    esac
    ;;
esac

return ret
