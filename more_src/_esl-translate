#compdef esl-translate
# Documentation: https://man.archlinux.org/search?q=esl-translate
# Reference accessed: 2026-05-16

# Easel esl-translate: 6-frame translate DNA, extract ORFs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-c[NCBI genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-l[minimum ORF length in codons]:n:' \
  '-m[require ATG start codon (or M)]' \
  '-M[require any start codon]' \
  '--informat[input format]:fmt:(fasta embl genbank uniprot)' \
  '--watson[only Watson (forward) strand]' \
  '--crick[only Crick (reverse) strand]' \
  '*:DNA sequence file:_files' && ret=0
return ret
