#compdef tor-resolve
# _tor-resolve — Tor Project tor-resolve CLI for resolving DNS hostnames through a Tor SOCKS proxy preventing DNS leaks supporting both A and PTR lookups via Tor SOCKS RESOLVE extension (torproject team, C); getopt
# upstream: https://gitlab.torproject.org/tpo/core/tor

_tor-resolve() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-4[IPv4]' \
        '-5[IPv5]' \
        '-x[reverse lookup]' \
        '-F[force lookup]' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--retry=+[N]:n:' \
        '*:hostname or IP and SOCKS host[:port]:'
}

_tor-resolve "$@"
