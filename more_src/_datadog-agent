#compdef datadog-agent

# Zsh completion for Datadog Agent

_datadog-agent() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'check:run the specified check'
    'config:print the runtime configuration'
    'configcheck:print all configurations loaded and resolved'
    'diagnose:run some connectivity diagnosis on your system'
    'flare:collect a flare and send it to Datadog'
    'health:print the current agent health'
    'hostname:print the hostname used by the Agent'
    'import:import and convert configuration from prior versions'
    'integration:manage Datadog integrations'
    'jmx:run JMXFetch troubleshooting commands'
    'launch-gui:start the Datadog Agent GUI'
    'restart-service:restart the agent within the service manager'
    'run:run the Agent'
    'secret:display information about decrypted secrets'
    'start:start the Agent'
    'start-service:start the agent within the service manager'
    'status:print the current agent status'
    'stop:stops a running Agent'
    'stop-service:stop the agent within the service manager'
    'stream-logs:stream the logs being processed'
    'tagger-list:print the tagger content of a running agent'
    'version:print agent version info'
    'workload-list:print the workload content of a running agent'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'datadog-agent command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        check)
          _arguments -s -S \
            '--check-rate[run check at configured collection interval]' \
            '--check-times=[number of times to run the check]:count:' \
            '--check-delay=[delay between checks in ms]:ms:' \
            '--log-level=[log level]:level:(trace debug info warn error critical off)' \
            '--json[format aggregator and check output as JSON]' \
            '--table[format check output as table]' \
            '--breakpoint[set a breakpoint in the check]' \
            '--profile-memory[profile memory during check execution]' \
            '--flare[save check results for inclusion in a flare]' \
            '--discovery-retry-interval=[retry interval]:seconds:' \
            '--discovery-timeout=[timeout]:seconds:' \
            '--discovery-min-instances=[min instances]:count:' \
            '1:check name:' \
            && ret=0
          ;;
        flare)
          _arguments -s -S \
            '-e+[email address]:email:' \
            '--email=[email address]:email:' \
            '-s[send the flare using the case ID specified]' \
            '--send[send the flare using the case ID specified]' \
            '-p+[profile duration]:seconds:' \
            '--profile-duration=[profile duration]:seconds:' \
            '--local[generate a local flare archive]' \
            '1:case ID:' \
            && ret=0
          ;;
        status)
          _arguments -s -S \
            '-j[print status as JSON]' \
            '--json[print status as JSON]' \
            '-p[print pretty-printed JSON]' \
            '--prettyprint[print pretty-printed JSON]' \
            '-s+[section to print]:section:(collector dogstatsd apm process)' \
            '--section=[section to print]:section:(collector dogstatsd apm process)' \
            && ret=0
          ;;
        integration)
          _arguments -s -S \
            '1:subcommand:(install remove freeze show)' \
            '2:package name:' \
            && ret=0
          ;;
        config)
          _arguments -s -S \
            '1:subcommand:(list-runtime set)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--cfgpath=[config path]:path:_files -/' \
            '--no-color[disable color output]' \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_datadog-agent "$@"
