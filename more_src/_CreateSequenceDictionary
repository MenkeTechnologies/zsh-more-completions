#compdef CreateSequenceDictionary
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/CreateSequenceDictionary.java
# Picard: create a .dict sequence dictionary from a reference FASTA

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-R --REFERENCE)'{-R,--REFERENCE}'=[input reference FASTA or FASTA.gz]:file:_files -g "*.(fa|fasta|fa.gz|fasta.gz)"' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output .dict sequence dictionary file]:file:_files' \
  '(-AS --GENOME_ASSEMBLY)'{-AS,--GENOME_ASSEMBLY}'=[value for the AS field]:as:' \
  '(-UR --URI)'{-UR,--URI}'=[value for the UR field]:uri:' \
  '(-SP --SPECIES)'{-SP,--SPECIES}'=[value for the SP field]:sp:' \
  '--TRUNCATE_NAMES_AT_WHITESPACE=[use first word of > line as sequence name]:b:(true false)' \
  '--NUM_SEQUENCES=[stop after writing this many sequences]:n:' \
  '(-AN --ALT_NAMES)'{-AN,--ALT_NAMES}'=[file of alternative contig names]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
