#compdef qtile-cmd
# Documentation: https://docs.qtile.org/en/latest/manual/commands/shell/qtile-cmd.html
# qtile-cmd: command-line interface to qtile's command graph

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --object)'{-o,--object}'[path to object (space separated)]:object:_default' \
  '(-f --function)'{-f,--function}'[function to execute on the object]:function:_default' \
  '(-a --args)'{-a,--args}'[arguments supplied to the function]:args:_default' \
  '(-i --info)'{-i,--info}'[print documentation for the function]' && ret=0

return ret
