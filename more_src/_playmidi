#compdef playmidi
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/playmidi.1.html
# play Standard MIDI Files on a sound card or external synthesizer

local ret=1

_arguments -s -S \
  '(-H --help)'{-H,--help}'[display the help text then exit]' \
  '*-v[increase verbosity (repeatable)]' \
  '-8[force 8-bit patches on Gravis Ultrasound]' \
  '-c+[channel mask in hex selecting which channels play]:mask' \
  '-d[omit drum/percussion tracks from playback]' \
  '-e[route output to external MIDI hardware]' \
  '-f[route output to FM synthesizer using FM patches]' \
  '-4[route to FM synth with 4-op OPL/3 patches]' \
  '-g[route output to Gravis Ultrasound device]' \
  '-a[route output to SoundBlaster/AWE/Live cards]' \
  '-E+[channel mask for external MIDI output]:mask' \
  '-F+[channel mask for FM output]:mask' \
  '-G+[channel mask for Gravis Ultrasound output]:mask' \
  '-i+[channels to ignore in hex]:mask' \
  '-I[list general MIDI programs and numbers]' \
  '-t+[tempo playback speed factor]:factor' \
  '-r[real-time ANSI graphics display of playback]' \
  '-P+[remap all percussion channels to one channel]:channel' \
  '-R+[initial reverb level (0-127)]:level' \
  '-C+[initial chorus level (0-127)]:level' \
  '-x+[exclude specified channel from loading]:channel' \
  '-z[zero channel data in output stream]' \
  '*:midi file:_files -g "*.(mid|midi)"' && ret=0

return ret
