#compdef dnsip
# _dnsip — djbdns dnsip (look up A records for one or more domain names; uses the resolver list from /etc/resolv.conf or $DNSCACHEIP)
# upstream: https://github.com/dterweij/ndjbdns (ndjbdns, the actively-maintained djbdns)
# Flags from dnsip.c on tip.

_dnsip() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-n --new)'{-n,--new}'[new output style]' \
        '*:domain:_hosts'
}

_dnsip "$@"
