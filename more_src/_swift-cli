#compdef swift
# _swift-cli — Swift compiler + driver (Apple + Swift project, Swift); compile, run, or use as SPM driver
# upstream: https://github.com/apple/swift

_swift-cli() {
    local -a sub=(
        'build:build a Swift package'
        'experimental-install:experimental install'
        'package:swift package commands'
        'package-collection:package collections'
        'run:build + run executable'
        'sdk:SDK commands'
        'test:run package tests'
        'demangle:demangle Swift symbols'
        'doc:swift doc'
        'format:swift format'
        'frontend:swift frontend'
        'inspect:swift inspect'
        'experimental-api-diff:API diff'
        'help:show help'
        'repl:start REPL'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-O[optimize]' \
        '-Onone[no optimize]' \
        '-Osize[optimize for size]' \
        '-g[debug info]' \
        '-target+[target triple]:str:' \
        '-sdk+[SDK]:dir:_files -/' \
        '-toolchain+[toolchain]:dir:_files -/' \
        '-emit-executable[emit executable]' \
        '-emit-library[emit library]' \
        '-emit-object[emit object]' \
        '-emit-assembly[emit assembly]' \
        '-emit-bc[emit LLVM bc]' \
        '-emit-ir[emit LLVM IR]' \
        '-emit-module[emit module]' \
        '-emit-sil[emit SIL]' \
        '-emit-sib[emit SIB]' \
        '-import-objc-header+[import header]:file:_files' \
        '-static-executable[static executable]' \
        '-static-stdlib[static stdlib]' \
        '-static-swift-stdlib[static swift stdlib]' \
        '-suppress-warnings[suppress warnings]' \
        '-warnings-as-errors[warnings as errors]' \
        '-Xcc+[clang flag]:flag:' \
        '-Xfrontend+[frontend flag]:flag:' \
        '-Xllvm+[LLVM flag]:flag:' \
        '-Xlinker+[linker flag]:flag:' \
        '-Xswiftc+[swiftc flag]:flag:' \
        '-c[compile only]' \
        '-o+[output file]:file:_files' \
        '-I+[search path]:dir:_files -/' \
        '-L+[library path]:dir:_files -/' \
        '-l+[link library]:str:' \
        '-D+[define]:def:' \
        '-F+[framework path]:dir:_files -/' \
        '-framework+[link framework]:framework:' \
        '-module-name+[module name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swift subcommand' sub ;;
        args)
            case $words[1] in
                build|run|test) _arguments \
                    '-c+[configuration]:cfg:(debug release)' \
                    '--configuration+[configuration]:cfg:(debug release)' \
                    '--package-path+[package path]:dir:_files -/' \
                    '--build-path+[build path]:dir:_files -/' \
                    '--cache-path+[cache path]:dir:_files -/' \
                    '--config-path+[config path]:dir:_files -/' \
                    '--security-path+[security path]:dir:_files -/' \
                    '--scratch-path+[scratch path]:dir:_files -/' \
                    '-Xcc+[clang flag]:flag:' \
                    '-Xswiftc+[swiftc flag]:flag:' \
                    '-Xlinker+[linker flag]:flag:' \
                    '-Xcxx+[clang++ flag]:flag:' \
                    '--triple+[triple]:str:' \
                    '--sdk+[SDK]:path:_files' \
                    '--toolchain+[toolchain]:path:_files' \
                    '-v[verbose]' \
                    '--verbose[verbose]' \
                    '-q[quiet]' \
                    '--quiet[quiet]' \
                    '*:file or args:_files' ;;
                package) _arguments '1:package cmd:(init resolve update describe dump-package compute-checksum config clean reset)' '*:args:' ;;
            esac
            ;;
    esac
}

_swift-cli "$@"
