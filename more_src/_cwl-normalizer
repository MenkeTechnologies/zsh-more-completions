#compdef cwl-normalizer
# Documentation: https://github.com/common-workflow-language/cwl-utils
# Normalize a CWL document

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  "--etools[output ExpressionTools, don't go all the way to CommandLineTools]" \
  '--skip-some1[skip processing of inputBinding and arguments sections]' \
  '--skip-some2[skip processing of outputEval or InitialWorkDirRequirement]' \
  '--no-expression-refactoring[do not refactor expressions]' \
  '1:output directory:_files -/' \
  '*:CWL document:_files -g "*.cwl"' && ret=0

return ret
