#compdef trash-empty
# Documentation: https://github.com/andreafrancia/trash-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs (trashcli/empty/parser.py).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[list files that will be deleted]' \
  '*--trash-dir=[specify trash directory]:directory:_directories' \
  '--all-users[empty trashcans of all users]' \
  '(-i --interactive)'{-i,--interactive}'[ask before emptying]' \
  '-f[do not ask before emptying]' \
  '--dry-run[show which files would be removed]' \
  '1:days old:' && ret=0

return ret
