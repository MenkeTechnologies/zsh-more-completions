#compdef trash-empty
# Zsh completion for trash-empty (trash-cli)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--trash-dir[Specify trash directory]:trash directory:_directories' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version]' \
  '::days old:' && ret=0
return ret
