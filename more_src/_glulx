#compdef glulx

# glulx: virtual machine for Inform/IF (Glulx interpreter)
# Documentation: https://www.eblong.com/zarf/glulx/Glulx-Spec.html
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-undo=[undo buffer size]:n:' \
  '-debug[debug mode]' \
  '-randomize[use real-time RNG]' \
  '*:.ulx file:_files -g "*.(ulx|gblorb)"' && ret=0
return ret
