#compdef spack

# Zsh completion for spack - HPC package manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'install:Build and install packages'
  'uninstall:Remove an installed package'
  'find:List and search installed packages'
  'list:List and search available packages'
  'info:Get detailed information on a package'
  'spec:Show what would be installed given a spec'
  'fetch:Fetch archives for packages'
  'stage:Expand downloaded archive in its stage directory'
  'patch:Apply patches to a package source'
  'env:Manage environments'
  'compiler:Manage compilers'
  'config:Get and set configuration options'
  'module:Generate or refresh module files'
  'extensions:List extensions for package'
  'providers:List packages that provide a virtual dependency'
  'dependents:Show packages that depend on another'
  'dependencies:Show dependencies of a package'
  'graph:Generate graphs of package dependency relationships'
  'buildcache:Create, download, and install binary packages'
  'mirror:Manage mirrors'
  'repo:Manage package source repositories'
  'gpg:Handle GPG actions for spack'
  'debug:Debugging commands for troubleshooting Spack'
  'docs:Open Spack documentation in a web browser'
  'help:Get help on spack and its commands'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--stacktrace[add stacktraces to all printed statements]' \
  '--color=[when to colorize output]:when:(always never auto)' \
  '-k[do not check SSL certificates when fetching]' \
  '--insecure[do not check SSL certificates when fetching]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'spack command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '--only=[select which stages to install]:stages:(package dependencies)' \
          '-j[number of build jobs]:jobs' \
          '--jobs=[number of build jobs]:jobs' \
          '--keep-prefix[do not remove the install prefix on failure]' \
          '--keep-stage[do not remove the build stage on success]' \
          '--no-checksum[do not check package checksums]' \
          '--overwrite[reinstall an existing spec]' \
          '-v[display verbose build output]' \
          '--verbose[display verbose build output]' \
          '--test=[run package tests]:scope:(root all)' \
          '--use-cache[check for pre-built binary packages]' \
          '--no-cache[do not check for pre-built binary packages]' \
          '-y[assume yes to every confirmation]' \
          '--yes-to-all[assume yes to every confirmation]' \
          '*:spec:' && ret=0
        ;;
      uninstall)
        _arguments \
          '-f[force uninstall even if dependents exist]' \
          '--force[force uninstall even if dependents exist]' \
          '-R[also uninstall dependents]' \
          '--dependents[also uninstall dependents]' \
          '-y[assume yes to every confirmation]' \
          '--yes-to-all[assume yes to every confirmation]' \
          '-a[uninstall all instances matching the spec]' \
          '--all[uninstall all instances matching the spec]' \
          '*:spec:' && ret=0
        ;;
      find)
        _arguments \
          '-l[show hashes with status]' \
          '--long[show hashes with status]' \
          '-L[show full hashes]' \
          '--very-long[show full hashes]' \
          '-d[show dependency information]' \
          '--deps[show dependency information]' \
          '-p[show install paths]' \
          '--paths[show install paths]' \
          '--json[output in JSON format]' \
          '*:spec:' && ret=0
        ;;
      list)
        _arguments \
          '-d[filter by description]' \
          '--search-description[filter by description]' \
          '--format=[output format]:format:(name_only version_json html)' \
          '*:filter:' && ret=0
        ;;
      info)
        _arguments '1:package:' && ret=0
        ;;
      env)
        local -a env_cmds=(
          'activate:Set the current environment'
          'deactivate:Deactivate the current environment'
          'create:Create a new environment'
          'destroy:Remove an environment'
          'list:List available environments'
          'status:Print the active environment'
          'view:View the environment managed directory'
        )
        _describe -t env_cmds 'env command' env_cmds && ret=0
        ;;
      compiler)
        local -a compiler_cmds=(
          'find:Search the system for compilers'
          'add:Search the system for compilers'
          'remove:Remove compiler by spec'
          'list:List available compilers'
          'info:Show compiler paths'
        )
        _describe -t compiler_cmds 'compiler command' compiler_cmds && ret=0
        ;;
      config)
        local -a config_cmds=(
          'get:Print configuration values'
          'blame:Print configuration with file provenance'
          'edit:Edit configuration file'
          'list:List configuration sections'
          'add:Add a configuration setting'
          'remove:Remove a configuration setting'
        )
        _describe -t config_cmds 'config command' config_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
