#compdef syz-testbuild
# _syz-testbuild — test that a kernel can be built and booted with syzkaller (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-testbuild/testbuild.go (flag).

_syz-testbuild() {
    _arguments \
        '-os=[OS to test]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[architecture to test]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-kernel_src=[path to kernel checkout]:dir:_files -/' \
        '-config=[kernel config]:file:_files' \
        '-sysctl=[kernel sysctl file]:file:_files' \
        '-cmdline=[kernel cmdline file]:file:_files' \
        '-userspace=[path to userspace for build]:dir:_files -/' \
        '-bisect_bin=[path to bisection binaries]:dir:_files -/' \
        '-syzkaller=[path to built syzkaller]:dir:_files -/' \
        '-sandbox=[sandbox]:sandbox:(none setuid namespace android)' \
        '-sandbox_arg=[sandbox runner argument]:n:' \
        '-compiler=[compiler to use]:cmd:_command_names -e' \
        '-compiler_type=[compiler type]:type:(clang gcc)' \
        '-linker=[linker to use]:cmd:_command_names -e'
}

_syz-testbuild "$@"
