# ============================================================================
# _jwt-cracker-server — zsh completion for distributed-jwt-cracker server
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/lmammino/distributed-jwt-cracker
#   Author     : Luciano Mammino (lucianomammino@gmail.com)
#                — co-author of "Node.js Design Patterns"
#   License    : MIT
#   Stars      : 60
#   Language   : JavaScript (Node.js)
#   npm        : distributed-jwt-cracker v1.0.0
#   Binary     : jwt-cracker-server  (package.json bin entry; sibling
#                                    jwt-cracker-client is the worker side)
#   Last push  : 2024-09-07
#
# WHAT IT IS
#   distributed-jwt-cracker is "an experimental distributed JWT token
#   cracker built using Node.js and ZeroMQ" — Luciano Mammino's example
#   project for the ZeroMQ chapter of the "Node.js Design Patterns" book.
#   The system splits brute-force JWT secret cracking across worker
#   processes:  the `jwt-cracker-server` (this completion) accepts a
#   target HS256 JWT token, enumerates candidate secrets by indexing
#   strings of the configured alphabet, hands out batched index ranges
#   to connected workers over a ZeroMQ REQ/REP socket, and broadcasts a
#   stop signal to all workers via a ZeroMQ PUB/SUB socket the moment a
#   worker reports the matching secret.  Workers spawn via the sibling
#   `jwt-cracker-client` binary (point each one at the server's host /
#   ports);  any number of clients can join the swarm.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/server.js yargs builder chain)
#   jwt-cracker-server <TOKEN> [OPTIONS]
#
#   Positional argument:
#     <TOKEN>                A target HS256 JWT (header.payload.signature);
#                            validated by `jsonwebtoken.decode` — only
#                            HS256 / `typ:"JWT"` tokens are accepted.
#
#   Options (yargs):
#     -p, --port <PORT>      Port for incoming worker connections
#                            (the ZeroMQ REP socket where workers ask
#                            for the next batch)            [default: 9900]
#     -P, --pubPort <PORT>   Port for broadcasting the "stop" signal
#                            (the ZeroMQ PUB socket all workers SUB to)
#                                                            [default: 9901]
#     -a, --alphabet <STR>   Alphabet used to generate candidate secrets
#                                            [default: isv.defaultAlphabet]
#     -b, --batchSize <N>    Number of attempts assigned to each worker
#                            per batch                       [default: 1000000]
#     -s, --start <N>        Starting index in the candidate enumeration
#                                                            [default: 0]
#     -h, --help             Show help
#         --version          Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `zmq ^2.15.3` declared in package.json — the
#   original `JustinTulloss/node-zeromq` binding (npm package `zmq`,
#   predecessor and direct lineage of today's canonical `zeromq` package
#   maintained by the zeromq.js team at zeromq/zeromq.js).  The `zmq`
#   v2.x line wraps the C libzmq via `node-gyp`-built native bindings,
#   exposing `Socket('req')` / `Socket('pub')` etc.  server.js loads it
#   as `const zmq = require('zmq')` and creates `Socket('rep')` and
#   `Socket('pub')` sockets to talk to the workers.  Verified via:
#     gh api repos/lmammino/distributed-jwt-cracker/contents/package.json
#       → "zmq": "^2.15.3"
#     gh api repos/lmammino/distributed-jwt-cracker/contents/src/server.js
#       → const zmq = require('zmq');
#   This entry is the TS-Node=120 leader bump that CLOSES Axis 65
#   (ZeroMQ Messaging Library) at 1/1/1 three-language symmetry:
#     Rust   = zmq 0.9 (erickt/rust-zmq)     (R849, `pushpin-publish`, fastly)
#     Go     = go-zeromq/zmq4 v0.15.0        (R850, `gophernotes`,     gopherdata)
#     TS-Node = zmq ^2.15.3 (JustinTulloss /
#                            zeromq.js team) (R851, `jwt-cracker-server`,
#                                                       lmammino)
#   Reaches the triple-120 landmark Rust=Go=TS-Node=120.
#
#   No completion for `jwt-cracker-server` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_jwt-cracker-server() {
    _arguments -s \
        '(-p --port)'{-p+,--port=}'[port for incoming worker connections (default 9900)]:port:' \
        '(-P --pubPort)'{-P+,--pubPort=}'[port for broadcasting stop signal (default 9901)]:port:' \
        '(-a --alphabet)'{-a+,--alphabet=}'[alphabet used to generate candidate secrets]:alphabet:' \
        '(-b --batchSize)'{-b+,--batchSize=}'[attempts per worker batch (default 1000000)]:N:' \
        '(-s --start)'{-s+,--start=}'[starting index in the enumeration (default 0)]:N:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        ':JWT token (HS256):'
}

_jwt-cracker-server "$@"
