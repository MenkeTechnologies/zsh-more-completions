#compdef kowl
# _kowl — Cloudhut Redpanda Console kowl CLI command-line frontend wrapping the Kowl now Redpanda Console open-source web UI for managing Apache Kafka and Redpanda clusters topics brokers consumer-groups schema-registry kafka-connect cluster acls roles RBAC users authentication-OIDC-Google-Github-Okta-Keycloak Prometheus-metrics audit-logs business-license (Redpanda Data team, Go); custom argparse
# upstream: https://github.com/redpanda-data/console

_kowl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config.filepath=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '-c+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '--server.listenPort=+[port]:n:' \
        '--server.listenAddress=+[host]:_hosts' \
        '--server.basePath=+[path]:str:' \
        '--logger.level=+[level]:l:(debug info warn error fatal)' \
        '--kafka.brokers=+[hosts]:_hosts' \
        '--kafka.clientId=+[id]:str:' \
        '--kafka.tls.enabled[enable TLS]' \
        '--kafka.tls.caFilepath=+[file]:file:_files -g "*.pem *.crt"' \
        '--kafka.tls.certFilepath=+[file]:file:_files -g "*.pem *.crt"' \
        '--kafka.tls.keyFilepath=+[file]:file:_files -g "*.pem *.key"' \
        '--kafka.sasl.enabled[enable SASL]' \
        '--kafka.sasl.mechanism=+[m]:m:(PLAIN SCRAM-SHA-256 SCRAM-SHA-512 GSSAPI OAUTHBEARER AWS_MSK_IAM)' \
        '--kafka.sasl.username=+[user]:str:' \
        '--kafka.sasl.password=+[password]:str:' \
        '--kafka.schemaRegistry.urls=+[url]:str:' \
        '--connect.enabled[enable Connect]' \
        '--connect.clusters[0].name=+[name]:str:' \
        '--connect.clusters[0].url=+[url]:str:' \
        '--login.enabled[enable login]' \
        '--login.jwtSecret=+[secret]:str:' \
        '--login.google.enabled[Google OAuth]' \
        '--login.github.enabled[GitHub OAuth]' \
        '--login.oidc.enabled[OIDC]' \
        '--license.filepath=+[file]:file:_files' \
        '*:args:'
}

_kowl "$@"
