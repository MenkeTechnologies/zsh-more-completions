#compdef cargo-web
# Documentation: https://github.com/koute/cargo-web
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above. Repo archived; succeeded by trunk and wasm-bindgen.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:compile project (wasm32/asmjs/emscripten target)'
  'check:typecheck the project'
  'test:run tests (headless Chrome or Node)'
  'start:build + serve with live reload'
  'deploy:produce static deploy artifacts'
  'prepare-emscripten:download/install Emscripten'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cargo-web command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build|check|test|start|deploy)
        _arguments \
          '--target=[build target]:t:(wasm32-unknown-unknown wasm32-unknown-emscripten asmjs-unknown-emscripten)' \
          '--release[release build]' \
          '-p+[package]:package:' \
          '--package=[package]:package:' \
          '--features=[features csv]:list:' \
          '--all-features[all features]' \
          '--no-default-features[no default features]' \
          '--nodejs[run tests under Node.js (test only)]' \
          '--auto-reload[automatic reload (start only)]' \
          '(-o --output)'{-o+,--output=}'[output directory (deploy only)]:dir:_directories' \
          '*:arg:_files' && ret=0
        ;;
      (*) _files ;;
    esac ;;
esac

return ret
