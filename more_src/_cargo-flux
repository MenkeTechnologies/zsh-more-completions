#compdef cargo-flux
# _cargo-flux — Flux: refinement types for Rust (flux-rs/flux)
# upstream: https://github.com/flux-rs/flux
# Subcommands from crates/flux-bin/src/cargo_flux_opts.rs; -F<key>=<val> driver flags from crates/flux-config/src/flags.rs.

_cargo-flux() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-V --version)'{-V,--version}'[print version information]' \
        '*'{-v,--verbose}'[verbose output (-Vv for more verbose)]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_cargo-flux_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                check|build)
                    _arguments \
                        '--message-format=[diagnostic format]:fmt:(human short json json-diagnostic-short json-diagnostic-rendered-ansi json-render-diagnostics)' \
                        '(-p --package)'{-p+,--package=}'[package to check]:package:' \
                        '--workspace[check all packages in the workspace]' \
                        '--exclude=[exclude package from workspace]:package:' \
                        '--features=[features to activate (space- or comma-separated)]:features:' \
                        '--all-features[activate all available features]' \
                        '--no-default-features[do not activate the `default` feature]' \
                        '--target=[target triple]:triple:' \
                        '--target-dir=[directory for build artifacts]:dir:_files -/' \
                        '--manifest-path=[path to Cargo.toml]:file:_files' \
                        '*-F-[Flux driver flag (key=value)]:flux flag:->fluxflags' && ret=0
                    case $state in
                        fluxflags)
                            local -a fflags
                            fflags=(
                                'log-dir=:directory to dump data (default ./log/)'
                                'cache=:enable query caching at this path'
                                'pointer-width=:pointer size (32 or 64; default 64)'
                                'solver=:default SMT solver (z3 or cvc5)'
                                'check-overflow=:overflow handling (strict, lazy, none)'
                                'allow-raw-deref=:raw-pointer-deref policy'
                                'scrape-quals=:enable qualifier scrapping in fixpoint (true/false)'
                                'allow-uninterpreted-cast=:allow uninterpreted casts (true/false)'
                                'smt-define-fun=:use SMT define-fun for monomorphic defs (true/false)'
                                'annots=:dump annotation size statistics (true/false)'
                                'timings=:dump per-function timing statistics (true/false)'
                                'summary=:print summary of checked/trusted functions (true/false)'
                                'include=:only check files matching glob'
                                'include-trusted=:trust items matching glob (implies -Finclude)'
                                'include-trusted-impl=:trust impl items matching glob'
                                'catch-bugs=:keep running after first error (true/false)'
                                'dump-constraint=:dump constraints generated per function (true/false)'
                                'dump-checker-trace=:dump checker trace at log level (trace/debug/info)'
                                'dump-fhir=:dump FHIR for each item (true/false)'
                                'dump-rty=:dump rty for each item (true/false)'
                                'lean-dir=:directory for emitted Lean definitions (default ./)'
                                'lean-project=:Lean project name (default lean_proofs)'
                                'lean=:Lean integration mode'
                                'no-panic=:implicitly label functions with no_panic (true/false)'
                                'std-extern-specs=:auto-inject flux_core/flux_alloc extern specs (true/false)'
                                'trusted=:trust all code by default (true/false)'
                                'ignore=:ignore all code by default (true/false)'
                                'verbose=:detailed error messages (true/false)'
                                'sysroot=:path to Flux sysroot directory'
                            )
                            _describe -t fluxflags 'flux driver flag' fflags -S '='
                            ret=0 ;;
                    esac ;;
                clean)
                    _arguments \
                        '(-p --package)'{-p+,--package=}'[package to clean]:package:' \
                        '--workspace[clean all packages in the workspace]' \
                        '--manifest-path=[path to Cargo.toml]:file:_files' \
                        '--target=[target triple]:triple:' \
                        '--target-dir=[directory for build artifacts]:dir:_files -/' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cargo-flux_commands] )) ||
_cargo-flux_commands() {
    local -a commands
    commands=(
        'check:check the package using Flux (default)'
        'build:compile the package using Flux'
        'clean:remove artifacts generated by cargo-flux'
    )
    _describe -t commands 'cargo flux command' commands
}

_cargo-flux "$@"
