#compdef editres
# Documentation: https://man.archlinux.org/search?q=editres
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-display[X display]:display:'
    '-geometry[Window geometry]:geometry:'
    '-name[Application name]:name:'
    '-xrm[X resource]:resource:'
    '*:resource file:_files'
)

_arguments -s -S $arguments
