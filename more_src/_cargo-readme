#compdef cargo-readme

_arguments -s \
  '(-i --input)'{-i,--input}'=[input file]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-r --project-root)'{-r,--project-root}'=[project root]:dir:_files -/' \
  '(-t --template)'{-t,--template}'=[template]:file:_files' \
  '--no-badges[no badges]' \
  '--no-indent-headings[no heading bump]' \
  '--no-license[no license]' \
  '--no-template[no template]' \
  '--no-title[no title]'
