#compdef hivex
# _hivex — Red Hat hivex CLI wrapper helper for libhivex Windows registry hive parser library showing build features library include paths Python Perl OCaml Ruby bindings (libguestfs team, C); getopt
# upstream: https://github.com/libguestfs/hivex

_hivex() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--prefix[show install prefix]' \
        '--libdir[show lib dir]' \
        '--includedir[show include dir]' \
        '--datarootdir[show data root dir]' \
        '--cflags[show CFLAGS]' \
        '--libs[show LIBS]' \
        '--libversion[library version]' \
        '--has-python[has Python bindings]' \
        '--has-ocaml[has OCaml bindings]' \
        '--has-ruby[has Ruby bindings]' \
        '--has-perl[has Perl bindings]'
}

_hivex "$@"
