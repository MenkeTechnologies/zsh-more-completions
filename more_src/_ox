#compdef ox

# curlpipe/ox — src/cli.rs HELP constant

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[show help]' \
  '(-v)'{-v,--version}'[show version]' \
  '--readonly[open files read-only]' \
  '-r[open files read-only]' \
  '(-c)'{-c+,--config=}'[config file]:file:_files' \
  '(-f)'{-f+,--filetype=}'[set syntax/file type]:type:' \
  '--stdin[read buffer from stdin]' \
  '--config-assist[interactive config setup]' \
  '*:file:_files' && ret=0

return ret
