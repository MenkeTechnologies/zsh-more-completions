#compdef mcron
# Documentation: https://www.gnu.org/software/mcron/
# GNU mcron job scheduler

_arguments -s -S \
  '-v[display version information]' \
  '--version[display version information]' \
  '-h[display help]' \
  '--help[display help]' \
  '-s[run as scheduler daemon]' \
  '--schedule=[display next N jobs]:count:' \
  '-d[run in daemon mode]' \
  '--daemon[run in daemon mode]' \
  '-i[run interactively]' \
  '--stdin[read job specifications from stdin]' \
  '-n[disable use of syslog]' \
  '--no-daemon[do not fork into background]' \
  '*:job file:_files' \
  && return 0
