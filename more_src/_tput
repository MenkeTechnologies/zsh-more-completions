#compdef tput
# _tput — OpenBSD tput (terminfo capability querier; emits terminal escape sequences for clear/init/reset/longname/<capname>; -T overrides $TERM, -S reads cap names from stdin, -V prints ncurses version)
# upstream: https://github.com/openbsd/src (usr.bin/tput)
# Synopsis from usr.bin/tput/tput.1 on tip.

_tput() {
    _arguments \
        '-S[read capability names from stdin]' \
        '-T+[terminal type]:term:' \
        '-V[show ncurses version + exit]' \
        '-x[clear scrollback (with clear)]' \
        '*:capname:(clear init reset longname cup cuu cud cuf cub home el ed bel bold smso rmso smul rmul setaf setab op cnorm civis sgr0 rev blink rep cols lines)'
}

_tput "$@"
