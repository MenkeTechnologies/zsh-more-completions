#compdef scstadmin

# scstadmin: SCST (SCSI Target Subsystem for Linux) admin tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-config[load configuration file]:file:_files' \
  '-write_config[write configuration to file]:file:_files' \
  '-clear_config[clear configuration]' \
  '-noprompt[do not prompt]' \
  '-list_handler[list device handlers]' \
  '-list_device[list devices for handler]:handler:' \
  '-list_driver[list target drivers]' \
  '-list_target[list targets for driver]:driver:' \
  '-open_dev[open device]:name:' \
  '-close_dev[close device]:name:' \
  '-add_lun[add LUN to group/target]' \
  '-rem_lun[remove LUN]' \
  '-add_target[add target to driver]' \
  '-rem_target[remove target from driver]' \
  '-add_group[add security group]' \
  '-rem_group[remove security group]' \
  '-add_init[add initiator to group]' \
  '-rem_init[remove initiator from group]' \
  '-set_drv_attr[set driver attribute]' \
  '-set_dev_attr[set device attribute]' \
  '-set_tgt_attr[set target attribute]' \
  '*::scstadmin args:_files' && ret=0
return ret
