#compdef scstadmin

# scstadmin: SCST (Generic SCSI Target Subsystem) configuration utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-debug[debug output]' \
  '-force[force operation]' \
  '-noprompt[no confirmation prompts]' \
  '-config[apply config file]:file:_files' \
  '-clear_config[clear current config]' \
  '-list_handler[list device handlers]' \
  '-list_dev[list devices]' \
  '-list_driver[list drivers]' \
  '-list_target[list targets]' \
  '-list_group[list groups]' \
  '-list_initiator[list initiators]' \
  '-list_lun[list LUNs]' \
  '-add_device[add device]:name:' \
  '-rem_device[remove device]:name:' \
  '-add_target[add target]:name:' \
  '-rem_target[remove target]:name:' \
  '-add_group[add group]:name:' \
  '-rem_group[remove group]:name:' \
  '-add_init[add initiator]:name:' \
  '-rem_init[remove initiator]:name:' \
  '-add_lun[add LUN]:n:' \
  '-rem_lun[remove LUN]:n:' \
  '-handler[handler name]:name:' \
  '-driver[driver name]:name:' \
  '-target[target name]:name:' \
  '-group[group name]:name:' \
  '-attributes[attribute key=val]:attr:' \
  '-write_config[write config to file]:file:_files' \
  '-check_config[check config validity]:file:_files' \
  '*::scstadmin args:_files' && ret=0
return ret
