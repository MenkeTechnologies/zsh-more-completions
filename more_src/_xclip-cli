#compdef xclip-cli
# _xclip-cli — Kim Saunders xclip X11 clipboard CLI alias (astrand team, C); custom argparse
# upstream: https://github.com/astrand/xclip

_xclip-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-display+[X display]:str:' \
        '-d+[X display]:str:' \
        '-loops+[loops]:n:' \
        '-l+[loops]:n:' \
        '-selection=+[selection]:s:(primary secondary clipboard buffer-cut)' \
        '-sel=+[selection]:s:(primary secondary clipboard buffer-cut)' \
        '-i[input from stdin]' \
        '-in[input from stdin]' \
        '-o[output to stdout]' \
        '-out[output to stdout]' \
        '-r[remove selection]' \
        '-rmlastnl[remove last newline]' \
        '-target=+[mime type]:str:' \
        '-t+[mime type]:str:' \
        '-filter[filter mode]' \
        '-f[filter mode]' \
        '-silent[silent]' \
        '-quiet[suppress messages]' \
        '-verbose[verbose]' \
        '*:files:_files'
}

_xclip-cli "$@"
