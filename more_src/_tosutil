#compdef tosutil
# Documentation: https://www.volcengine.com/docs/6349/148775
# tosutil - Volcengine TOS (Torch Object Storage) command line tool

local ret=1

_arguments -C -s \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '1:command:(config mb mkdir ls du stat cp setmeta set-acl rm mount presign)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      cp)
        _arguments -s \
          '-r[recursively operate on all objects]' \
          '-f[force operation without confirmation]' \
          '-u[only copy objects whose source is newer than destination]' \
          '-j[maximum number of concurrent jobs]:jobs' \
          '-p[maximum number of concurrent tasks for multipart]:tasks' \
          '-acl[access control list]:acl' \
          '-meta[customized metadata]:meta' \
          '-ps[part size for multipart]:bytes' \
          '-threshold[threshold to enable multipart]:bytes' \
          '-config[user-defined config file]:config:_files' \
          '-i[access key (AK)]:ak' \
          '-k[secret key (SK)]:sk' \
          '-e[endpoint]:endpoint' \
          '-re[region]:region' \
          '*:file:_files' && ret=0
        ;;
      rm)
        _arguments -s \
          '-r[recursively delete]' \
          '-f[force delete without confirmation]' \
          '-j[maximum number of concurrent jobs]:jobs' \
          '-config[user-defined config file]:config:_files' \
          '*:object:_files' && ret=0
        ;;
      config)
        _arguments -s \
          '-i[access key (AK)]:ak' \
          '-k[secret key (SK)]:sk' \
          '-e[endpoint]:endpoint' \
          '-re[region]:region' \
          '-config[user-defined config file]:config:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
