#compdef bw_tcp
# Documentation: https://lmbench.sourceforge.net/man/bw_tcp.8.html
# bw_tcp - lmbench TCP bandwidth benchmark

local ret=1

_arguments -s -S \
  '-m[message size for each data chunk]:size' \
  '-M[total bytes to transfer (default 10MB)]:bytes' \
  '-P[degree of parallelism]:count' \
  '-W[number of warmup iterations]:count' \
  '-N[number of repetitions]:count' \
  '-s[run in server mode]' \
  '-S[send shutdown signal to specified server]:server:_hosts' \
  '*::server:_hosts' && ret=0

return ret
