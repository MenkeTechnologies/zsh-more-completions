#compdef mris_distance_map
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mris_distance_map/mris_distance_map.cpp
# Compute a geodesic distance map on a surface

local ret=1

_arguments -s -S \
  '--help[display help]' \
  '--version[show version]' \
  '-V[reference vertex number]:vertexno:' \
  '-U[display help]' \
  '-H[display help]' \
  '*:file:_files' && ret=0

return ret
