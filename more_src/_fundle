#compdef fundle
# Documentation: https://github.com/danhper/fundle
# fundle - fish shell plugin manager

local ret=1

_arguments -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'init:initialize fundle and load plugins'
      'install:install all plugins'
      'update:update all plugins'
      'plugin:register a plugin'
      'list:list installed plugins'
      'clean:remove unused plugins'
      'self-update:update fundle itself'
      'version:show fundle version'
      'help:show available commands'
    )
    _describe -t commands 'fundle command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments '--profile[show plugin load times]' && ret=0
        ;;
      list)
        _arguments '-s[shorter output format]' && ret=0
        ;;
      plugin)
        _arguments \
          '--url=[URL to clone the plugin from]:url:' \
          '--path=[plugin path relative to repository root]:path:' \
          '1:plugin:' && ret=0
        ;;
    esac
    ;;
esac

return ret
