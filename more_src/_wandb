#compdef wandb
# Documentation: https://github.com/wandb/wandb
# Reference accessed: 2026-05-27
# Verified: upstream wandb/cli/cli.py (Click command tree) and wandb/cli/beta.py.

# Zsh completion for wandb (Weights & Biases) CLI

local curcontext="$curcontext" state line ret=1

local -a _wandb_subcommands
_wandb_subcommands=(
  'login:authenticate this machine with W&B'
  'init:initialize or update W&B configuration for the current directory'
  'sync:sync offline runs to the W&B server'
  'sweep:create or manage a sweep'
  'launch:launch or queue a W&B job'
  'launch-sweep:launch a sweep through the launch system'
  'launch-agent:run a W&B launch agent'
  'agent:run a sweep agent'
  'scheduler:run a sweep scheduler'
  'job:manage and view W&B jobs (list, describe, create)'
  'controller:run a local sweep controller'
  'docker:run a command inside a Docker container with W&B'
  'docker-run:wrapper around docker run that injects W&B env vars'
  'local:legacy alias for server start'
  'server:operate a local W&B server (start, stop)'
  'artifact:upload, download, list, or manage W&B artifacts'
  'pull:pull files from a run'
  'restore:restore a runs code and config'
  'online:switch to online mode'
  'offline:switch to offline mode'
  'status:show current wandb settings status'
  'disabled:disable wandb logging for current dir'
  'enabled:re-enable wandb logging for current dir'
  'verify:verify W&B installation and connectivity'
  'purge-cache:purge local wandb cache directories'
  'beta:beta/experimental commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show wandb version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'wandb subcommand' _wandb_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--cloud[log in to W&B public cloud]' \
          '(--host --base-url)'{--host=,--base-url=}'[log in to a specific W&B server URL]:url:' \
          '--relogin[force re-login]' \
          '(--verify --no-verify)--verify[verify API key after storing]' \
          '(--verify --no-verify)--no-verify[do not verify API key]' \
          '*:key:' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity (team or user)]:entity:' \
          '--reset[reset existing wandb configuration]' \
          '--mode=[wandb mode]:mode:(online offline disabled)' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--id=[existing run ID]:id:' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity (team or user)]:entity:' \
          '--job_type=[job type]:type:' \
          '(--sync-tensorboard --no-sync-tensorboard)--sync-tensorboard[sync tensorboard events]' \
          '(--sync-tensorboard --no-sync-tensorboard)--no-sync-tensorboard[do not sync tensorboard]' \
          '--include-globs=[include globs]:globs:' \
          '--exclude-globs=[exclude globs]:globs:' \
          '--include-online[include online runs]' \
          '--no-include-online[exclude online runs]' \
          '--include-offline[include offline runs]' \
          '--no-include-offline[exclude offline runs]' \
          '--include-synced[include already-synced runs]' \
          '--no-include-synced[exclude already-synced runs]' \
          '--mark-synced[mark runs as synced after upload]' \
          '--no-mark-synced[do not mark synced]' \
          '--sync-all[sync all runs found under path]' \
          '--clean[delete local data for synced runs]' \
          '--clean-old-hours=[clean synced runs older than N hours]:hours:' \
          '--clean-force[skip confirmation for --clean]' \
          '--show=[number of runs to show in summary]:n:' \
          '--append[append to existing run]' \
          '--skip-console[skip uploading console logs]' \
          '--replace-tags=[rename tags (old=new pairs)]:pairs:' \
          '*:run directory:_directories' && ret=0
        ;;
      sweep)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity (team or user)]:entity:' \
          '--controller[start a local controller]' \
          '--verbose[verbose output]' \
          '--name=[sweep display name]:name:' \
          '--program=[program to run]:program:_files' \
          '--settings=[sweep settings]:settings:' \
          '--update=[update an existing sweep]:sweep_id:' \
          '--stop[stop a sweep]' \
          '--cancel[cancel a sweep]' \
          '--pause[pause a sweep]' \
          '--resume[resume a sweep]' \
          '(-R --prior_run)'{-R+,--prior_run=}'[incorporate prior run]:run_id:' \
          '--queue=[queue name for launch-sweep mode]:queue:' \
          '1:config file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      launch-sweep)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity]:entity:' \
          '--queue=[launch queue name]:queue:' \
          '--resume_id=[resume existing sweep ID]:id:' \
          '--prior_run=[incorporate prior run]:run_id:' \
          '1:config file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      launch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-u --uri)'{-u+,--uri=}'[URI of code to launch]:uri:' \
          '(-j --job)'{-j+,--job=}'[job to launch]:job:' \
          '(-E --entry-point)'{-E+,--entry-point=}'[entry point]:entry:' \
          '(-g --git-version)'{-g+,--git-version=}'[git commit/branch]:rev:' \
          '--build-context=[git subdirectory used as build context]:dir:' \
          '--job-name=[name for the launched job]:name:' \
          '(-n --name)'{-n+,--name=}'[run name]:name:' \
          '--entity=[entity]:entity:' \
          '--project=[project]:project:' \
          '(-r --resource)'{-r+,--resource=}'[launch resource]:resource:(local-process local-container kubernetes sagemaker vertex)' \
          '-d+[docker image]:image:' \
          '--docker-image=[docker image]:image:' \
          '--base-image=[base docker image]:image:' \
          '(-c --config)'{-c+,--config=}'[launch config file]:file:_files -g "*.(yaml|json)"' \
          '*--set-var=[set runtime variable]:var:' \
          '(-q --queue)'{-q+,--queue=}'[queue name]:queue:' \
          '--async[do not block waiting for run]' \
          '*-R+[resource arg]:arg:' \
          '*--resource-args=[resource arguments]:args:' \
          '--build[build a local docker image]' \
          '--repository=[image registry/repo]:repo:' \
          '--project-queue=[project queue]:queue:' \
          '--dockerfile=[dockerfile path]:file:_files' \
          '--priority=[queue priority]:priority:(critical high medium low)' && ret=0
        ;;
      launch-agent)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-q --queue)*'{-q+,--queue=}'[queues to watch]:queue:' \
          '(-e --entity)'{-e+,--entity=}'[entity]:entity:' \
          '(-l --log-file)'{-l+,--log-file=}'[agent log file]:file:_files' \
          '(-j --max-jobs)'{-j+,--max-jobs=}'[max concurrent jobs]:n:' \
          '(-c --config)'{-c+,--config=}'[agent config yaml]:file:_files -g "*.yaml"' \
          '(-u --url)'{-u+,--url=}'[server URL]:url:' \
          '(-v --verbose)*'{-v,--verbose}'[verbose output]' && ret=0
        ;;
      agent)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity]:entity:' \
          '--count=[max sweep runs to run]:n:' \
          '--forward-signals[forward signals to child]' \
          '--verbose[verbose output]' \
          '1:sweep_id:' && ret=0
        ;;
      controller)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-v --verbose)*'{-v,--verbose}'[verbose output]' \
          '1:sweep_id:' && ret=0
        ;;
      job)
        _arguments -s -S \
          '1:action:(list describe create)' \
          '*:: :_files' && ret=0
        ;;
      docker-run)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' '*::docker args:' && ret=0
        ;;
      docker)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(--nvidia --no-nvidia)--nvidia[enable nvidia GPU support]' \
          '(--nvidia --no-nvidia)--no-nvidia[disable nvidia GPU support]' \
          '--digest[print image digest and exit]' \
          '(--jupyter --no-jupyter)--jupyter[run jupyter lab in container]' \
          '(--jupyter --no-jupyter)--no-jupyter[do not run jupyter lab]' \
          '--dir=[directory to mount code at]:dir:' \
          '--no-dir[do not mount current directory]' \
          '--shell=[container shell]:shell:' \
          '--port=[host port to bind jupyter]:port:' \
          '--cmd=[command to run in container]:cmd:' \
          '--no-tty[run without tty]' \
          '*:: :' && ret=0
        ;;
      local|server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(start stop)' \
          '(-p --port)'{-p+,--port=}'[host port to bind W&B local on]:port:' \
          '(-e --env)*'{-e+,--env=}'[env vars to pass to container]:env:' \
          '(--daemon --no-daemon)--daemon[run in daemon mode]' \
          '(--daemon --no-daemon)--no-daemon[run in foreground]' \
          '--upgrade[upgrade to latest version]' && ret=0
        ;;
      artifact)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(put get ls cache)' \
          '*:: :_files' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity]:entity:' \
          '1:run:' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-e --entity)'{-e+,--entity=}'[entity]:entity:' \
          '--no-git[do not initialize git]' \
          '(--branch --no-branch)--branch[create branch with restored state]' \
          '(--branch --no-branch)--no-branch[do not create branch]' \
          '1:run:' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(--settings --no-settings)--settings[show settings]' \
          '(--settings --no-settings)--no-settings[hide settings]' && ret=0
        ;;
      disabled|enabled)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--service[apply to wandb service only]' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--host=[verify a specific host]:host:' && ret=0
        ;;
      purge-cache)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--age=[purge cache entries older than N days]:days:' \
          '--force[skip confirmation]' && ret=0
        ;;
      online|offline)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      beta)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:beta command:(leet sync)' \
          '*:: :_files' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
