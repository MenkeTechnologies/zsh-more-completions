#compdef wandb
# Documentation: https://docs.wandb.ai/ref/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wandb (Weights & Biases)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'agent:run a sweep agent'
      'artifact:manage artifacts'
      'beta:beta features'
      'controller:run a sweep controller'
      'disabled:disable wandb logging'
      'docker:run a command in a Docker container'
      'docker-run:run a command in a Docker container (alias)'
      'enabled:enable wandb logging'
      'init:initialize a project'
      'job:manage jobs'
      'launch:launch a run'
      'launch-agent:run a launch agent'
      'launch-sweep:launch a sweep'
      'login:login to wandb'
      'offline:switch to offline mode'
      'online:switch to online mode'
      'pull:pull files from a run'
      'purge-cache:purge local cache'
      'restore:restore a run'
      'scheduler:run a sweep scheduler'
      'server:run a local wandb server'
      'status:show status'
      'sweep:create or manage sweeps'
      'sync:sync offline runs'
      'verify:verify installation'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      login)
        _arguments -s -S \
          '--cloud[login to W&B public cloud]' \
          '(--host --base-url)'{--host=,--base-url=}'[custom W&B server URL]:url' \
          '--relogin[force re-login]' \
          '--verify[authenticate API key and display source]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:key' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-p --project)'{-p+,--project=}'[project name]:project' \
          '(-e --entity)'{-e+,--entity=}'[entity (team or user)]:entity' \
          '(-m --mode)'{-m+,--mode=}'[wandb mode]:mode:(online offline disabled)' \
          '--reset[reset existing wandb configuration]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '--id=[existing run ID]:id' \
          '(-p --project)'{-p+,--project=}'[project name]:project' \
          '(-e --entity)'{-e+,--entity=}'[entity (team or user)]:entity' \
          '--include-globs=[include globs]:globs' \
          '--exclude-globs=[exclude globs]:globs' \
          '--include-online[include online runs]' \
          '--include-offline[include offline runs]' \
          '--include-synced[include already-synced runs]' \
          '--mark-synced[mark runs as synced after upload]' \
          '--append[append to existing run]' \
          '--clean[delete local data for synced runs]' \
          '--clean-old-hours=[delete synced runs older than N hours]:hours' \
          '--clean-force[skip confirmation for --clean]' \
          '--sync-tensorboard[control TensorBoard event syncing]' \
          '--skip-console[skip uploading console logs]' \
          '--replace-tags=[rename tags (old=new pairs)]:pairs' \
          '(- *)'{-h,--help}'[show help]' \
          '*:run directory:_directories' && ret=0
        ;;
      sweep)
        _arguments -s -S \
          '(-p --project)'{-p+,--project=}'[project name]:project' \
          '(-e --entity)'{-e+,--entity=}'[entity (team or user)]:entity' \
          '--name=[sweep display name]:name' \
          '--program=[program to run]:program:_files' \
          '--controller[start a local controller]' \
          '--verbose[verbose output]' \
          '--update=[update an existing sweep]:sweep id' \
          '--stop[stop a sweep]' \
          '--cancel[cancel a sweep]' \
          '--pause[pause a sweep]' \
          '--resume[resume a sweep]' \
          '(-R --prior_run)'{-R+,--prior_run=}'[incorporate prior run]:run id' \
          '(- *)'{-h,--help}'[show help]' \
          '1:config file:_files -g "*.yaml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
