#compdef wandb

# Zsh completion for wandb (Weights & Biases)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'agent:run a sweep agent'
      'artifact:manage artifacts'
      'controller:run a sweep controller'
      'disabled:disable wandb logging'
      'docker:run a command in a Docker container'
      'docker-run:run a command in a Docker container'
      'enabled:enable wandb logging'
      'init:initialize a project'
      'launch:launch a run'
      'launch-agent:run a launch agent'
      'login:login to wandb'
      'offline:switch to offline mode'
      'online:switch to online mode'
      'pull:pull files from a run'
      'restore:restore a run'
      'server:run a local wandb server'
      'status:show status'
      'sweep:create or manage sweeps'
      'sync:sync offline runs'
      'verify:verify installation'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      login)
        _arguments -s -S \
          '--key=[API key]:key' \
          '--host=[host]:host' \
          '--relogin[force re-login]' \
          '--cloud[login to wandb cloud]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-p --project)'{-p,--project}'[project name]:project' \
          '(-e --entity)'{-e,--entity}'[team or user]:entity' \
          '--reset[reset settings]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '--id=[run ID]:id' \
          '(-p --project)'{-p,--project}'[project name]:project' \
          '(-e --entity)'{-e,--entity}'[team or user]:entity' \
          '--include-globs=[include globs]:globs' \
          '--exclude-globs=[exclude globs]:globs' \
          '--include-online[include online runs]' \
          '--include-offline[include offline runs]' \
          '--include-synced[include synced runs]' \
          '--clean-old-hours=[clean runs older than N hours]:hours' \
          '--clean-force[force clean]' \
          '--mark-synced[mark as synced without syncing]' \
          '--append[append to existing run]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:run directory:_directories' && ret=0
        ;;
      sweep)
        _arguments -s -S \
          '(-p --project)'{-p,--project}'[project name]:project' \
          '(-e --entity)'{-e,--entity}'[team or user]:entity' \
          '--name=[sweep name]:name' \
          '--program=[program to run]:program:_files' \
          '--controller[start a controller]' \
          '--verbose[verbose output]' \
          '--update=[update a sweep]:sweep id' \
          '--stop[stop a sweep]' \
          '--cancel[cancel a sweep]' \
          '--pause[pause a sweep]' \
          '--resume[resume a sweep]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:config file:_files -g "*.yaml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
