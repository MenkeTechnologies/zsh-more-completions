#compdef acra-poisonrecordmaker
# _acra-poisonrecordmaker — generate Acra poison records (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Flags from cmd/acra-poisonrecordmaker/acra-poisonrecordmaker.go (flag).

_acra-poisonrecordmaker() {
    _arguments \
        '(- *)-h[show help]' \
        '-keys_dir=[folder containing keys]:dir:_files -/' \
        '-data_length=[random data block length (-1 = random)]:n:' \
        '-type=[poison record format]:type:(acrastruct acrablock)'
}

_acra-poisonrecordmaker "$@"
