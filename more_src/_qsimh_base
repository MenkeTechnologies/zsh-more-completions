#compdef qsimh_base
# Documentation: https://quantumai.google/qsim/usage
# qsim hybrid Schrodinger-Feynman circuit simulator

local ret=1

_arguments -s -S \
  '-c[circuit file to run]:circuit file:_files' \
  '-d[maximum time]:maxtime' \
  '-k[comma-separated list of qubit indices for part 1]:part1 qubits' \
  '-w[prefix value]:prefix' \
  '-p[number of prefix gates]:num prefix gates' \
  '-r[number of root gates]:num root gates' \
  '-t[number of threads to use]:num threads' \
  '-v[verbosity level (0,1,4,5)]:verbosity' \
  '-z[set flush-to-zero and denormals-are-zeros MXCSR flags]' && ret=0

return ret
