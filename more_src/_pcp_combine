#compdef pcp_combine
# Documentation: https://metplus.readthedocs.io/projects/met/en/latest/Users_Guide/reformat_grid.html
# pcp_combine - MET tool to sum/add/subtract/derive accumulated precipitation

local ret=1

_arguments -s \
  '-sum[sum precipitation across multiple matching files]' \
  '-add[add together data from explicit input files]' \
  '-subtract[compute difference of two input files]' \
  '-derive[compute summary fields (sum/min/max/range/mean/stdev/vld_count)]:stat_list:' \
  '*-pcpdir[directory containing input files]:dir:_files -/' \
  '-pcprx[regex for matching files in search directories]:regex:' \
  '*-field[field to extract from input files]:field:' \
  '-name[comma-separated output variable names]:names:' \
  '-input_thresh[required ratio of valid input files]:thresh:' \
  '-vld_thresh[required ratio of valid data at grid points]:thresh:' \
  '-log[direct output and errors to log file]:file:_files' \
  '-v[verbosity level]:level:' \
  '-compress[NetCDF deflate compression level (0-9)]:level:' \
  '*:file:_files' && ret=0

return ret
