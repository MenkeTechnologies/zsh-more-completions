#compdef gitlab-runner

# Zsh completion for gitlab-runner - GitLab CI runner

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[enable debug mode]' \
  '--log-level=[log level]:level:(debug info warn error fatal panic)' \
  '--cpuprofile=[write CPU profile to file]:file:_files' \
  '--listen-address=[metrics/debug listen address]:address' \
  {-c,--config}'=[config file path]:file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run multi runner service'
      'register:register a new runner'
      'reset-token:reset runner token'
      'unregister:unregister a runner'
      'verify:verify registered runners'
      'artifacts-downloader:download build artifacts'
      'artifacts-uploader:upload build artifacts'
      'cache-archiver:create and upload cache archives'
      'cache-extractor:download and extract cache archives'
      'cache-init:initialize distributed cache'
      'health-check:check health of runner'
      'install:install as a system service'
      'uninstall:uninstall the system service'
      'start:start the service'
      'stop:stop the service'
      'restart:restart the service'
      'status:show service status'
      'list:list all configured runners'
      'help:show help for a command'
    )
    _describe -t commands 'gitlab-runner command' commands && ret=0
    ;;
  args)
    case $words[1] in
      register)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-c,--config}'=[config file]:file:_files' \
          '--non-interactive[run in non-interactive mode]' \
          '-n[run in non-interactive mode]' \
          '--url=[GitLab instance URL]:url' \
          '-u=[GitLab instance URL]:url' \
          '--registration-token=[registration token]:token' \
          '-r=[registration token]:token' \
          '--token=[runner authentication token]:token' \
          '--name=[runner name]:name' \
          '--tag-list=[comma-separated tag list]:tags' \
          '--executor=[executor]:executor:(shell docker docker+machine kubernetes virtualbox parallels ssh docker-ssh docker-ssh+machine custom)' \
          '--docker-image=[default Docker image]:image' \
          && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-c,--config}'=[config file]:file:_files' \
          '--working-directory=[working directory]:directory:_directories' \
          '-d=[working directory]:directory:_directories' \
          '--service=[service name]:name' \
          '-n=[service name]:name' \
          '--user=[run as user]:user:_users' \
          '--syslog[log to syslog]' \
          && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--working-directory=[working directory]:directory:_directories' \
          '-d=[working directory]:directory:_directories' \
          '--service=[service name]:name' \
          '-n=[service name]:name' \
          '--user=[run as user]:user:_users' \
          && ret=0
        ;;
      help)
        local -a subcmds=(run register reset-token unregister verify install uninstall start stop restart status list)
        _describe -t commands 'gitlab-runner command' subcmds && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-c,--config}'=[config file]:file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
