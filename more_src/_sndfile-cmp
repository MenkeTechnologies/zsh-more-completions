#compdef sndfile-cmp
# Documentation: https://man.archlinux.org/search?q=sndfile-cmp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '1:first sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
    '2:second sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
)

_arguments -s -S $arguments
