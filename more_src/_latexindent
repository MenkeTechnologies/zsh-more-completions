#compdef latexindent
# Documentation: https://github.com/cmhughes/latexindent.pl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (Getopt::Long table in latexindent.pl).

# Flag set derived from the GetOptions() call in cmhughes/latexindent.pl.
local -a arguments

arguments=(
    '-h[Show help]'
    '--help[Show help]'
    '-v[Show version]'
    '--version[Show version]'
    '-vv[Show extended version info]'
    '--vversion[Show extended version info]'
    '-s[Silent mode]'
    '--silent[Silent mode]'
    '-t[Trace mode]'
    '--trace[Trace mode]'
    '-tt[More detailed trace mode]'
    '--ttrace[More detailed trace mode]'
    '-l[Local YAML settings file]:file:_files -g "*.yaml"'
    '--local[Local YAML settings file]:file:_files -g "*.yaml"'
    '-y[YAML settings as inline string]:settings'
    '--yaml[YAML settings as inline string]:settings'
    '-d[Use only defaultSettings.yaml]'
    '--onlydefault[Use only defaultSettings.yaml]'
    '-w[Overwrite the file in place]'
    '--overwrite[Overwrite the file in place]'
    '-wd[Overwrite only if output differs]'
    '--overwriteIfDifferent[Overwrite only if output differs]'
    '-o[Output to file]:file:_files'
    '--outputfile[Output to file]:file:_files'
    '-m[Modify line breaks]'
    '--modifylinebreaks[Modify line breaks]'
    '-g[Log file name]:file:_files'
    '--logfile[Log file name]:file:_files'
    '-c[Cruft directory for cache and log files]:dir:_directories'
    '--cruft[Cruft directory for cache and log files]:dir:_directories'
    '-sl[Also write log to terminal]'
    '--screenlog[Also write log to terminal]'
    '-r[Replacement mode (perform regex replacements)]'
    '--replacement[Replacement mode (perform regex replacements)]'
    '-rr[Replacement mode only (do not indent)]'
    '--onlyreplacement[Replacement mode only (do not indent)]'
    '-rv[Replacement mode respecting verbatim]'
    '--replacementrespectverb[Replacement mode respecting verbatim]'
    '-k[Check (only report changes)]'
    '--check[Check (only report changes)]'
    '-kv[Check verbose]'
    '--checkv[Check verbose]'
    '-n[Line numbers in output]:lines'
    '--lines[Line numbers in output]:lines'
    '--GCString[Use Unicode::GCString for character counting]'
    '*:latex file:_files -g "*.{tex,sty,cls,bib,bbl}"'
)

_arguments -s -S $arguments
