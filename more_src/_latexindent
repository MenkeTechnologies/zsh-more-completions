#compdef latexindent

local -a arguments

arguments=(
    '-h[Show help]'
    '--help[Show help]'
    '-v[Show version]'
    '--version[Show version]'
    '-w[Overwrite file]'
    '--overwrite[Overwrite file]'
    '-o[Output to file]:file:_files'
    '--outputfile[Output to file]:file:_files'
    '-s[Silent mode]'
    '--silent[Silent mode]'
    '-t[Trace mode]'
    '--trace[Trace mode]'
    '-tt[Enhanced trace mode]'
    '-l[Local settings file]:file:_files -g "*.yaml"'
    '--local[Local settings file]:file:_files -g "*.yaml"'
    '-y[YAML settings as string]:settings'
    '--yaml[YAML settings as string]:settings'
    '-d[Only default settings]'
    '--onlydefault[Only default settings]'
    '-g[Log file name]:file:_files'
    '--logfile[Log file name]:file:_files'
    '-c[Cruft directory]:dir:_directories'
    '--cruft[Cruft directory]:dir:_directories'
    '-m[Modify line breaks]'
    '--modifylinebreaks[Modify line breaks]'
    '-r[Replace mode]'
    '--replacement[Replace mode]'
    '-rv[Replacement mode, verbose]'
    '--replacementrespectverb[Replacement mode, respect verbatim]'
    '-rr[Replacement mode, no regex]'
    '--replacementnoreg[Replacement mode, no regex]'
    '--GCString[Use Unicode::GCString]'
    '*:latex file:_files -g "*.{tex,sty,cls,bib,bbl}"'
)

_arguments -s -S $arguments
