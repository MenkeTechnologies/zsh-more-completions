#compdef spm_encode
# Documentation: https://github.com/google/sentencepiece/blob/master/src/spm_encode_main.cc
# SentencePiece encoder: text to subword pieces or ids

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[model file name]:model:_files' \
  '--output_format=[output format]:format:(piece id proto sample_piece sample_id sample_proto nbest_piece nbest_id nbest_proto)' \
  '--input=[input filename]:file:_files' \
  '--output=[output filename]:file:_files' \
  '--extra_options=[colon-separated encoder extra options, e.g. reverse:bos:eos]:opts' \
  '--nbest_size=[NBest size]:n' \
  '--alpha=[smoothing parameter for sampling mode]:alpha' \
  '--random_seed=[seed value for random generator]:seed' \
  '--vocabulary=[restrict the vocabulary]:file:_files' \
  '--vocabulary_threshold=[words with frequency below threshold treated as OOV]:n' \
  '--generate_vocabulary[generate vocabulary file instead of segmentation]' \
  '*:input file:_files' && ret=0

return ret
