#compdef distrobox-init
# Documentation: https://man.archlinux.org/search?q=distrobox-init
# Reference accessed: 2026-05-16

_arguments -s \
  '(-n --name)'{-n,--name=}'[user name]:name:' \
  '(-u --user)'{-u,--user=}'[UID]:uid:' \
  '(-g --group)'{-g,--group=}'[GID]:gid:' \
  '(-d --home)'{-d,--home=}'[home directory]:dir:_files -/' \
  '--additional-packages=[extra packages]:pkgs:' \
  '(-I --init)'{-I,--init}'[use init]' \
  '--pre-init-hooks=[pre-init commands]:cmds:' \
  '--init-hooks=[init commands]:cmds:' \
  '--nvidia[integrate nVidia drivers]' \
  '(-U --upgrade)'{-U,--upgrade}'[upgrade mode]' \
  '*'{-v,--verbose}'[verbose]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:command:'
