#compdef weggli

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-R[recursive search]' \
  '-C[enable C++ mode]' \
  '-l[display only file paths]' \
  '-u[unique results only]' \
  '-f[force scan all files]' \
  '-n[no color output]' \
  '--limit=[max number of results]:count' \
  '-e+[exclude pattern]:pattern' \
  '-p+[additional pattern]:pattern' \
  '--extensions=[file extensions to search]:extensions' \
  '--before=[lines of context before match]:lines' \
  '--after=[lines of context after match]:lines' \
  '1:pattern:' \
  '2:path:_files' && return 0
