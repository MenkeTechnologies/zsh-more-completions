#compdef weggli
# Documentation: https://github.com/googleprojectzero/weggli
# Reference accessed: 2026-05-21
# Verified: upstream src/cli.rs clap argument definitions.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-p+,--pattern=}'[additional search pattern]:pattern' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*'{-e+,--extensions=}'[file extensions to include]:ext' \
  '(-B --before)'{-B+,--before=}'[lines before match (default 5)]:lines' \
  '(-A --after)'{-A+,--after=}'[lines after match (default 5)]:lines' \
  '(-l --limit)'{-l,--limit}'[only first match per function]' \
  '*'{-R+,--regex=}'[enforce variable regex match]:regex' \
  '(-X --cpp)'{-X,--cpp}'[enable C++ mode]' \
  '(-C --color)'{-C,--color}'[force color output]' \
  '(-f --force)'{-f,--force}'[force search despite syntax errors]' \
  '(-u --unique)'{-u,--unique}'[enforce uniqueness of variable matches]' \
  '--exclude=[exclude files matching regex]:regex' \
  '--include=[include only files matching regex]:regex' \
  '(-n --line-numbers)'{-n,--line-numbers}'[enable line numbers]' \
  '1:pattern:' \
  '2:path:_files' && return 0
