#compdef venom

_venom_commands() {
  local -a commands=(
    'run:Run test suites'
    'update:Update venom binary'
    'version:Print version'
  )
  _describe 'command' commands
}

_venom() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[Show help]' \
    '1:command:_venom_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        run)
          _arguments \
            '--format[Output format]:format:(xml json yaml tap html)' \
            '--output-dir[Output directory]:dir:_directories' \
            '--lib-dir[Lib directory for custom executors]:dir:_directories' \
            '--stop-on-failure[Stop on first failure]' \
            '--verbose[Set verbosity]:level:(1 2 3 4 5)' \
            '--var[Set variable]:var:' \
            '--var-from-file[Set variables from file]:file:_files -g "*.yml *.yaml *.json"' \
            '--html-report[Generate HTML report]' \
            '--no-check-variables[Do not check variables]' \
            '--strict[Enable strict mode]' \
            '--parallel[Number of parallel test suites]:num:' \
            '*:test files:_files -g "*.yml *.yaml"'
          ;;
      esac
      ;;
  esac
}

_venom "$@"
