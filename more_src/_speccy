#compdef speccy
# _speccy — OpenAPI lint/resolve/serve toolkit (wework/speccy)
# upstream: https://github.com/wework/speccy
# Subcommands from speccy.js (commander).

_speccy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'lint:lint a spec against rules'
                'resolve:pull in external $refs into one file'
                'serve:render docs in a local server'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                lint)
                    _arguments \
                        '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
                        '*'{-r+,--rules=}'[rule file (repeatable)]:file:_files' \
                        '*'{-s+,--skip=}'[rule name to skip (repeatable)]:rule:' \
                        '(-j --json-schema)'{-j,--json-schema}'[treat $ref like JSON Schema]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:spec file or URL:_files -g "*.{yaml,yml,json}"'
                    ;;
                resolve)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
                        '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
                        '(-j --json-schema)'{-j,--json-schema}'[treat $ref like JSON Schema]' \
                        '(-i --internal-refs)'{-i,--internal-refs}'[resolve internal references]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:spec file or URL:_files -g "*.{yaml,yml,json}"'
                    ;;
                serve)
                    _arguments \
                        '(-p --port)'{-p+,--port=}'[server port (default 5000)]:port:' \
                        '(-q --quiet)'{-q,--quiet}'[reduce verbosity]' \
                        '(-j --json-schema)'{-j,--json-schema}'[treat $ref like JSON Schema]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:spec file or URL:_files -g "*.{yaml,yml,json}"'
                    ;;
            esac
            ;;
    esac
}

_speccy "$@"
