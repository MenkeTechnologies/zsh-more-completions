#compdef strace-cli
# _strace-cli — strace trace system calls and signals CLI alias (strace team, C); custom argparse
# upstream: https://github.com/strace/strace

_strace-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[column for return values]:n:' \
        '-c[count syscalls and report summary]' \
        '-C[combine count with regular output]' \
        '-d[debug]' \
        '-D[run as detached]' \
        '-DD[detach more]' \
        '-DDD[detach the most]' \
        '-e+[expr]:str:' \
        '-f[trace child processes]' \
        '-ff[follow forks and write to separate files]' \
        '-F[follow vfork()s]' \
        '-h[show help]' \
        '-i[print instruction pointer]' \
        '-I+[mode]:m:(1 2 3 4)' \
        '-k[print stack trace]' \
        '-K[print syscall calls in raw format]' \
        '-n[print syscall numbers]' \
        '-o+[file]:file:_files' \
        '-O+[overhead]:n:' \
        '-p+[pid]:pid:_pids' \
        '-P+[path]:file:_files' \
        '-q[suppress messages about attaching/detaching]' \
        '-qq[suppress messages about process exits]' \
        '-qqq[suppress all extra messages]' \
        '-r[print relative timestamp]' \
        '-s+[max string size]:n:' \
        '-S+[sort]:s:(time calls name nothing)' \
        '-t[print absolute timestamp]' \
        '-tt[print timestamp with microseconds]' \
        '-ttt[print timestamp as float]' \
        '-T[show time spent in each syscall]' \
        '-u+[user]:_users' \
        '-v[print unabbreviated versions of structures]' \
        '-w[summarise time spent in syscalls]' \
        '-x[print non-ASCII strings in hex]' \
        '-xx[print all strings in hex]' \
        '-X+[mode]:m:(raw abbrev verbose)' \
        '-y[print paths assoc with FD args]' \
        '-yy[print protocol information assoc with sockets]' \
        '-Y[print numerics in human-friendly form]' \
        '-z[only print syscalls returning success]' \
        '-Z[only print syscalls returning errors]' \
        '-A[append output instead of overwriting]' \
        '-b+[syscall]:str:' \
        '-E+[var=value]:str:' \
        '-G[trace fault injections]' \
        '--columns=+[columns spec]:str:' \
        '--decode-fds=+[mode]:m:(path socket dev pidfd)' \
        '--decode-pids=+[mode]:m:(comm pidns)' \
        '--detach-on=+[mode]:m:(execve)' \
        '--follow-forks[follow forks]' \
        '--no-abbrev[no abbrev]' \
        '--read=+[fd]:str:' \
        '--write=+[fd]:str:' \
        '--inject=+[set]:str:' \
        '--fault=+[set]:str:' \
        '--trace=+[set]:str:' \
        '--trace-fds=+[fds]:str:' \
        '--trace-path=+[path]:file:_files' \
        '--secontext=+[mode]:m:(mismatch full)' \
        '--syscall-times[show syscall times]' \
        '--syscall-limit=+[n]:n:' \
        '--stack-traces[show stack traces]' \
        '--stack-traces-frame-limit=+[n]:n:' \
        '--print-pid-prefix[print PID prefix]' \
        '--no-print-pid-prefix[no PID prefix]' \
        '*:command:_command_names'
}

_strace-cli "$@"
