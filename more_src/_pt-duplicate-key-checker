#compdef pt-duplicate-key-checker

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--charset=[charset]:charset:' \
  '--databases=[databases to check]:dbs:' \
  '--engines=[storage engines to check]:engines:' \
  '--host=[MySQL host]:host:_hosts' \
  '--password=[MySQL password]:pw:' \
  '--port=[MySQL port]:port:' \
  '--socket=[MySQL socket]:file:_files' \
  '--summary[print summary]' \
  '--tables=[tables to check]:tables:' \
  '--user=[MySQL user]:user:' \
  '--verbose[verbose]' \
  '--version-check[do version check]' \
  '--key-types=[key types to check]:types:(fk indexes)' \
  '--clustered[detect clustered duplicates]' \
  '--ignore-databases=[ignore databases]:list:' \
  '--ignore-tables=[ignore tables]:list:' \
  '--ignore-engines=[ignore engines]:list:' \
  '*:DSN:' && ret=0

return ret
