#compdef aligncopy
# Documentation: https://man.archlinux.org/search?q=aligncopy
# Reference accessed: 2026-05-16

# EMBOSS aligncopy: read/write alignment, optionally changing format
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output filename]:file:_files' \
  '-sequences=[input alignment]:file:_files' \
  '-name=[output sequence name]:name:' \
  '-comment=[output alignment comment]:text:' \
  '-append[append to output file]' \
  '*:alignment file:_files' && ret=0

return ret
