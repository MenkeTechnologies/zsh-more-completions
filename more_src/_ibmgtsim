#compdef ibmgtsim

# ibmgtsim: InfiniBand management simulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-d[debug level]:n:' \
  '-f[topology file]:file:_files' \
  '-c[config file]:file:_files' \
  '*::ibmgtsim args:_files' && ret=0
return ret
