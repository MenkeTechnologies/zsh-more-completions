#compdef hindsight hindsight.py
# Documentation: https://github.com/obsidianforensics/hindsight
# Chrome/Chromium browser history forensics tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'=[Chromium profile directory]:directory:_directories' \
  '(-o --output)'{-o,--output}'=[output filename without extension]:filename' \
  '(-b --browser_type)'{-b,--browser_type}'=[force browser type]:browser:(Chrome Edge Brave Vivaldi Firefox Tor)' \
  '(-f --format)'{-f,--format}'=[output format]:format:(xlsx sqlite jsonl)' \
  '(-l --log)'{-l,--log}'=[log file location]:file:_files' \
  '(-t --timezone)'{-t,--timezone}'=[display timezone for XLSX]:timezone' \
  '(-d --decrypt)'{-d,--decrypt}'=[attempt decryption for OS]:os:(mac linux)' \
  '(-c --cache)'{-c,--cache}'=[cache directory path]:directory:_directories' \
  '(--nocopy --no_copy)'{--nocopy,--no_copy}'[do not copy files before opening]' \
  '--temp_dir=[temporary directory for copies]:directory:_directories' && ret=0

return ret
