#compdef btmgmt
# Documentation: https://manpages.debian.org/btmgmt.1
# Source: BlueZ — Bluetooth management interface CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[display help]' \
    '(- *)--version[display version]' \
    '--index=[adapter index]:index:' \
    '--timeout=[timeout (seconds) for non-interactive mode]:seconds:' \
    '*:command:' \
    && ret=0

return ret
