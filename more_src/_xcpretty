#compdef xcpretty

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-t --test)'{-t,--test}'[use test output format]' \
  '(-s --simple)'{-s,--simple}'[use simple output format]' \
  '(-k --knock)'{-k,--knock}'[use knock output format]' \
  '--tap[use TAP output format]' \
  '(-c --color)'{-c,--color}'[use colorized output]' \
  '--no-color[disable colors]' \
  '--no-utf[disable UTF-8]' \
  '(-r --report)'{-r,--report}'+[generate report]:type:(html json-compilation-database junit)' \
  '(-o --output)'{-o,--output}'+[output report to path]:file:_files' && ret=0

return ret
