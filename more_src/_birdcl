#compdef birdcl
# Documentation: https://manpages.debian.org/bookworm/bird2/birdcl.8.en.html
# BIRD light command client for the BIRD Internet Routing Daemon

local ret=1

_arguments -s -S \
  '-l[look for a communication socket in the current working directory]' \
  '-r[run in restricted mode: only show commands are allowed]' \
  '-s[use given filename for the control socket]:control socket:_files' \
  '-v[dump numeric return codes along with messages]' \
  '*:command:' && ret=0

return ret
