#compdef ballista-executor
# Documentation: https://datafusion.apache.org/ballista/user-guide/deployment/quick-start.html
# Apache DataFusion Ballista distributed query executor process

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--scheduler-host=[scheduler host]:host' \
  '--scheduler-port=[scheduler port]:port' \
  '--bind-host=[local IP address to bind to]:host' \
  '--external-host=[host name or IP to register with scheduler]:host' \
  '(-p --bind-port)'{-p,--bind-port}'=[bind port]:port' \
  '--bind-grpc-port=[gRPC service bind port]:port' \
  '--scheduler-connect-timeout-seconds=[how long to try connecting to scheduler before failing]:seconds' \
  '--work-dir=[directory for temporary IPC files]:dir:_files -/' \
  '(-c --concurrent-tasks)'{-c,--concurrent-tasks}'=[max concurrent tasks]:count' \
  '(-s --task-scheduling-policy)'{-s,--task-scheduling-policy}'=[task scheduling policy]:policy:(pull-staged push-staged)' \
  '--job-data-clean-up-interval-seconds=[interval to clean up old job dirs on the local machine]:seconds' \
  '--job-data-ttl-seconds=[seconds to retain job directories on each worker]:seconds' \
  '--log-dir=[path to save log]:dir:_files -/' \
  '--print-thread-info=[print thread ids and names in log file]:bool:(true false)' \
  '--log-level-setting=[special log level for sub modules]:level' \
  '--log-rotation-policy=[tracing log rotation policy]:policy:(minutely hourly daily never)' \
  '--grpc-server-max-decoding-message-size=[maximum size of decoded gRPC messages]:bytes' \
  '--grpc-server-max-encoding-message-size=[maximum size of encoded gRPC messages]:bytes' \
  '--executor-heartbeat-interval-seconds=[heartbeat interval to scheduler for push-based scheduling]:seconds' \
  '(-m --metrics)'{-m,--metrics}'=[metric collection policy of this executor instance]:policy' \
  '--memory-pool-size=[total executor memory budget e.g. 8GB]:size' \
  '--client-ttl=[seconds an established client connection is cached if unused]:seconds' && ret=0

return ret
