#compdef ca65
# ca65 — assembler for 6502-based systems

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*-D+[define a symbol]:name[=value]:' \
  '*-I+[add include search path]:directory:_directories' \
  '-U+[undefine a symbol]:name:' \
  '-g[add debug info]' \
  '-l+[create listing file]:listing file:_files' \
  '-mm+[set memory model]:model:(near far huge)' \
  '-o+[specify output file]:output file:_files' \
  '-s[enable smart mode]' \
  '-t+[set target system]:target:(apple2 apple2enh atari atarixl atmos c16 c64 c128 cbm510 cbm610 cx16 geos-apple geos-cbm lynx nes none osic1p pce pet plus4 sim6502 sim65c02 supervision vic20)' \
  '-v[increase verbosity]' \
  '--cpu=[set CPU type]:cpu:(6502 65c02 65sc02 65816 huc6280 4510)' \
  '--auto-import[auto-import undefined symbols]' \
  '--feature=[enable an emulation feature]:feature:(at_in_identifiers c_comments dollar_in_identifiers dollar_is_pc force_range labels_without_colons leading_dot_in_identifiers long_jsr_jmp_bug loose_char_term loose_string_term missing_char_term org_per_seg pc_assignment underline_in_numbers)' \
  '--forget-inc-paths[forget include paths]' \
  '--listing=[create listing file]:listing file:_files' \
  '--list-bytes=[set max bytes per listing line]:count:' \
  '--create-dep=[create dependency file]:dep file:_files' \
  '--debug-info[add debug info]' \
  '--bin-include-dir=[add binary include path]:directory:_directories' \
  '--include-dir=[add include search path]:directory:_directories' \
  '*:assembly source file:_files -g "*.(s|asm)(-.)"' && ret=0

return ret
