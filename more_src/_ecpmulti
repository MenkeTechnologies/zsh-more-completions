#compdef ecpmulti
# _ecpmulti — Project Trellis ecpmulti CLI assembling multiple ECP5 bitstream images into a single multi-boot dual-boot image with offset alignment headers for redundant fallback FPGA configurations on Lattice ECP5 SPI flash (David Shah team, C++); custom argparse
# upstream: https://github.com/YosysHQ/prjtrellis

_ecpmulti() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "*.bit"' \
        '-a+[alignment bytes]:n:' \
        '-p+[primary boot]:n:(0 1 2 3)' \
        '--idcode=+[idcode]:str:' \
        '--idcode-check[verify idcode]' \
        '--no-bram-init[skip bram init]' \
        '*:bit file:_files -g "*.bit"'
}

_ecpmulti "$@"
