#compdef hardour
# Documentation: https://github.com/Ardour/ardour/blob/master/headless/load_session.cc
# Headless Ardour: load and run an Ardour session without a GUI

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-h --help)'{-h,--help}'[print this message]' \
  '(-c --name)'{-c,--name}'[use a specific backend client name (default ardour)]:client name' \
  '(-B --bypass-plugins)'{-B,--bypass-plugins}'[bypass plugins]' \
  '(-d --disable-plugins)'{-d,--disable-plugins}'[disable all plugins in an existing session]' \
  '(-D --debug)'{-D,--debug}'[set debug flags (use -D list to see options)]:debug flags' \
  '(-O --no-hw-optimizations)'{-O,--no-hw-optimizations}'[disable h/w specific optimizations]' \
  '(-P --no-connect-ports)'{-P,--no-connect-ports}'[do not connect any ports at startup]' \
  '1:session directory:_files -/' \
  '2:snapshot name:_files' && ret=0

return ret
