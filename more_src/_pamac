#compdef pamac

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'search:search for packages'
      'list:list packages'
      'info:show package details'
      'install:install packages'
      'reinstall:reinstall packages'
      'remove:remove packages'
      'checkupdates:check for updates'
      'update:update the system'
      'upgrade:upgrade the system'
      'clone:clone or sync AUR packages build files'
      'build:build packages from AUR or local files'
      'clean:clean package cache'
    )
    _describe -t commands 'pamac command' commands
    ;;
  args)
    case $words[1] in
      search)
        _arguments -s -S \
          '(-a --aur)'{-a,--aur}'[search in AUR]' \
          '--repos[search only in repositories]' \
          '--installed[search only installed packages]' \
          '--files[search for packages that own specified files]' \
          '(-q --quiet)'{-q,--quiet}'[only print names]' \
          '--no-aur[do not search in AUR]' \
          '*:search term:' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-i --installed)'{-i,--installed}'[list installed packages]' \
          '--explicitly-installed[list explicitly installed packages]' \
          '--orphans[list orphan packages]' \
          '--foreign[list foreign packages]' \
          '--repos[list repo packages]' \
          '--groups[list package groups]' \
          '--files[list package files]' \
          '(-q --quiet)'{-q,--quiet}'[only print names]' \
          '*:package:' && ret=0
        ;;
      info)
        _arguments -s -S \
          '(-a --aur)'{-a,--aur}'[also search in AUR]' \
          '--no-aur[do not search in AUR]' \
          '*:package:' && ret=0
        ;;
      install)
        _arguments -s -S \
          '--as-deps[mark packages as dependencies]' \
          '--as-explicit[mark packages as explicitly installed]' \
          '-d[only download, do not install]' \
          '--download-only[only download, do not install]' \
          '--dry-run[simulate the install]' \
          '--no-confirm[do not ask for confirmation]' \
          '--no-upgrade[do not check for updates]' \
          '--overwrite=[overwrite conflicting files]:glob' \
          '*:package:_files' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '-o[also remove orphaned dependencies]' \
          '--orphans[also remove orphaned dependencies]' \
          '-n[also remove config files]' \
          '--no-save[also remove config files]' \
          '--no-confirm[do not ask for confirmation]' \
          '--dry-run[simulate the removal]' \
          '--unneeded[only remove packages that are not required]' \
          '*:package:' && ret=0
        ;;
      update|upgrade)
        _arguments -s -S \
          '(-a --aur)'{-a,--aur}'[also upgrade AUR packages]' \
          '--no-aur[do not upgrade AUR packages]' \
          '--force-refresh[force refresh of databases]' \
          '--enable-downgrade[enable package downgrade]' \
          '--download-only[only download, do not install]' \
          '--no-confirm[do not ask for confirmation]' \
          '--overwrite=[overwrite conflicting files]:glob' \
          '--devel[also check development packages]' \
          '--builddir=[build directory]:dir:_directories' && ret=0
        ;;
      checkupdates)
        _arguments -s -S \
          '(-a --aur)'{-a,--aur}'[also check AUR]' \
          '--no-aur[do not check AUR]' \
          '--devel[also check development packages]' \
          '(-q --quiet)'{-q,--quiet}'[only print names]' \
          '--builddir=[build directory]:dir:_directories' && ret=0
        ;;
      clone)
        _arguments -s -S \
          '--builddir=[build directory]:dir:_directories' \
          '--recurse[also clone dependencies]' \
          '--overwrite[overwrite existing files]' \
          '*:package:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--builddir=[build directory]:dir:_directories' \
          '--no-confirm[do not ask for confirmation]' \
          '--no-clone[do not clone build files]' \
          '--no-keep[do not keep built packages]' \
          '--dry-run[simulate the build]' \
          '*:package:_files' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '--build-files[also remove build files]' \
          '-k[number of old versions to keep]:number' \
          '--keep=[number of old versions to keep]:number' \
          '--uninstalled[only remove cache for uninstalled packages]' \
          '--no-confirm[do not ask for confirmation]' \
          '--dry-run[simulate the clean]' && ret=0
        ;;
    esac
    ;;
esac

return ret