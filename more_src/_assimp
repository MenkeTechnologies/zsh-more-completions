#compdef assimp

local -a subcmds

subcmds=(
    'dump:Convert model to assbin/assxml'
    'export:Export a model to a specific format'
    'extract:Extract embedded textures'
    'info:Show model info'
    'listext:List supported file extensions'
    'listexport:List supported export formats'
    'knowext:Check if an extension is known'
    'version:Show version'
    'help:Show help'
    'cmpdump:Compare two dump files'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'assimp subcommand' subcmds
        ;;
    options)
        case $words[1] in
            dump)
                _arguments \
                    '-b[Binary output]' \
                    '-s[Short format]' \
                    '-z[Compressed output]' \
                    '--log=[Log file]:log file:_files' \
                    '1:input file:_files' \
                    '2:output file:_files'
                ;;
            export)
                _arguments \
                    '-f[Output format]:format' \
                    '--log=[Log file]:log file:_files' \
                    '1:input file:_files' \
                    '2:output file:_files'
                ;;
            extract)
                _arguments \
                    '-t[Texture index]:index' \
                    '-ba[Extract all textures as BMP]' \
                    '-s[No output on stdout]' \
                    '--log=[Log file]:log file:_files' \
                    '1:input file:_files' \
                    '2:output directory:_directories'
                ;;
            info)
                _arguments \
                    '-r[Raw mode]' \
                    '-v[Verbose output]' \
                    '--log=[Log file]:log file:_files' \
                    '1:input file:_files'
                ;;
            knowext)
                _arguments '1:extension'
                ;;
            cmpdump)
                _arguments \
                    '1:first dump file:_files' \
                    '2:second dump file:_files'
                ;;
        esac
        ;;
esac
