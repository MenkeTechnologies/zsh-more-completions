#compdef yices yices2 yices-smt yices-smt2 yices-sat
# Documentation: https://github.com/SRI-CSL/yices2
# Reference accessed: 2026-05-21
# Verified: upstream sources src/frontend/yices/yices_reval.c, yices_smt.c,
# yices_smt2.c, yices_sat.c.

local curcontext="$curcontext" state line ret=1

case $service in
  (yices|yices2)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:n:' \
      '--logic=[set SMT logic]:logic:' \
      '--arith-solver=[arithmetic solver]:solver:(simplex floyd-warshall auto)' \
      '--mode=[usage mode]:mode:(one-shot multi-checks push-pop interactive ef)' \
      '--mcsat[enable MC-SAT solver]' \
      '--print-success[print ok after silent commands]' \
      '--abort-on-int[exit on SIGINT]' \
      '*:input file:_files' && ret=0 ;;
  (yices-smt2)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbosity)'{-v+,--verbosity=}'[verbosity]:n:' \
      '(-s --stats)'{-s,--stats}'[print stats]' \
      '(-t --timeout)'{-t+,--timeout=}'[timeout (seconds)]:s:' \
      '(-n --nthreads)'{-n+,--nthreads=}'[thread count]:n:' \
      '--incremental[enable push/pop support]' \
      '--interactive[interactive mode]' \
      '--yices-model-format[use Yices model format]' \
      '--dump-models[display models on SAT results]' \
      '--bvconst-in-decimal[bit-vector constants in decimal]' \
      '--mcsat[enable MCSat solver]' \
      '*:input file:_files -g "*.smt2"' && ret=0 ;;
  (yices-smt)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-t --timeout)'{-t+,--timeout=}'[timeout (seconds)]:s:' \
      '--var-elim[apply variable elimination]' \
      '--flatten[flatten OR and disequality terms]' \
      '--learn-eq[learn UF equalities]' \
      '--break-symmetries[break symmetries in UF]' \
      '--arith-elim[eliminate arithmetic variables]' \
      '--bvarith-elim[simplify bitvector arithmetic]' \
      '--keep-ite[retain if-then-else in egraph]' \
      '--show-model[print model if SAT]' \
      '--dump[dump solver state after internalization]' \
      '--simplex[use Simplex solver]' \
      '--floyd-warshall[use IDL/RDL Floyd-Warshall solver]' \
      '--random-seed=[PRNG seed]:n:' \
      '*:input file:_files -g "*.smt"' && ret=0 ;;
  (yices-sat)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbose)'{-v,--verbose}'[print statistics during search]' \
      '(-m --model)'{-m,--model}'[show model if SAT]' \
      '(-s --seed)'{-s+,--seed=}'[random seed]:n:' \
      '--stats[print statistics at end]' \
      '*:CNF file:_files -g "*.(cnf|dimacs)"' && ret=0 ;;
esac

return ret
