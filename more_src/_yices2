#compdef yices yices2 yices-smt yices-smt2 yices-sat

local curcontext="$curcontext" state line ret=1

case $service in
  (yices|yices2)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbosity)'{-v+,--verbosity=}'[verbosity]:n:' \
      '(-l --logic)'{-l+,--logic=}'[set logic]:logic:(QF_BV QF_LIA QF_LRA QF_NIA QF_NRA QF_UF QF_UFLIA QF_UFLRA QF_UFBV QF_UFNIA QF_AUFLIA QF_AUFBV QF_AX BV LIA LRA UFLIA UFLRA UF AUFLIA AUFLIRA AUFNIRA)' \
      '(-m --mode)'{-m+,--mode=}'[mode]:m:(one-shot multi-checks interactive push-pop)' \
      '(-t --print-success)'{-t,--print-success}'[print success]' \
      '*: :_files -g "*.smt *.smt2 *.ys"' && ret=0 ;;
  (yices-smt|yices-smt2)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbosity)'{-v+,--verbosity=}'[verbosity]:n:' \
      '(-i --incremental)'{-i,--incremental}'[incremental mode]' \
      '(-s --stats)'{-s,--stats}'[print stats]' \
      '(-t --timeout)'{-t+,--timeout=}'[timeout sec]:s:' \
      '(--smt2-model-format)--smt2-model-format[SMT2 model format]' \
      '(--bvconst-in-decimal)--bvconst-in-decimal[decimal bvconst]' \
      '*: :_files -g "*.smt *.smt2"' && ret=0 ;;
  (yices-sat)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-v --verbosity)'{-v+,--verbosity=}'[verbosity]:n:' \
      '(-m --model)'{-m,--model}'[print model]' \
      '(-s --seed)'{-s+,--seed=}'[seed]:n:' \
      '(-r --restart-interval)'{-r+,--restart-interval=}'[restart]:n:' \
      '*: :_files -g "*.cnf *.dimacs"' && ret=0 ;;
esac

return ret
