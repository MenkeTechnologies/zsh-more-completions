#compdef intelp2m
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/intelp2m/main.go
# coreboot Intel pad config to macro converter

local ret=1

_arguments -s -S \
  '-file[path to the inteltool log file]:file:_files' \
  '-o[path to the generated GPIO config file]:file:_files' \
  '-ign[exclude fields that should be ignored from advanced macros]' \
  '-n[generate macros without checking]' \
  '-i[show pads function in the comments]' \
  '-ii[show DW0/DW1 value in the comments]' \
  '-iii[show ignored bit fields in the comments]' \
  '-iiii[show target PAD_CFG() macro in the comments]' \
  '-t[template type (0 log, 1 gpio.h, 2 custom)]:type:(0 1 2)' \
  '-p[platform]:platform:(snr lbg apl cnl adl jsl)' \
  '-fld[bit fields macros style]:style:(none cb fsp raw)' && ret=0

return ret
