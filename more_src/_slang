#compdef slang
# Documentation: https://sv-lang.com/command-line-ref.html
# slang SystemVerilog compiler and language services

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help text and exit]' \
  '--version[show slang version information]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '--std=[set language version]:standard:(1364-2005 1800-2017 1800-2023 latest)' \
  '--single-unit[treat all input files as one compilation unit]' \
  '*'{-j,--threads}'=[control parallel compilation thread count]:threads:' \
  '*'{-I,--include-directory}'=[add directory for quoted includes]:dir:_files -/' \
  '*--isystem=[add directory for angle-bracket includes]:dir:_files -/' \
  '*'{-D,--define-macro}'=[define preprocessor macro]:macro:' \
  '*'{-U,--undefine-macro}'=[undefine macro]:macro:' \
  '*'{-v,--libfile}'=[add Verilog source library file]:file:_files' \
  '*'{-y,--libdir}'=[search directory for module instantiations]:dir:_files -/' \
  '*--libext=[specify library file extension]:ext:' \
  '*'{-f,-F}'=[process command file]:file:_files' \
  '*--top=[specify top-level module name]:module:' \
  '*-L+[set library search order]:library:' \
  '*-G+[override parameter value]:param:' \
  '--max-hierarchy-depth=[limit design hierarchy nesting]:depth:' \
  '--lint-only[perform linting without elaboration]' \
  '--parse-only[parse files without type checking]' \
  '--ast-json=[dump AST in JSON format]:file:_files' \
  '--error-limit=[cap error message output]:limit:' \
  '-Werror[treat warnings as errors]' \
  '*:source file:_files' && ret=0

return ret
