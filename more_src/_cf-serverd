#compdef cf-serverd
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-serverd.html
# Source: cfengine/core cf-serverd/cf-serverd-functions.c — CFEngine policy/file server daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-f --file)'{-f+,--file=}'[alternative input file]:file:_files' \
    '(-D --define)'{-D+,--define=}'[define classes at startup]:classes:_default' \
    '(-N --negate)'{-N+,--negate=}'[undefine classes at startup]:classes:_default' \
    '(-K --no-lock)'{-K,--no-lock}'[ignore locking constraints]' \
    '(-I --inform)'{-I,--inform}'[print basic info about system changes]' \
    '(-x --diagnostic)'{-x,--diagnostic}'[internal diagnostics (devs)]' \
    '(-F --no-fork)'{-F,--no-fork}'[run in foreground]' \
    '(-L --ld-library-path)'{-L+,--ld-library-path=}'[LD_LIBRARY_PATH for child processes]:path:_default' \
    '(-A --generate-avahi-conf)'{-A,--generate-avahi-conf}'[generate avahi discovery config]' \
    '(-C --color)'{-C+,--color=}'[colorized output]:when:(always auto never)' \
    '(-l --timestamp)'{-l,--timestamp}'[log timestamps]' \
    '(-t --graceful-detach)'{-t+,--graceful-detach=}'[seconds to wait before terminating on SIGHUP]:seconds:_default' \
    '--ignore-preferred-augments[skip def_preferred.json]' \
    && ret=0

return ret
