#compdef verged
# _verged — Verge Currency verged daemon CLI for the privacy-focused Tor-i2p multi-algo Scrypt X17 Lyra2REv2 myr-groestl Blake2s fork of Bitcoin running a full node maintaining the blockchain validating transactions wallet network sync RPC (vergecurrency team, C++); custom argparse
# upstream: https://github.com/vergecurrency/verge

_verged() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf verge.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-daemon[run as daemon]' \
        '-pid=+[file]:file:_files' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb tor i2p all)' \
        '-logips[log IPs]' \
        '-logtimestamps[log timestamps]' \
        '-shrinkdebugfile[shrink debug]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserver[enable RPC server]' \
        '-rpcwait[wait for RPC server]' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-i2psam=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-maxconnections=+[N]:n:' \
        '-paytxfee=+[XVG/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[file]:file:_files' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:'
}

_verged "$@"
