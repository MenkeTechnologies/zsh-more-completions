#compdef qgis_process
# Documentation: https://github.com/qgis/QGIS/blob/master/src/process/qgsprocess.cpp
# Documentation: https://github.com/qgis/QGIS/blob/master/src/process/main.cpp
# Reference accessed: 2026-05-27
# Verified: upstream src/process/qgsprocess.cpp showUsage and command dispatch

# Zsh completion for qgis_process (QGIS headless processing CLI)

local curcontext="$curcontext" state line ret=1

local -a _qgis_process_subcommands
_qgis_process_subcommands=(
  'plugins:list available and active plugins or enable/disable a plugin'
  'list:list all available processing algorithms'
  'help:show help for an algorithm'
  'run:run an algorithm by id or model file with PARAMETER=VALUE pairs after --'
)

_arguments -C \
  '(- *)'{-h,--help}'[output the help]' \
  '(- *)'{-v,--version}'[output all versions related to QGIS Process]' \
  '--json[output results as JSON objects]' \
  '--verbose[output verbose logs]' \
  '--no-python[disable Python support (faster startup)]' \
  '--skip-loading-plugins[avoid loading enabled plugins (faster startup)]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'qgis_process subcommand' _qgis_process_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      plugins)
        local -a _plugin_actions
        _plugin_actions=(
          'list:list installed plugins'
          'enable:enable an installed plugin'
          'disable:disable an installed plugin'
        )
        _arguments \
          '1: :{_describe -t plugin-actions "plugin action" _plugin_actions}' \
          '2:plugin name:' && ret=0
        ;;
      list)
        _message 'no more arguments' && ret=0
        ;;
      help)
        _arguments '1:algorithm id or model file:_files' && ret=0
        ;;
      run)
        _arguments \
          '1:algorithm id, model file, or Python script:_files' \
          '*:parameter (PARAM=VALUE after --):' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
