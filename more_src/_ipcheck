#compdef ipcheck
# Documentation: https://man.archlinux.org/search?q=ipcheck
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d[daemon mode]' \
  '-f+[config file]:file:_files' \
  '-i+[interface]:iface:' \
  '-l[print local IP only]' \
  '-r+[server]:srv:' \
  '-v[verbose]' \
  '-w+[wait sec]:sec:' \
  '*:hostname:_hosts' && ret=0

return ret
