#compdef rustywind
# Documentation: https://man.archlinux.org/search?q=rustywind
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--write[write changes to files]' \
  '--check-formatted[check if files are already formatted]' \
  '--allow-duplicates[allow duplicate classes]' \
  '--config-file=[path to config file]:config file:_files' \
  '--output=[output format]:format:(standard silent)' \
  '--stdin[read from stdin]' \
  '--quiet[suppress output]' \
  '*:file or directory:_files' && ret=0

return ret
