#compdef pcb-rnd

# pcb-rnd: fork of gEDA PCB with extensive plugin system
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '--copyright[show copyright]' \
  '-c[load config from file]:file:_files' \
  '-x[export hook (e.g. png, ps, gerber, eagle, kicad-legacy)]:hook:(png ps gerber gerber-rs274x bom xy dsn dxf eagle eagle-xml kicad-legacy kicad kicad-pro mucs ipcd356 svg openscad)' \
  '--gui[force GUI mode]:gui:(gtk2 gtk4 lesstif batch)' \
  '-d[set debug flag]:flag:' \
  '*:PCB file:_files -g "*.(pcb|lht|pcb.gz|lht.gz)"' && ret=0
return ret
