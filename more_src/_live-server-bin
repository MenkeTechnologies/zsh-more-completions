#compdef live-server
# _live-server-bin — live-server Node.js dev server with live reload (Tapio Vierros); auto-reloads on file changes
# upstream: https://github.com/tapio/live-server

_live-server-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--port=+[port]:port:' \
        '--host=+[host]:host:_hosts' \
        '--no-browser[do not open browser]' \
        '--browser=+[browser]:browser:(chrome firefox safari opera)' \
        '--quiet[suppress logging]' \
        '-q[quiet]' \
        '--open=+[open URL or path]:url:' \
        '-o+[open URL or path]:url:' \
        '--watch=+[paths to watch]:paths:' \
        '--ignore=+[ignore glob]:glob:' \
        '--ignorePattern=+[ignore regex]:regex:' \
        '--no-css-inject[disable CSS injection]' \
        '--entry-file=+[default file]:file:_files' \
        '--mount=+[mount path:dir]:str:' \
        '--spa[SPA mode]' \
        '--wait=+[ms delay before reload]:n:' \
        '--htpasswd=+[htpasswd file]:file:_files' \
        '--cors[enable CORS]' \
        '--https=+[https config json]:file:_files' \
        '--https-module=+[https module]:module:' \
        '--proxy=+[proxy url]:url:_urls' \
        '--middleware=+[middleware file]:file:_files' \
        '*:dir:_files -/'
}

_live-server-bin "$@"
