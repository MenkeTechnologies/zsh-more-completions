#compdef krb5-send-pr send-pr
# Documentation: https://man.archlinux.org/search?q=krb5-send-pr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-f+[file containing report]:file:_files' \
  '-L[print categories list]' \
  '-P+[problem report email]:email:' \
  '-s[severity]' \
  '-v[show version]' && ret=0

return ret
