#compdef krb5-send-pr send-pr
# Documentation: https://web.mit.edu/kerberos/krb5-latest/doc/
# Reference accessed: 2026-05-19
# Verified: MIT Kerberos send-pr option descriptions. Corrected:
# removed bogus -h; -L prints the PR form (not a category list);
# -P is a flag (request submitter-id) not an email arg; -s takes
# a severity argument; version flag is -V not lowercase -v.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-f+[file containing a complete problem report (- for stdin)]:file:_files' \
  '-t+[send the problem report to address]:address:' \
  '-c+[CC the problem report to address]:address:' \
  '-s+[give the problem report the given severity]:severity:' \
  '-L[print the blank PR form on standard output, no mail sent]' \
  '-P[request a submitter-id from the support site]' \
  '-b[batch mode, do not require confirmation]' \
  '--request-id[request a problem report number from the support site]' \
  '(- *)-V[display the krb5-send-pr version number]' && ret=0

return ret
