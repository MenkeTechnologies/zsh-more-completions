#compdef rnostr
# Documentation: https://github.com/rnostr/rnostr
# Source: rnostr/rnostr — Rust scalable Nostr relay.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rn_cmds
_rn_cmds=(
    'import:import data from a jsonl file'
    'export:export data to a jsonl file'
    'bench:benchmark a filter'
    'relay:start the Nostr relay server'
    'delete:delete data by filter'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'rnostr command' _rn_cmds && ret=0
        ;;
    args)
        case $line[1] in
            relay)
                _arguments -s -S \
                    '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(toml|yaml|yml|json)"' \
                    '--watch[hot reload on config changes]' \
                    && ret=0
                ;;
            import|export)
                _arguments -s -S \
                    '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
                    '*:jsonl file:_files -g "*.(jsonl|json)"' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
