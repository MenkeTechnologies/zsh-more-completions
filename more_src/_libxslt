#compdef xsltproc libxslt libxslt-tools
# _libxslt — Daniel Veillard libxslt GNOME XSLT C library xsltproc command-line XSLT processor (GNOME team, C); getopt
# upstream: https://github.com/GNOME/libxslt

_libxslt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--timing[print timing]' \
        '--repeat[repeat 20x]' \
        '--debug[debug]' \
        '--dumpextensions[dump extensions]' \
        '--novalid[skip DTD validation]' \
        '--nonet[refuse network access]' \
        '--noout[no output]' \
        '--maxdepth=+[N]:n:' \
        '--maxvars=+[N]:n:' \
        '--maxparserdepth=+[N]:n:' \
        '--seed-rand=+[N]:n:' \
        '--huge[relax parser limits]' \
        '--load-trace[print loaded files]' \
        '--encoding=+[encoding]:e:(utf-8 iso-8859-1 utf-16 us-ascii)' \
        '--catalogs[use SGML catalogs]' \
        '--xinclude[XInclude]' \
        '--profile[profile]' \
        '--norman[skip normalization]' \
        '--nodtdattr[skip default DTD attr]' \
        '--stringparam+[name value]:str:' \
        '--param+[name value]:str:' \
        '--path=+[path list]:str:' \
        '--html[input is HTML]' \
        '--xinclude[XInclude]' \
        '*:files:_files -g "*.xsl *.xslt *.xml *.html *.htm"'
}

_libxslt "$@"
