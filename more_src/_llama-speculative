#compdef llama-speculative
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/examples/speculative/speculative.cpp
# Reference accessed: 2026-05-27
# Verified: upstream common_params_parse with LLAMA_EXAMPLE_SPECULATIVE in common/arg.cpp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-m --model)'{-m+,--model=}'[model path]:model file:_files -g "*.gguf"' \
  '-mu+[model download URL]:url' \
  '--model-url=[model download URL]:url' \
  '-hf+[Hugging Face model repo]:repo' \
  '--hf-repo=[Hugging Face model repo]:repo' \
  '--hf-file=[Hugging Face model file]:file' \
  '(-md --model-draft --spec-draft-model)'{-md+,--model-draft=,--spec-draft-model=}'[draft model for speculative decoding]:model file:_files -g "*.gguf"' \
  '(-hfd -hfrd --hf-repo-draft --spec-draft-hf)'{-hfd+,-hfrd+,--hf-repo-draft=,--spec-draft-hf=}'[Hugging Face draft model repo]:repo' \
  '(-td --threads-draft --spec-draft-threads)'{-td+,--threads-draft=,--spec-draft-threads=}'[number of threads for draft model]:threads' \
  '(-tbd --threads-batch-draft --spec-draft-threads-batch)'{-tbd+,--threads-batch-draft=,--spec-draft-threads-batch=}'[number of threads for draft batch processing]:threads' \
  '(-ngld --gpu-layers-draft --n-gpu-layers-draft --spec-draft-ngl)'{-ngld+,--gpu-layers-draft=,--n-gpu-layers-draft=,--spec-draft-ngl=}'[number of draft model layers to store in VRAM]:layers' \
  '(-devd --device-draft --spec-draft-device)'{-devd+,--device-draft=,--spec-draft-device=}'[comma-separated list of devices for draft model]:devices' \
  '(-ctkd --cache-type-k-draft --spec-draft-type-k)'{-ctkd+,--cache-type-k-draft=,--spec-draft-type-k=}'[KV cache data type for K for draft model]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1 iq4_nl)' \
  '(-ctvd --cache-type-v-draft --spec-draft-type-v)'{-ctvd+,--cache-type-v-draft=,--spec-draft-type-v=}'[KV cache data type for V for draft model]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1 iq4_nl)' \
  '--spec-draft-n-max=[max number of tokens to draft for speculative decoding]:n' \
  '--spec-draft-n-min=[min number of draft tokens to use for speculative decoding]:n' \
  '(--spec-draft-p-split --draft-p-split)'{--spec-draft-p-split=,--draft-p-split=}'[speculative decoding split probability]:p' \
  '(--spec-draft-p-min --draft-p-min)'{--spec-draft-p-min=,--draft-p-min=}'[minimum speculative decoding probability (greedy)]:p' \
  '--spec-type=[comma-separated list of speculative decoding types]:types' \
  '-np+[number of parallel sequences to decode]:slots' \
  '--parallel=[number of parallel sequences to decode]:slots' \
  '-p+[prompt text]:prompt' \
  '--prompt=[prompt text]:prompt' \
  '-f+[read prompt from file]:prompt file:_files' \
  '--file=[read prompt from file]:prompt file:_files' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-b+[logical batch size]:size' \
  '--batch-size=[logical batch size]:size' \
  '-ub+[physical batch size]:size' \
  '--ubatch-size=[physical batch size]:size' \
  '-n+[number of tokens to predict]:count' \
  '--predict=[number of tokens to predict]:count' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:threads' \
  '(-tb --threads-batch)'{-tb+,--threads-batch=}'[number of threads for batch processing]:threads' \
  '-s+[RNG seed]:seed' \
  '--seed=[RNG seed]:seed' \
  '--temp=[temperature]:temperature' \
  '--top-k=[top-k sampling]:k' \
  '--top-p=[top-p sampling]:p' \
  '--min-p=[min-p sampling]:p' \
  '--repeat-penalty=[repetition penalty]:penalty' \
  '--color[colorize output]' \
  '-ngl+[number of layers to offload to GPU]:layers' \
  '--gpu-layers=[number of layers to offload to GPU]:layers' \
  '-sm+[how to split the model across GPUs]:mode:(none layer row)' \
  '--split-mode=[how to split the model across GPUs]:mode:(none layer row)' \
  '-mg+[main GPU index]:GPU index' \
  '--main-gpu=[main GPU index]:GPU index' \
  '--tensor-split=[tensor split ratios across GPUs]:split' \
  '-dev+[comma-separated list of devices]:devices' \
  '--device=[comma-separated list of devices]:devices' \
  '--list-devices[print list of available devices and exit]' \
  '--rpc=[comma-separated list of RPC servers]:servers' \
  '-fa+[enable flash attention]:mode:(on off auto)' \
  '--flash-attn=[enable flash attention]:mode:(on off auto)' \
  '--mlock[force system to keep model in RAM]' \
  '--no-mmap[do not memory-map model]' \
  '--numa=[NUMA optimization]:strategy:(distribute isolate numactl)' \
  '--rope-scaling=[RoPE scaling type]:type:(none linear yarn)' \
  '--rope-freq-base=[RoPE base frequency]:freq' \
  '--rope-freq-scale=[RoPE frequency scaling factor]:scale' \
  '--cache-type-k=[KV cache data type for K]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1 iq4_nl)' \
  '--cache-type-v=[KV cache data type for V]:type:(f16 f32 q8_0 q4_0 q4_1 q5_0 q5_1 iq4_nl)' \
  '-nkvo[disable KV cache offloading]' \
  '--no-kv-offload[disable KV cache offloading]' \
  '--lora=[apply LoRA adapter]:lora file:_files -g "*.gguf"' \
  '--lora-scaled=[apply LoRA adapter with user-defined scaling]:lora file' \
  '--log-disable[disable logging]' \
  '--log-file=[log to file]:log file:_files' \
  '--log-colors=[colored logging]:mode:(on off auto)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' && ret=0

return ret
