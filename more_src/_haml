#compdef haml

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'render:render a haml template'
  'compile:show compile result'
  'temple:show Temple intermediate'
  'parse:show parse result'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '--escape-html[escape HTML]' \
  '--no-escape-html[no escape HTML]' \
  '--escape-attrs[escape attrs]' \
  '--no-escape-attrs[no escape attrs]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'haml subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (render)
        _arguments -s \
          '(-I --load-path)'{-I,--load-path}'=[paths]:dirs:' \
          '*'{-r,--require}'=[library]:lib:' \
          '*:file:_files -g "*.haml"' && ret=0 ;;
      (compile)
        _arguments -s \
          '(-a --actionview)'{-a,--actionview}'[ActionView]' \
          '--no-actionview[no ActionView]' \
          '--color[color]' \
          '--no-color[no color]' \
          '(-c --check)'{-c,--check}'[check syntax]' \
          '--no-check[no check]' \
          '*:file:_files -g "*.haml"' && ret=0 ;;
      (temple|parse)
        _arguments -s \
          '--color[color]' \
          '--no-color[no color]' \
          '*:file:_files -g "*.haml"' && ret=0 ;;
      (help) _arguments '*:command:(render compile temple parse version)' && ret=0 ;;
    esac
    ;;
esac

return ret
