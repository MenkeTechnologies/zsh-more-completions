#compdef http-prompt
# Documentation: https://man.archlinux.org/search?q=http-prompt
# Reference accessed: 2026-05-16

# Zsh completion for http-prompt interactive HTTP client

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(--spec)'--spec'[OpenAPI spec]:file:_files' \
  '*:: : _message "http-prompt session flags; see http-prompt --help"' && ret=0

return ret
