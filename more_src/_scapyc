#compdef scapyc
# _scapyc — Scapy scapyc (Python compiler/runner shim for Scapy scripts that wires Scapy's interactive globals into a normal Python program; positional Python script file, -c run inline code, -i interactive after script, -e/--no-pkg disable plugin autoload, -P prefer Python2; supports passing args via -- separator)
# upstream: https://github.com/secdev/scapy
# Flags from Scapy scripts/scapyc on tip.

_scapyc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[run inline code]:code:' \
        '-i[interactive after script]' \
        '-e[disable plugin autoload]' \
        '--no-pkg[disable plugin autoload]' \
        '-P[prefer Python 2]' \
        '*:script and args:_files -g "*.py"'
}

_scapyc "$@"
