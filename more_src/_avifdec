#compdef avifdec
# Documentation: avifdec --help (libavif 1.4.2)
# Source: AVIF image decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-j --jobs)'{-j+,--jobs=}'[worker threads or all]:jobs:' \
    '(-c --codec)'{-c+,--codec=}'[codec to use]:codec:(aom dav1d)' \
    '(-d --depth)'{-d+,--depth=}'[output depth]:depth:(8 16)' \
    '--sato[enable Sample Transforms decoding]' \
    '(-q --quality)'{-q+,--quality=}'[JPEG output quality 0..100]:q:' \
    '--png-compress=[PNG compression 0..9]:level:' \
    '(-u --upsampling)'{-u+,--upsampling=}'[chroma upsampling]:algo:(automatic fastest best nearest bilinear)' \
    '(-r --raw-color)'{-r,--raw-color}'[output raw RGB instead of premultiplied]' \
    '--index=[frame index or all]:index:' \
    '--progressive[enable progressive AVIF processing]' \
    '--no-strict[disable strict decoding]' \
    '(-i --info)'{-i,--info}'[decode all frames, print info, do not save]' \
    '--icc=[ICC profile file]:file:_files' \
    '--ignore-icc[ignore embedded ICC profile]' \
    '--size-limit=[max image size in total pixels]:pixels:' \
    '--dimension-limit=[max width/height]:pixels:' \
    '1:input avif:_files -g "*.avif"' \
    '2:output image:_files' \
    && ret=0

return ret
