#compdef ghi
# Documentation: https://github.com/stephencelis/ghi
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list issues'
  'show:show an issue'
  'open:open (create or reopen) an issue'
  'close:close an issue'
  'lock:restrict issue conversation to collaborators'
  'unlock:remove conversation restrictions'
  'edit:edit an existing issue'
  'comment:add a comment to an issue'
  'label:manage labels'
  'assign:set an issue assignee'
  'milestone:manage milestones'
  'status:check if issues are enabled'
  'enable:enable issues for the repo'
  'disable:disable issues for the repo'
)

_arguments -C \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '(-p --paginate --no-pager)'{-p,--paginate}'[paginate output]' \
  '(-p --paginate --no-pager)--no-pager[disable pager]' \
  '--[<user>/]<repo>=[target repository]:repo:' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  (cmds)
    _describe -t commands 'ghi command' commands && ret=0
    ;;
  (args)
    _default && ret=0
    ;;
esac

return ret
