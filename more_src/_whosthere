#compdef whosthere
# Documentation: https://github.com/ramonvermeulen/whosthere
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for whosthere - LAN discovery TUI

local curcontext="$curcontext" state line ret=1

local -a _wt_cmds
_wt_cmds=(
  'scan:perform a single scan and output results'
  'daemon:run as a background service with HTTP API'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--config=[path to custom configuration file]:file:_files' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'whosthere command' _wt_cmds && ret=0
    ;;
  args)
    case $words[1] in
      scan)
        _arguments \
          '(-t --timeout)'{-t,--timeout}'[maximum timeout for each scan in seconds]:seconds' \
          '--json[output results in JSON format]' \
          '--pretty[format JSON output with indentation]' && ret=0
        ;;
      daemon)
        _arguments \
          '--port=[HTTP API port]:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
