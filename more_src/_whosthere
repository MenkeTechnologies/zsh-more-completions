#compdef whosthere
# Documentation: https://man.archlinux.org/search?q=whosthere
# Reference accessed: 2026-05-16

# Zsh completion for whosthere — LAN discovery TUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-i --interface)'{-i,--interface}'[network interface]:iface' && ret=0

return ret
