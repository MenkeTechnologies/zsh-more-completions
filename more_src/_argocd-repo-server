#compdef argocd-repo-server
# Documentation: https://argo-cd.readthedocs.io/en/stable/operator-manual/server-commands/argocd-repo-server/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# argocd-repo-server: manifest generation server for Argo CD
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--loglevel=[log level]:level:(debug info warn error)' \
  '--logformat=[log format]:fmt:(text json)' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--namespace=[namespace]:ns:' \
  '--metrics-port=[metrics port]:port:' \
  '--metrics-host=[metrics host]:host:' \
  '--port=[port]:port:' \
  '--address=[bind address]:addr:' \
  '--repo-server=[repo server addr]:addr:' \
  '--redis=[redis address]:addr:' \
  '--redis-ca-certificate=[redis CA cert]:file:_files' \
  '--insecure[allow insecure connections]' \
  '--basehref=[UI base href]:path:' \
  '--rootpath=[UI root path]:path:' \
  '--repo-server-timeout-seconds=[repo server timeout]:s:' \
  '--application-namespaces=[application namespaces]:list:' \
  '--enable-proxy-extension[enable proxy extension]' \
  '--max-resource-quota=[max resource quota]:n:' \
  '--connection-status-cache-expiration=[cache expiration]:duration:' \
  '--app-state-cache-expiration=[app state cache expiration]:duration:' \
  '--default-cache-expiration=[default cache expiration]:duration:' \
  '--login-attempts-expiration=[login attempts expiration]:duration:' \
  '--login-attempts-window=[login attempts window]:duration:' \
  '--gpg-source=[GPG source]:source:' \
  '--auth-mode=[auth mode]:mode:' \
  '*::argocd-repo-server args:_files' && ret=0
return ret
