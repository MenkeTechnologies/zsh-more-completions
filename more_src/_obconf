#compdef obconf
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/obconf.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--version[display version information and exit]' \
  '--archive=[create theme archive from theme directory]:theme:' \
  '--install=[install theme archive and select it]:file:_files -g "*.obt"' \
  '--config-file=[path to configuration file]:file:_files -g "*.xml"' \
  '--tab=[display the tab NUMBER]:number:' && ret=0

return ret
