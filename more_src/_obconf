#compdef obconf
# Documentation: https://man.archlinux.org/search?q=obconf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--archive=+[archive theme]:file:_files' \
  '--install=+[install theme]:file:_files -g "*.obt"' \
  '--config-file=+[config file]:file:_files -g "*.xml"' \
  '--tab=+[start on tab]:tab:(theme appearance windows mouse desktops dock margins)' && ret=0

return ret
