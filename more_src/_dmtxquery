#compdef dmtxquery
# Documentation: https://man.archlinux.org/search?q=dmtxquery
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --query)'{-q,--query}'+[query type]:type:(version build options)' && ret=0

return ret
