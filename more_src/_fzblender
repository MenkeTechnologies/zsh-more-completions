#compdef fzblender
# GMT supplements/gsfml — produce optimal smooth fit to fracture zone traces

local ret=1

_arguments -s \
  '-D+[save intermediate filtered output]:file:_files' \
  '-E+[apply secondary filter after primary]:opts:_default' \
  '-F+[along-track primary filter type and width]:opts:_default' \
  '-I+[select FZ id]:id:_default' \
  '-Q+[range of quality indices]:range:_default' \
  '-S+[model/data traces to blend with weights]:opts:_default' \
  '-T+[output file name prefix]:prefix:_default' \
  '-Z+[quality index thresholds amp/var/F/width]:opts:_default' \
  '*-V[verbose (stackable)]' \
  '-bo+[binary output format]:format:_default' \
  '-do+[replace NaN output with nodata]:nodata:_default' \
  '-i+[input column selection]:cols:_default' \
  '-o+[output column selection]:cols:_default' \
  '-q+[row/data limits]:limits:_default' \
  '*:input analysis file:_files' \
  && ret=0

return ret
