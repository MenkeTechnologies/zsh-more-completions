#compdef odutil

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'show:show OpenDirectory state'
  'set:set OpenDirectory configuration'
  'reset:reset OpenDirectory state'
)

_arguments -C \
  '1: :->verb' \
  '*::arg:->args' && ret=0

case $state in
  (verb)
    _describe -t verbs 'odutil verb' verbs && ret=0
    ;;
  (args)
    case $line[1] in
      (show)
        _values 'show target' \
          'cache' 'nodes' 'requests' 'connections' 'sessions' \
          'nodenames' 'users' 'statistics' 'all' 'configuration' && ret=0
        ;;
      (set)
        _values 'set target' 'log' 'statistics' 'configuration' && ret=0
        ;;
      (reset)
        _values 'reset target' 'cache' 'statistics' && ret=0
        ;;
    esac
    ;;
esac

return ret
