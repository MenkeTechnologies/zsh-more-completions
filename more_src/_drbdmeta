#compdef drbdmeta
# _drbdmeta — DRBD metadata block tool CLI (LINBIT, C); custom argparse
# upstream: https://github.com/LINBIT/drbd-utils

_drbdmeta() {
    local -a sub=(
        'create-md:create meta data'
        'get-gi:show generation identifiers'
        'show-gi:show GI details'
        'dump-md:dump metadata block'
        'restore-md:restore metadata block'
        'wipe-md:wipe metadata block'
        'outdate:outdate the data set'
        'invalidate:invalidate the data set'
        'set-gi:set generation identifiers'
        'forget-peer:forget peer'
        'check-resize:check if resize required'
        'apply-al:apply activity log'
        'repair-md:repair metadata block'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--force[force]' \
        '-f[force]' \
        '--ignore-sanity-checks[ignore sanity checks]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--peer-max-bio-size=+[peer max bio size]:n:' \
        '--node-id=+[node id]:n:' \
        '--al-stripes=+[al stripes]:n:' \
        '--al-stripe-size-kB=+[al stripe size kB]:n:' \
        '--initialize-bitmap-from-exposed-data-uuid[initialize bitmap from exposed]' \
        '1:minor:' \
        '2:meta-data-index:(internal flex-external)' \
        '3:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drbdmeta subcommand' sub ;;
    esac
}

_drbdmeta "$@"
