#compdef gitops

# Zsh completion for gitops (Weave GitOps CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'check:check prerequisites'
      'completion:generate shell completion'
      'create:create GitOps resources'
      'delete:delete GitOps resources'
      'get:get GitOps resources'
      'logs:show logs for resources'
      'resume:resume suspended resources'
      'suspend:suspend resources'
      'version:show version'
      'beta:beta commands'
    )
    _describe -t commands 'gitops command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      create)
        local -a create_cmds=(
          'dashboard:create a dashboard'
          'helmrelease:create a HelmRelease'
          'kustomization:create a Kustomization'
          'source:create a source'
          'terraform:create a Terraform resource'
        )
        _arguments \
          '--namespace[namespace]:namespace' \
          '--export[export in YAML format]' \
          '1:resource:->create_sub' && ret=0
        case $state in
          create_sub) _describe -t commands 'create subcommand' create_cmds && ret=0 ;;
        esac
        ;;
      get)
        local -a get_cmds=(
          'bcrypt-hash:get a bcrypt hash'
          'helmrelease:get HelmReleases'
          'kustomization:get Kustomizations'
          'source:get sources'
          'terraform:get Terraform resources'
          'templates:get templates'
        )
        _arguments \
          '--namespace[namespace]:namespace' \
          '(-A --all-namespaces)'{-A,--all-namespaces}'[list across all namespaces]' \
          '1:resource:->get_sub' && ret=0
        case $state in
          get_sub) _describe -t commands 'get subcommand' get_cmds && ret=0 ;;
        esac
        ;;
      *)
        _arguments \
          '--namespace[namespace]:namespace' \
          '--kubeconfig[path to kubeconfig]:file:_files' \
          '--endpoint[GitOps endpoint]:url' && ret=0
        ;;
    esac
    ;;
esac

return ret
