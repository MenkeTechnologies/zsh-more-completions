#compdef pmxcfs
# _pmxcfs — Proxmox Server Solutions pmxcfs Proxmox cluster filesystem fuse mount db-replicated /etc/pve daemon (proxmox team, C); custom argparse
# upstream: https://git.proxmox.com/?p=pve-cluster.git

_pmxcfs() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[debug mode]' \
        '--debug[debug mode]' \
        '-f[foreground]' \
        '--foreground[foreground]' \
        '-l[local mode]' \
        '--local[local mode]' \
        '-v[verbose]' \
        '--verbose[verbose]'
}

_pmxcfs "$@"
