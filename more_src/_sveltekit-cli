#compdef sv
# _sveltekit-cli — SvelteKit / Svelte 5 unified scaffold CLI (Svelte team); create / migrate / add / check Svelte projects
# upstream: https://github.com/sveltejs/cli

_sveltekit-cli() {
    local -a sub=(
        'create:scaffold a new project'
        'add:add an integration (typescript, tailwind, prettier, etc.)'
        'check:run svelte-check'
        'migrate:run a migration'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sv subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--template+[project template]:template:(skeleton minimal default)' \
                    '--types+[type checking]:type:(typescript checkjs none)' \
                    '--no-add-ons[skip add-ons]' \
                    '1:project dir:_files -/' ;;
                add) _arguments '*:integration:(tailwindcss eslint prettier playwright vitest storybook drizzle paraglide mdsvex tailwind lucia svelte-add)' ;;
                migrate) _arguments '1:migration:(svelte-5 sveltekit-2 svelte-4 self-closing-tags)' ;;
                check) _arguments \
                    '--watch[watch mode]' \
                    '--tsconfig+[tsconfig]:file:_files' \
                    '--threshold+[threshold]:lvl:(warning error)' \
                    '--workspace+[workspace dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_sveltekit-cli "$@"
