#compdef ssdb-server
# Documentation: https://ideawu.github.io/ssdb-docs/install.html
# SSDB server — a fast NoSQL database, an alternative to Redis

local ret=1

_arguments -s -S \
  '-d[run ssdb-server as a daemon]' \
  '-s+[control the running server]:action:(stop restart)' \
  '1:config file:_files -g "*.conf"' && ret=0

return ret
