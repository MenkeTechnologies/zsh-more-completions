#compdef bomctl
# Documentation: https://man.archlinux.org/search?q=bomctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list SBOMs'
  'fetch:fetch SBOM'
  'push:push SBOM'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--registry=[OCI registry]:url:' \
  '--storage-type=[storage backend]:type:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'bomctl command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      list|fetch|push)
        _arguments '*:args: _default' && ret=0
        ;;
      help)
        _arguments '1:topic: _default' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
