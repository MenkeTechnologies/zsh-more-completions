#compdef mkenvimage
# Documentation: https://man.archlinux.org/search?q=mkenvimage
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-r[redundant environment (two copies)]' \
  '-b[big-endian]' \
  '-p+[pad fill byte]:byte:' \
  '-s+[environment partition size]:size:' \
  '-o+[output file]:file:_files' \
  ':input:_files'
