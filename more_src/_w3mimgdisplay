#compdef w3mimgdisplay
# Documentation: https://github.com/tats/w3m/blob/master/w3mimgdisplay.c
# Reference accessed: 2026-05-16
# Verified: upstream tats/w3m w3mimgdisplay.c. Reads pixel-draw
# commands from stdin (protocol: 0=draw, 1=redraw, 2=terminate,
# 3=sync, 4=nop, 5=get size, 6=clear).
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# w3mimgdisplay: w3m helper for inline image display
local curcontext="$curcontext" ret=1
_arguments -C \
  '-test[test mode]' \
  '-size[print image size]:file:_files' \
  '-anim[animation count]:n:' \
  '-bg[background color]:color:' \
  '-x[x offset]:x:' \
  '-y[y offset]:y:' && ret=0
return ret
