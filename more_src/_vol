  'vmscan.Vmscan:VM scan'
  'yarascan.YaraScan:yara scan'
  'windows.pslist:list processes'
  'windows.psscan:scan processes'
  'windows.pstree:process tree'
  'windows.dlllist:list DLLs'
  'windows.malfind:find injected code'
  'windows.netscan:network scan'
  'windows.netstat:network connections'
  'windows.cmdline:cmdline'
  'windows.handles:handles'
  'windows.filescan:file scan'
  'windows.modules:kernel modules'
  'windows.lsadump:LSA dump'
  'windows.hashdump:hash dump'
  'windows.svcscan:service scan'
  'windows.svclist:services'
  'windows.driverscan:driver scan'
  'windows.registry.printkey:print registry key'
  'windows.registry.hivelist:registry hives'
  'windows.registry.userassist:userassist'
  'windows.registry.amcache:amcache'
  'windows.info:Windows info'
  'windows.cmdscan:cmd scan'
  'windows.consoles:consoles'
  'windows.envars:env vars'
  'windows.getsids:SIDs'
  'windows.privileges:privileges'
  'windows.scheduled_tasks:scheduled tasks'
  'windows.sessions:sessions'
  'windows.ssdt:SSDT'
  'windows.thrdscan:thread scan'
  'windows.threads:threads'
  'windows.vadinfo:VAD info'
  'windows.dumpfiles:dump files'
  'linux.pslist:list processes'
  'linux.psscan:scan processes'
  'linux.pstree:process tree'
  'linux.bash:bash history'
  'linux.lsmod:list modules'
  'linux.lsof:list open files'
  'linux.malfind:find injected code'
  'linux.psaux:psaux'
  'linux.ip:network'
  'linux.netfilter:netfilter rules'
  'linux.elfs:loaded ELFs'
  'linux.envars:env vars'
  'linux.boottime:boot time'
  'linux.kallsyms:kallsyms'
