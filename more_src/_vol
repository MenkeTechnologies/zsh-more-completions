)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '--parallelism=[parallelism]:mode:(processes threads off)' \
  '*'{-e,--extend}'=[extend setting]:setting:' \
  '(-p --plugin-dirs)'{-p,--plugin-dirs}'=[plugin dirs]:dirs:' \
  '(-s --symbol-dirs)'{-s,--symbol-dirs}'=[symbol dirs]:dirs:' \
  '*'{-v,--verbosity}'[verbose]' \
  '(-l --log)'{-l,--log}'=[log file]:file:_files' \
  '(-o --output-dir)'{-o,--output-dir}'=[output dir]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-f --file)'{-f,--file}'=[memory image]:file:_files' \
  '--write-config[write config.json]' \
  '--save-config=[save config to file]:file:_files' \
  '--clear-cache[clear cache]' \
  '--cache-path=[cache path]:dir:_files -/' \
  '--offline[offline]' \
  '(-u --remote-isf-url)'{-u,--remote-isf-url}'=[ISF URL]:url:' \
  '*--filters=[filter]:filter:' \
  '*--hide-columns=[hide columns]:prefixes:' \
  '(-r --renderer)'{-r,--renderer}'=[renderer]:renderer:(quick pretty csv json jsonl)' \
  '1: :->plugin' \
  '*::arg:->args' && ret=0

case $state in
  (plugin) _describe -t plugins 'volatility plugin' plugins && ret=0 ;;
esac

return ret
