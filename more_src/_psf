#compdef psf
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss165.html
# KAPPA: determine the parameters of a model star image

local ret=1

_arguments -s \
  'AXES=[draw labelled and annotated axes]:axes:(TRUE FALSE)' \
  'CLEAR=[clear the current picture first]:clear:(TRUE FALSE)' \
  'COFILE=[text file containing star coordinates]:file:_files' \
  'CUT=[output NDF size as fraction of peak]:cut' \
  'DEVICE=[graphics device for the profile plot]:device' \
  'GAUSS=[fix radial fall-off to 2]:gauss:(TRUE FALSE)' \
  'IN=[input NDF containing star images]:NDF:_files' \
  'INCAT=[catalogue with star positions]:catalogue:_files' \
  'ISIZE=[side length for marginal profiles]:isize' \
  'LOGFILE=[text file for the output table]:file:_files' \
  'MARGIN=[margin widths for axis annotation]:margin' \
  'MARKER=[PGPLOT marker type]:marker' \
  'MINOR=[annotate axis with minor-axis distance]:minor:(TRUE FALSE)' \
  'NORM=[normalize model PSF to unity]:norm:(TRUE FALSE)' \
  'OUT=[output NDF with the fitted PSF]:NDF:_files' \
  'POSCOLS=[column positions of coordinates]:poscols' \
  'PROFOUT=[output NDF with the 1D profile]:NDF:_files' \
  'RANGE=[number of profile widths for fitting]:range' \
  'STYLE=[plotting style attributes]:style' \
  'TITLE=[title for the output PSF NDF]:title' \
  'USEAXIS=[which two axes to use]:useaxis' \
  'XLEFT=[axis value for the left end]:xleft' \
  'XRIGHT=[axis value for the right end]:xright' \
  'YBOT=[axis value for the bottom end]:ybot' \
  'YTOP=[axis value for the top end]:ytop' \
  '*:NDF:_files' && ret=0

return ret
