#compdef nomacs
# Documentation: https://man.archlinux.org/search?q=nomacs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen]' \
  '(-p --private)'{-p,--private}'[private mode]' \
  '(-m --mode)'{-m+,--mode=}'[viewing mode]:mode:(default frameless pseudocolor)' \
  '(-d --directory)'{-d+,--directory=}'[load directory]:dir:_files -/' \
  '(-t --tab)*'{-t+,--tab=}'[load image to new tab]:file:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp"' \
  '--batch=[batch settings file]:file:_files -g "*.nfo"' \
  '--batch-log=[batch log file]:file:_files' \
  '--import-settings=[import settings file]:file:_files -g "*.nfo"' \
  '--export-settings=[export settings file]:file:_files -g "*.nfo"' \
  '--register-files[register file associations (Windows)]' \
  '--slideshow[start slideshow]' \
  '--pong[start pong game]' \
  '--no-cache[disable image cache]' \
  '--full-frame[fit to frame]' \
  '*: :_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.dds *.psd *.tga *.ppm *.pgm *.pbm *.pnm *.exr *.hdr *.heif *.heic *.avif *.raw *.cr2 *.nef *.dng *.arw *.orf *.rw2 *.sr2"' && ret=0

return ret
