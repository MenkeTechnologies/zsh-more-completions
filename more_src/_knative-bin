#compdef kn
# _knative-bin — Knative serverless CLI (Knative project, Go); manage Knative services, revisions, triggers
# upstream: https://github.com/knative/client

_knative-bin() {
    local -a sub=(
        'service:service commands'
        'revision:revision commands'
        'route:route commands'
        'plugin:plugin commands'
        'trigger:trigger commands'
        'source:source commands'
        'broker:broker commands'
        'channel:channel commands'
        'subscription:subscription commands'
        'domain:domain mapping commands'
        'completion:print shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config+[kn config file]:file:_files' \
        '--context+[kube context]:context:' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--log-http[log HTTP req/resp]' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kn subcommand' sub ;;
        args)
            case $words[1] in
                service) _arguments \
                    '1:service cmd:(apply create delete describe export list list-revisions list-routes update)' \
                    '*:service name:' ;;
                revision) _arguments \
                    '1:revision cmd:(delete describe list)' \
                    '*:revision name:' ;;
                trigger) _arguments \
                    '1:trigger cmd:(create delete describe list update)' \
                    '*:trigger name:' ;;
                source) _arguments \
                    '1:source cmd:(apiserver binding container ping list list-types)' \
                    '*:source name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_knative-bin "$@"
