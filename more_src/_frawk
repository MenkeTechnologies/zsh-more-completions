#compdef frawk
# Documentation: https://man.archlinux.org/search?q=frawk
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h -help)'{-h,-help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '-v=[Assign variable before run]:var=value:' \
  '(-F)-F+[Field separator]:separator:' \
  '(-f)-f+[AWK program file]:file:_files' \
  '1:program or -:_default' \
  '*::files: _files'
