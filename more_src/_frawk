#compdef frawk
# Documentation: https://github.com/ezrosent/frawk/blob/master/info/overview.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# frawk — efficient awk-like language.
# Flag set from info/overview.md and CLI argument parser.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[AWK program file]:file:_files' \
  '-F+[field separator]:separator' \
  '-v+[assign variable before run]:var=value' \
  '-i+[input format]:format:(csv tsv)' \
  '-o+[output format]:format:(csv tsv)' \
  '-H[parse first line into FI field-name map]' \
  '-A[disable static taint analysis for shell invocations]' \
  '--utf8[enable UTF-8 validation on all input]' \
  '-Binterp[use bytecode interpreter (not JIT)]' \
  '-O0[disable LLVM optimizations]' \
  '--dump-cfg[print untyped control-flow graph]' \
  '--dump-bytecode[print generated bytecode]' \
  '--dump-llvm[print generated LLVM code]' \
  '-pr[parallel run with dynamic worker count]' \
  '-pf[file-per-worker parallel mode]' \
  '1:program or -:_default' \
  '*::files:_files'
