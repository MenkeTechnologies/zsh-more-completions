#compdef vsphere-csi-syncer
# _vsphere-csi-syncer — vSphere CSI metadata syncer + supervisor cluster controllers (k8s ↔ CNS metadata, storage-quota webhook)
# upstream: https://github.com/kubernetes-sigs/vsphere-csi-driver
# Flags from cmd/syncer/main.go on tip.

_vsphere-csi-syncer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print syncer version and exit]' \
        '--leader-election[enable leader election]' \
        '--leader-election-namespace=[namespace for leader-election lease]:ns:' \
        '--leader-election-lease-duration=[lease duration]:duration:' \
        '--leader-election-renew-deadline=[lease renew deadline]:duration:' \
        '--leader-election-retry-period=[lease retry period]:duration:' \
        '--operation-mode=[syncer operation mode]:mode:(METADATA_SYNC FULL_SYNC STORAGE_QUOTA_WEBHOOK)' \
        '--webhook-client-cert-verification[verify webhook client certificates]' \
        '--supervisor-fss-name=[supervisor feature-state-switch configmap name]:name:' \
        '--supervisor-fss-namespace=[supervisor feature-state-switch configmap namespace]:ns:' \
        '--fss-name=[internal feature-state-switch configmap name]:name:' \
        '--fss-namespace=[internal feature-state-switch configmap namespace]:ns:' \
        '--storagequota-sync-interval=[storage quota periodic sync interval]:duration:' \
        '--enable-profile-server[enable syncer profiling endpoint]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_vsphere-csi-syncer "$@"
