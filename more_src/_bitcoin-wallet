#compdef bitcoin-wallet
# Documentation: https://github.com/bitcoin/bitcoin (src/bitcoin-wallet.cpp SetupWalletToolArgs)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'info:get wallet info'
  'create:create a new descriptor wallet file'
  'dump:print out all wallet key-value records (uses -dumpfile)'
  'createfromdump:create new wallet file from dumped records (uses -dumpfile)'
)

_arguments -C \
  '(- *)-version[print version and exit]' \
  '(- *)-help[show help]' \
  '-datadir=-[data directory]:dir:_directories' \
  '-wallet=-[wallet name]:name:' \
  '-dumpfile=-[file for dump output or createfromdump input]:file:_files' \
  '-debug=-[output debugging information]:category:' \
  '-printtoconsole[send trace/debug info to console]' \
  '-regtest[run on regtest]' \
  '-testnet[run on testnet]' \
  '-testnet4[run on testnet4]' \
  '-signet[run on signet]' \
  '-chain=-[chain name]:chain:(main test testnet4 signet regtest)' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'bitcoin-wallet command' _subcmds && ret=0
    ;;
esac

return ret
