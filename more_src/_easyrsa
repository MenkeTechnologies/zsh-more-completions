#compdef easyrsa

# Zsh completion for easyrsa - Easy-RSA PKI management

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '--batch[non-interactive mode]' \
  '--sbatch[silent batch mode]' \
  '--days=[certificate validity period]:days' \
  '--digest=[message digest algorithm]:algorithm:(sha1 sha256 sha384 sha512)' \
  '--dn-mode=[distinguished name mode]:mode:(cn_only org)' \
  '--keysize=[key size in bits]:bits' \
  '--pki-dir=[PKI directory]:directory:_directories' \
  '--req-cn=[common name for the request]:common name' \
  '--subject-alt-name=[subject alternative name]:SAN' \
  '--use-algo=[cryptographic algorithm]:algorithm:(rsa ec ed)' \
  '--copy-ext[copy extensions from request to certificate]' \
  '--ns-cert-type=[Netscape certificate type]:type' \
  '--passin=[password input method]:method' \
  '--passout=[password output method]:method' \
  '--vars=[vars file]:file:_files' \
  '--no-pass[do not encrypt private keys]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init-pki:initialize a new PKI'
      'build-ca:build a certificate authority'
      'gen-req:generate a certificate request'
      'sign-req:sign a certificate request'
      'build-client-full:generate and sign a client certificate'
      'build-server-full:generate and sign a server certificate'
      'revoke:revoke a certificate'
      'gen-crl:generate a certificate revocation list'
      'update-db:update the certificate database'
      'show-req:display a certificate request'
      'show-cert:display a certificate'
      'import-req:import a certificate request'
      'export-p7:export a PKCS#7 file'
      'export-p8:export a PKCS#8 file'
      'export-p12:export a PKCS#12 file'
      'set-rsa-pass:set or change RSA key passphrase'
      'set-ec-pass:set or change EC key passphrase'
      'gen-dh:generate Diffie-Hellman parameters'
      'show-ca:display the CA certificate'
      'verify-cert:verify a certificate'
      'renew:renew a certificate'
      'revoke-renewed:revoke a renewed certificate'
      'revoke-expired:revoke an expired certificate'
      'make-safe-ssl:generate a safe SSL config'
      'upgrade:upgrade Easy-RSA'
    )
    _describe -t commands 'easyrsa command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      sign-req)
        _arguments -s -S \
          '1:type:(client server serverClient ca code-signing email)' \
          '2:name' && ret=0
        ;;
      gen-req|build-client-full|build-server-full|revoke|show-req|show-cert|export-p7|export-p8|export-p12|set-rsa-pass|set-ec-pass|verify-cert|renew|revoke-renewed|revoke-expired)
        _arguments -s -S \
          '1:name' && ret=0
        ;;
      import-req)
        _arguments -s -S \
          '1:request file:_files' \
          '2:short name' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
