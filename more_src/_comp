#compdef comp
# Documentation: man comp(1)
# Source: nmh uip/comp.c (master) — compose a new message (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-draftfolder+[draft folder]:folder:_default' \
    '-draftmessage+[draft message]:msg:_default' \
    '-nodraftfolder[no draft folder]' \
    '-editor+[editor to use]:cmd:_command_names -e' \
    '-noedit[skip editor invocation]' \
    '-file+[file to use as draft]:file:_files' \
    '-form+[format file]:file:_files' \
    '(-use -nouse)-use[use existing draft]' \
    '(-use -nouse)-nouse[do not use existing draft]' \
    '-whatnowproc+[whatnow program]:cmd:_command_names -e' \
    '-nowhatnowproc[skip whatnow program]' \
    '-build[just build draft, do not invoke whatnow]' \
    '-version[show version]' \
    '-help[show help]' \
    '-to+[recipient address]:to:_default' \
    '-cc+[cc address]:cc:_default' \
    '-from+[sender address]:from:_default' \
    '-fcc+[fcc mailbox]:fcc:_default' \
    '-width+[output width]:cols:_default' \
    '-subject+[message subject]:subject:_default' \
    '1::message:_default' \
    && ret=0

return ret
