#compdef ragtag ragtag.py
# ragtag — reference-guided scaffolding and misassembly correction

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'correct:homology-based misassembly correction'
  'scaffold:homology-based scaffolding'
  'patch:gap filling and sequence joining'
  'merge:merge multiple scaffolding AGP files'
  'agp2fa:convert AGP file to FASTA'
  'agpcheck:validate AGP files'
  'asmstats:compute assembly statistics'
  'splitasm:split assembly at gaps'
  'updategff:update GFF coordinates'
  'delta2paf:convert delta to PAF format'
  'paf2delta:convert PAF to delta format'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'ragtag command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (correct)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o[output directory]:output dir:_files -/' \
          '-t[number of threads]:threads' \
          '-f[minimum unique alignment length]:length' \
          '--remove-small[remove alignments shorter than -f]' \
          '-q[minimum mapq]:mapq' \
          '-d[maximum alignment merge distance]:distance' \
          '-b[minimum break distance from contig ends]:distance' \
          '-e[reference headers to ignore]:file:_files' \
          '-j[query headers to leave uncorrected]:file:_files' \
          '--inter[only break misassemblies between reference sequences]' \
          '--intra[only break misassemblies within reference sequences]' \
          '--gff[do not break within GFF intervals]:GFF file:_files' \
          '-w[overwrite intermediate files]' \
          '-u[add suffix to unaltered sequence headers]' \
          '--aligner[whole genome aligner]:aligner:(minimap2 nucmer unimap)' \
          '--mm2-params[minimap2 parameters]:params' \
          '--unimap-params[unimap parameters]:params' \
          '--nucmer-params[nucmer parameters]:params' \
          '1:reference FASTA:_files' \
          '2:query FASTA:_files' \
          && ret=0
        ;;
      (scaffold)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o[output directory]:output dir:_files -/' \
          '-t[number of threads]:threads' \
          '-f[minimum unique alignment length]:length' \
          '--remove-small[remove alignments shorter than -f]' \
          '-q[minimum mapq]:mapq' \
          '-d[maximum alignment merge distance]:distance' \
          '-i[minimum grouping confidence score]:score' \
          '-a[minimum location confidence score]:score' \
          '-s[minimum orientation confidence score]:score' \
          '-e[reference headers to ignore]:file:_files' \
          '-j[query headers to leave unplaced]:file:_files' \
          '-C[concatenate unplaced contigs into chr0]' \
          '-r[infer gap sizes]' \
          '-g[minimum inferred gap size]:size' \
          '-m[maximum inferred gap size]:size' \
          '-w[overwrite intermediate files]' \
          '-u[add suffix to unplaced sequence headers]' \
          '--aligner[whole genome aligner]:aligner:(minimap2 nucmer unimap)' \
          '--mm2-params[minimap2 parameters]:params' \
          '--unimap-params[unimap parameters]:params' \
          '--nucmer-params[nucmer parameters]:params' \
          '1:reference FASTA:_files' \
          '2:query FASTA:_files' \
          && ret=0
        ;;
      (patch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o[output directory]:output dir:_files -/' \
          '-t[number of threads]:threads' \
          '-f[minimum unique alignment length]:length' \
          '--remove-small[remove alignments shorter than -f]' \
          '-q[minimum mapq]:mapq' \
          '-d[maximum alignment merge distance]:distance' \
          '-s[minimum merged alignment length]:length' \
          '-i[max merged alignment distance from terminus]:fraction' \
          '-e[target headers to ignore]:file:_files' \
          '-j[query headers to ignore]:file:_files' \
          '--fill-only[only fill existing gaps]' \
          '--join-only[only join sequences, do not fill gaps]' \
          '-w[overwrite intermediate files]' \
          '-u[add suffix to unplaced sequence headers]' \
          '--aligner[aligner executable]:aligner:(nucmer minimap2 unimap)' \
          '--mm2-params[minimap2 parameters]:params' \
          '--unimap-params[unimap parameters]:params' \
          '--nucmer-params[nucmer parameters]:params' \
          '1:target FASTA:_files' \
          '2:query FASTA:_files' \
          && ret=0
        ;;
      (merge)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o[output directory]:output dir:_files -/' \
          '-f[CSV list of AGP file weights]:weights' \
          '-j[query headers to leave unplaced]:file:_files' \
          '-l[minimum assembly sequence length]:length' \
          '-w[overwrite intermediate files]' \
          '-u[add suffix to unplaced sequence headers]' \
          '-b[Hi-C BAM alignments]:BAM file:_files' \
          '-r[restriction enzymes or DNase]:enzymes' \
          '1:assembly FASTA:_files' \
          '*:AGP files:_files' \
          && ret=0
        ;;
      (agp2fa)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:AGP file:_files' \
          '2:components FASTA:_files' \
          && ret=0
        ;;
      (asmstats)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-g[genome size for NGx]:size' \
          '*:assembly files:_files' \
          && ret=0
        ;;
      (splitasm)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-n[minimum gap size]:size' \
          '-o[output AGP file]:output file:_files' \
          '1:assembly FASTA:_files' \
          && ret=0
        ;;
      (updategff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c[update for misassembly correction]' \
          '1:GFF file:_files' \
          '2:AGP file:_files' \
          && ret=0
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
