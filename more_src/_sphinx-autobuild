#compdef sphinx-autobuild

# Zsh completion for sphinx-autobuild - rebuild Sphinx documentation on changes

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '--port[port to serve on (default 8000)]:port:' \
  '--host[host to serve on (default localhost)]:host:' \
  '--re-ignore[regular expression for files to ignore]:regex:' \
  '--ignore[file pattern to ignore]:pattern:' \
  '--no-initial[skip the initial build]' \
  '--open-browser[open browser after the initial build]' \
  '--delay[delay before opening browser (seconds)]:seconds:' \
  '--watch[additional directories to watch]:directory:_files -/' \
  '--pre-build[command to run before each build]:command:' \
  '(-b)-b+[build format]:builder:(html dirhtml singlehtml htmlhelp qthelp devhelp epub applehelp latex man texinfo text gettext doctest linkcheck xml pseudoxml)' \
  '(-a)-a[write all files (default: only write new and changed files)]' \
  '(-E)-E[do not use a saved environment, always read all files]' \
  '-d+[path for the cached environment and doctree files]:directory:_files -/' \
  '-j+[build in parallel with N processes]:n:' \
  '-c+[path where configuration file is located]:directory:_files -/' \
  '-C[use no config file at all]' \
  '-D+[override a setting in configuration file]:setting=value:' \
  '-A+[pass a value into HTML templates]:name=value:' \
  '-n[nit-picky mode, warn about all missing references]' \
  '-v[increase verbosity]' \
  '-q[no output on stdout, just warnings on stderr]' \
  '-Q[no output at all, not even warnings]' \
  '--color[do emit colored output]' \
  '-N[do not emit colored output]' \
  '-w+[write warnings (and errors) to given file]:file:_files' \
  '-W[turn warnings into errors]' \
  '--keep-going[with -W, keep going when getting warnings]' \
  '-T[show full traceback on exception]' \
  '-P[run Pdb on exception]' \
  '1:source directory:_files -/' \
  '2:output directory:_files -/' \
  '*:filenames:_files'
