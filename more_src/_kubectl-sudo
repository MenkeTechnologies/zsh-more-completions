#compdef kubectl-sudo
# Documentation: https://github.com/postfinance/kubectl-sudo
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-sudo wraps kubectl by adding --as and --as-group impersonation flags.
# It accepts no flags of its own; everything is forwarded to kubectl.

_arguments -s -S \
  '*:kubectl arguments:_default'
