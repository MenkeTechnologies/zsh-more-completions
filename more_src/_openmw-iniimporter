#compdef openmw-iniimporter
# _openmw-iniimporter — import Morrowind.ini settings into openmw.cfg (OpenMW/openmw)
# upstream: https://github.com/OpenMW/openmw
# Flags from apps/mwiniimporter/main.cpp (boost::program_options).

_openmw-iniimporter() {
    _arguments \
        '(- *)'{-h,--help}'[produce help message]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-i --ini)'{-i+,--ini=}'[Morrowind.ini file]:file:_files' \
        '(-c --cfg)'{-c+,--cfg=}'[openmw.cfg file]:file:_files' \
        '(-o --output)'{-o+,--output=}'[output openmw.cfg file]:file:_files' \
        '(-g --game-files)'{-g,--game-files}'[import esm and esp files]' \
        '(-f --fonts)'{-f,--fonts}'[import bitmap fonts]' \
        '(-A --no-archives)'{-A,--no-archives}'[disable bsa archives import]' \
        '(-e --encoding)'{-e+,--encoding=}'[character encoding]:enc:(win1250 win1251 win1252)'
}

_openmw-iniimporter "$@"
