#compdef aips
# Documentation: http://www.aips.nrao.edu/cgi-bin/ZXHLP2.PL?AIPS
# Start classic AIPS (Astronomical Image Processing System); options are case-insensitive

local ret=1

_arguments -s -S \
  '*:option:->opts' && ret=0

case $state in
  opts)
    _values -S = 'aips option' \
      'OLD[use the OLD (released) AIPS version]' \
      'NEW[use the NEW (current) AIPS version]' \
      'TST[use the TST (test) AIPS version]' \
      'TV[set TV display server (TV=disp:host, TV=local, or TV=local:n)]' \
      'NOTV[start without a TV display server]' \
      'TVOK[allow TV start even if display checks fail]' \
      'DA[data area disk assignments (DA=host,..., DA=default, or DA=all)]' \
      'PR[set printer device (PR=lpdev)]' \
      'TP[tape host(s) (TP=tphost,...)]' \
      'TPOK[allow tape server start even if checks fail]' \
      'REMOTE[run AIPS on a remote host]' \
      'REM[run AIPS on a remote host]' \
      'TEK[use a Tektronix terminal for graphics]' \
      'DEBUG[run under a debugger (DEBUG=prog:aips)]' \
      'LOCAL[force local data-disk lookup]' \
      'NORL[disable readline command-line editing]' \
      'NOEX[do not execute, just set up the environment]' && ret=0
    ;;
esac

return ret
