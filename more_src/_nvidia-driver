#compdef nvidia-driver
# Documentation: https://man.archlinux.org/search?q=nvidia-driver
# Reference accessed: 2026-05-16

# nvidia-driver: distro wrapper to install/configure NVIDIA driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(install uninstall configure status help)' \
  '*::nvidia-driver args:_files' && ret=0
return ret
