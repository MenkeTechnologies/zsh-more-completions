#compdef s6-fdholder-delete
# _s6-fdholder-delete — s6 fdholder s6-fdholder-delete (delete one stored fd from a running s6-fdholderd over its UCSPI-Unix socket; identified by id)
# upstream: https://github.com/skarnet/s6
# Flags from src/fdholder/s6-fdholder-delete.c on tip.

_s6-fdholder-delete() {
    _arguments \
        '-t+[timeout (ms)]:ms:' \
        '1:socket:_files' \
        '2:id:'
}

_s6-fdholder-delete "$@"
