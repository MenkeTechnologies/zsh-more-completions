#compdef xfce4-settings xfce4-settings-manager

# xfce4-settings(-manager): Xfce control panel
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-d[set dialog]:dialog:(xfce4-accessibility-settings xfce4-appearance-settings xfce-display-settings xfce-keyboard-settings xfce-mouse-settings xfce4-session-settings xfce4-power-manager-settings xfce4-mime-settings xfce4-workspace-settings xfce4-mailwatch-plugin xfce4-color-settings)' \
  '--dialog=[set dialog]:dialog:' \
  '--display=[X display]:display:' \
  '--socket-id=[embed into socket]:id:' \
  '*::xfce4-settings args:_files' && ret=0
return ret
