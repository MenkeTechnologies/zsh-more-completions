#compdef stevedore

local -a _stevedore_commands
_stevedore_commands=(
  'build:build Docker images'
  'create:create resources'
  'get:get resources'
  'init:initialize a project'
  'promote:promote Docker images'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config[config file]:file:_files' \
  '--log-level[log level]:level:(debug info warn error fatal panic)' \
  '--no-color[disable color]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'stevedore commands' _stevedore_commands
    ;;
  args)
    case "$words[1]" in
      build)
        _arguments \
          '--image-name[image name]:name' \
          '--image-version[image version]:version' \
          '--registry[registry]:registry' \
          '--push-after-build[push after building]' \
          '--cascade[cascade build]' \
          '--cascade-depth[cascade depth]:depth' \
          '--connection-local[use local Docker daemon]' \
          '--no-push[do not push]' \
          '--dry-run[dry run]' \
          '--num-workers[number of workers]:count' \
          '--enable-semver-tags[enable semver tags]' \
          '*:image name'
        ;;
      create)
        _arguments '1:resource:(configuration credentials)' \
          '--dry-run[dry run]' \
          '*:args'
        ;;
      get)
        _arguments \
          '1:resource:(builders configuration credentials images)' \
          '--output[output format]:format:(json yaml)' \
          '*:args'
        ;;
      init)
        _arguments \
          '--builders-path[builders path]:dir:_directories' \
          '--config[config file]:file:_files' \
          '--credentials-dir[credentials directory]:dir:_directories' \
          '--images-path[images path]:dir:_directories' \
          '--log-path[log path]:dir:_directories'
        ;;
      promote)
        _arguments \
          '--image-name[source image]:name' \
          '--image-promote-name[target image]:name' \
          '--image-promote-registry[target registry]:registry' \
          '--image-promote-tag[target tag]:tag' \
          '--remove-promote-tags[remove promote tags]' \
          '--dry-run[dry run]' \
          '--enable-semver-tags[enable semver tags]' \
          '*:image name'
        ;;
    esac
    ;;
esac
