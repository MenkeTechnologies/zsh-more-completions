#compdef corral
# Documentation: https://github.com/boogie-org/corral
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '1: : _default' \
  '*::args: _default'
