#compdef acra-tokens
# _acra-tokens — manipulate Acra token stores (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Subcommands from cmd/acra-tokens/acra-tokens.go.

_acra-tokens() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)-h[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'status:show token-store status'
                'disable:disable a token (mark as revoked)'
                'enable:enable a previously disabled token'
                'remove:remove tokens from the store'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_acra-tokens "$@"
