#compdef dotnet-dump

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'collect:capture a process dump'
  'analyze:interactive SOS shell on a dump'
  'ps:list dotnet processes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotnet-dump subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (collect)
        _arguments \
          '(-p --process-id)'{-p,--process-id=}'[process id]:pid:' \
          '(-n --name)'{-n,--name=}'[process name]:name:' \
          '--type=[dump type]:type:(Full Heap Mini Triage)' \
          '(-o --output)'{-o,--output=}'[output dump path]:file:_files' \
          '--diag[diagnostic logging]' \
          '--crashreport[generate crash report]' && ret=0
        ;;
      (analyze)
        _arguments \
          '*'{-c,--command=}'[debug command to run on start]:cmd:' \
          ':dump:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
