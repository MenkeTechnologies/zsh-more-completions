#compdef faust2mathdoc
# Documentation: https://faustdoc.grame.fr/manual/tools/
# Reference accessed: 2026-06-21
# Verified: flags parsed by the faust2mathdoc script in grame-cncm/faust tools/faust2appls.

local ret=1

_arguments -s -S \
  '(-mdlang --mathdoc-lang -l)'{-mdlang,--mathdoc-lang,-l}'+[documentation language]:lang:(en fr it)' \
  '(-utf8 --utf8)'{-utf8,--utf8}'[recode the dsp input to UTF-8]' \
  '*:dsp file:_files -g "*.dsp"' && ret=0

return ret
