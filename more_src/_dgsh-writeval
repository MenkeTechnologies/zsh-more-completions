#compdef dgsh-writeval
# Documentation: https://www.spinellis.gr/sw/dgsh/dgsh-writeval.html
# dgsh-writeval - directed graph shell value store writer (Unix-domain socket)

local ret=1

_arguments -s -S \
  '-s+[path of the Unix-domain socket to create]:path:_files' \
  '-b+[window start position, n units from input end (default 1)]:n:' \
  '-e+[window end position, n units from input end (default 0)]:n:' \
  '-l+[process fixed-width len-sized records]:len:' \
  '-t+[record termination character (default newline)]:char:' \
  '-u+[window unit: s/m/h/d/r (default r)]:unit:(s m h d r)' && ret=0

return ret
