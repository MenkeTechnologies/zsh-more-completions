#compdef pix-png
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=pix-png&sektion=1
# BRL-CAD pix image to PNG converter

local ret=1

_arguments -s \
  '-a[autosize input to determine height and width]' \
  '-w[input width in pixels]:width' \
  '-n[input height in scanlines]:height' \
  '-s[square size for both width and height]:size' \
  '-g[gamma correction value for the PNG]:gamma' \
  '-o[output PNG file]:output:_files' \
  '*:input.pix:_files' && ret=0

return ret
