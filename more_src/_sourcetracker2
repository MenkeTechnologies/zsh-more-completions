#compdef sourcetracker2
# Documentation: https://github.com/biota/sourcetracker2/blob/master/sourcetracker/_cli/gibbs.py
# SourceTracker2 Bayesian microbial source tracking

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-i --table_fp)'{-i,--table_fp}'=[feature table file (biom)]:table:_files' \
  '(-m --mapping_fp)'{-m,--mapping_fp}'=[sample metadata mapping file]:mapping:_files' \
  '(-o --output_dir)'{-o,--output_dir}'=[output directory location]:dir:_files -/' \
  '--loo[leave-one-out cross-validation]' \
  '--jobs=[number of parallel jobs]:jobs' \
  '--alpha1=[Dirichlet parameter alpha1]:alpha1' \
  '--alpha2=[Dirichlet parameter alpha2]:alpha2' \
  '--beta=[Dirichlet parameter beta]:beta' \
  '--source_rarefaction_depth=[rarefaction depth for sources]:depth' \
  '--sink_rarefaction_depth=[rarefaction depth for sinks]:depth' \
  '--restarts=[number of sampler restarts]:restarts' \
  '--draws_per_restart=[MCMC draws per restart]:draws' \
  '--burnin=[number of burn-in iterations]:burnin' \
  '--delay=[delay between draws]:delay' \
  '--per_sink_feature_assignments[feature-level assignments per sink]' \
  '--sample_with_replacement[sample with replacement]' \
  '--source_sink_column=[metadata column distinguishing sources/sinks]:column' \
  '--source_column_value=[metadata value indicating source samples]:value' \
  '--sink_column_value=[metadata value indicating sink samples]:value' \
  '--source_category_column=[metadata column for source categorization]:column' \
  '--diagnostics[enable diagnostic analysis]' \
  '--limit=[convergence threshold for diagnostics]:limit' \
  '--stacked_bar[generate stacked bar visualization]' \
  '--no_heatmap[suppress heatmap output]' \
  '--paired_heatmap[generate paired heatmap comparison]' \
  '--title=[plot title text]:title' \
  '--heatmap_color=[colormap scheme]:cmap' \
  '--keep_unknowns[retain unknown source contributions]' \
  '--transpose[transpose output orientation]' \
  '*:command:(gibbs)' && ret=0

return ret
