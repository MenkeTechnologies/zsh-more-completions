#compdef thin-entrypoint thin_entrypoint
# _thin-entrypoint — Multus thin-mode DaemonSet entrypoint (k8snetworkplumbingwg/multus-cni)
# upstream: https://github.com/k8snetworkplumbingwg/multus-cni
# Flags from cmd/thin_entrypoint/main.go on tip.

_thin-entrypoint() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cni-bin-dir=[CNI binary directory]:dir:_files -/' \
        '--cni-conf-dir=[CNI config directory]:dir:_files -/' \
        '--cni-version=[CNI spec version for generated multus config]:ver:(0.3.0 0.3.1 0.4.0 1.0.0 1.1.0)' \
        '--multus-conf-file=[multus CNI config file (auto or absolute path)]:file:_files' \
        '--multus-bin-file=[multus binary path]:file:_files' \
        '--multus-cni-conf-dir=[multus-specific CNI config dir]:dir:_files -/' \
        '--skip-multus-binary-copy=[skip copying multus binary]:bool:(true false)' \
        '--multus-kubeconfig-file-host=[multus kubeconfig path on the host]:file:_files' \
        '--multus-master-cni-file-name=[master CNI file name in autoconfig dir]:name:' \
        '--namespace-isolation=[enable namespace isolation]:bool:(true false)' \
        '--global-namespaces=[comma-sep global namespaces]:list:' \
        '--multus-autoconfig-dir=[multus autoconfig source dir]:dir:_files -/' \
        '--multus-log-to-stderr=[multus log to stderr]:bool:(true false)' \
        '--multus-log-level=[multus log level]:level:(panic error warning verbose debug)' \
        '--multus-log-file=[multus log file path]:file:_files' \
        '--override-network-name=[override network name from master CNI]:bool:(true false)' \
        '--cleanup-config-on-exit=[remove generated config on exit]:bool:(true false)' \
        '--skip-config-watch=[skip watching master CNI / kubeconfig changes]:bool:(true false)' \
        '--rename-conf-file=[rename master CNI file to invalidate it]:bool:(true false)' \
        '--readiness-indicator-file=[readiness indicator file path]:file:_files' \
        '--additional-bin-dir=[additional CNI binDir injected into config]:dir:_files -/'
}

_thin-entrypoint "$@"
