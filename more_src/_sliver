#compdef sliver

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'generate:generate an implant binary'
      'implants:list implant builds'
      'sessions:list active sessions'
      'use:switch the active session'
      'info:get info about a session'
      'jobs:manage jobs'
      'mtls:start an mTLS listener'
      'wg:start a WireGuard listener'
      'dns:start a DNS listener'
      'http:start an HTTP listener'
      'https:start an HTTPS listener'
      'stage-listener:start a stager listener'
      'profiles:manage implant profiles'
      'beacons:list active beacons'
      'interact:interact with a session'
      'operators:manage operators'
      'websites:manage websites'
      'armory:manage armory packages'
      'update:check for updates'
      'version:display version'
    )
    _describe -t commands 'sliver command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (generate)
        _arguments -s -S \
          '--help[show help]' \
          '--os=[target operating system]:os:(windows linux darwin)' \
          '--arch=[target architecture]:arch:(amd64 386 arm64)' \
          '--name=[implant name]:name' \
          '--lhost=[listen host]:host' \
          '--lport=[listen port]:port' \
          '--save=[save implant to file]:file:_files' \
          '--debug[enable debug mode]' \
          '--format=[output format]:format:(exe shared-lib service shellcode)' \
          '--mtls=[mTLS connection string]:connection' \
          '--wg=[WireGuard connection string]:connection' \
          '--http=[HTTP(S) connection string]:connection' \
          '--dns=[DNS connection string]:connection' \
          '--skip-symbols[skip symbol obfuscation]' \
          '--evasion[enable evasion features]' \
          '--reconnect=[reconnect interval in seconds]:seconds' \
          '--max-errors=[max connection errors]:count' \
          '--timeout=[command timeout in seconds]:seconds' \
          '--beacon[generate a beacon implant]' && ret=0
        ;;
      (mtls)
        _arguments -s -S \
          '--help[show help]' \
          '--lhost=[listen host]:host' \
          '--lport=[listen port]:port' \
          '--persistent[make listener persistent]' && ret=0
        ;;
      (wg)
        _arguments -s -S \
          '--help[show help]' \
          '--lhost=[listen host]:host' \
          '--lport=[listen port]:port' \
          '--nport=[n-port for key exchange]:port' \
          '--key-port=[key exchange port]:port' \
          '--persistent[make listener persistent]' && ret=0
        ;;
      (dns)
        _arguments -s -S \
          '--help[show help]' \
          '--domains=[DNS domains]:domains' \
          '--lport=[listen port]:port' \
          '--no-canaries[disable DNS canaries]' \
          '--persistent[make listener persistent]' && ret=0
        ;;
      (http|https)
        _arguments -s -S \
          '--help[show help]' \
          '--domain=[domain for listener]:domain' \
          '--lhost=[listen host]:host' \
          '--lport=[listen port]:port' \
          '--website=[website name]:name' \
          '--persistent[make listener persistent]' && ret=0
        ;;
      (sessions|beacons|implants|jobs)
        _arguments -s -S \
          '--help[show help]' \
          '--kill=[kill session/job by ID]:id' \
          '--kill-all[kill all]' && ret=0
        ;;
      (profiles)
        _arguments -s -S \
          '--help[show help]' \
          '--name=[profile name]:name' && ret=0
        ;;
      (use|interact|info)
        _arguments -s -S \
          '--help[show help]' \
          '1:session id' && ret=0
        ;;
      (stage-listener)
        _arguments -s -S \
          '--help[show help]' \
          '--url=[stage listener URL]:url' \
          '--profile=[implant profile to use]:profile' && ret=0
        ;;
    esac
    ;;
esac

return ret
