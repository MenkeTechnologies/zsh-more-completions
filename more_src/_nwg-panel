#compdef nwg-panel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[config file]:config file:_files' \
  '-s[css file]:css file:_files' \
  '-o[output name]:output:' \
  '-r[restart]' && ret=0

return ret
