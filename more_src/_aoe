#compdef aoe
# Documentation: https://man.archlinux.org/search?q=aoe
# Reference accessed: 2026-05-16

# njbrake/agent-of-empires src/cli/definition.rs (clap); Homebrew: Formula/a/aoe.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p)'{-p+,--profile=}'[workspace profile]:profile:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'aoe command' compadd -- \
    add agents init list ls remove rm send status session group profile project worktree \
    tmux sounds theme serve cockpit uninstall update completion
  ;;
args)
  case $line[1] in
    init)
      _arguments '*:directory:_files -/' && ret=0
      ;;
    status)
      _arguments \
        '(-v)'{-v,--verbose}'[verbose session list]' \
        '(-q)'{-q,--quiet}'[only waiting count]' \
        '--json[JSON output summary]' && ret=0
      ;;
    serve)
      _arguments -s \
        '--port=[listen port]' \
        '--host=[bind host]' \
        '--no-auth[disable authentication (localhost only)]' \
        '--read-only[read-only dashboard]' \
        '--remote[public HTTPS tunnel]' \
        '--tunnel-name=[named Cloudflare tunnel]' \
        '--no-tailscale[skip Tailscale for remote]' \
        '--tunnel-url=[hostname for named tunnel]' \
        '--daemon[detach daemon]' \
        '--stop[stop running daemon]' \
        '--passphrase=[dashboard passphrase]' && ret=0
      ;;
    completion)
      _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0
      ;;
    *)
      _default && ret=0
      ;;
  esac
  ;;
esac

return ret
