#compdef rsbuild

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'dev:start the dev server'
  'build:build the app for production'
  'preview:preview the production build locally'
  'inspect:inspect Rspack and Rsbuild configurations'
)

_arguments -C \
  '--base=[base path]:base:' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '--config-loader=[config loader]:loader:(auto jiti native)' \
  '--env-mode=[env mode]:mode:' \
  '--env-dir=[env directory]:dir:_files -/' \
  '--environment=[environment name]:name:' \
  '(- *)'{-h,--help}'[show help]' \
  '--log-level=[log level]:level:(info warn error silent)' \
  '(-m --mode)'{-m,--mode=}'[build mode]:mode:(development production none)' \
  '--no-env[ignore env files]' \
  '(-r --root)'{-r,--root=}'[project root]:dir:_files -/' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rsbuild subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (dev|preview)
        _arguments \
          '(-o --open)'{-o,--open=}'[open URL]:url:' \
          '--port=[port]:port:' \
          '--host=[host]:host:_hosts' && ret=0
        ;;
      (build)
        _arguments '(-w --watch)'{-w,--watch}'[watch mode]' && ret=0
        ;;
      (inspect)
        _arguments \
          '--output=[output dir]:dir:_files -/' \
          '--verbose[verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
