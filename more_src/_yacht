#compdef yacht
# _yacht — SelfhostedPro Yacht docker container management UI CLI alias (SelfhostedPro team, Python/Vue); custom argparse
# upstream: https://github.com/SelfhostedPro/Yacht

_yacht() {
    local -a sub=(
        'login:login to yacht'
        'logout:logout'
        'apps:list:list apps'
        'apps:get:get app info'
        'apps:create:create app'
        'apps:update:update app'
        'apps:delete:delete app'
        'apps:logs:show logs'
        'apps:restart:restart app'
        'apps:stop:stop app'
        'apps:start:start app'
        'apps:exec:exec in app'
        'apps:stats:show stats'
        'apps:processes:show processes'
        'images:list:list images'
        'images:get:get image'
        'images:pull:pull image'
        'images:delete:delete image'
        'images:prune:prune images'
        'volumes:list:list volumes'
        'volumes:create:create volume'
        'volumes:delete:delete volume'
        'volumes:prune:prune volumes'
        'networks:list:list networks'
        'networks:create:create network'
        'networks:delete:delete network'
        'networks:prune:prune networks'
        'templates:list:list templates'
        'templates:create:create template'
        'templates:delete:delete template'
        'templates:update:update template'
        'templates:variables:list template vars'
        'compose:up:compose up'
        'compose:down:compose down'
        'compose:list:list compose projects'
        'compose:logs:compose logs'
        'compose:restart:compose restart'
        'system:info:system info'
        'system:df:disk usage'
        'system:events:show events'
        'system:auth:check auth'
        'system:prune:prune system'
        'users:list:list users'
        'users:create:create user'
        'users:delete:delete user'
        'users:update:update user'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[yacht url]:url:_urls' \
        '--user=+[username]:user:_users' \
        '--password=+[password]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yacht subcommand' sub ;;
        args)
            case $words[1] in
                apps:get|apps:update|apps:delete|apps:logs|apps:restart|apps:stop|apps:start|apps:exec|apps:stats|apps:processes) _arguments '1:app name:' ;;
                templates:create|templates:delete|templates:update) _arguments '1:template:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_yacht "$@"
