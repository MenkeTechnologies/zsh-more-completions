#compdef corosync-cmapctl

# corosync-cmapctl: configuration-map runtime read/write tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-b[print binary values as hex]' \
  '-d[delete key]:key:' \
  '-D[delete key with prefix]:prefix:' \
  '-g[get key value]:key:' \
  '-m[print key changes (watch)]' \
  '-p[load key/value from file]:file:_files' \
  '-s[set key=value with type]:key value type:' \
  '-t[track changes to key]:key:' \
  '-T[track changes to keys with prefix]:prefix:' \
  '*::corosync-cmapctl args:_files' && ret=0
return ret
