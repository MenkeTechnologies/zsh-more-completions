#compdef corosync-cmapctl

# corosync-cmapctl: get/set corosync CMAP (Cluster Map) keys
local curcontext="$curcontext" ret=1
_arguments -C \
  '-b[show byte values as bytes]' \
  '-d[delete key]:key:' \
  '-D[delete key prefix]:prefix:' \
  '-g[get key value]:key:' \
  '-h[show help]' \
  '-k[track key changes (watch mode)]:key:' \
  '-m[set key to value with type]:type:(i8 u8 i16 u16 i32 u32 i64 u64 fpt dbl str bin)' \
  '-p[load keys from file]:file:_files' \
  '-s[set key=value with type]:type:(i8 u8 i16 u16 i32 u32 i64 u64 fpt dbl str bin)' \
  '-t[run within track context]' \
  '*::corosync-cmapctl args:_files' && ret=0
return ret
