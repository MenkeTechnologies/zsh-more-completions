#compdef phonopy-load
# Documentation: https://phonopy.github.io/phonopy/command-options.html
# phonopy: run phonopy by auto-loading phonopy.yaml settings

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[detailed output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress log messages]' \
  '(-c --cell)'{-c,--cell}'+[unit cell crystal structure file]:file:_files' \
  '(--pa --primitive-axes)'{--pa,--primitive-axes}'=[primitive cell axes transformation]:matrix' \
  '--dim=[supercell dimensions]:dim' \
  '--readfc[read existing force constants]' \
  '--writefc[write force constants to file]' \
  '--fc-symmetry[apply symmetry to force constants]' \
  '--band=[calculate phonon band structure]:band' \
  '(--mesh --mp)'{--mesh,--mp}'=[set q-point mesh]:mesh' \
  '--nac[enable non-analytical term correction]' \
  '--pdos=[compute projected density of states]:pdos' \
  '--dos[calculate total density of states]' \
  '--tmin=[minimum temperature]:tmin' \
  '--tmax=[maximum temperature]:tmax' \
  '--tstep=[temperature step size]:tstep' \
  '-t[compute thermal properties]' \
  '--hdf5[write output in HDF5 format]' \
  '-p[plot results]' \
  '-s[save plot to file]' \
  '*:file:_files' && ret=0

return ret
