#compdef xstow

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-d+[set stow directory]:stow directory:_directories' \
  '-t+[set target directory]:target directory:_directories' \
  '-n[do not actually make changes]' \
  '-v+[increase verbosity]:verbosity level:(0 1 2 3 4)' \
  '-D[unstow instead of stow]' \
  '-R[restow (unstow then stow)]' \
  '--ignore=[ignore files matching regex]:regex' \
  '--override=[override files matching regex]:regex' \
  '-F[force mode, allow conflicts]' \
  '-ap+[add copy protection]:pattern' \
  '-al+[add link protection]:pattern' \
  '-tr+[add traverse link]:pattern' \
  '-kl+[add keep link]:pattern' \
  '-i+[add ignore pattern]:pattern' \
  '-f+[use config file]:config file:_files' \
  '*:package:_directories' && return 0
