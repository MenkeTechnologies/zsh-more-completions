#compdef gofmt
# _gofmt-bin — Go source code formatter (Go team); canonical formatter for Go files
# upstream: https://pkg.go.dev/cmd/gofmt

_gofmt-bin() {
    _arguments \
        '-d[display diffs instead of rewriting]' \
        '-e[print all errors]' \
        '-l[list files whose formatting differs]' \
        '-r+[rewrite rule]:rule:' \
        '-s[simplify code]' \
        '-w[write result back to file]' \
        '-cpuprofile+[CPU profile]:file:_files' \
        '*:file or dir:_files'
}

_gofmt-bin "$@"
