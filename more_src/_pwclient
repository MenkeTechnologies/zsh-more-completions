#compdef pwclient
# Documentation: https://patchwork.readthedocs.io/projects/pwclient/en/latest/usage.html
# pwclient — command-line client for the Patchwork patch tracking system.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debugging logging (REST backend only)]' \
  '1:command:(apply git-am get info projects states view update list search check-get check-list check-info check-create event-list)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      apply|get|info|view|check-get)
        _arguments -s \
          '(-h --use-hashes)'{-h,--use-hashes}'[look up patch by hash instead of ID]' \
          '*:patch id:' && ret=0
        ;;
      git-am)
        _arguments -s \
          '(-h --use-hashes)'{-h,--use-hashes}'[look up patch by hash instead of ID]' \
          '(-s --signoff)'{-s,--signoff}'[pass --signoff to git-am]' \
          '(-3 --3way)'{-3,--3way}'[pass --3way to git-am]' \
          '(-m --msgid)'{-m,--msgid}'[pass --message-id to git-am]' \
          '*:patch id:' && ret=0
        ;;
      list|search)
        _arguments -s \
          '(-s --state)'{-s+,--state=}'[filter by patch state]:state:' \
          '(-a --archived)'{-a+,--archived=}'[filter by archived state]:archived:(yes no)' \
          '(-p --project)'{-p+,--project=}'[filter by project name]:project:' \
          '(-w --submitter)'{-w+,--submitter=}'[filter by submitter]:who:' \
          '(-d --delegate)'{-d+,--delegate=}'[filter by delegate]:who:' \
          '-n+[limit results to first n]:count:' \
          '-N+[limit results to last N]:count:' \
          '(-m --msgid)'{-m+,--msgid=}'[filter by Message-Id]:msgid:' \
          '(-H --hash)'{-H+,--hash=}'[filter by hash]:hash:' \
          '(-S --series)'{-S+,--series=}'[filter by series ID]:series:' \
          '(-f --format)'{-f+,--format=}'[output format string]:format:' \
          '*:filter:' && ret=0
        ;;
      update)
        _arguments -s \
          '(-h --use-hashes)'{-h,--use-hashes}'[look up patch by hash instead of ID]' \
          '(-c --commit-ref)'{-c+,--commit-ref=}'[commit reference for this change]:commit:' \
          '(-s --state)'{-s+,--state=}'[set patch state]:state:' \
          '(-a --archived)'{-a+,--archived=}'[set archived state]:archived:(yes no)' \
          '*:patch id:' && ret=0
        ;;
      check-create)
        _arguments -s \
          '(-c --context)'{-c+,--context=}'[check context]:context:' \
          '(-s --state)'{-s+,--state=}'[check state]:state:(pending success warning fail)' \
          '*:patch id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
