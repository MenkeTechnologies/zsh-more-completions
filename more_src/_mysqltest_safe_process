#compdef mysqltest_safe_process

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--parent-pid=[parent process PID]:pid:_pids' \
  '*--env=[set environment variable KEY=VAL]:key=value:' \
  '--kill-server=[server PID to kill on exit]:pid:_pids' \
  '--client-pid=[client process PID]:pid:_pids' \
  '--verbose[verbose output]' \
  '--[stop option processing]' \
  '*::command:_normal' && ret=0

return ret
