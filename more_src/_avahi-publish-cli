#compdef avahi-publish-cli
# _avahi-publish-cli — Avahi avahi-publish register mDNS/DNS-SD services or addresses CLI alias (avahi team, C); custom argparse
# upstream: https://github.com/avahi/avahi

_avahi-publish-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[publish service]' \
        '--service[publish service]' \
        '-a[publish address]' \
        '--address[publish address]' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-R[no fail if daemon not running]' \
        '--no-reverse[do not publish reverse]' \
        '-f[fail if daemon not running]' \
        '--no-fail[do not fail]' \
        '*:name type port txt:'
}

_avahi-publish-cli "$@"
