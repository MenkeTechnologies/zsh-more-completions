#compdef pandoc-crossref

# Zsh completion for pandoc-crossref - pandoc filter for cross-references

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose output]' \
  '(-p --man-page)'{-p,--man-page}'[show man page]' \
  '--citeproc[use citeproc for citations]' \
  '-d+[specify defaults file]:defaults file:_files' \
  '--natbib[use natbib for citations]' \
  '--biblatex[use biblatex for citations]' \
  '-o+[output format]:output format:(json native plain latex html)' \
  && ret=0

return ret
