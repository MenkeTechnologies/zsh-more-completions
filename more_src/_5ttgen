#compdef 5ttgen
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/5ttgen.html
# Source: MRtrix3/mrtrix3 bin/5ttgen — generate a 5TT image for ACT (Python; subcommand fsl/freesurfer/gif/hsvs).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-nocrop[do not crop the output to reduce size]' \
    '-sgm_amyg_hipp[represent amygdalae+hippocampi as SGM]' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '-config+[temporary config key/value]:key:_default:value:_default' \
    '1:algorithm:(fsl freesurfer gif hsvs)' \
    '*:algorithm-specific arguments:_files' \
    && ret=0

return ret
