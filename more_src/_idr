#compdef idr
# Documentation: https://github.com/nboley/idr
# idr: Irreproducible Discovery Rate framework for measuring peak reproducibility

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --samples)'{-s+,--samples=}'[two files containing peaks and scores]:files:_files' \
  '(-p --peak-list)'{-p+,--peak-list=}'[take all peaks from this file]:file:_files' \
  '--input-file-type[file format of input samples]:type:(narrowPeak broadPeak bed gff)' \
  '--rank[column to use for ranking peaks]:rank:(signal.value p.value q.value)' \
  '(-o --output-file)'{-o+,--output-file=}'[destination for results]:file:_files' \
  '--output-file-type[output format]:type:(narrowPeak broadPeak bed)' \
  '(-l --log-output-file)'{-l+,--log-output-file=}'[log destination]:file:_files' \
  '(-i --idr-threshold)'{-i+,--idr-threshold=}'[global IDR cutoff for reporting peaks]:float:' \
  '--soft-idr-threshold[threshold for stats while returning all peaks below hard threshold]:float:' \
  '--use-old-output-format[use legacy output formatting]' \
  '--plot[generate PNG visualization]' \
  '--use-nonoverlapping-peaks[include peaks without a matching counterpart]' \
  '--peak-merge-method[aggregation method for merged peaks]:method:(sum avg min max)' \
  '--initial-mu[starting mu value]:float:' \
  '--initial-sigma[starting sigma value]:float:' \
  '--initial-rho[starting rho value]:float:' \
  '--initial-mix-param[starting mixture parameter value]:float:' \
  '--fix-mu[prevent mu from changing during optimization]' \
  '--fix-sigma[prevent sigma from changing during optimization]' \
  '--dont-filter-peaks-below-noise-mean[include signal points below noise mean]' \
  '--use-best-multisummit-IDR[use best IDR value across multi-summit peak groups]' \
  '--allow-negative-scores[accept negative score values]' \
  '--random-seed[tie-breaking seed]:int:' \
  '--max-iter[maximum optimization iterations]:int:' \
  '--convergence-eps[parameter convergence threshold]:float:' \
  '--only-merge-peaks[return merged peaks without IDR calculation]' \
  '--verbose[enable debug output]' \
  '--quiet[suppress status messages]' && ret=0

return ret
