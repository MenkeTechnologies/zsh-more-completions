#compdef scrcpy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '--always-on-top[make window always on top]' \
  '(-b --video-bit-rate)'{-b,--video-bit-rate}'[set video bit rate]:bit rate (e.g. 8M)' \
  '--audio-bit-rate[set audio bit rate]:bit rate' \
  '--audio-buffer[set audio buffer duration]:duration in ms' \
  '--audio-codec[set audio codec]:codec:(opus aac raw)' \
  '--audio-source[set audio source]:source:(output mic)' \
  '--no-audio[disable audio forwarding]' \
  '--video-codec[set video codec]:codec:(h264 h265 av1)' \
  '--video-source[set video source]:source:(display camera)' \
  '--crop[crop the device screen]:crop (W:H:X:Y)' \
  '(-d --select-usb)'{-d,--select-usb}'[use USB device]' \
  '--disable-screensaver[disable screensaver while scrcpy is running]' \
  '--display[specify display ID]:display ID' \
  '--display-buffer[set display buffering]:duration in ms' \
  '(-e --select-tcpip)'{-e,--select-tcpip}'[use TCP/IP device]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
  '--force-adb-forward[force ADB forward reverse connection]' \
  '--forward-all-clicks[forward all clicks to device]' \
  '--keyboard[set keyboard input mode]:mode:(sdk uhid aoa disabled)' \
  '--legacy-paste[use legacy paste mechanism]' \
  '--list-displays[list available displays]' \
  '--list-cameras[list available cameras]' \
  '--list-camera-sizes[list available camera sizes]' \
  '--list-encoders[list available encoders]' \
  '--lock-video-orientation[lock video orientation]:orientation:(unlocked initial 0 1 2 3)' \
  '--max-fps[limit framerate]:fps' \
  '(-m --max-size)'{-m,--max-size}'[limit size (width and height)]:pixels' \
  '--mouse[set mouse input mode]:mode:(sdk uhid aoa disabled)' \
  '(-n --no-control)'{-n,--no-control}'[disable device control]' \
  '(-N --no-playback)'{-N,--no-playback}'[disable video and audio playback]' \
  '--no-cleanup[disable cleanup actions on exit]' \
  '--no-clipboard-autosync[disable automatic clipboard sync]' \
  '--no-downsize-on-error[do not retry with lower definition on error]' \
  '--no-key-repeat[do not forward repeated key events]' \
  '--no-mipmaps[disable mipmaps]' \
  '--no-power-on[do not power on device on start]' \
  '--no-video[disable video forwarding]' \
  '--otg[run in OTG mode]' \
  '(-p --port)'{-p,--port}'[set port range for tunnels]:port range (from\:to)' \
  '--pause-on-exit[make scrcpy pause on exit]:when:(true false if-error)' \
  '--power-off-on-close[turn screen off when closing]' \
  '--prefer-text[inject text events instead of key events]' \
  '--print-fps[print framerate to stdout]' \
  '--push-target[set target directory on device]:directory' \
  '(-r --record)'{-r,--record}'[record screen to file]:file:_files -g "*.mp4 *.mkv"' \
  '--record-format[force recording format]:format:(mp4 mkv)' \
  '--render-driver[specify SDL render driver]:driver:(direct3d opengl opengles2 opengles metal software)' \
  '--rotation[set initial display rotation]:rotation:(0 1 2 3)' \
  '(-s --serial)'{-s,--serial}'[device serial number]:serial' \
  '--shortcut-mod[set shortcut modifier keys]:modifier:(lctrl rctrl lalt ralt lsuper rsuper)' \
  '(-S --turn-screen-off)'{-S,--turn-screen-off}'[turn device screen off]' \
  '(-t --show-touches)'{-t,--show-touches}'[show touches on the device]' \
  '--tcpip[configure and reconnect over TCP/IP]:address (ip\:port)' \
  '--time-limit[set maximum mirroring time]:seconds' \
  '--tunnel-host[set tunnel host]:host' \
  '--tunnel-port[set tunnel port]:port' \
  '--v4l2-buffer[add a buffering delay for v4l2 sink]:duration in ms' \
  '--v4l2-sink[output to v4l2loopback device]:device:_files -g "/dev/video*"' \
  '(-w --stay-awake)'{-w,--stay-awake}'[keep device awake]' \
  '--window-borderless[disable window decorations]' \
  '--window-title[set custom window title]:title' \
  '--window-x[set initial window x position]:x' \
  '--window-y[set initial window y position]:y' \
  '--window-width[set initial window width]:width' \
  '--window-height[set initial window height]:height' \
  && ret=0

return ret
