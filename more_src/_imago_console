#compdef imago_console
# Documentation: https://lifescience.opensource.epam.com/imago/imago_console.html
# Imago OCR console application - chemical structure image recognition

local ret=1

_arguments -s -S \
  '-o+[save single recognition result to file]:file:_files' \
  '-characters[extract only characters from images]' \
  '-learn+[process machine learning for collection]:dir:_files -/' \
  '-learnd+[shorthand for -learn -dir -images]:dir:_files -/' \
  '-compare+[calculate similarity between molfiles]:molfile:_files' \
  '-retcode[return similarity 0..100 in ERRORLEVEL]' \
  '-test+[calculate similarity score on test collection]:dir:_files -/' \
  '-config+[use specified configuration cluster file]:file:_files' \
  '-log[enable debug log output to ./log.html]' \
  '-logvfs[store log in single encoded file]' \
  '-noexp[do not expand chemical abbreviations]' \
  '-pr[use probabilistic separator (experimental)]' \
  '-tl+[time limit per single image in ms]:ms:' \
  '-similarity+[override default comparison method]:tool:' \
  '-pass[only print filenames, do not process images]' \
  '-override+[override config by applying string]:config_string:' \
  '-dir+[process every image from directory]:dir:_files -/' \
  '-rec[process directory recursively]' \
  '-images[skip non-supported files from directory]' \
  '*:image file:_files' && ret=0

return ret
