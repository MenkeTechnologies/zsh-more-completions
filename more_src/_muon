#compdef muon muon-meson
# Documentation: https://man.archlinux.org/search?q=muon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analyze:run a static analyzer on the current project'
  'check:check if a filename parses'
  'fmt:format meson.build files'
  'fmt_unstable:format meson.build files (unstable)'
  'samu:invoke the built-in samurai backend'
  'samurai:invoke the built-in samurai backend'
  'setup:configure and generate buildfiles'
  'options:list available project options and defaults'
  'install:install the project'
  'test:execute tests defined in source files'
  'subprojects:operate on subprojects'
  'wrap:manipulate wrap-files'
  'introspect:print project metadata'
  'dist:create a distribution archive'
  'compile:run the build (default subcommand)'
  'configure:configure an existing build directory'
  'eval:evaluate a meson script'
  'meson:translate from meson CLI'
  'repl:interactive meson script repl'
  'info:print project info from build dir'
  'devenv:dump developer environment'
  'env2mfile:generate cross/native file from current environment'
  'rewrite:in-place edit of meson.build files'
  'version:print muon version'
  'help:show help'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)version[show version]' \
  '*-v[increase verbosity]' \
  '-C+[chdir to path before running command]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'muon command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup)
        _arguments \
          '*-D+[set/override an option]:option:' \
          '--cross-file=[cross file]:file:_files' \
          '--native-file=[native file]:file:_files' \
          '--reconfigure[reconfigure build dir]' \
          '*:build_dir:_files -/' && ret=0 ;;
      (install)
        _arguments \
          '--destdir=[install destination]:dir:_files -/' \
          '--dry-run[do not install]' \
          '*:build_dir:_files -/' && ret=0 ;;
      (test)
        _arguments \
          '*--setup=[test setup name]:setup:' \
          '*--suite=[test suite]:suite:' \
          '-j+[jobs]:n:' \
          '--list[list available tests]' \
          '--verbose[verbose output]' \
          '*:test_name:' && ret=0 ;;
      (fmt|fmt_unstable)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-i --in-place)'{-i,--in-place}'[edit files in place]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '*::file:_files -g "meson.build|meson_options.txt"' && ret=0 ;;
      (samu|samurai)
        _arguments \
          '*::ninja_target:' && ret=0 ;;
      (introspect)
        _arguments \
          '*::sub:(buildoptions targets tests installed projectinfo)' && ret=0 ;;
      (rewrite)
        _arguments \
          '*::sub:(kwargs target default-options command)' && ret=0 ;;
      (subprojects)
        _arguments \
          '*::sub:(download update checkout purge foreach packagefiles list)' && ret=0 ;;
      (wrap)
        _arguments \
          '*::sub:(list search install update info status promote regenerate-cache)' && ret=0 ;;
    esac ;;
esac

return ret
