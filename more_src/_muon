#compdef muon muon-meson
# Documentation: https://muon.build/muon.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analyze:run a static analyzer'
  'build:setup and build in a single step'
  'devenv:execute commands within a developer environment'
  'fmt:format a meson source file'
  'help:show help, including meson function references'
  'install:install files'
  'internal:specialized subcommands (parsing, eval, diagnostics)'
  'meson:translate from meson CLI'
  'options:list project options'
  'setup:setup a build directory'
  'subprojects:manage subproject dependencies'
  'test:run tests'
  'version:print muon version'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)version[show version]' \
  '*-v[increase verbosity]' \
  '-C+[chdir to path before running command]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'muon command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup)
        _arguments \
          '*-D+[set/override an option]:option:' \
          '--cross-file=[cross file]:file:_files' \
          '--native-file=[native file]:file:_files' \
          '--reconfigure[reconfigure build dir]' \
          '*:build_dir:_files -/' && ret=0 ;;
      (install)
        _arguments \
          '--destdir=[install destination]:dir:_files -/' \
          '--dry-run[do not install]' \
          '*:build_dir:_files -/' && ret=0 ;;
      (test)
        _arguments \
          '*--setup=[test setup name]:setup:' \
          '*--suite=[test suite]:suite:' \
          '-j+[jobs]:n:' \
          '--list[list available tests]' \
          '--verbose[verbose output]' \
          '*:test_name:' && ret=0 ;;
      (fmt)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-i --in-place)'{-i,--in-place}'[edit files in place]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '*::file:_files -g "meson.build|meson_options.txt"' && ret=0 ;;
      (subprojects)
        _arguments \
          '*::sub:(download update checkout clean foreach list)' && ret=0 ;;
    esac ;;
esac

return ret
