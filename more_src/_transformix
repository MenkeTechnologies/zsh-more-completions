#compdef transformix
# Documentation: https://elastix.dev/doxygen/commandlinearg.html
# transformix - apply an elastix transform to an image or generate a deformation field

local ret=1

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[print version information and exit]' \
  '-tp[transform parameter file]:transform parameters:_files' \
  '-out[output directory]:output dir:_files -/' \
  '-in[input image to transform]:input image:_files -g "*.{nii,nii.gz,mhd,mha,hdr,img,gipl}"' \
  '-def[points file to transform (or "all" for full deformation field)]:points:_files' \
  '-jac[generate spatial Jacobian determinant image (use "all")]:jac:(all)' \
  '-jacmat[generate spatial Jacobian matrix image (use "all")]:jacmat:(all)' \
  '-threads[maximum number of threads to use]:threads:' && ret=0

return ret
