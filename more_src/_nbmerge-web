#compdef nbmerge-web
# Documentation: https://nbdime.readthedocs.io/en/latest/cli.html
# nbmerge-web - web app for manually resolving Jupyter notebook merge conflicts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version]' \
  '--config[list valid config keys and current values]' \
  '--log-level=[set logging verbosity]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
  '(-p --port)'{-p,--port}'=[port for the server]:port:' \
  '(-b --browser)'{-b,--browser}'=[browser to launch]:browser:' \
  '--ip=[interface to listen on]:ip:' \
  '(-w --workdirectory)'{-w,--workdirectory}'=[server working directory]:dir:_files -/' \
  '--base-url=[URL path prefix]:url:' \
  '--persist[keep server running after remote close requests]' \
  '--merge-strategy=[merge strategy]:strategy:(inline use-base use-local use-remote union)' \
  '--input-strategy=[merge strategy for inputs]:strategy:(inline use-base use-local use-remote union)' \
  '--output-strategy=[merge strategy for outputs]:strategy:(inline use-base use-local use-remote union remove clear-all)' \
  '--out=[output file]:file:_files' \
  '*:notebook:_files -g "*.ipynb"' && ret=0

return ret
