#compdef linkerd-network-validator
# _linkerd-network-validator — Linkerd network-validator initContainer (binds a TCP listener on the proxy outbound port and confirms an outbound connect lands there before exiting; if it fails the pod cannot proxy traffic and is later evicted by linkerd-cni-repair-controller)
# upstream: https://github.com/linkerd/linkerd2-proxy-init
# Flags from validator/src/main.rs Args on tip (clap); LINKERD_NETWORK_VALIDATOR_LOG_LEVEL / LINKERD_NETWORK_VALIDATOR_LOG_FORMAT env vars bind to --log-level and --log-format.

_linkerd-network-validator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--log-level=[tracing log filter (LINKERD_NETWORK_VALIDATOR_LOG_LEVEL)]:filter:' \
        '--log-format=[log format (LINKERD_NETWORK_VALIDATOR_LOG_FORMAT)]:fmt:(plain json)' \
        '--timeout=[validation timeout]:duration:' \
        '--listen-addr=[server bind address that should receive the redirected connection]:addr:' \
        '--connect-addr=[client connect address (an arbitrary unroutable destination)]:addr:'
}

_linkerd-network-validator "$@"
