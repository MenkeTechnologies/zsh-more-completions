#compdef panel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'serve:serve Panel application'
      'convert:convert Panel application to standalone format'
      'bundle:bundle Panel resources'
    )
    _describe -t commands 'panel command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      serve)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--port[port to listen on]:port' \
          '--address[address to listen on]:address' \
          '*--allow-websocket-origin[allowed websocket origin]:origin' \
          '--prefix[URL prefix]:prefix' \
          '--num-procs[number of worker processes]:number' \
          '--num-threads[number of threads per process]:number' \
          '--warm[pre-warm the application]' \
          '--autoreload[enable autoreload on code changes]' \
          '*--static-dirs[static directories to serve]:dir:_directories' \
          '--dev[run in development mode]' \
          '--show[open the application in a browser]' \
          '--log-level[set log level]:level:(debug info warning error critical)' \
          '*:script:_files -g "*.py"' && ret=0
        ;;
      convert)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--to[target format]:format:(pyodide-worker pyodide pyscript)' \
          '--out[output directory]:directory:_directories' \
          '--title[application title]:title' \
          '--pwa[enable progressive web app]' \
          '--skip-embed[skip embedding resources]' \
          '*:script:_files -g "*.py"' && ret=0
        ;;
      bundle)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '*:script:_files -g "*.py"' && ret=0
        ;;
    esac
    ;;
esac

return ret
