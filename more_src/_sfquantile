#compdef sfquantile
# Documentation: https://github.com/ahay/src/blob/master/user/ivlad/Mquantile.c
# Madagascar: compute a quantile value (percentage clip) of the data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'pclip=[percentage clip, between 0 and 100]:percent' \
  'memsize=[max amount of RAM in Mb to be used]:Mb' \
  '*:RSF file:_files' && ret=0

return ret
