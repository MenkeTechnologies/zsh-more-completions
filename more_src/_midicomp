#compdef midicomp
# Documentation: https://github.com/markc/midicomp
# convert Standard MIDI Files to and from a plain text format

local ret=1

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[send any debug output to stderr]' \
  '(-v --verbose)'{-v,--verbose}'[output in columns with notes on]' \
  '(-c --compile)'{-c,--compile}'[compile ascii input into SMF]' \
  '(-n --note)'{-n,--note}'[note on/off value as note|octave]' \
  '(-t --time)'{-t,--time}'[use absolute time instead of ticks]' \
  '--fold=[fold sysex data at N columns]:columns' \
  '*:midi file:_files' && ret=0

return ret
