#compdef multitail

# Zsh completion for multitail - multiple log tail viewer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-i[add file to tail]:file:_files' \
  '-I[add file to tail in same window]:file:_files' \
  '-iw[add file with interval]:file:_files' \
  '-l[execute command and tail output]:command:' \
  '-L[execute command in same window]:command:' \
  '-j[read from stdin]' \
  '-J[read from stdin in same window]' \
  '--mergeall[merge all windows]' \
  '--no-mergeall[do not merge all windows]' \
  '--retry[retry if file does not exist]' \
  '--retry-all[retry for all files]' \
  '-s[split vertically]:columns:' \
  '-sw[set widths for split]:widths:' \
  '-sn[set number of columns]:columns:' \
  '-wh[set window height]:height:' \
  '-n[set number of lines]:lines:' \
  '-N[set number of lines for buffering]:lines:' \
  '-f[follow mode]' \
  '--follow-all[follow all files]' \
  '-d[only show differences]' \
  '-D[show differences and all original]' \
  '-m[set number of lines in buffer]:lines:' \
  '-mb[set memory buffer size]:bytes:' \
  '-M[set bytes per file]:bytes:' \
  '-p[set default pause mode]:mode:(l t)' \
  '-cS[set color scheme]:scheme:' \
  '-cs[select default color scheme]:scheme:' \
  '-Cs[set color for status line]:colors:' \
  '-ci[set color for strings]:color:' \
  '-c-[strip ANSI color codes]' \
  '-c+[pass ANSI color codes]' \
  '-w[do not use stripes]' \
  '-T[set title]:title:' \
  '-t[set window title]:title:' \
  '-x[set window title format]:format:' \
  '-du[do not display the status line]' \
  '-ts[add timestamp]:format:' \
  '-o[set output file]:file:_files' \
  '-b[set scroll back lines]:lines:' \
  '-ev[regular expression filter]:regex:' \
  '-e[regular expression highlight]:regex:' \
  '-ex[regular expression to exclude]:regex:' \
  '-ec[execute command on match]:command:' \
  '-eX[case sensitive match]:pattern:' \
  '-fr[set filter]:filter:' \
  '-rc[set refresh interval]:seconds:' \
  '-R[restart window when command exits]:seconds:' \
  '-q[quiet mode, do not display info]' \
  '-Z[set color palette]:colors:' \
  '-u[set update interval]:seconds:' \
  '-F[use config file]:file:_files' \
  '*:file:_files'
