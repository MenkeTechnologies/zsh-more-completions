#compdef fcollect
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/fcollect.html
# Collect housekeeping/engineering AppId data into a FITS filter file

local ret=1

_arguments -s -S \
  'obsid=[observation identifier code]:obsid:' \
  'fdpath=[path to the XFD top level directory]:fdpath:_files -/' \
  'appidfile=[ASCII file listing AppIds and columns]:appidfile:_files' \
  'outfile=[output FITS filename, XFD for standard naming]:outfile:_files' \
  'deltat=[output timestep in seconds]:deltat:' \
  'maxgap=[max gap for interpolation in seconds]:maxgap:' \
  'breakfile=[PCA breakdown history, CALDB or NONE]:breakfile:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
