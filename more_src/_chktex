#compdef chktex
# Documentation: chktex --help (ChkTeX 1.7.9)
# Source: ChkTeX — LaTeX semantic checker.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-i,--license}'[show license / distribution info]' \
    '(-l --localrc)'{-l,--localrc=}'[read local .chktexrc-format file]:file:_files' \
    '(-d --debug)'{-d,--debug=}'[debug bitmask]:n:' \
    '(-r --reset)'{-r,--reset}'[reset settings to default]' \
    '*(-S --set)'{-S,--set=}'[read argument as chktexrc line]:assignment:' \
    '*(-w --warnon)'{-w,--warnon=}'[turn warning ID on as a warning]:id:' \
    '*(-e --erroron)'{-e,--erroron=}'[turn ID on as an error]:id:' \
    '*(-m --msgon)'{-m,--msgon=}'[turn ID on as a message]:id:' \
    '*(-n --nowarn)'{-n,--nowarn=}'[mute warning ID]:id:' \
    '(-L --nolinesupp)'{-L,--nolinesupp}'[disable per-line/file suppressions]' \
    '(-v --verbosity)'{-v,--verbosity=-}'[output verbosity]::level:(0 1 2 3)' \
    '(-V --pipeverb)'{-V,--pipeverb=-}'[verbosity when stdout != tty]::level:(0 1 2 3)' \
    '(-s --splitchar)'{-s,--splitchar=}'[field separator for -v0]:char:' \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '(-p --pseudo)'{-p,--pseudo=}'[pseudonym for input]:name:' \
    '(-q --quiet)'{-q,--quiet}'[no banner]' \
    '(-W --version)'{-W,--version}'[show version]' \
    '(-I --inputfiles)'{-I,--inputfiles=-}'[read \\input files (0=off 1=on)]:flag:(0 1)' \
    '(-b --backup)'{-b,--backup=-}'[turn backup files on/off]:flag:(0 1)' \
    '(-t --makebackup)'{-t,--makebackup=-}'[backup if any changes]:flag:(0 1)' \
    '(-x --pipemode)'{-x,--pipemode=-}'[pipe-friendly output 0/1]:flag:(0 1)' \
    '(-g --globalrc)'{-g,--globalrc=-}'[load global chktexrc 0/1]:flag:(0 1)' \
    '*:LaTeX file:_files -g "*.{tex,ltx,latex}"' \
    && ret=0

return ret
