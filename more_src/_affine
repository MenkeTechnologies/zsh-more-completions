#compdef affine affine-cli
# _affine — Toeverything AFFiNE local-first open-source knowledge-base CLI for the AFFiNE writer/whiteboard/database hybrid managing workspaces blocks edgeless mode and self-hosted server (toeverything team, TypeScript); commander.js
# upstream: https://github.com/toeverything/AFFiNE

_affine() {
    local -a sub=(
        'init:initialize new workspace'
        'serve:run self-hosted server'
        'export:export workspace'
        'import:import workspace'
        'sync:sync with cloud'
        'login:login to AFFiNE Cloud'
        'logout:logout'
        'workspace:workspace operations'
        'config:show config'
        'reset:reset state'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'affine subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--db-url=+[url]:str:' \
                    '--redis-url=+[url]:str:' \
                    '--storage-backend=+[b]:b:(local s3 r2 gcs azure)' \
                    '--storage-path=+[dir]:dir:_files -/' ;;
                export) _arguments \
                    '--workspace=+[id]:str:' \
                    '--format=+[f]:f:(json affine markdown pdf html)' \
                    '--output=+[file]:file:_files' ;;
                import) _arguments \
                    '--format=+[f]:f:(json affine notion roam markdown)' \
                    '*:input file:_files' ;;
                workspace) _arguments \
                    '1:action:(list create delete rename info members invite revoke)' \
                    '*:workspace name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_affine "$@"
