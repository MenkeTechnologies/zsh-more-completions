#compdef consul
# _consul-bin — HashiCorp Consul service mesh + KV store CLI (HashiCorp, Go); manage Consul cluster + agents
# upstream: https://github.com/hashicorp/consul

_consul-bin() {
    local -a sub=(
        'acl:ACL management'
        'agent:run a Consul agent'
        'catalog:catalog commands'
        'config:configuration entries'
        'connect:Consul Connect mesh'
        'debug:capture debug info'
        'event:fire an event'
        'exec:run a command on nodes'
        'force-leave:force a node to leave'
        'info:print server info'
        'intention:manage intentions'
        'join:join Consul agents'
        'keygen:generate gossip key'
        'keyring:keyring management'
        'kv:KV store commands'
        'leave:gracefully leave'
        'license:license commands'
        'lock:execute a command holding lock'
        'login:login via auth method'
        'logout:logout'
        'maint:maintenance mode'
        'members:list members'
        'monitor:tail logs'
        'namespace:namespaces (enterprise)'
        'operator:operator commands'
        'partition:admin partitions (enterprise)'
        'peering:peering commands'
        'reload:reload config'
        'rtt:network round-trip-time'
        'services:services'
        'snapshot:snapshot commands'
        'tls:TLS helpers'
        'troubleshoot:troubleshoot upstreams'
        'validate:validate config'
        'version:show version'
        'watch:watch for changes'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'consul subcommand' sub ;;
        args)
            case $words[1] in
                kv) _arguments '1:kv cmd:(delete export get import put)' '*:key:' ;;
                catalog) _arguments '1:catalog cmd:(datacenters nodes services)' '*:args:' ;;
                services) _arguments '1:services cmd:(deregister export register)' '*:args:' ;;
                agent) _arguments \
                    '-config-file+[config file]:file:_files' \
                    '-config-dir+[config dir]:dir:_files -/' \
                    '-data-dir+[data dir]:dir:_files -/' \
                    '-server[run as server]' \
                    '-ui[enable UI]' \
                    '-bind+[bind addr]:addr:' \
                    '-client+[client addr]:addr:' \
                    '-bootstrap-expect+[bootstrap expect]:n:' \
                    '-retry-join+[retry join]:host:_hosts' \
                    '-node+[node name]:name:' \
                    '-datacenter+[datacenter]:dc:' \
                    '-encrypt+[gossip key]:str:' \
                    '-log-level+[log level]:level:(trace debug info warn err)' ;;
            esac
            ;;
    esac
}

_consul-bin "$@"
