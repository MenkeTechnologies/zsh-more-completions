#compdef tsci
# Documentation: https://docs.tscircuit.com/intro/quickstart-cli
# tsci - tscircuit command line interface

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    init:initialize\ a\ new\ tscircuit\ project
    dev:start\ development\ server\ for\ a\ package
    build:run\ tscircuit\ eval\ and\ output\ circuit\ json
    export:export\ tscircuit\ code\ to\ various\ formats
    push:save\ package\ code\ to\ Registry\ API
    clone:clone\ a\ package\ from\ the\ registry
    add:add\ a\ component\ package\ to\ your\ project
    remove:remove\ a\ component\ package\ from\ your\ project
    install:install\ project\ dependencies
    update:update\ component\ packages\ to\ latest\ version
    auth:login/logout
    login:login\ to\ tscircuit\ registry
    logout:logout\ from\ tscircuit\ registry
    config:manage\ tscircuit\ CLI\ configuration
    snapshot:generate\ schematic\ and\ PCB\ snapshots
    transpile:transpile\ TypeScript/TSX\ to\ JavaScript
    setup:setup\ utilities\ like\ GitHub\ Actions
    doctor:run\ diagnostic\ checks
    check:partially\ build\ and\ validate\ circuit\ artifacts
    search:search\ for\ footprints\ CAD\ models\ or\ packages
    import:search\ JLCPCB\ or\ registry\ and\ import
    convert:convert\ a\ .kicad_mod\ footprint\ to\ a\ component
    simulate:run\ a\ simulation
    upgrade:upgrade\ CLI\ to\ the\ latest\ version
    version:print\ CLI\ version
  ))' \
  '*::arg:_files' && ret=0

return ret
