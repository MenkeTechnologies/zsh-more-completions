#compdef chefdk chef
# _chefdk — Chef chefdk legacy Chef Development Kit CLI managing cookbook creation generators verify habitat workflows policyfile install Berkshelf bundler dependency tooling deprecated in favor of Chef Workstation (chef team, Ruby); Thor
# upstream: https://github.com/chef/chef-dk

_chefdk() {
    local -a sub=(
        'gem:run RubyGems'
        'env:show env info'
        'exec:exec command in chefdk env'
        'generate:generate generators'
        'install:install policyfile cookbooks'
        'update:update policyfile lock'
        'push:push policyfile to server'
        'show-policy:show policyfile detail'
        'undelete:undelete policyfile'
        'diff:show diff'
        'export:export policyfile'
        'verify:verify chefdk installation'
        'shell-init:shell init script'
        'provision:provision a node'
        'apply:apply recipe'
        'clean-policy-cookbooks:clean policy cookbooks'
        'clean-policy-revisions:clean policy revisions'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--chef-license=+[mode]:m:(accept accept-no-persist accept-silent)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'chefdk subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '1:generator:(app cookbook recipe attribute file template repo policyfile resource provider lwrp helpers role environment data-bag template)' \
                    '*:name:' ;;
                install|update|push|show-policy|export) _arguments \
                    '-c+[Policyfile.rb]:file:_files -g "Policyfile.rb *.rb"' \
                    '--policyfile=+[file]:file:_files' \
                    '*:policyfile:_files -g "Policyfile.rb *.rb"' ;;
                shell-init) _arguments '1:shell:(bash zsh fish powershell sh)' ;;
                exec) _arguments '*:command:_command_names -e' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_chefdk "$@"
