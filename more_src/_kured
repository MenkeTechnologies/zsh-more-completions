#compdef kured
# _kured — Kubernetes reboot daemon (kubereboot/kured)
# upstream: https://github.com/kubereboot/kured
# Flags from cmd/kured/main.go (pflag).

_kured() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--node-id=[node ID to operate on]:id:'
        '--force-reboot[reboot even if drain fails]'
        '--metrics-host=[host to bind the Prometheus metrics endpoint]:host:'
        '--metrics-port=[port for the Prometheus metrics endpoint]:port:'
        '--drain-grace-period=[seconds to wait for pod termination]:seconds:'
        '--drain-pod-selector=[label selector for pods that block a drain]:selector:'
        '--skip-wait-for-delete-timeout=[skip wait if pod has DeletionTimestamp older than N]:seconds:'
        '--drain-delay=[wait before draining]:duration:'
        '--drain-timeout=[overall drain timeout]:duration:'
        '--reboot-delay=[wait after drain before reboot]:duration:'
        '--reboot-method=[how to trigger the reboot]:method:(command signal)'
        '--period=[between reboot-required checks]:duration:'
        '--ds-namespace=[namespace the kured DaemonSet runs in]:ns:'
        '--ds-name=[DaemonSet name]:name:'
        '--lock-annotation=[node annotation used as the reboot lock]:annotation:'
        '--lock-ttl=[reboot-lock time-to-live]:duration:'
        '--lock-release-delay=[delay before releasing the reboot lock]:duration:'
        '--prometheus-url=[Prometheus URL for the alert-filter blocker]:url:'
        '--alert-filter-regexp=[regex for alerts that block reboot]:regex:'
        '--alert-filter-match-only[invert: only block on matching alerts]'
        '--alert-firing-only[only consider firing alerts]'
        '--reboot-sentinel=[file whose presence indicates reboot-required]:path:_files'
        '--prefer-no-schedule-taint=[taint name applied during PreferNoSchedule phase]:taint:'
        '--reboot-sentinel-command=[command whose exit code indicates reboot-required]:cmd:'
        '--reboot-command=[command used to trigger the reboot]:cmd:'
        '--concurrency=[max nodes rebooting concurrently]:n:'
        '--reboot-signal=[signal number for the signal reboot method]:n:'
        '--slack-hook-url=[Slack incoming webhook URL]:url:'
        '--slack-username=[Slack username]:user:'
        '--slack-channel=[Slack channel]:channel:'
        '--notify-url=[shoutrrr notify URL]:url:'
        '--message-template-uncordon=[uncordon-message template]:template:'
        '--message-template-drain=[drain-message template]:template:'
        '--message-template-reboot=[reboot-message template]:template:'
        '*--blocking-pod-selector=[label selector for pods that block reboot]:selector:'
        '--reboot-days=[comma-separated days to allow reboot]:days:(mon tue wed thu fri sat sun)'
        '--start-time=[start of the reboot window]:HH\:MM:'
        '--end-time=[end of the reboot window]:HH\:MM\:SS:'
        '--time-zone=[timezone for the reboot window]:tz:'
        '--annotate-nodes[annotate nodes with reboot info]'
        '--log-format=[log format]:format:(text json)'
        '*--pre-reboot-node-labels=[labels to set on the node before reboot]:label:'
        '*--post-reboot-node-labels=[labels to set on the node after reboot]:label:'
    )
    _arguments -s $args
}

_kured "$@"
