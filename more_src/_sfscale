#compdef sfscale
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/main/scale.c
# Madagascar: scale data by maximum value along an axis or by a constant factor

local ret=1

_arguments -s \
  'axis=[scale by maximum in dimensions up to this axis]:axis' \
  'rscale=[scale by this factor]:rscale' \
  'dscale=[scale by this factor (works if rscale=0)]:dscale' \
  'pclip=[data clip percentile]:pclip' \
  '*:RSF file:_files' && ret=0

return ret
