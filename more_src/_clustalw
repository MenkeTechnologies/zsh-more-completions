#compdef clustalw clustalw2
# Documentation: http://www.clustal.org/download/clustalw_help.txt
# Reference accessed: 2026-05-17
# Verified: ClustalW2 upstream `-HELP` output. ClustalW uses
# single-dash long option names, =VALUE syntax, case-insensitive.
# `-OPTIONS` and `-CHECK` are the help/dump-options switches (no
# -h/-V analog).
# Removed from prior file: bogus man.archlinux.org search URL.

# ClustalW: progressive multiple sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-INFILE=[input sequence file]:file:_files' \
  '-PROFILE1=[profile 1 alignment]:file:_files' \
  '-PROFILE2=[profile 2 alignment]:file:_files' \
  '-ALIGN[do multiple alignment (default)]' \
  '-TREE[only compute guide tree]' \
  '-BOOTSTRAP=[bootstrap replicates]:n:' \
  '-PROFILE[profile alignment mode]' \
  '-SEQUENCES[align sequences to profile]' \
  '-TYPE=[DNA or PROTEIN]:type:(DNA PROTEIN)' \
  '-OUTFILE=[output alignment file]:file:_files' \
  '-OUTPUT=[output format]:format:(CLUSTAL GCG GDE PHYLIP PIR NEXUS FASTA)' \
  '-OUTPUTTREE=[tree output format]:format:(NJ PHYLIP DIST NEXUS)' \
  '-OUTORDER=[output order]:order:(INPUT ALIGNED)' \
  '-CASE=[character case]:case:(LOWER UPPER)' \
  '-SEQNO=[show sequence numbers]:bool:(ON OFF)' \
  '-SEQNOS=[show seq numbers]:bool:(ON OFF)' \
  '-GUIDETREE=[guide tree input file]:file:_files' \
  '-NEWTREE=[guide tree output file]:file:_files' \
  '-PWMATRIX=[pairwise scoring matrix]:matrix:(BLOSUM PAM GONNET ID)' \
  '-PWDNAMATRIX=[pairwise DNA matrix]:matrix:(IUB CLUSTALW)' \
  '-MATRIX=[full alignment scoring matrix]:matrix:(BLOSUM PAM GONNET ID)' \
  '-DNAMATRIX=[DNA scoring matrix]:matrix:(IUB CLUSTALW)' \
  '-GAPOPEN=[gap opening penalty]:val:' \
  '-GAPEXT=[gap extension penalty]:val:' \
  '-ENDGAPS[allow gaps at sequence ends]' \
  '-GAPDIST=[gap separation distance]:val:' \
  '-NOPGAP[don'\''t place gaps near hydrophobic residues]' \
  '-NOHGAP[don'\''t place gaps near hydrophilic residues]' \
  '-HGAPRESIDUES=[hydrophilic residues]:residues:' \
  '-MAXDIV=[%divergence for delayed alignment]:pct:' \
  '-TRANSWEIGHT=[transition weight]:val:' \
  '-NOWEIGHTS[disable sequence weighting]' \
  '-QUICKTREE[fast neighbour joining for guide tree]' \
  '-KIMURA[use Kimura distance correction]' \
  '-TOSSGAPS[ignore positions with any gap]' \
  '-RANGE=[start..end of alignment to output]:range:' \
  '-OPTIONS[show full option list]' \
  '-CHECK[show non-default options used]' \
  '*::clustal options:_files' && ret=0
return ret
