#compdef chpass chfn chsh
# _chpass — OpenBSD chpass (edit the user database via $EDITOR; chfn/chsh are aliases for /etc/passwd field editing; -s pre-sets shell, -a lets root supply a full passwd line)
# upstream: https://github.com/openbsd/src (usr.bin/chpass)
# Flags from usr.bin/chpass/chpass.1 on tip.

_chpass() {
    _arguments \
        '-a+[whole passwd line (root only)]:passwd-line:' \
        '-s+[new shell]:shell:_files -g "/bin/*sh /usr/local/bin/*"' \
        '1:user:_users'
}

_chpass "$@"
