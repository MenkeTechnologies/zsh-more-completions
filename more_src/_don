autoload -U is-at-least

_don() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[Path to the config file]:CONFIG:_files' \
'--config=[Path to the config file]:CONFIG:_files' \
'-v[Enable verbose output (timing info for lifecycle events)]' \
'--verbose[Enable verbose output (timing info for lifecycle events)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_don_commands" \
"*::: :->don" \
&& ret=0
    case $state in
    (don)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:don-command-$line[1]:"
        case $line[1] in
            (start)
_arguments "${_arguments_options[@]}" : \
'-p+[Run only services/tasks in this profile]:PROFILE:_default' \
'--profile=[Run only services/tasks in this profile]:PROFILE:_default' \
'*--log-filter=[Restrict displayed log lines to the given comma-separated set of service/task names. Affects pipe-mode output and seeds the TUI filter on startup (overriding any \`hidden = true\` defaults). Ring buffers and file sinks are unaffected — \`don logs <name>\` still returns full output. Example\: \`--log-filter=web,api,db\`]:LOG_FILTER:_default' \
'-c+[Path to the config file]:CONFIG:_files' \
'--config=[Path to the config file]:CONFIG:_files' \
'()-d[Start don in the background and exit once the daemon is launching]' \
'()--detached[Start don in the background and exit once the daemon is launching]' \
'--no-tui[Force pipe-mode output instead of the TUI, even on a TTY. Useful for CI, log capture, scripted shutdown tests, and any environment where the terminal doesn'\''t reliably answer DSR cursor queries]' \
'-v[Enable verbose output (timing info for lifecycle events)]' \
'--verbose[Enable verbose output (timing info for lifecycle events)]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Name of a stopped service to start (omit to start the daemon):_default' \
&& ret=0
;;
(stop)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to the config file]:CONFIG:_files' \
'--config=[Path to the config file]:CONFIG:_files' \
'-v[Enable verbose output (timing info for lifecycle events)]' \
'--verbose[Enable verbose output (timing info for lifecycle events)]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Name of the service to stop (omit to stop the daemon):_default' \
&& ret=0
;;
(restart)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to the config file]:CONFIG:_files' \
'--config=[Path to the config file]:CONFIG:_files' \
'-v[Enable verbose output (timing info for lifecycle events)]' \
'--verbose[Enable verbose output (timing info for lifecycle events)]' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Name of the service to restart:_default' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to the config file]:CONFIG:_files' \
'--config=[Path to the config file]:CONFIG:_files' \
'-v[Show detailed info\: watch paths, ports, build tool targets, commands]' \
