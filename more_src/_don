(( $+functions[_don_commands] )) ||
_don_commands() {
    local commands; commands=(
'start:Start services and run tasks' \
'stop:Stop the daemon, or stop one running service when a name is given' \
'restart:Restart a running service' \
'status:Show status of all services and tasks' \
'logs:View logs for a service or task' \
'attach:Interactively attach stdin/stdout to a running service' \
'cleanup:Clean up stale state from a previous run' \
'run:Run a task (bypasses auto_run)' \
'validate:Validate the config file' \
'version:Print the don version' \
'wisdom:' \
'completions:Print shell completion script to stdout' \
'init:Scaffold a starter don.toml in the current directory' \
'exec:Run a command with .don/bin on PATH (for downloaded binaries)' \
'__complete:Internal\: list names for shell completion scripts. Hidden from help' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'don commands' commands "$@"
}
