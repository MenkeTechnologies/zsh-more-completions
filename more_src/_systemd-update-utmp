#compdef systemd-update-utmp
# Documentation: source-direct extraction from upstream
# systemd/systemd src/update-utmp/update-utmp.c —
#   verb dispatch table at lines 55-105 (2 VERB_NOARG
#     declarations)
#   run() main dispatch at lines 107-119 (no parse_argv;
#     dispatch_verb directly on argv-skip-1)
#   audit hook at lines 64-67 + 94-97 (SYSTEM_BOOT and
#     SYSTEM_SHUTDOWN audit messages via libaudit)
# Reference accessed: 2026-05-30 via gh api.
#
# systemd-update-utmp writes utmp+wtmp records and audit log
# messages at boot and shutdown.  Invoked by the systemd-update-
# utmp.service / systemd-update-utmp-runlevel.service units.
# Not intended for direct user invocation but completes the
# corpus's systemd utility coverage.
#
# Critical extraction note: systemd-update-utmp is one of the
# SIMPLEST systemd binaries in terms of CLI surface — it has
# **NO parse_argv()** at all.  run() at lines 107-119 directly
# calls dispatch_verb(strv_skip(argv, 1), &c).  This means NO
# OPTION_COMMON_HELP / OPTION_COMMON_VERSION etc. — invoking
# `systemd-update-utmp --help` would dispatch to a verb named
# `--help` which doesn't exist (returns an error).  The tool
# is system-managed and not designed for direct user
# interaction.
#
# Critical extraction note: both verbs are VERB_NOARG with
# `/* help= */ NULL` — meaning they're INTENTIONALLY HIDDEN
# from any verb help table.  This is the systemd convention
# for "internal-use-only verbs".  Completion still surfaces
# them so users know what arguments the binary accepts.
#
# Critical extraction note: audit log messages decoded source-
# direct from lines 64-67 + 94-97 — `AUDIT_SYSTEM_BOOT` for
# reboot verb, `AUDIT_SYSTEM_SHUTDOWN` for shutdown verb.
# Both gated behind `#if HAVE_AUDIT`.

local -a subcommands=(
  'reboot:write reboot utmp record + AUDIT_SYSTEM_BOOT audit message (called by systemd-update-utmp.service at boot)'
  'shutdown:write shutdown utmp record + AUDIT_SYSTEM_SHUTDOWN audit message (called by systemd-update-utmp-runlevel.service at shutdown)'
)

_arguments \
  '1:verb:->subcmd'

case $state in
  subcmd)
    _describe -t subcommands 'systemd-update-utmp verb' subcommands
    ;;
esac
