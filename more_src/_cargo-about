#compdef cargo-about

# Zsh completion for cargo-about (Cargo license compliance tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'generate:generate license report'
      'init:initialize config file'
    )
    _describe -t commands 'cargo-about command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (generate)
        _arguments \
          '(-o --output-file)'{-o,--output-file}'[output file]:file:_files' \
          '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.toml"' \
          '--all-features[activate all features]' \
          '--no-default-features[disable default features]' \
          '--features[activate features]:features' \
          '--workspace[check entire workspace]' \
          '--manifest-path[path to Cargo.toml]:path:_files -g "Cargo.toml"' \
          '--format[output format]:format:(json handlebars)' \
          '--threshold[confidence threshold]:threshold:(0.0 0.5 0.8 0.9 1.0)' \
          '1:template:_files -g "*.hbs"' && ret=0
        ;;
      (init)
        _arguments \
          '--no-handlebars[do not create handlebars template]' && ret=0
        ;;
    esac
    ;;
esac

return ret
