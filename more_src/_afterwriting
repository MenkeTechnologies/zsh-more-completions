_afterwriting() {
    case "$service" in
        afterwriting-fonts)
            _arguments -s -S \
                '(-h --help)'{-h,--help}'[print help]' \
                '(-r --regular)'{-r,--regular=}'[regular weight TTF font file (required — only style strictly required)]:TTF file:_files -g "*.(ttf|TTF|otf|OTF)"' \
                '(-i --italic)'{-i,--italic=}'[italic weight TTF font file]:TTF file:_files -g "*.(ttf|TTF|otf|OTF)"' \
                '(-b --bold)'{-b,--bold=}'[bold weight TTF font file]:TTF file:_files -g "*.(ttf|TTF|otf|OTF)"' \
                '--bolditalic=[bold-italic weight TTF font file]:TTF file:_files -g "*.(ttf|TTF|otf|OTF)"' \
                '(-o --output)'{-o,--output=}'[output JS file embedding the fonts (consumed by `afterwriting --fonts`); .js extension optional]:output JS:_files -g "*.js"'
            ;;
        afterwriting|*)
            _arguments -s -S \
                '(- *)'{-h,--help}'[print help]' \
                '--source=[input Fountain script (.fountain) — REQUIRED]:input file:_files -g "*.fountain"' \
                '--pdf=[output PDF filename (omit value to derive from --source basename); prompts on overwrite unless --overwrite]:output PDF:_files -g "*.pdf"' \
                '--overwrite[overwrite existing output PDF without prompting]' \
                '--config=[JSON config file (schema in docs/clients.md: embolden_scene_headers / show_page_numbers / split_dialogue / print_title_page / print_profile a4|usletter / scenes_numbers none|left|right|both / each_scene_on_new_page / font_family / etc. + optional snippets dict)]:config JSON:_files -g "*.(json|JSON)"' \
                '*--setting=[override a setting as NAME=VALUE (repeatable; e.g. --setting print_title_page=false --setting scenes_numbers=both)]:NAME=VALUE:' \
                '--fonts=[custom-font JS file (generated by `afterwriting-fonts`); .js extension optional]:fonts JS:_files -g "*.js"'
            ;;
    esac
}

_afterwriting "$@"
