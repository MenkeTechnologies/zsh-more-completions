#compdef randgen
# Documentation: https://man.archlinux.org/search?q=randgen
# Reference accessed: 2026-05-16
# Source: cargo binstall randgen@0.2.0
# Probed via: --generate-completion zsh
# Repository: https://github.com/sorairolake/randgen

autoload -U is-at-least

_randgen() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-f+[Output in the specified output format]:FORMAT:((raw\:"Encode the generated bytes as raw bytes"
base64\:"Encode the generated bytes as base64"
base64url\:"Encode the generated bytes as URL-safe base64"
hex\:"Encode the generated bytes as hex string"))' \
'--format=[Output in the specified output format]:FORMAT:((raw\:"Encode the generated bytes as raw bytes"
base64\:"Encode the generated bytes as base64"
base64url\:"Encode the generated bytes as URL-safe base64"
hex\:"Encode the generated bytes as hex string"))' \
'-r+[Random number generator to use]:RNG:((chacha8\:"A CSPRNG that uses the ChaCha8 algorithm"
chacha12\:"A CSPRNG that uses the ChaCha12 algorithm"
chacha20\:"A CSPRNG that uses the ChaCha20 algorithm"
hc128\:"A CSPRNG that uses the HC-128 algorithm"
isaac\:"A PRNG that uses the ISAAC algorithm"
isaac64\:"A PRNG that uses the ISAAC-64 algorithm"
mt\:"The MT19937 PRNG"
mt64\:"The MT19937-64 PRNG"
pcg32\:"The pcg32 PRNG"
pcg64\:"The pcg64 PRNG"
pcg64dxsm\:"The PCG64DXSM PRNG"
pcg64mcg\:"The pcg64_fast PRNG"
sfc32\:"The sfc32 PRNG"
sfc64\:"The sfc64 PRNG"
splitmix64\:"The splitmix64 PRNG"
xorshift\:"The Xorshift PRNG"
xoroshiro64*\:"The xoroshiro64* PRNG"
xoroshiro64**\:"The xoroshiro64** PRNG"
xoroshiro128+\:"The xoroshiro128+ PRNG"
xoroshiro128++\:"The xoroshiro128++ PRNG"
xoroshiro128**\:"The xoroshiro128** PRNG"
xoshiro128+\:"The xoshiro128+ PRNG"
xoshiro128++\:"The xoshiro128++ PRNG"
xoshiro128**\:"The xoshiro128** PRNG"
xoshiro256+\:"The xoshiro256+ PRNG"
xoshiro256++\:"The xoshiro256++ PRNG"
xoshiro256**\:"The xoshiro256** PRNG"
xoshiro512+\:"The xoshiro512+ PRNG"
xoshiro512++\:"The xoshiro512++ PRNG"
xoshiro512**\:"The xoshiro512** PRNG"))' \
'--random-number-generator=[Random number generator to use]:RNG:((chacha8\:"A CSPRNG that uses the ChaCha8 algorithm"
chacha12\:"A CSPRNG that uses the ChaCha12 algorithm"
chacha20\:"A CSPRNG that uses the ChaCha20 algorithm"
hc128\:"A CSPRNG that uses the HC-128 algorithm"
isaac\:"A PRNG that uses the ISAAC algorithm"
isaac64\:"A PRNG that uses the ISAAC-64 algorithm"
mt\:"The MT19937 PRNG"
mt64\:"The MT19937-64 PRNG"
pcg32\:"The pcg32 PRNG"
pcg64\:"The pcg64 PRNG"
pcg64dxsm\:"The PCG64DXSM PRNG"
pcg64mcg\:"The pcg64_fast PRNG"
sfc32\:"The sfc32 PRNG"
sfc64\:"The sfc64 PRNG"
splitmix64\:"The splitmix64 PRNG"
xorshift\:"The Xorshift PRNG"
xoroshiro64*\:"The xoroshiro64* PRNG"
xoroshiro64**\:"The xoroshiro64** PRNG"
xoroshiro128+\:"The xoroshiro128+ PRNG"
xoroshiro128++\:"The xoroshiro128++ PRNG"
xoroshiro128**\:"The xoroshiro128** PRNG"
xoshiro128+\:"The xoshiro128+ PRNG"
xoshiro128++\:"The xoshiro128++ PRNG"
xoshiro128**\:"The xoshiro128** PRNG"
xoshiro256+\:"The xoshiro256+ PRNG"
xoshiro256++\:"The xoshiro256++ PRNG"
xoshiro256**\:"The xoshiro256** PRNG"
xoshiro512+\:"The xoshiro512+ PRNG"
xoshiro512++\:"The xoshiro512++ PRNG"
xoshiro512**\:"The xoshiro512** PRNG"))' \
'-s+[Random seed to use]:NUMBER:_default' \
'--seed=[Random seed to use]:NUMBER:_default' \
'--generate-completion=[Generate shell completion]:SHELL:((bash\:"Bash"
elvish\:"Elvish"
fish\:"fish"
nushell\:"Nushell"
powershell\:"PowerShell"
zsh\:"Zsh"))' \
'-p[Print information showing the progress of the output of the generated result. This progress bar does not indicate the progress of the generation of random bytes itself]' \
'--progress[Print information showing the progress of the output of the generated result. This progress bar does not indicate the progress of the generation of random bytes itself]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::bytes -- Number of bytes to generate:_default' \
&& ret=0
}

(( $+functions[_randgen_commands] )) ||
_randgen_commands() {
    local commands; commands=()
    _describe -t commands 'randgen commands' commands "$@"
}

if [ "$funcstack[1]" = "_randgen" ]; then
    _randgen "$@"
else
    compdef _randgen randgen
fi
