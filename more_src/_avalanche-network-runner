#compdef avalanche-network-runner
# _avalanche-network-runner — Ava Labs avalanche-network-runner CLI for managing local multi-node Avalanche test networks for plugin and subnet development (ava-labs team, Go); cobra
# upstream: https://github.com/ava-labs/avalanche-network-runner

_avalanche-network-runner() {
    local -a sub=(
        'server:start gRPC server'
        'control:control network'
        'ping:ping server'
        'rpc:make RPC call'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--log-level=+[level]:l:(off fatal error warn info debug trace verbo)' \
        '--log-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'avalanche-network-runner subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '--port=+[host:port]:str:' \
                    '--grpc-gateway-port=+[host:port]:str:' \
                    '--snapshots-dir=+[dir]:dir:_files -/' ;;
                control) _arguments \
                    '1:action:(start stop restart attach-peer add-node remove-node restart-node send-outbound-message status save-snapshot load-snapshot remove-snapshot get-snapshot-names health uris)' \
                    '--endpoint=+[host:port]:str:' \
                    '--exec-path=+[file]:file:_files' \
                    '--num-nodes=+[N]:n:' \
                    '--plugin-dir=+[dir]:dir:_files -/' \
                    '--custom-vms=+[csv]:str:' \
                    '--snapshot-name=+[name]:str:' \
                    '--whitelisted-subnets=+[csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_avalanche-network-runner "$@"
