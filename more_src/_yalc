#compdef yalc

# Zsh completion for yalc - local package development tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'publish:publish package to local store'
      'push:publish and update all installations'
      'add:add package from local store'
      'link:link package from local store'
      'update:update packages from local store'
      'remove:remove package'
      'retreat:remove packages and restore from backup'
      'check:check package.json for yalc references'
      'dir:show yalc store directory'
      'installations:show yalc installations'
    )
    _describe -t commands 'yalc command' commands && ret=0
    ;;
  args)
    case $line[1] in
      publish|push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--changed[publish only if package changed]' \
          '--force[force publish]' \
          '--no-scripts[do not run pre/post scripts]' \
          '--private[publish private packages]' \
          '--content[show files to be published]' \
          '--push[push update to installations]' \
          '--replace[force replace package content]' \
          '--sig[use custom script signature]' \
          '--scripts[run pre/post scripts]' \
          '--no-sig[do not use script signature]' && ret=0
        ;;
      add|link)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dev[add as devDependency]' \
          '--pure[do not touch package.json or lock file]' \
          '--link[create symlink]' \
          '--file[copy files instead of link]' \
          '--workspace[use workspace protocol]' \
          '*:package' && ret=0
        ;;
      update|remove|retreat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[apply to all packages]' \
          '*:package' && ret=0
        ;;
    esac
    ;;
esac

return ret
