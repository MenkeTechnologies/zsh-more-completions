#compdef yalc
# Documentation: https://github.com/wclr/yalc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for yalc - local npm package development tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--quiet[suppress output]' \
  '--no-colors[disable colored text]' \
  '--store-folder=[override default store location]:dir:_files -/' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'publish:copy publishable files to local store'
      'push:publish and propagate changes to installations'
      'add:install a package from store into project'
      'link:create symlink from .yalc to node_modules'
      'update:update package(s) from store'
      'remove:remove package from project'
      'retreat:temporarily revert packages'
      'restore:reactivate retreated packages'
      'check:validate package.json for yalc dependencies'
      'dir:show yalc store directory location'
      'installations:manage installations records'
    )
    _describe -t commands 'yalc command' commands && ret=0
    ;;
  args)
    case $line[1] in
      publish)
        _arguments -s -S \
          '--no-scripts[skip lifecycle scripts]' \
          '--sig[add hash signature to version]' \
          '--content[display included files]' \
          '--no-workspace-resolve[omit workspace protocol resolution]' \
          '--push[push to installations after publish]' \
          '--changed[only publish if changed]' \
          '--private[publish private packages]' \
          '--force[force publish]' \
          '--scripts[run pre/post scripts]' && ret=0
        ;;
      push)
        _arguments -s -S \
          '--changed[only push if content changed]' \
          '--replace[force replacement]' \
          '--update[run package manager update]' \
          '--scripts[execute pre/post scripts]' \
          '--no-scripts[skip lifecycle scripts]' \
          '--sig[add hash signature]' && ret=0
        ;;
      add)
        _arguments -s -S \
          '--link[create link: dependency instead of file:]' \
          '--dev[add to devDependencies]' \
          '--pure[do not modify package.json or modules]' \
          '(-W --workspace)'{-W,--workspace}'[use workspace: protocol]' \
          '*:package' && ret=0
        ;;
      link)
        _arguments -s -S \
          '*:package' && ret=0
        ;;
      update)
        _arguments -s -S \
          '--update[run package manager update command]' \
          '--upgrade[alias for --update]' \
          '--up[alias for --update]' \
          '*:package' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '--all[remove all yalc packages]' \
          '*:package' && ret=0
        ;;
      retreat)
        _arguments -s -S \
          '--all[retreat all packages]' \
          '*:package' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '*:package' && ret=0
        ;;
      installations)
        _arguments -s -S \
          '1:subcommand:(show clean)' \
          '*:package' && ret=0
        ;;
    esac
    ;;
esac

return ret
