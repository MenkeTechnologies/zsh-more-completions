#compdef capa

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --rules)*'{-r+,--rules=}'[path to rules directory or file]:path:_files' \
  '(-s --signatures)*'{-s+,--signatures=}'[path to signatures directory or file]:path:_files' \
  '(-v --verbose -vv)'{-v,--verbose}'[verbose output]' \
  '(-v --verbose)-vv[very verbose output]' \
  '-q[quiet output, only matches]' \
  '(-j --json)'{-j,--json}'[output JSON]' \
  '--color=[colorize output]:mode:(auto always never)' \
  '(-f --format)'{-f+,--format=}'[input format]:format:(auto pe elf macho dotnet sc32 sc64 cape vmray dexray drakvuf freeze)' \
  '(-b --backend)'{-b+,--backend=}'[analysis backend]:backend:(vivisect ghidra ida binja pefile dnfile freeze)' \
  '--os=[target operating system]:os:(auto windows linux macos)' \
  '--arch=[target architecture]:arch:(auto x86 amd64 arm aarch64)' \
  '(-t --tag)*'{-t+,--tag=}'[filter rules by metadata value]:tag:' \
  '--restrict-to-functions=[comma-separated function VAs]:list:' \
  '--restrict-to-processes=[comma-separated PIDs]:list:' \
  '--rules-version=[rules version]:version:' \
  '--debug[enable debug logging]' \
  '*::file:_files' && ret=0

return ret
