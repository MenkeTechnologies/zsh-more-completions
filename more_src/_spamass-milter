#compdef spamass-milter
# Documentation: https://man.archlinux.org/search?q=spamass-milter
# Reference accessed: 2026-05-16

# spamass-milter: SpamAssassin integration as a sendmail/postfix milter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-D[debug to syslog]' \
  '-d[debug level]:n:' \
  '-f[detach (daemonize)]' \
  '-i[ignore networks (CIDR list)]:list:' \
  '-m[do not modify body]' \
  '-M[disable Auth-Results]' \
  '-p[milter socket]:path:_files' \
  '-P[PID file]:file:_files' \
  '-r[reject score]:score:' \
  '-u[run as user]:user:_users' \
  '-R[reject text]:text:' \
  '-x[don'\''t modify subject]' \
  '-g[group]:group:_groups' \
  '-b[forward to spam-bouncer addr]:addr:' \
  '-B[bcc address]:addr:' \
  '-e[exempt accounts from rejection]:list:' \
  '-I[ignore auth users]' \
  '-s[set max message size]:bytes:' \
  '*::spamass-milter args:_files' && ret=0
return ret
