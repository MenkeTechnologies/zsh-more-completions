#compdef oshrun
# Documentation: https://www.open-mpi.org/doc/v3.0/man1/oshrun.1.php
# Reference accessed: 2026-05-16
# Verified: Open MPI v3 oshrun(1) manpage. oshrun is an alias of
# mpirun/orterun/shmemrun when Open MPI is built with OpenSHMEM.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing the full mpirun flag set.

# oshrun: OpenSHMEM launcher (mpirun alias)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-np -n -c --n)'{-np+,-n+,-c+,--n=}'[number of processes]:n:' \
  '-N+[per-node process count]:n:' \
  '-npersocket+[per-socket count]:n:' \
  '-npernode+[per-node count]:n:' \
  '-pernode[one per node]' \
  '(-H --host)'{-H+,--host=}'[host list]:hosts:_hosts' \
  '-hostfile=[host file]:file:_files' \
  '--default-hostfile=[default host file]:file:_files' \
  '-machinefile=[machine file]:file:_files' \
  '-cpu-set=[CPU set list]:list:' \
  '-nolocal[do not run on local node]' \
  '--map-by=[mapping policy]:spec:' \
  '--rank-by=[ranking policy]:spec:' \
  '--bind-to=[binding policy]:spec:' \
  '(-rf --rankfile)'{-rf+,--rankfile=}'[rank file]:file:_files' \
  '--report-bindings[report bindings]' \
  '-output-filename=[output filename prefix]:path:_files' \
  '-stdin=[stdin rank]:rank:' \
  '-merge-stderr-to-stdout[merge stderr to stdout]' \
  '-tag-output[tag output lines]' \
  '-timestamp-output[timestamp output]' \
  '-xml[XML output]' \
  '-xterm=[ranks for xterm]:ranks:' \
  '--prefix=[install prefix]:path:_files -/' \
  '--noprefix[no prefix]' \
  '(-s --preload-binary)'{-s,--preload-binary}'[preload binary on target]' \
  '--preload-files=[preload files]:list:' \
  '(-wdir -wd)'{-wdir+,-wd+}'[working directory]:path:_files -/' \
  '-x[export env var]:var:' \
  '-path=[search path]:path:' \
  '-mca[set MCA parameter]:key value:' \
  '-gmca[set global MCA parameter]:key value:' \
  '-tune=[tune file]:file:_files' \
  '-debug[enable debug]' \
  '--get-stack-traces[get stack traces]' \
  '--timeout=[timeout seconds]:s:' \
  '-tv[start under totalview]' \
  '-display-map[display process map]' \
  '-display-allocation[display allocation]' \
  '-output-proctable[output proctable]' \
  '--allow-run-as-root[allow run as root]' \
  '--app=[app file]:file:_files' \
  '-enable-recovery[enable recovery]' \
  '-max-restarts=[max restarts]:n:' \
  '--ompi-server=[OMPI server URI]:uri:' \
  '--personality=[personality]:name:' \
  '*::command:_normal' && ret=0
return ret
