#compdef yappi

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[Profile builtins]' \
  '-c[Clock type]:clock type:(cpu wall)' \
  '-o[Output file]:file:_files' \
  '-f[Output format]:format:(pstat callgrind ystat)' \
  '-s[Sort type]:sort type:(name ncall ttot tsub tavg)' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '*:script and arguments:_files -g "*.py"' && ret=0

return ret
