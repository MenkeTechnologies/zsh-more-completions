#compdef auto

# Intuit Auto release tool completion

_auto_subcommands() {
  local -a subcmds=(
    'init:Initialize Auto configuration'
    'create-labels:Create labels on the project'
    'label:Get the label for a pull request'
    'pr-check:Check that a PR has a valid label'
    'pr-status:Set the status on a PR commit'
    'pr-body:Update the PR body with release notes'
    'comment:Add a comment to a PR or issue'
    'version:Get the version bump for the next release'
    'changelog:Generate a changelog'
    'release:Create a release'
    'shipit:Run the full release pipeline'
    'latest:Get the latest release'
    'next:Get the next release version'
    'canary:Create a canary release'
    'info:Display project information'
  )
  _describe -t commands 'auto subcommand' subcmds
}

_auto() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--verbose[enable verbose logging]' \
    '*--plugins=[plugins to use]:plugin' \
    '--no-verify[skip verification steps]' \
    '--dry-run[perform a dry run]' \
    '--from=[git ref to start from]:ref' \
    '--use-version=[use a specific version]:version' \
    '--base-branch=[base branch name]:branch' \
    '--only-publish-with-release-label[only publish with release label]' \
    '1:subcommand:_auto_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        shipit|release|canary|next)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--dry-run[perform a dry run]' \
            '--from=[git ref to start from]:ref' \
            '--use-version=[use a specific version]:version' \
            '--base-branch=[base branch name]:branch' \
            '--only-publish-with-release-label[only publish with release label]'
          ;;
        changelog)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--dry-run[perform a dry run]' \
            '--from=[git ref to start from]:ref' \
            '--to=[git ref to end at]:ref'
          ;;
        pr-check|pr-status|pr-body|comment|label)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--pr=[pull request number]:pr number' \
            '--dry-run[perform a dry run]'
          ;;
        create-labels)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--dry-run[perform a dry run]'
          ;;
        init)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        info)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        version)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--from=[git ref to start from]:ref'
          ;;
      esac
      ;;
  esac
}

_auto "$@"
