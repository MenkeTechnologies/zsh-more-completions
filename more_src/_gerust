#compdef gerust
# Documentation: https://man.archlinux.org/search?q=gerust
# Reference accessed: 2026-05-16

# Zsh completion for gerust Axum project generator (mainmatter/gerust).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--outdir=[output directory]:directory:_directories' \
  '--full[full blueprint with examples]' \
  '--minimal[minimal blueprint without database]' \
  '--no-vcs[skip git init]' \
  '--no-color[disable colored output]' \
  '--debug[verbose debug output]' \
  '1:workspace name:'
