#compdef gerust
# Documentation: https://github.com/mainmatter/gerust
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gerust Axum project generator (mainmatter/gerust).
# CLI flags from src/main.rs clap derive.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --outdir)'{-o,--outdir}'=[output directory]:directory:_directories' \
  '(-f --full)'{-f,--full}'[full blueprint with examples]' \
  '(-m --minimal)'{-m,--minimal}'[minimal blueprint without database]' \
  '--no-vcs[skip VCS init]' \
  '--no-color[disable colored output]' \
  '--debug[verbose debug output]' \
  '1:workspace name:'
