#compdef ideasUnvToFoam
# Converts an I-Deas unv format mesh to OpenFOAM format

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-dump[dump boundary faces as boundaryFaces.obj (for debugging)]' \
  '-region+[specify the mesh region]:region:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':.unv file:_files -g "*.unv"' && ret=0

return ret
