#compdef edb-psql edbpsql
# Documentation: https://www.enterprisedb.com/docs/epas/latest/installing/linux_install_details/managing_an_advanced_server_installation/connecting_to_epas/
# edb-psql - EDB Postgres Advanced Server interactive terminal (psql variant)

local ret=1

_arguments -s \
  '(-a --echo-all)'{-a,--echo-all}'[echo all input from script]' \
  '(-A --no-align)'{-A,--no-align}'[unaligned table output mode]' \
  '(-b --echo-errors)'{-b,--echo-errors}'[echo failed commands]' \
  '*'{-c,--command=}'[run only single command and exit]:command' \
  '(-d --dbname)'{-d,--dbname=}'[database name to connect to]:database' \
  '(-e --echo-queries)'{-e,--echo-queries}'[echo commands sent to server]' \
  '(-E --echo-hidden)'{-E,--echo-hidden}'[display queries that backslash commands generate]' \
  '(-f --file)'{-f,--file=}'[execute commands from file then exit]:file:_files' \
  '(-F --field-separator)'{-F,--field-separator=}'[field separator for unaligned output]:sep' \
  '(-H --html)'{-H,--html}'[HTML table output mode]' \
  '(-l --list)'{-l,--list}'[list available databases then exit]' \
  '(-L --log-file)'{-L,--log-file=}'[send session log to file]:file:_files' \
  '(-n --no-readline)'{-n,--no-readline}'[disable enhanced command line editing]' \
  '(-o --output)'{-o,--output=}'[send query results to file]:file:_files' \
  '(-P --pset)'{-P,--pset=}'[set printing option]:option' \
  '(-q --quiet)'{-q,--quiet}'[run quietly (no messages)]' \
  '(-R --record-separator)'{-R,--record-separator=}'[record separator for unaligned output]:sep' \
  '(-s --single-step)'{-s,--single-step}'[single-step mode (confirm each query)]' \
  '(-S --single-line)'{-S,--single-line}'[single-line mode (newline ends command)]' \
  '(-t --tuples-only)'{-t,--tuples-only}'[print rows only]' \
  '(-T --table-attr)'{-T,--table-attr=}'[set HTML table tag attributes]:attr' \
  '*'{-v,--set=,--variable=}'[set psql variable NAME to VALUE]:assignment' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
  '(-W --password)'{-W,--password}'[force password prompt]' \
  '(-x --expanded)'{-x,--expanded}'[expanded table output mode]' \
  '(-X --no-psqlrc)'{-X,--no-psqlrc}'[do not read startup file]' \
  '(-z --field-separator-zero)'{-z,--field-separator-zero}'[set field separator to zero byte]' \
  '(-0 --record-separator-zero)'{-0,--record-separator-zero}'[set record separator to zero byte]' \
  '(-1 --single-transaction)'{-1,--single-transaction}'[execute as a single transaction]' \
  '(-? --help)'{-\?,--help=}'[show help (options/commands/variables)]' \
  '(-h --host)'{-h,--host=}'[database server host or socket directory]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[database server port]:port' \
  '(-U --username)'{-U,--username=}'[database user name]:user' \
  '*:database:_files' && ret=0

return ret
