#compdef pd-simulator
# _pd-simulator — TiKV PD scheduler simulator
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-simulator/main.go on tip.

_pd-simulator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--pd-endpoints=[PD address(es)]:csv:' \
        '--config=[simulator config TOML file]:file:_files -g "*.toml"' \
        '--case=[simulator case name]:name:' \
        '--serverLog=[PD server log level]:level:(debug info warn error)' \
        '--simLog=[simulator log level]:level:(debug info warn error)' \
        '--log-file=[simulator log file]:file:_files' \
        '--status-addr=[status endpoint bind host\:port]:host\:port:'
}

_pd-simulator "$@"
