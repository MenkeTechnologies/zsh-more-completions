#compdef gevgen_ndcy
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gNucleonDecayEvGen.cxx
# gevgen_ndcy - GENIE nucleon decay event generation application

local ret=1

_arguments -s -S \
  '(-h)-h[show syntax and exit]' \
  '-r[MC run number (default 1000)]:run:' \
  '-n[number of events to generate]:nevents:' \
  '-m[nucleon decay mode ID]:mode:' \
  '-N[decayed nucleon PDG code (2212 proton, 2112 neutron)]:pdg:' \
  '-g[input geometry: ROOT file or target mix]:geom:_files' \
  '-L[geometry length units (default mm)]:units:' \
  '-D[geometry density units (default g_cm3)]:units:' \
  '-t[top volume name for event generation]:topvol:' \
  '-o[output event file prefix (default gntp)]:prefix:' \
  '--seed[random number seed]:seed:' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '--event-record-print-level[verbosity for event record output]:level:' \
  '--mc-job-status-refresh-rate[status file update frequency]:rate:' \
  '*: :_files' && ret=0

return ret
