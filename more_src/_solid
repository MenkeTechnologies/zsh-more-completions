#compdef solid solid-cli
# _solid — SolidJS reactive UI framework CLI (Ryan Carniato / SolidJS team, TypeScript); commander
# upstream: https://github.com/solidjs/solid

_solid() {
    local -a sub=(
        'create:scaffold a new project'
        'dev:start dev server'
        'build:build for production'
        'preview:preview production build'
        'serve:serve production build'
        'test:run tests'
        'lint:run lints'
        'docs:open documentation'
        'add:add an integration/plugin'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'solid subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:name:' \
                    '--template=+[template]:t:(bare ts hackernews todomvc with-tailwindcss with-prisma with-trpc with-auth with-mdx)' \
                    '--git[git init]' \
                    '--no-install[no install]' ;;
                add) _arguments \
                    '*:integration:(tailwindcss prisma trpc auth mdx vitest playwright)' ;;
                dev|build|preview|serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '--open[open browser]' \
                    '--no-open[no open]' \
                    '--mode=+[mode]:m:(development production preview)' \
                    '*:arg:' ;;
                test) _arguments '*:pattern:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_solid "$@"
