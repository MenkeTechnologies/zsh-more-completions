#compdef sysdig-cli sysdigcli
# _sysdig-cli — Sysdig sysdig-cli CLI command-line frontend to the Sysdig Secure Sysdig Monitor SaaS observability and security platform managing teams users notifications-channels policies vulnerability-scanning compliance-audit cloud-security-agent installation onboarding-agent dashboards alerts events-feed runtime-security visibility (Sysdig team, Go); cobra
# upstream: https://sysdig.com/

_sysdig-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'team:team management'
        'user:user management'
        'notification:notification channels'
        'policy:security policy management'
        'rules:falco rules management'
        'list:list resources'
        'image:image scanning'
        'fs:filesystem scanning'
        'iac:infrastructure-as-code scanning'
        'k8s:Kubernetes security'
        'aws:AWS integration'
        'gcp:GCP integration'
        'azure:Azure integration'
        'profile:profile management'
        'event:event ingestion'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--region=+[r]:r:(us1 us2 us3 us4 eu1 eu2 ap1 au1)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sysdig-cli subcommand' sub ;;
        args)
            case $words[1] in
                image|fs|iac) _arguments \
                    '--detail[show detail]' \
                    '--severity=+[s]:s:(critical high medium low negligible unknown)' \
                    '--pull=+[when]:w:(always missing never)' \
                    '*:target:_files' ;;
                team|user|notification|policy|rules) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_sysdig-cli "$@"
