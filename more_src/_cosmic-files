#compdef cosmic-files
# _cosmic-files — COSMIC desktop file manager (pop-os/cosmic-files)
# upstream: https://github.com/pop-os/cosmic-files
# Args from src/lib.rs (env::args; --no-daemon plus path positionals).

_cosmic-files() {
    _arguments \
        '--no-daemon[do not daemonize]' \
        '*:directory or file to open:_files'
}

_cosmic-files "$@"
