#compdef so
# Documentation: https://github.com/samtay/so
# Reference accessed: 2026-05-21
# Verified: upstream samtay/so README CLI documentation.
# Removed from prior file: fabricated -t/--type, -l/--limit, -q/--query,
# -V/--version (-h prints version + help in this CLI).

# Zsh completion for so (StackOverflow CLI)

_arguments -s -S \
  '*'{-s,--site=}'[StackExchange site to search (repeatable)]:site:' \
  '(-e --engine)'{-e,--engine=}'[search engine to use]:engine:(google duckduckgo stackexchange)' \
  '--lucky[enable lucky mode]' \
  '--set-api-key=[configure StackExchange API key]:key:' \
  '(- *)'{-h,--help}'[show help and current defaults]' \
  '*:query:' && return 0
