#compdef syncthing-cli
# Command-line interface for Syncthing file synchronization

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--endpoint[API endpoint]:url:' \
  '--apikey[API key]:key:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:show or modify configuration'
      'errors:show recent errors'
      'id:show device ID'
      'index:show index'
      'status:show system status'
      'restart:restart Syncthing'
      'shutdown:shut down Syncthing'
    )
    _describe -t commands 'syncthing-cli command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
