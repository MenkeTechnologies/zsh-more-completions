#compdef ansible-sign
# Documentation: https://github.com/ansible/ansible-sign
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcommands=(
      'project:sign or verify Ansible project content'
    )
    _describe -t commands 'ansible-sign subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      project)
        local -a project_subcommands=(
          'gpg-sign:sign an Ansible project with GPG'
          'gpg-verify:verify GPG signature of an Ansible project'
        )
        _arguments -C \
          '(- *)--help[show help]' \
          '1: :->project_cmd' \
          '*:: :->project_args' && ret=0
        case $state in
          project_cmd)
            _describe -t commands 'project subcommand' project_subcommands && ret=0
            ;;
          project_args)
            _arguments \
              '(- *)--help[show help]' \
              '--fingerprint[GPG fingerprint]:fingerprint: ' \
              '--gnupg-home[GnuPG home directory]:directory:_directories' \
              '*:project directory:_directories' && ret=0
            ;;
        esac
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
