#compdef prof2-ipol
# Documentation: https://professor.hepforge.org/docs.sphinx213/prof2-ipol.html
# prof2-ipol - Professor2 build interpolation file from per-run histograms

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--pname --pfile)'{--pname,--pfile}'=[name of the params file in each run directory]:name:' \
  '--limits=[text file with parameter limits and fixed parameters]:file:_files' \
  '--wfile=[weight file restricting ipol building to a subset of bins]:file:_files' \
  '--order=[global order of interpolation polynomials]:order:' \
  '--ierr=[how to interpolate MC errors]:mode:(none mean median symm)' \
  '--eorder=[order of polynomials for uncertainty interpolation]:order:' \
  '--rc=[run combination file]:file:_files' \
  '-j[number of threads to use]:threads:' \
  '--summ=[summary description written to the ipol output file]:text:' \
  '(-v --debug)'{-v,--debug}'[turn on debug messages]' \
  '(-q --quiet)'{-q,--quiet}'[turn off messages]' \
  '--split=[incorporate a linear split in parameter space]:split:' \
  '1:runsdir:_files -/' \
  '2:ipolfile:_files' && ret=0

return ret
