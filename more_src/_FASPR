#compdef FASPR
# Documentation: https://github.com/tommyhuangthu/FASPR
# FASPR fast and accurate protein side-chain packing

local ret=1

_arguments -s -S \
  '-i+[input backbone PDB file for packing]:input:_files -g "*.pdb"' \
  '-o+[output repacked model PDB file]:output:_files -g "*.pdb"' \
  '-s+[sequence file (one-letter codes) for mutation/fixing]:sequence:_files' \
  '*:file:_files' && ret=0

return ret
