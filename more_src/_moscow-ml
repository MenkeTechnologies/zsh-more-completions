#compdef mosml mosmlc mosmllex mosmlyac mosmltop

local curcontext="$curcontext" state line ret=1

case $service in
  (mosml|mosmltop)
    _arguments -C \
      '-h[show help]' \
      '-help[show help]' \
      '-version[show version]' \
      '-quietdec[quiet declarations]' \
      '-noheader[no startup header]' \
      '-perv+[load pervasives]:b:(true false)' \
      '-stdlib+[stdlib path]:dir:_files -/' \
      '-I+[include dir]:dir:_files -/' \
      '-imptypes+[implicit types]:b:(true false)' \
      '-valuepoly+[value poly]:b:(true false)' \
      '-conservative[conservative mode]' \
      '-impure[impure mode]' \
      '*: :_files -g "*.sml *.sig *.ui *.uo"' && ret=0 ;;
  (mosmlc)
    _arguments -C \
      '-h[help]' \
      '-c[compile only]' \
      '-o+[output]:file:_files' \
      '-I+[include dir]:dir:_files -/' \
      '-stdlib+[stdlib path]:dir:_files -/' \
      '-imptypes[implicit types]' \
      '-noheader[no header]' \
      '-perv+[pervasives]:b:(true false)' \
      '-toplevel[generate toplevel]' \
      '-structure[structure mode]' \
      '-files+[files of files]:file:_files' \
      '-orthodox[orthodox mode]' \
      '-verbose[verbose]' \
      '-quotation[quotation]' \
      '-msgstyle+[msg style]:s:(short long)' \
      '*: :_files -g "*.sml *.sig *.ui *.uo *.c *.o"' && ret=0 ;;
  (mosmllex)
    _arguments -C \
      '-h[help]' \
      '-o+[output]:file:_files' \
      '*: :_files -g "*.lex"' && ret=0 ;;
  (mosmlyac)
    _arguments -C \
      '-h[help]' \
      '-v[verbose]' \
      '-b+[base name]:name:' \
      '-q[quiet]' \
      '*: :_files -g "*.grm"' && ret=0 ;;
esac

return ret
