#compdef dspy-cli
# Documentation: https://github.com/stanfordnlp/dspy-cli
# Reference accessed: 2026-05-22
# Verified: dspy-cli --help Typer/Click CLI.

# Zsh completion for dspy-cli - DSPy project scaffolding and serve CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dspy-cli command' \
      'new[create new DSPy project]' \
      'generate[generate components in project]' \
      'g[alias for generate]' \
      'serve[start HTTP API server for DSPy programs]' \
      's[alias for serve]' && ret=0
    ;;
esac

return ret
