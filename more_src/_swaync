#compdef swaync
# Documentation: https://github.com/ErikReider/SwayNotificationCenter/blob/main/src/main.vala
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swaync (SwayNotificationCenter daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --style)'{-s,--style}'[custom stylesheet file]:style file:_files -g "*.css"' \
  '(-c --config)'{-c,--config}'[custom config file]:config file:_files -g "*.json"' \
  '--skip-system-css[skip parsing packaged stylesheet]' \
  '--custom-system-css[custom CSS file as system CSS]:file:_files -g "*.css"' \
  '--replace[replace existing running instance]' && ret=0

return ret
