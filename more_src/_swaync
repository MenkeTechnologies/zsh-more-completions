#compdef swaync

# Zsh completion for swaync (Sway Notification Center daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file]:config file:_files -g "*.json"' \
  '(-s --style)'{-s,--style}'[style CSS file]:style file:_files -g "*.css"' \
  '(-l --log-level)'{-l,--log-level}'[log level]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
