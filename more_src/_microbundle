#compdef microbundle

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build the library'
  'watch:build and watch for changes'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-i+[entry module]:entry:_files' \
  '--entry=[entry module]:entry:_files' \
  '-o+[output directory]:directory:_directories' \
  '--output=[output directory]:directory:_directories' \
  '-f+[output format]:format:(modern es cjs umd)' \
  '--format=[output format]:format:(modern es cjs umd)' \
  '--target=[JS syntax target]:target:(node web)' \
  '--external=[external dependencies]:dependencies' \
  '--globals=[global variable names]:globals' \
  '--define=[compile-time definitions]:definitions' \
  '--alias=[module aliases]:aliases' \
  '--compress=[enable compression]:compress:(true false)' \
  '--no-compress[disable compression]' \
  '--strict[enforce undefined global context]' \
  '--name=[UMD global name]:name' \
  '--cwd=[working directory]:directory:_directories' \
  '--sourcemap=[generate source map]:sourcemap:(true false inline)' \
  '--raw[skip Babel transforms]' \
  '--jsx=[JSX pragma]:pragma' \
  '--jsxFragment=[JSX fragment pragma]:pragma' \
  '--jsxImportSource=[JSX import source]:source' \
  '--tsconfig=[tsconfig path]:file:_files -g "tsconfig*.json"' \
  '--generateTypes=[generate TypeScript types]:generate:(true false)' \
  '--css=[CSS handling]:css:(inline modules)' \
  '--css-modules=[CSS modules behavior]:behavior:(true false)' \
  '--workers=[use worker threads]:workers:(true false)' \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'microbundle command' commands && ret=0
    ;;
esac

return ret
