#compdef xrdp-sesman
# Documentation: https://manpages.debian.org/bookworm/xrdp/xrdp-sesman.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-k --kill)'{-k,--kill}'[kill running xrdp-sesman daemon]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[run in foreground]' \
  '--dump-config[print configuration]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files'
