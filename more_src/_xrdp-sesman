#compdef xrdp-sesman

_arguments -s \
  '(-k --kill)'{-k,--kill}'[kill running xrdp-sesman daemon]' \
  '(-r --reload)'{-r,--reload}'[reload configuration]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[run in foreground]' \
  '--dump-config[print configuration]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files'
