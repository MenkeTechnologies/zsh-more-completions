#compdef click-cli
# _click-cli — Armin Ronacher Click Python command-line library boilerplate CLI alias (Pallets, Python); custom argparse
# upstream: https://github.com/pallets/click

_click-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '*:arg:'
}

_click-cli "$@"
