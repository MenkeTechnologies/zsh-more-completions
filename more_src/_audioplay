#compdef audioplay
# Documentation: man audioplay(1)
# Source: netbsd/src usr.bin/audio/play — play audio files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[write block size]:buffersize:_default' \
    '-b+[balance level (0-63)]:balance:_default' \
    '-c+[number of channels (requires -f)]:channels:_default' \
    '-d+[audio device (default /dev/sound)]:device:_files' \
    '-e+[audio encoding (requires -f)]:encoding:(mulaw ulaw alaw slinear linear ulinear adpcm slinear_le linear_le ulinear_le slinear_be linear_be ulinear_be)' \
    '-P+[sample precision in bits (requires -f)]:precision:(4 8 16 24 32)' \
    '-p+[output port]:port:(speaker headphone line)' \
    '-s+[sample rate (requires -f)]:sample rate:_default' \
    '-v+[volume/gain (0-255)]:volume:_default' \
    '-f[force playback despite unknown format]' \
    '(- *)-h[display help message]' \
    '-i[exit immediately if device unavailable]' \
    '-n[parse files without writing audio data]' \
    '-q[suppress output]' \
    '-V[verbose output]' \
    '*:audio file:_files' \
    && ret=0

return ret
