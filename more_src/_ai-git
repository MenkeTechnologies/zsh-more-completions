#compdef ai-git
# Documentation: https://github.com/sadiksaifi/ai-git
# Reference accessed: 2026-05-23
# Verified: upstream README ai-git --help (@ai-git/cli npm package).

# Zsh completion for ai-git - AI-powered conventional commit message generator

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'configure:set up AI provider and model'
  'upgrade:update ai-git to the latest version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--provider=[AI provider for this run]:provider:(claude-code gemini-cli codex opencode pi openrouter openai google-ai-studio anthropic cerebras)' \
  '--model=[model id for this run]:model:' \
  '(-A --stage-all)'{-A,--stage-all}'[stage all changes before generating]' \
  '(-C --commit)'{-C,--commit}'[commit without confirmation]' \
  '(-P --push)'{-P,--push}'[push to remote after committing]' \
  '(-H --hint)'{-H+,--hint=}'[guide the AI with additional context]:hint:' \
  '(-X --exclude)'{-X+,--exclude=}'[skip files when staging]:pattern:' \
  '--dangerously-auto-approve[stage, commit, and push without prompts]' \
  '--dry-run[preview prompt without calling the AI]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'ai-git command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
