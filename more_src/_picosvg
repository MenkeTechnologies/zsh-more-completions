#compdef picosvg
# Documentation: https://github.com/googlefonts/picosvg
# Simplify an SVG into a restricted "pico" subset

local ret=1

_arguments -s -S \
  '--helpfull[show all help including absl flags]' \
  '--drop_unsupported[blindly discard all elements not understood]' \
  '--nodrop_unsupported[do not discard unsupported elements]' \
  '--clip_to_viewbox[clip content outside viewbox]' \
  '--noclip_to_viewbox[do not clip content outside viewbox]' \
  '--output_file=[output SVG file (- means stdout)]:file:_files' \
  '--allow_text[allow text elements (passed through, not converted)]' \
  '--noallow_text[disallow text elements]' \
  '*:svg file:_files -g "*.(svg|SVG)"' && ret=0

return ret
