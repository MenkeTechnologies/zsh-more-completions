#compdef darktable

# Zsh completion for darktable - darktable photography workflow

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[enable debug output]:debug:(all cache camctl camsupport control dev fswatch imageio input ioporder lighttable lua masks memory nan opencl params perf print pwstorage signal sql undo)' \
  '--library=[library file to use]:file:_files -g "*.db"' \
  '--datadir=[override data directory]:dir:_directories' \
  '--moduledir=[override module directory]:dir:_directories' \
  '--tmpdir=[override temp directory]:dir:_directories' \
  '--configdir=[override config directory]:dir:_directories' \
  '--cachedir=[override cache directory]:dir:_directories' \
  '--localedir=[override locale directory]:dir:_directories' \
  '--luacmd=[lua command to execute after startup]:lua command' \
  '--conf=[set config option]:key=value' \
  '--noiseprofiles=[set noiseprofiles JSON file]:file:_files -g "*.json"' \
  '--disable-opencl[disable OpenCL GPU support]' \
  '-t[number of threads for OpenMP]:threads' \
  '--threads=[number of threads for OpenMP]:threads' \
  '*:file:_files -g "*.{raw,cr2,cr3,nef,arw,orf,raf,dng,rw2,pef,srw,jpg,jpeg,tif,tiff,png,exr}"' && ret=0

return ret
