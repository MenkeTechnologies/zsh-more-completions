#compdef xob
# Documentation: https://github.com/florentc/xob/blob/master/README.md
# xob: a lightweight overlay volume (or anything) bar for X

local ret=1

_arguments -s -S \
  '-m[maximum value / number of steps in the bar]:maximum:_default' \
  '-t[duration in ms the bar stays on screen after update]:timeout:_default' \
  '-c[path to a config file specifying styles]:configfile:_files' \
  '-s[chosen style from the configuration]:style:_default' && ret=0

return ret
