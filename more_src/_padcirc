#compdef padcirc
# Documentation: https://adcirc.github.io/adcirc/user_guide/running_adcirc/command_line_options.html
# ADCIRC coastal circulation and storm surge model (parallel/MPI).

local ret=1

_arguments -s -S \
  '-I[look for input files in INPUTDIR]:inputdir:_files -/' \
  '-O[write fulldomain output files to GLOBALDIR]:globaldir:_files -/' \
  '-L[write subdomain output to PE* subdirectories]' \
  '-S[write subdomain binary hotstart files to PE* subdirectories]' \
  '-R[read subdomain binary hotstart files]' \
  '-W[dedicate NUM_WRITERS MPI processes for ASCII output]:num_writers:' \
  '-Ws[like -W but appends simulation time to new files]:num_split_writers:' \
  '-H[dedicate NUM_HOTSTART_WRITERS processes for binary hotstart files]:num_hotstart_writers:' \
  '-M[write subdomain harmonic analysis files]' \
  '-Mft[mesh file format]:type:(ascii xdmf)' \
  '-Mfn[mesh file name]:file:_files' \
  '-Nft[nodal attributes file format]:type:(ascii xdmf)' \
  '-Nfn[nodal attributes file name]:file:_files' && ret=0

return ret
