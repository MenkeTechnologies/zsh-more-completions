#compdef salome
# Documentation: https://man.archlinux.org/search?q=salome
# Reference accessed: 2026-05-16

# Salome: pre/post processing platform for CAE/CFD
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'start:start a salome session (default)'
  'connect:connect to a running session'
  'shell:open shell with salome env'
  'killall:kill all running salome sessions'
  'info:print salome configuration info'
  'help:print help'
  'context:show salome environment context'
  'config:show config'
  'test:run salome regression tests'
  'remote:run command on remote machine'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-t[run in non-GUI terminal mode]' \
  '-g[run with GUI (default)]' \
  '--gui[run with GUI]' \
  '--shutdown-servers[shut down servers on session exit]' \
  '--logger[start logger window]' \
  '--xterm[start kernel in xterm window]' \
  '--portkill[kill orphaned port]' \
  '--port=[Naming Service port]:n:' \
  '--ns-port-log=[file with NS port info]:file:_files' \
  '--user-config=[user config file]:file:_files' \
  '--save-config[save current config to user file]' \
  '--print-port[print active NS port and exit]' \
  '--modules=[comma-separated module list]:modules:' \
  '--show-resources[show available resource files]' \
  '--debug-py=[load Python debug]:opt:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'salome command' commands && ret=0 ;;
esac
return ret
