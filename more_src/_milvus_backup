#compdef milvus_backup milvus-backup
# Documentation: https://milvus.io/docs/milvus_backup_cli.md
# Milvus Backup: back up and restore Milvus collections

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[config YAML file]:file:_files -g "*.yaml"' \
  '1:command:((
    create\:"create a backup"
    list\:"list all backups"
    get\:"get a backup by name"
    delete\:"delete a backup by name"
    restore\:"restore a backup"
    check\:"check connections and config"
    server\:"start the backup server"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      create)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'=[backup name]:name:' \
          '(-c --colls)'{-c,--colls}'=[comma-separated collection names]:collections:' && ret=0
        ;;
      restore)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'=[backup name to restore]:name:' \
          '(-s --suffix)'{-s,--suffix}'=[suffix for new collections]:suffix:' && ret=0
        ;;
      delete|get)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'=[backup name]:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
