#compdef texdoctk
# _texdoctk — TeX Live texdoctk (Tk-based browser over the texdoc package documentation database; --debug prints what it would do, --datafile picks an alternate texdoctk.dat, --viewer overrides $PDFVIEWER)
# upstream: https://tug.org/svn/texlive (Master/texmf-dist/scripts/texdoctk)
# Flags from texlive scripts/texdoctk/texdoctk.pl on tip.

_texdoctk() {
    _arguments \
        '--help[show help]' \
        '--debug[print actions only]' \
        '--datafile+[texdoctk.dat path]:file:_files' \
        '--viewer+[PDF viewer command]:command:_command_names -e' \
        '--terminal+[terminal command]:command:_command_names -e'
}

_texdoctk "$@"
