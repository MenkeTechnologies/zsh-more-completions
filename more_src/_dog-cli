#compdef dog

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-q --query)*'{-q+,--query=}'[query]:q:' \
  '(-t --type)*'{-t+,--type=}'[type]:t:(A AAAA CAA CNAME HINFO LOC MX NAPTR NS NSEC OPT PTR SOA SRV SSHFP TLSA TXT URI)' \
  '(-n --nameserver)*'{-n+,--nameserver=}'[nameserver]:ns:' \
  '(--class)--class=[class]:c:(IN CH HS NONE ANY)' \
  '(-1 --short)'{-1,--short}'[short output]' \
  '(-J --json)'{-J,--json}'[JSON]' \
  '(--seconds)--seconds[show TTL in seconds]' \
  '(--time)--time[show timing]' \
  '(--color)--color=[color]:c:(always automatic never)' \
  '(--colour)--colour=[color]:c:(always automatic never)' \
  '(-Z)*-Z+[advanced opts csv]:opts:' \
  '(-U --udp)'{-U,--udp}'[UDP]' \
  '(-T --tcp)'{-T,--tcp}'[TCP]' \
  '(-S --tls)'{-S,--tls}'[DNS over TLS]' \
  '(-H --https)'{-H,--https}'[DNS over HTTPS]' \
  '*: :' && ret=0

return ret
