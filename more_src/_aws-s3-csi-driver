#compdef aws-s3-csi-driver
# _aws-s3-csi-driver — Mountpoint for Amazon S3 CSI driver (controller+node)
# upstream: https://github.com/awslabs/mountpoint-s3-csi-driver
# Flags from cmd/aws-s3-csi-driver/main.go on tip; node-id from NODE_NAME env var.

_aws-s3-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--mp-version=[Mountpoint version to report in NodeGetInfo]:version:' \
        '--node-id=[node-id to report in NodeGetInfo]:id:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_aws-s3-csi-driver "$@"
