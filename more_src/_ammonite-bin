#compdef amm
# _ammonite-bin — Ammonite Scala script runner + REPL (Li Haoyi, Scala); Scala-as-shell-script
# upstream: https://github.com/com-lihaoyi/Ammonite

_ammonite-bin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[code]:str:' \
        '--code+[code]:str:' \
        '-p+[predef file]:file:_files -g "*.sc"' \
        '--predef+[predef file]:file:_files -g "*.sc"' \
        '--no-default-predef[no default predef]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--watch[watch + rerun]' \
        '-w[watch + rerun]' \
        '--bsp[run as BSP server]' \
        '--banner+[banner text]:str:' \
        '-b+[banner text]:str:' \
        '--class-based[class based REPL]' \
        '--home+[home dir]:dir:_files -/' \
        '-h+[home dir]:dir:_files -/' \
        '--no-home-predef[no home predef]' \
        '--no-remote-logging[no remote logging]' \
        '--remote-logging+[remote logging]:bool:(true false)' \
        '--thin[thin REPL]' \
        '--color+[color]:when:(true false)' \
        '--no-color[no color]' \
        '--warn[warn level]' \
        '--debug[debug]' \
        '--bsp-version+[BSP version]:ver:' \
        '-D+[system property]:KEY=VAL:' \
        '*:script:_files -g "*.sc"'
}

_ammonite-bin "$@"
