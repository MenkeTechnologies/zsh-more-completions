#compdef otelcol-otlp
# _otelcol-otlp — OpenTelemetry Collector OTLP-only distribution (otlp+otlphttp receivers/exporters)
# upstream: https://github.com/open-telemetry/opentelemetry-collector-releases
# Shares otelcol CLI surface: otelcol/{command,flags}.go on tip.

_otelcol-otlp() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print collector version]' \
        '*--config=[config location (e.g. file:/path/cfg.yaml, env:CFG, http://host/cfg)]:uri:' \
        '*--set=[set arbitrary component config property (e.g. processors.batch.timeout=2s)]:kv:' \
        '--feature-gates=[csv of feature gates to enable/disable]:gates:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                featuregate:'display feature gates information'
                components:'list components in the collector binary'
                validate:'validate the configuration without running'
                'config-print':'print the resolved configuration and exit'
            )
            _describe -t commands 'otelcol-otlp subcommand' subs
            ;;
    esac
}

_otelcol-otlp "$@"
