#compdef lk
# Documentation: https://github.com/livekit/livekit-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# livekit-cli — urfave/cli (brew livekit-cli installs `lk`)
local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'cloud:LiveKit Cloud operations'
      'project:manage configured projects'
      'app:bootstrap apps from templates'
      'room:room operations including join'
      'token:create access tokens'
      'egress:start or test recording/egress'
      'load-test:simulate concurrent publishers and subscribers'
      'perf:performance and agent load tests'
      'docs:browse and search LiveKit documentation'
    )
    _describe -t commands 'lk command' commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
