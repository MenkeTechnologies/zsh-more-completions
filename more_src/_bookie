#compdef bookie bk-shell
# Documentation: https://man.archlinux.org/search?q=bookie
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--conf=[bookie config file]:file:_files' \
  '--readOnly=[start in read-only mode]:flag:(true false)' && ret=0

return ret
