#compdef pmemd pmemd.MPI pmemd.cuda

# Amber pmemd: optimized MD engine (CPU/CUDA variants)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-O[overwrite output]' \
  '-A[append to output]' \
  '-i[input file (mdin)]:file:_files' \
  '-o[output file (mdout)]:file:_files' \
  '-p[topology file]:file:_files' \
  '-c[coordinate file]:file:_files' \
  '-r[restart output]:file:_files' \
  '-ref[reference coordinates]:file:_files' \
  '-x[trajectory output]:file:_files' \
  '-v[velocity output]:file:_files' \
  '-frc[force output]:file:_files' \
  '-e[energy output]:file:_files' \
  '-inf[runtime info file]:file:_files' \
  '-l[log file]:file:_files' \
  '-rem[replica exchange method]:n:' \
  '-remlog[REM log file]:file:_files' \
  '-suffix[output suffix]:suffix:' \
  '-help[show help]' \
  '*::pmemd args:_files' && ret=0
return ret
