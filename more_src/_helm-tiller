#compdef helm-tiller
# Documentation: https://github.com/rimusz/helm-tiller
# helm tiller: run Tiller locally without deploying it to the cluster

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(install start start-ci stop run)' \
  '*::arg:_default' && ret=0

return ret
