#compdef as31
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/as31.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# as31: 8031/8051 assembler
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[print verbose options message to stderr]' \
  '-l[generate listing file (infile.lst)]' \
  '-s[write output to stdout]' \
  '-v[print version number]' \
  '-A+[format-specific argument string]:arg:' \
  '-F+[output format]:format:(hex tdr byte od srec2 srec3 srec4)' \
  '-O+[output file]:file:_files' \
  '*:source file:_files -g "*.(asm|s)"' && ret=0
return ret
