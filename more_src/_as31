#compdef as31

# as31: 8031/8051 assembler
# Documentation: http://www.pjrc.com/tech/8051/index.html#as31
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[create listing]' \
  '-O[output format]:fmt:(srec ihex bin tdr od byte)' \
  '-d[debug]' \
  '-v[verbose]' \
  '*:source file:_files -g "*.(asm|s)"' && ret=0
return ret
