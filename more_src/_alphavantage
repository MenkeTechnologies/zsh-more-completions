#compdef alphavantage alphavantage-cli av
# _alphavantage — Alpha Vantage alphavantage CLI command-line frontend wrapping the Alpha Vantage financial markets API providing global stocks Forex digital cryptocurrencies commodities economic indicators technical indicators fundamentals earnings income-statement balance-sheet cash-flow income company-overview real-time-intraday daily weekly monthly time-series (Alpha Vantage team, Go); cobra
# upstream: https://www.alphavantage.co/

_alphavantage() {
    local -a sub=(
        'login:authenticate'
        'time-series:time series data'
        'intraday:intraday time series'
        'daily:daily time series'
        'weekly:weekly time series'
        'monthly:monthly time series'
        'global-quote:global quote'
        'search:symbol search'
        'fundamental:fundamentals'
        'overview:company overview'
        'income:income statement'
        'balance:balance sheet'
        'cash-flow:cash flow statement'
        'earnings:earnings'
        'listing:listing status'
        'ipo:IPO calendar'
        'earnings-calendar:earnings calendar'
        'forex:forex'
        'crypto:crypto'
        'commodity:commodity'
        'economic:economic indicator'
        'technical:technical indicator'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--symbol=+[ticker]:str:' \
        '--interval=+[i]:i:(1min 5min 15min 30min 60min)' \
        '--outputsize=+[o]:o:(compact full)' \
        '--datatype=+[t]:t:(json csv)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'alphavantage subcommand' sub ;;
        args)
            case $words[1] in
                time-series|intraday|daily|weekly|monthly|global-quote|search|fundamental|overview|income|balance|cash-flow|earnings|forex|crypto|commodity|economic|technical) _arguments '*:symbol:' ;;
            esac
            ;;
    esac
}

_alphavantage "$@"
