#compdef scil_volume_crop
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_volume_crop.html
# Scilpy: crop a nifti volume to its bounding box

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ignore_voxel_size[ignore voxel size compatibility test]' \
  '--input_bbox=[JSON file with bounding box to use]:file:_files' \
  '--output_bbox=[JSON file to write computed bounding box]:file:_files' \
  '--use_deprecated_pickle[use .pkl bounding boxes instead of .json]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_image:_files' \
  '2:out_image:_files' && ret=0

return ret
