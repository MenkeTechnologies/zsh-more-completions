#compdef dmtxread
# Documentation: https://man.archlinux.org/search?q=dmtxread
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --codewords)'{-c,--codewords}'[print codeword indices]' \
  '(-d --diagnose)'{-d,--diagnose}'[diagnose plot of decode regions]' \
  '(-D --milliseconds)'{-D,--milliseconds}'+[time limit ms]:ms:' \
  '(-E --edge-thresh)'{-E,--edge-thresh}'+[edge threshold percent]:percent:' \
  '(-g --gap)'{-g,--gap}'+[grid gap in pixels]:px:' \
  '(-l --line-break)'{-l,--line-break}'[force newline after each result]' \
  '(-m --milliseconds)'{-m,--milliseconds}'+[per-image time limit ms]:ms:' \
  '(-M --max-count)'{-M,--max-count}'+[max barcodes to decode]:n:' \
  '(-n --new-line)'{-n,--new-line}'[append newline]' \
  '(-N --new-line)'{-N,--new-line}'[stop after one barcode]' \
  '(-p --page)'{-p,--page}'+[page index for multi-image files]:n:' \
  '(-q --square-deviation)'{-q,--square-deviation}'+[max square deviation]:deg:' \
  '(-R --resolution)'{-R,--resolution}'+[image resolution dpi]:dpi:' \
  '(-S --shrink)'{-S,--shrink}'+[shrink image factor]:factor:' \
  '(-t --shape)'{-t,--shape}'+[symbol shape]:shape:(square rectangle)' \
  '(-U --unicode)'{-U,--unicode}'[unicode output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --crop)'{-w,--crop}'+[crop region WxH+X+Y]:crop:' \
  '(-X --x-range)'{-X,--x-range}'+[X range min,max]:range:' \
  '(-Y --y-range)'{-Y,--y-range}'+[Y range min,max]:range:' \
  '*:image:_files -g "*.{png,jpg,jpeg,tiff,tif,gif,bmp,ico,xpm,pnm,pbm,pgm,ppm,xbm,xv}"' && ret=0

return ret
