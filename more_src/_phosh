#compdef phosh
# Documentation: https://manpages.debian.org/unstable/phosh/phosh.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian unstable phosh(1) manpage OPTIONS section.

# phosh: phone shell for GNOME (Pure Maps mobile shell)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-U --unlocked -L --locked)'{-U,--unlocked}'[do not start with screen locked]' \
  '(-L --locked -U --unlocked)'{-L,--locked}'[start with screen locked]' \
  '(- *)--version[show version information]' && ret=0
return ret
