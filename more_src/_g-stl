#compdef g-stl
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=g-stl&sektion=1
# BRL-CAD geometry database to STL converter

local ret=1

_arguments -s \
  '-o[output file name (default stdout)]:output:_files' \
  '-m[directory for output files]:directory:_files -/' \
  '-b[write binary STL output]' \
  '-i[use inches for output (default mm)]' \
  '-8[facetize using marching cubes]' \
  '-D[calculational distance tolerance (mm)]:tolerance' \
  '-a[absolute tessellation tolerance]:tolerance' \
  '-r[relative tessellation tolerance]:tolerance' \
  '-n[surface-normal tessellation tolerance]:tolerance' \
  '-x[librt debug flag]:flag' \
  '-X[NMG debug flag]:flag' \
  '-v[verbose output]' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
