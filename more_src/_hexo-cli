#compdef hexo
# _hexo-cli — Hexo fast static blog SSG (Tommy Chen); Node.js Markdown-driven blog generator
# upstream: https://github.com/hexojs/hexo

_hexo-cli() {
    local -a sub=(
        'init:create new site'
        'new:create new post'
        'generate:generate static files'
        'g:alias for generate'
        'server:start dev server'
        's:alias for server'
        'deploy:deploy site'
        'd:alias for deploy'
        'clean:remove generated files and cache'
        'list:list posts/pages/categories/tags'
        'render:render files'
        'migrate:migrate from other blog system'
        'publish:publish a draft'
        'config:show config'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--debug[debug log]' \
        '--silent[silent]' \
        '--cwd+[cwd]:dir:_files -/' \
        '--config+[config file]:file:_files -g "_config*.yml"' \
        '--draft[include drafts]' \
        '--safe[disable plugin loading]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hexo subcommand' sub ;;
        args)
            case $words[1] in
                generate|g) _arguments \
                    '(-d --deploy)'{-d,--deploy}'[deploy after generate]' \
                    '(-w --watch)'{-w,--watch}'[watch for changes]' \
                    '(-f --force)'{-f,--force}'[force generate]' ;;
                server|s) _arguments \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-i --ip)'{-i,--ip}'+[ip]:host:_hosts' \
                    '(-s --static)'{-s,--static}'[only static files]' \
                    '(-l --log)'{-l,--log}'[enable log]' \
                    '(-o --open)'{-o,--open}'[open browser]' ;;
                new) _arguments \
                    '(-p --path)'{-p,--path}'+[post path]:path:' \
                    '(-r --replace)'{-r,--replace}'[replace existing]' \
                    '(-s --slug)'{-s,--slug}'+[post slug]:slug:' \
                    '1:layout:(post draft page)' \
                    '2:title:' ;;
                init) _arguments '1:dir:_files -/' '--no-clone[skip git clone]' '--no-install[skip npm install]' ;;
                deploy|d) _arguments '(-g --generate)'{-g,--generate}'[generate before deploy]' ;;
                publish) _arguments '1:layout:(post draft page)' '2:title:' ;;
            esac
            ;;
    esac
}

_hexo-cli "$@"
