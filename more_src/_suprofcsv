#compdef suprofcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/suprofcsv.c
# input Q-file or parameters, make profile, output Q-file

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:file:_files' \
  'keyp=[point key name]:key' \
  'keyx=[X coordinate name]:key' \
  'keyy=[Y coordinate name]:key' \
  'chordi=[initial chord distance]:chordi' \
  'nmina=[minimum averaging number]:nmina' \
  'nmaxa=[maximum averaging number]:nmaxa' \
  'dextra=[extra distance to extrapolate]:dextra' \
  'nmins=[minimum centred smoothing number]:nmins' \
  'nmaxs=[maximum centred smoothing number]:nmaxs' \
  'chordf=[final chord distance]:chordf' \
  'ename=[names to eliminate from output]:ename' \
  'formxy=[C format code for printing values]:formxy' \
  'shiftrec=[list of Q-record numbers to shift]:shiftrec' \
  'shiftdist=[list of distances to shift]:shiftdist' \
  'point_crz=[cdp number of point zero]:point_crz' \
  'point_cru=[cdps per one point unit]:point_cru' \
  'qout=[output file for q-records]:file:_files' \
  '*:file:_files' && ret=0


return ret
