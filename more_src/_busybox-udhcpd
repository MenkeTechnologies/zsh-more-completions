#compdef udhcpd
# _busybox-udhcpd — Erik Andersen Russ Dill BusyBox udhcpd tiny DHCP server suitable for embedded systems (busybox team, C); getopt
# upstream: https://git.busybox.net/busybox

_busybox-udhcpd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-f[run in foreground]' \
        '-S[log to syslog]' \
        '-I+[bind interface]:str:' \
        '-P+[server port]:port:_ports' \
        '*:config file:_files -g "*.conf udhcpd.conf"'
}

_busybox-udhcpd "$@"
