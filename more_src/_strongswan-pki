#compdef strongswan-pki pki
# _strongswan-pki — strongSwan strongswan-pki pki CLI for creating and managing X.509 certificate authority operations key generation CSR signing self-signed certificates CRL OCSP and PKCS#7/8/12 (strongswan team, C); getopt
# upstream: https://github.com/strongswan/strongswan

_strongswan-pki() {
    local -a sub=(
        '--gen:generate private key'
        '--keyid:show key identifier'
        '--pkcs7:create or extract PKCS#7'
        '--pkcs8:create or extract PKCS#8'
        '--pkcs12:create or extract PKCS#12'
        '--print:print credential'
        '--pub:extract public key'
        '--req:create certificate request'
        '--self:create self-signed cert'
        '--issue:issue cert with CA'
        '--signcrl:sign CRL'
        '--acert:create attribute certificate'
        '--ocsp:OCSP responder cert'
        '--scep:run SCEP client'
        '--ack:print fingerprints'
        '--verify:verify cert chain'
        '--help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[debug level]:n:(0 1 2 3 4)' \
        '--debug=+[level]:n:(0 1 2 3 4)' \
        '-o+[options]:str:' \
        '-t+[key type]:t:(rsa ecdsa ed25519 ed448 bliss)' \
        '--type=+[key type]:t:(rsa ecdsa ed25519 ed448 bliss)' \
        '-s+[size bits]:n:' \
        '--size=+[size bits]:n:' \
        '-f+[output format]:f:(pem der pkcs1 pkcs8 pkcs12 dnskey sshkey)' \
        '--outform=+[fmt]:f:(pem der pkcs1 pkcs8 pkcs12)' \
        '-g+[digest]:d:(sha1 sha224 sha256 sha384 sha512 sha3_224 sha3_256 sha3_384 sha3_512)' \
        '--digest=+[digest]:d:(sha1 sha224 sha256 sha384 sha512)' \
        '-i+[input file]:file:_files' \
        '--in=+[input file]:file:_files' \
        '-x+[CA cert]:file:_files' \
        '--cacert=+[CA cert]:file:_files' \
        '-k+[private key]:file:_files' \
        '--cakey=+[CA key]:file:_files' \
        '-c+[issuer cert]:file:_files' \
        '-d+[lifetime days]:n:' \
        '--lifetime=+[days]:n:' \
        '-n+[CN]:str:' \
        '--dn=+[DN]:str:' \
        '-S+[san csv]:str:' \
        '--san=+[san csv]:str:' \
        '-p+[serial hex]:str:' \
        '--serial=+[serial hex]:str:' \
        '-F+[flags]:str:' \
        '--flag=+[flags]:str:' \
        '--ca[CA cert]' \
        '--pathlen=+[N]:n:' \
        '*:args:'
}

_strongswan-pki "$@"
