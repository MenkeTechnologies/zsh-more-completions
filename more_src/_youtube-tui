#compdef youtube-tui
# _youtube-tui — terminal YouTube client (Siriusmart/youtube-tui)
# upstream: https://github.com/Siriusmart/youtube-tui
# Commands from src/global/functions/run_command.rs.

_youtube-tui() {
    local -a commands
    commands=(
        'help:print the help command list'
        'version:print version info'
        'loadpage:load a page (popular / trending / channel / video / playlist / search / library)'
        'bookmark:bookmark a video/playlist/channel by id'
        'unmark:remove a bookmark'
        'togglemark:toggle a bookmark on/off'
        'rmcache:remove a cached item by id'
        'switchprovider:cycle the Invidious/Piped instance provider'
        'history:back / clear history navigation'
        'back:alias for `history back`'
        'flush:flush the current page state'
        'reload:reload the current page (alias: r)'
        'quit:exit the TUI'
        'run:run an external shell command'
        'parrun:run an external shell command in parallel'
        'copy:copy text to the clipboard'
        'sync:sync a subscribed channel by identifier'
        'unsub:unsubscribe from a channel'
        'syncall:sync all subscribed channels'
        'key:simulate a key + modifier'
        'mpv:control mpv (prop / tprop / sprop / commands)'
        'echo:echo a message into the TUI status line'
    )
    _describe -t commands 'youtube-tui command' commands
}

_youtube-tui "$@"
