#compdef anki

# completions for anki flashcard application

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '-b+[base folder]:path:_directories'
  '--base=[base folder]:path:_directories'
  '-p+[profile to load]:profile name'
  '--profile=[profile to load]:profile name'
  '-l+[language to use]:language code'
  '--lang=[language to use]:language code'
  '--syncserver=[custom sync server URL]:url'
  '--safemode[disable add-ons and custom settings on startup]'
  '*:file:_files -g "*.apkg(-.)"'
)

_arguments -s -S $arguments
