#compdef FuzzilliCli
# Documentation: https://github.com/googleprojectzero/fuzzilli/blob/main/Sources/FuzzilliCli/main.swift
# Fuzzilli JavaScript engine coverage-guided fuzzer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information]' \
  '--profile=[select preconfigured target profile]:profile' \
  '--jobs=[total number of fuzzing jobs]:n' \
  '--engine=[fuzzing engine]:engine:(mutation hybrid multi)' \
  '--corpus=[corpus scheduler]:scheduler:(basic markov)' \
  '--logLevel=[log verbosity]:level:(verbose info warning error fatal)' \
  '--maxIterations=[run for specified iteration count]:n' \
  '--maxRuntimeInHours=[run for specified duration in hours]:n' \
  '--timeout=[execution timeout in ms]:ms' \
  '--minMutationsPerSample=[discard samples after this many mutations]:n' \
  '--minCorpusSize=[minimum samples kept in corpus]:n' \
  '--maxCorpusSize=[maximum corpus growth limit]:n' \
  '--markovDropoutRate=[low-edge sample rejection rate]:rate' \
  '--consecutiveMutations=[mutations per sample]:n' \
  '--corpusGenerationIterations=[iterations before switching phases]:n' \
  '--minimizationLimit=[percentage of instructions to retain]:p' \
  '--storagePath=[output directory for crashes and corpus]:path:_files -/' \
  '--resume[import corpus from previous session]' \
  '--overwrite[delete existing storage and start fresh]' \
  '--staticCorpus[mutate existing corpus without adding]' \
  '--exportStatistics[collect and save fuzzing metrics]' \
  '--statisticsExportInterval=[minutes between statistic saves]:n' \
  '--importCorpus=[import existing FuzzIL program corpus]:path:_files -/' \
  '--corpusImportMode=[import strategy]:mode:(default full unminimized)' \
  '--instanceType=[network role]:type:(root leaf intermediate standalone)' \
  '--bindTo=[parent node binding address]:host\:port' \
  '--connectTo=[child node connection target]:host\:port' \
  '--corpusSyncMode=[synchronization mode]:mode:(up down full none)' \
  '--diagnostics[save failed/timed-out programs]' \
  '--swarmTesting[use random code generator weights]' \
  '--inspect[generate detailed mutation history files]' \
  '--argumentRandomization[randomize engine arguments]' \
  '--additionalArguments=[pass extra arguments to engine]:args' \
  '--tag=[identifier for this instance]:tag' \
  '--wasm[enable WebAssembly code generators]' \
  '--wasm-opt-path=[path to wasm-opt binary]:path:_files' \
  '--forDifferentialFuzzing[enable differential fuzzing features]' \
  '--bundle[generate multi-script bundles]' \
  '*:js engine binary:_files' && ret=0

return ret
