#compdef brew-bundle
# _brew-bundle — Homebrew brew bundle Brewfile manager subcommand alias (Homebrew team, Ruby); custom argparse
# upstream: https://github.com/Homebrew/homebrew-bundle

_brew-bundle() {
    local -a sub=(
        'install:install everything in Brewfile (default)'
        'dump:write Brewfile from current state'
        'cleanup:remove things not in Brewfile'
        'check:check whether everything is installed'
        'list:list things in Brewfile'
        'edit:edit Brewfile'
        'sh:create script env vars'
        'env:print env vars'
        'exec:exec command with Brewfile env'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--file=+[Brewfile path]:file:_files -g "Brewfile *.bundle"' \
        '--global[use global Brewfile]' \
        '-g[use global Brewfile]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-lock[no lock]' \
        '--no-upgrade[no upgrade]' \
        '--no-vscode[no vscode]' \
        '--force[force]' \
        '-f[force]' \
        '--zap[zap removed casks]' \
        '--all[all bundle entries]' \
        '-a[all bundle entries]' \
        '--brews[only brews]' \
        '--casks[only casks]' \
        '--taps[only taps]' \
        '--mas[only Mac App Store]' \
        '--whalebrew[only whalebrew]' \
        '--vscode[only VSCode extensions]' \
        '--describe[include comments in Brewfile]' \
        '--no-restart[no restart services]' \
        '--check-mas[check Mac App Store]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brew bundle subcommand' sub ;;
        args)
            case $words[1] in
                exec) _arguments '*:cmd:_command_names -e' ;;
            esac
            ;;
    esac
}

_brew-bundle "$@"
