#compdef create-nx-workspace
# Documentation: https://www.npmjs.com/package/create-nx-workspace
# Reference accessed: 2026-05-23
# Verified: npx create-nx-workspace --help.

# Zsh completion for create-nx-workspace - scaffold a new Nx workspace

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--name=[workspace name]:name:' \
  '--preset=[Nx preset]:preset:(apps npm ts web-components angular-monorepo angular-standalone react-monorepo react-standalone vue-monorepo vue-standalone nuxt nuxt-standalone next nextjs-standalone react-native expo nest express react vue angular node-standalone node-monorepo ts-standalone)' \
  '--interactive[enable interactive preset selection]' \
  '--workspaceType=[workspace type]:type:(integrated package-based standalone)' \
  '--appName=[app name for monorepo stacks]:name:' \
  '--style=[stylesheet type]:style:' \
  '--standaloneApi[use Angular standalone components]' \
  '--routing[add routing setup]' \
  '--useReactRouter[SSR React app with React Router]' \
  '--bundler=[bundler]:bundler:' \
  '--workspaces[use package manager workspaces]' \
  '--useProjectJson[use project.json for Nx config]' \
  '--formatter=[code formatter]:formatter:' \
  '--framework=[framework]:framework:' && ret=0

return ret
