#compdef forw
# Documentation: man forw(1)
# Source: nmh uip/forw.c (master) — forward nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-annotate -noannotate)-annotate[annotate original]' \
    '(-annotate -noannotate)-noannotate[do not annotate]' \
    '-draftfolder+[draft folder]:folder:_default' \
    '-draftmessage+[draft message]:msg:_default' \
    '-nodraftfolder[no draft folder]' \
    '-editor+[editor]:cmd:_command_names -e' \
    '-noedit[skip editor]' \
    '-filter+[filter file]:file:_files' \
    '-form+[format file]:file:_files' \
    '(-format -noformat)-format[apply format]' \
    '(-format -noformat)-noformat[no format]' \
    '(-inplace -noinplace)-inplace[in-place annotation]' \
    '(-inplace -noinplace)-noinplace[no in-place]' \
    '(-mime -nomime)-mime[forward via MIME message/digest]' \
    '(-mime -nomime)-nomime[forward as plain text]' \
    '-digest+[digest list]:digest:_default' \
    '-issue+[digest issue number]:N:_default' \
    '-volume+[digest volume number]:N:_default' \
    '-whatnowproc+[whatnow program]:cmd:_command_names -e' \
    '-nowhatnowproc[skip whatnow]' \
    '(-dashstuffing -nodashstuffing)-dashstuffing[dash-stuff message]' \
    '(-dashstuffing -nodashstuffing)-nodashstuffing[no dash-stuffing]' \
    '-version[show version]' \
    '-help[show help]' \
    '-file+[draft file]:file:_files' \
    '-build[build draft only]' \
    '-from+[sender address]:from:_default' \
    '-to+[recipient address]:to:_default' \
    '-cc+[cc address]:cc:_default' \
    '-subject+[subject]:subject:_default' \
    '-fcc+[fcc mailbox]:fcc:_default' \
    '-width+[output width]:cols:_default' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
