#compdef wpull
# Documentation: https://wpull.readthedocs.io/en/master/options.html
# wpull - wget-compatible web downloader / crawler with WARC support

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[display version information]' \
  '--plugin-script=[load plugin script]:file:_files' \
  '--plugin-args=[pass arguments to plugin]:args' \
  '--database=[save database to file instead of memory]:file:_files' \
  '--database-uri=[save database using SQLAlchemy URI]:uri' \
  '--concurrent=[run N simultaneous downloads]:n' \
  '--debug-console-port=[run web debug console on port]:port' \
  '--debug-manhole[install Manhole debugging socket]' \
  '--ignore-fatal-errors[suppress fatal exception errors]' \
  '--monitor-disk=[pause if disk space low]:bytes' \
  '--monitor-memory=[pause if memory low]:bytes' \
  '(-o --output-file)'{-o,--output-file}'[write messages to file]:file:_files' \
  '(-a --append-output)'{-a,--append-output}'[append messages to file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[print debugging messages]' \
  '(-v --verbose)'{-v,--verbose}'[print detailed progress]' \
  '(-nv --no-verbose)'{-nv,--no-verbose}'[print informative messages and errors]' \
  '(-q --quiet)'{-q,--quiet}'[print errors only]' \
  '(-qq --very-quiet)'{-qq,--very-quiet}'[minimal output]' \
  '--ascii-print[ASCII-only output]' \
  '--report-speed=[display speed in bits]:type' \
  '(-i --input-file)'{-i,--input-file}'[download URLs from file]:file:_files' \
  '(-F --force-html)'{-F,--force-html}'[read input files as HTML]' \
  '(-B --base)'{-B,--base}'[resolve relative URLs to base URL]:url' \
  '--http-proxy=[HTTP proxy for requests]:proxy' \
  '--https-proxy=[HTTPS proxy for requests]:proxy' \
  '--proxy-user=[proxy authentication username]:user' \
  '--proxy-password=[proxy authentication password]:password' \
  '--no-proxy[disable proxy support]' \
  '(-t --tries)'{-t,--tries}'[retry attempts on transient errors]:number' \
  '--retry-connrefused[retry connection refusals]' \
  '--retry-dns-error[retry DNS failures]' \
  '(-T --timeout)'{-T,--timeout}'[set DNS/connect/read timeout]:seconds' \
  '--dns-timeout=[DNS request timeout]:seconds' \
  '--connect-timeout=[connection request timeout]:seconds' \
  '--read-timeout=[read request timeout]:seconds' \
  '--session-timeout=[file download timeout]:seconds' \
  '(-w --wait)'{-w,--wait}'[wait between requests]:seconds' \
  '--waitretry=[wait up to N seconds on retries]:seconds' \
  '--random-wait[randomize wait intervals]' \
  '(-O --output-document)'{-O,--output-document}'[stream documents to file]:file:_files' \
  '(-nc --no-clobber)'{-nc,--no-clobber}'[do not overwrite existing files]' \
  '(-c --continue)'{-c,--continue}'[resume partial downloads]' \
  '--progress=[progress indicator type]:type:(dot bar none)' \
  '(-N --timestamping)'{-N,--timestamping}'[download only newer files]' \
  '--no-use-server-timestamps[do not set file modification times]' \
  '(-S --server-response)'{-S,--server-response}'[display server protocol responses]' \
  '(-Q --quota)'{-Q,--quota}'[stop after NUMBER bytes]:number' \
  '--bind-address=[bind to local address]:address' \
  '--limit-rate=[limit bandwidth]:rate' \
  '--no-dns-cache[disable DNS caching]' \
  '--rotate-dns[use different resolved IPs]' \
  '--restrict-file-names=[safe filename modes]:modes' \
  '(-4 --inet4-only)'{-4,--inet4-only}'[IPv4 only]' \
  '(-6 --inet6-only)'{-6,--inet6-only}'[IPv6 only]' \
  '--prefer-family=[prefer IPv4 or IPv6]:family:(IPv4 IPv6 none)' \
  '--user=[username for FTP and HTTP]:user' \
  '--password=[password for FTP and HTTP]:password' \
  '--no-iri[ASCII encoding only]' \
  '--local-encoding=[input file encoding]:encoding' \
  '--remote-encoding=[force document decoding]:encoding' \
  '--max-filename-length=[limit filename length]:number' \
  '(-nd --no-directories)'{-nd,--no-directories}'[do not create directories]' \
  '(-x --force-directories)'{-x,--force-directories}'[always create directories]' \
  '(-nH --no-host-directories)'{-nH,--no-host-directories}'[skip hostname directories]' \
  '--protocol-directories[create scheme directories]' \
  '(-P --directory-prefix)'{-P,--directory-prefix}'[save under directory]:prefix:_files -/' \
  '--cut-dirs=[skip leading directories]:number' \
  '--http-user=[HTTP authentication username]:user' \
  '--http-password=[HTTP authentication password]:password' \
  '--no-cache[do not use cached versions]' \
  '--default-page=[index page name]:name' \
  '(-E --adjust-extension)'{-E,--adjust-extension}'[add HTML/CSS extensions]' \
  '--ignore-length[ignore Content-Length header]' \
  '--header=[add HTTP header]:header' \
  '--max-redirect=[follow up to N redirects]:number' \
  '--referer=[set referrer]:url' \
  '--save-headers[include headers in files]' \
  '(-U --user-agent)'{-U,--user-agent}'[custom user agent]:agent' \
  '--no-robots[ignore robots.txt]' \
  '--no-http-keep-alive[disable persistent connections]' \
  '--no-cookies[disable cookie support]' \
  '--load-cookies=[load Mozilla cookies.txt]:file:_files' \
  '--save-cookies=[save Mozilla cookies.txt]:file:_files' \
  '--keep-session-cookies[include session cookies]' \
  '--post-data=[POST query string]:data' \
  '--post-file=[POST query from file]:file:_files' \
  '--content-disposition[use Content-Disposition filename]' \
  '--content-on-error[keep error pages]' \
  '--http-compression[request HTTP compression]' \
  '--html-parser=[HTML parser selection]:parser:(html5lib libxml2-lxml)' \
  '--link-extractors=[link extractors]:extractors' \
  '--escaped-fragment[rewrite hash fragments]' \
  '--strip-session-id[remove session ID tokens]' \
  '--secure-protocol=[SSL/TLS version]:protocol:(SSLv3 TLSv1 TLSv1.1 TLSv1.2 auto)' \
  '--https-only[HTTPS URLs only]' \
  '--no-check-certificate[skip SSL validation]' \
  '--no-strong-crypto[allow weak protocols/ciphers]' \
  '--certificate=[client certificate]:file:_files' \
  '--certificate-type=[certificate type]:type:(PEM)' \
  '--private-key=[client private key]:file:_files' \
  '--private-key-type=[key type]:type:(PEM)' \
  '--ca-certificate=[CA certificate bundle]:file:_files' \
  '--ca-directory=[CA certificates directory]:dir:_files -/' \
  '--no-use-internal-ca-certs[skip built-in CA certs]' \
  '--random-file=[SSL PRNG seed file]:file:_files' \
  '--edg-file=[entropy daemon socket]:file:_files' \
  '--ftp-user=[FTP username]:user' \
  '--ftp-password=[FTP password]:password' \
  '--no-remove-listing[keep directory listings]' \
  '--no-glob[disable FTP glob patterns]' \
  '--preserve-permissions[apply server Unix permissions]' \
  '--retr-symlinks=[handle symlinks]:retr:(0 1 no off on yes)' \
  '--warc-file=[save WARC file]:file:_files' \
  '--warc-append[append to WARC file]' \
  '--warc-header=[add WARC metadata]:header' \
  '--warc-max-size=[WARC file size limit]:number' \
  '--warc-move=[move completed WARC files]:dir:_files -/' \
  '--warc-cdx[write CDX index]' \
  '--warc-dedup=[write revisit records]:file:_files' \
  '--no-warc-compression[do not compress WARC]' \
  '--no-warc-digests[skip SHA1 hash computation]' \
  '--no-warc-keep-log[do not save log in WARC]' \
  '--warc-tempdir=[WARC temporary directory]:dir:_files -/' \
  '(-r --recursive)'{-r,--recursive}'[follow and download links]' \
  '(-l --level)'{-l,--level}'[maximum recursion depth]:number' \
  '--delete-after[download then delete files]' \
  '(-k --convert-links)'{-k,--convert-links}'[rewrite links to local files]' \
  '(-K --backup-converted)'{-K,--backup-converted}'[backup before converting links]' \
  '(-p --page-requisites)'{-p,--page-requisites}'[download embedded objects]' \
  '--page-requisites-level=[requisites recursion depth]:number' \
  '--sitemaps[download Sitemaps for discovery]' \
  '(-A --accept)'{-A,--accept}'[accept file suffixes]:list' \
  '(-R --reject)'{-R,--reject}'[reject file suffixes]:list' \
  '--accept-regex=[accept matching URLs]:regex' \
  '--reject-regex=[reject matching URLs]:regex' \
  '--regex-type=[regex type]:type:(pcre)' \
  '(-D --domains)'{-D,--domains}'[include hostname suffixes]:list' \
  '--exclude-domains=[exclude hostname suffixes]:list' \
  '--hostnames=[include specific hostnames]:list' \
  '--exclude-hostnames=[exclude specific hostnames]:list' \
  '--follow-ftp[follow FTP links]' \
  '--follow-tags=[follow links in HTML tags]:list' \
  '--ignore-tags=[skip links in HTML tags]:list' \
  '(-H --span-hosts)'{-H,--span-hosts}'[follow links to other hostnames]' \
  '--span-hosts-allow=[selective spanning]:list' \
  '(-L --relative)'{-L,--relative}'[relative links only]' \
  '(-I --include-directories)'{-I,--include-directories}'[include paths]:list' \
  '--trust-server-names[use final URL for filename]' \
  '(-X --exclude-directories)'{-X,--exclude-directories}'[exclude paths]:list' \
  '(-np --no-parent)'{-np,--no-parent}'[do not follow parent directories]' \
  '--no-strong-redirects[do not auto-span for redirects]' \
  '--proxy-server[run HTTP proxy for capturing]' \
  '--proxy-server-address=[proxy bind address]:address' \
  '--proxy-server-port=[proxy bind port]:port' \
  '--phantomjs[use PhantomJS for dynamic pages]' \
  '--phantomjs-exe=[PhantomJS executable path]:file:_files' \
  '--phantomjs-max-time=[session duration]:seconds' \
  '--phantomjs-scroll=[page scroll repetitions]:num' \
  '--phantomjs-wait=[wait between interactions]:seconds' \
  '--no-phantomjs-snapshot[do not snapshot dynamic pages]' \
  '--no-phantomjs-smart-scroll[always scroll to maximum]' \
  '--youtube-dl[use youtube-dl for videos]' \
  '--youtube-dl-exe=[youtube-dl executable path]:file:_files' \
  '*:url:_urls' && ret=0

return ret
