#compdef runmultihap
# Documentation: https://github.com/spacetelescope/drizzlepac/blob/main/drizzlepac/runmultihap.py
# DrizzlePac HAP: multi-visit processing, mosaics and sourcelists

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --input_custom_pars_file)'{-c,--input_custom_pars_file}'=[customized configuration JSON file]:file:_files' \
  '(-d --diagnostic_mode)'{-d,--diagnostic_mode}'[enable extra log messages and diagnostic files]' \
  '(-l --log_level)'{-l,--log_level}'=[log verbosity level]:level:(critical error warning info debug)' \
  '(-s --skip_gaia_alignment)'{-s,--skip_gaia_alignment}'[skip alignment to Gaia/HSC sources]' \
  '1:input csv file:_files' && ret=0

return ret
