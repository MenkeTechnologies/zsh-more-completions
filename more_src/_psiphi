#compdef psiphi
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/psiphi.html
# Calculates phi and psi torsion angles from protein coordinates

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-infile=[clean protein structure coordinates file]:file:_files' \
  '-chainnumber=[chain to analyse]:number:' \
  '-startresiduenumber=[beginning residue]:number:' \
  '-finishresiduenumber=[ending residue]:number:' \
  '-outfile=[output report file]:file:_files' \
  '-rformat2=[report format]:format:' \
  '-rdirectory2=[output directory]:dir:_files -/' \
  '-auto[turn off prompts]' \
  '-stdout[write output to stdout]' \
  '-version[show version]' \
  '*:coordinates file:_files' && ret=0

return ret
