#compdef dbml-renderer
# Documentation: https://github.com/softwaretechnik-berlin/dbml-renderer
# dbml-renderer - render a DBML file to SVG or DOT

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --input)'{-i,--input}'[DBML input file (default stdin)]:input:_files' \
  '(-f --format)'{-f,--format}'[output format]:format:(svg dot)' \
  '(-o --output)'{-o,--output}'[output file (default stdout)]:output:_files' && ret=0

return ret
