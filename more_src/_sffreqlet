#compdef sffreqlet
# Documentation: https://ahay.org/RSF/sffreqlet.html
# Madagascar: 1-D seislet frame

local ret=1

_arguments -s \
  'freq=[auxiliary input file name]:file:_files' \
  'inv=[if y, do inverse transform (y/n)]:bool:(y n)' \
  'verb=[verbosity flag (y/n)]:bool:(y n)' \
  'decomp=[do decomposition (y/n)]:bool:(y n)' \
  'ncycle=[number of iterations]:int:' \
  'niter=[number of Bregman iterations]:int:' \
  'perc=[percentage for sharpening]:float:' \
  'type=[wavelet type]:type:(haar linear biorthogonal)' \
  '*:rsf file:_files' && ret=0

return ret
