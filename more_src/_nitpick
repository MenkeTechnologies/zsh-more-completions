#compdef nitpick

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check style violations'
  'fix:auto-fix style violations'
  'ls:list configured styles'
  'init:initialize nitpick config'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--offline[run in offline mode]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'nitpick command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check|fix)
        _arguments -s -S \
          '--violations[violation types]:type:(missing-file different-values)' \
          '*:files:_files' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
