#compdef ITGSend
# Documentation: https://traffic.comics.unina.it/software/ITG/manual/
# D-ITG sender component: generates traffic flows toward an ITGRecv instance

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '-l+[generate sender-side log file]:logfile:_files' \
  '-L+[generate sender-side log on a remote ITGLog]:log server address' \
  '-x+[ask ITGRecv to generate receiver-side log file]:receiver logfile:_files' \
  '-X+[ask ITGRecv to log on a remote ITGLog]:log server address' \
  '-q+[number of packets to push to the log at once]:log buffer size' \
  '-Sda+[set the destination address for the signaling channel]:address' \
  '-Sdp+[set the destination port for the signaling channel]:port' \
  '-Ssa+[set the source address for the signaling channel]:address' \
  '-Ssp+[set the source port for the signaling channel]:port' \
  '-Si+[set the network interface for the signaling channel]:interface' \
  '-H[enable NAT traversal: FTP-like passive mode]' \
  '-m+[set the type of meter]:meter:(owdm rttm)' \
  '-t+[set the generation duration in ms]:duration' \
  '-z+[set the number of packets to generate]:packets' \
  '-k+[set the number of KBytes to generate]:kbytes' \
  '-d+[start the generation after the specified delay in ms]:delay' \
  '-b+[set the DS byte for QoS tests]:ds byte' \
  '-f+[set the IP Time To Live]:ttl' \
  '-a+[set the destination address]:address' \
  '-sa+[set the source address]:address' \
  '-rp+[set the destination port]:port' \
  '-sp+[set the source port]:port' \
  '-i+[bind to the given interface]:interface' \
  '-p+[select the metadata sent in the payload]:metadata' \
  '-T+[layer 4 protocol]:protocol:(UDP TCP ICMP SCTP DCCP)' \
  '-D[disable TCP Nagle algorithm]' \
  '-C+[constant inter-departure time]:rate' \
  '-U+[uniform IDT distribution]:min rate' \
  '-E+[exponential IDT distribution]:mean rate' \
  '-N+[normal IDT distribution]:mean' \
  '-O+[poisson IDT distribution]:mean' \
  '-V+[pareto IDT distribution]:shape' \
  '-Y+[cauchy IDT distribution]:shape' \
  '-G+[gamma IDT distribution]:shape' \
  '-W+[weibull IDT distribution]:shape' \
  '-Ft+[read IDTs from file (in ms)]:filename:_files' \
  '-B+[generate bursty traffic]:on distribution' \
  '-c+[constant packet size]:packet size' \
  '-u+[uniform packet size distribution]:min size' \
  '-e+[exponential packet size distribution]:average size' \
  '-n+[normal packet size distribution]:mean' \
  '-o+[poisson packet size distribution]:mean' \
  '-v+[pareto packet size distribution]:shape' \
  '-y+[cauchy packet size distribution]:shape' \
  '-g+[gamma packet size distribution]:shape' \
  '-w+[weibull packet size distribution]:shape' \
  '-Fs+[read payload sizes from file]:filename:_files' \
  '-Fp+[read payload content from file]:filename:_files' \
  '-s+[set the seed for generating distributions]:seed' \
  '-poll[use busy-wait loop for IDTs shorter than 1 msec]' \
  '-j+[guarantee the mean packet rate]:flag:(0 1)' \
  '-P[enable thread high priority (Windows only)]' && ret=0

return ret
