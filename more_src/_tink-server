#compdef tink-server
# _tink-server — Tinkerbell workflow API gRPC/HTTP server (tinkerbell/tink)
# upstream: https://github.com/tinkerbell/tink
# Flags from cmd/tink-server/main.go on tip.

_tink-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--grpc-authority=[gRPC server bind host\:port]:host\:port:' \
        '--http-authority=[HTTP server bind host\:port]:host\:port:' \
        '--backend=[datastore backend]:backend:(kubernetes)' \
        '--kubeconfig=[kubeconfig (backend=kubernetes)]:file:_files' \
        '--kubernetes=[apiserver URL (backend=kubernetes)]:url:_urls' \
        '--kube-namespace=[Kubernetes namespace to target]:ns:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr[log to stderr]'
}

_tink-server "$@"
