#compdef knex

# Zsh completion for Knex.js CLI

_knex() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:create a fresh knexfile'
    'migrate\:make:create a named migration file'
    'migrate\:latest:run all pending migrations'
    'migrate\:up:run the next or specified migration'
    'migrate\:rollback:rollback the last batch or all of migrations'
    'migrate\:down:undo the last or specified migration'
    'migrate\:currentVersion:view the current version for the migration'
    'migrate\:list:list all migrations files with status'
    'migrate\:status:list all migrations files with status'
    'migrate\:unlock:forcefully unlock the migrations lock table'
    'seed\:make:create a named seed file'
    'seed\:run:run seed files'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'knex command' commands && ret=0
      ;;
    (args)
      _arguments -s -S \
        '--debug[run with debugging]' \
        '--knexfile=[path to knexfile]:knexfile:_files -g "*.{js,ts,mjs,cjs}"' \
        '--knexpath=[path to knex module]:knex path:_files' \
        '--cwd=[specify the working directory]:directory:_files -/' \
        '--client=[database client]:client:(pg mysql mysql2 oracledb mssql sqlite3 better-sqlite3)' \
        '--connection=[database connection string]:connection:' \
        '--migrations-directory=[migrations directory]:directory:_files -/' \
        '--migrations-table-name=[migrations table name]:name:' \
        '--env=[environment]:environment:(development test staging production)' \
        '--esm[enable ESM interop]' \
        '--specific=[specific seed or migration file]:file:_files' \
        '--all[rollback all migrations]' \
        '-x+[file extension]:extension:(js ts mjs cjs coffee)' \
        '--extension=[file extension]:extension:(js ts mjs cjs coffee)' \
        '--stub=[path to stub file]:stub file:_files' \
        '--help[display help]' \
        '--version[display version]' \
        '1:name:' \
        && ret=0
      ;;
  esac

  return ret
}

_knex "$@"
