#compdef grd2xyz
# Documentation: https://docs.generic-mapping-tools.org/latest/grd2xyz.html
# Source: GenericMappingTools/gmt classic-mode grd2xyz — convert a grid to xyz triplets.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[color components from z (CPT)]:cpt:_files -g "*.cpt(-.)"' \
    '-F+[replace x/y with col/row (or 1-D index)]:opts:_default' \
    '-L+[limit output to single row/column]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T+[STL triangulation output (ASCII/binary)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[output weights (supplied or cell area)]:opts:_default' \
    '-Z+[single-column output (row/col ordering)]:flags:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-o+[output column selection]:cols:_default' \
    '-s+[NaN-record handling]:opts:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
