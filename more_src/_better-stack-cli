#compdef better-stack-cli better-stack betterstack
# _better-stack-cli — Better Stack better-stack-cli CLI command-line frontend wrapping the Better Stack observability incident-management uptime-monitoring log-management platform formerly Better Uptime Logtail providing monitor heartbeat status-page incident on-call schedule team policy escalation source live-tail log-drain log-query metric service-availability-SLO synthetic-monitoring (Better Stack team Tomas Kalivoda Better Stack, Go); cobra
# upstream: https://betterstack.com/

_better-stack-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'monitor:monitor operations'
        'heartbeat:heartbeat operations'
        'status-page:status page operations'
        'incident:incident operations'
        'on-call:on-call operations'
        'schedule:schedule operations'
        'team:team operations'
        'policy:policy operations'
        'source:log source operations'
        'tail:live log tail'
        'log:log search and ops'
        'metric:metric operations'
        'sla:SLA operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token=+[token]:str:' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--team=+[name]:str:' \
        '--region=+[r]:r:(us eu)' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'better-stack subcommand' sub ;;
        args)
            case $words[1] in
                monitor|heartbeat|status-page|incident|on-call|schedule|team|policy|source|metric|sla) _arguments '1:op:(list get create update delete pause resume acknowledge resolve)' '*:id:' ;;
                tail) _arguments '*:source:' ;;
                log) _arguments '1:op:(search export tail)' '*:query:' ;;
            esac
            ;;
    esac
}

_better-stack-cli "$@"
