#compdef mris_convert
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_convert
# mris_convert - convert between surface file formats and overlay data

local ret=1

_arguments -s -S \
  '-p[treat input as a patch file]' \
  '-c[combine surface with curvature file]:curv file:_files' \
  '-o[combine surface with orig file]:orig file:_files' \
  '-t[talairach transform input]' \
  '1:input surface:_files' \
  '2:output surface:_files' && ret=0

return ret
