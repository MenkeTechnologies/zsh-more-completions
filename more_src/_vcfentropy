#compdef vcfentropy
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfentropy.md
# Annotate VCF records with Shannon entropy of flanking sequence

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --fasta-reference)'{-f,--fasta-reference}'[FASTA reference file for flanking sequences]:FASTA file:_files' \
  '(-w --window-size)'{-w,--window-size}'[size of the window over which to calculate entropy]:bp' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
