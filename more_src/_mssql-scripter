#compdef mssql-scripter
# Documentation: https://github.com/microsoft/mssql-scripter/blob/dev/doc/usage_guide.md
# mssql-scripter - generate CREATE and INSERT T-SQL scripts for SQL Server / Azure SQL databases

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--connection-string[database connection string]:conn string' \
  '(-S --server)'{-S,--server}'[server name]:server' \
  '(-d --database)'{-d,--database}'[database name]:database' \
  '(-U --user)'{-U,--user}'[login id]:user' \
  '(-P --password)'{-P,--password}'[password]:password' \
  '(-f --file-path)'{-f,--file-path}'[output file or directory]:path:_files' \
  '--file-per-object[create separate file for each object]' \
  '--append[append script to existing file]' \
  '--exclude-use-database[omit USE DATABASE statement]' \
  '--data-only[generate data scripts only]' \
  '--schema-and-data[include both schema and data]' \
  '--script-create[script CREATE statements]' \
  '--script-drop[script DROP statements]' \
  '--script-drop-create[script DROP and CREATE statements]' \
  '*--include-objects[objects to include]:object' \
  '*--exclude-objects[objects to exclude]:object' \
  '*--include-schemas[schemas to include]:schema' \
  '*--exclude-schemas[schemas to exclude]:schema' \
  '*--include-types[object types to include]:type' \
  '*--exclude-types[object types to exclude]:type' \
  '--target-server-version[target SQL Server version]:version' \
  '--target-server-edition[target SQL Server edition]:edition' \
  '(-r --continue-on-error)'{-r,--continue-on-error}'[continue despite errors]' \
  '--check-for-existence[verify object existence]' \
  '--convert-uddts[convert user-defined data types]' \
  '--include-dependencies[include dependent objects]' \
  '--disable-schema-qualification[remove schema prefixes]' \
  '--display-progress[show progress during scripting]' \
  '--enable-toolsservice-logging[enable verbose logging]' \
  '--version[show version]' && ret=0

return ret
