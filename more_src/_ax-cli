#compdef ax-cli ax-platform
# _ax-cli — Meta Facebook Ax ax-cli CLI command-line frontend wrapping the Ax adaptive experimentation platform from Meta providing experiment optimization Bayesian-optimization bandit a-b-testing BOTorch backend trials arm metric optimization-config status update get cube quad evaluate parallel sequential clients service api factor (Meta team, Python); click
# upstream: https://ax.dev/

_ax-cli() {
    local -a sub=(
        'create-experiment:create an experiment'
        'load-experiment:load an experiment'
        'save-experiment:save an experiment'
        'get-next-trial:get the next trial to evaluate'
        'complete-trial:complete a trial'
        'list-trials:list all trials'
        'get-best:get best parameters'
        'evaluate:run evaluation'
        'render:render results'
        'export-frame:export trials as DataFrame'
        'remove-trial:remove a trial'
        'service-api:service API operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--name=+[name]:str:' \
        '--parameters=+[json]:str:' \
        '--parameter-constraints=+[json]:str:' \
        '--outcome-constraints=+[json]:str:' \
        '--objectives=+[json]:str:' \
        '--minimize[minimize]' \
        '--maximize[maximize]' \
        '--tracking-metric-names=+[list]:str:' \
        '--status-quo=+[json]:str:' \
        '--num-arms=+[N]:n:' \
        '--num-trials=+[N]:n:' \
        '--trial-type=+[t]:t:(GENERATOR_RUN BATCH SINGLE)' \
        '--generation-strategy=+[json]:str:' \
        '--storage-uri=+[uri]:str:' \
        '--immutable-search-space-and-opt-config[immutable]' \
        '--support-intermediate-data[support intermediate]' \
        '--enforce-sequential-optimization[enforce sequential]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ax-cli subcommand' sub ;;
    esac
}

_ax-cli "$@"
