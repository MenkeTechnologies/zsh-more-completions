#compdef toybox
# _toybox — Rob Landley toybox (single multi-call binary providing 200+ Linux utilities; toybox prints command list, toybox <cmd> [args] dispatches to that command; symlinked names of each command work as standalone binaries)
# upstream: https://github.com/landley/toybox
# Subcommands from toybox toys/*/*.c on tip.

_toybox() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--long[print long command names]' \
        '--info[print build/host info]' \
        '1:command:(acpi ascii base32 base64 basename blockdev cal cat chattr chcon chgrp chmod chown chroot chrt cksum clear cmp comm cp cpio crc32 cut date dd df diff dirname dmesg dnsdomainname du echo egrep env expand expr factor fallocate false fgrep file find fmt free freeramdisk fsync ftpget ftpput getconf getopt grep groups gunzip gzip head help hexdump host hostid hostname iconv id ifconfig inotifyd insmod install ionice iorenice ip ipcrm ipcs kill killall killall5 link ln logger login logname losetup ls lsattr lsmod lspci lsusb makedevs md5sum mix mkdir mkfifo mknod mkpasswd mkswap mktemp modinfo more mount mountpoint mv nbd-client nbd-server netcat netstat nice nl nohup nproc nsenter od oneit openvt partprobe passwd paste patch pgrep pidof ping ping6 pivot_root pkill pmap poweroff printenv printf prlimit ps pwd pwdx readahead readelf readlink realpath reboot renice reset rev rfkill rm rmdir rmmod route runcon sed seq setfattr setsid sha1sum sha224sum sha256sum sha384sum sha512sum shred shuf skeleton sleep sort split stat stty su sulogin swapoff swapon switch_root sync sysctl syslogd tac tail tar taskset tcpsvd tee telnet telnetd test tftp tftpd time timeout top touch toysh traceroute traceroute6 true truncate tty tunctl ulimit umount uname uniq unix2dos unlink unshare uptime useradd userdel usermod usleep uuidgen uudecode uuencode vconfig vi vmstat w watch wc wget which who whoami xargs xxd xzcat yes zcat)' \
        '*::args:'
}

_toybox "$@"
