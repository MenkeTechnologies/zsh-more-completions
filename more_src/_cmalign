#compdef cmalign
# Documentation: https://manpages.debian.org/testing/infernal/cmalign.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmalign: align sequences to a covariance model
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output alignment file]:file:_files' \
  '(-g --glocal)'{-g,--glocal}'[global alignment]' \
  '--noprob[do not output posterior probabilities]' \
  '--matchonly[only emit match-column residues]' \
  '--mxsize[soft memory cap (MB)]:MB:' \
  '--cpu[number of CPU threads]:n:' \
  '--ileaved[interleaved output]' \
  '--small[use small-memory alignment algorithm]' \
  '--nonbanded[disable banded alignment]' \
  '--notrunc[disallow truncated alignment]' \
  '--sub[infer subseq endpoints (truncated alignment)]' \
  '--hbanded[use HMM-banded CYK]' \
  '--tau[HMM band tail loss probability]:tau:' \
  '--mxtau[posterior matrix tau]:val:' \
  '--maxtau[maximum tau]:val:' \
  '--seed[random seed]:n:' \
  '--informat[input format]:format:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip)' \
  '--outformat[output format]:format:(stockholm pfam a2m afa clustal phylip phylips)' \
  '*:CM file and sequence file:_files' && ret=0
return ret
