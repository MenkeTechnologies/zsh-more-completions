#compdef lep
# Documentation: https://github.com/leptonai/leptonai/tree/main/leptonai/cli
# Lepton AI / NVIDIA DGX Cloud Lepton command line interface

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'login:log in to a Lepton workspace'
      'logout:log out of the current workspace'
      'deployment:manage deployments'
      'job:manage jobs'
      'pod:manage pods'
      'secret:manage secrets'
      'storage:manage storage'
      'workspace:manage workspaces'
      'node:manage nodes'
      'ingress:manage ingresses'
      'log:view logs'
      'raycluster:manage Ray clusters'
      'template:manage templates'
      'finetune:manage fine-tuning jobs'
    )
    _describe -t commands 'lep command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      job)
        local -a sub
        sub=(
          'create:create a job'
          'list:list jobs'
          'get:get a job'
          'log:view job logs'
          'stop:stop a job'
          'start:start a job'
          'clone:clone a job'
          'remove:remove a job'
          'remove-all:remove all jobs'
          'stop-all:stop all jobs'
          'replicas:list job replicas'
          'nodes:list job nodes'
          'events:list job events'
        )
        _describe -t subcommands 'job subcommand' sub && ret=0
        ;;
      deployment)
        local -a sub
        sub=(
          'create:create a deployment'
          'list:list deployments'
          'get:get a deployment'
          'status:show deployment status'
          'update:update a deployment'
          'restart:restart a deployment'
          'remove:remove a deployment'
          'stop:stop a deployment'
          'log:view deployment logs'
          'endpoint:show the deployment endpoint'
          'events:list deployment events'
        )
        _describe -t subcommands 'deployment subcommand' sub && ret=0
        ;;
      secret)
        local -a sub
        sub=(
          'create:create a secret'
          'list:list secrets'
          'remove:remove a secret'
        )
        _describe -t subcommands 'secret subcommand' sub && ret=0
        ;;
      node)
        local -a sub
        sub=(
          'list:list nodes'
          'list-nodes:list nodes'
          'list-reservations:list reservations'
          'resource-shape:show resource shapes'
          'storage:show node storage'
        )
        _describe -t subcommands 'node subcommand' sub && ret=0
        ;;
      workspace)
        local -a sub
        sub=(
          'login:log in to a workspace'
          'logout:log out of a workspace'
          'list:list workspaces'
          'remove:remove a workspace'
          'removeall:remove all workspaces'
          'id:print the current workspace id'
          'token:print the current workspace token'
          'url:print the current workspace url'
          'status:show workspace status'
        )
        _describe -t subcommands 'workspace subcommand' sub && ret=0
        ;;
      *)
        ret=0
        ;;
    esac
    ;;
esac

return ret
