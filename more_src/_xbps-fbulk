#compdef xbps-fbulk
# Documentation: https://man.archlinux.org/search?q=xbps-fbulk
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-a+[target architecture]:arch:' \
  '-j+[parallel jobs]:n:' \
  '-l+[log directory]:dir:_files -/' \
  '1:xbps-src-path:_files' \
  '*:packages:' && ret=0

return ret
