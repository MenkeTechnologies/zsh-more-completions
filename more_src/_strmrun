#compdef strmrun
# strmrun - KLayout buddy tool: run a Ruby/Python script against the layout engine
# Source: https://www.klayout.de/command_args.html (KLayout interpreter options)
# Reference accessed: 2026-06-21

local ret=1

_arguments -s \
  '-h[show help]' \
  '-r+[run script in interpreter mode then exit]:script:_files -g "*.(rb|py|drc|lydrc)"' \
  '-rd+[define an interpreter variable (name=value)]:name=value:' \
  '-rx[ignore implicit macros]' \
  '-e[force edit mode]' \
  '-z[non-GUI mode]' \
  '-zz[fully headless mode]' \
  '-j+[add path to macro search locations]:dir:_directories' \
  '-d+[debug level]:level:' \
  '-wd+[define an expression variable (name=value)]:name=value:' \
  '-v[show version]' \
  '*:script:_files -g "*.(rb|py|drc)"' && ret=0

return ret
