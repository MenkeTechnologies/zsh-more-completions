#compdef efilter

# NCBI EDirect efilter: filter Entrez results by date/type/range
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-query=[filter query string]:query:' \
  '-mindate=[minimum date (YYYY/MM/DD)]:date:' \
  '-maxdate=[maximum date]:date:' \
  '-datetype=[date field to filter on]:type:(PDAT EDAT MDAT)' \
  '-days=[entries within last N days]:days:' \
  '-feature=[feature type filter]:type:' \
  '-organism=[organism filter]:organism:' \
  '-source=[source database filter]:source:' \
  '-status=[status filter]:status:' \
  '-type=[publication type filter]:type:' \
  '-journal=[journal name filter]:journal:' \
  '-released=[release status (last_week/last_month/last_year)]:status:' \
  '-published=[published in date range]:range:' \
  '-country=[country filter]:country:' \
  '-pub=[publication type]:type:' \
  '-cmd=[command mode]:cmd:' \
  '*::filter terms:' && ret=0
return ret
