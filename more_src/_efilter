#compdef efilter
# Documentation: https://dataguide.nlm.nih.gov/edirect/efilter.html
# Reference accessed: 2026-05-17
# Verified: upstream NLM EDirect docs at the URL above.

# NCBI EDirect efilter: filter and/or sort Entrez search results
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-query=[filter query string]:query:' \
  '-sort=[sort results by field]:field:' \
  '-mindate=[minimum date (YYYY/MM/DD)]:date:' \
  '-maxdate=[maximum date]:date:' \
  '-datetype=[date field to filter on]:type:(PDAT EDAT MDAT)' \
  '-days=[entries within last N days]:days:' \
  '-field=[query words individually in a field]:field:' \
  '-pairs=[query overlapping word pairs]:field:' \
  '-spell[correct misspellings in queries]' \
  '-pub=[publication type]:type:(abstract clinical english free journal review)' \
  '-journal=[journal name filter]:journal:' \
  '-released=[release status]:status:(last_week last_month last_year prev_years)' \
  '-country=[country filter]:country:' \
  '-feature=[feature type filter]:feature:' \
  '-location=[location filter]:location:' \
  '-molecule=[molecule filter]:molecule:' \
  '-organism=[organism filter]:organism:' \
  '-source=[source database filter]:source:' \
  '-division=[division filter]:division:' \
  '-status=[gene status (alive)]:status:(alive)' \
  '-type=[type filter (coding/pseudo)]:type:' \
  '-class=[SNP variant class]:class:(missense nonsense synonymous)' \
  '-kind=[biosystems kind]:kind:(pathway)' \
  '-pathway=[pathway type]:type:(reactome wikipathways)' \
  '-label=[label query]:label:' \
  '*::filter terms:' && ret=0
return ret
