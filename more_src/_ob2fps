#compdef ob2fps
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp fingerprint generator using the Open Babel toolkit

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--FP2[create FP2-type fingerprints (default)]' \
  '--MACCS[generate MACCS fingerprints]' \
  '--rdmaccs[generate RDMACCS fingerprints]' \
  '--id-tag=[identifier SD field]:tag:' \
  '-o+[output filename]:file:_files' \
  '--using=[reference fingerprint type from existing file]:file:_files' \
  '--no-progress[disable progress bar]' \
  '*:structure file:_files' && ret=0

return ret
