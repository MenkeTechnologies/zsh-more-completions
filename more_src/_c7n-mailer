#compdef c7n-mailer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[mailer config file]:file:_files -g "*.yml(|.yaml)"' \
  '--config[mailer config file]:file:_files -g "*.yml(|.yaml)"' \
  '--run[run the mailer daemon]' \
  '--update-lambda[deploy/update Lambda mailer]' \
  '--type[transport type]:type:(sqs sns)' \
  '--templates[custom templates directory]:directory:_directories' \
  '--group[resource group for Azure]:group:' \
  '--max-num-processes[max parallel processes]:number:' \
  '(-h --help)'{-h,--help}'[show help]' \
  && ret=0

return ret
