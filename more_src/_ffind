#compdef ffind
# _ffind — Brian Carrier Sleuthkit ffind CLI for finding allocated or deleted file names mapped to a given inode metadata address across NTFS FAT extX HFS+ ISO9660 file systems (sleuthkit team, C); getopt
# upstream: https://github.com/sleuthkit/sleuthkit

_ffind() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-a[only allocated]' \
        '-d[only deleted]' \
        '-l[long]' \
        '-n+[image start offset]:n:' \
        '-o+[image offset]:n:' \
        '-b+[block size]:n:' \
        '-f+[fs type]:t:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs1 ufs2 yaffs2 iso9660 hfs swap)' \
        '-i+[img type]:i:(raw aff afd afm afflib aff4 ewf split qcow vmdk vhd)' \
        '-z+[zone]:str:' \
        '-s+[time skew]:n:' \
        '-r+[recursive]' \
        '-p[just print path]' \
        '*:image inode:_files'
}

_ffind "$@"
