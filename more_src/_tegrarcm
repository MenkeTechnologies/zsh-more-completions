#compdef tegrarcm

# tegrarcm: NVIDIA Tegra USB recovery mode programmer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--bct=[BCT file]:file:_files' \
  '--bootloader=[bootloader image]:file:_files' \
  '--loadaddr=[load address]:hex:' \
  '--entryaddr=[entry address]:hex:' \
  '--soc=[Tegra SoC]:soc:(tegra20 tegra30 tegra114 tegra124 tegra210 tegra186 tegra194)' \
  '--keyfile=[secure boot key]:file:_files' \
  '--miniloader=[mini-loader]:file:_files' \
  '--reset[reset device]' \
  '--usb-port-path=[USB device port path]:path:' \
  '--list[list connected devices]' \
  '*::tegrarcm args:_files' && ret=0
return ret
