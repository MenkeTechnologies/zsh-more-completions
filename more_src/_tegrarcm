#compdef tegrarcm
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/tegrarcm.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Ubuntu focal tegrarcm(1) man page.
# Removed from prior file: -h/-v short forms (not documented), --reset, --list,
# --keyfile (use --pkc), and the hardcoded --soc value list (man page just
# says "Tegra SoC chip model" without enumerating values).

local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[print help and exit]' \
  '--version[print version and exit]' \
  '--bct=[BCT file]:file:_files' \
  '--bootloader=[bootloader/firmware file]:file:_files' \
  '--loadaddr=[hex load address]:hex:' \
  '--entryaddr=[hex entry address]:hex:' \
  '--miniloader=[custom miniloader file]:file:_files' \
  '--miniloader_entry=[miniloader entry address]:hex:' \
  '--usb-port-path=[USB device physical port path]:path:' \
  '--pkc=[private key file (DER)]:file:_files -g "*.der"' \
  '--gen-signed-msgs[generate signed messages]' \
  '--signed-msgs-file=[message file prefix]:prefix:' \
  '--download-signed-msgs[download signed messages]' \
  '--soc=[Tegra SoC chip model]:soc:' \
  '--usb-timeout=[USB transfer timeout (ms)]:ms:' \
  '*:command:(readbct)' && ret=0
return ret
