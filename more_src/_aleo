#compdef aleo
# _aleo — Aleo Network Foundation aleo SDK CLI for Aleo zero-knowledge programs new build run execute transfer deploy and key generation in Leo and snarkVM (AleoHQ team, Rust); clap
# upstream: https://github.com/AleoHQ/aleo

_aleo() {
    local -a sub=(
        'new:create new Aleo project'
        'build:build Aleo program'
        'clean:clean build artifacts'
        'run:run a function locally'
        'execute:execute on chain'
        'deploy:deploy program'
        'transfer:transfer ALEO credits'
        'account:account operations'
        'node:run local Aleo node'
        'developer:developer commands'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--network=+[net]:n:(mainnet testnet3 testnet4 canarynet)' \
        '--endpoint=+[url]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aleo subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments '*:project name:' ;;
                build|clean) _arguments \
                    '-p+[path]:dir:_files -/' \
                    '--path=+[path]:dir:_files -/' ;;
                run|execute) _arguments \
                    '-p+[path]:dir:_files -/' \
                    '--path=+[path]:dir:_files -/' \
                    '*:function and inputs:' ;;
                deploy) _arguments \
                    '--private-key=+[key]:str:' \
                    '--fee=+[microcredits]:n:' \
                    '*:program:_files -g "*.aleo"' ;;
                transfer) _arguments \
                    '--private-key=+[key]:str:' \
                    '--recipient=+[addr]:str:' \
                    '--amount=+[microcredits]:n:' \
                    '--fee=+[microcredits]:n:' ;;
                account) _arguments \
                    '1:action:(new sign verify)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_aleo "$@"
