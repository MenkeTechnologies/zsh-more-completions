#compdef impacket-reg
# Documentation: https://github.com/fortra/impacket/blob/master/examples/reg.py
# Windows registry manipulation script

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-debug[turn DEBUG output ON]' \
  '-ts[adds timestamp to every logging output]' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-dc-ip=[IP address of the domain controller]:ip' \
  '-target-ip=[IP address of the target machine]:ip' \
  '-port=[destination port to connect to SMB server]:port:(139 445)' \
  '1:target (\[\[domain/\]username\[:password\]@\]<host>):' \
  '*::command:((query\:"return subkeys and entries under a subkey" add\:"add a new subkey or entry to the registry" delete\:"delete a subkey or entries from the registry" save\:"save subkeys/entries/values to a file" backup\:"back up SAM, SYSTEM and SECURITY to a file"))' && ret=0

return ret
