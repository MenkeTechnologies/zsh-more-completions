#compdef hackmd hackmd-cli codimd
# _hackmd — HackMD team hackmd-cli command-line interface for the HackMD/CodiMD collaborative Markdown workspace (hackmdio team, Node.js); commander
# upstream: https://github.com/hackmdio/hackmd-cli

_hackmd() {
    local -a sub=(
        'login:login to HackMD'
        'logout:logout from HackMD'
        'whoami:show current user'
        'history:show history'
        'me:show current user'
        'profile:show current profile'
        'export:export notes'
        'import:import notes from files'
        'note:note subcommands'
        'team:team subcommands'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.json"' \
        '-c+[config file]:file:_files -g "*.json"' \
        '--cookie-path=+[cookie path]:file:_files' \
        '--server-url=+[server url]:url:_urls' \
        '--enterprise[enterprise mode]' \
        '--clientconfig=+[config]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hackmd subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--email=+[email]:str:' \
                    '-e+[email]:str:' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--ldap[ldap login]' ;;
                export) _arguments \
                    '--format=+[format]:f:(md html pdf slide)' \
                    '-f+[format]:f:(md html pdf slide)' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '*:note id:' ;;
                import) _arguments \
                    '--team-path=+[team path]:str:' \
                    '*:file:_files -g "*.md *.markdown"' ;;
                note) _arguments '1:note cmd:(create list publish update delete share unshare permission history)' ;;
                team) _arguments '1:team cmd:(list note members invite remove role)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_hackmd "$@"
