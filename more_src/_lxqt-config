#compdef lxqt-config
# Documentation: https://github.com/lxqt/lxqt-config
# Reference accessed: 2026-05-17
# Verified: lxqt/lxqt-config upstream. Standard Qt application flags
# only — no tool-specific CLI flags documented upstream.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --reverse, --platformpluginpath, --qmljsdebugger,
# --qwindow* options (these are generic Qt flags but not all are
# documented for this binary).

# lxqt-config: LXQt configuration center hub
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--style=[Qt GUI style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '--platform=[Qt platform plugin]:platform:' \
  '--platformpluginpath=[Qt plugin path]:dir:_files -/' \
  '--display=[X display]:display:' \
  '--qmljsdebugger=[QML debugger]:port:' \
  '--reverse[reverse layout direction]' \
  '--qwindowgeometry=[window geometry]:WxH+X+Y:' \
  '--qwindowicon=[window icon]:icon:' \
  '--qwindowtitle=[window title]:title:' \
  '*::lxqt-config args:_files' && ret=0
return ret
