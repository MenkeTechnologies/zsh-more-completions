#compdef jreleaser
# _jreleaser — multi-platform release automation (jreleaser/jreleaser)
# upstream: https://github.com/jreleaser/jreleaser
# Subcommands from plugins/jreleaser/src/main/java/org/jreleaser/cli/*.java (picocli).

_jreleaser() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[suppress all output]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '(-i --info)'{-i,--info}'[enable info logging]' \
        '(-w --warn)'{-w,--warn}'[enable warning logging]' \
        '--basedir=[base project directory]:dir:_files -/' \
        '--config-file=[explicit jreleaser config file]:file:_files -g "*.{yml,yaml,toml,json}"' \
        '--output-directory=[output directory]:dir:_files -/' \
        '--dry-run[run without performing side effects]' \
        '--git-root-search[search up the directory tree for the git root]' \
        '--strict[treat warnings as errors]' \
        '*'{-P+,--set-property=}'[override a property (key=value)]:prop:' \
        '*--system-property=[set a JVM system property (key=value)]:prop:' \
        '*-e+[set an env var (key=value)]:env:' \
        '--select-current-platform[only act on the current OS/arch platform]' \
        '*--select-platform=[only act on this platform identifier]:platform:' \
        '1: :_jreleaser_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_jreleaser_commands] )) ||
_jreleaser_commands() {
    local -a commands
    commands=(
        'init:initialize jreleaser configuration files'
        'config:print the resolved jreleaser configuration'
        'template:scaffold packager templates'
        'template-eval:evaluate a template against the config'
        'download:download artifacts referenced by the config'
        'assemble:assemble distributions (jlink, jpackage, native-image, archive, ...)'
        'changelog:generate the release changelog'
        'checksum:generate checksums for distribution artifacts'
        'catalog:generate SBOMs / supply-chain catalogs'
        'sign:sign distribution artifacts'
        'deploy:deploy generated artifacts to artifact repositories'
        'upload:upload generated artifacts to cloud storage'
        'release:create a release on the configured release tools'
        'prepare:prepare distributions for packaging'
        'package:package prepared distributions'
        'publish:publish packaged distributions to their packagers'
        'announce:announce the release to the configured announcers'
        'full-release:run download → assemble → release → publish → announce'
        'json-schema:print the jreleaser JSON schema'
        'env:print effective JReleaser environment'
        'io:show last failed I/O log entries'
    )
    _describe -t commands 'jreleaser command' commands
}

_jreleaser "$@"
