#compdef apt-key
# Documentation: https://manpages.debian.org/apt-key
# Source: Debian/apt cmdline/apt-key.in — apt trusted-key manager (shell, deprecated upstream).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '--keyring+[restrict to keyring file]:file:_files -g "*.{gpg,asc}"' \
    '1:command:(add del export exportall update net-update list finger adv)' \
    '*::command args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            add) _arguments '1:key file:_files' && ret=0 ;;
            del|export) _arguments '1:keyid:_default' && ret=0 ;;
            adv) _arguments '*:gpg argument:_default' && ret=0 ;;
        esac
        ;;
esac

return ret
