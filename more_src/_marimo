#compdef marimo

# Zsh completion for marimo - reactive Python notebook

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'edit:create or edit a marimo notebook'
  'new:create a new marimo notebook'
  'run:run a marimo notebook as an app'
  'tutorial:open a marimo tutorial'
  'convert:convert between notebook formats'
  'export:export a notebook to various formats'
  'config:manage marimo configuration'
  'env:print environment information'
  'recover:recover a notebook from autosave'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[print version information]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'marimo command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (edit|new)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to run on]:port' \
          '--host=[host to bind to]:host' \
          '--headless[do not open the browser]' \
          '--token[require authentication token]' \
          '--no-token[do not require authentication token]' \
          '--token-password=[set password for token authentication]:password' \
          '--sandbox[run in sandbox mode]' \
          '--watch[watch for file changes and reload]' \
          '--base-url=[set base URL]:url' \
          '1:notebook file:_files -g "*.py"' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to run on]:port' \
          '--host=[host to bind to]:host' \
          '--headless[do not open the browser]' \
          '--token[require authentication token]' \
          '--no-token[do not require authentication token]' \
          '--include-code[include code in the app]' \
          '--base-url=[set base URL]:url' \
          '--sandbox[run in sandbox mode]' \
          '--watch[watch for file changes and reload]' \
          '1:notebook file:_files -g "*.py"' && ret=0
        ;;
      (tutorial)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to run on]:port' \
          '--host=[host to bind to]:host' \
          '1:tutorial:(intro dataflow ui markdown plots sql layout fileformat for-jupyter-users)' && ret=0
        ;;
      (convert)
        _arguments -s -S \
          '1:input file:_files -g "*.{py,ipynb,md}"' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' && ret=0
        ;;
      (export)
        _arguments -s -S \
          '1:format:(html md ipynb script)' \
          '2:notebook file:_files -g "*.py"' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' \
          '--include-code[include code in export]' \
          '--no-include-code[exclude code from export]' && ret=0
        ;;
      (config)
        _arguments -s -S \
          '1:action:(show)' && ret=0
        ;;
      (recover)
        _arguments -s -S \
          '1:notebook file:_files -g "*.py"' && ret=0
        ;;
    esac
    ;;
esac

return ret
