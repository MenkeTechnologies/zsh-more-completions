#compdef marimo
# Documentation: https://docs.marimo.io/cli/
# Reference accessed: 2026-05-19
# Verified: upstream marimo CLI reference at docs.marimo.io/cli.
# Removed from prior file: bogus man.archlinux.org URL; added check,
# pair, shell-completion subcommands; corrected export format set to
# include html-wasm, pdf, session, thumbnail; added config describe.

# Zsh completion for marimo - reactive Python notebook

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'edit:create or edit a marimo notebook'
  'new:create empty notebook or generate from AI prompt'
  'run:run a marimo notebook as an app (read-only)'
  'check:check and format marimo files'
  'tutorial:open a marimo tutorial'
  'convert:convert Jupyter/Markdown/script to marimo notebook'
  'export:export a notebook to various formats'
  'config:manage marimo configuration'
  'env:print environment information'
  'recover:recover a marimo notebook from a JSON file'
  'pair:AI pair programming helpers'
  'shell-completion:install shell completions'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[print version information]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'marimo command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (edit|new)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to run on]:port' \
          '--host=[host to bind to]:host' \
          '--proxy=[proxy URL]:url' \
          '--headless[do not open the browser]' \
          '--token[require authentication token]' \
          '--no-token[do not require authentication token]' \
          '--token-password=[set password for token authentication]:password' \
          '--token-password-file=[file containing token password]:file:_files' \
          '--base-url=[set base URL]:url' \
          '--allow-origins=[allowed CORS origins]:origins' \
          '--skip-update-check[skip update check]' \
          '--sandbox[run in sandbox mode]' \
          '--no-sandbox[disable sandbox mode]' \
          '--trusted[mark notebook as trusted]' \
          '--untrusted[mark notebook as untrusted]' \
          '--watch[watch for file changes and reload]' \
          '--skew-protection[enable skew protection]' \
          '--no-skew-protection[disable skew protection]' \
          '--timeout=[startup timeout]:secs' \
          '--session-ttl=[session TTL]:secs' \
          '1:notebook file:_files -g "*.py"' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to run on]:port' \
          '--host=[host to bind to]:host' \
          '--proxy=[proxy URL]:url' \
          '--headless[do not open the browser]' \
          '--token[require authentication token]' \
          '--no-token[do not require authentication token]' \
          '--include-code[include code in the app]' \
          '--session-ttl=[session TTL]:secs' \
          '--watch[watch for file changes and reload]' \
          '--base-url=[set base URL]:url' \
          '--allow-origins=[allowed CORS origins]:origins' \
          '--sandbox[run in sandbox mode]' \
          '--check[run check before serving]' \
          '--no-check[skip check before serving]' \
          '--trusted[mark notebook as trusted]' \
          '--untrusted[mark notebook as untrusted]' \
          '--show-tracebacks[show full tracebacks]' \
          '--no-show-tracebacks[suppress tracebacks]' \
          '1:notebook file:_files -g "*.py"' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '--fix[apply fixes]' \
          '--strict[strict mode]' \
          '--verbose[verbose output]' \
          '--quiet[quiet output]' \
          '--unsafe-fixes[apply unsafe fixes]' \
          '--ignore-scripts[ignore script files]' \
          '--format=[output format]:format' \
          '--select=[rules to select]:rules' \
          '--ignore=[rules to ignore]:rules' \
          '*:file:_files -g "*.py"' && ret=0
        ;;
      (tutorial)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to run on]:port' \
          '--host=[host to bind to]:host' \
          '1:tutorial:(intro dataflow ui markdown plots sql layout fileformat for-jupyter-users)' && ret=0
        ;;
      (convert)
        _arguments -s -S \
          '1:input file:_files -g "*.{py,ipynb,md}"' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' && ret=0
        ;;
      (export)
        _arguments -s -S -C \
          '1:format:(html html-wasm md ipynb script pdf session thumbnail)' \
          '*::export-arg:->export_args' && ret=0
        case $state in
          (export_args)
            _arguments -s -S \
              '(-o --output)'{-o,--output}'[output file path]:file:_files' \
              '--include-code[include code in export]' \
              '--no-include-code[exclude code from export]' \
              '--watch[watch and re-export on change]' \
              '--sandbox[export in sandbox mode]' \
              '--sort=[sort order]:order' \
              '--include-outputs[include cell outputs]' \
              '(-f --force)'{-f,--force}'[overwrite output]' \
              '1:notebook file:_files -g "*.py"' && ret=0
            ;;
        esac
        ;;
      (config)
        _arguments -s -S \
          '1:action:(show describe)' && ret=0
        ;;
      (recover)
        _arguments -s -S \
          '1:notebook file:_files -g "*.{py,json}"' && ret=0
        ;;
      (pair)
        _arguments -s -S \
          '1:action:(prompt)' \
          '--url=[notebook URL]:url' \
          '--claude[generate Claude prompt]' \
          '--codex[generate Codex prompt]' \
          '--opencode[generate opencode prompt]' \
          '--with-token[include auth token]' && ret=0
        ;;
      (shell-completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
