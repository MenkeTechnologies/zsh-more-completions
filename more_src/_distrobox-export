#compdef distrobox-export

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--app=[application to export]:application' \
  '--bin=[binary to export]:binary:_files' \
  '--service=[service to export]:service' \
  '--delete[delete exported application]' \
  '--export-label=[label for exported app]:label' \
  '--export-path=[path to export to]:directory:_directories' \
  '--extra-flags=[extra flags]:flags' \
  '--sudo[export with sudo prefix]' \
  '-a[application to export]:application' \
  '-b[binary to export]:binary:_files' \
  '-s[service to export]:service' \
  '-d[delete exported application]' \
  '-el[export label]:label' \
  '-ep[export path]:directory:_directories' \
  '-ef[extra flags]:flags' && ret=0

return ret
