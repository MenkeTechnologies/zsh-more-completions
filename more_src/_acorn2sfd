#compdef acorn2sfd
# Documentation: https://fontforge.org/docs/fontutils/acorn2sfd.html
# Convert Acorn RISC/OS font directories to FontForge sfd format

local ret=1

_arguments -s -S \
  '(- *)-help[show mini description and list options]' \
  '(- *)-version[show version (date stamp of source)]' \
  '-includestrokes[retain the secondary stroked character variant]' \
  '*:acorn font dir:_files -/' && ret=0

return ret
