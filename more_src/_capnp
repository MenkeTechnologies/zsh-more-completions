#compdef capnp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'compile:compile Cap\x27n Proto schema'
      'decode:decode binary message to text'
      'encode:encode text message to binary'
      'eval:evaluate a constant from a schema file'
      'id:generate a unique type ID'
      'convert:convert between message formats'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      compile)
        _arguments \
          '-I+[add import path]:directory:_directories' \
          '--import-path=[add import path]:directory:_directories' \
          '-o+[output specification]:output spec' \
          '--output=[output specification]:output spec' \
          '--src-prefix=[prefix to remove from source paths]:prefix' \
          '--no-standard-import[do not add standard import paths]' \
          '*:schema file:_files -g "*.capnp"' && ret=0
        ;;
      decode|encode)
        _arguments \
          '--flat[use flat format]' \
          '--packed[use packed format]' \
          '--short[use short text format]' \
          '--segment-size=[maximum segment size]:size' \
          '1:schema file:_files -g "*.capnp"' \
          '2:type name' && ret=0
        ;;
      eval)
        _arguments \
          '-I+[add import path]:directory:_directories' \
          '--binary[output as binary]' \
          '--flat[use flat format]' \
          '--packed[use packed format]' \
          '--short[use short text format]' \
          '1:expression' && ret=0
        ;;
    esac
    ;;
esac

return ret
