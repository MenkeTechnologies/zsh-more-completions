#compdef yarn-cli2 yarn2
# _yarn-cli2 — Facebook Yarn yarn-cli2 CLI command-line frontend wrapping the Yarn open-source fast reliable and secure dependency manager for JavaScript Node.js originally Facebook now community-maintained current Yarn Berry Yarn 2/3/4 Plug n Play PnP zero-installs constraints CLI Berry alternative to npm yarn-classic-v1 and yarn-berry-v2-3-4 Yarn-2 Yarn-3 Yarn-4 install add remove run upgrade outdated pack publish workspaces workspace install run remove patch unplug version policies link unlink why explain info config rebuild npm whoami git list deduplicate dedupe constraints exec node up cache plugin search audit dlx (Facebook Yarn Maël Nison Sebastien Lorber, JavaScript/TypeScript); commander
# upstream: https://yarnpkg.com/

_yarn-cli2() {
    local -a sub=(
        'add:Add a dependency'
        'audit:Check for vulnerabilities'
        'autoclean:Clean unused files'
        'bin:Print bin folder'
        'cache:Cache operations'
        'check:Verify integrity'
        'config:Configure CLI'
        'constraints:Check workspace constraints'
        'create:Create from a template'
        'dedupe:Deduplicate dependencies'
        'dlx:Execute a one-off package'
        'exec:Execute a shell command'
        'explain:Explain a message'
        'generate-lock-entry:Generate lock entry'
        'global:Global operations'
        'help:show help'
        'import:Import from npm lockfile'
        'info:Show package info'
        'init:Initialize a project'
        'install:Install dependencies'
        'licenses:List installed package licenses'
        'link:Link a package'
        'list:List installed packages'
        'login:Log in to registry'
        'logout:Log out of registry'
        'node:Run with package paths'
        'npm:NPM operations'
        'outdated:List outdated packages'
        'owner:Manage package owners'
        'pack:Package as tarball'
        'patch:Patch a package'
        'patch-commit:Commit a patch'
        'plugin:Plugin operations'
        'policies:Policy operations'
        'pop:Pop a stash'
        'push:Push a stash'
        'rebuild:Rebuild native modules'
        'remove:Remove a dependency'
        'rewrite-imports:Rewrite imports'
        'run:Run a script'
        'search:Search registry'
        'set:Set a setting'
        'set-version:Set Yarn version'
        'set-resolution:Set resolution'
        'stage:Stage changes'
        'start:Run start script'
        'stash:Stash changes'
        'tag:Tag operations'
        'team:Team operations'
        'test:Run tests'
        'unlink:Unlink a package'
        'unplug:Unplug a package'
        'up:Upgrade dependencies'
        'upgrade:Upgrade dependencies'
        'upgrade-interactive:Interactive upgrade'
        'version:Show or set version'
        'versions:Show versions'
        'why:Show why dependency installed'
        'workspace:Workspace ops'
        'workspaces:All-workspaces ops'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--ignore-engines[ignore engines]' \
        '--ignore-platform[ignore platform]' \
        '--ignore-scripts[ignore scripts]' \
        '--no-bin-links[no bin links]' \
        '--no-default-rc[no default rc]' \
        '--ignore-optional[ignore optional]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--prod[production]' \
        '--production[production]' \
        '--update-checksums[update checksums]' \
        '--mode=+[m]:m:(skip-build update-lockfile)' \
        '--immutable[immutable install]' \
        '--immutable-cache[immutable cache]' \
        '--check-cache[check cache]' \
        '--check-resolutions[check resolutions]' \
        '--inline-builds[inline builds]' \
        '--frozen-lockfile[frozen lockfile]' \
        '--no-progress[no progress]' \
        '--non-interactive[non interactive]' \
        '--json[JSON output]' \
        '--prefer-offline[prefer offline]' \
        '--offline[offline]' \
        '--scope=+[scope]:str:' \
        '--registry=+[url]:str:' \
        '--use-yarnrc=+[file]:file:_files' \
        '--no-lockfile[no lockfile]' \
        '--har[generate HAR]' \
        '--strict-semver[strict semver]' \
        '--public[public access]' \
        '--access=+[a]:a:(public restricted)' \
        '--patterns=+[pattern]:str:' \
        '--depth=+[N]:n:' \
        '--all[all packages]' \
        '-A[all]' \
        '-D[dev dep]' \
        '--dev[dev dep]' \
        '-P[peer dep]' \
        '--peer[peer dep]' \
        '-O[optional dep]' \
        '--optional[optional dep]' \
        '-E[exact]' \
        '--exact[exact]' \
        '-T[tilde]' \
        '--tilde[tilde]' \
        '--caret[caret]' \
        '-C[caret]' \
        '--use-build-rule[use build rule]' \
        '--from=+[ref]:str:' \
        '--include=+[pattern]:str:' \
        '*--include=+[pattern]:str:' \
        '--exclude=+[pattern]:str:' \
        '*--exclude=+[pattern]:str:' \
        '--no-private[no private]' \
        '--immediate[immediate]' \
        '--recursive[recursive]' \
        '-R[recursive]' \
        '--topological[topological order]' \
        '-t[topological]' \
        '--topological-dev[topological dev]' \
        '--no-deps[no deps]' \
        '--ignore-policies[ignore policies]' \
        '--check-files[check files]' \
        '--flat[flat]' \
        '--latest[latest]' \
        '--no-default-script[no default script]' \
        '--from-template[from template]' \
        '--access-token=+[token]:str:' \
        '--otp=+[code]:str:' \
        '--tag=+[name]:str:' \
        '--target=+[name]:str:' \
        '--cached[use cache]' \
        '--no-immutable[no immutable]' \
        '--why[show why]' \
        '--strategy=+[s]:s:(reset highest greedy)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yarn subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|upgrade|up|outdated|why|info|patch|unplug|link|unlink|exec|run|test|why|dlx|create|publish|pack|search|owner|team) _arguments '*:package:' ;;
                workspace|workspaces) _arguments '*:arg:' ;;
                config) _arguments '1:op:(get set list unset)' '*:key:' ;;
                cache) _arguments '1:op:(clean dir list)' '*:arg:' ;;
                plugin) _arguments '1:op:(import remove list runtime export)' '*:name:' ;;
                policies) _arguments '1:op:(set-version)' '*:arg:' ;;
                version) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_yarn-cli2 "$@"
