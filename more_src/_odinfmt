#compdef odinfmt
# ============================================================================
#  _odinfmt — Odin language code formatter (ships with ols, the Odin LSP)
#
#  Source-direct extraction from
#    https://github.com/DanielGavin/ols/blob/master/tools/odinfmt/main.odin
#    https://github.com/odin-lang/Odin/blob/master/core/flags/parsing.odin
#    https://github.com/odin-lang/Odin/blob/master/core/flags/doc.odin
#
#  Part of the Odin Language Server (DanielGavin/ols).  996 GH stars on the
#  ols repo; canonical Odin formatter installed by every Odin developer
#  alongside the language server.  Reads odinfmt.json config + formats
#  Odin source files via the `src:odin/format` + `src:odin/printer`
#  internal modules.
#
#  CLI library taxonomy update: first documented Odin entry.  odinfmt uses
#  Odin's stdlib `core:flags` package — `import "core:flags"` brings the
#  flags namespace into scope.  core:flags is Odin's first-party CLI
#  parser, RTTI-driven: an anonymous-or-named struct with FIELDS
#  ANNOTATED VIA BACKTICK-DELIMITED STRUCT TAGS (`args:"name=X,pos=N,
#  manifold=K"` + `usage:"..."`) becomes the spec; `flags.parse(&args,
#  os.args[1:], .Unix)` populates the struct in-place via Odin's runtime
#  type information.  Brings cross-language CLI library taxonomy variant
#  count to 77.
#
#  Surface (verbatim from tools/odinfmt/main.odin `Args` struct):
#    -w        write the new format to file
#    -stdin    formats code from standard input
#    -config   path to a config file (odinfmt.json)
#    <path>    positional: file or directory to format (pos=0)
#
#  Parsing style: `.Odin` (default) — accepts `-flag`, `-flag:value`,
#  `-map:key=value`.  (Distinct from `.Unix` style which would accept
#  `-flag`, `--flag`, `--flag=value`, `--flag value`.)
#
#  Dup-skipped neighbors during hunt (unfit or smaller surface):
#    - runic (Samudevv/runic, 88 stars — 3-flag C-ABI bindings generator,
#      smaller surface; exercises Unix parsing style + full error-union
#      switch dispatch, would be a future SISTER demo)
#    - hephaistos (Znarf64/hephaistos, 27 stars — Hephaistos Shading Lang
#      driver, narrow surface)
#    - draupnir (odin-arsenal/draupnir, 3 stars — project scaffold, narrow)
#    - crux (FourteenBrush/crux, 3 stars — WIP Minecraft server, narrow)
# ============================================================================

_odinfmt() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-w[write the new format to file]' \
    '-stdin[format code from standard input]' \
    '-config[path to odinfmt.json config file]:config file:_files -g "*.json"' \
    '*:Odin source file or directory:_files -g "*.odin"'
}

_odinfmt "$@"
