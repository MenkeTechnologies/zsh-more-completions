#compdef DupMasker
# Documentation: https://github.com/rmhubley/RepeatMasker/blob/master/DupMasker
# RepeatMasker: annotate segmental duplications in a masked sequence

local ret=1

_arguments -s \
  '-version[print version and exit]' \
  '-engine[search engine to use]:engine:(abblast wublast ncbi)' \
  '-maxDiv[maximum divergence to report]:value:' \
  '-maxWidth[maximum width to report]:value:' \
  '-forceSearch[force a new search]' \
  '-align[produce alignment output]' \
  '-gff[produce GFF output]' \
  '-pa[number of parallel processors]:value:' \
  '-dupout[write duplication output]' \
  '*:fasta file:_files' && ret=0

return ret
