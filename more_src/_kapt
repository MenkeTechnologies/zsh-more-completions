#compdef kapt
# Documentation: https://kotlinlang.org/docs/kapt.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; flags cross-checked with
# local `kapt -help` (KaptCli, kotlin-annotation-processing-cli.jar).

# kapt: run Kotlin annotation processing over source files (kotlinc-based).
# Prior file invented javac-style flags (-sources -classpath -d -s -processor
# -Xmaxerrs -encoding etc). Real CLI uses -Kapt-* options.

local -a arguments

arguments=(
    '-Kapt-mode=[annotation processing mode]:mode:(apt stubs stubsAndApt compile)'
    '-Kapt-sources=[output path for generated sources]:dir:_directories'
    '-Kapt-classes=[output path for generated classes]:dir:_directories'
    '-Kapt-stubs=[output path for Java stubs]:dir:_directories'
    '-Kapt-classpath=[annotation processor classpath]:classpath:_files'
    '-Kapt-processors=[annotation processor qualified names]:fqnames:'
    '*-Kapt-option:[annotation processor option key=value]:option:'
    '*-Kapt-javac-option:[javac option key=value]:option:'
    '-Kapt-tools-jar-location=[tools.jar location (JDK <= 1.8)]:file:_files'
    '-Kapt-use-light-analysis=[skip body analysis if possible]:b:(true false)'
    '-Kapt-correct-error-types=[replace error types from generated sources]:b:(true false)'
    '-Kapt-dump-default-parameter-values=[put initializers on fields]:b:(true false)'
    '-Kapt-map-diagnostic-locations=[map stub diagnostics to Kotlin sources]:b:(true false)'
    '-Kapt-verbose=[enable verbose output]:b:(true false)'
    '-Kapt-show-processor-stats=[show processor timings]:b:(true false)'
    '-Kapt-dump-processor-stats=[dump processor statistics to file]:file:_files'
    '-Kapt-dump-file-read-history=[dump files read by processors to file]:file:_files'
    '-Kapt-strict=[error on stub generation incompatibilities]:b:(true false)'
    '-Kapt-strip-metadata=[strip @Metadata annotations from stubs]:b:(true false)'
    '-Kapt-use-k2=[use K2]:b:(true false)'
    '*:Kotlin source files:_files -g "*.kt"'
)

_arguments -s -S $arguments
