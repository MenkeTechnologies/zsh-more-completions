#compdef dipy_fit_dki
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_fit_dki.html
# DIPY: fit diffusion kurtosis (DKI) model and save DKI metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--fit_method=[fitting method (OLS ULLS WLS UWLLS)]:method:(OLS ULLS WLS UWLLS)' \
  '--b0_threshold=[threshold for b0 detection]:thr' \
  '--sigma=[noise variance estimate]:sigma' \
  '--save_metrics=[metrics to save]:metrics' \
  '--extract_pam_values[save PAM volumes as individual files]' \
  '--npeaks=[number of peaks per voxel]:n' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_dt_tensor=[DTI tensors filename]:file:_files' \
  '--out_dk_tensor=[DKI tensors filename]:file:_files' \
  '--out_fa=[FA volume filename]:file:_files' \
  '--out_ga=[GA volume filename]:file:_files' \
  '--out_rgb=[color FA filename]:file:_files' \
  '--out_md=[mean diffusivity filename]:file:_files' \
  '--out_ad=[axial diffusivity filename]:file:_files' \
  '--out_rd=[radial diffusivity filename]:file:_files' \
  '--out_mode=[mode volume filename]:file:_files' \
  '--out_evec=[eigenvectors filename]:file:_files' \
  '--out_eval=[eigenvalues filename]:file:_files' \
  '--out_mk=[mean kurtosis filename]:file:_files' \
  '--out_ak=[axial kurtosis filename]:file:_files' \
  '--out_rk=[radial kurtosis filename]:file:_files' \
  '--out_pam=[peaks filename]:file:_files' \
  '--out_peaks_dir=[peak directions filename]:file:_files' \
  '--out_peaks_values=[peak values filename]:file:_files' \
  '--out_peaks_indices=[peak indices filename]:file:_files' \
  '--out_sphere=[sphere vertices filename]:file:_files' \
  '*:input (volumes bvals bvecs masks):_files' && ret=0

return ret
