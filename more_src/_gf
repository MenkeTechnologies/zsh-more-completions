#compdef gf

# Zsh completion for gf - a wrapper around grep for pattern matching

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-list[list available patterns]' \
  '-save[save a pattern]:name:' \
  '-silent[do not print errors or warnings]' \
  '-dump[dump the pattern used to stdout]' \
  '-o[show only matching parts of a line]' \
  '-r[recurse into subdirectories]' \
  '-l[show only filenames of files that match]' \
  ':pattern:->pattern' \
  '*:file:_files' && ret=0

case $state in
  pattern)
    # List saved gf patterns if available
    local -a patterns
    if [[ -d ~/.gf ]]; then
      patterns=(${${(f)"$(ls ~/.gf/*.json 2>/dev/null)"}:t:r})
    fi
    if (( #patterns )); then
      _describe -t patterns 'pattern' patterns && ret=0
    fi
    ;;
esac

return ret
