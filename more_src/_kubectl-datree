#compdef kubectl-datree
# Documentation: https://github.com/datreeio/kubectl-datree
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-datree (datreeio): invoked as `kubectl datree test [datree CLI
# args] -- [options]`. Plugin options follow the `--` separator.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:(test)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '-n+[test all resources in a namespace]:namespace:' \
      '--all[test all resources across the cluster]' \
      '--exclude=[exclude namespaces (used with --all)]:namespace:' \
      '*:datree args:_default' && ret=0
    ;;
esac

return ret
