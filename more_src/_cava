#compdef cava
# Documentation: https://man.archlinux.org/search?q=cava
# Reference accessed: 2026-05-16

# Zsh completion for cava (Console Audio Visualizer for ALSA)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-p+[path to config file]:file:_files' \
  '-k[show list of available keybindings]'
