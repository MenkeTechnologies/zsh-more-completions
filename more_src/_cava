#compdef cava
# Documentation: https://github.com/karlstav/cava
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for cava (Console-based Audio Visualizer for ALSA).
# Upstream `cava -?` lists -p (config path) and -v (version) as the only
# documented switches.

_arguments -s -S \
  '(- *)-?[show help]' \
  '(- *)-v[show version]' \
  '-p+[path to config file]:file:_files'

