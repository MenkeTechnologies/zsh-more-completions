#compdef pvdataserver
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/pvdataserver.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ParaView pvdataserver: data-only server (for render+data split)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--server-port=[listen port]:n:' \
  '--client-host=[reverse client host]:host:' \
  '--reverse-connection[reverse client connection]' \
  '--connect-id=[connect identifier]:id:' \
  '--enable-bt[backtrace on signal]' \
  '--render-server-host=[render server host]:host:' \
  '--render-server-port=[render server port]:n:' \
  '*::options:_files' && ret=0
return ret
