#compdef qhold
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/qhold.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# qhold: hold a PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-W[wait]:delay:' \
  '-t[type]:type:(u o s)' \
  '*:jobid:' && ret=0
return ret
