#compdef qhold
# Documentation: https://github.com/openpbs/openpbs/blob/master/doc/man1/qhold.1B
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qhold: hold a PBS job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[print PBS version and exit]' \
  '(- *)'{-\?,--help}'[brief help message]' \
  '(- *)--man[full documentation]' \
  '-h+[hold list (one or more of u/o/s/n/p)]:hold:(u o s n p)' \
  '*:jobid:' && ret=0
return ret
