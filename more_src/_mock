#compdef mock

# Zsh completion for mock - RPM build mock environment

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-r --root)'{-r,--root}'[chroot config name]:config' \
  '--resultdir=[path for resulting files]:directory:_files -/' \
  '--configdir=[change directory for config files]:directory:_files -/' \
  '--uniqueext=[unique extension for buildroot]:extension' \
  '--arch=[target architecture]:architecture:(x86_64 i686 aarch64 ppc64le s390x armv7hl)' \
  '--forcearch=[force architecture]:architecture:(x86_64 i686 aarch64 ppc64le s390x armv7hl)' \
  '--enable-network[enable networking in the chroot]' \
  '--isolation=[isolation technology]:isolation:(simple nspawn)' \
  '--rebuild[rebuild an SRPM]:*:SRPM:_files -g "*.src.rpm"' \
  '--buildsrpm[build an SRPM from a spec file]' \
  '--spec=[spec file to build]:file:_files -g "*.spec"' \
  '--sources=[source directory]:directory:_files -/' \
  '--chain[chain build a list of packages]' \
  '--localrepo=[use local repo]:directory:_files -/' \
  '--init[initialize the chroot]' \
  '--clean[clean the chroot]' \
  '--scrub=[scrub the chroot]:target:(all chroot cache root-cache c-cache yum-cache dnf-cache lvm)' \
  '--shell[run a shell in the chroot]' \
  '--chroot[run a command in the chroot]' \
  '--install[install packages in the chroot]:*:package' \
  '--remove[remove packages from the chroot]:*:package' \
  '--update[update packages in the chroot]' \
  '--orphanskill[kill orphan processes in the chroot]' \
  '--copyin[copy files into the chroot]' \
  '--copyout[copy files out of the chroot]' \
  '--pm-cmd[run a package manager command]' \
  '--yum-cmd[run a yum command]' \
  '--dnf-cmd[run a dnf command]' \
  '--snapshot[create a snapshot of the chroot]' \
  '--rollback-to[rollback to a snapshot]' \
  '--remove-snapshot[remove a snapshot]' \
  '--umount[unmount the chroot]' \
  '--mount[mount the chroot]' \
  '--bootstrap-chroot[initialize bootstrap chroot]' \
  '--no-clean[do not clean before building]' \
  '--no-cleanup-after[do not clean up after building]' \
  '--short-circuit=[skip to a specific stage]:stage:(prep build install binary)' \
  '--define=[define an RPM macro]:macro' \
  '--with=[enable optional build feature]:feature' \
  '--without=[disable optional build feature]:feature' \
  '--nocheck[skip running tests]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--trace[enable internal mock tracing]' \
  '--print-root-path[print the chroot path]' \
  '--rpmbuild-opts=[extra options for rpmbuild]:options' \
  '--plugin-option=[plugin option]:plugin:option:value' \
  '--enable-plugin=[enable a plugin]:plugin' \
  '--disable-plugin=[disable a plugin]:plugin' \
  '*:SRPM or spec:_files -g "*.src.rpm *.spec"'
