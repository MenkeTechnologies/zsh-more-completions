#compdef thokr
# Documentation: https://github.com/jrnxf/thokr
# Terminal typing test

_arguments -s -S \
  '-w[number of words to type]:count:' \
  '--words[number of words to type]:count:' \
  '-s[number of seconds for the test]:seconds:' \
  '--seconds[number of seconds for the test]:seconds:' \
  '-p[prompt string to type]:prompt:' \
  '--prompt[prompt string to type]:prompt:' \
  '-f[file to read words from]:file:_files' \
  '--file[file to read words from]:file:_files' \
  '-n[number of lines of words to display]:lines:' \
  '--number-of-lines[number of lines of words to display]:lines:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  && return 0
