#compdef diffstat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-b[ignore "Binary files differ" lines]' \
  '-c[prefix each line with comment (#)]' \
  '-C[add SGR color escape sequences]' \
  '-d[debug output]' \
  '-D+[location of patched files]:dir:_files -/' \
  '-e+[redirect stderr to file]:file:_files' \
  '-E[trim escape sequences]' \
  '-f+[format]:fmt:((0\:concise 1\:normal 2\:filled 4\:values))' \
  '-k[do not merge filenames]' \
  '-K[resolve ambiguity of only-filenames]' \
  '-l[list filenames only]' \
  '-m[merge insert/delete data as modified lines]' \
  '-n+[minimum width for filenames]:n:' \
  '-N+[maximum width for filenames]:n:' \
  '-o+[redirect stdout to file]:file:_files' \
  '-p+[pathname separators to strip]:n:' \
  '-q[suppress "0 files changed" for empty diffs]' \
  '-r+[rounding]:r:((0\:none 1\:simple 2\:adjusted))' \
  '-R[assume patch was reversed]' \
  '-s[show only summary line]' \
  '-S+[location of original files]:dir:_files -/' \
  '-t[print CSV table instead of histogram]' \
  '-T[print amounts in addition to histogram]' \
  '-u[do not sort the input list]' \
  '-v[show progress when output redirected]' \
  '-w+[max width of output]:width:' \
  '*:diff file:_files'  && ret=0

return ret
