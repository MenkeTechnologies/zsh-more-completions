#compdef tpws
# Documentation: https://github.com/bol-van/zapret/blob/master/tpws/tpws.c
# zapret transparent TCP proxy DPI circumvention tool

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--bind-addr=[bind to local address]:addr:' \
  '--bind-iface4=[bind to IPv4 interface]:iface:_net_interfaces' \
  '--bind-iface6=[bind to IPv6 interface]:iface:_net_interfaces' \
  '--bind-linklocal=[link-local bind mode]:mode:' \
  '--bind-wait-ifup=[wait seconds for interface up]:seconds:' \
  '--bind-wait-ip=[wait seconds for IP]:seconds:' \
  '--bind-wait-ip-linklocal=[wait seconds for link-local IP]:seconds:' \
  '--bind-wait-only[wait for bind then exit]' \
  '--port=[listen port]:port:' \
  '--daemon[run as daemon]' \
  '--user=[drop privileges to user]:user:_users' \
  '--uid=[drop privileges to uid:gid]:uid:' \
  '--maxconn=[max connections]:number:' \
  '--maxfiles=[max file descriptors]:number:' \
  '--max-orphan-time=[max orphan connection time]:seconds:' \
  '--ipcache-lifetime=[IP cache lifetime]:seconds:' \
  '--ipcache-hostname=[cache resolved hostnames]:::' \
  '--hostcase[change Host header case]' \
  '--hostspell=[Host header spelling]:spell:' \
  '--hostdot[add dot after hostname]' \
  '--hostnospace[remove space after Host:]' \
  '--hostpad=[pad request with headers]:bytes:' \
  '--domcase[mix domain case]' \
  '--split-http-req=[split HTTP request]:mode:' \
  '--split-tls=[split TLS clienthello]:mode:' \
  '--split-pos=[split position]:pos:' \
  '--split-any-protocol[split any protocol]' \
  '--disorder[send second segment first]' \
  '--oob[send out-of-band byte at split]' \
  '--oob-data=[OOB byte value]:byte:' \
  '--methodspace[add space after method]' \
  '--methodeol[insert newline before method]' \
  '--hosttab[add tab after hostname]' \
  '--unixeol[use \n instead of \r\n]' \
  '--tlsrec=[TLS record split position]:pos:' \
  '--hostlist=[apply only to hosts in file]:file:_files' \
  '--hostlist-domains=[apply only to domains list]:list:' \
  '--hostlist-exclude=[exclude hosts in file]:file:_files' \
  '--hostlist-exclude-domains=[exclude domains list]:list:' \
  '--hostlist-auto=[auto hostlist file]:file:_files' \
  '--pidfile=[write pid to file]:file:_files' \
  '--debug=[debug level]:::' \
  '--debug-level=[debug verbosity level]:level:' \
  '--dry-run[validate parameters and exit]' \
  '--socks[run as SOCKS proxy]' \
  '--no-resolve[disable DNS resolution]' \
  '--resolver-threads=[number of resolver threads]:number:' \
  '--skip-nodelay[do not set TCP_NODELAY]' \
  '--tamper-start=[start tampering at position]:pos:' \
  '--tamper-cutoff=[stop tampering at position]:pos:' \
  '--connect-bind-addr=[bind outbound to address]:addr:' \
  '--new[start new strategy block]' \
  '--skip[skip strategy block]' \
  '--filter-l3=[filter by L3 protocol]:proto:(ipv4 ipv6)' \
  '--filter-tcp=[filter by TCP ports]:ports:' \
  '--filter-l7=[filter by L7 protocol]:proto:' \
  '--ipset=[apply only to ipset file]:file:_files' \
  '--ipset-ip=[apply only to ips]:ips:' \
  '--ipset-exclude=[exclude ipset file]:file:_files' \
  '--ipset-exclude-ip=[exclude ips]:ips:' && ret=0

return ret
