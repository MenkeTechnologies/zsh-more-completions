#compdef stockfish
# Documentation: https://man.archlinux.org/search?q=stockfish
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'uci:announce UCI mode and list supported options'
  'isready:wait until engine is ready'
  'ucinewgame:reset internal engine state'
  'position:set up a position (startpos|fen ...)'
  'go:start calculating the best move'
  'stop:stop calculating'
  'setoption:set a UCI option'
  'd:display the current position'
  'eval:show static evaluation'
  'flip:flip side to move'
  'bench:run benchmark'
  'compiler:show compiler info'
  'quit:exit'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'stockfish command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setoption)
        _arguments \
          'name[option name]:opt:(Threads Hash Ponder MultiPV Skill\ Level Move\ Overhead Slow\ Mover UCI_Chess960 UCI_LimitStrength UCI_Elo UCI_ShowWDL SyzygyPath SyzygyProbeDepth Syzygy50MoveRule SyzygyProbeLimit EvalFile EvalFileSmall ClearHash)' \
          '*::value:' && ret=0 ;;
      (position)
        _arguments \
          '*::source:(startpos fen moves)' && ret=0 ;;
      (go)
        _arguments \
          '*::scope:(infinite ponder depth nodes mate movetime wtime btime winc binc movestogo searchmoves)' && ret=0 ;;
    esac ;;
esac

return ret
