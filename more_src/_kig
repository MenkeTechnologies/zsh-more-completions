#compdef kig
# Documentation: https://manpages.debian.org/testing/kig/kig.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Has headless converter mode.

# kig: KDE interactive geometry tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '(-c --convert-to-native)'{-c,--convert-to-native}'[convert to native Kig format (headless)]' \
  '(-o --outfile)'{-o+,--outfile=}'[output file (- for stdout)]:file:_files' \
  '*:kig file:_files -g "*.kig(-.)"' && ret=0
return ret
