#compdef kig
# Documentation: https://apps.kde.org/kig/
# Reference accessed: 2026-05-16
# Verified: upstream KDE kig. Has headless CLI converter mode.
# Removed from prior file: bogus man.archlinux.org search URL.

# kig: KDE interactive geometry tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '(-c --convert-to-native)'{-c,--convert-to-native}'[convert to native Kig format (headless)]' \
  '(-o --outfile)'{-o+,--outfile=}'[output file (- for stdout)]:file:_files' \
  '*:kig file:_files -g "*.kig(-.)"' && ret=0
return ret
