#compdef quartus_asm
# _quartus_asm — Intel Altera Quartus quartus_asm CLI for the Assembler stage of the Quartus Prime FPGA flow producing the device programming files SOF POF JIC RBF JAM JBC RPD for in-system programmer device families (Intel team, C++); custom argparse
# upstream: https://www.intel.com/content/www/us/en/products/details/fpga/development-tools/quartus-prime.html

_quartus_asm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--rev=+[revision]:str:' \
        '--revision=+[revision]:str:' \
        '--write_settings_files[write settings files]' \
        '--no_write_settings_files[no write settings files]' \
        '--read_settings_files[read settings files]' \
        '--output_directory=+[dir]:dir:_files -/' \
        '--use_qpi[use QPI]' \
        '--family=+[family]:str:' \
        '--device=+[device]:str:' \
        '--generate_sof[generate SOF]' \
        '--generate_pof[generate POF]' \
        '--generate_jic[generate JIC]' \
        '--generate_rbf[generate RBF]' \
        '--generate_jam[generate JAM]' \
        '--generate_jbc[generate JBC]' \
        '--generate_rpd[generate RPD]' \
        '--list-extensions[list extensions]' \
        '--archive=+[file]:file:_files -g "*.qar"' \
        '--64bit[64-bit mode]' \
        '*:project name:_files -g "*.qpf *.qsf"'
}

_quartus_asm "$@"
