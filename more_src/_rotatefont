#compdef rotatefont
# Documentation: https://adobe-type-tools.github.io/afdko/AFDKO-Overview.html
# AFDKO: rotate and translate glyphs in a font, including hints

local ret=1

_arguments -s -S \
  '-rt[set rotation matrix: degrees x-offset y-offset]:values:' \
  '-rtf[load per-glyph rotation entries from a text file]:file:_files' \
  '-matrix[set full 6-value transformation matrix]:matrix:' \
  '-rtw[transform glyph advance widths by the rotation matrix]' \
  '-rew[set undefined advance widths to the em-size]' \
  '-row[override width flag settings]' \
  '-o[output font file]:output:_files' \
  '-t[output font type]:type:' \
  '-u[print usage]' \
  '-h[print help]' \
  '*:font:_files' && ret=0

return ret
