#compdef songbird
# Documentation: https://github.com/biocore/songbird/blob/master/scripts/songbird
# songbird multinomial regression for microbiome differential abundance

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--input-biom=[input feature table (biom)]:file:_files' \
  '--metadata-file=[input sample metadata file]:file:_files' \
  '--formula=[regression formula]:formula' \
  '--training-column=[metadata column specifying training samples]:column' \
  '--num-random-test-examples=[number of random samples for testing]:n' \
  '--epochs=[number of epochs to train]:n' \
  '--batch-size=[size of mini-batch]:n' \
  '--differential-prior=[width of normal prior on differentials]:n' \
  '--learning-rate=[gradient descent decay rate]:rate' \
  '--clipnorm=[gradient clipping size]:n' \
  '--min-sample-count=[minimum total count for a sample to be kept]:n' \
  '--min-feature-count=[minimum total count for a feature to be kept]:n' \
  '--checkpoint-interval=[seconds before storing a checkpoint]:n' \
  '--summary-interval=[seconds before storing a summary]:n' \
  '--summary-dir=[summary directory for results]:dir:_files -/' \
  '--random-seed=[random seed]:n' \
  '--silent[suppress progress output]' \
  '--no-silent[show progress output]' \
  '*:command:(multinomial)' && ret=0

return ret
