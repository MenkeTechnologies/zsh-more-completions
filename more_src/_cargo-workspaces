#compdef cargo-workspaces

# Zsh completion for cargo-workspaces (Rust workspace management)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:List workspace crates'
      'changed:List changed crates since last tag'
      'version:Bump version of crates'
      'publish:Publish crates in correct order'
      'exec:Execute command in each crate directory'
      'create:Create a new workspace crate'
      'rename:Rename a crate in the workspace'
      'init:Initialize a new cargo workspace'
    )
    _describe -t commands 'cargo-workspaces command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      list)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-a[Show all crates including private]' \
          '--all[Show all crates including private]' \
          '-l[Show long format]' \
          '--long[Show long format]' \
          '--json[Output as JSON]' && ret=0
        ;;
      changed)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--since=[Git ref to compare against]:ref' \
          '--force=[Force include specific crates]:crate' \
          '--ignore-changes=[Ignore changes in paths]:glob' \
          '--include-merged-tags[Include merged tags]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--force=[Force version crates]:crates' \
          '--exact[Use exact version instead of caret]' \
          '--no-git-tag[Do not create git tags]' \
          '--no-git-commit[Do not create git commit]' \
          '--no-git-push[Do not push to remote]' \
          '--allow-branch=[Allow versioning on branch]:branch' \
          '--amend[Amend the last commit]' \
          '--message=[Custom commit message]:message' \
          '--pre-id=[Pre-release identifier]:id' \
          '-y[Skip confirmation prompt]' \
          '--yes[Skip confirmation prompt]' \
          '1:bump:(major minor patch premajor preminor prepatch custom)' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--from-git[Publish using versions from git tags]' \
          '--dry-run[Dry run without publishing]' \
          '--no-verify[Skip crate verification]' \
          '--token=[Registry token]:token' \
          '--registry=[Registry to publish to]:registry' \
          '--allow-dirty[Allow dirty working directory]' \
          '-y[Skip confirmation prompt]' \
          '--yes[Skip confirmation prompt]' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--no-bail[Do not bail on first error]' \
          '--ignore=[Ignore specific crates]:crate' \
          '*:command' && ret=0
        ;;
      create)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--edition=[Rust edition]:edition:(2015 2018 2021)' \
          '--name=[Crate name]:name' \
          '--lib[Create library crate]' \
          '--bin[Create binary crate]' \
          '1:path:_directories' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
