#compdef mdbook-utils
# _mdbook-utils — Markdown / mdBook maintenance utilities (john-cd/mdbook-utils)
# upstream: https://github.com/john-cd/mdbook-utils
# Subcommands from src/cli/mod.rs (clap derive).

_mdbook-utils() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-y --yes)'{-y,--yes}'[auto-confirm any user prompt]' \
        '--log=[log level]:level:(error warn info debug trace)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'refdefs:manage reference definitions'
                'links:manage links'
                'markdown:manage code blocks (embedded examples) and includes'
                'sitemap:generate sitemap.xml from markdown files'
                'debug:parse markdown to events and write to file'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                sitemap|debug)
                    _arguments \
                        '(-m --markdown-dir)'{-m+,--markdown-dir=}'[source dir of markdown files]:dir:_files -/' \
                        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
                        '(-b --base-url)'{-b+,--base-url=}'[base URL]:url:' \
                        '--map-index=[map filename FROM:TO]:mapping:'
                    ;;
            esac
            ;;
    esac
}

_mdbook-utils "$@"
