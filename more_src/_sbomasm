#compdef sbomasm
# SBOM assembler: merge, edit, enrich and sign SBOMs (interlynk-io)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    assemble:"merge multiple SBOMs into one document"
    edit:"modify SBOM metadata"
    rm:"remove components"
    enrich:"add missing license information"
    view:"render SBOM in human-readable format"
    generate:"create configuration templates"
    sign:"cryptographically sign an SBOM"
    verify:"verify a signed SBOM"
    securesbomkey:"manage signing keys"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      assemble)
        _arguments -s \
          '(-n --name)'{-n,--name}'[application name]:name:' \
          '(-v --version)'{-v,--version}'[application version]:version:' \
          '(-t --type)'{-t,--type}'[component type]:type:(application container device firmware library)' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' \
          '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
          '--augmentMerge[enrich existing SBOM without creating new root]' \
          '--primary[primary SBOM for augment merge]:file:_files' \
          '--merge-mode[merge strategy]:mode:(overwrite append)' \
          '--flat-merge[flatten hierarchy during merge]' \
          '*:sbom file:_files' && ret=0
        ;;
      edit)
        _arguments -s \
          '--subject[target element]:subject:' \
          '--supplier[supplier information]:supplier:' \
          '--license[license information]:license:' \
          '--tool[tool information]:tool:' \
          '--author[author details]:author:' \
          '--timestamp[add timestamp]' \
          '--lifecycle[component lifecycle stage]:stage:' \
          '--cpe[CPE identifier]:cpe:' \
          '--missing[only edit missing fields]' \
          '--search[search criteria for components]:search:' \
          '--output[output file]:file:_files' \
          '*:sbom file:_files' && ret=0
        ;;
      enrich)
        _arguments -s \
          '--fields[fields to enrich]:fields:(license)' \
          '--force[force update existing data]' \
          '--license-exp-join[license expression operator]:op:(AND OR)' \
          '--max-retries[retry attempts]:n:' \
          '--max-wait[maximum wait time]:seconds:' \
          '--output[output file]:file:_files' \
          '*:sbom file:_files' && ret=0
        ;;
      view)
        _arguments -s \
          '(-o --output)'{-o,--output}'[save to file]:file:_files' \
          '--verbose[detailed output]' \
          '--only-licenses[license-only view]' \
          '--filter-type[filter by component types]:type:' \
          '--min-severity[minimum vulnerability severity]:severity:' \
          '--only-unresolved[show only unresolved vulnerabilities]' \
          '--max-depth[limit tree depth]:n:' \
          '--format[output format]:format:(hierarchical flat json)' \
          '--vulnerabilities[include vulnerability data]' \
          '*:sbom file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
