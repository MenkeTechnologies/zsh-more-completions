#compdef ebook-convert

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--title=[set title]:title' \
  '--authors=[set authors]:authors' \
  '--author-sort=[author sort string]:string' \
  '--language=[set language]:language' \
  '--publisher=[set publisher]:publisher' \
  '--series=[set series name]:series' \
  '--series-index=[set series index]:index' \
  '--tags=[set tags]:tags' \
  '--isbn=[set ISBN]:isbn' \
  '--comments=[set comments]:comments' \
  '--pubdate=[set publication date]:date' \
  '--rating=[set rating]:rating' \
  '--cover=[set cover image]:file:_files' \
  '--book-producer=[set book producer]:producer' \
  '--output-profile=[output profile]:profile:(default generic_eink kindle kindle_dx kindle_fire kindle_oasis kindle_pw kindle_pw3 kindle_voyage kobo nook sony tablet)' \
  '--input-profile=[input profile]:profile:(default kindle nook sony)' \
  '--base-font-size=[base font size in pt]:size' \
  '--font-size-mapping=[font size mapping]:mapping' \
  '--embed-font-family=[embed font family]:font' \
  '--subset-embedded-fonts[subset embedded fonts]' \
  '--line-height=[line height in pt]:height' \
  '--margin-top=[top margin in pt]:margin' \
  '--margin-bottom=[bottom margin in pt]:margin' \
  '--margin-left=[left margin in pt]:margin' \
  '--margin-right=[right margin in pt]:margin' \
  '--change-justification=[text justification]:justification:(left justify original)' \
  '--smarten-punctuation[use typographic punctuation]' \
  '--unsmarten-punctuation[use plain punctuation]' \
  '--asciiize[transliterate unicode to ASCII]' \
  '--chapter=[XPath for chapter detection]:xpath' \
  '--chapter-mark=[chapter mark style]:style:(none rule both pagebreak)' \
  '--page-breaks-before=[XPath for page breaks]:xpath' \
  '--no-default-epub-cover[no default EPUB cover]' \
  '--no-svg-cover[no SVG cover]' \
  '--preserve-cover-aspect-ratio[preserve cover aspect ratio]' \
  '--epub-flatten[flatten EPUB file structure]' \
  '--level1-toc=[XPath for level 1 TOC]:xpath' \
  '--level2-toc=[XPath for level 2 TOC]:xpath' \
  '--level3-toc=[XPath for level 3 TOC]:xpath' \
  '--verbose[verbose processing]' \
  '--debug-pipeline=[save debug output]:directory:_directories' \
  '1:input file:_files' \
  '2:output file:_files'
