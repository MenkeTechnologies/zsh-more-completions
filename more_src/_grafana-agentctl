#compdef grafana-agentctl
# Documentation: https://man.archlinux.org/search?q=grafana-agentctl
# Reference accessed: 2026-05-16

# grafana-agentctl: CLI for Grafana Agent
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'config-check:check config file'
  'config-init:generate sample config'
  'config-decode-state:decode state file'
  'sample-stats:sample stats from prometheus'
  'target-stats:target stats'
  'wal-stats:WAL stats'
  'completion:emit shell completion'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--enable-features=[features]:features:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'grafana-agentctl command' commands && ret=0 ;;
esac
return ret
