#compdef pyroscope

# Zsh completion for Pyroscope continuous profiler

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'server:start the Pyroscope server'
      'connect:connect to a running process'
      'exec:start a new process and profile it'
      'adhoc:run an ad-hoc profiling session'
      'agent:start the Pyroscope agent'
      'admin:administration commands'
    )
    _describe -t commands 'pyroscope command' commands && ret=0
    ;;
  args)
    case $line[1] in
      exec)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--application-name=[application name]:name' \
          '--spy-name=[profiler spy]:spy:(auto rbspy pyspy gospy ebpfspy dotnetspy phpspy)' \
          '--sample-rate=[sample rate]:rate' \
          '--detect-subprocesses[detect and profile subprocesses]' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--server-address=[Pyroscope server address]:address' \
          '--auth-token=[authentication token]:token' \
          '*--tag=[tag in key=value format]:tag' \
          '--upstream-threads=[number of upload threads]:threads' \
          '*:command:_command_names -e' \
          && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--config=[config file]:file:_files' \
          && ret=0
        ;;
      connect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--application-name=[application name]:name' \
          '--spy-name=[profiler spy]:spy:(auto rbspy pyspy gospy ebpfspy dotnetspy phpspy)' \
          '--sample-rate=[sample rate]:rate' \
          '--server-address=[Pyroscope server address]:address' \
          '--auth-token=[authentication token]:token' \
          '*--tag=[tag in key=value format]:tag' \
          '1:pid' \
          && ret=0
        ;;
      adhoc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--spy-name=[profiler spy]:spy:(auto rbspy pyspy gospy ebpfspy dotnetspy phpspy)' \
          '--output-format=[output format]:format:(collapsed pprof)' \
          '*:command:_command_names -e' \
          && ret=0
        ;;
      agent)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--server-address=[Pyroscope server address]:address' \
          '--auth-token=[authentication token]:token' \
          '--log-level=[log level]:level:(debug info warn error)' \
          && ret=0
        ;;
      admin)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->admin_cmds' && ret=0
        case $state in
          admin_cmds)
            local -a admin_commands=(
              'app:manage applications'
              'storage:manage storage'
              'user:manage users'
            )
            _describe -t commands 'admin subcommand' admin_commands && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
