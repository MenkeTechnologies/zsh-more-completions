#compdef maildirsync
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/maildirsync.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# maildirsync: online synchronizer for Maildir-format mailboxes
local curcontext="$curcontext" ret=1

_arguments -C \
  '(-r --recursive)'{-r,--recursive}'[process base folder recursively]' \
  '(-b --backup)'{-b,--backup}'+[back up deleted files to dir]:directory:_directories' \
  '(-B --backup-tree)'{-B,--backup-tree}'[organize backups in a Maildir tree]' \
  '--bzip2=[path to bzip2 utility]:program:_command_names -e' \
  '--gzip=[path to gzip utility]:program:_command_names -e' \
  '--maildirsync=[path to maildirsync on remote machine]:program' \
  '(-R --rsh)'{-R,--rsh}'+[remote shell utility]:rsh:(ssh rsh)' \
  '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '(-a --alg)'{-a,--alg}'+[synchronization algorithm]:algorithm:(md5 size mtime)' \
  '(-d --delete-before)'{-d,--delete-before}'[delete before transferring]' \
  '*'{-x,--exclude}'+[exclude a directory regexp]:regex' \
  '*--exclude-source=[exclude directories from source side]:regex' \
  '*--exclude-target=[exclude directories from target side]:regex' \
  '--destination=[transform filenames (win/lin conversion)]:transform:(win lin)' \
  '--rename=[Perl expression to rename transferred files]:perl-expr' \
  '*:maildir:_files -/' && ret=0

return ret
