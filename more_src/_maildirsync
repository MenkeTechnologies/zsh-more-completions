#compdef maildirsync

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '*:maildir:_files -/' && ret=0

return ret
