#compdef imagemagick-cli convert-cli
# _imagemagick-cli — ImageMagick convert/magick legacy CLI alias (ImageMagick team, C); custom argparse
# upstream: https://github.com/ImageMagick/ImageMagick

_imagemagick-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-list+[type]:t:(Color Configure Coder Complex Compose Compress Configure Dash Debug Decoration Delegate Direction Dispose Distort Dither Endian Evaluate FillRule Filter Font Format Function Gravity Intensity Interlace Interpolate Kernel LayerMethod LineCap LineJoin List Locale LogEvent Log Magic Method Metric Mime Module Morphology NoiseType Orientation PixelChannel PixelIntensity PixelMask PixelTrait Policy PolicyDomain PolicyRights Primitive QuantumFormat Resource SparseColor Statistic Storage Stretch Style Threshold Tool TransmitType Type Units Validate VirtualPixel Weight)' \
        '-quality=+[level]:n:' \
        '-resize=+[geometry]:str:' \
        '-rotate=+[deg]:str:' \
        '-flip[flip vertically]' \
        '-flop[flip horizontally]' \
        '-crop=+[geometry]:str:' \
        '-trim[trim]' \
        '-shave=+[geometry]:str:' \
        '-extent=+[geometry]:str:' \
        '-thumbnail=+[geometry]:str:' \
        '-sample=+[geometry]:str:' \
        '-scale=+[geometry]:str:' \
        '-blur=+[radius]:str:' \
        '-sharpen=+[radius]:str:' \
        '-gaussian-blur=+[radius]:str:' \
        '-unsharp=+[radius]:str:' \
        '-modulate=+[brightness,saturation,hue]:str:' \
        '-brightness-contrast=+[brightness,contrast]:str:' \
        '-colorspace=+[colorspace]:c:(RGB sRGB CMYK Gray HSL HSB Lab LAB Luv YIQ YUV YCbCr XYZ HCL HCLp HSI HSV HWB LCH LCHab LCHuv Log scRGB)' \
        '-depth=+[bits]:n:' \
        '-density=+[dpi]:str:' \
        '-strip[remove metadata]' \
        '-auto-orient[auto orient]' \
        '-background=+[color]:str:' \
        '-bordercolor=+[color]:str:' \
        '-border=+[geometry]:str:' \
        '-fill=+[color]:str:' \
        '-stroke=+[color]:str:' \
        '-font=+[font name]:str:' \
        '-pointsize=+[size]:n:' \
        '-gravity=+[mode]:m:(None Center East Forget NorthEast North NorthWest SouthEast South SouthWest West)' \
        '-annotate=+[text]:str:' \
        '-draw=+[primitive]:str:' \
        '-composite[composite mode]' \
        '-compose=+[mode]:m:(Atop Blend Blur Bumpmap ChangeMask Clear ColorBurn ColorDodge Colorize CopyBlack CopyBlue CopyCyan CopyGreen Copy CopyMagenta CopyAlpha CopyRed CopyYellow Darken DarkenIntensity DivideDst DivideSrc Dst Difference Displace Dissolve Distort DstAtop DstIn DstOut DstOver Exclusion HardLight HardMix Hue In LinearBurn LinearDodge LinearLight Lighten LightenIntensity LuminizeMathematics MinusDst MinusSrc Modulate ModulusAdd ModulusSubtract Multiply None Out OverCompose Overlay PegtopLight PinLight Plus ReplaceAlpha Saturate Screen Soft-Light Src SrcAtop SrcIn SrcOut SrcOver Stereo VividLight Xor)' \
        '-page=+[geometry]:str:' \
        '-units=+[unit]:u:(PixelsPerInch PixelsPerCentimeter Undefined)' \
        '-format=+[format]:str:' \
        '-define=+[name=value]:str:' \
        '-delay=+[ticks]:str:' \
        '-loop=+[count]:n:' \
        '-monitor[monitor progress]' \
        '-debug=+[events]:str:' \
        '-verbose[verbose]' \
        '*:files:_files'
}

_imagemagick-cli "$@"
