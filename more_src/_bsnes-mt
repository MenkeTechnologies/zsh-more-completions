#compdef bsnes-mt
# Documentation: https://github.com/Marat-Tanalin/bsnes-mt
# Reference accessed: 2026-05-16
# Verified: bsnes-mt is a Marat Tanalin fork of bsnes adding integer scaling,
# PNG screenshots, etc. Like upstream bsnes, the binary takes only a ROM
# positional argument; CLI flag surface (beyond ROM path) is not documented.
# Tool kept per "do not delete files" directive with conservative completion.

# bsnes-mt: Marat Tanalin's fork of bsnes (SNES emulator)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:SNES ROM:_files -g "*.(sfc|smc|fig|swc|bs|st|zip|7z)"' && ret=0
return ret
