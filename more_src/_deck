#compdef deck

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'gateway:Kong Gateway operations'
  'file:declarative file operations'
  'konnect:Konnect operations'
  'ping:test connection to a Kong Gateway'
  'completion:generate shell completion'
  'version:show deck version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--kong-addr=[Kong admin URL]:url:' \
  '--kong-addr-tls-skip-verify[skip TLS verify for Kong]' \
  '--kong-addr-tls-server-name=[server name for Kong TLS]:name:' \
  '*--headers=[extra HTTP header]:header:' \
  '--tls-skip-verify[skip TLS verification]' \
  '--tls-server-name=[TLS SNI override]:name:' \
  '--ca-cert-file=[CA cert file]:file:_files' \
  '--ca-cert=[CA cert literal]:cert:' \
  '--tls-client-cert=[client cert literal]:cert:' \
  '--tls-client-cert-file=[client cert file]:file:_files' \
  '--tls-client-key=[client key literal]:key:' \
  '--tls-client-key-file=[client key file]:file:_files' \
  '--konnect-addr=[Konnect URL]:url:' \
  '--konnect-control-plane-name=[Konnect control plane]:name:' \
  '--konnect-token=[Konnect PAT]:token:' \
  '--konnect-token-file=[Konnect PAT file]:file:_files' \
  '--konnect-email=[Konnect email]:email:' \
  '--timeout=[request timeout]:duration:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--no-color[disable color]' \
  '--analytics=[enable analytics]:flag:(true false)' \
  '--config=[config file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'deck subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (gateway)
        _values 'gateway action' \
          'dump' 'diff' 'sync' 'ping' 'validate' 'reset' 'apply' && ret=0
        ;;
      (file)
        _values 'file action' \
          'openapi2kong' 'merge' 'patch' 'render' 'validate' 'convert' \
          'namespace' 'lint' 'add-tags' 'remove-tags' 'add-plugins' 'list-tags' && ret=0
        ;;
      (konnect)
        _values 'konnect action' 'ping' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
