#compdef shadow
# _shadow-go — Go x/tools shadow analyzer (Alan Donovan, Go team); flags shadowed variable declarations
# upstream: https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/shadow

_shadow-go() {
    _arguments \
        '-strict[strict mode]' \
        '-V[show version]' \
        '-c+[surrounding source context]:n:' \
        '-cpuprofile+[CPU profile]:file:_files' \
        '-debug+[debug flags]:flags:' \
        '-fix[apply rewrites]' \
        '-flags[print analyzer flags]' \
        '-json[json output]' \
        '-memprofile+[memory profile]:file:_files' \
        '-source[show source]' \
        '-tags+[build tags]:tags:' \
        '-trace+[trace file]:file:_files' \
        '-v[verbose]' \
        '*:packages:'
}

_shadow-go "$@"
