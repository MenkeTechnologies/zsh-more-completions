#compdef agave-validator
# Documentation: https://docs.anza.xyz/operations/setup-a-validator
# agave-validator - Solana (Agave) validator node

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--identity=[validator identity keypair file]:file:_files' \
  '--vote-account=[vote account keypair/pubkey]:file:_files' \
  '--ledger=[ledger storage directory]:dir:_files -/' \
  '--accounts=[accounts database directory]:dir:_files -/' \
  '--rpc-port=[JSON RPC server port]:port:' \
  '--dynamic-port-range=[range for dynamically assigned ports]:range:' \
  '*--entrypoint=[cluster entrypoint gossip address]:host\:port:' \
  '*--known-validator=[trusted validator identity for snapshots]:pubkey:' \
  '--only-known-rpc[restrict RPC bootstrap to known validators]' \
  '--log=[log file path]:file:_files' \
  '--expected-genesis-hash=[expected cluster genesis hash]:hash:' \
  '--wal-recovery-mode=[write-ahead-log recovery mode]:mode:' \
  '--limit-ledger-size=[cap ledger storage size in shreds]:n:' && ret=0

return ret
