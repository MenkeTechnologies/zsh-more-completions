#compdef git-hyper-blame
# Documentation: https://chromium.googlesource.com/chromium/tools/depot_tools/+/main/man/html/git-hyper-blame.html
# git hyper-blame — like git blame but ignoring given commits and blaming through them.

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-i+[a revision to ignore; may be given multiple times]:revision:__git_commits' \
  '--ignore-file=[file containing a list of revisions to ignore]:file:_files' \
  '--no-default-ignores[do not ignore commits from the .git-blame-ignore-revs file]' \
  '1:revision:__git_commits' \
  '*:file:_files' && ret=0

return ret
