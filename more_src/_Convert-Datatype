#compdef Convert-Datatype
# Documentation: https://step.esa.int/main/wp-content/help/versions/9.0.0/snap/org.esa.snap.snap.gpf.ui/gpf/org_esa_snap_raster_gpf_ConvertDataTypeOp.html
# ESA SNAP gpt Convert-Datatype operator - convert product data type

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PtargetDataType=[target data type]:type:(int8 int16 int32 uint8 uint16 uint32 float32 float64)' \
  '-PtargetScalingStr=[scaling method]:scaling:(Truncate (Linear \(slope and intercept\)) (Linear \(between 95% clipped histogram\)) (Linear \(peak clipped histogram\)) Logarithmic)' \
  '-PtargetNoDataValue=[target no data value]:value' \
  '*:graph xml:_files' && ret=0

return ret
