#compdef cloud-config-init

# cloud-init "config" stage (modules with frequency=once-per-instance/always)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[debug]' \
  '--debug[debug]' \
  '--force[run regardless of cloud-init disabled file]' \
  '--frequency=[run modules at this frequency]:freq:(instance always once)' \
  '--mode=[run in this mode (init|config|final)]:mode:(init config final)' \
  '*::cloud-init args:_files' && ret=0
return ret
