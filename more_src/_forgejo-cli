#compdef forgejo-cli forgejo
# _forgejo-cli — Forgejo self-hostable Git forge (Gitea soft fork) CLI alias (forgejo team, Go); urfave/cli
# upstream: https://codeberg.org/forgejo/forgejo

_forgejo-cli() {
    local -a sub=(
        'web:start web server'
        'serv:internal serv command'
        'hook:run hook'
        'hook:pre-receive:pre-receive hook'
        'hook:update:update hook'
        'hook:post-receive:post-receive hook'
        'hook:proc-receive:proc-receive hook'
        'dump:dump everything'
        'restore-repo:restore single repo'
        'dump-repo:dump single repo'
        'migrate:run migrations'
        'migrate-storage:migrate attachment storage'
        'cert:generate self-signed cert'
        'admin:user:create:create user'
        'admin:user:change-password:change user password'
        'admin:user:must-change-password:require password change'
        'admin:user:list:list users'
        'admin:user:delete:delete user'
        'admin:user:generate-access-token:generate access token'
        'admin:auth:list:list auth sources'
        'admin:auth:delete:delete auth source'
        'admin:auth:add-oauth:add oauth provider'
        'admin:auth:update-oauth:update oauth provider'
        'admin:auth:add-ldap:add ldap'
        'admin:auth:add-ldap-simple:add ldap simple'
        'admin:auth:update-ldap:update ldap'
        'admin:auth:update-ldap-simple:update ldap simple'
        'admin:auth:add-smtp:add smtp'
        'admin:auth:update-smtp:update smtp'
        'admin:regenerate:hooks:regenerate hooks'
        'admin:regenerate:keys:regenerate ssh keys'
        'admin:sendmail:send mail'
        'doctor:run health checks'
        'manager:logging:add:add logging'
        'manager:logging:pause:pause logging'
        'manager:logging:resume:resume logging'
        'manager:logging:release-and-reopen:release and reopen logs'
        'manager:logging:remove:remove logger'
        'manager:shutdown:shutdown server'
        'manager:restart:restart server'
        'manager:flush-queues:flush queues'
        'manager:processes:list processes'
        'embedded:list:list embedded resources'
        'embedded:view:view embedded resource'
        'embedded:extract:extract embedded resource'
        'generate:secret:generate secret'
        'docs:dump command docs'
        'completion:generate completion'
        'help:show help'
        'actions:generate-runner-token:generate runner token'
        'actions:generate-runner-secret:generate runner secret'
        'actions:register:register runner'
        'convert:convert charset'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--install-port=+[install port]:port:' \
        '--pid=+[pid file]:file:_files' \
        '-P+[pid file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--custom-path=+[custom path]:dir:_files -/' \
        '-C+[custom path]:dir:_files -/' \
        '--work-path=+[work path]:dir:_files -/' \
        '-w+[work path]:dir:_files -/' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'forgejo subcommand' sub ;;
        args)
            case $words[1] in
                admin:user:create) _arguments \
                    '--name=+[username]:user:_users' \
                    '--username=+[username]:user:_users' \
                    '--password=+[password]:str:' \
                    '--email=+[email]:str:' \
                    '--admin[admin user]' \
                    '--random-password[random password]' \
                    '--must-change-password[must change password]' \
                    '--access-token[generate access token]' \
                    '--restricted[restricted user]' ;;
                dump) _arguments \
                    '--file=+[output file]:file:_files' \
                    '-f+[output file]:file:_files' \
                    '--type=+[archive type]:t:(zip tar tar.gz tar.bz2 tar.xz tar.sz tar.zst)' \
                    '-t+[archive type]:t:(zip tar tar.gz tar.bz2 tar.xz tar.sz tar.zst)' \
                    '--skip-repository[skip repos]' \
                    '-R[skip repos]' \
                    '--skip-log[skip logs]' \
                    '-L[skip logs]' \
                    '--skip-custom-dir[skip custom dir]' \
                    '--skip-lfs-data[skip lfs data]' \
                    '--skip-attachment-data[skip attachments]' \
                    '--skip-package-data[skip packages]' \
                    '--skip-repo-archives[skip repo archives]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_forgejo-cli "$@"
