#compdef bigWigtoWig bigWigToWig bigWigtoBedGraph bigWigToBedGraph
# _bigWigtoWig — UCSC Kent Lab bigWigToWig and bigWigToBedGraph convert binary bigWig to ASCII wig or bedGraph (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigWig.html

_bigWigtoWig() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-chrom=+[chromosome name]:str:' \
        '-start=+[start position]:n:' \
        '-end=+[end position]:n:' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '*:bigWig out_wig:_files -g "*.bw *.bigwig *.wig *.bedgraph"'
}

_bigWigtoWig "$@"
