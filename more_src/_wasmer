#compdef wasmer
# Documentation: https://github.com/wasmerio/wasmer (lib/cli/src/commands/)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*-v[increase verbosity]' \
  '--log-format=[log format]:format:(text json)' \
  '--registry=[registry URL]:url' \
  '--token=[registry token]:token' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'add:Add packages to a Wasmer project'
      'app:Manage Wasmer Edge apps'
      'auth:Manage authentication'
      'binfmt:Manage binfmt_misc registration'
      'cache:Manage the Wasmer cache'
      'compile:Compile a WebAssembly binary'
      'config:Show Wasmer configuration'
      'connect:Connect to a remote runtime'
      'container:Container subcommands'
      'create-exe:Create a native executable'
      'create-obj:Create a native object file'
      'deploy:Deploy an application to Wasmer Edge'
      'domain:Manage domains'
      'gen-c-header:Generate a C header file'
      'init:Initialize a new wasmer.toml'
      'inspect:Inspect a WebAssembly file'
      'journal:Manage journal files'
      'login:Log in to Wasmer'
      'logout:Log out of Wasmer'
      'namespace:Manage namespaces'
      'package:Manage packages'
      'publish:Publish a package to the Wasmer registry'
      'run:Run a WebAssembly file or package'
      'self-update:Update Wasmer'
      'ssh:Open SSH to a Wasmer Edge instance'
      'validate:Validate a WebAssembly binary'
      'wast:Run a WAST test script'
      'whoami:Show the currently logged-in user'
      'completions:Generate shell completions'
    )
    _describe -t commands 'wasmer command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      run)
        _arguments -s -S \
          '*--dir=[pre-open a directory]:dir:_directories' \
          '*--mapdir=[map a host directory to a guest directory (GUEST:HOST)]:mapping' \
          '*--env=[set environment variable (KEY=VALUE)]:var' \
          '--invoke=[invoke a specific function]:function' \
          '--singlepass[use Singlepass compiler]' \
          '--cranelift[use Cranelift compiler]' \
          '--llvm[use LLVM compiler]' \
          '--enable-all[enable all features]' \
          '--enable-bulk-memory[enable bulk memory]' \
          '--enable-multi-value[enable multi-value]' \
          '--enable-reference-types[enable reference types]' \
          '--enable-simd[enable SIMD]' \
          '--enable-threads[enable threads]' \
          '--enable-multi-memory[enable multi memory]' \
          '*:wasm file:_files -g "*.(wasm|wat|webc)"' && ret=0
        ;;
      compile|create-exe|create-obj|inspect|gen-c-header)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '--target=[target triple]:target' \
          '--cpu-features=[CPU features (csv)]:list' \
          '--singlepass[use Singlepass compiler]' \
          '--cranelift[use Cranelift compiler]' \
          '--llvm[use LLVM compiler]' \
          '*:wasm file:_files -g "*.(wasm|wat)"' && ret=0
        ;;
      completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac
return ret
