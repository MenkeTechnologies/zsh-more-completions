#compdef wasmer

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'run:run a WebAssembly file or package'
      'compile:compile a WebAssembly binary'
      'create-exe:create a native executable'
      'create-obj:create a native object file'
      'cache:manage the Wasmer cache'
      'config:show Wasmer configuration'
      'self-update:update Wasmer'
      'inspect:inspect a WebAssembly file'
      'init:initialize a new package'
      'login:log in to a registry'
      'publish:publish a package'
      'package:manage packages'
      'app:manage Wasmer Edge apps'
      'deploy:deploy an application'
      'domain:manage domains'
      'namespace:manage namespaces'
      'ssh:connect via SSH'
      'validate:validate a WebAssembly binary'
      'wast:run a WAST test script'
      'binfmt:manage binfmt_misc registration'
      'add:add a package to the project'
      'gen-c-header:generate a C header file'
    )
    _describe -t commands 'wasmer command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      run)
        _arguments -s -S \
          '--dir[pre-open directory]:directory:_files -/' \
          '--mapdir[map a host directory to a guest directory]:mapping' \
          '--env[set environment variable]:VAR=VALUE' \
          '--invoke[invoke a specific function]:function name' \
          '--singlepass[use Singlepass compiler]' \
          '--cranelift[use Cranelift compiler]' \
          '--llvm[use LLVM compiler]' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '--singlepass[use Singlepass compiler]' \
          '--cranelift[use Cranelift compiler]' \
          '--llvm[use LLVM compiler]' \
          '(-o --output)'{-o,--output}'[output file]:output file:_files' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac
return ret
