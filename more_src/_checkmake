#compdef checkmake
# Documentation: https://github.com/mrtazz/checkmake
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_checkmake() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)--version[Show version]' \
    '--debug[Enable debug output]' \
    '--config[Configuration file]:file:_files -g "*.ini"' \
    '--format[Output format]:format:(default json)' \
    '*:makefile:_files -g "(GNUm|M|m)akefile*"'
}

_checkmake "$@"
