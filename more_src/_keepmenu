#compdef keepmenu
# Documentation: https://man.archlinux.org/search?q=keepmenu
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --autotype)'{-a+,--autotype=}'[override default autotype sequence]:seq:' \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
  '(-C --clipboard)'{-C,--clipboard}'[copy selection to clipboard]' \
  '(-d --database)'{-d+,--database=}'[Keepass database path]:file:_files -g "*.kdbx"' \
  '(-k --keyfile)'{-k+,--keyfile=}'[keyfile path]:file:_files' \
  '(-t --totp)'{-t,--totp}'[TOTP mode]' \
  '--cache-time=[password cache minutes]:n:' \
  '--last-used[open last used database]' \
  '*:: :' && ret=0

return ret
