#compdef adk
# Documentation: https://github.com/google/adk-python
# Reference accessed: 2026-05-22
# Verified: src/google/adk/cli/cli_tools_click.py Click CLI (adk --help).

# Zsh completion for adk - Google Agent Development Kit CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'adk command' \
      'create[create new agent app]' \
      'run[run an agent]' \
      'test[run agent test JSON files]' \
      'eval[evaluate agent with eval sets]' \
      'eval_set[manage eval sets]' \
      'optimize[optimize root agent instructions]' \
      'web[start FastAPI server with Web UI]' \
      'api_server[start FastAPI server for agents]' \
      'deploy[deploy agent to hosted environments]' \
      'conformance[conformance testing tools]' \
      'migrate[ADK migration commands]' && ret=0
    ;;
  args)
    case $line[1] in
      deploy)
        if (( CURRENT == 2 )); then
          _values 'deploy command' \
            'agent_engine[deploy to Agent Engine]' \
            'cloud_run[deploy to Cloud Run]' \
            'gke[deploy to GKE]' && ret=0
        fi
        ;;
      eval_set)
        if (( CURRENT == 2 )); then
          _values 'eval_set command' \
            'create[create empty eval set]' \
            'add_eval_case[add eval cases to set]' \
            'generate_eval_cases[generate eval cases dynamically]' && ret=0
        fi
        ;;
      conformance)
        if (( CURRENT == 2 )); then
          _values 'conformance command' \
            'record[generate conformance test YAML]' \
            'test[run conformance tests]' && ret=0
        fi
        ;;
      migrate)
        if (( CURRENT == 2 )); then
          _values 'migrate command' \
            'session[migrate session database schema]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
