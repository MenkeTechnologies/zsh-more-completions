#compdef xskbench xdp-bench
# _xskbench — xdp-tools xskbench CLI XDP AF_XDP socket benchmark performance test tool measuring throughput packets-per-second latency frame-budget zero-copy-rx-tx-l2fwd-drop modes XSK ring fill completion need-wakeup-copy-or-zerocopy busy-poll-irq-coalesce on attached XDP programs (xdp-project team, C); getopt
# upstream: https://github.com/xdp-project/xdp-tools

_xskbench() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[device]:_net_interfaces' \
        '--device=+[iface]:_net_interfaces' \
        '-m+[mode]:m:(drop rx tx l2fwd)' \
        '--mode=+[m]:m:(drop rx tx l2fwd)' \
        '-q+[queue]:n:' \
        '--queue=+[N]:n:' \
        '-Q+[num queues]:n:' \
        '--num-queues=+[N]:n:' \
        '-b+[batch size]:n:' \
        '--batch-size=+[N]:n:' \
        '-z[zero copy]' \
        '--zero-copy[zero copy]' \
        '-c[copy mode]' \
        '--copy[copy mode]' \
        '-p+[poll interval]:n:' \
        '--poll-interval=+[ms]:n:' \
        '-N+[need wakeup]:s:(yes no)' \
        '--need-wakeup=+[s]:s:(yes no)' \
        '-I+[interval sec]:n:' \
        '--interval=+[sec]:n:' \
        '-t+[duration sec]:n:' \
        '--duration=+[sec]:n:' \
        '-T[print timestamps]' \
        '--timestamp[print timestamps]' \
        '-X+[xdp prog]:file:_files -g "*.bpf *.o"' \
        '--xdp-program=+[file]:file:_files -g "*.bpf *.o"' \
        '-B[busy poll]' \
        '--busy-poll[busy poll]' \
        '*::'
}

_xskbench "$@"
