#compdef kdenlive
# Documentation: https://www.mankier.com/1/kdenlive
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kdenlive - Kdenlive video editor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-i[set clip to add]:clip file:_files -g "*.{mp4,mkv,avi,mov,webm,flv,mpg,mpeg,wmv,ogv,mlt,wav,mp3,ogg,flac}"' \
  '--mlt-path=[set MLT environment path]:path:_directories' \
  '--mlt-log=[set MLT log level]:level:(verbose debug)' \
  '--qwindowtitle=[caption in the titlebar]:caption:' \
  '--icon=[application icon]:icon:' \
  '--style=[application GUI style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files -g "*.qss"' \
  '--config=[configuration file]:file:_files' \
  '*:file:_files -g "*.kdenlive"' && ret=0

return ret
