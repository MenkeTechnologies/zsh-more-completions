#compdef gistit

# jrbasso/gistit — `src/gistit.c` usage()

local ret=1
_arguments -s -S \
  '(-v)'{-v,--version}'[show version]' \
  '(-h)'{-h,--help}'[help]' \
  '(-d)'{-d,--description=}'[gist description text]:description:' \
  '--copy[copy resulting URL to clipboard]' \
  '-priv[create secret gist]' \
  '-i+[stdin filename label]:name:' \
  '*:files to upload:_files' && ret=0
return ret
