#compdef gearman
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/gearman.1.html
# gearman - Gearman client/worker command-line tool

local ret=1

_arguments -s -S \
  '-H[print help menu]' \
  '-f+[function name to use for jobs (can be given multiple times)]:function:' \
  '-h+[job server host]:host:_hosts' \
  '-p+[Gearman server port]:port:' \
  '-t+[timeout in milliseconds]:ms:' \
  '-i+[create a pidfile for the process]:pidfile:_files' \
  '-n[run one job per line]' \
  '-N[same as -n but strip off the newline]' \
  '-b[run jobs in the background]' \
  '-I[run jobs as high priority]' \
  '-L[run jobs as low priority]' \
  '-P[prefix all output lines with function names]' \
  '-s[send job without reading from standard input]' \
  '-u+[unique key to use for job]:unique:' \
  '-w[run in worker mode]' \
  '-c+[number of jobs for worker to run before exiting]:count:' \
  '*:arg:_files' && ret=0

return ret
