#compdef mergeOrSplitBaffles
# Detects faces that share points (baffles) and merges or splits them

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-detectOnly[find baffles only, but do not merge or split them]' \
  '-split[topologically split duplicate surfaces]' \
  '-fields[update fields]' \
  '-region+[specify alternative mesh region]:region:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
