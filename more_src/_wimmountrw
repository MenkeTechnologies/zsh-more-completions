#compdef wimmountrw
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-mount.1.html
# wimmountrw — mount a WIM image read-write via FUSE

local ret=1

_arguments -s -S \
  '--check[verify integrity of the WIM before mounting]' \
  '--streams-interface=[how named data streams are made available]:interface:(none xattr windows)' \
  '--debug[enable FUSE debugging and do not fork to background]' \
  '--ref=[reference additional WIMs or split parts]:glob' \
  '--staging-dir=[store temporary staging files under DIR]:dir:_files -/' \
  '--unix-data[honor UNIX-specific metadata from capture]' \
  '--allow-other[pass allow_other to the FUSE mount]' \
  '*:WIM file:_files' && ret=0

return ret
