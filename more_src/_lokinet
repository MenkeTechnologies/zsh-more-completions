#compdef lokinet

# Zsh completion for lokinet - Lokinet VPN

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-g[generate default config]:config file:_files' \
  '--config=[path to config file]:config file:_files' \
  '--log-level=[log level]:level:(debug info warn error none)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'add:add an exit node mapping'
      'del:remove an exit node mapping'
      'list:list exit node mappings'
      'exit:manage exit nodes'
      'map:map a .loki address'
      'unmap:unmap a .loki address'
      'status:show status'
      'bootstrap:add a bootstrap node'
    )
    _describe -t commands 'lokinet commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      add|map)
        _arguments -s -S \
          '1:address:' \
          '2:exit node:' && ret=0
        ;;
      del|unmap)
        _arguments -s -S \
          '1:address:' && ret=0
        ;;
      exit)
        _arguments -s -S \
          '1:exit address:' \
          '--auth=[authentication token]:token:' \
          '--range=[IP range]:range:' && ret=0
        ;;
    esac
    ;;
esac

return ret
