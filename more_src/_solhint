#compdef solhint

# Zsh completion for solhint - Solidity linter

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init-config:create initial configuration with default rules'
  'list-rules:display enabled rules of current config'
  'stdin:read file from stdin'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-f --formatter)'{-f,--formatter}'[output formatter]:formatter:(stylish unix table json compact tap)' \
  '(-w --max-warnings)'{-w,--max-warnings}'[number of allowed warnings]:num:' \
  '(-q --quiet)'{-q,--quiet}'[report errors only]' \
  '--ignore-path[file with patterns to ignore]:file:_files' \
  '--fix[automatically fix problems]' \
  '--fixShow[show fixes that would be applied]' \
  '--noPrompt[do not prompt for confirmation]' \
  '--init[create initial configuration]' \
  '--save[save fix results to original file]' \
  '--disc[disable color output]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _alternative \
      'commands:command:_describe -t commands "command" commands' \
      'files:file:_files -g "*.sol"' && ret=0
    ;;
  args)
    case $words[1] in
      stdin)
        _arguments \
          '--filename[filename for the stdin input]:filename:' && ret=0
        ;;
      *)
        _files -g '*.sol' && ret=0
        ;;
    esac
    ;;
esac

return ret
