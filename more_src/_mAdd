#compdef mAdd
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mAdd.html
# Coadd reprojected images into an output mosaic per a FITS header template

local ret=1

_arguments -s -S \
  '-p+[directory containing reprojected images]:imgdir:_files -/' \
  '-n[ignore pixel-area weighting; no area output]' \
  '-a+[averaging method]:type:(mean median count)' \
  '-e[exact size mode: match template exactly]' \
  '-d+[debugging level (1-3)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:images table:_files -g "*.tbl"' \
  '2:header template:_files' \
  '3:output FITS:_files -g "*.fits"' && ret=0

return ret
