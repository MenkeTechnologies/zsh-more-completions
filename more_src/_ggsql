_ggsql() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'exec:execute a ggsql query passed inline'
                'run:execute a ggsql query from a .sql file'
                'parse:parse a query and show the AST (for debugging)'
                'validate:validate a query syntactically (and against reader column schema if --reader given)'
                'docs:show documentation for ggsql syntax (clauses, layers, scales, aesthetics, coords)'
                'skill:show the ggsql skill — usage guide for AI assistants and humans'
                'help:print help for a subcommand'
            )
            _describe -t commands 'ggsql command' subcmds && ret=0
            ;;
        args)
            local -a reader_schemes=(
                'duckdb\://memory:in-memory DuckDB (default)'
                'duckdb\://path/to/file.duckdb:DuckDB database file'
                'sqlite\://path/to/file.db:SQLite database file'
                'odbc\://DSN=mydsn:ODBC DSN connection'
                'polars\://path/to/file.parquet:Polars Parquet reader'
            )
            case $words[1] in
                exec)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--reader=[data source connection string (default duckdb://memory)]:URI:_alternative "schemes:reader scheme:(($reader_schemes))" "files:file:_files"' \
                        '--writer=[output writer format (default vegalite)]:format:(vegalite)' \
                        '--output=[output file path (default stdout)]:file:_files' \
                        '(-v --verbose)'{-v,--verbose}'[show verbose output (execution details, statistics)]' \
                        '1:ggsql query string:' && ret=0
                    ;;
                run)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--reader=[data source connection string (default duckdb://memory)]:URI:_alternative "schemes:reader scheme:(($reader_schemes))" "files:file:_files"' \
                        '--writer=[output writer format (default vegalite)]:format:(vegalite)' \
                        '--output=[output file path (default stdout)]:file:_files' \
                        '(-v --verbose)'{-v,--verbose}'[show verbose output (execution details, statistics)]' \
                        '1:.sql file:_files -g "*.(sql|SQL|ggsql)"' && ret=0
                    ;;
                parse)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--format=[output format for AST]:format:(pretty debug json)' \
                        '1:ggsql query string:' && ret=0
                    ;;
                validate)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--reader=[data source connection string for column validation (omit to skip column checks)]:URI:_alternative "schemes:reader scheme:(($reader_schemes))" "files:file:_files"' \
                        '1:ggsql query string:' && ret=0
                    ;;
                docs)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--format=[output format (default: rendered text on TTY, raw markdown when piped)]:format:((text\:"ANSI-rendered markdown for terminal display" markdown\:"raw markdown for piping or AI agents" json\:"structured JSON with metadata and body"))' \
                        '1::clause name OR category:(draw layer scale aesthetic coord position from where group order limit having window)' \
                        '2::topic within category:' && ret=0
                    ;;
                skill)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--format=[output format (default: rendered text on TTY, raw markdown when piped)]:format:((text\:"ANSI-rendered markdown for terminal display" markdown\:"raw markdown for piping or AI agents" json\:"structured JSON with metadata and body"))' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(exec run parse validate docs skill)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_ggsql "$@"
