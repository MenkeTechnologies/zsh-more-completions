#compdef zig-cli2
# Documentation: https://ziglang.org/documentation/master/
# Reference accessed: 2026-05-21
# Verified: upstream command list cross-checked against ziglang/zig
#   src/main.zig normal_usage table. Alternate zig command-name completion.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build project'
  'fetch:fetch package and add to build.zig.zon'
  'init:initialize project'
  'init-exe:initialize executable project'
  'init-lib:initialize library project'
  'ast-check:check syntax of file'
  'build-exe:create executable from .zig'
  'build-lib:create library from .zig'
  'build-obj:create object from .zig'
  'test:create and run unit tests'
  'run:create and run executable'
  'fmt:format files'
  'reduce:minimize crashing test case'
  'targets:list supported targets'
  'version:show version'
  'env:show env info'
  'help:show help'
  'cc:C compiler'
  'c++:C++ compiler'
  'translate-c:translate C to Zig'
  'rc:Windows resource compiler'
  'dlltool:create import lib from def'
  'lib:create import lib'
  'ranlib:generate index for archive'
  'objcopy:copy and translate object files'
  'ar:create static library'
  'std:open zig std library docs'
  'libc:print libc paths'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zig command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '(-h --help)'{-h,--help}'[help]' \
          '(-p --prefix)'{-p+,--prefix=}'[install prefix]:dir:_files -/' \
          '(--prefix-lib-dir)--prefix-lib-dir=[lib subdir]:dir:_files -/' \
          '(--prefix-exe-dir)--prefix-exe-dir=[exe subdir]:dir:_files -/' \
          '(--prefix-include-dir)--prefix-include-dir=[include subdir]:dir:_files -/' \
          '(--sysroot)--sysroot=[sysroot]:dir:_files -/' \
          '(--search-prefix)*--search-prefix=[search prefix]:dir:_files -/' \
          '(--libc)--libc=[libc paths file]:file:_files' \
          '(-fopt-bin -fno-opt-bin)-fopt-bin[optimized binary]' \
          '(-fopt-bin -fno-opt-bin)-fno-opt-bin[no optimized binary]' \
          '(-Doptimize)*-Doptimize=[optimize mode]:m:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
          '(-Dtarget)*-Dtarget=[target triple]:t:' \
          '*-D+[k=v option]:v:' \
          '(--build-runner)--build-runner=[build runner]:file:_files' \
          '(--cache-dir)--cache-dir=[cache dir]:dir:_files -/' \
          '(--global-cache-dir)--global-cache-dir=[global cache]:dir:_files -/' \
          '(--zig-lib-dir)--zig-lib-dir=[zig lib dir]:dir:_files -/' \
          '(--summary)--summary=[summary mode]:m:(all new failures none)' \
          '(--debug-log)*--debug-log=[debug log scope]:s:' \
          '(--debug-pkg-config)--debug-pkg-config[debug pkg-config]' \
          '(--seed)--seed=[seed]:n:' \
          '(--prominent-compile-errors)--prominent-compile-errors[show compile errors]' \
          '(-fwine -fno-wine)-fwine[use wine for windows]' \
          '(-freference-trace)-freference-trace[reference trace]' \
          '(-fno-reference-trace)-fno-reference-trace[no reference trace]' \
          '(-j)-j+[parallel jobs]:n:' \
          '*: :' && ret=0 ;;
      (build-exe|build-lib|build-obj)
        _arguments \
          '-femit-bin=[emit binary]:file:_files' \
          '-fno-emit-bin[no emit bin]' \
          '-femit-asm=[emit asm]:file:_files' \
          '-femit-llvm-ir=[emit LLVM IR]:file:_files' \
          '-femit-llvm-bc=[emit LLVM BC]:file:_files' \
          '-femit-h=[emit header]:file:_files' \
          '-femit-docs=[emit docs]:dir:_files -/' \
          '-femit-implib=[emit import lib]:file:_files' \
          '-target=[target]:t:' \
          '-mcpu=[cpu]:c:' \
          '-O+[optimize]:o:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
          '*-I+[include path]:dir:_files -/' \
          '*-isystem+[system include]:dir:_files -/' \
          '*-L+[lib path]:dir:_files -/' \
          '*-l+[lib]:lib:' \
          '*-D+[macro]:macro:' \
          '*--name+[output name]:n:' \
          '*-fLLD[use LLD]' \
          '*-fno-LLD[disable LLD]' \
          '*-fstrip[strip]' \
          '*-fno-strip[no strip]' \
          '*-fsingle-threaded[single threaded]' \
          '*: :_files -g "*.zig *.c *.cpp *.s *.o *.a"' && ret=0 ;;
      (test|run)
        _arguments \
          '-target=[target]:t:' \
          '-O+[optimize]:o:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
          '--test-filter=[filter]:f:' \
          '--test-evented-io[evented IO]' \
          '--test-no-exec[no exec]' \
          '--test-cmd=[wrapper cmd]:c:' \
          '--cache-dir=[cache dir]:dir:_files -/' \
          '*: :_files -g "*.zig"' && ret=0 ;;
      (fmt)
        _arguments \
          '--check[check only]' \
          '--ast-check[run ast-check first]' \
          '--color=[color]:c:(auto on off)' \
          '--exclude=[exclude]:p:' \
          '--stdin[read from stdin]' \
          '*: :_files' && ret=0 ;;
      (init|init-exe|init-lib)
        _arguments '*: :_files -/' && ret=0 ;;
      (cc|c++|translate-c)
        _arguments '*: :_files' && ret=0 ;;
      (env|targets|version|libc)
        _arguments '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
