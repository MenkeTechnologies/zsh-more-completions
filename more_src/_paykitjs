#   Last push  : 2026-06-02
#
# WHAT IT IS
#   PayKit is "the billing framework for TypeScript — products
#   in code, handles Stripe, webhooks".  Developers declare
#   their product catalog (Plans, Tiers, Trials, Meters, Tax,
#   Discounts) in a single TypeScript `paykit.config.ts` file
#   and PayKit pushes the typed declaration to the configured
#   payment provider (Stripe or Polar) via the canonical
#   `@paykitjs/stripe` adapter on `stripe ^19.1.0`.  The CLI
#   ships project scaffolding (`paykitjs init` with framework
#   auto-detection — Next.js, Remix, Express, SvelteKit,
#   Nuxt, Astro, Hono), a `push` command that applies typed
#   migrations to provider + database, a `status` command for
#   drift detection, and a `listen` subcommand that opens a
#   webhook tunnel for local development with retry / replay
#   semantics.
#
# CLI ARGUMENT GRAMMAR  (verbatim from packages/paykit/src/cli/
#                       index.ts + per-command commands/*.ts —
#                       commander v12 with `new Command()`
#                       chain)
#   paykitjs <SUBCOMMAND> [args...]
#
#   Global flags (auto-injected by commander):
#     -v, --version                  Show version
#     -h, --help                     Show help
#
#   Subcommands:
#     init                           Initialize PayKit in your
#                                    project (scaffolds
#                                    `paykit.config.ts`, env
#                                    file, framework
#                                    integration code)
#       -c, --cwd <DIR>                Working directory
#                                      [default: cwd]
#       -y, --defaults                 Skip prompts, use
#                                      defaults
#
#     push                           Apply migrations and sync
#                                    products to database +
#                                    payment provider
#       -c, --cwd <DIR>                Working directory
#       --config <PATH>                Path to paykit.config.ts
#       -y, --yes                      Skip confirmation prompt
#
#     status                         Check PayKit config and
#                                    sync status
#       -c, --cwd <DIR>                Working directory
#       --config <PATH>                Path to paykit.config.ts
#       --throw                        Exit with code 1 on
#                                      issues
#
#     listen                         Register a provider webhook
#                                    tunnel, replay missed
#                                    events, and stream new
#                                    webhooks
#       -c, --cwd <DIR>                Working directory
#       --config <PATH>                Path to paykit.config.ts
#       --retry <WINDOW>               Retry failed deliveries
#                                      received within this
#                                      window
#       --forward-to <URL>             Forward webhooks to a
#                                      local app origin
#
#       listen enable                  Ensure the webhook
#                                      tunnel + provider
#                                      webhook endpoint, then
#                                      exit
#         -c, --cwd <DIR> / --config <PATH>
#
#       listen retry <DELIVERY_ID>     Replay a stored delivery
#         -c, --cwd <DIR> / --config <PATH> / --forward-to <URL>
#
#       listen disable                 Disable the webhook
#                                      tunnel for the current
#                                      provider account
#         -c, --cwd <DIR> / --config <PATH>
#
# AXIS / CORPUS POSITION
#   Direct dependency on `stripe ^19.1.0` declared in
#   packages/stripe/package.json (the `@paykitjs/stripe`
#   workspace adapter that the `paykitjs` CLI invokes through
#   the typed PayKit Provider interface) — `stripe` is THE
#   canonical Node.js Stripe SDK officially maintained by
#   Stripe (stripe/stripe-node, 4K+ stars, ~9M npm downloads/
#   week; the production Node client used by every major
#   Node.js Stripe integration).  stripe-node exposes the
#   typed `Stripe` constructor with `new Stripe(apiKey,
#   { apiVersion: '2025-09-30.clover', telemetry: false,
#     maxNetworkRetries: 2, timeout: 80_000 })`, every Stripe
#   v1 API resource as a typed namespace (`stripe.customers`,
#   `stripe.subscriptions`, `stripe.invoices`, `stripe.
#   paymentIntents`, `stripe.checkout.sessions`, `stripe.
#   paymentLinks`, `stripe.products`, `stripe.prices`,
#   `stripe.coupons`, `stripe.discounts`, `stripe.refunds`,
#   `stripe.charges`, `stripe.accounts`, `stripe.balance`,
#   `stripe.balanceTransactions`, `stripe.subscriptionSchedules`,
#   `stripe.invoiceItems`, `stripe.usageRecords`,
#   `stripe.taxRates`, `stripe.taxCodes`, `stripe.reporting.*`,
#   `stripe.terminal.*`, `stripe.identity.*`, `stripe.issuing.
#   *`, `stripe.treasury.*`, `stripe.climate.*`, `stripe.fileLinks`,
#   `stripe.files`, `stripe.events`, `stripe.webhookEndpoints`,
#   `stripe.creditNotes`, …), typed `Stripe.<Resource>CreateParams`
#   / `<Resource>UpdateParams` / `<Resource>ListParams` builder
#   types, typed `Stripe.ApiList<T>` paginated responses with
#   `for await (const x of stripe.customers.list().autoPaging
#   Iterator())`, the typed `Stripe.Webhook.signature` helper
#   plus `stripe.webhooks.constructEvent(payload, sig, secret)`,
#   the typed `Stripe.Event<T>` discriminated union covering
#   400+ webhook event types, and idempotency-key auto-
#   generation via the second argument of every mutating call.
#   paykitjs's `packages/stripe/src/index.ts` constructs a
#   typed `new Stripe(apiKey)` per environment, walks the
#   typed PayKit declarative manifest, and emits provider-
#   specific mutation batches through `stripe.products.create`
#   / `stripe.prices.create` / `stripe.subscriptions.update`
#   etc. with structured idempotency keys.  Verified via:
#     gh api repos/getpaykit/paykit/contents/packages/paykit/
#         package.json
#       → "commander": "^12.1.0"
#       → "bin": {"paykitjs": "./src/cli/index.ts"}
#     gh api repos/getpaykit/paykit/contents/packages/stripe/
#         package.json
#       → "stripe": "^19.1.0"
#       → "name": "@paykitjs/stripe"
#     gh api repos/getpaykit/paykit/contents/packages/paykit/
#         src/cli/index.ts
#       → const program = new Command()
#           .name("paykitjs")
#           .description("CLI for PayKit")
#           .version(version, "-v, --version");
#       → switch (commandName) { case "status" | "init" |
#                                 "push" | "listen" }
#   This entry is the TS-Node=150 leader bump that CLOSES Axis
#   95 (Stripe / async-stripe) at 1/1/1 three-language symmetry
#   — pairing Rust=async-stripe via devflowinc/trieve (R969
#   _trieve-server — round-number Rust=150 landmark), Go=stripe-
#   go via passwall/passwall-server (R970 _passwall-server —
#   R970 round-number commit landmark), and TS-Node=stripe-node
#   via getpaykit/paykit (this entry).  Triple-150 landmark on
#   commit.  Axis 95 = 88th axis closed.
#
#   No completion for `paykitjs` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_paykitjs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_paykitjs_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '(-c --cwd)'{-c,--cwd}'=[working directory]:dir:_files -/' \
                        '(-y --defaults)'{-y,--defaults}'[skip prompts and use defaults]' && ret=0 ;;
                push)
                    _arguments \
                        '(-c --cwd)'{-c,--cwd}'=[working directory]:dir:_files -/' \
                        '--config=[path to paykit.config.ts]:file:_files -g "paykit*.ts"' \
                        '(-y --yes)'{-y,--yes}'[skip confirmation prompt]' && ret=0 ;;
                status)
                    _arguments \
                        '(-c --cwd)'{-c,--cwd}'=[working directory]:dir:_files -/' \
                        '--config=[path to paykit.config.ts]:file:_files -g "paykit*.ts"' \
                        '--throw[exit with code 1 on issues]' && ret=0 ;;
                listen)
                    _arguments \
                        '(-c --cwd)'{-c,--cwd}'=[working directory]:dir:_files -/' \
                        '--config=[path to paykit.config.ts]:file:_files -g "paykit*.ts"' \
                        '--retry=[retry failed deliveries within this window]:window:' \
                        '--forward-to=[forward webhooks to a local app origin]:url:' \
                        '1::listen subcommand:(enable retry disable)' \
                        '*::arg:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_paykitjs_commands] )) ||
_paykitjs_commands() {
    local -a commands
    commands=(
        'init:initialize PayKit in your project'
        'push:apply migrations and sync products to provider'
        'status:check PayKit configuration and sync status'
        'listen:register webhook tunnel, replay events, stream webhooks'
    )
    _describe -t commands 'paykitjs command' commands
}

_paykitjs "$@"
