#compdef sffft3
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/generic/Mfft3.c
# Madagascar: FFT transform on an extra axis (complex input and output)

local ret=1

_arguments -s \
  'inv=[if y perform inverse transform]:inv:(y n)' \
  'sym=[if y apply symmetric scaling (Hermitian operator)]:sym:(y n)' \
  'sign=[transform sign (0 or 1)]:sign:(0 1)' \
  'opt=[if y determine optimal size for efficiency]:opt:(y n)' \
  'axis=[axis to transform]:axis' \
  'pad=[padding factor]:pad' \
  '*:RSF file:_files' && ret=0

return ret
