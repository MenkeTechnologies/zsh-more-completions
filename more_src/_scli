#compdef scli
# Documentation: https://github.com/isamert/scli
# Reference accessed: 2026-05-21
# Verified: upstream README documents --enable-notifications, --color,
# --wrap-at, --save-history/-s, --editor-command,
# --clipboard-put-command, --key-bind, and the `link` subcommand with
# --name.

local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'link:link scli to an existing Signal account'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--enable-notifications[enable desktop notifications]' \
  '--color=[colorize messages]:scheme:' \
  '--wrap-at=[message wrapping width]:n:' \
  '(-s --save-history)'{-s,--save-history}'[save conversation history]' \
  '--editor-command=[external editor command]:cmd:' \
  '--clipboard-put-command=[clipboard command]:cmd:' \
  '*--key-bind=[remap keyboard shortcut (ACTION:KEY)]:binding:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'scli subcommand' subcommands && ret=0 ;;
  args)
    case $line[1] in
      link)
        _arguments '--name=[device name]:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
