#compdef connectomeedit
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/connectomeedit.html
# Source: MRtrix3/mrtrix3 cmd/connectomeedit.cpp — basic connectome editing operations (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:input (connectome):_files -g "*.{csv,txt}"' \
    '2:operation:(to_symmetric upper_triangular lower_triangular transpose zero_diagonal)' \
    '3:output:_files -g "*.{csv,txt}"' \
    && ret=0

return ret
