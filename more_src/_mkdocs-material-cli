#compdef mkdocs-material-cli mkdocs-material
# _mkdocs-material-cli — Martin Donath Material for MkDocs theme CLI alias (squidfunk team, Python); click
# upstream: https://github.com/squidfunk/mkdocs-material

_mkdocs-material-cli() {
    local -a sub=(
        'help:show help'
        'serve:serve docs locally'
        'build:build static site'
        'new:create new project'
        'gh-deploy:deploy to github pages'
        'get-deps:install plugin deps'
        'social-cards:generate social cards'
        'social:generate social cards'
        'tags:generate tag pages'
        'projects:project commands'
        'theme:list-icons:list bundled icons'
        'theme:list-fonts:list bundled fonts'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mkdocs subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--dev-addr=+[bind addr]:str:' \
                    '-a+[bind addr]:str:' \
                    '--livereload[livereload]' \
                    '--no-livereload[no livereload]' \
                    '--dirtyreload[dirty reload]' \
                    '--clean[clean reload]' \
                    '-f+[config file]:file:_files -g "mkdocs.{yml,yaml}"' \
                    '--config-file=+[config file]:file:_files -g "mkdocs.{yml,yaml}"' \
                    '--strict[strict mode]' \
                    '-s[strict mode]' \
                    '-t+[theme]:t:(material mkdocs readthedocs)' \
                    '--theme=+[theme]:t:(material mkdocs readthedocs)' \
                    '--use-directory-urls[use directory urls]' \
                    '--no-directory-urls[no directory urls]' \
                    '--watch=+[extra watch dir]:dir:_files -/' \
                    '-w+[extra watch dir]:dir:_files -/' \
                    '--watch-theme[watch theme]' ;;
                build) _arguments \
                    '-c[clean output dir]' \
                    '--clean[clean output dir]' \
                    '--dirty[dirty build]' \
                    '-f+[config file]:file:_files -g "mkdocs.{yml,yaml}"' \
                    '--config-file=+[config file]:file:_files -g "mkdocs.{yml,yaml}"' \
                    '--strict[strict mode]' \
                    '-s[strict mode]' \
                    '-t+[theme]:t:(material mkdocs readthedocs)' \
                    '--theme=+[theme]:t:(material mkdocs readthedocs)' \
                    '--site-dir=+[output dir]:dir:_files -/' \
                    '-d+[output dir]:dir:_files -/' ;;
                gh-deploy) _arguments \
                    '-c[clean output dir]' \
                    '--clean[clean output dir]' \
                    '--dirty[dirty build]' \
                    '-m+[commit message]:str:' \
                    '--message=+[commit message]:str:' \
                    '--remote-branch=+[remote branch]:str:' \
                    '-b+[remote branch]:str:' \
                    '--remote-name=+[remote name]:str:' \
                    '-r+[remote name]:str:' \
                    '--force[force push]' \
                    '--no-history[no history]' \
                    '--ignore-version[ignore version]' \
                    '--shell[use shell]' ;;
                new) _arguments '1:project name:' ;;
            esac
            ;;
    esac
}

_mkdocs-material-cli "$@"
