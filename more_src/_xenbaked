#compdef xenbaked
# Documentation: https://man.archlinux.org/search?q=xenbaked
# Reference accessed: 2026-05-16

# xenbaked: Xen baker daemon collecting performance trace data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '*::xenbaked args:_files' && ret=0
return ret
