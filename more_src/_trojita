#compdef trojita
# Documentation: https://man.archlinux.org/search?q=trojita
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--mainwindow-show=[show main window]:bool:(true false)' \
  '--addressbook=[address book file]:file:_files' \
  '--log-to-disk[log to disk]' \
  '*:imap_url:' && ret=0

return ret
