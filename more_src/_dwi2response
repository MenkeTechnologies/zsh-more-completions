#compdef dwi2response
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwi2response.html
# Source: MRtrix3/mrtrix3 bin/dwi2response — response function estimation dispatcher (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[initial mask for voxel selection]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-voxels+[output final voxel selection image]:image:_files' \
    '-shells+[b-values to use (comma-separated)]:shells:_default' \
    '-lmax+[max harmonic degree(s), comma-separated]:lmax:_default' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:algorithm:(dhollander fa manual msmt_5tt tax tournier)' \
    '*:algorithm-specific arguments:_files' \
    && ret=0

return ret
