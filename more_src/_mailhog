#compdef mailhog MailHog

# Zsh completion for MailHog - email testing tool

_arguments -s -S \
  '-api-bind-addr=[HTTP API bind address]:address:' \
  '-cors-origin=[CORS allowed origin]:origin:' \
  '-hostname=[hostname for SMTP EHLO/HELO]:hostname:_hosts' \
  '-invite-jim[enable Jim (chaos monkey)]:' \
  '-jim-accept=[chance of accepting connection]:probability:' \
  '-jim-disconnect=[chance of disconnecting]:probability:' \
  '-jim-linkspeed-affect=[chance of slow link]:probability:' \
  '-jim-linkspeed-max=[max link speed (bytes/s)]:speed:' \
  '-jim-linkspeed-min=[min link speed (bytes/s)]:speed:' \
  '-jim-reject-auth=[chance of rejecting auth]:probability:' \
  '-jim-reject-recipient=[chance of rejecting recipient]:probability:' \
  '-jim-reject-sender=[chance of rejecting sender]:probability:' \
  '-mongo-coll=[MongoDB collection name]:collection:' \
  '-mongo-db=[MongoDB database name]:database:' \
  '-mongo-uri=[MongoDB URI]:uri:' \
  '-outgoing-smtp=[outgoing SMTP config file]:config file:_files -g "*.json"' \
  '-smtp-bind-addr=[SMTP bind address]:address:' \
  '-storage=[message storage]:storage:(memory mongodb maildir)' \
  '-ui-bind-addr=[UI bind address]:address:' \
  '-ui-web-path=[web UI path]:path:'
