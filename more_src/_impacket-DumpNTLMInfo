#compdef impacket-DumpNTLMInfo
# Documentation: https://github.com/fortra/impacket/blob/master/examples/DumpNTLMInfo.py
# Do NTLM authentication and parse information

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-debug[turn DEBUG output ON]' \
  '-ts[adds timestamp to every logging output]' \
  '-target-ip=[IP address of the target machine]:ip' \
  '-port=[destination port to connect to SMB/RPC server (default 445)]:port' \
  '-protocol=[protocol to use (default SMB)]:protocol:(SMB RPC)' \
  '1:target (<targetName or address>):' && ret=0

return ret
