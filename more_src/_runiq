#compdef runiq

local -a arguments

arguments=(
  '(-f --filter)'{-f,--filter}'=[set deduplication filter]:filter:(naive bloom sorted digest)'
  '(-i --invert)'{-i,--invert}'[print only duplicate lines]'
  '(-s --sort)'{-s,--sort}'[sort output]'
  '(-c --count)'{-c,--count}'[prepend count of occurrences]'
  '(-o --output)'{-o,--output}'=[write output to file]:output file:_files'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version information]'
  '*:input file:_files'
)

_arguments -s -S $arguments
