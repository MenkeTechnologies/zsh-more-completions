#compdef retrace
# Documentation: https://developer.android.com/tools/retrace
# R8 retrace - de-obfuscate stack traces using an R8/ProGuard mapping file

local ret=1

_arguments -s -S \
  '--verbose[print method parameters and return types]' \
  '--info[set diagnostic level to info]' \
  '--quiet[reduce printed information]' \
  '--regex=[regex for parsing stack trace lines]:regex:' \
  '1:mapping file:_files' \
  '2:stack trace file:_files' && ret=0

return ret
