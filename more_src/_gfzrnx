#compdef gfzrnx
# Documentation: https://gnss.git-pages.gfz-potsdam.de/gfzrnx/basics/usage/
# GFZ RINEX 2/3/4 conversion and manipulation toolbox

local ret=1

_arguments -s \
  '*-finp[input RINEX file(s)]:file:_files' \
  '-fout[output RINEX or statistics file]:file:_files' \
  '-f[force overwrite of existing output files]' \
  '-vo[output RINEX version]:ver:(2 3 4)' \
  '-vosc[output fully standards-compliant version]:ver:(2 3 4)' \
  '-vnum[modify header version number]:m.nn' \
  '-kv[keep major output version matching input]' \
  '-smp[sampling rate (sec)]:num' \
  '-smp_nom[sampling rate for automatic naming]:num' \
  '-d[file duration (sec)]:sec' \
  '-sei[strict epoch interval mode]:mode:(in out)' \
  '-epo_beg[first output epoch]:epoch' \
  '-satsys[filter satellite systems]:letters' \
  '-ot[observation types to include]:list' \
  '-prn[include specific PRNs]:prn-list' \
  '-no_prn[exclude specific PRNs]:prn-list' \
  '-rsot[remove sparse observation types]:n' \
  '-splice[combine multiple files]' \
  '-splice_direct[splice without RAM storage]' \
  '-split[divide files into n-second segments]:n' \
  '-crux[header manipulation definitions]:file:_files' \
  '-hded[header editing only mode]' \
  '-meta[extract file metadata]:type' \
  '-tab[generate tabular output]' \
  '-stk_obs[output data statistics]' \
  '-fdiff[compare two RINEX files]' \
  '-4to9[site naming configuration]:file:_files' \
  '-nomren23[RINEX-2 to RINEX-3 naming]:params' \
  '-site[station identifier]:sitename' \
  '-q[quiet mode]' \
  '-errlog[store error logs to file]:file:_files' \
  '(-h -help)'{-h,-help}'[display help information]' && ret=0

return ret
