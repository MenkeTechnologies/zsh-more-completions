#compdef clinfo
# Documentation: https://man.archlinux.org/search?q=clinfo
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-a[list all platforms and devices]' \
  '--all[list all platforms and devices]' \
  '-l[list platforms and devices by name]' \
  '--list[list platforms and devices by name]' \
  '--human[human-readable output]' \
  '--raw[raw output]' \
  '--json[JSON output]' \
  '--offline[also show offline devices]'
