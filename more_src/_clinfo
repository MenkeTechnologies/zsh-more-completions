#compdef clinfo
# Documentation: https://manpages.debian.org/bookworm/clinfo/clinfo.1.en.html
# Reference accessed: 2026-05-17
# Verified: Debian bookworm clinfo(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated mapping of -a/--all (real long form is --all-props);
# missing -A/--always-all-props, -d/--device, --prop, --null-platform.

# clinfo: OpenCL platform/device info reporter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h -?)-h[show help]' \
  '(-h -?)-?[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --all-props)'{-a,--all-props}'[list all property names]' \
  '(-A --always-all-props)'{-A,--always-all-props}'[always list all property names]' \
  '--human[human-readable output]' \
  '--raw[raw output]' \
  '--json[JSON output]' \
  '(-l --list)'{-l,--list}'[list platforms and devices by name]' \
  '(-d --device)'{-d+,--device=}'[query specific device platform\:device]:p\:d:' \
  '*--prop=[query specific property name]:name:' \
  '--offline[also show offline devices]' \
  '--null-platform[query the cl_null_platform_id platform]' && ret=0
return ret
