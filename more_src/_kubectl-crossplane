#compdef kubectl-crossplane
# kubectl plugin for managing Crossplane resources

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build a Crossplane package'
      'install:install a Crossplane package'
      'push:push a Crossplane package'
      'update:update a Crossplane package'
      'xpkg:manage Crossplane packages'
    )
    _describe -t commands 'kubectl-crossplane command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          '-f[package directory]:dir:_files -/' \
          '-o[output file]:file:_files' \
          '--name[package name]:name:' && ret=0
        ;;
      push)
        _arguments \
          '-f[package file]:file:_files' \
          '*:registry/image:' && ret=0
        ;;
      install)
        _arguments \
          '--name[installation name]:name:' \
          '*:package:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
