#compdef amethyst
# _amethyst — ianyh Amethyst tiling WM for macOS CLI alias (Ian Ynda-Hummel, Swift); custom URL scheme
# upstream: https://github.com/ianyh/Amethyst

_amethyst() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--reload[reload config]' \
        '--restart[restart amethyst]' \
        '--quit[quit amethyst]' \
        '--toggle-layout[toggle layout]' \
        '--cycle-layout[cycle layout]' \
        '--set-layout=+[set layout]:l:(tall wide fullscreen column row floating 3column-left 3column-middle 3column-right tall-right)' \
        '--shrink-main[shrink main pane]' \
        '--expand-main[expand main pane]' \
        '--increase-main[increase main pane count]' \
        '--decrease-main[decrease main pane count]' \
        '--focus-next[focus next window]' \
        '--focus-previous[focus previous window]' \
        '--swap-next[swap with next window]' \
        '--swap-previous[swap with previous window]' \
        '--swap-main[swap with main]' \
        '--throw-space=+[throw window to space]:n:' \
        '--focus-space=+[focus space]:n:' \
        '--throw-screen=+[throw window to screen]:n:' \
        '--focus-screen=+[focus screen]:n:' \
        '--toggle-tiling[toggle tiling for current window]' \
        '--toggle-float[toggle float for current window]' \
        '--display-current-layout[display current layout]' \
        '--restart-current-display-layout[restart current display layout]' \
        '*:arg:'
}

_amethyst "$@"
