#compdef changie

# Zsh completion for changie (changelog automation)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize changie configuration'
      'new:Create a new changelog entry'
      'batch:Batch pending changes into a version'
      'merge:Merge batched changes into the changelog'
      'latest:Print the latest version'
      'next:Print the next version'
      'completion:Generate shell completions'
    )
    _describe -t commands 'changie command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      new)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-k+[Kind of change]:kind' \
          '--kind=[Kind of change]:kind' \
          '-b+[Body of the change]:body' \
          '--body=[Body of the change]:body' \
          '-c+[Custom values]:custom' \
          '--custom=[Custom values]:custom' \
          '-e[Open editor for body]' \
          '--editor[Open editor for body]' \
          '--dry-run[Print change without saving]' && ret=0
        ;;
      batch)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--dry-run[Print batch without saving]' \
          '--move-dir=[Directory to move changes to]:dir:_directories' \
          '--remove-prereleases[Remove prerelease versions]' \
          '-k[Keep unreleased changes]' \
          '--keep[Keep unreleased changes]' \
          '-p+[Prerelease value]:prerelease' \
          '--prerelease=[Prerelease value]:prerelease' \
          '-m+[Metadata value]:metadata' \
          '--metadata=[Metadata value]:metadata' \
          '-j[Include major version bump]' \
          '--major[Include major version bump]' \
          '-i[Include minor version bump]' \
          '--minor[Include minor version bump]' \
          '-a[Include patch version bump]' \
          '--patch[Include patch version bump]' \
          '1:version' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--dry-run[Print merge without saving]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
