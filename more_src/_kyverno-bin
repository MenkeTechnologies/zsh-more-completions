#compdef kyverno
# _kyverno-bin — Kyverno k8s policy CLI (Nirmata + CNCF, Go); apply, test, validate Kyverno policies against manifests
# upstream: https://github.com/kyverno/kyverno

_kyverno-bin() {
    local -a sub=(
        'apply:apply policy to resources'
        'completion:print shell completion'
        'create:create policy file'
        'docs:generate docs'
        'fix:fix policy resources'
        'help:show help'
        'inspect:inspect resource'
        'jp:JMESPath utility'
        'json:JSON utility'
        'migrate:migrate policy versions'
        'oci:OCI image policies'
        'test:run policy tests'
        'validate:validate Rego/Kyverno policy'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-V+[verbosity]:n:' \
        '--verbosity+[verbosity]:n:' \
        '--add_dir_header[add dir header]' \
        '--alsologtostderr[log to stderr too]' \
        '--log_backtrace_at+[log backtrace at]:str:' \
        '--log_dir+[log dir]:dir:_files -/' \
        '--logtostderr+[log to stderr]:bool:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kyverno subcommand' sub ;;
        args)
            case $words[1] in
                apply) _arguments \
                    '-p+[policy file]:file:_files' \
                    '--policy+[policy file]:file:_files' \
                    '-r+[resource file]:file:_files' \
                    '--resource+[resource file]:file:_files' \
                    '--cluster[apply to live cluster]' \
                    '--mutate-logpath+[mutate log path]:file:_files' \
                    '-o+[output format]:fmt:(yaml json)' \
                    '--output+[output format]:fmt:' \
                    '--stdin[read from stdin]' \
                    '--audit-warn[show audit warnings]' \
                    '--policy-report[generate policy report]' \
                    '--git-branch+[git branch]:branch:' \
                    '-b+[git branch]:branch:' \
                    '*:resources:_files' ;;
                test) _arguments \
                    '-f+[test file]:file:_files' \
                    '--file-name+[test file name]:str:' \
                    '--git-branch+[git branch]:branch:' \
                    '-b+[git branch]:branch:' \
                    '*:dir:_files -/' ;;
                create) _arguments '1:policy file:_files' '--name+[name]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kyverno-bin "$@"
