#compdef systemd-vmspawn
# _systemd-vmspawn (systemd VM helper that spawns a VM image as if it were a portable service: -M machine name, -i image, --bind/--bind-ro pass-through paths, --network-bridge/--network-tap/--private-network, --setenv, --runtime-network, --boot, --register, -E env override, --quiet)
# upstream: https://github.com/systemd/systemd (src/vmspawn)
# Flags from systemd src/vmspawn/vmspawn.c on tip.

_systemd-vmspawn() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-q[quiet]' \
        '-M+[machine name]:name:' \
        '--machine+[machine name]:name:' \
        '-i+[image]:file:_files' \
        '--image+[image]:file:_files' \
        '*--bind+[bind mount]:src[:dst]:' \
        '*--bind-ro+[ro bind mount]:src[:dst]:' \
        '*--setenv+[KEY=VALUE]:env:' \
        '*-E+[KEY=VALUE]:env:' \
        '--network-bridge+[bridge]:bridge:' \
        '--network-tap[private TAP network]' \
        '--private-network[private network]' \
        '--register=*[register with machined]:bool:(yes no)' \
        '--cpus+[cpus]:n:' \
        '--memory+[memory]:size:' \
        '--smbios=*[smbios spec]:spec:' \
        '*--firmware+[fw blob]:file:_files' \
        '--background=*[bg mode]:mode:(auto yes no)' \
        '*::command:_command_names -e'
}

_systemd-vmspawn "$@"
