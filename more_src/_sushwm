#compdef sushwm
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/PotashCorp_SU/sushwm/sushwm.c
# set one or more header words using trace number arithmetic or from a file

local ret=1

_arguments -s -S \
  'key=[header key word(s) to set]:key' \
  'a=[value(s) on first trace]:a' \
  'b=[increment(s) within group]:b' \
  'c=[group increment(s)]:c' \
  'd=[trace number shift(s)]:d' \
  'j=[number of elements in group]:j' \
  'infile=[binary file of values for the key fields]:file:_files' \
  'format=[format of the infile]:format:(float double integer)' \
  '*:file:_files' && ret=0

return ret
