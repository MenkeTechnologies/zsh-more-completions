#compdef rpmrebuild

_arguments -s \
  '(-5 --md5-compat-digest)'{-5,--md5-compat-digest}'[RPM 4.4 compatible MD5 digest]' \
  '(-a --additional)'{-a,--additional=}'[additional rpmbuild flags]:flags:' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '--cap-from-db[POSIX caps from RPM DB]' \
  '--cap-from-fs[POSIX caps from filesystem]' \
  '(-c --comment-missing)'{-c,--comment-missing=}'[comment missing files]:value:(yes no)' \
  '*'{-D,--define=}'[pass define]:def:' \
  '(-d --directory)'{-d,--directory=}'[output directory]:dir:_files -/' \
  '(-e --edit-spec)'{-e,--edit-spec}'[edit spec file]' \
  '(-f --filter)'{-f,--filter=}'[plugin command]:cmd:' \
  '(- *)'{-h,--help}'[show help]' \
  '--help-plugins[plugin help]' \
  '(-i --include)'{-i,--include=}'[options file]:file:_files' \
  '(-I --install)'{-I,--install}'[install created package]' \
  '(-k --keep-perm)'{-k,--keep-perm}'[keep permissions]' \
  '(-l --list-plugin)'{-l,--list-plugin}'[list plugins]' \
  '(-m --modify)'{-m,--modify=}'[plugin modify command]:cmd:' \
  '(-n --notest-install)'{-n,--notest-install}'[skip test install]' \
  '(-p --package)'{-p,--package}'[use package file]' \
  '--pug-from-db[perms from RPM DB]' \
  '--pug-from-fs[perms from filesystem]' \
  '(-P --autoprovide)'{-P,--autoprovide}'[auto compute provides]' \
  '(-R --autorequire)'{-R,--autorequire}'[auto compute requires]' \
  '(-r --release)'{-r,--release=}'[release version]:ver:' \
  '(-s --spec-only)'{-s,--spec-only=}'[generate spec only]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--debug[debug mode]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-w --warning)'{-w,--warning}'[show warnings]' \
  '(-y --verify)'{-y,--verify=}'[verify package]:value:(yes no)' \
  '*:rpm:_files -g "*.rpm"'
