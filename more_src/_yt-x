#compdef yt-x
# Documentation: https://github.com/Benexl/yt-x
# yt-x - browse youtube and other yt-dlp supported sites from the terminal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-s --search)'{-s,--search}'[execute a video search immediately]:term' \
  '(-sp --search-playlist)'{-sp,--search-playlist}'[execute a playlist search]:term' \
  '(-sc --search-channel)'{-sc,--search-channel}'[execute a channel search]:term' \
  '(-ss --search-short)'{-ss,--search-short}'[execute a short search]:term' \
  '(-sm --search-movie)'{-sm,--search-movie}'[execute a movie search]:term' \
  '(-cp --custom-playlist)'{-cp,--custom-playlist}'[open a specific custom playlist]:name' \
  '(-cc --custom-cmd)'{-cc,--custom-cmd}'[execute a specific custom command]:name' \
  '(-sv --saved-video)'{-sv,--saved-video}'[open a specific saved video]:title' \
  '(-l --launcher)'{-l,--launcher}'[override the default menu launcher]:launcher:(fzf rofi)' \
  '--preview[enable the preview window]' \
  '--no-preview[disable the preview window]' \
  '--preview-images[enable image preview]' \
  '--no-preview-images[disable image preview]' \
  '(-ce --cmd-exit)'{-ce,--cmd-exit}'[exit after shortcut menu options]' \
  '(-ps --playlist-skip)'{-ps,--playlist-skip}'[skip playlist selection menu]' \
  '(-me --media-exit)'{-me,--media-exit}'[exit after media action]' \
  '--play[watch the selected video]' \
  '--play-all[play entire playlist]' \
  '--listen[listen to audio of selected video]' \
  '--listen-all[listen to entire playlist as audio]' \
  '--download[download selected video]' \
  '--download-all[download entire playlist]' \
  '--download-audio[download audio only]' \
  '--download-audio-all[download playlist as audio]' \
  '--save[save video to local list]' \
  '--save-playlist[save playlist locally]' \
  '--shell[open subshell with state variables]' \
  '(-p --player)'{-p,--player}'[specify media player]:player:(mpv vlc tplay)' \
  '--mpv-args[pass custom mpv arguments]:args' \
  '--vlc-args[pass custom vlc arguments]:args' \
  '--tplay-args[pass custom tplay arguments]:args' \
  '--disown-player[run player in background]' \
  '--no-disown-player[keep player attached]' \
  '--feed[open personalized feed]' \
  '--subscriptions-feed[open subscriptions feed]' \
  '--watch-later[open watch later playlist]' \
  '--playlists[browse saved playlists]' \
  '--custom-playlists[browse custom playlists]' \
  '--saved[open saved videos]' \
  '--recent[show recently watched]' \
  '--liked[open liked videos]' \
  '--watch-history[show watch history]' \
  '--clips[browse clips]' \
  '--new-custom-cmd[create custom command]' \
  '--custom-cmds[execute custom command]' \
  '--search-history[browse search history]' \
  '--edit-search-history[edit search history file]' \
  '--edit-custom-playlists[edit custom playlists]' \
  '--edit-mpv-config[edit mpv configuration]' \
  '--edit-yt-dlp-config[edit yt-dlp configuration]' \
  '--edit-custom-cmds[edit custom commands]' \
  '--rofi-theme-main[custom rofi theme for main menu]:path:_files' \
  '--rofi-theme-preview[custom rofi theme for preview]:path:_files' \
  '--rofi-theme-prompt[custom rofi theme for prompts]:path:_files' \
  '--rofi-theme-confirm[custom rofi theme for confirmations]:path:_files' \
  '--rofi-theme-pager[custom rofi theme for pager]:path:_files' \
  '(-x --extension)'{-x,--extension}'[load specific extension file]:file:_files' \
  '(-e --edit-config)'{-e,--edit-config}'[open configuration file]' \
  '(-U --update)'{-U,--update}'[check for and apply updates]' \
  '(-E --generate-desktop-entry)'{-E,--generate-desktop-entry}'[generate desktop entry]' \
  '--config-write[write runtime config to file]' && ret=0

return ret
