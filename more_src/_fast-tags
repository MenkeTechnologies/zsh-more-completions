#compdef fast-tags
# Documentation: https://github.com/elaforge/fast-tags
# Fast tags-file generator for Haskell

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--version[display current version]' \
  '--cabal[parse cabal files and generate tags for exposed modules]' \
  '(-e --emacs)'{-e,--emacs}'[generate tags in Emacs format]' \
  '*--exclude=[exclude files matching a pattern when using -R]:pattern' \
  '(-L --follow-symlinks)'{-L,--follow-symlinks}'[follow symbolic links during recursive traversal]' \
  '--nomerge[replace existing tags file instead of merging]' \
  '--no-module-tags[omit module-level tags from output]' \
  '-o+[output file (defaults to tags for Vim, TAGS for Emacs)]:file:_files' \
  '--qualified[generate both qualified and unqualified tag versions]' \
  '--fully-qualified[generate fully qualified tags (A.B.C.f)]' \
  '--src-prefix=[strip this path prefix from module names]:prefix' \
  '-R[recursively process all files under specified directories]' \
  '(-v --verbose)'{-v,--verbose}'[print files during tagging]' \
  '-0[expect newline-separated (or 0-separated) file list on stdin]' \
  '*:file:_files' && ret=0

return ret
