#compdef wails3
# Documentation: https://github.com/wailsapp/wails/blob/master/v3/cmd/wails3/main.go
# Wails v3 CLI: build cross-platform desktop apps with Go and web tech

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'docs:open the docs'
      'init:initialise a new project'
      'build:build the project'
      'dev:run in dev mode'
      'package:package application'
      'doctor:system status report'
      'doctor-ng:system status report (new TUI)'
      'releasenotes:show release notes'
      'task:run and list tasks'
      'generate:generation tools'
      'update:update tools'
      'service:service tools'
      'tool:various tools'
      'setup:project setup wizards'
      'sign:sign binaries and packages'
      'ios:iOS tooling'
      'android:Android tooling'
      'version:print the version'
      'sponsor:sponsor the project'
    )
    _describe -t commands 'wails3 command' cmds && ret=0
    ;;
esac

return ret
