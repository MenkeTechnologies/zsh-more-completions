#compdef gostringer
# _gostringer — gostringer alternate Stringer generator (community fork); compatible with x/tools stringer
# upstream: https://github.com/anjmao/gostringer

_gostringer() {
    _arguments \
        '-type+[type names]:types:' \
        '-output+[output file]:file:_files' \
        '-tags+[build tags]:tags:' \
        '-linecomment[use line comment]' \
        '-trimprefix+[trim prefix]:prefix:' \
        '*:dir:_files -/'
}

_gostringer "$@"
