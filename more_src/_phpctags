#compdef phpctags
# Documentation: https://github.com/vim-php/phpctags/blob/master/bootstrap.php
# Enhanced ctags-compatible index generator for PHP

local ret=1

_arguments -s -S \
  '(--help)--help[display option summary]' \
  '(--version)--version[print version information]' \
  '-a[append tags to existing file]' \
  '(-o)-f+[write tags to file (default tags)]:tags file:_files' \
  '(-f)-o+[write tags to file]:tags file:_files' \
  '-C+[use cache file for faster updates]:cache:_files' \
  '-n[equivalent to --excmd=number]' \
  '-N[equivalent to --excmd=pattern]' \
  '-R[equivalent to --recurse=yes]' \
  '-u[equivalent to --sort=no]' \
  '-V[equivalent to --verbose=yes]' \
  '--append=[append to existing tag file]:yesno:(yes no)' \
  '--debug[respect PHP error level configuration]' \
  '--exclude=[exclude matching files/directories]:pattern:' \
  '--excmd=[EX command type for tag location]:type:(number pattern mix)' \
  '--fields=[extension fields flags]:fields:' \
  '--kinds=[enable/disable tag kinds]:kinds:' \
  '--extensions=[file extensions to scan]:exts:' \
  '--format=[tag file format version]:level:(1 2)' \
  '--memory=[memory limit]:limit:' \
  '--recurse=[recurse into directories]:yesno:(yes no)' \
  '--sort=[sort tags]:sort:(yes no foldcase)' \
  '--verbose=[verbose output]:yesno:(yes no)' \
  '*:file:_files' && ret=0

return ret
