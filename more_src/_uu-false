#compdef uu-false
# Documentation: https://uutils.github.io/coreutils/docs/utils/false.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

autoload -U is-at-least

_uu-false() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--help[Print help information]' \
'--version[Print version information]' \
&& ret=0
}

(( $+functions[_uu-false_commands] )) ||
_uu-false_commands() {
    local commands; commands=()
    _describe -t commands 'uu-false commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-false" ]; then
    _uu-false "$@"
else
    compdef _uu-false uu-false
fi
