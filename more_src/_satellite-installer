#compdef satellite-installer

# Red Hat Satellite installer (foreman-installer wrapper with satellite scenario)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-S --scenario)'{-S,--scenario=}'[deployment scenario]:scenario:(satellite capsule)' \
  '(-i --interactive)'{-i,--interactive}'[interactive parameter prompts]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-l --verbose-log-level)'{-l,--verbose-log-level=}'[log level]:level:(NOTICE INFO DEBUG)' \
  '(-n --noop)'{-n,--noop}'[dry-run]' \
  '--list-scenarios[list available scenarios]' \
  '--enable-foreman-plugin-katello[enable Katello plugin]' \
  '--enable-foreman-proxy-plugin-pulp[enable Pulp proxy plugin]' \
  '--reset[reset parameters to defaults]' \
  '--upgrade[upgrade installation]' \
  '--upgrade-puppet[upgrade Puppet during install]' \
  '*::installer params (--foreman-foreman-url=URL etc):_files' && ret=0
return ret
