#compdef satellite-installer

# satellite-installer: Red Hat Satellite installer (kafo wrapper over puppet)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--full-help[show full help including module options]' \
  '-i[run interactive wizard]' \
  '--interactive[run interactive wizard]' \
  '-n[non-interactive]' \
  '--noop[no-op mode]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-l[log level]:level:(debug info notice warning err alert emerg crit)' \
  '--log-level=[log level]:level:(debug info notice warning err alert emerg crit)' \
  '--list-scenarios[list available scenarios]' \
  '-S[scenario name]:scenario:(satellite capsule)' \
  '--scenario=[scenario name]:scenario:(satellite capsule)' \
  '--upgrade[upgrade to next minor]' \
  '--migrations-only[only run db migrations]' \
  '--reset[full reset to defaults]' \
  '--detailed-exitcodes[exit with detailed status]' \
  '--no-colors[disable colored output]' \
  '--show-defaults[show default values in help]' \
  '--ignore-undocumented[ignore undocumented options]' \
  '--enable-*[enable a kafo puppet module]' \
  '--disable-*[disable a kafo puppet module]' \
  '*::module options:_files' && ret=0
return ret
