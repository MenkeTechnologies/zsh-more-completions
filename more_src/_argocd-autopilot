#compdef argocd-autopilot

# Zsh completion for argocd-autopilot - Argo CD app-of-apps bootstrapping

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_argocd_autopilot_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '--git-token[Git provider API token]:token:'
  '--repo[Repository URL]:url:'
  '--installation-path[Installation path within the repository]:path:'
  '--namespace[Target namespace]:namespace:'
  '--kubeconfig[Path to kubeconfig file]:file:_files'
  '--context[Kubernetes context to use]:context:'
  '--dest-server[Destination Kubernetes server URL]:url:'
  '--project[Project name]:project:'
)

_argocd_autopilot_repo_commands() {
  local -a commands
  commands=(
    'bootstrap:Bootstrap a new installation'
    'create:Create a new GitOps repository'
  )
  _describe -t commands 'repo commands' commands
}

_argocd_autopilot_project_commands() {
  local -a commands
  commands=(
    'create:Create a new project'
    'delete:Delete a project'
    'list:List all projects'
  )
  _describe -t commands 'project commands' commands
}

_argocd_autopilot_app_commands() {
  local -a commands
  commands=(
    'create:Create a new application'
    'delete:Delete an application'
    'list:List all applications'
  )
  _describe -t commands 'app commands' commands
}

_arguments -s -S -C \
  "${_argocd_autopilot_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'repo:Manage GitOps repositories'
      'project:Manage projects'
      'app:Manage applications'
      'version:Print version information'
      'completion:Generate shell completion script'
    )
    _describe -t commands 'argocd-autopilot commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      repo)
        _arguments -s -S -C \
          "${_argocd_autopilot_global_flags[@]}" \
          '1:subcommand:_argocd_autopilot_repo_commands' \
          '*::arg:->repo_args' && ret=0
        case "$state" in
          repo_args)
            case "${line[1]}" in
              bootstrap)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" \
                  '--app[Application specifier]:app spec:' \
                  '--dry-run[Perform a dry run]' \
                  '--hide-password[Hide password from logs]' \
                  '--provider[Git provider]:provider:(github gitlab bitbucket)' && ret=0
                ;;
              create)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" \
                  '--name[Repository name]:name:' \
                  '--host[Git host]:host:' \
                  '--owner[Repository owner]:owner:' \
                  '--provider[Git provider]:provider:(github gitlab bitbucket)' \
                  '--public[Create a public repository]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      project)
        _arguments -s -S -C \
          "${_argocd_autopilot_global_flags[@]}" \
          '1:subcommand:_argocd_autopilot_project_commands' \
          '*::arg:->project_args' && ret=0
        case "$state" in
          project_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" \
                  '1:project name:' \
                  '--dest-kube-context[Destination Kubernetes context]:context:' \
                  '--dry-run[Perform a dry run]' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" \
                  '1:project name:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      app)
        _arguments -s -S -C \
          "${_argocd_autopilot_global_flags[@]}" \
          '1:subcommand:_argocd_autopilot_app_commands' \
          '*::arg:->app_args' && ret=0
        case "$state" in
          app_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" \
                  '1:app name:' \
                  '--app[Application specifier]:app spec:' \
                  '--type[Application type]:type:(kustomize helm directory)' \
                  '--dest-namespace[Destination namespace]:namespace:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" \
                  '1:app name:' \
                  '--global[Delete from all projects]' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_argocd_autopilot_global_flags[@]}" && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      version)
        _arguments -s -S \
          "${_argocd_autopilot_global_flags[@]}" \
          '--short[Show short version]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          "${_argocd_autopilot_global_flags[@]}" \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
