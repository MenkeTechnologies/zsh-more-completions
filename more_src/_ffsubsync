#compdef ffsubsync

_arguments -s \
  '*-i[input subtitle]:file:_files -g "*.(srt|ass|ssa|vtt|sbv)"' \
  '--srtin=[input subtitle]:file:_files -g "*.(srt|ass|ssa|vtt|sbv)"' \
  '-o[output subtitle]:file:_files' \
  '--srtout=[output subtitle]:file:_files' \
  '--merge-with-reference[merge output with reference]' \
  '--merge[alias for --merge-with-reference]' \
  '--make-test-case[make test case]' \
  '--create-test-case[alias of --make-test-case]' \
  '(--reference-stream --refstream)'{--reference-stream,--refstream}'=[reference stream spec]:spec:' \
  '(- *)'{-v,--version}'[show version]' \
  '--overwrite-input[overwrite input file]' \
  '--encoding=[input encoding]:enc:' \
  '--max-subtitle-seconds=[max subtitle seconds]:s:' \
  '--start-seconds=[start seconds]:s:' \
  '--max-offset-seconds=[max offset seconds]:s:' \
  '--apply-offset-seconds=[apply offset seconds]:s:' \
  '--frame-rate=[frame rate]:fps:' \
  '--skip-infer-framerate-ratio[skip framerate inference]' \
  '--non-speech-label=[non-speech label]:label:' \
  '--output-encoding=[output encoding]:enc:' \
  '--reference-encoding=[reference encoding]:enc:' \
  '--vad=[VAD]:vad:(auditok webrtc silero)' \
  '--no-fix-framerate[do not fix frame rate]' \
  '--serialize-speech[serialize speech detection]' \
  '(--extract-subs-from-stream --extract-subtitles-from-stream)'{--extract-subs-from-stream,--extract-subtitles-from-stream}'=[stream spec]:spec:' \
  '--suppress-output-if-offset-less-than=[suppress threshold]:s:' \
  '(--ffmpeg-path --ffmpegpath)'{--ffmpeg-path,--ffmpegpath}'=[ffmpeg path]:path:_files' \
  '--log-dir-path=[log dir]:dir:_files -/' \
  '--gss[golden section search]' \
  '--strict[strict mode]' \
  '*:reference:_files'
