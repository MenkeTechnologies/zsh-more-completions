#compdef clawsker
# Documentation: https://manpages.debian.org/bookworm/clawsker/clawsker.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm clawsker(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL; generic stub.

# clawsker: Claws Mail hidden preferences editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-a --alternate-config-dir)'{-a,--alternate-config-dir=}'[alternate Claws config directory]:dir:_files -/' \
  '(-b --verbose)'{-b,--verbose}'[verbose output]' \
  '(-c --clawsrc)'{-c,--clawsrc=}'[Claws Mail config file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-i --ignore-versions)'{-i,--ignore-versions}'[ignore Claws Mail version check]' \
  '(-k --hide-disabled-keys)'{-k,--hide-disabled-keys}'[hide disabled keys instead of greying out]' \
  '(-r --read-only)'{-r,--read-only}'[disable saving changes]' \
  '(-s --small-screen)'{-s,--small-screen}'[use a smaller main window]' \
  '(-u --use-claws-version)'{-u,--use-claws-version=}'[force a specific Claws Mail version]:version:' \
  '(-v --version)'{-v,--version}'[show version and exit]' && ret=0
return ret
