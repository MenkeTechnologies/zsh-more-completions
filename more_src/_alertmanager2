#compdef alertmanager2
# _alertmanager2 — Prometheus alertmanager2 CLI command-line frontend wrapping the Alertmanager Prometheus alert handler dedup-grouping-routing-silencing-inhibition routing-tree receivers email slack pagerduty opsgenie wechat webhook pushover victorops telegram discord matrix mesh-gossip-clustering high-availability federation Prometheus-Server-Rule-Evaluator (Prometheus CNCF team, Go); kingpin
# upstream: https://prometheus.io/docs/alerting/latest/alertmanager/

_alertmanager2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--config.file=+[file]:file:_files -g "alertmanager.yml *.yml *.yaml"' \
        '--storage.path=+[dir]:dir:_files -/' \
        '--data.retention=+[d]:str:' \
        '--alerts.gc-interval=+[d]:str:' \
        '--web.external-url=+[url]:str:' \
        '--web.route-prefix=+[path]:str:' \
        '--web.listen-address=+[host:port]:_hosts' \
        '--web.config.file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--web.get-concurrency=+[N]:n:' \
        '--web.timeout=+[d]:str:' \
        '--cluster.listen-address=+[host:port]:_hosts' \
        '--cluster.advertise-address=+[host:port]:_hosts' \
        '--cluster.peer=+[host:port]:_hosts' \
        '--cluster.peer-timeout=+[d]:str:' \
        '--cluster.gossip-interval=+[d]:str:' \
        '--cluster.pushpull-interval=+[d]:str:' \
        '--cluster.tcp-timeout=+[d]:str:' \
        '--cluster.probe-timeout=+[d]:str:' \
        '--cluster.probe-interval=+[d]:str:' \
        '--cluster.settle-timeout=+[d]:str:' \
        '--cluster.reconnect-interval=+[d]:str:' \
        '--cluster.reconnect-timeout=+[d]:str:' \
        '--cluster.tls-config=+[file]:file:_files -g "*.yml *.yaml"' \
        '--cluster.allow-insecure-public-advertise-address-discovery[allow insecure]' \
        '--feature=+[name]:str:' \
        '--log.level=+[level]:l:(debug info warn error)' \
        '--log.format=+[fmt]:f:(logfmt json)' \
        '*:args:'
}

_alertmanager2 "$@"
