#compdef csharpier dotnet-csharpier
# Documentation: https://csharpier.com/docs/CLI
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for csharpier - opinionated C# code formatter
# Modern csharpier is subcommand-based: format, check, server, pipe-files.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show CSharpier version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'format:format C# files'
      'check:check formatting without modifying files'
      'server:run an HTTP server for IDE plugins'
      'pipe-files:long-lived mode reading filenames from stdin'
    )
    _describe -t commands 'csharpier command' commands && ret=0
    ;;
  args)
    local -a shared=(
      '(-h --help)'{-h,--help}'[show help]'
      '--config-path=[path to config file]:file:_files'
      '--log-format=[log format]:format:(Console MsBuild)'
      '--log-level=[log level]:level:(None Error Warning Information Debug)'
    )
    case $words[1] in
      format)
        _arguments -s -S \
          "$shared[@]" \
          '--ignore-path=[ignore file path]:file:_files' \
          '--stdin-path=[path used when reading from stdin]:path:_files' \
          '--no-cache[bypass formatting cache]' \
          '--include-generated[format generated files]' \
          '--skip-validation[skip syntax tree validation]' \
          '--write-stdout[write formatted output to stdout]' \
          '--no-msbuild-check[do not validate csproj references]' \
          '--skip-write[skip writing changes to disk]' \
          '--compilation-errors-as-warnings[treat compilation errors as warnings]' \
          '*:file or directory:_files' && ret=0
        ;;
      check)
        _arguments -s -S \
          "$shared[@]" \
          '--unformatted-as-warnings[report unformatted files as warnings]' \
          '--include-generated[check generated files]' \
          '--no-msbuild-check[do not validate csproj references]' \
          '--compilation-errors-as-warnings[treat compilation errors as warnings]' \
          '*:file or directory:_files' && ret=0
        ;;
      server)
        _arguments -s -S \
          "$shared[@]" \
          '--server-port=[server port (random if unset)]:port:' && ret=0
        ;;
      pipe-files)
        _arguments -s -S "$shared[@]" && ret=0
        ;;
    esac
    ;;
esac

return ret
