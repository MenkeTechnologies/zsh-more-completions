#compdef csharpier dotnet-csharpier

# Zsh completion for csharpier - opinionated C# code formatter

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show CSharpier version]'
  '--check[check formatting without modifying files]'
  '--fast[skip cache and other performance optimizations]'
  '--skip-write[skip writing changes to disk]'
  '--write-stdout[write formatted output to stdout]'
  '--pipe-multiple-files[run in long-lived mode reading filenames from stdin]'
  '(-c --config-path)'{-c,--config-path}'[path to .csharpierrc config file]:file:_files'
  '--no-cache[do not use the cache]'
  '--no-msbuild-check[do not validate csproj references]'
  '--include-generated[format generated files]'
  '--compilation-error-as-warning[treat compilation errors as warnings]'
  '--log-level[log level]:level:(None Error Warning Information Debug)'
  '*:file or directory:_files'
)

_arguments -s $arguments
