#compdef ve volc

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'configure:manage profiles and credentials'
  'sso:SSO operations'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
  'ecs:Elastic Compute Service'
  'vpc:Virtual Private Cloud'
  'clb:Cloud Load Balancer'
  'rds_mysql:RDS MySQL'
  'rds_mssql:RDS SQL Server'
  'rds_postgresql:RDS PostgreSQL'
  'redis:Redis'
  'mongodb:MongoDB'
  'tos:Tinder Object Storage'
  'ebs:Elastic Block Storage'
  'vpn:VPN Gateway'
  'natgateway:NAT Gateway'
  'transitrouter:Transit Router'
  'iam:Identity and Access Management'
  'cdn:CDN'
  'dns:DNS'
  'kms:Key Management Service'
  'certificate_service:Certificate Service'
  'cr:Container Registry'
  'vke:Volcengine Kubernetes Engine'
  'vefaas:Function-as-a-Service'
  'billing:Billing'
  'organization:Organization'
  'monitor_service:Monitor Service'
  'log_service:Log Service'
  'dts:Data Transmission Service'
  'vedb_mysql:veDB MySQL'
  'escloud:Elasticsearch Cloud'
  'cloud_monitor:Cloud Monitor'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 've service' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (configure)
        _values 'configure action' \
          'set' 'get' 'list' 'delete' 'profile' 'sso-session' 'sso' && ret=0
        ;;
      (sso)
        _values 'sso action' 'login' 'logout' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
