#compdef xbps-remove
# Documentation: https://man.voidlinux.org/xbps-remove.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config)'{-C,--config}'+[path to XBPS configuration directory]:dir:_directories' \
  '(-c --cachedir)'{-c,--cachedir}'+[path to cache directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-F --force-revdeps)'{-F,--force-revdeps}'[force removal even with reverse deps (DANGEROUS)]' \
  '(-f --force)'{-f,--force}'[force removal of modified files]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run, show actions only]' \
  '(-O --clean-cache)'{-O,--clean-cache}'[remove outdated cached packages]' \
  '(-o --remove-orphans)'{-o,--remove-orphans}'[remove orphan packages]' \
  '(-R --recursive)'{-R,--recursive}'[recursively remove unused dependencies]' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '(-y --yes)'{-y,--yes}'[assume yes to all questions]' \
  '*:package: ' && ret=0

return ret
