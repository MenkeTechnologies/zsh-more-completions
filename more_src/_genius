#compdef genius
# GNOME Genius Mathematics Tool

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--exec=[execute expression]:expression:' \
  '--exec-file=[execute commands from file]:file:_files -g "*.gel"' \
  '-e[execute expression]:expression:' \
  '--no-rc[do not load RC file]' \
  '--no-plugins[do not load plugins]' \
  '-i[interactive mode]' \
  '-q[quiet mode]' \
  '--precision=[set floating point precision]:bits:' \
  '--maxdigits=[set max digits for display]:digits:' \
  '*:file:_files -g "*.gel"' && ret=0

return ret
