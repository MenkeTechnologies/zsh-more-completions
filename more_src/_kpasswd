#compdef kpasswd
# Documentation: https://man.archlinux.org/search?q=kpasswd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-?[Display help]'
    '--help[Display help]'
    '--usage[Display usage]'
    '-c[Cache name]:cache name:_files'
    '--cache=[Cache name]:cache name:_files'
    '--admin-server=[Admin server to contact]:server'
    '*:principal'
)

_arguments -s -S $arguments
