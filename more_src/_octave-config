#compdef octave-config
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/octave-config.1.html
# report installation paths and configuration variables for Octave

local ret=1

_arguments -s -S \
  '--m-site-dir[display main directory for site-specific .m files]' \
  '--oct-site-dir[display main directory for site-specific .oct libraries]' \
  '(-p --print)'{-p,--print}'[print default value of an Octave config variable]:var:(API_VERSION BINDIR DATADIR LIBDIR PREFIX VERSION)' \
  '(-v --version)'{-v,--version}'[display the version number of octave]' \
  '(-h -? --help)'{-h,--help}'[print help message]' && ret=0

return ret
