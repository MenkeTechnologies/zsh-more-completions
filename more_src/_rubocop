#compdef rubocop

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-V,--verbose-version}'[show verbose version info]' \
  '(-l --lint)'{-l,--lint}'[run only Lint cops]' \
  '(-x --fix-layout)'{-x,--fix-layout}'[run only Layout cops]' \
  '--safe[run only safe cops]' \
  '--only-guide-cops[run only style-guide cops]' \
  '--only=[run only listed cops]:cops:' \
  '--except=[exclude listed cops]:cops:' \
  '(-F --fail-fast)'{-F,--fail-fast}'[abort on first offense]' \
  '--disable-pending-cops[disable pending cops]' \
  '--enable-pending-cops[enable pending cops]' \
  '--ignore-disable-comments[ignore rubocop:disable comments]' \
  '--force-exclusion[force file exclusions]' \
  '--only-recognized-file-types[skip unrecognized file types]' \
  '--ignore-parent-exclusion[ignore parent exclusion]' \
  '--ignore-unrecognized-cops[ignore unrecognized cops]' \
  '--force-default-config[use default config]' \
  '(-s --stdin)'{-s,--stdin=}'[lint stdin treating as filename]:filename:' \
  '--editor-mode[editor integration mode]' \
  '(-P --parallel)'{-P,--parallel}'[run in parallel]' \
  '--no-parallel[disable parallel]' \
  '--raise-cop-error[raise on cop error]' \
  '(-f --format)'{-f,--format=}'[formatter]:fmt:(progress simple clang fuubar emacs json html files offenses worst tap quiet github junit markdown pacman)' \
  '(-D --display-cop-names)'{-D,--display-cop-names}'[show cop names]' \
  '--no-display-cop-names[hide cop names]' \
  '(-E --extra-details)'{-E,--extra-details}'[show extra details]' \
  '(-S --display-style-guide)'{-S,--display-style-guide}'[show style guide URL]' \
  '(-o --out)'{-o,--out=}'[output file]:file:_files' \
  '--stderr[write to stderr]' \
  '--display-time[show time taken]' \
  '--display-only-failed[show only failed cops]' \
  '--display-only-fail-level-offenses[show only fail-level offenses]' \
  '--display-only-correctable[show only correctable offenses]' \
  '--display-only-safe-correctable[show only safe-correctable offenses]' \
  '--color[force color]' \
  '--no-color[disable color]' \
  '(-a --autocorrect)'{-a,--autocorrect,--auto-correct}'[autocorrect (safe)]' \
  '--safe-auto-correct[autocorrect (safe; deprecated alias)]' \
  '(-A --autocorrect-all)'{-A,--autocorrect-all,--auto-correct-all}'[autocorrect including unsafe]' \
  '--disable-uncorrectable[insert disable comments for uncorrectable]' \
  '--auto-gen-config[generate .rubocop_todo.yml]' \
  '--regenerate-todo[regenerate .rubocop_todo.yml]' \
  '--exclude-limit=[exclude-limit count]:n:' \
  '--no-exclude-limit[no exclude limit]' \
  '--offense-counts[include offense counts]' \
  '--no-offense-counts[no offense counts]' \
  '--auto-gen-only-exclude[only emit Exclude in todo]' \
  '--no-auto-gen-only-exclude[disable]' \
  '--auto-gen-timestamp[include timestamp]' \
  '--no-auto-gen-timestamp[no timestamp]' \
  '--auto-gen-enforced-style[emit EnforcedStyle]' \
  '--no-auto-gen-enforced-style[disable]' \
  '--fail-level=[fail level]:level:(info refactor convention warning error fatal autocorrect)' \
  '(-C --cache)'{-C,--cache=}'[enable cache]:flag:(true false)' \
  '--cache-root=[cache directory]:dir:_files -/' \
  '--lsp[run as LSP server]' \
  '--mcp[run as MCP server]' \
  '--server[run server]' \
  '--no-server[disable server]' \
  '--restart-server[restart server]' \
  '--start-server[start server]' \
  '--stop-server[stop server]' \
  '--server-status[show server status]' \
  '--no-detach[do not detach server]' \
  '(-L --list-target-files)'{-L,--list-target-files}'[list target files]' \
  '--list-enabled-cops-for=[list enabled cops for path]:path:_files' \
  '--show-cops=[show details of cops]:cops:' \
  '--show-docs-url=[show docs URL for cops]:cops:' \
  '--init[initialize a config]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.yml"' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '*--plugin=[plugin file]:file:_files' \
  '*'{-r,--require=}'[require file]:file:_files' \
  '--profile[profile execution]' \
  '--memory[show memory usage]' \
  '*:file:_files'
