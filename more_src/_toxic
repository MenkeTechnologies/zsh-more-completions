#compdef toxic
# Documentation: https://manpages.debian.org/bookworm/toxic/toxic.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm toxic(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL; generic stub.

# toxic: ncurses-based Tox client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-4 --ipv4)'{-4,--ipv4}'[force IPv4 connection]' \
  '(-b --debug)'{-b,--debug}'[enable stderr debugging]' \
  '(-c --config)'{-c+,--config=}'[alternate config file]:file:_files' \
  '(-d --default-locale)'{-d,--default-locale}'[use default locale]' \
  '(-e --encrypt-data)'{-e,--encrypt-data}'[encrypt an unencrypted data file]' \
  '(-f --file)'{-f+,--file=}'[alternate Tox profile data file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --logging)'{-l,--logging}'[enable toxcore stderr logging]' \
  '(-n --nodes)'{-n+,--nodes=}'[alternate DHT bootstrap nodes file]:file:_files' \
  '(-o --noconnect)'{-o,--noconnect}'[do not connect to DHT network]' \
  '(-p --SOCKS5-proxy)'{-p+,--SOCKS5-proxy=}'[SOCKS5 proxy IP+port]:proxy:' \
  '(-P --HTTP-proxy)'{-P+,--HTTP-proxy=}'[HTTP proxy IP+port]:proxy:' \
  '(-r --namelist)'{-r+,--namelist=}'[alternate nameservers list]:file:_files' \
  '(-t --force-tcp)'{-t,--force-tcp}'[force TCP connection]' \
  '(-T --tcp-relay)'{-T,--tcp-relay}'[act as TCP relay server]' \
  '(-u --unencrypt-data)'{-u,--unencrypt-data}'[unencrypt a data file]' && ret=0
return ret
