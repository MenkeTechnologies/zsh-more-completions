#compdef gatherheaderdoc
# Documentation: https://man.archlinux.org/search?q=gatherheaderdoc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[gather toplevel category]:category:' \
  '-t+[title]:title:' \
  '-x[do not include external groups]' \
  '-N[do not link to xref docs]' \
  '-d[debug]' \
  '-n[no-op mode]' \
  '-w[suppress warnings]' \
  '*:directory:_files -/' && ret=0

return ret
