#compdef gatherheaderdoc
# Documentation: https://keith.github.io/xcode-man-pages/gatherheaderdoc.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gatherheaderdoc: postprocess HeaderDoc output to create an index TOC page (Apple Xcode).
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-H[include htmlHeader from config file]' \
  '-X[output XML instead of HTML]' \
  '-d[debug]' \
  '*:directory:_files -/' && ret=0

return ret
