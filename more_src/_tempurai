#compdef tempurai coder
# Documentation: https://github.com/tempurai/coder
# Reference accessed: 2026-05-22
# Verified: package.json bin and README usage (tempurai / @tempurai/coder).

# Zsh completion for tempurai - Tempurai multi-agent coding assistant TUI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:task or prompt:' && ret=0

return ret
