#compdef retdec-decompiler retdec-fileinfo retdec-unpacker retdec-archive-decompiler
# Documentation: source-direct extraction from upstream
# avast/retdec
#   - src/retdec-decompiler/retdec-decompiler.cpp `isParam(i, ...)`
#     argv-walking pairs.  Enum values for -m/--mode (bin|raw),
#     -a/--arch (mips|pic32|arm|thumb|arm64|powerpc|x86|x86-64),
#     -e/--endian (little|big), -f/--output-format
#     (plain|json|json-human) decoded from the if/throw chains
#     in the parser.
#   - scripts/retdec-fileinfo.py + scripts/retdec-unpacker.py +
#     scripts/retdec-archive-decompiler.py argparse
#     `parser.add_argument(...)` declarations.
# Reference accessed: 2026-05-30 via gh api.
# avast retdec R160b — 4-stem multi-binary harvest of the
# retdec retargetable-decompiler user-facing CLI suite:
# retdec-decompiler (C++ main binary), retdec-fileinfo (YARA
# pattern + archive-aware fileinfo wrapper), retdec-unpacker
# (generic + upx unpacker driver), retdec-archive-decompiler
# (static-archive batch decompiler).  Sister to the heavily
# covered reverse-engineering family in the corpus (radare2 +
# r2pm + rasm2 + rabin2 + rax2 + rahash2 + ragg2 + radiff2 +
# ghidra + binwalk + yara + yarac + angr + honggfuzz).

case $service in

  retdec-decompiler)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '--print-after-all[print module after each pass]' \
      '--print-before-all[print module before each pass]' \
      '(-m --mode)'{-m+,--mode=}'[input mode]:mode:(bin raw)' \
      '(-b --bit-size)'{-b+,--bit-size=}'[bit size (16|32|64)]:bits:(16 32 64)' \
      '(-a --arch)'{-a+,--arch=}'[target architecture]:arch:(mips pic32 arm thumb arm64 powerpc x86 x86-64)' \
      '(-e --endian)'{-e+,--endian=}'[endianness]:endian:(little big)' \
      '(-f --output-format)'{-f+,--output-format=}'[output format]:fmt:(plain json json-human)' \
      '--max-memory=[set maximum memory in bytes]:bytes:' \
      '--no-memory-limit[disable the maximum-memory limit]' \
      '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
      '(-k --keep-unreachable-funcs)'{-k,--keep-unreachable-funcs}'[keep unreachable functions in the output]' \
      '(-p --pdb)'{-p+,--pdb=}'[PDB debug info file]:pdb:_files' \
      '--select-ranges=[comma-separated VA ranges to decompile]:ranges:' \
      '--select-functions=[comma-separated functions to decompile]:funcs:' \
      '--select-decode-only[only decode, do not decompile, the selection]' \
      '--raw-section-vma=[raw mode: section VMA]:addr:' \
      '--raw-entry-point=[raw mode: entry-point address]:addr:' \
      '--cleanup[clean temp files when done]' \
      '--config=[input config JSON]:file:_files -g "*.json"' \
      '--disable-static-code-detection[skip static-code-detection pass]' \
      '--backend-disabled-opts=[comma-separated backend opts to disable]:opts:' \
      '--backend-enabled-opts=[comma-separated backend opts to enable]:opts:' \
      '--backend-call-info-obtainer=[backend call-info obtainer]:name:' \
      '--backend-var-renamer=[backend variable renamer]:name:' \
      '--backend-no-opts[disable backend optimizations]' \
      '--backend-emit-cfg[backend: emit CFGs to .dot]' \
      '--backend-emit-cg[backend: emit call graph to .dot]' \
      '--backend-keep-all-brackets[backend: keep all brackets]' \
      '--backend-keep-library-funcs[backend: keep library functions in output]' \
      '--backend-no-time-varying-info[backend: do not use time-varying info]' \
      '--backend-no-var-renaming[backend: do not rename variables]' \
      '--backend-no-compound-operators[backend: avoid compound operators (+=, ++ etc.)]' \
      '--backend-no-symbolic-names[backend: do not emit symbolic constant names]' \
      '--ar-index=[decompile object at given index from archive]:n:' \
      '--ar-name=[decompile object with given name from archive]:name:' \
      '--static-code-sigfile=[additional static-code signature file]:file:_files' \
      '--timeout=[decompilation timeout in seconds]:sec:' \
      '(-s --silent)'{-s,--silent}'[silent: no progress / non-error stderr]' \
      '1:input binary file:_files'
    ;;

  retdec-fileinfo)
    _arguments -s -S \
      '(-j --json)'{-j,--json}'[forward --json to the archive decompiler when fileinfo target is an archive]' \
      '--use-external-patterns[use external YARA patterns from signsrch]' \
      '*:fileinfo passthrough args:_files'
    ;;

  retdec-unpacker)
    _arguments -s -S \
      '(-e --extended-exit-codes)'{-e,--extended-exit-codes}'[use more granular exit codes than just 0/1]' \
      '(-o --output)'{-o+,--output=}'[output file (default: <input>-unpacked)]:file:_files' \
      '--max-memory=[limit max memory in bytes]:bytes:' \
      '--max-memory-half-ram[limit max memory to half of system RAM]' \
      '1:packed binary file:_files'
    ;;

  retdec-archive-decompiler)
    _arguments -s -S \
      '--plain[print list of archive members in plain text]' \
      '--json[print list of archive members in JSON]' \
      '--list[list archive members instead of decompiling]' \
      '1:archive file (.a|.lib):_files -g "*.(a|lib)"' \
      '*:arguments after -- are forwarded to retdec-decompiler:'
    ;;

esac
