#compdef hpack
# Documentation: https://github.com/sol/hpack
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--numeric-version[show numeric version]' \
  '--silent[suppress output]' \
  '--canonical[ignore existing .cabal formatting]' \
  '(-f --force)'{-f,--force}'[force generation of .cabal file]' \
  '--hash[include SHA-256 hash in generated .cabal]' \
  '--no-hash[exclude hash]' \
  '*:package.yaml file:_files -g "*.yaml"' && ret=0

return ret
