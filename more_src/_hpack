#compdef hpack

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--silent[suppress output]' \
  '--force[overwrite existing .cabal file]' \
  '-f[overwrite existing .cabal file]' \
  '--hash[include hash in generated .cabal file]' \
  '--todir=[output directory]:directory:_directories' \
  '*:package.yaml files:_files -g "package.yaml"' && ret=0

return ret
