#compdef pasmo

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-v[verbose]' \
  '-d[debug output]' \
  '--bin[binary output]' \
  '--prl[CP/M PRL output]' \
  '--cmd[CP/M-86 CMD]' \
  '--plus3dos[+3DOS header]' \
  '--tap[TAP file]' \
  '--tzx[TZX file]' \
  '--cdt[CDT file]' \
  '--cdtbas[CDT BASIC]' \
  '--amsdos[Amsdos AMSDOS]' \
  '--hex[Intel HEX]' \
  '--mlz[ZX81 MLZ]' \
  '--name=[program name]:name:' \
  '--include=[include dir]:dir:_files -/' \
  '-I+[include dir]:dir:_files -/' \
  '-D+[define symbol]:macro:' \
  '-o+[output file]:file:_files' \
  '--equ=[set symbol]:s:' \
  '--public=[public symbols]:list:' \
  '--err+[error messages]:f:(simple plain quoted)' \
  '--alocal[allow local labels]' \
  '--nocase[no case sensitive]' \
  '--w8080[80x86]' \
  '--listing+[list file]:file:_files' \
  '--symbol+[symbol file]:file:_files' \
  '*: :_files -g "*.asm *.s *.z80"' && ret=0

return ret
