#compdef uncompyle6
# Documentation: https://github.com/rocky/python-uncompyle6
# uncompyle6 - Python bytecode decompiler

local ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'=[write decompiled output to path]:output:_files' \
  '(-r --recurse)'{-r,--recurse}'[recursively search directories for .pyc/.pyo]' \
  '(-a --asm)'{-a,--asm}'[include byte-code in output]' \
  '(-A --asm++)'{-A,--asm++}'[show xdis and tokenized assembler output]' \
  '(-g --grammar)'{-g,--grammar}'[show matching grammar rules]' \
  '(-t --tree)'{-t,--tree}'[show syntax tree]' \
  '(-T --tree++)'{-T,--tree++}'[show parse tree and AST]' \
  '--linemaps[show bytecode-to-source line correspondences]' \
  '--verify=[verification method]:method:(run syntax)' \
  '--start-offset=[start decompilation at offset]:offset' \
  '--stop-offset=[stop decompilation at offset]:offset' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
