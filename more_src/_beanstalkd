#compdef beanstalkd
# Documentation: https://github.com/beanstalkd/beanstalkd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-b+[write-ahead log directory]:directory:_directories' \
  '-f+[fsync interval in milliseconds]:ms' \
  '-F[never fsync]' \
  '-l+[listen address]:address' \
  '-p+[listen port]:port' \
  '-u+[run as user]:user:_users' \
  '-z+[maximum job size in bytes]:bytes' \
  '-s+[maximum write-ahead log file size]:bytes' \
  '-c[legacy flag, no effect]' \
  '-n[legacy flag, no effect]' \
  '*-V[increase verbosity]'
