#compdef cobaya-bib
# Documentation: https://cobaya.readthedocs.io/en/latest/cosmo_basic_runs.html
# cobaya: generate bibtex references for components in an input file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:input file or component:_files -g "*.yaml"' && ret=0

return ret
