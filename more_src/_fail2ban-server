#compdef fail2ban-server

# Zsh completion for fail2ban-server - fail2ban server daemon

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[configuration directory]:directory:_directories' \
  '-s[socket path]:socket file:_files' \
  '-p[pid file]:pid file:_files' \
  '-x[force execution of server]' \
  '-b[start in background]' \
  '-f[start in foreground]' \
  '-t[test configuration and exit]' \
  '*-v[increase verbosity]' \
  '-d[dump configuration and exit]' \
  '--loglevel=[log level]:level:(CRITICAL ERROR WARNING NOTICE INFO DEBUG TRACEDEBUG HEAVYDEBUG)' \
  '--logtarget=[log target]:target:_alternative "builtins:builtin target:(STDOUT STDERR SYSLOG SYSOUT)" "files:log file:_files"' \
  '--syslogsocket=[syslog socket]:socket:_alternative "builtins:builtin socket:(auto)" "files:socket file:_files"' \
  '--async[start server asynchronously]' \
  '--timeout=[timeout for async wait]:seconds'
