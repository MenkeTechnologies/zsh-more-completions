#compdef lxqt-config-file-associations
# Documentation: https://github.com/lxqt/lxqt-config/tree/master/lxqt-config-file-associations
# Reference accessed: 2026-05-19
# Verified: upstream main.cpp uses QCommandLineParser without custom
# options — only inherited QApplication flags apply.

# lxqt-config-file-associations: configure MIME type handlers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--style=[Qt GUI style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '--platform=[Qt platform plugin]:platform:' \
  '--platformpluginpath=[Qt plugin path]:dir:_files -/' \
  '--display=[X display]:display:' \
  '--reverse[reverse layout direction]' \
  '*::lxqt-config-file-associations args:_files' && ret=0
return ret
