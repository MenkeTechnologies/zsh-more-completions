#compdef plot-vcfstats
# Documentation: https://github.com/samtools/bcftools/blob/develop/misc/plot-vcfstats
# plot the output of bcftools stats

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[show help]' \
  '(-m --merge)'{-m,--merge}'[merge vcfstats files to STDOUT, skip plotting]' \
  '(-p --prefix)'{-p,--prefix}'+[output directory]:dir:_files -/' \
  '(-P --no-PDF)'{-P,--no-PDF}'[skip the PDF creation step]' \
  '(-r --rasterize -v --vectors)'{-r,--rasterize}'[rasterize PDF images for fast rendering]' \
  '(-s --sample-names)'{-s,--sample-names}'[use sample names for xticks rather than numeric IDs]' \
  '*'{-t,--title}'+[identify files by these titles in plots]:title' \
  '(-T --main-title)'{-T,--main-title}'+[main title for the PDF]:title' \
  '(-v --vectors -r --rasterize)'{-v,--vectors}'[generate vector graphics for PDF images]' \
  '*:vcfstats file:_files' && ret=0

return ret
