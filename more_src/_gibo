#compdef gibo
# Documentation: https://man.archlinux.org/search?q=gibo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  dump:'print boilerplate .gitignore snippets'
  list:'list boilerplate names'
  search:'search boilerplate names'
  update:'refresh cached gitignore repo'
  version:'print gibo version'
  root:'print local boilerplate cache directory'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'gibo' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dump) _arguments '*:boilerplate names: _default' && ret=0 ;;
      (search) _arguments '1:search substring: _default' && ret=0 ;;
      (list|update|version|root) ;;
      (*) ;;
    esac
    ;;
esac

return ret
