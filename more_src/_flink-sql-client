#compdef flink-sql-client
# Documentation: https://nightlies.apache.org/flink/flink-docs-stable/docs/dev/table/sqlclient/
# Flink SQL Client (embedded or gateway mode)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '1:mode:(embedded gateway)' \
  '(-e --endpoint)'{-e,--endpoint}'[remote SQL Gateway address host:port or URL]:endpoint' \
  '(-f --file)'{-f,--file}'[execute SQL script file non-interactively]:file:_files' \
  '(-i --init)'{-i,--init}'[initialize session from SQL file]:file:_files' \
  '(-hist --history)'{-hist,--history}'[file to save command history]:file:_files' \
  '(-s --session)'{-s,--session}'[session identifier]:session' \
  '*'{-j,--jar}'[import a JAR file]:jar:_files -g "*.jar"' \
  '*'{-l,--library}'[import a directory of JAR files]:dir:_files -/' \
  '*-D[set a session dynamic config key=value]:property' \
  '(-pyarch --pyArchives)'{-pyarch,--pyArchives}'[add Python archive files for the job]:archives' \
  '(-pyexec --pyExecutable)'{-pyexec,--pyExecutable}'[Python interpreter for the UDF worker]:path:_files' \
  '(-pyclientexec --pyClientExecutable)'{-pyclientexec,--pyClientExecutable}'[Python interpreter path for the client]:path:_files' \
  '(-pyfs --pyFiles)'{-pyfs,--pyFiles}'[attach custom Python files]:files:_files' \
  '(-pyreq --pyRequirements)'{-pyreq,--pyRequirements}'[Python requirements.txt with dependencies]:file:_files' && ret=0

return ret
