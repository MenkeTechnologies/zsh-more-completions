#compdef ncls
# Documentation: https://www.mankier.com/1/ncls
# ncls - an ls that displays multimedia in the terminal with Notcurses

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '-d[list directories themselves, not their contents]' \
  '-l[use a long listing format]' \
  '-L[dereference symbolic links]' \
  '-R[list subdirectories recursively]' \
  '(-a --align)'{-a,--align}'[align images]:type:(left center right)' \
  '(-b --blitter)'{-b,--blitter}'[blitter to use]:blitter:(ascii half quad sex braille pixel)' \
  '(-s --scale)'{-s,--scale}'[scaling mode]:scalemode:(none hires scale scalehi stretch)' \
  '*:path:_files' && ret=0

return ret
