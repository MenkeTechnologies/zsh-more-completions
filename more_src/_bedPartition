#compdef bedPartition
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# split BED ranges into non-overlapping ranges for cluster jobs

local ret=1

_arguments -s -S \
  '-verbose=[verbosity level]:level:' \
  '-minPartitionItems=[minimum items per partition]:n:' \
  '-partMergeDist=[merge distance between partitions]:n:' \
  '-parallel=[number of parallel jobs]:n:' \
  '*:bedFile rangesBed:_files' && ret=0

return ret
