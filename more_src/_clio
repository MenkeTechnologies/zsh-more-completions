#compdef clio
# Documentation: https://github.com/iowarp/clio-agent
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# CLIO launcher + server lifecycle manager (iowarp/clio-agent).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the server (no TUI)'
  'stop:stop the server'
  'restart:stop then start'
  'status:show PID, port, and health'
  'ps:show PID, port, and health (alias)'
  'logs:tail the server and gact stderr logs'
  'doctor:check prerequisites and install layout'
  'report:print a diagnostics bundle for GitHub issues'
  'completion:print shell completion script'
  'uninstall:run the uninstaller'
  'attach:ensure server is up then attach the TUI'
  'help:show help text'
)

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'clio command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (completion)
        _values 'shell' bash zsh && ret=0
        ;;
      (logs)
        _message -e 'number of lines' && ret=0
        ;;
    esac
    ;;
esac

return ret
