#compdef point2grid
# Documentation: https://metplus.readthedocs.io/projects/met/en/latest/Users_Guide/reformat_point.html
# point2grid - MET tool to regrid point observations to a grid

local ret=1

_arguments -s \
  '*-field[data to be regridded]:field:' \
  '-config[configuration file]:file:_files' \
  '-goes_qc[comma-separated QC flag values for GOES data]:flags:' \
  '-adp[Aerosol Detection Product file for dust/smoke filtering]:file:_files' \
  '-method[regridding method]:method:(MIN MAX MEDIAN UW_MEAN DW_MEAN AW_MEAN GAUSSIAN MAXGAUSS)' \
  '-gaussian_dx[distance interval for Gaussian smoothing]:dx:' \
  '-gaussian_radius[radius of influence for Gaussian interpolation]:radius:' \
  '-prob_cat_thresh[threshold for computing probability of occurrence]:thresh:' \
  '-vld_thresh[required ratio of valid data for regridding]:thresh:' \
  '-name[comma-separated output variable names]:names:' \
  '-log[direct output and errors to log file]:file:_files' \
  '-v[verbosity level]:level:' \
  '-compress[NetCDF compression level (0-9)]:level:' \
  '*:file:_files' && ret=0

return ret
