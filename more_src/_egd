#compdef egd
# Documentation: https://man.archlinux.org/search?q=egd
# Reference accessed: 2026-05-16

# egd: Entropy Gathering Daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-b[bind path]:path:_files' \
  '-w[wait for connections]' \
  '-d[daemonize]' \
  '*::egd args:_files' && ret=0
return ret
