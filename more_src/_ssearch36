#compdef ssearch36
# Documentation: https://manpages.debian.org/testing/fasta3/fasta36.1.en.html
# Smith-Waterman protein/DNA sequence comparison

local ret=1

_arguments -s -S \
  '-b+[number of best scores/descriptions to show]:count:' \
  '-d+[number of best alignments to show]:count:' \
  '-E+[expectation value upper limit for display]:evalue:' \
  '-F+[expectation value lower limit for display]:evalue:' \
  '-H[do not show histogram]' \
  '-m+[alignment display options (formats 0-11, B, BB)]:format:' \
  '-O+[send output to file]:file:_files' \
  '-s+[specify substitution matrix (e.g. BLOSUM50, PAM250)]:matrix:' \
  '-T+[number of threads or workers to use]:threads:' \
  '-w+[line width for output]:width:' \
  '-z+[specify the statistical calculation]:method:' \
  '1:query file:_files' \
  '2:library file:_files' \
  '3:ktup:' && ret=0

return ret
