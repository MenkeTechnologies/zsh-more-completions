#compdef flex-cli
# _flex-cli — Vern Paxson flex fast lexical analyzer generator CLI alias (westes team, C); custom argparse
# upstream: https://github.com/westes/flex

_flex-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[generate backing up info]' \
        '--backup[generate backing up info]' \
        '-c[do nothing (POSIX compat)]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f[full DFA]' \
        '--full[full DFA]' \
        '-F[fast]' \
        '--fast[fast]' \
        '-i[case insensitive]' \
        '--case-insensitive[case insensitive]' \
        '-l[POSIX/AT&T compatibility]' \
        '--lex-compat[POSIX/AT&T compatibility]' \
        '-n[no -n option]' \
        '-p[generate performance report]' \
        '--perf-report[generate performance report]' \
        '-s[suppress default rule]' \
        '--nodefault[suppress default rule]' \
        '-t[write generated scanner to stdout]' \
        '--stdout[write generated scanner to stdout]' \
        '-v[show stats]' \
        '--verbose[show stats]' \
        '-w[do not warn]' \
        '--nowarn[do not warn]' \
        '+x[no warnings]' \
        '-X[trace mode]' \
        '--trace[trace mode]' \
        '-7[7-bit chars]' \
        '--7bit[7-bit chars]' \
        '-8[8-bit chars]' \
        '--8bit[8-bit chars]' \
        '-B[batch scanner]' \
        '--batch[batch scanner]' \
        '-I[interactive scanner]' \
        '--interactive[interactive scanner]' \
        '-Ce[equiv classes]' \
        '-Cf[full table]' \
        '-CF[full table no compress]' \
        '-Cm[meta-equivalence classes]' \
        '-Cr[do not use read]' \
        '-o+[output file]:file:_files' \
        '--outfile=+[output file]:file:_files' \
        '-P+[prefix]:str:' \
        '--prefix=+[prefix]:str:' \
        '-S+[skeleton file]:file:_files' \
        '--skel=+[skeleton file]:file:_files' \
        '-T[trace mode]' \
        '--c++[c++]' \
        '+[c++]' \
        '--reentrant[reentrant scanner]' \
        '-R[reentrant scanner]' \
        '--bison-bridge[bison bridge]' \
        '--bison-locations[bison locations]' \
        '--noline[no line directives]' \
        '-Lf[do not generate #line]' \
        '--posix[posix mode]' \
        '--noyywrap[no yywrap]' \
        '--yylineno[yylineno]' \
        '--main[main function]' \
        '--nounistd[no unistd]' \
        '--header-file=+[header file]:file:_files' \
        '--tables-file=+[tables file]:file:_files' \
        '--tables-verify[verify tables]' \
        '--ecs[equiv classes]' \
        '--meta-ecs[meta equiv classes]' \
        '--read[use read instead of fread]' \
        '--no-array[generate scanner without array]' \
        '--array[generate scanner with array]' \
        '--pointer[generate scanner with pointer]' \
        '*:scanner file:_files -g "*.{l,ll,lpp,l++}"'
}

_flex-cli "$@"
