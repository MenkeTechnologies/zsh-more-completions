#compdef iwspy
# Documentation: https://hewlettpackard.github.io/wireless-tools/Tools.html
# Documentation: https://manpages.debian.org/bookworm/wireless-tools/iwspy.8.en.html
# Reference accessed: 2026-05-27
# Verified: upstream iwspy(8) manpage synopsis (Debian wireless-tools)

# Zsh completion for iwspy (wireless-tools spy-list manager).
# Synopsis:
#   iwspy [interface]
#   iwspy interface [+] DNSNAME | IPADDR | HWADDR [...]
#   iwspy interface off
#   iwspy interface setthr low high
#   iwspy interface getthr

local curcontext="$curcontext" state line ret=1

local -a _iwspy_subcmds
_iwspy_subcmds=(
  '+:append the new addresses to the current list instead of replacing it'
  'off:remove the current list of addresses and disable spy'
  'setthr:set low and high signal strength thresholds for the iwspy event'
  'getthr:retrieve the current low and high signal strength thresholds'
)

_net_ifaces() {
  local -a ifaces
  if [[ -d /sys/class/net ]]; then
    ifaces=(/sys/class/net/*(:t))
  fi
  _describe -t interfaces 'wireless interface' ifaces
}

_arguments -C \
  '1: :_net_ifaces' \
  '2: :->op' \
  '*:: :->rest' && ret=0

case $state in
  op)
    _alternative \
      'subcmds:operation:_describe -t subcmds "iwspy operation" _iwspy_subcmds' \
      'addrs:address:' && ret=0
    ;;
  rest)
    case $line[2] in
      setthr)
        _message 'low high (signal strength thresholds)' && ret=0
        ;;
      off|getthr)
        ;;
      *)
        _message 'additional DNSNAME, IPADDR, or HWADDR' && ret=0
        ;;
    esac
    ;;
esac

return ret
