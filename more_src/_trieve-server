# WHAT IT IS
#   Trieve is "an all-in-one platform for search, recommendations,
#   RAG, and analytics offered via API".  The main `trieve-
#   server` binary boots an actix-web HTTP service that proxies
#   typed search / recommend / RAG / analytics requests to a
#   backing Qdrant vector database (with sharding +
#   replication + quantization configurable via environment
#   variables), persists organizations / users / API keys to
#   PostgreSQL (`DATABASE_URL`), caches in Redis (`REDIS_URL`),
#   and runs a Stripe-backed billing pipeline that bills usage
#   per organization via the async-stripe `metered-usage` API.
#   Companion worker binaries handle background ingestion,
#   BK-tree indexing, group rebuilds, word-ID cronjobs, and
#   stripe billing batches.
#
# CLI ARGUMENT GRAMMAR  (verbatim from server/src/lib.rs —
#                       trieve-server is configured ENTIRELY
#                       via environment variables, NOT via
#                       command-line flags;  the binary takes
#                       no positional arguments)
#   trieve-server
#
#   Configuration is via env vars only (selected most-used):
#     DATABASE_URL                   PostgreSQL DSN (REQUIRED)
#     REDIS_URL                      Redis DSN     (REQUIRED)
#     ADMIN_API_KEY                  Admin API key for
#                                    privileged endpoints
#     SECRET_KEY                     Symmetric key (default:
#                                    "0123" × 16)
#     SALT                           Password salt (default:
#                                    "supersecuresalt")
#     SENTRY_URL                     Sentry DSN (optional)
#     REDIS_CONNECTIONS              Redis pool size
#     QUANTIZE_VECTORS               true|false
#     REPLICATION_FACTOR             Qdrant replication factor
#     QDRANT_SHARD_COUNT             Qdrant shard count
#     VECTOR_SIZES                   Comma-separated vector
#                                    dimensions
#     CREATE_QDRANT_COLLECTIONS      true|false (default true)
#     USE_ANALYTICS                  true|false  (enables
#                                    ClickHouse analytics)
#     STRIPE_SECRET_KEY              Stripe API key for the
#                                    async-stripe billing
#                                    pipeline
#     STRIPE_WEBHOOK_SECRET          Stripe webhook secret for
#                                    request signature
#                                    verification
#     (plus dozens more — see server/src/lib.rs `get_env!` and
#      `std::env::var` calls)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `async-stripe = "0.37.1"` declared in
#   server/Cargo.toml — `async-stripe` is THE canonical Rust
#   Stripe SDK maintained by arlyon (arlyon/async-stripe,
#   600+ stars, the predominant Stripe API client for the Rust
#   ecosystem).  async-stripe is the Rust counterpart of
#   stripe-node / stripe-go / stripe-python:  it exposes the
#   typed `stripe::Client` constructor with `Client::new(
#   api_key)`, typed model objects (`Customer`, `Subscription`,
#   `Invoice`, `Charge`, `PaymentIntent`, `PaymentMethod`,
#   `Plan`, `Price`, `Product`, `Coupon`, `Discount`,
#   `Refund`, `Account`, `BalanceTransaction`, `UsageRecord`,
#   `Setup Intent`, `Payment Link`, `Checkout Session`,
#   `Subscription Schedule`, `Invoice Item`), the typed
#   `Create*Params` / `Update*Params` / `List*Params` builder
#   structs for every endpoint, the `Webhook` constructor with
#   typed `EventObject`, signature verification via
#   `Webhook::construct_event(payload, sig_header, secret)`,
#   pagination via `List<T>::lazy(client)`, the `Expand` typed
#   expansion enum, `Currency` enum (151+ ISO 4217 codes), and
#   a tokio-async transport over `reqwest`.  trieve-server's
#   `server/src/bin/send-stripe-billing.rs` uses
#   `stripe::UsageRecord::create(client, &usage_params)` to
#   batch-upload organization-scoped per-search billable usage
#   to Stripe Metered Subscriptions.  Verified via:
#     gh api repos/devflowinc/trieve/contents/server/
#         Cargo.toml
#       → async-stripe = { version = "0.37.1", features = [...] }
#       → [package] name = "trieve-server"
#       → [[bin]] name = "trieve-server" path =
#           "src/main.rs"
#       → [[bin]] name = "send-stripe-billing"
#     gh api repos/devflowinc/trieve/contents/server/src/main.rs
#       → fn main() -> std::io::Result<()> {
#           trieve_server::main() }
#     gh api repos/devflowinc/trieve/contents/server/src/lib.rs
#       → 30+ `std::env::var(...)` / `get_env!(...)` calls,
#         configuration is env-only — no clap / argh / argparse
