#compdef apt-clone-cli apt-clone
# Documentation: https://manpages.debian.org/testing/apt-clone/apt-clone.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian testing apt-clone(8) manpage. Real binary is apt-clone.

# apt-clone: clone and restore APT package state across systems
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'info:show info about a apt-clone archive'
  'clone:create clone file'
  'restore:restore from clone file'
  'restore-new-distro:restore + distribution upgrade'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'apt-clone command' commands && ret=0 ;;
  args)
    case $line[1] in
      clone)
        _arguments \
          '--source=[alternate source dir]:dir:_files -/' \
          '--with-dpkg-repack[include dpkg-repack of local packages]' \
          '*:destination:_files' && ret=0 ;;
      restore|restore-new-distro)
        _arguments \
          '--destination=[alternate destination]:dir:_files -/' \
          '--force[force restore]' \
          '--dry-run[do not modify system]' \
          '--restore-src[restore /etc/apt/sources.list]' \
          '--restore-etc-apt[restore /etc/apt/]' \
          '*:source:_files' && ret=0 ;;
    esac ;;
esac
return ret
