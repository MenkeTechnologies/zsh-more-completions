#compdef johnny
# _johnny — Aleksey Cherepanov shinnok openwall johnny CLI Qt GUI frontend to John the Ripper password cracker presenting hash list session management wordlist mask attack incremental external mode for downstream john process invocation per-format md5 sha256 sha512 bcrypt scrypt argon2 NTLM presentation (Openwall team, Qt); custom argparse
# upstream: https://openwall.info/wiki/john/johnny

_johnny() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--platform=+[platform]:p:(linuxfb minimal eglfs offscreen vnc wayland xcb)' \
        '--style=+[s]:s:(Fusion Windows Macintosh Material Universal)' \
        '*:hash file:_files'
}

_johnny "$@"
