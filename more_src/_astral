#compdef astral
# Documentation: https://github.com/smirarab/ASTRAL/blob/master/astral-tutorial.md
# ASTRAL species tree estimation from unrooted gene trees

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i+[input file of gene trees in Newick format]:gene trees:_files' \
  '-o+[output file for species tree]:output:_files' \
  '-q+[score a given species tree topology]:species tree:_files' \
  '-a+[mapping file for multi-individual datasets]:map:_files' \
  '-b+[multi-locus bootstrap replicate list file]:file:_files' \
  '-r+[number of bootstrap replicates]:count' \
  '-g[gene plus site resampling for bootstrap]' \
  '--gene-only[gene-only bootstrapping]' \
  '-s+[random seed]:seed' \
  '-c+[Yule prior lambda hyperparameter]:lambda' \
  '-e+[extra trees to expand search space]:file:_files' \
  '-f+[extra species-labeled trees]:file:_files' \
  '-t+[branch annotation level]:level:(0 1 2 3 4 8 10 16 32)' \
  '-m+[remove genes with fewer leaves than threshold]:count' \
  '-R+[rename gene tree taxa via mapping file]:map:_files' \
  '-k+[output intermediate data]:kind:(completed bootstraps bootstraps_norun searchspace_norun)' \
  '-x[run exact version (<=18 taxa)]' \
  '--polylimit=[polytomy resolution search space size]:size' \
  '--samplingrounds=[individual sampling rounds]:rounds' \
  '*:gene trees:_files' && ret=0

return ret
