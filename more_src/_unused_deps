#compdef unused_deps
# Documentation: https://github.com/bazelbuild/buildtools/tree/main/unused_deps
# Reference accessed: 2026-05-21
# Verified: upstream unused_deps.go declares flags -version, -cquery, -build_tool, -extra_action_file, -output_file.

_arguments -s -S \
  '-version[print the version of unused_deps]' \
  '-cquery[use cquery instead of query]' \
  '-build_tool[build tool to use]:tool:' \
  '-extra_action_file[extra action file]:file:_files' \
  '-output_file[output file (with extra_action_file)]:file:_files' \
  '*:Bazel target pattern:'
