#compdef 1dMarry
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dMarry.html
# Join or split ragged-right .1D files for 3dDeconvolve

local ret=1

_arguments -s -S \
  '-sep[separator characters between joined values (default *,)]:abc' \
  '-divorce[split a married file into separate single-valued files]' \
  '*:file:_files' && ret=0

return ret
