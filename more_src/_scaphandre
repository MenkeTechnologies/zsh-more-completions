#compdef scaphandre

local -a _scaphandre_commands
_scaphandre_commands=(
  'json:output to JSON'
  'prometheus:expose metrics via Prometheus endpoint'
  'qemu:expose metrics for virtual machines'
  'riemann:push metrics to Riemann'
  'stdout:display metrics on stdout'
  'warp10:push metrics to Warp10'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--no-header[do not print header]' \
  '--sensor[sensor to use]:sensor:(powercap_rapl msr_rapl)' \
  '--sensor-buffer-per-domain-max-kb[max buffer per domain]:size' \
  '--sensor-buffer-per-socket-max-kb[max buffer per socket]:size' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'scaphandre commands' _scaphandre_commands
    ;;
  args)
    case "$words[1]" in
      stdout)
        _arguments \
          '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds' \
          '--max-top-consumers[max processes to display]:count' \
          '--raw[raw values]' \
          '(-s --step)'{-s,--step}'[interval between measurements]:seconds' \
          '--containers[show container stats]' \
          '--qemu[show QEMU VM stats]'
        ;;
      json)
        _arguments \
          '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds' \
          '(-s --step)'{-s,--step}'[interval between measurements]:seconds' \
          '--max-top-consumers[max processes to output]:count' \
          '--containers[show container stats]' \
          '(-f --file)'{-f,--file}'[output file]:file:_files'
        ;;
      prometheus)
        _arguments \
          '(-a --address)'{-a,--address}'[listening address]:address' \
          '(-p --port)'{-p,--port}'[listening port]:port' \
          '(-s --step)'{-s,--step}'[interval between measurements]:seconds' \
          '--suffix[metric name suffix]:suffix' \
          '--containers[show container stats]' \
          '--qemu[show QEMU VM stats]'
        ;;
      riemann)
        _arguments \
          '(-a --address)'{-a,--address}'[Riemann address]:address' \
          '(-p --port)'{-p,--port}'[Riemann port]:port' \
          '(-s --step)'{-s,--step}'[interval between measurements]:seconds' \
          '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds' \
          '--mtls[use mTLS]' \
          '--ca[CA file]:file:_files' \
          '--cert[client certificate]:file:_files' \
          '--key[client key]:file:_files'
        ;;
      warp10)
        _arguments \
          '--host[Warp10 host]:host' \
          '--port[Warp10 port]:port' \
          '--scheme[scheme]:scheme:(http https)' \
          '--token[write token]:token' \
          '(-s --step)'{-s,--step}'[interval between measurements]:seconds' \
          '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds'
        ;;
      qemu)
        _arguments \
          '(-a --address)'{-a,--address}'[listening address]:address' \
          '(-p --port)'{-p,--port}'[listening port]:port' \
          '(-s --step)'{-s,--step}'[interval between measurements]:seconds'
        ;;
    esac
    ;;
esac
