#compdef create-prisma
# Documentation: https://github.com/prisma/create-prisma
# Reference accessed: 2026-05-24
# Verified: npm view create-prisma bin; create-prisma README at the URL above.

# Zsh completion for create-prisma - Prisma 7 project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--name=[project name or path]:name:'   '--template=[app template]:template:(hono elysia nest next svelte astro nuxt tanstack-start turborepo)'   '--provider=[database provider]:provider:(postgresql mysql sqlite sqlserver cockroachdb)'   '--package-manager=[package manager]:manager:(npm pnpm yarn bun deno)'   '--schema-preset=[schema preset]:preset:(empty basic)'   '--yes[accept defaults and skip prompts]'   '--no-install[scaffold only without installing dependencies]'   '--no-generate[skip prisma generate]'   '--prisma-postgres[provision Prisma Postgres for PostgreSQL]'   '--skills[enable Prisma skills add-on]'   '--mcp[enable Prisma MCP add-on]'   '--extension[enable Prisma IDE extension add-on]'   '--force[allow scaffolding into a non-empty directory]'   '--verbose[print full command output]'   ':project directory:_directories' && ret=0

return ret
