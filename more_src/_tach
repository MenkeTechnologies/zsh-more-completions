#compdef tach
# Documentation: https://man.archlinux.org/search?q=tach
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:interactively define module boundaries'
  'check:check boundaries and interfaces are respected'
  'check-external:check external dependencies are declared'
  'sync:sync constraints with actual dependencies'
  'show:visualize dependency graph'
  'report:per-module report of imports/exports'
  'install:install pre-commit hook'
  'modules:manage modules'
  'mod:alias for modules'
  'modularize:identify candidate modules'
  'lint:lint configuration'
  'upgrade:upgrade tach config to latest schema'
  'test:run tests respecting tach.toml constraints'
  'cache:cache utilities'
  'tdd:identify upstream tests required for change'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-e --exclude)*'{-e+,--exclude=}'[exclude path glob]:glob:' \
  '--root=[project root directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tach command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (check)
        _arguments \
          '--root=[project root]:dir:_files -/' \
          '*--exclude=[exclude glob]:glob:' \
          '--exact[require all dependencies declared]' \
          '--dependencies[skip module dependency check]' \
          '--interfaces[skip module interface check]' && ret=0 ;;
      (sync)
        _arguments \
          '--add[add missing dependencies]' \
          '--prune[remove unused dependencies]' && ret=0 ;;
      (show)
        _arguments \
          '--out=[output filename]:file:_files' \
          '--mermaid[output mermaid format]' \
          '--web[open in browser]' \
          '--included-paths=[only include paths]:globs:' && ret=0 ;;
      (report) _arguments '*:path:_files' && ret=0 ;;
    esac ;;
esac

return ret
