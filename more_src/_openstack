#compdef openstack

local curcontext="$curcontext" state line ret=1
local -a objects verbs

objects=(
  'server:compute instances'
  'volume:block storage volumes'
  'network:networking resources'
  'image:image resources'
  'project:projects'
  'user:user accounts'
  'role:role assignments'
  'domain:identity domains'
  'credential:user credentials'
  'token:authentication tokens'
  'port:network ports'
  'router:routers'
  'subnet:subnets'
  'security:security groups'
  'floating:floating IPs'
  'backup:volume/server backups'
  'snapshot:volume snapshots'
  'aggregate:compute aggregates'
  'hypervisor:hypervisor monitoring'
  'quota:resource quotas'
  'catalog:service catalog'
  'endpoint:service endpoints'
  'service:catalog services'
  'keypair:SSH keypairs'
  'flavor:compute flavors'
  'availability:availability zones'
  'console:console URLs'
  'consistency:consistency groups'
  'help:show help for command'
)

verbs=(create list show set unset delete add remove)

_arguments -C \
  '--os-auth-url=[identity service endpoint]:url:' \
  '--os-auth-type=[auth plugin type]:type:' \
  '--os-username=[username]:user:' \
  '--os-password=[password]:pw:' \
  '--os-token=[existing token]:token:' \
  '--os-project-name=[project name]:name:' \
  '--os-project-domain-name=[project domain]:name:' \
  '--os-project-domain-id=[project domain id]:id:' \
  '--os-user-domain-name=[user domain]:name:' \
  '--os-user-domain-id=[user domain id]:id:' \
  '--os-domain-name=[domain name]:name:' \
  '--os-domain-id=[domain id]:id:' \
  '--os-default-domain=[default domain]:name:' \
  '--os-identity-api-version=[identity API version]:ver:(2.0 3)' \
  '--os-cloud=[clouds.yaml entry]:name:' \
  '--os-application-credential-id=[app credential id]:id:' \
  '--os-application-credential-secret=[app credential secret]:secret:' \
  '--os-passcode=[TOTP passcode]:code:' \
  '--os-region-name=[region]:region:' \
  '--os-interface=[interface]:iface:(public internal admin)' \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--debug[debug output]' \
  '--log-file=[log file]:file:_files' \
  '(-f --format)'{-f,--format=}'[output format]:fmt:(table json yaml csv value)' \
  '*'{-c,--column=}'[column]:col:' \
  '--max-width=[max width]:width:' \
  '--noindent[no indentation]' \
  '--prefix=[prefix]:str:' \
  '1: :->object' \
  '*::arg:->args' && ret=0

case $state in
  (object)
    _describe -t objects 'openstack object' objects && ret=0
    ;;
  (args)
    _describe -t verbs 'openstack verb' verbs && ret=0
    ;;
esac

return ret
