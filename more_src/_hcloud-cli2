#compdef hcloud-cli2
# Documentation: https://man.archlinux.org/search?q=hcloud-cli2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'all:show all resources'
  'certificate:certificate management'
  'completion:print shell completion'
  'config:CLI config'
  'context:auth contexts'
  'datacenter:datacenter info'
  'firewall:firewall management'
  'floating-ip:floating IP commands'
  'image:images'
  'iso:ISO list'
  'load-balancer:load balancers'
  'load-balancer-type:LB types'
  'location:locations'
  'network:networks'
  'placement-group:placement groups'
  'primary-ip:primary IPs'
  'server:servers'
  'server-type:server types'
  'ssh-key:SSH keys'
  'volume:volumes'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--config=[config file]:file:_files -g "*.toml"' \
  '*--context=[context]:c:' \
  '*--debug[debug]' \
  '*--debug-file=[debug file]:file:_files' \
  '*--endpoint=[endpoint URL]:url:' \
  '*--token=[API token]:t:' \
  '*--quiet[quiet]' \
  '*--poll-interval=[poll interval]:t:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hcloud command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '1:subcommand:(add-label add-to-placement-group attach-iso attach-to-network change-alias-ips change-type create create-image delete describe detach-from-network detach-iso disable-backup disable-protection disable-rescue enable-backup enable-protection enable-rescue ip list metrics poweroff poweron reboot rebuild remove-from-placement-group remove-label request-console reset reset-password set-rdns shutdown ssh update)' \
          '*: :' && ret=0 ;;
      (network)
        _arguments \
          '1:subcommand:(add-label add-route add-subnet change-ip-range create delete describe disable-protection enable-protection list remove-label remove-route remove-subnet update)' \
          '*: :' && ret=0 ;;
      (volume)
        _arguments \
          '1:subcommand:(add-label attach create delete describe detach disable-protection enable-protection list remove-label resize update)' \
          '*: :' && ret=0 ;;
      (load-balancer)
        _arguments \
          '1:subcommand:(add-label add-service add-target attach-to-network change-algorithm change-type create delete delete-service describe detach-from-network disable-protection disable-public-interface enable-protection enable-public-interface list metrics remove-label remove-target update update-service)' \
          '*: :' && ret=0 ;;
      (firewall)
        _arguments \
          '1:subcommand:(add-label add-rule apply-to-resource create delete delete-rule describe list remove-from-resource remove-label set-rules update)' \
          '*: :' && ret=0 ;;
      (image)
        _arguments \
          '1:subcommand:(add-label delete describe disable-protection enable-protection list remove-label update)' \
          '*: :' && ret=0 ;;
      (ssh-key)
        _arguments \
          '1:subcommand:(add-label create delete describe list remove-label update)' \
          '*: :' && ret=0 ;;
      (placement-group)
        _arguments \
          '1:subcommand:(add-label create delete describe list remove-label update)' \
          '*: :' && ret=0 ;;
      (primary-ip)
        _arguments \
          '1:subcommand:(add-label assign create delete describe disable-protection enable-protection list remove-label set-rdns unassign update)' \
          '*: :' && ret=0 ;;
      (floating-ip)
        _arguments \
          '1:subcommand:(add-label assign create delete describe disable-protection enable-protection list remove-label set-rdns unassign update)' \
          '*: :' && ret=0 ;;
      (certificate)
        _arguments \
          '1:subcommand:(add-label create delete describe list remove-label retry update)' \
          '*: :' && ret=0 ;;
      (context)
        _arguments \
          '1:subcommand:(active create delete list use)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(get list set unset)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
