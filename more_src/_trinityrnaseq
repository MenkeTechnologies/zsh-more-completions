#compdef Trinity trinity trinityrnaseq TrinityStats.pl
# _trinityrnaseq — Brian Haas Broad Trinity de novo RNA-seq transcriptome assembly Inchworm Chrysalis Butterfly modules (trinityrnaseq team, Perl/C++); custom argparse
# upstream: https://github.com/trinityrnaseq/trinityrnaseq

_trinityrnaseq() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--show_full_usage_info[show full usage]' \
        '--version[show version]' \
        '--seqType=+[seq type]:t:(fq fa)' \
        '--max_memory=+[memory]:str:' \
        '--left=+[left reads csv]:str:' \
        '--right=+[right reads csv]:str:' \
        '--single=+[single reads csv]:str:' \
        '--samples_file=+[samples file]:file:_files' \
        '--include_supertranscripts[include supertranscripts]' \
        '--SS_lib_type=+[type]:t:(R F RF FR)' \
        '--CPU=+[threads]:n:' \
        '--min_contig_length=+[N]:n:' \
        '--output=+[output dir]:dir:_files -/' \
        '--full_cleanup[full cleanup]' \
        '--genome_guided_bam=+[bam file]:file:_files -g "*.bam"' \
        '--jaccard_clip[jaccard clip]' \
        '--genome_guided_max_intron=+[N]:n:' \
        '--genome_guided_min_coverage=+[F]:f:' \
        '--genome_guided_min_reads_per_partition=+[N]:n:' \
        '--prep[only prep]' \
        '--no_normalize_reads[no normalize]' \
        '--normalize_by_read_set[normalize by read set]' \
        '--normalize_max_read_cov=+[N]:n:' \
        '--normalize_max_pct_aligned=+[F]:f:' \
        '--no_distributed_trinity_exec[no distributed]' \
        '--grid_node_CPU=+[N]:n:' \
        '--grid_node_max_memory=+[mem]:str:' \
        '--grid_conf_file=+[file]:file:_files' \
        '--singularity_img=+[file]:file:_files' \
        '--singularity_extra_params=+[params]:str:' \
        '--FORCE[force]' \
        '--no_run_inchworm[no inchworm]' \
        '--no_run_chrysalis[no chrysalis]' \
        '--no_distributed_trinity_exec[no distributed]' \
        '--show_advanced_options[show advanced options]' \
        '--KMER_SIZE=+[N]:n:' \
        '--inchworm_cpu=+[N]:n:' \
        '--quality_trimming_params=+[params]:str:' \
        '--no_bowtie[no bowtie]' \
        '--bflyHeapSpaceMax=+[bytes]:str:' \
        '--bflyHeapSpaceInit=+[bytes]:str:' \
        '--bflyGCThreads=+[N]:n:' \
        '--bflyCPU=+[N]:n:' \
        '--bflyCalculateCPU[calc CPU]' \
        '--no_salmon[no salmon]' \
        '--no_super_reads[no super reads]' \
        '--no_cleanup[no cleanup]' \
        '--no_path_merging[no path merging]' \
        '--min_kmer_cov=+[N]:n:' \
        '--min_glue=+[N]:n:' \
        '--max_reads_per_graph=+[N]:n:' \
        '--max_reads_per_loop=+[N]:n:' \
        '--max_reads_per_partition=+[N]:n:' \
        '--min_iso_ratio=+[F]:f:' \
        '--group_pairs_distance=+[N]:n:' \
        '--path_reinforcement_distance=+[N]:n:' \
        '--no_triplet_lock[no triplet lock]' \
        '--Butterfly_max_RAM=+[bytes]:str:'
}

_trinityrnaseq "$@"
