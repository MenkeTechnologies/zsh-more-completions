#compdef erln8
# Documentation: https://github.com/erln8/erln8
# The sneaky Erlang version manager

local ret=1

_arguments -s \
  '--use=[set up the current directory to use a specific version of Erlang]:id' \
  '--list[list available Erlang installations]' \
  '--remote[add/delete/show remotes]' \
  '--clone[clone an Erlang source repository]' \
  '--fetch[update source repos]' \
  '--build[build a specific version of OTP from source]' \
  '--build-latest[build the latest tagged version of OTP from source]' \
  '--repo=[specify repo name to build from]:repo' \
  '--id=[user-assigned name for a version of Erlang]:id' \
  '--config=[build configuration]:config' \
  '--show[show the configured version of Erlang in the current directory]' \
  '--prompt[display the version of Erlang configured for this directory tree]' \
  '--configs[list build configs]' \
  '--repos[list build repos]' \
  '--set-default=[set the system-wide Erlang default]:id' \
  '--get-default[display the system-wide Erlang default]' \
  '--force[overwrite an erln8.config in the current directory]' \
  '--buildable[list tags to build from configured source repos]' \
  '--version[show the installed version of erln8]' \
  '--setup-bins[regenerate erln8-managed OTP application links]' \
  '--debug[show debug output]' && ret=0

return ret
