#compdef k6

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'archive:create archive bundle'
  'cloud:run in K6 Cloud'
  'completion:generate completion'
  'help:show help'
  'inspect:inspect a script'
  'login:authenticate'
  'logout:log out'
  'new:create new script'
  'pause:pause running test'
  'resume:resume running test'
  'run:run a load test'
  'scale:scale a running test'
  'stats:show test statistics'
  'status:show test status'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-a+[address]:addr:' \
  '*--address=[address]:addr:' \
  '*-c+[config file]:file:_files -g "*.json"' \
  '*--config=[config file]:file:_files -g "*.json"' \
  '*--log-format=[log format]:f:(text json raw)' \
  '*--log-output=[log output]:o:(stderr stdout file none loki)' \
  '*--no-color[no color]' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'k6 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|cloud)
        _arguments \
          '(-u --vus)'{-u+,--vus=}'[VUs]:n:' \
          '(-d --duration)'{-d+,--duration=}'[duration]:t:' \
          '(-i --iterations)'{-i+,--iterations=}'[iterations]:n:' \
          '(-s --stage)*'{-s+,--stage=}'[stage]:s:' \
          '*--rps=[max RPS]:n:' \
          '*--batch=[batch size]:n:' \
          '*--batch-per-host=[batch per host]:n:' \
          '*--user-agent=[user agent]:ua:' \
          '*--http-debug=[debug]:m:(headers full)' \
          '*--include-system-env-vars[include env]' \
          '*--insecure-skip-tls-verify[insecure TLS]' \
          '*--no-connection-reuse[no conn reuse]' \
          '*--no-vu-connection-reuse[no VU conn reuse]' \
          '*--no-thresholds[no thresholds]' \
          '*--no-summary[no summary]' \
          '*--no-usage-report[no usage report]' \
          '*--no-setup[no setup]' \
          '*--no-teardown[no teardown]' \
          '*--summary-export=[summary file]:file:_files' \
          '*--summary-time-unit=[time unit]:u:(s ms us)' \
          '*--summary-trend-stats=[stats csv]:list:' \
          '*--max-redirects=[max redirects]:n:' \
          '*-e+[env k=v]:e:' \
          '*--env=[env k=v]:e:' \
          '*--tag=[tag k=v]:t:' \
          '*-o+[output]:o:(json csv influxdb cloud datadog timescaledb statsd)' \
          '*--out=[output]:o:' \
          '*--blacklist-ip=[blacklist IP]:ip:' \
          '*--block-hostnames=[block hostnames csv]:list:' \
          '*--throw[throw on error]' \
          '*--linger[linger]' \
          '*--paused[start paused]' \
          '*--quiet[quiet]' \
          '*--vus-max=[max VUs]:n:' \
          '*--system-tags=[system tags csv]:list:' \
          '*--profile=[profile mode]:m:(cpu mem block trace mutex)' \
          '*--execution-segment=[segment]:s:' \
          '*--execution-segment-sequence=[sequence]:s:' \
          '*--scenarios=[scenarios csv]:list:' \
          '*-w+[wait period]:t:' \
          '*--exit-on-running[exit on running]' \
          '*--show-logs[show logs]' \
          '*--archive-out=[archive out]:file:_files' \
          '*--console-output=[console output]:file:_files' \
          '*--discard-response-bodies[discard bodies]' \
          '*--include-system-env-vars[include env]' \
          '*--dns=[DNS resolver]:r:' \
          '*--local-ips=[local IPs csv]:list:' \
          '*--minimum-iteration-duration=[min iter duration]:t:' \
          '*: :_files -g "*.js *.ts"' && ret=0 ;;
      (archive)
        _arguments \
          '*-O+[archive output]:file:_files' \
          '*--archive-out=[archive output]:file:_files' \
          '*: :_files' && ret=0 ;;
      (inspect)
        _arguments \
          '*: :_files -g "*.js *.tar"' && ret=0 ;;
      (new)
        _arguments \
          '(--project-id)--project-id=[id]:id:' \
          '(-f --force)'{-f,--force}'[force]' \
          '(--template)--template=[template]:t:(minimal protocol browser)' \
          '*: :_files' && ret=0 ;;
      (cloud)
        _arguments \
          '1:subcommand:(login logout run upload)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
