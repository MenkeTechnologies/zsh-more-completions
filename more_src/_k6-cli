#compdef k6
# Documentation: https://github.com/grafana/k6/blob/master/internal/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'archive:create an archive'
  'cloud:run a test on Grafana Cloud k6'
  'deps:list dependencies of a test script'
  'inspect:inspect a script or archive'
  'new:create and initialize a new k6 script'
  'run:run a load test'
  'stats:show test metrics'
  'version:show version'
  'completion:generate shell autocompletion script'
  'help:help about any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-a+[address]:addr:' \
  '*--address=[address]:addr:' \
  '*-c+[config file]:file:_files -g "*.json"' \
  '*--config=[config file]:file:_files -g "*.json"' \
  '*--log-format=[log output format]:f:' \
  '*--log-output=[change the output for k6 logs]:o:' \
  '*--secret-source=[setup a secret source]:source:' \
  '*--no-color[disable colored output]' \
  '*-q[disable progress updates]' \
  '*--quiet[disable progress updates]' \
  '*-v[enable verbose logging]' \
  '*--verbose[enable verbose logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'k6 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|cloud)
        _arguments \
          '(-u --vus)'{-u+,--vus=}'[VUs]:n:' \
          '(-d --duration)'{-d+,--duration=}'[duration]:t:' \
          '(-i --iterations)'{-i+,--iterations=}'[iterations]:n:' \
          '(-s --stage)*'{-s+,--stage=}'[stage]:s:' \
          '*--rps=[max RPS]:n:' \
          '*--batch=[batch size]:n:' \
          '*--batch-per-host=[batch per host]:n:' \
          '*--user-agent=[user agent]:ua:' \
          '*--http-debug=[debug]:m:(headers full)' \
          '*--include-system-env-vars[include env]' \
          '*--insecure-skip-tls-verify[insecure TLS]' \
          '*--no-connection-reuse[no conn reuse]' \
          '*--no-vu-connection-reuse[no VU conn reuse]' \
          '*--no-thresholds[do not run thresholds]' \
          '*--no-usage-report[do not send anonymous usage stats]' \
          '*--no-setup[do not run setup()]' \
          '*--no-teardown[do not run teardown()]' \
          '*--summary-time-unit=[time unit for trend stats]:u:(s ms us)' \
          '*--summary-trend-stats=[trend stats csv]:list:' \
          '*--summary-mode=[summary mode]:m:' \
          '*--max-redirects=[follow at most n redirects]:n:' \
          {-e+,--env=}'[add/override environment variable VAR=value]:e:' \
          '*--tag=[add a tag name=value to all samples]:t:' \
          '(-o --out)*'{-o+,--out=}'[uri for an external metrics database]:o:' \
          '*--blacklist-ip=[blacklist an ip range from being called]:ip:' \
          '*--block-hostnames=[block a hostname pattern]:list:' \
          '(-w --throw)'{-w,--throw}'[throw warnings as errors]' \
          '(-l --linger)'{-l,--linger}'[keep the API server alive past test end]' \
          '(-p --paused)'{-p,--paused}'[start the test in a paused state]' \
          '*--system-tags=[system tags csv]:list:' \
          '*--compatibility-mode=[JavaScript compatibility mode]:m:(extended base experimental_enhanced)' \
          '(-t --type)'{-t+,--type=}'[override test type js or archive]:t:(js archive)' \
          '*--execution-segment=[limit execution to segment]:s:' \
          '*--execution-segment-sequence=[execution segment sequence]:s:' \
          '*--discard-response-bodies[read but do not save HTTP response bodies]' \
          '*--include-system-env-vars[pass real system env vars to the runtime]' \
          '*--dns=[DNS resolver configuration]:r:' \
          '*--local-ips=[client IP ranges/CIDRs for VU requests]:list:' \
          '*--traces-output=[set the traces output]:o:' \
          '*--min-iteration-duration=[minimum time per single iteration]:t:' \
          '*--console-output=[redirect console logging to file]:file:_files' \
          '*: :_files -g "*.js *.ts"' && ret=0 ;;
      (archive)
        _arguments \
          '(-O --archive-out)'{-O+,--archive-out=}'[archive output filename]:file:_files' \
          '*--exclude-env-vars[do not embed env vars in archive metadata]' \
          '*: :_files' && ret=0 ;;
      (inspect)
        _arguments \
          '*: :_files -g "*.js *.tar"' && ret=0 ;;
      (new)
        _arguments \
          '(--project-id)--project-id=[id]:id:' \
          '(-f --force)'{-f,--force}'[force]' \
          '(--template)--template=[template]:t:(minimal protocol browser)' \
          '*: :_files' && ret=0 ;;
      (cloud)
        _arguments \
          '1:subcommand:(run login upload project)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
