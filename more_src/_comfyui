#compdef comfyui comfyui-cli
# _comfyui — comfyanonymous ComfyUI node-based Stable Diffusion UI CLI alias (comfyanonymous, Python); custom argparse
# upstream: https://github.com/comfyanonymous/ComfyUI

_comfyui() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--listen=+[listen address]:host:_hosts' \
        '--port=+[port]:port:' \
        '--external-address=+[external address]:host:_hosts' \
        '--enable-cors-header=+[CORS allowed origin]:str:' \
        '--max-upload-size=+[max upload size MB]:n:' \
        '--extra-model-paths-config=+[extra model paths config]:file:_files' \
        '--output-directory=+[output directory]:dir:_files -/' \
        '--temp-directory=+[temp directory]:dir:_files -/' \
        '--input-directory=+[input directory]:dir:_files -/' \
        '--auto-launch[auto launch browser]' \
        '--disable-auto-launch[disable auto launch]' \
        '--cuda-device=+[CUDA device id]:n:' \
        '--cuda-malloc[CUDA malloc]' \
        '--disable-cuda-malloc[disable CUDA malloc]' \
        '--force-fp32[force FP32]' \
        '--force-fp16[force FP16]' \
        '--bf16-unet[BF16 UNET]' \
        '--fp16-unet[FP16 UNET]' \
        '--fp8_e4m3fn-unet[FP8 e4m3fn UNET]' \
        '--fp8_e5m2-unet[FP8 e5m2 UNET]' \
        '--fp16-vae[FP16 VAE]' \
        '--fp32-vae[FP32 VAE]' \
        '--bf16-vae[BF16 VAE]' \
        '--cpu[force CPU]' \
        '--mps[use MPS]' \
        '--directml=+[DirectML adapter]:n:' \
        '--ipex[Intel IPEX]' \
        '--xpu[Intel XPU]' \
        '--disable-ipex-optimize[disable IPEX optimize]' \
        '--gpu-only[GPU only]' \
        '--highvram[high VRAM]' \
        '--normalvram[normal VRAM]' \
        '--lowvram[low VRAM]' \
        '--novram[no VRAM]' \
        '--cpu-vae[CPU VAE]' \
        '--disable-xformers[disable xformers]' \
        '--force-channels-last[force channels last]' \
        '--dont-print-server[do not print server URL]' \
        '--quick-test-for-ci[quick test for CI]' \
        '--windows-standalone-build[windows standalone build]' \
        '--disable-metadata[disable metadata]' \
        '--multi-user[multi user]' \
        '--verbose[verbose]' \
        '--log-stdout[log to stdout]' \
        '--front-end-version=+[frontend version]:str:' \
        '--front-end-root=+[frontend root]:dir:_files -/' \
        '--user-directory=+[user directory]:dir:_files -/' \
        '--enable-compress-response-body[enable response compression]' \
        '--preview-method=+[preview method]:m:(none auto latent2rgb taesd)' \
        '--cache-classic[classic cache]' \
        '--cache-lru=+[lru cache size]:n:' \
        '*:arg:'
}

_comfyui "$@"
