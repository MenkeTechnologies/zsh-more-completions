#compdef pyo3-stubgen pyo3_stubgen
# _pyo3-stubgen — generate .pyi files from compiled pyo3 extension modules (MusicalNinjas/pyo3-stubgen)
# upstream: https://github.com/MusicalNinjas/pyo3-stubgen
# Flags from pyo3_stubgen/generate.py (click).

_pyo3-stubgen() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1:module name:' \
        '2:output directory:_files -/'
}

_pyo3-stubgen "$@"
