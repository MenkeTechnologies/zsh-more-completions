#compdef OpenSwathAnalyzer
# Documentation: https://www.openms.org/documentation/html/TOPP_OpenSwathAnalyzer.html
# OpenMS: scores chromatographic peak groups from OpenSWATH extracted ion chromatograms

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input chromatograms file (mzML)]:file:_files -g "*.mzML"' \
  '-tr[transition file (TraML)]:file:_files' \
  '-out[output file (featureXML)]:file:_files' \
  '-rt_norm[RT normalization file (trafoXML)]:file:_files' \
  '-no-strict[allow non-strict mapping of chromatograms]' \
  '*-swath_files[SWATH files for MS2 spectra (mzML)]:file:_files -g "*.mzML"' \
  '-min_upper_edge_dist[minimal distance to SWATH edge in Th]:double:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
