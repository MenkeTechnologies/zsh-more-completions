#compdef tailcall
# =============================================================================
# tailcall — Tailcall HQ's "High Performance GraphQL
#          Runtime" — a Rust-implemented GraphQL gateway
#          + composer that declaratively wraps existing
#          REST/gRPC/GraphQL backend services as a
#          unified GraphQL schema, exposing them through
#          a single high-throughput async-graphql server.
#          Authors write a *.graphql configuration with
#          tailcall directives like `@http(path:"/...")`,
#          `@grpc(method:"...")`, `@call(query:"...")`,
#          `@expr(body:"...")` declaring how to fetch +
#          transform data; tailcall compiles this to a
#          fully-typed GraphQL endpoint with automatic
#          N+1 detection, batching, and request
#          deduplication.
#          Distinguishing from Apollo Server (Node.js;
#          JS-implemented; resolver-function-per-field
#          model), GraphQL Mesh (Node.js; similar
#          declarative approach but heavier
#          dependency tree), Hasura (PostgreSQL-
#          autogenerated GraphQL; Haskell-implemented;
#          DB-only), PostGraphile (Node.js; PostgreSQL-
#          only), and Grafbase Gateway (R??? in
#          corpus) by:
#            - ASYNC-GRAPHQL FOUNDATION — uses
#              async-graphql/async-graphql v7.0 (this
#              is the headline CLI library that OPENS
#              Axis 46 on the Rust side; see taxonomy
#              notes below) — the dominant Rust
#              async GraphQL server library — for
#              schema parsing, query execution,
#              subscription handling, and federation
#              support.  ~3,660+ stars on the
#              upstream library
#            - DECLARATIVE CONFIGURATION — instead of
#              writing imperative resolvers, users
#              declare `type Query { post(id: Int!):
#              Post @http(path: "/posts/{{.args.id}}") }`
#              + tailcall generates the resolver
#              automatically.  Reduces boilerplate +
#              eliminates entire classes of resolver
#              bugs
#            - N+1 QUERY DETECTION — `tailcall check
#              -n` analyzes the configuration's call
#              graph + detects N+1 patterns (e.g.
#              `posts { author { name } }` where
#              each author fetch is a separate HTTP
#              call) BEFORE deployment; recommends
#              batching strategies
#            - AUTOMATIC BATCHING + DEDUPLICATION —
#              when N+1 patterns are detected at
#              runtime, tailcall batches concurrent
#              fetches into single requests +
#              deduplicates identical concurrent
#              fetches; reduces backend load without
#              requiring DataLoader-style boilerplate
#            - GENERATE FROM REST / gRPC / OPENAPI —
#              `tailcall gen <file>` introspects an
#              OpenAPI spec, gRPC proto file, or
#              Postman collection + generates a
#              tailcall configuration that wraps the
#              source service as GraphQL.  Reduces
#              the cost of exposing legacy REST/
#              gRPC services through GraphQL
#            - INIT TEMPLATE — `tailcall init` (or
#              `tailcall init ./myproject`) scaffolds
#              a fresh tailcall project with sample
#              configuration + Docker compose +
#              README; reduces the bootstrap cost
#              for newcomers
#            - CHECK BEFORE START — `tailcall check
#              <file>` validates the configuration
#              before launching the server; catches
#              schema syntax errors, type
#              mismatches, dangling references,
#              N+1 query patterns; `-s, --schema`
#              flag prints the resolved GraphQL
#              schema
#            - MULTIPLE CONFIG SOURCES — start +
#              check accept MULTIPLE config files in
#              the same invocation, allowing modular
#              configurations spread across files;
#              supports remote configs via
#              http(s):// URLs in addition to local
#              files (`-v false` disables TLS verify
#              for remote configs)
#            - MIMALLOC ALLOCATOR — uses Microsoft's
#              mimalloc allocator (feature-gated)
#              for improved heap performance on
#              high-throughput workloads
#            - HTTP-CACHE-REQWEST INTEGRATION —
#              uses http-cache-reqwest with moka
#              backend for transparent caching of
#              upstream HTTP fetches; configurable
#              cache TTL per-resolver via tailcall
#              directives
#            - OPENTELEMETRY INSTRUMENTATION —
#              `tailcall start` configures OTel
#              tracing for the entire GraphQL
#              execution pipeline; spans created
#              per-resolver, per-HTTP-fetch, per-
#              batch; integrates with the Axis 39
#              OTel ecosystem (rotel R745, uptrace
#              R746, codemachine R747)
#            - WASM SUPPORT — the core tailcall
#              library compiles to WebAssembly
#              (with `--no-default-features`),
#              enabling tailcall to run inside
#              edge runtimes (Cloudflare Workers,
#              Fastly Compute@Edge, Vercel Edge
#              Functions); ties into the Axis 33
#              WASM ecosystem
#            - LLM-ASSISTED CONFIG GENERATION —
#              `src/cli/llm/` integrates with LLM
#              providers for AI-assisted config
#              generation; experimental feature
#              for natural-language → tailcall
#              configuration translation
#            - 1,440+ STARS ON tailcallhq/tailcall
#              — backed by Tailcall HQ (the
#              commercial company at tailcall.run);
#              Apache-2.0 license; active
#              development by a dedicated team
#          Used by: backend engineers exposing
#          legacy REST/gRPC services through a
#          unified GraphQL API without writing
#          per-resolver code, federated-GraphQL
#          deployments needing high-throughput
#          gateway nodes, edge-compute teams using
#          the WASM build for low-latency GraphQL
#          at CDN edges, and any team migrating
#          from Apollo Server / GraphQL Mesh to
#          a faster Rust-implemented runtime.
#
# Author:  Tailcall HQ (https://tailcall.run); the
#          commercial company behind the open-
#          source runtime.  "Next generation of API
#          Orchestration" per the organization
#          tagline.
# Source:  https://github.com/tailcallhq/tailcall
#          https://github.com/tailcallhq/tailcall/blob/main/src/main.rs
#          https://github.com/tailcallhq/tailcall/blob/main/src/cli/command.rs
#          https://github.com/tailcallhq/tailcall/blob/main/Cargo.toml
# Manpage: No traditional manpage; `tailcall --help`
#          shows clap-derived subcommand list;
#          `tailcall <sub> --help` per-subcommand
#          options.  Full documentation at https://
#          tailcall.run/docs/
# Library: async-graphql/async-graphql v7.0.9 (Sun
#          Li's "A GraphQL server library
#          implemented in Rust").  This is the
#          headline dependency for this completion's
#          axis-46 opening role; see taxonomy notes
#          below.  Also clap v4 (Axis 1 argparse
#          with derive macro), strum_macros (enum
#          string conversion), tokio v1.37 (async
#          runtime), reqwest v0.11 with rustls-tls
#          (HTTP client), tracing v0.1 (Axis 9
#          logging), serde + serde_json (data),
#          anyhow + thiserror (Axis 6 errors),
#          indexmap, url, convert_case, tailcall-
#          valid (own validation library), http
#          v0.2 + headers v0.3 (HTTP types),
#          mimalloc (optional allocator), http-
#          cache-reqwest with moka (HTTP caching).
# License: Apache-2.0
# Status:  1,440+ stars on tailcallhq/tailcall;
#          active development (latest commit
#          2026-06-01); production-grade GraphQL
#          gateway with growing enterprise
#          deployment base
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — AXIS 46 OPENS:
#   GRAPHQL SERVER / GRAPHQL RUNTIME
# -----------------------------------------------------------------------------
# This completion **OPENS AXIS 46** in the cross-
# language CLI library taxonomy: GraphQL Server /
# GraphQL Runtime (libraries that implement the
# GraphQL specification's server-side: schema
# parsing, query execution, resolver dispatch,
# subscription handling, federation support — as
# distinct from Axis 38 OpenAPI which handles
# OpenAPI/REST specifications, or generic HTTP
# servers).
#
# Pattern: R772 125th language (Cogent) closes the
# prior 3+1 cycle → R773 Rust=101 (tailcall/async-
# graphql → Axis 46 OPENS THIS) is the first
# leader bump in the new cycle.  Pending: R774
# Go=101 with a 99designs/gqlgen user; R775
# TS-Node=101 with an apollo-server user; R776
# 126th language.
#
# WHY async-graphql IS A DISTINCTIVE AXIS-46 OPENER:
#
#   async-graphql/async-graphql by Sun Li (孙立)
#   is the dominant Rust GraphQL server library +
#   the modern choice for new Rust GraphQL
#   projects.  Distinguishing characteristics:
#     1. ASYNC-FIRST — every resolver is async by
#        default; integrates naturally with tokio
#        + async-std without callback ceremony.
#        Juniper (the older alternative) requires
#        more manual async wrapping
#     2. DECLARATIVE MACROS — `#[Object]`,
#        `#[derive(SimpleObject)]`, `#[Subscription]`,
#        `#[derive(InputObject)]`, `#[derive(Enum)]`
#        proc-macros generate the GraphQL schema
#        from Rust types automatically; users
#        write idiomatic Rust + get correct
#        GraphQL schema
#     3. FEDERATION SUPPORT — implements Apollo
#        Federation v2 (`@key`, `@external`,
#        `@requires`, `@provides`); compatible
#        with apollo-router + grafbase + tailcall
#        federation gateways
#     4. SUBSCRIPTIONS via WEBSOCKET — supports
#        graphql-ws + graphql-transport-ws
#        subscription protocols; integrates with
#        axum/actix-web/poem/rocket web frameworks
#     5. DATALOADER PATTERN — built-in DataLoader
#        for batching + caching of resolver
#        fetches; reduces N+1 query patterns
#        automatically
#     6. EXTENSION SYSTEM — pluggable extensions
#        for query logging, depth limiting,
#        complexity analysis, query caching,
#        Apollo Tracing format export
#     7. ~3,660+ STARS ON async-graphql/async-
#        graphql
#     8. ECOSYSTEM-DOMINANT — used by tailcall
#        (this completion), bitloops, monad-bft,
#        rusk, linera-protocol, sui, grafbase
#        (acquired by The Guild), and many other
#        modern Rust GraphQL projects
#
# Maintained by Sun Li (@sunli829) + contributors
# at async-graphql/async-graphql.  License: MIT
# OR Apache-2.0 (dual).
#
# Cross-language CLI library taxonomy after R773:
#   * 125 languages
#   * 481 total CLI library variants (Rust 101 /
#     Go 100 / TS-Node 100)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 38 axes at 1/1/1 three-language symmetric
#   * Axis 46 opens with Rust=async-graphql (this
#     round); pending Go + TS-Node companions
#
# Comparison to other Axis 46 candidates (Rust):
#   * async-graphql (R773 THIS) — Sun Li's modern
#     async GraphQL server; ~3,660 stars;
#     dominant choice for new projects
#   * juniper (graphql-rust/juniper) — older
#     GraphQL server lib; ~5,960 stars; sync API
#     dominant, async retrofitted; was the
#     standard before async-graphql's rise
#   * tailcall (THIS PROJECT) — itself a high-
#     level GraphQL runtime BUILT on async-
#     graphql
#   * roapi — auto-API from datasets; already in
#     corpus
#   * pg_graphql — PostgreSQL-only; not a server
#     library
#
# async-graphql is the chosen Axis 46 opener
# because:
#   - It is the upstream Rust GraphQL server
#     library that EVERY new Rust GraphQL project
#     uses
#   - tailcall uses async-graphql v7 as a DIRECT
#     dependency in Cargo.toml as its core GraphQL
#     execution engine
#   - It is the closest functional analog to Go's
#     99designs/gqlgen (the dominant code-first
#     Go GraphQL server) and TS-Node's apollo-
#     server (the dominant Node.js GraphQL
#     server)
#   - Demonstrates the proc-macro-driven schema-
#     from-types pattern unique to Rust's macro
#     system
#
# Pending companion picks for Axis 46:
#   - Go=101: a Go CLI tool prominently using
#            99designs/gqlgen (the dominant code-
#            first Go GraphQL server library;
#            ~10,000+ stars) as the headline
#            GraphQL library
#   - TS-Node=101: a Node.js CLI tool prominently
#            using @apollo/server (Apollo
#            GraphQL's official server; ~14,000
#            stars) OR graphql-yoga (The Guild's
#            modern alternative; ~8,000+ stars)
#            as the headline GraphQL library
#
# -----------------------------------------------------------------------------
#
# THE tailcall CLI
#
# tailcall is a multi-subcommand CLI built on clap
# v4 with the derive macro.  Invocation:
#   tailcall <subcommand> [args]
#
# Subcommands:
#   start <CONFIGS>...                start the
#                                     GraphQL server
#   check <CONFIGS>...                validate
#                                     composition spec
#   init [FOLDER]                     initialize new
#                                     project
#   gen <CONFIG>                      generate tailcall
#                                     config from
#                                     source file
#
# start flags:
#   <FILES>...                        configuration
#                                     files (local
#                                     paths or
#                                     http(s) URLs;
#                                     space-separated)
#   -v, --verify-ssl <BOOL>           verify SSL for
#                                     remote config
#                                     URLs (default
#                                     true)
#
# check flags:
#   <FILES>...                        configuration
#                                     files
#   -n, --n-plus-one-queries          detect N+1
#                                     query patterns
#   -s, --schema                      display
#                                     resolved GraphQL
#                                     schema
#   -v, --verify-ssl <BOOL>           verify SSL for
#                                     remote config
#                                     URLs (default
#                                     true)
#
# init flags:
#   [FOLDER]                          target folder
#                                     for new project
#                                     (default ".")
#
# gen flags:
#   <FILE>                            input source
#                                     file (OpenAPI
#                                     YAML / gRPC
#                                     proto / Postman
#                                     collection)
#
# Common invocations:
#   # Start a GraphQL server from a local config
#   tailcall start config.graphql
#
#   # Start with multiple config files (modular)
#   tailcall start ./config/base.graphql ./config/extensions.graphql
#
#   # Start with a remote config (over HTTPS)
#   tailcall start https://example.com/config.graphql
#
#   # Start with remote config + skip SSL verify (dev only)
#   tailcall start https://internal/config.graphql -v false
#
#   # Validate a config without starting
#   tailcall check config.graphql
#
#   # Detect N+1 queries in the config
#   tailcall check config.graphql -n
#   tailcall check config.graphql --n-plus-one-queries
#
#   # Display the resolved GraphQL schema
#   tailcall check config.graphql -s
#   tailcall check config.graphql --schema
#
#   # Combine schema display + N+1 detection
#   tailcall check config.graphql -n -s
#
#   # Initialize a new project in current directory
#   tailcall init
#
#   # Initialize a new project in a specific folder
#   tailcall init ./my-graphql-gateway
#
#   # Generate tailcall config from OpenAPI spec
#   tailcall gen openapi.yaml
#
#   # Generate from gRPC proto file
#   tailcall gen service.proto
#
#   # Generate from Postman collection
#   tailcall gen postman.json
#
# OPTIONS (sourced directly from
# https://github.com/tailcallhq/tailcall/blob/main/src/cli/command.rs):
#
# (See subcommand documentation above for the
# complete flag set.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tailcall_subcommands
_tailcall_subcommands=(
    'start:start the GraphQL server on the configured port'
    'check:validate composition spec (config files + N+1 detection)'
    'init:initialize a new tailcall project'
    'gen:generate tailcall config from OpenAPI/gRPC/Postman source'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:subcommand:->subcmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    subcmd)
        _describe -t subcmds 'tailcall subcommand' _tailcall_subcommands && ret=0
        ;;
    args)
        case $words[1] in
            start)
                _arguments \
                    '(-v --verify-ssl)'{-v,--verify-ssl}'=[verify SSL for remote configs (default true)]:bool:(true false)' \
                    '*:config file:_files -g "*.(graphql|gql|yaml|yml)"' \
                    && ret=0
                ;;
            check)
                _arguments \
                    '(-n --n-plus-one-queries)'{-n,--n-plus-one-queries}'[detect N+1 query patterns]' \
                    '(-s --schema)'{-s,--schema}'[display resolved GraphQL schema]' \
                    '(-v --verify-ssl)'{-v,--verify-ssl}'=[verify SSL for remote configs (default true)]:bool:(true false)' \
                    '*:config file:_files -g "*.(graphql|gql|yaml|yml)"' \
                    && ret=0
                ;;
            init)
                _arguments \
                    '1:target folder:_directories' \
                    && ret=0
                ;;
            gen)
                _arguments \
                    '1:source file (OpenAPI/proto/Postman):_files -g "*.(yaml|yml|json|proto|graphql)"' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
