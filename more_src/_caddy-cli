#compdef caddy-cli
# _caddy-cli — Matt Holt Caddy ultimate server with automatic HTTPS CLI alias (caddyserver team, Go); cobra
# upstream: https://github.com/caddyserver/caddy

_caddy-cli() {
    local -a sub=(
        'add-package:install caddy plugins'
        'adapt:adapt config to JSON'
        'build-info:show build info'
        'caddyfile:caddyfile commands'
        'completion:generate completion'
        'environ:print env vars'
        'file-server:simple file server'
        'fmt:format caddyfile'
        'hash-password:hash password'
        'help:show help'
        'json-to-caddyfile:convert json to caddyfile'
        'list-modules:list installed modules'
        'manpage:generate manpages'
        'remove-package:remove caddy plugins'
        'respond:respond with a payload'
        'reverse-proxy:simple reverse proxy'
        'run:start the server'
        'start:start as background daemon'
        'stop:gracefully stop'
        'storage:storage commands'
        'storage export:export storage'
        'storage import:import storage'
        'trust:install trusted CA cert'
        'untrust:remove trusted CA cert'
        'upgrade:upgrade caddy'
        'validate:validate config'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'caddy subcommand' sub ;;
        args)
            case $words[1] in
                run|start) _arguments \
                    '--config=+[config file]:file:_files -g "{Caddyfile,*.{json,yaml,yml}}"' \
                    '-c+[config file]:file:_files -g "{Caddyfile,*.{json,yaml,yml}}"' \
                    '--adapter=+[adapter]:a:(caddyfile json json5 nginx yaml)' \
                    '-a+[adapter]:a:(caddyfile json json5 nginx yaml)' \
                    '--pidfile=+[file]:file:_files' \
                    '--watch[watch config for changes]' \
                    '-w[watch config for changes]' \
                    '--environ[print environment]' \
                    '-e[print environment]' \
                    '--envfile=+[env file]:file:_files' \
                    '--resume[resume from autosave]' \
                    '--pingback=+[address]:str:' \
                    '--skip-install-trust[skip install trust]' ;;
                stop|reload) _arguments \
                    '--config=+[config file]:file:_files' \
                    '--address=+[admin endpoint]:str:' \
                    '--force[force]' ;;
                adapt) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--adapter=+[adapter]:a:(caddyfile json json5 nginx yaml)' \
                    '-a+[adapter]:a:(caddyfile json json5 nginx yaml)' \
                    '--pretty[pretty json]' \
                    '-p[pretty json]' \
                    '--validate[validate]' ;;
                fmt) _arguments \
                    '--overwrite[overwrite]' \
                    '-w[overwrite]' \
                    '--diff[show diff]' \
                    '-d[show diff]' \
                    '*:file:_files -g "Caddyfile"' ;;
                file-server|respond|reverse-proxy) _arguments \
                    '--listen=+[address]:str:' \
                    '--to=+[upstream]:str:' \
                    '--from=+[domain]:str:' \
                    '--access-log[enable access log]' \
                    '--browse[enable directory browsing]' \
                    '--root=+[dir]:dir:_files -/' \
                    '--domain=+[domain]:str:' \
                    '--templates[enable template]' \
                    '--header-down=+[header]:str:' \
                    '--header-up=+[header]:str:' \
                    '--change-host-header[change host header]' \
                    '--insecure[insecure tls]' \
                    '--internal-certs[use caddy CA]' \
                    '--debug[debug]' \
                    '--quic[enable HTTP/3 QUIC]' ;;
                trust|untrust) ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                hash-password) _arguments \
                    '--plaintext=+[password]:str:' \
                    '--algorithm=+[algo]:a:(bcrypt scrypt)' ;;
                validate) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--adapter=+[adapter]:a:(caddyfile json yaml)' ;;
            esac
            ;;
    esac
}

_caddy-cli "$@"
