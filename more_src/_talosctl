#compdef talosctl

local curcontext="$curcontext" state line ret=1

_talosctl_commands() {
  local -a commands=(
    'apply-config:apply configuration to a node'
    'bootstrap:bootstrap the etcd cluster'
    'cluster:manage local docker-based clusters'
    'completion:generate shell completions'
    'config:manage talosctl configuration'
    'containers:list containers'
    'copy:copy files from a node'
    'crashdump:dump debug information'
    'dashboard:launch a node dashboard'
    'disks:get disk information'
    'dmesg:retrieve kernel logs'
    'edit:edit a resource'
    'etcd:manage etcd'
    'events:receive runtime events'
    'gen:generate secrets, PKI, and tokens'
    'get:get a specific resource'
    'health:check cluster health'
    'images:list container images'
    'inspect:inspect a resource'
    'kubeconfig:download admin kubeconfig'
    'list:list files on a node'
    'logs:retrieve logs for a service'
    'memory:show memory usage'
    'mounts:list mounts'
    'netstat:show network connections'
    'patch:patch a resource'
    'pcap:capture network packets'
    'processes:list running processes'
    'read:read a file on a node'
    'reboot:reboot a node'
    'reset:reset a node'
    'restart:restart a service'
    'rollback:rollback a node to previous configuration'
    'service:manage system services'
    'shutdown:shutdown a node'
    'stats:get container stats'
    'support:generate a support bundle'
    'time:get time from a node'
    'upgrade:upgrade Talos on a node'
    'upgrade-k8s:upgrade Kubernetes'
    'usage:retrieve disk usage'
    'validate:validate a configuration'
    'version:print version'
  )
  _describe -t commands 'talosctl command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--cluster=[cluster name]:name' \
  '--context=[context to use]:context' \
  '(-e --endpoints)'{-e,--endpoints}'=[override endpoints]:endpoints' \
  '(-n --nodes)'{-n,--nodes}'=[target node addresses]:nodes' \
  '--talosconfig=[path to talosconfig]:file:_files' \
  '1: :_talosctl_commands' \
  '*:: :->args' && ret=0

return ret
