#compdef kwalletd6
# Documentation: https://man.archlinux.org/search?q=kwalletd6
# Reference accessed: 2026-05-16

# kwalletd6: KDE Plasma 6 wallet daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--debug[enable debug output]' \
  '*::kwalletd6 args:_files' && ret=0
return ret
