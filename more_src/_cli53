#compdef cli53

# Zsh completion for cli53 (AWS Route53 CLI tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'create:create a hosted zone'
      'delete:delete a hosted zone'
      'list:list hosted zones'
      'import:import DNS records from BIND format'
      'export:export DNS records to BIND format'
      'rrcreate:create a resource record'
      'rrdelete:delete a resource record'
      'rrpurge:purge all resource records'
      'instances:list EC2 instances'
      'dsync:sync DNS with instance data'
    )
    _describe -t commands 'cli53 command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (create)
        _arguments \
          '--comment[zone comment]:comment' \
          '--vpc-id[VPC ID for private zone]:vpc-id' \
          '--vpc-region[VPC region]:region' \
          '--delegation-set-id[delegation set ID]:id' \
          '1:domain name' && ret=0
        ;;
      (delete)
        _arguments \
          '--purge[delete all records first]' \
          '1:zone' && ret=0
        ;;
      (import)
        _arguments \
          '--file[BIND zone file]:file:_files' \
          '--editauth[edit SOA and NS records]' \
          '--replace[replace existing records]' \
          '--wait[wait for sync]' \
          '--dry-run[show changes without applying]' \
          '1:zone' && ret=0
        ;;
      (export)
        _arguments \
          '--full[include SOA and NS records]' \
          '1:zone' && ret=0
        ;;
      (rrcreate)
        _arguments \
          '--replace[replace existing record]' \
          '--append[append to existing record]' \
          '--wait[wait for sync]' \
          '--ttl[TTL value]:ttl' \
          '-i[use identifier for weighted/latency]:identifier' \
          '--weight[weight for weighted routing]:weight' \
          '--region[region for latency routing]:region' \
          '--failover[failover type]:type:(PRIMARY SECONDARY)' \
          '--health-check[health check ID]:id' \
          '--alias-target[alias target]:target' \
          '1:zone' \
          '2:record spec' && ret=0
        ;;
      (rrdelete)
        _arguments \
          '--wait[wait for sync]' \
          '-i[identifier]:identifier' \
          '1:zone' \
          '2:name' \
          '3:type:(A AAAA CNAME MX NS PTR SOA SRV TXT CAA)' && ret=0
        ;;
      (rrpurge)
        _arguments \
          '--confirm[confirm purge]' \
          '--wait[wait for sync]' \
          '1:zone' && ret=0
        ;;
      (list)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
