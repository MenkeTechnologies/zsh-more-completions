#compdef dwi2fod
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwi2fod.html
# Source: MRtrix3/mrtrix3 cmd/dwi2fod.cpp — estimate fibre Orientation Distribution Functions from DWI (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-directions+[directions file]:file:_files' \
    '-lmax+[max harmonic orders (comma-separated per tissue)]:order:_default' \
    '-mask+[mask image]:file:_files -g "*.{nii,nii.gz,mif}"' \
    '-shells+[comma-separated b-value shells]:shells:_default' \
    '-fslgrad+[FSL-format bvecs bvals]:files:_files' \
    '-grad+[MRtrix-format gradient file]:file:_files' \
    '-bvalue_scaling+[apply b-value scaling]:mode:(yes no auto)' \
    '1:algorithm:(csd msmt_csd)' \
    '2:dwi (input DWI):_files -g "*.{nii,nii.gz,mif}"' \
    '*:response/odf pairs:_files' \
    && ret=0

return ret
