#compdef wuzz
# Documentation: https://man.archlinux.org/search?q=wuzz
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-X+[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '*-H+[HTTP header]:header' \
  '-d+[request body data]:data' \
  '-u+[initial URL]:url' \
  '-t+[TLS config]:config file:_files' \
  '-c+[cookie jar file]:cookie file:_files' \
  '--insecure[skip TLS certificate verification]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
