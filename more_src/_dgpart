#compdef dgpart
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/dgmap.1.html
# PT-Scotch: compute a distributed partition of a source graph

local ret=1

_arguments -s \
  '-c-[choose default mapping strategy (b,q,s,t,x options)]:options' \
  '-h[display help]' \
  '-m-[use parallel mapping strategy]:strat' \
  '-r-[set root process for centralized files (default 0)]:pnum' \
  '-V[display version and copyright]' \
  '-v-[set verbose mode (m,s,t)]:verb' \
  '*:file:_files' && ret=0

return ret
