#compdef cargo-tauri

# Zsh completion for cargo-tauri - Tauri application CLI (cargo subcommand)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new Tauri project in an existing directory'
  'dev:run the application in development mode'
  'build:build the application for production'
  'bundle:generate bundles for the application'
  'android:android specific commands'
  'ios:iOS specific commands'
  'info:show Tauri environment info'
  'add:add a Tauri plugin to your project'
  'remove:remove a Tauri plugin from your project'
  'plugin:manage Tauri plugins'
  'icon:generate icons from a source image'
  'signer:tauri updater signing utilities'
  'completions:generate shell completions'
  'migrate:migrate from v1 to v2'
  'permission:manage plugin permissions'
  'capability:manage plugin capabilities'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'tauri command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments \
          '(-f --force)'{-f,--force}'[force overwrite existing files]' \
          '(-l --log)'{-l,--log}'[enable logging]' \
          '(-d --directory)'{-d,--directory}'[set target directory]:dir:_directories' \
          '(-t --tauri-path)'{-t,--tauri-path}'[path to Tauri project]:path:_directories' \
          '(-A --app-name)'{-A,--app-name}'[app name]:name:' \
          '(-W --window-title)'{-W,--window-title}'[window title]:title:' \
          '(-D --dist-dir)'{-D,--dist-dir}'[web assets location]:dir:_directories' \
          '(-P --dev-path)'{-P,--dev-path}'[url of dev server]:url:' \
          '--before-dev-command[command to run before starting dev]:command:' \
          '--before-build-command[command to run before build]:command:' \
          '--ci[skip interactive prompts]' && ret=0
        ;;
      dev)
        _arguments \
          '(-r --runner)'{-r,--runner}'[binary to use to run the app]:runner:' \
          '(-t --target)'{-t,--target}'[target triple]:target:' \
          '(-f --features)'{-f,--features}'[features to enable]:features:' \
          '(-e --exit-on-panic)'{-e,--exit-on-panic}'[exit on panic]' \
          '(-c --config)'{-c,--config}'[JSON string or path to tauri config]:config:' \
          '--release[run in release mode]' \
          '--args[pass args to the binary]:args:' \
          '--no-watch[disable file watching]' \
          '--no-dev-server[skip dev server]' \
          '--no-dev-server-wait[do not wait for dev server]' \
          '--port[dev server port]:port:' \
          '--host[run dev server at specified host]:host:' && ret=0
        ;;
      build)
        _arguments \
          '(-r --runner)'{-r,--runner}'[binary to use to build]:runner:' \
          '(-d --debug)'{-d,--debug}'[build with debug profile]' \
          '(-t --target)'{-t,--target}'[target triple]:target:' \
          '(-f --features)'{-f,--features}'[features to enable]:features:' \
          '(-b --bundles)'{-b,--bundles}'[which bundles to package]:bundles:(deb appimage msi app dmg updater)' \
          '(-c --config)'{-c,--config}'[JSON string or path to tauri config]:config:' \
          '--ci[skip interactive prompts]' \
          '--no-bundle[skip bundling]' && ret=0
        ;;
      android|ios)
        local -a mobile_commands=(
          'init:initialize mobile target'
          'dev:run in development'
          'build:build the application'
          'open:open in IDE'
        )
        _describe -t mobile-commands 'mobile command' mobile_commands
        ;;
      plugin)
        local -a plugin_commands=(
          'new:create a new plugin'
          'init:initialize plugin in existing dir'
          'android:android plugin commands'
          'ios:iOS plugin commands'
        )
        _describe -t plugin-commands 'plugin command' plugin_commands
        ;;
      completions)
        _arguments \
          '(-s --shell)'{-s,--shell}'[shell to generate completions for]:shell:(bash zsh fish powershell elvish)' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' && ret=0
        ;;
      icon)
        _arguments \
          '(-o --output)'{-o,--output}'[output directory]:dir:_directories' \
          '(-p --png)'{-p,--png}'[custom png sizes to generate]:sizes:' \
          '*:icon:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
