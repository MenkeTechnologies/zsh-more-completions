#compdef kubectl-shovel
# Documentation: https://github.com/dodopizza/kubectl-shovel/blob/master/cli/docs/kubectl-shovel.md
# kubectl-shovel - gather diagnostics from running k8s dotnet applications

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for kubectl-shovel]' \
  '--pod-name=[target pod (required)]:pod' \
  '(-c --container)'{-c,--container}'=[target container in pod]:container' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-p --process-id)'{-p,--process-id}'=[process ID to collect from]:pid' \
  '--image=[dumper image to use for job]:image' \
  '--limit-cpu=[limit maximal CPU consumption for the job]:cpu' \
  '--limit-memory=[limit maximal memory consumption for the job]:memory' \
  '--output-host-path=[host folder for storing artifacts]:path:_files -/' \
  '(-t --store-output-on-host)'{-t,--store-output-on-host}'[store output on node instead of downloading locally]' \
  '--diag[enable dump collection diagnostic logging]' \
  '--context=[name of the kubeconfig context to use]:context' \
  '--kubeconfig=[path to the kubeconfig file to use]:file:_files' \
  '*:command:(coredump dump gcdump trace version completion)' && ret=0

return ret
