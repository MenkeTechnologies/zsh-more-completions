#compdef wily

# Zsh completion for wily - Python code complexity over time

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-c,--config}'=[config file]:file:_files' \
  '--debug[enable debug output]' \
  {-p,--path}'=[path to repository]:directory:_directories' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build the wily cache'
      'report:show a report for a file'
      'graph:graph a metric for a file'
      'rank:rank files by a metric'
      'diff:show diff of metrics'
      'index:show the index of files'
      'clean:clean the wily cache'
      'setup:run the setup wizard'
    )
    _describe -t commands 'wily command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-n,--max-revisions}'=[maximum number of revisions]:int' \
          {-o,--operators}'=[operators to use]:operator:(maintainability cyclomatic_complexity halstead raw loc)' && ret=0
        ;;
      report)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-n=[number of revisions]:int' \
          '1:file:_files' \
          '*:metrics:(maintainability.mi cyclomatic_complexity.complexity loc.sloc halstead.h1 raw.loc)' && ret=0
        ;;
      graph)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'=[output file]:file:_files' \
          '1:file:_files' \
          '2:metric:(maintainability.mi cyclomatic_complexity.complexity loc.sloc halstead.h1 raw.loc)' && ret=0
        ;;
      rank)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-t,--threshold}'=[threshold value]:float' \
          '1:metric:(maintainability.mi cyclomatic_complexity.complexity loc.sloc halstead.h1 raw.loc)' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-r,--revision}'=[revision to compare]:revision' \
          '--metrics=[metrics to compare]:metric:(maintainability.mi cyclomatic_complexity.complexity loc.sloc halstead.h1 raw.loc)' \
          '1:file:_files' && ret=0
        ;;
      index)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:file:_files' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-y,--yes}'[skip confirmation prompt]' && ret=0
        ;;
    esac
    ;;
esac

return ret
