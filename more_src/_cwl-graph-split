#compdef cwl-graph-split
# Documentation: https://github.com/common-workflow-language/cwl-utils
# Split a packed CWL document into separate files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --mainfile)'{-m,--mainfile}'=[name of the main document]:name' \
  '(-f --output-format)'{-f,--output-format}'=[format of the output CWL files]:format:(json yaml)' \
  '(-p --pretty)'{-p,--pretty}'[beautify the output CWL document (yaml only)]' \
  '(-C --outdir)'{-C,--outdir}'=[output folder for the unpacked CWL files]:dir:_files -/' \
  '*:packed CWL document:_files -g "*.cwl"' && ret=0

return ret
