#compdef refind-mkfont
# Documentation: refind/fonts/mkfont.sh in upstream rEFInd source
# Reference accessed: 2026-05-16
# Verified: upstream rEFInd source mkfont.sh - no CLI flags, only
# positional args (font name, size pt, y-offset, output PNG).
# Wraps ImageMagick `convert`.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# refind-mkfont: create rEFInd font file from a system font
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:font name:' \
  '2:size in points:' \
  '3:Y offset:' \
  '4:output PNG:_files -g "*.png(-.)"' && ret=0
return ret
