#compdef aptitude-cli
# _aptitude-cli — Debian aptitude TUI APT frontend CLI alias (Debian project / Daniel Burrows, C++); custom argparse
# upstream: https://salsa.debian.org/apt-team/aptitude

_aptitude-cli() {
    local -a sub=(
        'install:install packages'
        'remove:remove packages'
        'purge:purge packages and config'
        'hold:mark package as held'
        'unhold:mark package as not held'
        'markauto:mark as automatically installed'
        'unmarkauto:mark as manually installed'
        'forbid-version:forbid version'
        'update:update package list'
        'safe-upgrade:safe upgrade'
        'full-upgrade:full upgrade'
        'dist-upgrade:full upgrade (alias)'
        'forget-new:forget new packages list'
        'search:search packages'
        'show:show package info'
        'showsrc:show source package info'
        'source:download source'
        'changelog:show changelog'
        'download:download package'
        'reinstall:reinstall packages'
        'why:why is a package installed'
        'why-not:why is a package not installable'
        'add-user-tag:add user tag'
        'remove-user-tag:remove user tag'
        'build-dep:install build dependencies'
        'build-depends:install build dependencies'
        'help:show help'
        'version:show version'
        'clean:remove downloaded files'
        'autoclean:remove old downloaded files'
        'keep:cancel pending actions'
        'keep-all:cancel pending actions on all'
        'no-act:show actions only'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--simulate[simulate]' \
        '-s[simulate]' \
        '--assume-yes[assume yes]' \
        '-y[assume yes]' \
        '--no-act[no act]' \
        '-D[show dep info]' \
        '--show-deps[show dep info]' \
        '-F+[display format]:str:' \
        '--display-format=+[display format]:str:' \
        '-O+[order]:str:' \
        '--sort=+[order]:str:' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-Z[show size changes]' \
        '--schedule-only[schedule only]' \
        '--with-recommends[with recommends]' \
        '--without-recommends[without recommends]' \
        '--with-suggests[with suggests]' \
        '--without-suggests[without suggests]' \
        '--purge-unused[purge unused]' \
        '--target-release=+[target release]:str:' \
        '-t+[target release]:str:' \
        '--allow-untrusted[allow untrusted]' \
        '--no-install-recommends[no install recommends]' \
        '-r[install recommends]' \
        '-R[no install recommends]' \
        '--show-summary=+[show summary]:s:(no-summary first-package first-package-and-type all-packages all-packages-with-dep-versions)' \
        '-i[install]' \
        '-u[update]' \
        '-S+[state file]:file:_files' \
        '--state-file=+[state file]:file:_files' \
        '-o+[option]:str:' \
        '--option=+[option]:str:' \
        '-c+[config file]:file:_files' \
        '--config-file=+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aptitude subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|purge|reinstall|hold|unhold|markauto|unmarkauto|forbid-version|search|show|source|download|changelog|why|why-not|build-dep|build-depends) _arguments '*:package:' ;;
                add-user-tag|remove-user-tag) _arguments \
                    '1:tag:' \
                    '*:package:' ;;
            esac
            ;;
    esac
}

_aptitude-cli "$@"
