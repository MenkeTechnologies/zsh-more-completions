#compdef acpisrc
# Documentation: acpisrc
# Source: acpica/acpica source/tools/acpisrc/asmain.c (master) — ACPICA source code translator (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[check file for non-printable characters]:file:_files' \
    '-c[generate cleaned source]' \
    '-h[insert dual-license header]' \
    '-i[cleanup macro indentation]' \
    '(-l -u)-l[generate Linux source]' \
    '(-l -u)-u[generate custom source translation]' \
    '-d[leave debug statements in code]' \
    '-s[source statistics only]' \
    '(-v -vd)-v[show version]' \
    '(-v -vd)-vd[show build date]' \
    '-vb[verbose mode]' \
    '-y[suppress overwrite prompts]' \
    '1:source dir/file:_files' \
    '2::output dir/file:_files' \
    && ret=0

return ret
