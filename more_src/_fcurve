#compdef fcurve
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fcurve.txt
# Bin column data into a light curve

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "gtifile=[good time interval file]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "timecol=[time column name]:" \
  "columns=[columns to bin]:" \
  "binsz=[bin size in time units]:" \
  "lowval=[lowest value to include]:" \
  "highval=[highest value to include]:" \
  "binmode=[binning mode]:" \
  "extname=[output extension name]:" \
  "copyprime=[copy primary array]:bool:(yes no)" \
  "copyall=[copy all other extensions]:bool:(yes no)" \
  "sensecase=[case sensitive column names]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
