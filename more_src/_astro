#compdef astro

# Zsh completion for Astro web framework CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'dev:Start the development server'
      'build:Build your project'
      'preview:Preview your build locally'
      'add:Add an integration'
      'check:Check your project for errors'
      'sync:Generate content collection types'
      'preferences:Configure user preferences'
      'telemetry:Configure telemetry settings'
    )
    _describe -t commands 'astro command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      dev)
        _arguments -s -S \
          '--port=[port to listen on]:port' \
          '--host=[network address to listen on]:host' \
          '--open[open the app in the browser on server start]' \
          '--root=[path to project root]:directory:_directories' \
          '--config=[path to config file]:config file:_files' \
          '--site=[site URL for the build]:url' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--root=[path to project root]:directory:_directories' \
          '--config=[path to config file]:config file:_files' \
          '--site=[site URL for the build]:url' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      preview)
        _arguments -s -S \
          '--port=[port to listen on]:port' \
          '--host=[network address to listen on]:host' \
          '--open[open the app in the browser on server start]' \
          '--root=[path to project root]:directory:_directories' \
          '--config=[path to config file]:config file:_files' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      add)
        _arguments -s -S \
          '--yes[accept all prompts]' \
          '--root=[path to project root]:directory:_directories' \
          '-h[show help]' \
          '--help[show help]' \
          '1:integration' && ret=0
        ;;
      check)
        _arguments -s -S \
          '--watch[watch for file changes]' \
          '--root=[path to project root]:directory:_directories' \
          '--config=[path to config file]:config file:_files' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '--root=[path to project root]:directory:_directories' \
          '--config=[path to config file]:config file:_files' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      preferences)
        _arguments -s -S \
          '--global[apply preferences globally]' \
          '-h[show help]' \
          '--help[show help]' \
          '1:action:(enable disable reset list)' \
          '2:preference:(devToolbar)' && ret=0
        ;;
      telemetry)
        _arguments -s -S \
          '-h[show help]' \
          '--help[show help]' \
          '1:action:(enable disable reset status)' && ret=0
        ;;
    esac
    ;;
esac

return ret
