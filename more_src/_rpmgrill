#compdef rpmgrill
# Documentation: https://www.mankier.com/1/rpmgrill
# Reference accessed: 2026-05-16
# Verified: mankier rpmgrill(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# rpmgrill: post-build RPM lint / inspection framework
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show usage]' \
  '--version[show version]' \
  '--man[display man page]' \
  '--list-plugins[list available plugins and exit]' \
  '--disable=[disable comma-separated plugins]:plugins:' \
  '--verbose[show progress messages]' \
  '--blacklist-config=[YAML config to suppress test failures]:file:_files' \
  '*:base dir:_files -/' && ret=0
return ret
