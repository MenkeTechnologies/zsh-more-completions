#compdef hoverctl

# Zsh completion for hoverctl - Hoverfly API simulation CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start a Hoverfly instance'
  'stop:stop a Hoverfly instance'
  'mode:get or set the Hoverfly mode'
  'destination:get or set the Hoverfly destination'
  'middleware:get or set the Hoverfly middleware'
  'export:export a Hoverfly simulation'
  'import:import a Hoverfly simulation'
  'delete:delete Hoverfly simulation data'
  'logs:get the Hoverfly logs'
  'status:get the Hoverfly status'
  'targets:get the registered Hoverfly targets'
  'version:get the Hoverfly version'
  'config:show the hoverctl configuration'
  'login:login to Hoverfly'
  'flush:flush the Hoverfly cache'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--host=[Hoverfly host]:host' \
  '--admin-port=[admin port]:port' \
  '--proxy-port=[proxy port]:port' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--target=[target Hoverfly instance]:target' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'hoverctl command' commands && ret=0
    ;;
  args)
    case $words[1] in
      start)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--webserver[start in webserver mode]' \
          '--listen-on-host=[listen on host]:host' \
          '--admin-port=[admin port]:port' \
          '--proxy-port=[proxy port]:port' \
          '--cert=[path to certificate]:file:_files' \
          '--key=[path to key]:file:_files' \
          '--disable-tls[disable TLS verification]' \
          '--upstream-proxy=[upstream proxy URL]:url' \
          '--cache[enable request/response caching]' && ret=0
        ;;
      mode)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:mode:(simulate capture modify synthesize spy diff)' && ret=0
        ;;
      export|import)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:file:_files' && ret=0
        ;;
      login)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--username=[username]:username' \
          '--password=[password]:password' && ret=0
        ;;
      delete)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--force[skip confirmation]' && ret=0
        ;;
      *)
        _arguments \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
