#compdef peukerdouglas PeukerDouglas
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/PeukerDouglas.html
# TauDEM: Peuker-Douglas upward-curved cell indicator grid

local ret=1

_arguments -s -S \
  '-fel[input float elevation grid]:felfile:_files' \
  '-ss[output stream source indicator grid]:ssfile:_files' \
  '-par[smoothing weights: center side diagonal (default 0.4 0.1 0.05)]:center weight:' \
  '*:file:_files' && ret=0

return ret
