#compdef ceph-syn

# ceph-syn: synthetic Ceph client for benchmarks
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '--conf=[ceph config file]:file:_files -g "*.conf"' \
  '--cluster=[cluster name]:name:' \
  '-i[id]:id:' \
  '--id=[id]:id:' \
  '-n[name]:name:' \
  '--name=[name]:name:' \
  '--syn[synthetic operation]:op:' \
  '--num-client=[number of clients]:n:' \
  '*::ceph-syn args:_files' && ret=0
return ret
