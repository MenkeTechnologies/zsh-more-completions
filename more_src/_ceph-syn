#compdef ceph-syn
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-syn/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-syn: synthetic Ceph client for benchmarks
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[detach from console and daemonize]' \
  '(-c --conf)'{-c+,--conf=}'[use this ceph.conf instead of default]:file:_files -g "*.conf"' \
  '-m+[connect to specified monitor]:monaddress\:port:' \
  '*--syn=[synthetic workload spec]:workloadspec:' \
  '--num_client=[number of client threads]:n:' \
  '*::ceph-syn args:_files' && ret=0
return ret
