#compdef kubectx
# Documentation: https://github.com/ahmetb/kubectx
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubectx (switch Kubernetes contexts)

local curcontext="$curcontext" state line ret=1

local -a contexts
contexts=(${(f)"$(kubectl config get-contexts -o name 2>/dev/null)"})

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help message]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-c --current)'{-c,--current}'[Show current context name]' \
  '(-u --unset)'{-u,--unset}'[Unset the current context]' \
  '(-r --readonly)'{-r,--readonly}'[Launch a read-only shell for a context]:context:($contexts)' \
  '(-s --shell)'{-s,--shell}'[Start a shell session pinned to a context]:context:($contexts)' \
  '-d[Delete contexts]:context:($contexts)' \
  '1:context:->ctx' && ret=0

case "$state" in
  ctx)
    _describe -t contexts 'kubernetes context' contexts && ret=0
    ;;
esac

return ret
