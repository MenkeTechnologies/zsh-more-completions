#compdef lutable
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss91.html
# KAPPA LUTABLE - manipulate an image-display colour table

local ret=1

_arguments -C \
  'DEVICE=[graphics device to use]:device:' \
  'COLTAB=[lookup table selection]:table:(Negative Colour Grey External)' \
  'FULL=[preserve the entire colour table]:flag:(TRUE FALSE)' \
  'LUT=[NDF containing the lookup table data array]:NDF file:_files' \
  'MAPPING=[colour distribution among pens]:mapping:(Histogram Linear Logarithmic)' \
  'NDF=[input NDF for histogram-equalisation mapping]:NDF file:_files' \
  'NN=[nearest-neighbour interpolation]:flag:(TRUE FALSE)' \
  'PERCENTILES=[histogram range boundaries]:percentiles:' \
  'SHADE=[histogram shading bias (-1 to +1)]:shade:' \
  '*:NDF file:_files' && ret=0

return ret
