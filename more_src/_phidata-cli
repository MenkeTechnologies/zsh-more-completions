#compdef phidata-cli
# Documentation: https://docs.phidata.com
# Reference accessed: 2026-05-23
# Verified: phi --help (phidata PyPI package).

# Zsh completion for phidata-cli - Phidata AI engineer toolkit (binary phi)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'phi command' \
      'init[initialize phidata]' \
      'reset[reset phi installation]' \
      'auth[authenticate with phidata.com]' \
      'ping[ping phidata servers]' \
      'config[print phi config]' \
      'set[set cwd as active workspace]' \
      'start[start resources from resources.py]' \
      'stop[stop resources]' \
      'patch[update resources]' \
      'restart[restart resources]' \
      'ws[manage workspaces]' && ret=0
    ;;
  args)
    case $line[1] in
      ws)
        if (( CURRENT == 3 )); then
          _values 'ws command' \
            'create[create workspace]' \
            'setup[setup workspace from directory]' \
            'up[start workspace resources]' \
            'down[stop workspace resources]' \
            'patch[update workspace resources]' \
            'restart[restart workspace resources]' \
            'config[print workspace config]' \
            'delete[delete workspace record]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
