#compdef TotalSegmentator
# Documentation: https://github.com/wasserth/TotalSegmentator
# Robust segmentation of anatomical structures in CT/MR images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input file or dicom folder]:input:_files' \
  '-o[output directory]:output:_files -/' \
  '(-ta --task)'{-ta,--task}'[task name]:task:' \
  '--device[compute device]:device:(cpu gpu)' \
  '--fast[use lower resolution model]' \
  '--save_lowres[save at model resolution]' \
  '--resampling_order[spline interpolation order]:order:' \
  '*--roi_subset[only segment these class names]:class:' \
  '--robust_crop[use better but slower cropping]' \
  '--preview[generate 3D rendering preview]' \
  '--ml[output single multilabel nifti]' \
  '--statistics[generate statistics.json]' \
  '--statistics_extra[additional morphometric statistics]' \
  '--radiomics[generate radiomics features json]' \
  '--output_type[output format]:type:(nifti dicom_seg dicom_rtstruct)' \
  '--report[write json run manifest]' \
  '--list-tasks[print available tasks]' \
  '--list-classes[print task classes]' \
  '--higher_order_resampling[smoother segmentations]' \
  '--nr_thr_saving[thread count for saving]:threads:' \
  '--save_probabilities[save softmax probabilities]' \
  '--body_seg[crop to body region]' \
  '--force_split[split image into 3 parts]' \
  '*:arg:_files' && ret=0

return ret
