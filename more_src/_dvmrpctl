#compdef dvmrpctl
# _dvmrpctl — OpenBSD dvmrpctl (control + introspect dvmrpd(8) DVMRP multicast routing daemon; show neighbors/interfaces/IGMP/MFC/RIB/summary, log level brief/verbose)
# upstream: https://github.com/openbsd/src (usr.sbin/dvmrpctl)
# Commands from usr.sbin/dvmrpctl/dvmrpctl.8 on tip.

_dvmrpctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'dvmrpctl command' \
                '(show:show subsystem state (summary|interfaces|neighbor|igmp|mfc|rib) log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(summary interfaces neighbor igmp mfc rib)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_dvmrpctl "$@"
