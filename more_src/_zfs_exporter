#compdef zfs_exporter
# Documentation: https://github.com/pdf/zfs_exporter
# Prometheus exporter for ZFS pool and dataset metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--web.listen-address=[address on which to expose metrics and web interface]:addr' \
  '--web.telemetry-path=[path under which to expose metrics]:path' \
  '--web.disable-exporter-metrics[exclude metrics about the exporter itself]' \
  '--web.config.file=[path to TLS/auth config file]:file:_files' \
  '--web.systemd-socket[use systemd socket activation (Linux only)]' \
  '--collector.dataset-filesystem[enable the dataset-filesystem collector]' \
  '--collector.dataset-snapshot[enable the dataset-snapshot collector]' \
  '--collector.dataset-volume[enable the dataset-volume collector]' \
  '--collector.pool[enable the pool collector]' \
  '--properties.dataset-filesystem=[properties to collect for filesystems]:props' \
  '--properties.dataset-snapshot=[properties to collect for snapshots]:props' \
  '--properties.dataset-volume=[properties to collect for volumes]:props' \
  '--properties.pool=[properties to collect for pools]:props' \
  '--deadline=[max duration before returning cached data]:dur' \
  '*--pool=[name of pool to collect (repeatable)]:pool' \
  '--exclude=[exclude datasets matching the regex]:regex' \
  '--log.level=[only log messages with given severity or above]:level' \
  '--log.format=[output format of log messages]:format:(logfmt json)' \
  '--version[show application version]' && ret=0

return ret
