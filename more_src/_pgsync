#compdef pgsync

# Zsh completion for pgsync - sync Postgres data between databases

_arguments -s -S \
  '--from=[source database URL]:url:' \
  '--to=[destination database URL]:url:' \
  '--to-safe[prevent writes to production databases]' \
  '--schema-first[copy schema before data]' \
  '--schema-only[copy schema only]' \
  '--all-schemas[copy all schemas]' \
  '--no-rules[do not apply data rules]' \
  '--no-sequences[do not sync sequences]' \
  '--init[create configuration file]' \
  '--config=[config file]:file:_files -g "*.yml"' \
  '--db=[database group]:group:' \
  '--debug[enable debug logging]' \
  '--in-batches[sync in batches]' \
  '--batch-size=[batch size]:size:' \
  '--sleep=[sleep between batches]:seconds:' \
  '--fail-fast[exit on first error]' \
  '--defer-constraints[defer constraints during sync]' \
  '--disable-user-triggers[disable user triggers]' \
  '--disable-integrity[disable integrity checks]' \
  '--truncate[truncate tables before syncing]' \
  '--preserve[preserve existing rows]' \
  '--overwrite[overwrite existing rows]' \
  '--jobs=[parallel jobs]:jobs:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:tables:'
