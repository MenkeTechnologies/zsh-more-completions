#compdef klog
# Documentation: https://klog.jotaen.net
# Reference accessed: 2026-05-19
# Verified: upstream klog.jotaen.net command-line tool documentation.
# Added real subcommands (evaluation/manipulation/management) and
# documented common flags in place of bare passthrough.

# jotaen/klog - plain-text time tracking
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'print:pretty-print records to the terminal'
  'total:evaluate the overall total time'
  'report:print a chronological calendar timeline'
  'today:display the current day separately'
  'tags:aggregate total times by tags'
  'info:show filtering information'
  'track:add new entries to records'
  'start:create an open-ended time range'
  'stop:close an open-ended time range'
  'pause:pause an activity without stopping it'
  'create:create a new empty record'
  'bookmarks:manage file bookmarks'
  'edit:open files in the editor'
  'goto:open the file explorer at a bookmark'
  'config:show configuration options'
  'json:convert klog data to JSON'
  'version:show version information'
)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'klog command' commands && ret=0 ;;
  args)
    _arguments -s -S \
      '--date=[specify the designated date]:date:' \
      '*--tag=[filter by tag]:tag:' \
      '--since=[filter from a specific date]:date:' \
      '--until=[filter until a specific date]:date:' \
      '--period=[filter by time period]:period:' \
      '--diff[calculate should-total difference]' \
      '--now[simulate open ranges as closed now]' \
      '--quiet[omit descriptive output]' \
      '--fill[print a consecutive date stream]' \
      '--follow[keep the process open for live updates]' \
      '*:file:_files -g "*.klg"' && ret=0
    ;;
esac
return ret
