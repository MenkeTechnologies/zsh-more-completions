#compdef rosegarden
# Documentation: https://man.archlinux.org/search?q=rosegarden
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options]' \
  '--display=[X display]:display:' \
  '--nosound[disable sound]' \
  '--nosplash[disable splash screen]' \
  '--existingsequencer[use existing sequencer]' \
  '--non-unique[allow non-unique instance]' \
  '*:file:_files -g "*.{rg,rgp,mid,midi,xml}"' && ret=0

return ret
