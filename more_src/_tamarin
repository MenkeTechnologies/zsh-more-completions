#compdef tamarin-prover
# Documentation: https://man.archlinux.org/search?q=tamarin-prover
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'interactive:start interactive proof browser'
  'batch:run a batch proof'
  'test:test installation'
  'variants:print variants'
  'analyze:analyze theory file'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '--prove+[try to prove lemma]:lemma:' \
  '--lemma+[only specific lemma]:lemma:' \
  '--quit-on-warning[quit on warning]' \
  '--no-color[no color output]' \
  '(-D --diff)'{-D,--diff}'[observational equivalence]' \
  '(-O --output)'{-O+,--output=}'[output file]:file:_files' \
  '--proof-output+[proof output dir]:dir:_files -/' \
  '--html+[HTML output dir]:dir:_files -/' \
  '--dot+[dot output dir]:dir:_files -/' \
  '--json+[JSON output dir]:dir:_files -/' \
  '--bound+[step bound]:n:' \
  '--heuristic+[heuristic]:h:' \
  '--stop-on-trace+[trace mode]:m:(dfs bfs seqdfs)' \
  '(-p --port)'{-p+,--port=}'[interactive port]:p:' \
  '--interface+[interface to listen on]:if:' \
  '--workdir+[working dir]:dir:_files -/' \
  '--auto-sources[auto sources]' \
  '*-D+[define cpp]:macro:' \
  '*: :_files -g "*.spthy *.sapic"' && ret=0

return ret
