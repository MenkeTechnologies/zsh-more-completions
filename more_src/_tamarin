#compdef tamarin-prover
# Documentation: https://github.com/tamarin-prover/tamarin-prover/tree/master/src/Main
# Reference accessed: 2026-05-21
# Verified: upstream src/Main/Mode/{Batch,Interactive}.hs and src/Main/{TheoryLoader,Environment}.hs.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--prove=[prove lemmas matching prefix/name (repeatable)]:lemma:' \
  '--lemma=[select lemma(s) by name or prefix]:lemma:' \
  '--stop-on-trace=[trace search mode (default DFS)]:mode:(DFS BFS SEQDFS SORRY NONE)' \
  '(-b --bound)'{-b,--bound}'=[bound the proof depth]:int:' \
  '--heuristic=[proof method ranking sequence]:h:' \
  '--partial-evaluation=[partially evaluate multiset rewriting]:mode:(SUMMARY VERBOSE)' \
  '*'{-D,--defines}'=[define preprocessor flag]:macro:' \
  '--diff[observational equivalence mode using diff terms]' \
  '--quit-on-warning[strict mode: quit on any warning]' \
  '--auto-sources[try to auto-generate sources lemmas]' \
  '--oraclename=[path to oracle heuristic]:file:_files' \
  '--oracle-only[stop proof search if oracle does not rank any goal]' \
  '--quiet[hide oracle/tactic computation steps]' \
  '(-v --verbose)'{-v,--verbose}'[display full proof calculation info]' \
  '(-c --open-chains)'{-c,--open-chains}'=[open chains limit (default 10)]:n:' \
  '(-s --saturation)'{-s,--saturation}'=[saturation limit (default 5)]:n:' \
  '(-d --derivcheck-timeout)'{-d,--derivcheck-timeout}'=[derivation check timeout secs (default 5)]:n:' \
  '--no-reuse[do not export reuse or source lemmas]' \
  '--no-restrictions[do not export restrictions]' \
  '--replication-bound=[replication bound for DeepSec export]:n:' \
  '--no-compress[do not use compressed sequent visualization]' \
  '--parse-only[just parse and pretty print input]' \
  '--precompute-only[just run precomputation]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-O --Output)'{-O,--Output}'=[output directory]:dir:_directories' \
  '(-m --output-module)'{-m,--output-module}'=[output module]:module:' \
  '--output-json=[serialize traces as JSON]:file:_files' \
  '--oj=[serialize traces as JSON]:file:_files' \
  '--output-dot=[serialize traces as DOT]:file:_files' \
  '--od=[serialize traces as DOT]:file:_files' \
  '(-p --port)'{-p,--port}'=[port for interactive mode]:port:' \
  '(-i --interface)'{-i,--interface}'=[interface for interactive mode]:iface:' \
  '--image-format=[interactive image format (default SVG)]:format:(PNG SVG)' \
  '--debug[show interactive server debug output]' \
  '--no-logging[suppress interactive web server logs]' \
  '--with-dot=[path to GraphViz dot tool]:file:_files' \
  '--with-json=[path to JSON rendering tool]:file:_files' \
  '--with-maude=[path to maude rewriting tool]:file:_files' \
  '*: :_files -g "*.(spthy|sapic)"' && ret=0

return ret
