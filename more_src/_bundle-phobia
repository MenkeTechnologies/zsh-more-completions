#compdef bundle-phobia
# _bundle-phobia — CLI client for the bundlephobia.com service (AdrieanKhisbe/bundle-phobia-cli)
# upstream: https://github.com/AdrieanKhisbe/bundle-phobia-cli
# Flags from main.js (yargs).

_bundle-phobia() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --package)'{-p+,--package=}'[package.json file to read deps from]:file:_files -g "package.json"' \
        '(-r --range)'{-r+,--range=}'[number of versions to fetch (0 = all)]:n:' \
        '(-j --json)'{-j,--json}'[output JSON instead of formatted string]' \
        '(-s --size)'{-s,--size}'[output only module size]' \
        '(-g --gzip-size)'{-g,--gzip-size}'[output only gzipped size]' \
        '(-d --dependencies)'{-d,--dependencies}'[output only dependency count]' \
        '(-x --fail-fast)'{-x,--fail-fast}'[stop on first error]' \
        '(-1 --serial)'{-1,--serial}'[run requests serially]' \
        '--self[output bundle-phobia stats]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'install:install packages if size constraints are met'
            )
            _describe -t commands command cmds || _message 'package'
            ;;
        args)
            case $words[1] in
                install)
                    _arguments \
                        '(-w --warn)'{-w,--warn}'[warn but still install on violation]' \
                        '(-i --interactive)'{-i,--interactive}'[ask for override on violation]' \
                        '(-m --max-size)'{-m+,--max-size=}'[per-library size threshold]:size:' \
                        '(-M --max-gzip-size)'{-M+,--max-gzip-size=}'[per-library gzip size threshold]:size:' \
                        '(-o --max-overall-size)'{-o+,--max-overall-size=}'[overall dep size threshold]:size:' \
                        '(-O --max-overall-gzip-size)'{-O+,--max-overall-gzip-size=}'[overall gzip dep size threshold]:size:' \
                        '(-x --fail-fast)'{-x,--fail-fast}'[stop on first error]' \
                        '*:package:'
                    ;;
            esac
            ;;
    esac
}

_bundle-phobia "$@"
