#compdef lcdshow
# Documentation: https://man.archlinux.org/search?q=lcdshow
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[command to send]:cmd:' \
  '-s+[server host:port]:host:_hosts' \
  '-r+[reporting level]:level:(0 1 2 3 4 5)' && ret=0

return ret
