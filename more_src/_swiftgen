#compdef swiftgen

# Zsh completion for swiftgen - Swift code generator for project resources

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run SwiftGen with a parser and template'
  'config:manage and use configuration files'
  'template:manage built-in templates'
  'help:show help for a subcommand'
)

local -a parsers=(
  'strings:parse .strings files'
  'xcassets:parse .xcassets catalogs'
  'fonts:parse font files'
  'ib:parse Interface Builder files'
  'plist:parse property list files'
  'json:parse JSON files'
  'yaml:parse YAML files'
  'files:parse arbitrary file hierarchies'
  'coredata:parse Core Data model files'
  'colors:parse color palettes'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show swiftgen version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'swiftgen command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-p --templatePath)'{-p,--templatePath}'[path to template file]:file:_files' \
          '(-t --templateName)'{-t,--templateName}'[name of built-in template]:template name:' \
          '--param[template parameters]:param:' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:parser:(strings xcassets fonts ib plist json yaml files coredata colors)' \
          '*:input path:_files' && ret=0
        ;;
      (config)
        local -a config_sub=(
          'lint:lint the configuration file'
          'init:create a new configuration file'
          'run:run SwiftGen using a configuration file'
          'doc:open SwiftGen documentation'
        )
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:->configsub' \
          '*::arg:->configargs' && ret=0
        case $state in
          (configsub)
            _describe -t configsub 'config subcommand' config_sub && ret=0
            ;;
          (configargs)
            case $line[1] in
              (run)
                _arguments \
                  '--config[config file path]:file:_files -g "*.(yml|yaml)"' \
                  '--verbose[verbose output]' \
                  '--quiet[suppress output]' && ret=0
                ;;
              (lint)
                _arguments \
                  '--config[config file path]:file:_files -g "*.(yml|yaml)"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (template)
        local -a template_sub=(
          'list:list available built-in templates'
          'which:show path to a built-in template'
          'cat:print content of a built-in template'
          'doc:open online documentation for a template'
        )
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:->tmplsub' \
          '2:parser:(strings xcassets fonts ib plist json yaml files coredata colors)' \
          '3:template name:' && ret=0
        case $state in
          (tmplsub)
            _describe -t template_sub 'template subcommand' template_sub && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
