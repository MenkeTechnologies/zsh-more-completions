#compdef btrfs-property
# _btrfs-property — btrfs-progs btrfs property (get/set/list per-object btrfs properties: label/ro/compression/etc.; first arg is verb (get|set|list), second is object (file/dir/subvol/device), optional --types restricts target object type)
# upstream: https://github.com/kdave/btrfs-progs
# Subcommands from btrfs-progs cmds/property.c on tip.

_btrfs-property() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->verb' \
        '*::arg:->args'
    case $state in
        verb) _describe -t commands 'property verb' '(get set list)' ;;
        args)
            _arguments \
                '-t+[object types]:type:(s i f d b)' \
                '--types+[object types]:type:(s i f d b)' \
                '-f[force]' \
                '*:path:_files'
            ;;
    esac
}

_btrfs-property "$@"
