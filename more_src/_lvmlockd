#compdef lvmlockd

# lvmlockd: LVM lock daemon for shared VG access
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-D --debug)'{-D,--debug}'[debug mode]' \
  '(-s --socket-path)'{-s,--socket-path=}'[socket path]:file:_files' \
  '(-g --gl-type)'{-g,--gl-type=}'[global lock type]:type:(dlm sanlock)' \
  '(-S --syslog-priority)'{-S,--syslog-priority=}'[syslog priority]:pri:(emerg alert crit err warning notice info debug)' \
  '(-A --adopt-opt)'{-A,--adopt-opt=}'[adopt opt]:val:' \
  '(-p --pid-file)'{-p,--pid-file=}'[PID file]:file:_files' \
  '(-o --host-id-source)'{-o,--host-id-source=}'[host ID source]:src:(file uname)' \
  '(-r --renew-interval)'{-r,--renew-interval=}'[lease renew interval]:sec:' \
  '*::lvmlockd args:_files' && ret=0
return ret
