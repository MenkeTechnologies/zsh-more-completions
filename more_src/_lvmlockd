#compdef lvmlockd
# Documentation: https://man.archlinux.org/search?q=lvmlockd
# Reference accessed: 2026-05-16

# lvmlockd: LVM lock manager daemon (sanlock/dlm backend)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-T[run in test mode]' \
  '-D[debug mode (foreground)]' \
  '-f[run in foreground]' \
  '-g[lock manager type]:type:(sanlock dlm idm)' \
  '-i[host ID for sanlock]:host_id:' \
  '-F[lock manager flags]:flag:' \
  '-S[sanlock io timeout]:sec:' \
  '-A[adopt orphan locks on startup]' \
  '-p[PID file]:file:_files' \
  '-l[log file]:file:_files' \
  '-r[restart timeout]:sec:' \
  '-s[syslog priority]:level:(emerg alert crit err warning notice info debug)' \
  '-G[gl_use_dlm]' \
  '-E[help-extra (advanced)]' \
  '*::lvmlockd args:_files' && ret=0
return ret
