#compdef zap-api-scan
# Documentation: https://man.archlinux.org/search?q=zap-api-scan
# Reference accessed: 2026-05-16

# ZAP API scan: OpenAPI/Swagger/SOAP API scan (Docker entrypoint / standalone python)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-t[target URL]:url:' \
  '-c[config file]:file:_files' \
  '-u[remote config URL]:url:' \
  '-g[generate config file]:file:_files' \
  '-m[mins for spider]:n:' \
  '-r[generate HTML report]:file:_files' \
  '-w[generate Markdown report]:file:_files' \
  '-x[generate XML report]:file:_files' \
  '-J[generate JSON report]:file:_files' \
  '-l[level: PASS WARN FAIL]:level:(PASS WARN FAIL)' \
  '-s[short output]' \
  '-z[zap options]:opts:' \
  '-P[zap port]:port:' \
  '-d[debug]' \
  '-i[ignore warnings]' \
  '-j[use ajax spider]' \
  '-n[zap context file]:file:_files' \
  '-p[zap context user]:user:' \
  '-T[max time for scan (mins)]:mins:' \
  '-D[max delay for active scan]:mins:' \
  '-I[ignore status code in failures]' \
  '-f[API definition format]:fmt:(openapi soap graphql)' \
  '*::zap-api-scan args:_files' && ret=0
return ret
