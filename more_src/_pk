#compdef pk
# Documentation: https://man.archlinux.org/search?q=pk
# Reference accessed: 2026-05-16

# johnmorrow/pk — field extractor (`src/main.rs` clap)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '-b[backslash-escape delimiters in input]' \
  '-d+[input delimiter characters]:chars:' \
  '-e[allow empty fields]' \
  '-f+[read input from file]:file:_files' \
  '-S+[output field separator]:sep:' \
  '-T[trim non-alphanumeric around fields]' \
  '*:field specs (indices ranges literals):' && ret=0
return ret
