#compdef pk
# Documentation: https://github.com/johnmorrow/pk
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# johnmorrow/pk - field extractor (clap)

local ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-b --backslash)'{-b,--backslash}'[backslash-escape delimiters in input]' \
  '(-d --delimiters)'{-d+,--delimiters=}'[input delimiter characters]:chars:' \
  '(-e --empty)'{-e,--empty}'[allow empty fields]' \
  '(-f --file)'{-f+,--file=}'[read input from file]:file:_files' \
  '-q+[quote handling (optional quote chars)]:quote:' \
  '-E+[exclude strings from output (colon-separated)]:strings:' \
  '-N+[text for empty fields]:text:' \
  '(-S --separator)'{-S+,--separator=}'[output field separator]:sep:' \
  '(-T --trim)'{-T,--trim}'[trim non-alphanumeric around fields]' \
  '*:field specs:' && ret=0
return ret
