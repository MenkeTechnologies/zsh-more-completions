#compdef EstimateLibraryComplexity
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#EstimateLibraryComplexity
# Picard: estimate library complexity from sequence of read pairs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '*'{-I=,--INPUT=}'[input file(s) to estimate complexity from]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output file for per-library metrics]:file:_files' \
  '--MIN_IDENTICAL_BASES=[bases at read starts that must match to group reads]:int:' \
  '--MAX_DIFF_RATE=[max rate of differences to call two reads identical]:float:' \
  '--MIN_MEAN_QUALITY=[min mean base quality for a read pair to be analyzed]:int:' \
  '--MAX_GROUP_RATIO=[skip self-similar groups this many times over expected size]:int:' \
  '--BARCODE_TAG=[barcode SAM tag (e.g. BC)]:tag:' \
  '--READ_ONE_BARCODE_TAG=[read-one barcode SAM tag]:tag:' \
  '--READ_TWO_BARCODE_TAG=[read-two barcode SAM tag]:tag:' \
  '--READ_NAME_REGEX=[regex for parsing read names for optical duplicates]:regex:' \
  '--OPTICAL_DUPLICATE_PIXEL_DISTANCE=[max pixel distance for optical duplicates]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
