#compdef doit-cli
# _doit-cli — Eduardo Schettino doit Python task automation CLI alias (Eduardo Schettino / pydoit, Python); custom argparse
# upstream: https://github.com/pydoit/doit

_doit-cli() {
    local -a sub=(
        'run:run tasks (default)'
        'auto:keep running on file changes'
        'clean:clean task results'
        'completion:print shell completion'
        'dumpdb:dump database'
        'forget:forget task'
        'help:show help'
        'ignore:ignore tasks'
        'info:show task info'
        'list:list tasks'
        'reset-dep:reset deps'
        'strace:strace tasks'
        'tabcompletion:tab completion (alias)'
        'task-graph:graph tasks'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dir=+[change to dir]:dir:_files -/' \
        '-d+[change to dir]:dir:_files -/' \
        '--seek-file[seek dodo file in parents]' \
        '-k[seek dodo file in parents]' \
        '--file=+[dodo file]:file:_files -g "dodo.py *.py"' \
        '-f+[dodo file]:file:_files -g "dodo.py *.py"' \
        '--db-file=+[db file]:file:_files' \
        '--backend=+[backend]:b:(dbm json sqlite3)' \
        '--num-process=+[parallel processes]:n:' \
        '-n+[parallel processes]:n:' \
        '--parallel-type=+[parallel type]:t:(process thread)' \
        '-P+[parallel type]:t:(process thread)' \
        '--reporter=+[reporter]:r:(default console json executed-only zero error-only)' \
        '-r+[reporter]:r:(default console json executed-only zero error-only)' \
        '--output-file=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--check_file_uptodate=+[check file uptodate]:m:(md5 timestamp)' \
        '--check-file-uptodate=+[check file uptodate]:m:(md5 timestamp)' \
        '--verbosity=+[verbosity]:n:(0 1 2)' \
        '-v+[verbosity]:n:(0 1 2)' \
        '--continue[continue on errors]' \
        '-c[continue on errors]' \
        '--no-continue[no continue on errors]' \
        '--always-execute[always execute]' \
        '-a[always execute]' \
        '--minversion=+[min version]:str:' \
        '--single[single task mode]' \
        '-s[single task mode]' \
        '--cleanforget[clean and forget]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doit subcommand' sub
            _files ;;
        args)
            case $words[1] in
                run) _arguments '*:task:' ;;
                list) _arguments \
                    '--all[show all]' \
                    '--quiet[quiet]' \
                    '--status[show status]' \
                    '--private[show private]' \
                    '--no-status[no status]' \
                    '--deps[show deps]' \
                    '--template=+[template]:str:' \
                    '--sort=+[sort]:s:(name definition)' ;;
                clean) _arguments \
                    '--dry-run[dry run]' \
                    '--all[clean all]' \
                    '--cleandep[clean dependencies]' \
                    '--cleanforget[clean and forget]' \
                    '*:task:' ;;
                forget|ignore|info|task-graph) _arguments '*:task:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
                auto) _arguments \
                    '--loop[loop forever]' \
                    '*:task:' ;;
            esac
            ;;
    esac
}

_doit-cli "$@"
