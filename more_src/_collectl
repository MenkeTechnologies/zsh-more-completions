#compdef collectl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-s+[specify subsystems to monitor]:subsystems:(c C d D f i j J l L m M n N s t T x X y Y z Z)' \
  '-i+[sampling interval]:interval (seconds):' \
  '--verbose[display verbose output]' \
  '-c+[number of samples to collect]:count:' \
  '-R+[run for specified time]:runtime:' \
  '-f+[flush data to file]:file:_files' \
  '-F+[filename for output]:file:_files' \
  '-P[generate output in plot format]' \
  '-p+[playback file]:file:_files' \
  '--from+[start time for playback]:time:' \
  '--thru+[end time for playback]:time:' \
  '-A+[set address for data collection]:address:' \
  '--align[align output on interval boundary]' \
  '-D+[set debug level]:level:' \
  '--export+[export data to specified format]:format:(graphite ganglia lexpr)' \
  '--lustsvcs[show Lustre services]' \
  '--top+[display data in top-like format]:type:(process slab)' \
  '-o+[output options]:options:' \
  '--grep+[grep pattern for filtering]:pattern:' \
  '--hr+[set header repeat interval]:interval:' \
  '--sep+[field separator]:separator:' \
  '--rawtoo[generate raw and plot data]' \
  '--all[collect all data]' \
  '--procfilt+[filter processes]:filter:' \
  '--dskfilt+[filter disk names]:filter:' \
  '--netfilt+[filter network interfaces]:filter:' \
  '*:file:_files' && ret=0

return ret
