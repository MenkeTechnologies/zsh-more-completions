#compdef binwalk
# _binwalk-bin — binwalk firmware analysis & extraction (Python); signature scanner + entropy + extract for firmware images
# upstream: https://github.com/ReFirmLabs/binwalk

_binwalk-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-B --signature)'{-B,--signature}'[signature scan (default)]' \
        '(-R --raw)'{-R,--raw}'+[raw bytes]:bytes:' \
        '(-A --opcodes)'{-A,--opcodes}'[opcode scan]' \
        '(-m --magic)'{-m,--magic}'+[custom magic file]:file:_files' \
        '(-b --dumb)'{-b,--dumb}'[disable smart scanning]' \
        '(-I --invalid)'{-I,--invalid}'[show invalid results]' \
        '(-x --exclude)'{-x,--exclude}'+[exclude pattern]:pattern:' \
        '(-y --include)'{-y,--include}'+[include pattern]:pattern:' \
        '(-E --entropy)'{-E,--entropy}'[entropy analysis]' \
        '(-F --fast)'{-F,--fast}'[fast entropy]' \
        '(-J --save)'{-J,--save}'[save entropy plot to file]' \
        '(-N --nplot)'{-N,--nplot}'[do not plot]' \
        '(-H --high)'{-H,--high}'+[high entropy threshold]:f:' \
        '(-L --low)'{-L,--low}'+[low entropy threshold]:f:' \
        '(-e --extract)'{-e,--extract}'[extract files]' \
        '(-M --matryoshka)'{-M,--matryoshka}'[recursively extract]' \
        '(-d --depth)'{-d,--depth}'+[depth limit]:n:' \
        '(-D --dd)'{-D,--dd}'+[type:ext:cmd]:str:' \
        '(-C --directory)'{-C,--directory}'+[output dir]:dir:_files -/' \
        '(-j --size)'{-j,--size}'+[bytes to scan]:n:' \
        '(-o --offset)'{-o,--offset}'+[start offset]:n:' \
        '(-l --length)'{-l,--length}'+[length to scan]:n:' \
        '(-r --rm)'{-r,--rm}'[remove zero-size files]' \
        '(-z --carve)'{-z,--carve}'[carve resources]' \
        '(-P --plugins)'{-P,--plugins}'+[plugin dir]:dir:_files -/' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-W --hexdump)'{-W,--hexdump}'[hexdump output]' \
        '(-w --diff)'{-w,--diff}'[diff between files]' \
        '(-G --green)'{-G,--green}'[only ASCII hex]' \
        '*:firmware file:_files'
}

_binwalk-bin "$@"
