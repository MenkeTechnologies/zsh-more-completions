#compdef smamfcal
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/smamfcal.html
# Multifrequency antenna and passband calibration

local ret=1

_arguments -s \
  'vis=[input visibility data file]:dataset:_files' \
  'line=[standard line parameter for frequency/channel selection]:line' \
  'edge=[number of channels to drop at spectral window edges]:edge' \
  'select=[standard UV selection criteria]:select' \
  'flux=[source flux, reference frequency (GHz), spectral index]:flux' \
  'refant=[reference antenna (default 3)]:refant' \
  'minants=[minimum antenna count for a solution (default 2)]:minants' \
  'interval=[max solution interval and gap size in minutes]:interval' \
  'weight=[weighting method for bandpass and gain solving]:weight' \
  'smooth=[three params for moving average smoothing]:smooth' \
  'polyfit=[degree of orthogonal polynomial for bandpass fit (default 3)]:polyfit' \
  'tol=[solution convergence tolerance (default 0.001)]:tol' \
  'options=[delay,nopassol,interpolate,oldflux,msmooth,opolyfit,wrap,averrll]:options' \
  '*:dataset:_files' && ret=0

return ret
