#compdef ladle

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'serve:start development server'
  'build:build static output'
  'preview:preview production build'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ladle command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (serve)
        _arguments \
          '--host=[server host]:host' \
          '--port=[server port]:port' \
          '--stories=[glob pattern for stories]:pattern' \
          '--theme=[UI theme]:theme:(light dark auto)' \
          '--config=[config file]:file:_files' \
          '--viteConfig=[vite config file]:file:_files' \
          '--base=[base path]:path' \
          '--mode=[vite mode]:mode' \
          '--open=[open browser]:open:(none dashboard)' \
          '--noWatch[disable file watching]' && ret=0
        ;;
      (build)
        _arguments \
          '--stories=[glob pattern for stories]:pattern' \
          '--theme=[UI theme]:theme:(light dark auto)' \
          '--config=[config file]:file:_files' \
          '--viteConfig=[vite config file]:file:_files' \
          '--base=[base path]:path' \
          '--mode=[vite mode]:mode' \
          '--out=[output directory]:directory:_directories' && ret=0
        ;;
      (preview)
        _arguments \
          '--host=[server host]:host' \
          '--port=[server port]:port' \
          '--out=[output directory]:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
