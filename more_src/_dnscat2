#compdef dnscat2 dnscat2.rb dnscat
# Documentation: https://man.archlinux.org/search?q=dnscat2
# Reference accessed: 2026-05-16

if [[ ${service} == dnscat ]]; then
  _arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--delay=[max delay ms]:ms:' \
    '--steady[always wait full delay]' \
    '--max-retransmits=[retransmits]:n:' \
    '--retransmit-forever[never give up]' \
    '--secret=[shared secret]:secret:' \
    '--no-encryption[disable encryption]' \
    '--console[I/O via console]' \
    '(-e --exec)'{-e,--exec}'=[process]:process:' \
    '--command[command session]' \
    '--ping[ping]' \
    '*-d[debug verbose]' \
    '*-q[quiet]' \
    '--packet-trace[packet trace]' \
    '--dns=[DNS options]:opts:' \
    '--tcp=[TCP options]:opts:' \
    '*:domain:'
else
  _arguments -s \
    '-h[help placeholder]' \
    '--version[print version]' \
    '--dns=[DNS server options]:opts:' \
    '--dnshost=[DNS bind IP]:ip:' \
    '--dnsport=[DNS bind port]:port:' \
    '--passthrough=[upstream host\:port]:host\:port:' \
    '--security=[security level]:level:(open encrypted authenticated)' \
    '--secret=[shared secret]:secret:' \
    '--auto_command=[command on connect]:cmd:' \
    '--auto_attach[auto-attach]' \
    '--packet_trace[packet trace]' \
    '--process=[process]:process:' \
    '--history_size=[history lines]:n:' \
    '--listener=[debug listener port]:port:' \
    '--firehose[stdout output]' \
    '--cache[caching]' \
    '*:domain:'
fi
