#compdef arm-none-eabi-objdump
# _arm-none-eabi-objdump — Arm Limited arm-none-eabi-objdump CLI for the bare-metal ARM cross-objdump disassembling ELF object files showing sections symbols headers DWARF debug info source-mixed disassembly Cortex-M instruction (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-objdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-a[archive headers]' \
        '--archive-headers[archive headers]' \
        '-f[file headers]' \
        '--file-headers[file headers]' \
        '-p[private headers]' \
        '--private-headers[private headers]' \
        '-P+[private options]:str:' \
        '--private=+[private options]:str:' \
        '-h[section headers]' \
        '--section-headers[section headers]' \
        '-x[all headers]' \
        '--all-headers[all headers]' \
        '-d[disassemble]' \
        '--disassemble[disassemble]' \
        '-D[disassemble all sections]' \
        '--disassemble-all[disassemble all sections]' \
        '-S[mix source]' \
        '--source[mix source]' \
        '-l[line numbers]' \
        '--line-numbers[line numbers]' \
        '-r[reloc entries]' \
        '--reloc[reloc entries]' \
        '-R[dynamic reloc entries]' \
        '--dynamic-reloc[dynamic reloc entries]' \
        '-s[full contents of sections]' \
        '--full-contents[full contents of sections]' \
        '-g[debugging info]' \
        '--debugging[debugging info]' \
        '-G[stabs]' \
        '--stabs[stabs]' \
        '-t[symbol table]' \
        '--syms[symbol table]' \
        '-T[dynamic symbol table]' \
        '--dynamic-syms[dynamic symbol table]' \
        '-z[disassemble zeros]' \
        '--disassemble-zeroes[disassemble zeros]' \
        '-w[no line wrap]' \
        '--wide[no line wrap]' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-W+[dwarf section]:s:(all info abbrev aranges macro frames str loc ranges pubnames pubtypes gdb_index trace_info trace_abbrev trace_aranges debug_addr debug_cu_index debug_tu_index)' \
        '--dwarf=+[dwarf section]:s:(all info abbrev aranges macro frames str loc ranges pubnames pubtypes gdb_index)' \
        '-j+[section]:str:' \
        '--section=+[section]:str:' \
        '-m+[machine]:str:' \
        '--architecture=+[machine]:str:' \
        '-M+[disassembler-options]:str:' \
        '--disassembler-options=+[options]:str:' \
        '-EB[big endian]' \
        '-EL[little endian]' \
        '*:object file:_files -g "*.o *.elf *.axf *.so *.a"'
}

_arm-none-eabi-objdump "$@"
