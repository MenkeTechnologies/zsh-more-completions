#compdef dund

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '--listen[server mode]' \
  '--connect=+[bdaddr]:bdaddr:' \
  '--search[search for servers]' \
  '--kill=+[kill matching]:bdaddr:' \
  '--killall[kill all]' \
  '--show[show connections]' \
  '--server=+[server]:srv:' \
  '--nodetach[no fork]' \
  '--persist=+[persist interval]:sec:' \
  '--auth[require auth]' \
  '--encrypt[require encryption]' \
  '--secure[require secure auth]' \
  '--master[become master]' \
  '--cache[cache PIN]' \
  '--pppd=+[pppd path]:file:_files' \
  '--device=+[device]:dev:' && ret=0

return ret
