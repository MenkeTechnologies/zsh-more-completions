#compdef dund
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/dund.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# BlueZ dund(1) — Bluetooth dial-up networking daemon

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(--show --list -l)'{--show,--list,-l}'[show active DUN connections]' \
  '(--listen -s)'{--listen,-s}'[accept incoming DUN connections]' \
  '(--dialup -u)'{--dialup,-u}'[listen for dialup/telephone connections]' \
  '(--connect -c)'{--connect=,-c+}'[create DUN connection to bdaddr]:bdaddr:' \
  '(--mrouter -m)'{--mrouter=,-m+}'[create mRouter connection]:bdaddr:' \
  '(--search -Q)'{--search,-Q}'[search and connect (optional duration)]' \
  '(--kill -k)'{--kill=,-k+}'[kill DUN connection to bdaddr]:bdaddr:' \
  '(--killall -K)'{--killall,-K}'[kill all DUN connections]' \
  '(--channel -C)'{--channel=,-C+}'[RFCOMM channel]:channel:' \
  '(--device -i)'{--device=,-i+}'[source bdaddr]:bdaddr:' \
  '(--nosdp -D)'{--nosdp,-D}'[disable SDP]' \
  '(--auth -A)'{--auth,-A}'[enable authentication]' \
  '(--encrypt -E)'{--encrypt,-E}'[enable encryption]' \
  '(--secure -S)'{--secure,-S}'[secure connection]' \
  '(--master -M)'{--master,-M}'[become master of piconet]' \
  '(--nodetach -n)'{--nodetach,-n}'[run in foreground, do not daemonize]' \
  '(--persist -p)'{--persist,-p}'[persist mode (optional interval)]' \
  '(--pppd -d)'{--pppd=,-d+}'[pppd path]:file:_files' \
  '(--msdun -X)'{--msdun,-X}'[enable Microsoft dialup networking support]' \
  '(--activesync -a)'{--activesync,-a}'[enable Microsoft ActiveSync networking]' \
  '(--cache)--cache[enable address cache]' \
  '*::pppd options:_default' && ret=0

return ret
