#compdef tiup

_tiup_commands() {
    local -a commands
    commands=(
        'install:Install a specific version of a component'
        'list:List available components or versions'
        'uninstall:Uninstall a component'
        'update:Update TiUP components to the latest version'
        'status:List the status of running components'
        'clean:Clean the data of instantiated components'
        'mirror:Manage a repository mirror'
        'telemetry:Controls things about telemetry'
        'completion:Generate shell completion script'
        'env:Display TiUP environment information'
        'history:Display the historical execution record'
        'playground:Bootstrap a local TiDB cluster for fun'
        'cluster:Deploy a TiDB cluster for production'
        'bench:Benchmark workload'
        'dm:Data migration platform manager'
    )
    _describe -t commands 'tiup command' commands
}

_tiup() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-B --binpath)'{-B,--binpath}'[Specify the binary path of component]:path:_files' \
        '(-T --tag)'{-T,--tag}'[Specify a tag for the component instance]:tag:' \
        '--ssh[SSH client type]:type:(builtin system)' \
        '--ssh-timeout[SSH connection timeout in seconds]:seconds:' \
        '(-h --help)'{-h,--help}'[Print help]' \
        '(-v --version)'{-v,--version}'[Print version]' \
        '1:command:_tiup_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                install|uninstall|update)
                    _arguments \
                        '1:component:(tidb tikv pd tiflash ctl grafana prometheus tiup playground cluster dm bench cdc)'
                    ;;
                list)
                    _arguments \
                        '--installed[List installed components only]' \
                        '--all[List all available components]' \
                        '--verbose[Show detailed information]' \
                        '1:component:'
                    ;;
                playground)
                    _arguments \
                        '--db[Number of TiDB instances]:number:' \
                        '--kv[Number of TiKV instances]:number:' \
                        '--pd[Number of PD instances]:number:' \
                        '--tiflash[Number of TiFlash instances]:number:' \
                        '--host[Playground listen host]:host:_hosts' \
                        '--monitor[Enable Prometheus and Grafana]' \
                        '--tag[Specify a tag]:tag:' \
                        '1:version:'
                    ;;
                cluster)
                    _arguments \
                        '1:action:(deploy list display start stop restart scale-in scale-out destroy upgrade edit-config reload patch rename audit prune check template)'
                    ;;
                mirror)
                    _arguments \
                        '1:action:(init set show publish clone merge rotate)'
                    ;;
            esac
            ;;
    esac
}

_tiup "$@"
