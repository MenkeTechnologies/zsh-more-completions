#compdef eot2ttf eot-tools eot-utils
# _eot2ttf — Adobe eot2ttf CLI for unwrapping Embedded Open Type EOT containers back to standard TrueType/OpenType TTF sources stripping EOT headers and decompressing MicroType embedding (adobe team, C); getopt
# upstream: https://github.com/adobe-type-tools/afdko

_eot2ttf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files -g "*.ttf *.otf *.ttc"' \
        '--output=+[output file]:file:_files -g "*.ttf *.otf *.ttc"' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--keep-eot-header[keep EOT header]' \
        '--no-decompress[no MTX decompress]' \
        '--strip-name-records[strip name records]' \
        '--force[overwrite]' \
        '-f[overwrite]' \
        '*:EOT file:_files -g "*.eot *.EOT"'
}

_eot2ttf "$@"
