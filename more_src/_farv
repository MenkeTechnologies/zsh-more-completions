# ----------------------------------------------------------------------------
# Background Management Functions
# ----------------------------------------------------------------------------

list_backgrounds() {
    if [[ ! -d "$FARV_CURRENT_LINK/backgrounds" ]]; then
        echo "No backgrounds folder found for current theme"
        return 1
    fi

    echo "Available backgrounds for current theme:"

    # Get current selection
    local current_bg=""
    if [[ -L "$FARV_CURRENT_LINK/backgrounds/current-background" ]]; then
        current_bg=$(basename "$(readlink "$FARV_CURRENT_LINK/backgrounds/current-background")")
    fi

    # List all backgrounds
    local found_any=false
    for bg in "$FARV_CURRENT_LINK/backgrounds"/*.{jpg,jpeg,png}; do
        if [[ -f "$bg" ]]; then
            local bg_name=$(basename "$bg")
            if [[ "$bg_name" == "$current_bg" ]]; then
                echo "  * $bg_name (current)"
            else
                echo "    $bg_name"
            fi
            found_any=true
        fi
    done

    if [[ "$found_any" == "false" ]]; then
        echo "  No background images found"
    fi
}

set_background() {
    local background_name="$1"

    if [[ -z "$background_name" ]]; then
        echo "Error: Background filename required"
        return 1
    fi

    # Check if the background exists in current theme
    if [[ ! -f "$FARV_CURRENT_LINK/backgrounds/$background_name" ]]; then
        echo "Error: Background file '$background_name' not found"
        echo "Available backgrounds:"
        list_backgrounds
        return 1
    fi

    # Update the current-background symlink in current theme
    ln -sf "$background_name" "$FARV_CURRENT_LINK/backgrounds/current-background"

    # Run wallpaper scripts to apply the new background
    echo "Setting background to $background_name..."
    local scripts
    readarray -t scripts < <(find "$FARV_SYSTEM_DIR/themes" "$FARV_USER_THEMES" -name "*wallpaper*" -type f -executable 2>/dev/null)

    for script in "${scripts[@]}"; do
        if [[ -x "$script" ]]; then
            echo "  - $(basename "$script")"
            "$script"
        fi
    done
}

show_current_background() {
    if [[ -L "$FARV_CURRENT_LINK/backgrounds/current-background" ]]; then
        local current_bg
        current_bg=$(basename "$(readlink "$FARV_CURRENT_LINK/backgrounds/current-background")")
        echo "Current background: $current_bg"
    else
        echo "No background selection found"
    fi
}

cycle_to_next_background() {
    if [[ ! -d "$FARV_CURRENT_LINK/backgrounds" ]]; then
        echo "No backgrounds folder found for current theme"
        return 1
    fi

    # Get current background
    local current_bg=""
    if [[ -L "$FARV_CURRENT_LINK/backgrounds/current-background" ]]; then
        current_bg=$(basename "$(readlink "$FARV_CURRENT_LINK/backgrounds/current-background")")
    fi

    # Get all available backgrounds (sorted)
    local backgrounds=()
    for bg in "$FARV_CURRENT_LINK/backgrounds"/*.{jpg,jpeg,png}; do
        if [[ -f "$bg" ]]; then
            local bg_name=$(basename "$bg")
            if [[ "$bg_name" != "current-background" ]]; then
                backgrounds+=("$bg_name")
            fi
        fi
    done

    if [[ ${#backgrounds[@]} -eq 0 ]]; then
        echo "No background images found"
        return 1
    fi

    # Sort the backgrounds array
    IFS=$'\n' backgrounds=($(sort <<<"${backgrounds[*]}"))
    unset IFS

    # Find next background
    local next_bg=""
    if [[ -z "$current_bg" ]]; then
        # No current background, use first one
        next_bg="${backgrounds[0]}"
    else
        # Find current background in sorted list and get next one
        for i in "${!backgrounds[@]}"; do
            if [[ "${backgrounds[i]}" == "$current_bg" ]]; then
                # Get next background (wrap around to first if at end)
                local next_index=$(( (i + 1) % ${#backgrounds[@]} ))
                next_bg="${backgrounds[next_index]}"
                break
            fi
        done

        # If current background not found, use first one
        if [[ -z "$next_bg" ]]; then
            next_bg="${backgrounds[0]}"
        fi
    fi

    # Set the next background
    if [[ -n "$next_bg" ]]; then
        ln -sf "$next_bg" "$FARV_CURRENT_LINK/backgrounds/current-background"
        echo "Switched to background: $next_bg"

        # Run wallpaper scripts to apply the new background
        local scripts
        readarray -t scripts < <(find "$FARV_SYSTEM_DIR/themes" "$FARV_USER_THEMES" -name "*wallpaper*" -type f -executable 2>/dev/null)

        for script in "${scripts[@]}"; do
            if [[ -x "$script" ]]; then
                "$script"
            fi
        done
    fi
}

cycle_to_prev_background() {
    if [[ ! -d "$FARV_CURRENT_LINK/backgrounds" ]]; then
        echo "No backgrounds folder found for current theme"
        return 1
    fi

    # Get current background
    local current_bg=""
    if [[ -L "$FARV_CURRENT_LINK/backgrounds/current-background" ]]; then
        current_bg=$(basename "$(readlink "$FARV_CURRENT_LINK/backgrounds/current-background")")
    fi

    # Get all available backgrounds (sorted)
    local backgrounds=()
    for bg in "$FARV_CURRENT_LINK/backgrounds"/*.{jpg,jpeg,png}; do
        if [[ -f "$bg" ]]; then
            local bg_name=$(basename "$bg")
            if [[ "$bg_name" != "current-background" ]]; then
                backgrounds+=("$bg_name")
            fi
        fi
    done

    if [[ ${#backgrounds[@]} -eq 0 ]]; then
        echo "No background images found"
        return 1
    fi

    # Sort the backgrounds array
    IFS=$'\n' backgrounds=($(sort <<<"${backgrounds[*]}"))
    unset IFS

    # Find previous background
    local prev_bg=""
    if [[ -z "$current_bg" ]]; then
        # No current background, use last one
        prev_bg="${backgrounds[-1]}"
    else
        # Find current background in sorted list and get previous one
        for i in "${!backgrounds[@]}"; do
            if [[ "${backgrounds[i]}" == "$current_bg" ]]; then
                # Get previous background (wrap around to last if at beginning)
                if [[ $i -eq 0 ]]; then
                    prev_bg="${backgrounds[-1]}"
                else
                    local prev_index=$(( i - 1 ))
                    prev_bg="${backgrounds[prev_index]}"
                fi
                break
            fi
        done

        # If current background not found, use last one
        if [[ -z "$prev_bg" ]]; then
            prev_bg="${backgrounds[-1]}"
        fi
    fi

    # Set the previous background
    if [[ -n "$prev_bg" ]]; then
        ln -sf "$prev_bg" "$FARV_CURRENT_LINK/backgrounds/current-background"
        echo "Switched to background: $prev_bg"

        # Run wallpaper scripts to apply the new background
        local scripts
        readarray -t scripts < <(find "$FARV_SYSTEM_DIR/themes" "$FARV_USER_THEMES" -name "*wallpaper*" -type f -executable 2>/dev/null)

        for script in "${scripts[@]}"; do
            if [[ -x "$script" ]]; then
                "$script"
            fi
        done
    fi
}

cycle_to_random_background() {
    if [[ ! -d "$FARV_CURRENT_LINK/backgrounds" ]]; then
        echo "No backgrounds folder found for current theme"
        return 1
    fi

    # Get current background
    local current_bg=""
    if [[ -L "$FARV_CURRENT_LINK/backgrounds/current-background" ]]; then
        current_bg=$(basename "$(readlink "$FARV_CURRENT_LINK/backgrounds/current-background")")
    fi

    # Get all available backgrounds
    local backgrounds=()
    for bg in "$FARV_CURRENT_LINK/backgrounds"/*.{jpg,jpeg,png}; do
        if [[ -f "$bg" ]]; then
            local bg_name=$(basename "$bg")
            if [[ "$bg_name" != "current-background" ]]; then
                backgrounds+=("$bg_name")
            fi
        fi
    done

    if [[ ${#backgrounds[@]} -eq 0 ]]; then
        echo "No background images found"
        return 1
    fi

    # If only one background, just use it
    if [[ ${#backgrounds[@]} -eq 1 ]]; then
        local random_bg="${backgrounds[0]}"
    else
        # Choose a random background (different from current if possible)
        local random_bg=""
        local attempts=0
        while [[ -z "$random_bg" || ("$random_bg" == "$current_bg" && $attempts -lt 10) ]]; do
            local random_index=$((RANDOM % ${#backgrounds[@]}))
            random_bg="${backgrounds[random_index]}"
            ((attempts++))
        done
    fi

    # Set the random background
    if [[ -n "$random_bg" ]]; then
        ln -sf "$random_bg" "$FARV_CURRENT_LINK/backgrounds/current-background"
        echo "Switched to background: $random_bg"

        # Run wallpaper scripts to apply the new background
        local scripts
        readarray -t scripts < <(find "$FARV_SYSTEM_DIR/themes" "$FARV_USER_THEMES" -name "*wallpaper*" -type f -executable 2>/dev/null)

        for script in "${scripts[@]}"; do
            if [[ -x "$script" ]]; then
                "$script"
            fi
        done
    fi
}

