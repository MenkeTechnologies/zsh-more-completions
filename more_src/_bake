#compdef bake
# _bake — Sara Adams Bake task runner from bakelang minimal make-replacement (bakelang team, Bash/Go); custom argparse
# upstream: https://github.com/SaraAdams/bake

_bake() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--file=+[Bakefile]:file:_files -g "Bakefile"' \
        '-f+[Bakefile]:file:_files -g "Bakefile"' \
        '--list[list targets]' \
        '-l[list targets]' \
        '--directory=+[change to dir]:dir:_files -/' \
        '-C+[change to dir]:dir:_files -/' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--verbose[verbose]' \
        '--force[force rebuild]' \
        '-B[force rebuild]' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--keep-going[keep going on errors]' \
        '-k[keep going on errors]' \
        '--check[check syntax only]' \
        '*:target:'
}

_bake "$@"
