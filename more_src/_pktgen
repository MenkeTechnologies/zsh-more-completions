#compdef pktgen
# _pktgen — Linux pktgen userspace helper (pktgen-dpdk / kernel pktgen control script; -f config file, -s socket count, -l log file, -P promiscuous, -m memory-channels, -n cores list, --eal-args raw DPDK EAL args; positional ports list)
# upstream: https://github.com/pktgen/Pktgen-DPDK
# Flags from Pktgen-DPDK app/pktgen.c on tip.

_pktgen() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files' \
        '-s+[socket count]:n:' \
        '-l+[log file]:file:_files' \
        '-P[promiscuous]' \
        '-m+[memory channels]:n:' \
        '-n+[cores list]:cores:' \
        '--eal-args=*[raw EAL args]:args:' \
        '*:port:'
}

_pktgen "$@"
