#compdef dredd

# Zsh completion for dredd - HTTP API testing framework

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dry-run[do not run any real HTTP transaction]' \
  '--hookfiles=[pattern to match hook files]:pattern:_files' \
  '--language=[language of hook files]:language:(nodejs ruby python perl go rust php)' \
  '--server=[server command to start before testing]:command' \
  '--server-wait=[seconds to wait for server to start]:seconds' \
  '--init[initialize dredd configuration]' \
  '--names[list names of requests without executing them]' \
  '--only=[run only specified tests]:test names' \
  '--reporter=[output reporter]:reporter:(apiary cli dot html json junit markdown nyan xunit)' \
  '--output=[output file]:file:_files' \
  '--header=[extra header to include in every request]:header' \
  '--sorted[sort requests by path and method]' \
  '--user=[basic auth credentials]:user:password' \
  '--inline-errors[show errors inline with test results]' \
  '--details[show test details]' \
  '--method=[HTTP methods to test]:method:(GET POST PUT PATCH DELETE OPTIONS HEAD)' \
  '--color=[use terminal colors]:enable:(true false)' \
  '--loglevel=[log level]:level:(error warning debug)' \
  '--path=[additional paths to API description files]:path:_files' \
  '--sandbox[load and run hook files in a sandboxed context]' \
  '--config=[path to dredd configuration file]:file:_files -g "*.yml *.yaml *.json"' \
  '1:API description document:_files -g "*.yaml *.yml *.json *.apib *.md"' \
  '2:API endpoint URL'
