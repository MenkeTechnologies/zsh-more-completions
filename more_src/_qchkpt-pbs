#compdef qchkpt
# _qchkpt-pbs — PBS qchkpt (request a checkpoint of one or more running PBS jobs; -t array selector limits which array sub-jobs are checkpointed; the checkpoint script configured via the job's pbs_attr or queue's $action chkpt_abort runs on the executing host)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qchkpt.c on tip.

_qchkpt-pbs() {
    _arguments \
        '-t+[array selector]:range:' \
        '*:jobID:'
}

_qchkpt-pbs "$@"
