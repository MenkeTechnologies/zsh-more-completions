#compdef s5cmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--endpoint-url=[S3 endpoint URL]:url' \
  '--credentials-file=[credentials file]:credentials:_files' \
  {-p,--profile}'=[AWS profile]:profile' \
  '--no-sign-request[do not sign requests]' \
  '--json[output as JSON]' \
  '--stat[show stats]' \
  '--numworkers=[number of workers]:workers' \
  '--retry-count=[retry count]:count' \
  '--dry-run[dry run]' \
  '--show-progress[show progress]' \
  '--log=[log level]:level:(trace debug info error)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ls:list buckets and objects'
      'cp:copy objects'
      'mv:move objects'
      'rm:remove objects'
      'mb:make bucket'
      'rb:remove bucket'
      'du:show disk usage'
      'pipe:read from stdin and upload'
      'cat:print object content'
      'run:run commands from file'
      'select:run SQL queries on objects'
      'sync:sync directories and S3 prefixes'
      'head:print object metadata'
      'version:print version'
    )
    _describe -t commands 's5cmd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      cp|mv|sync)
        _arguments -s -S \
          '--flatten[flatten directory structure]' \
          '--no-clobber[do not overwrite existing]' \
          '--if-size-differ[only copy if size differs]' \
          '--if-source-newer[only copy if source is newer]' \
          '--acl=[access control]:acl:(private public-read public-read-write authenticated-read)' \
          '--storage-class=[storage class]:class:(STANDARD REDUCED_REDUNDANCY STANDARD_IA ONEZONE_IA INTELLIGENT_TIERING GLACIER DEEP_ARCHIVE)' \
          '--part-size=[part size for multipart]:size' \
          '--concurrency=[concurrency]:concurrency' \
          '--content-type=[content type]:type' \
          '--content-encoding=[content encoding]:encoding' \
          '--content-disposition=[content disposition]:disposition' \
          '--cache-control=[cache control]:cache control' \
          '*:source and destination:_files' \
          && ret=0
        ;;
      rm)
        _arguments -s -S \
          '*:object' \
          && ret=0
        ;;
      ls)
        _arguments -s -S \
          '--humanize[human readable sizes]' \
          '--show-fullpath[show full path]' \
          '*:prefix' \
          && ret=0
        ;;
      run)
        _arguments -s -S \
          '1:command file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
