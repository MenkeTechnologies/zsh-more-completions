#compdef apxs apxs2

_arguments -s \
  '-n=[module name]:name:' \
  '-q[query mode (print build variables)]' \
  '-v[verbose; with -q list known variables]' \
  '*-S=[set apxs setting key=value]:setting:' \
  '-g[generate sample module skeleton]' \
  '-c[compile sources to DSO]' \
  '-o=[output DSO filename]:file:_files' \
  '*-D-[preprocessor define name=value]:define:' \
  '*-I=[include directory]:dir:_files -/' \
  '*-L=[library directory]:dir:_files -/' \
  '*-l=[library name]:lib:' \
  '*-Wc,[pass flags to libtool --mode=compile]:flags:' \
  '*-Wl,[pass flags to libtool --mode=link]:flags:' \
  '-p[link against apr/apr-util]' \
  '-i[install DSO into modules dir]' \
  '-a[activate module (add LoadModule)]' \
  '-A[activate but commented out]' \
  '-e[edit httpd.conf only]' \
  '*:source:_files'
