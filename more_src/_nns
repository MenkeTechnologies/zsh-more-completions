#compdef nns
# Documentation: https://man.archlinux.org/search?q=nns
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-host+[host to query]:host:_hosts' \
  '-port+[port]:port:' \
  '-localonly+[local only]:flag:(true false)' \
  '*:name:' && ret=0

return ret
