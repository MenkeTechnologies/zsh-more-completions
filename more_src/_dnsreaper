#compdef dnsreaper
# Documentation: https://github.com/punk-security/dnsReaper
# subdomain takeover scanner

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--out[output file (use stdout for streaming)]:output file:_files' \
  '--out-format[output format]:format:(csv json)' \
  '--resolver[custom DNS resolver]:resolver' \
  '--parallelism[parallel domain tests]:parallelism' \
  '--disable-probable[skip probable conditions]' \
  '--enable-unlikely[include high false-positive conditions]' \
  '--signature[scan with specific signature only]:signature' \
  '--exclude-signature[skip specific signature]:signature' \
  '--pipeline[exit non-zero on detection]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--nocolour[disable colored text]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:provider:->providers' \
  '*::arg:_files' && ret=0

case $state in
  providers)
    local -a providers=(
      'aws:fetch domains from AWS Route53'
      'azure:fetch domains from Azure DNS'
      'bind:read from DNS BIND zone file'
      'cloudflare:fetch domains from Cloudflare'
      'digitalocean:fetch domains from Digital Ocean'
      'file:read domains from file (one per line)'
      'godaddy:fetch domains from GoDaddy'
      'googlecloud:fetch domains from Google Cloud'
      'projectdiscovery:fetch domains from ProjectDiscovery'
      'securitytrails:fetch domains from Security Trails'
      'single:scan a single domain'
      'zonetransfer:fetch records via DNS zone transfer'
    )
    _describe -t providers 'dnsreaper provider' providers && ret=0
    ;;
esac

return ret
