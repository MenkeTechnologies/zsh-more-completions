#compdef Compute-Slope-Aspect
# Documentation: https://raw.githubusercontent.com/senbox-org/snap-engine/master/snap-dem/src/main/java/org/esa/snap/dem/gpf/ComputeSlopeAspectOp.java
# ESA SNAP gpt Compute-Slope-Aspect operator - compute slope and aspect from a DEM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PdemName=[the digital elevation model]:dem' \
  '-PdemResamplingMethod=[DEM resampling method]:method' \
  '-PexternalDEMFile=[external DEM file]:file:_files' \
  '-PexternalDEMNoDataValue=[external DEM no data value]:value' \
  '-PexternalDEMApplyEGM=[apply earth gravitational model to external DEM]:flag:(true false)' \
  '-PdemBandName=[the DEM band name]:band' \
  '*:graph xml:_files' && ret=0

return ret
