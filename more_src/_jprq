#compdef jprq
# Documentation: https://github.com/azimjohn/jprq
# jprq - expose localhost to the internet over HTTP and TCP

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(auth http tcp serve)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      http)
        _arguments -s \
          '-s[specify a custom subdomain]:subdomain:' \
          '--debug[enable jprq debugger]' \
          '--cname=[serve on a different domain]:domain:' \
          '*:port:' && ret=0
        ;;
      tcp)
        _arguments -s '*:port:' && ret=0
        ;;
      serve)
        _arguments -s '*:directory:_files -/' && ret=0
        ;;
      auth)
        _arguments -s '*:token:' && ret=0
        ;;
    esac
    ;;
esac

return ret
