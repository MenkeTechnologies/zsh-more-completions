#compdef monkeytype
# _monkeytype — runtime type collector for Python (Instagram/MonkeyType)
# upstream: https://github.com/Instagram/MonkeyType
# Subcommands from monkeytype/cli.py.

_monkeytype() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-c --config)'{-c+,--config=}'[config module path]:module:' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '--disable-type-rewriting[disable type rewriting]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:run a Python script under tracing'
                'apply:generate and apply a stub'
                'stub:generate a stub'
                'list-modules:list modules with traces'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '--disable-type-rewriting[disable type rewriting]' \
                        '*:script:_files -g "*.py"'
                    ;;
                apply|stub)
                    _arguments \
                        '--sample-count[print number of traced calls]' \
                        '--diff[print stub diff before applying]' \
                        '--ignore-existing-annotations[ignore existing annotations]' \
                        '--include-unparsable-defaults[include unparsable default values]' \
                        '--limit=[max traces to consider]:n:' \
                        '*:module path:'
                    ;;
                list-modules)
                    _arguments \
                        '--limit=[max modules]:n:'
                    ;;
            esac
            ;;
    esac
}

_monkeytype "$@"
