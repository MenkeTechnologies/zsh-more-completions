#compdef xgensum
# Documentation: https://man.voidlinux.org/xtools.1
# update SHA256 sum in templates (xtools)

local ret=1

_arguments -s -S \
  '-f[overwrite existing checksum]' \
  '-c[only print computed checksum]' \
  '-i[update in place]' \
  '-a[process all distfiles]' \
  '-H[use given hash command]:command:' \
  '*:package:' && ret=0

return ret
