#compdef privoxy-cli
# _privoxy-cli — Privoxy non-caching web proxy with filtering CLI alias (privoxy team, C); custom argparse
# upstream: https://github.com/privoxy/privoxy

_privoxy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--chroot[chroot]' \
        '--user=+[user[.group]]:str:' \
        '--no-daemon[no daemon]' \
        '--pidfile=+[pid file]:file:_files' \
        '--config-test[test config]' \
        '--pre-chroot-nslookup=+[hostname]:host:_hosts' \
        '*:config file:_files -g "config*"'
}

_privoxy-cli "$@"
