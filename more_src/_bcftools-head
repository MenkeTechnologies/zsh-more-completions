#compdef bcftools-head
# Documentation: http://www.htslib.org/doc/bcftools.html#head
# bcftools head: View the header of a VCF/BCF file

local ret=1

_arguments -s -S \
  '(-h --header)'{-h,--header}'[Display only the first INT header lines. By default, all header lines]:INT: ' \
  '(-n --records)'{-n,--records}'[Also display the first INT variant records. By default, no variant rec]:INT: ' \
  '(-s --samples)'{-s,--samples}'[Display the first INT variant records including the last #CHROM header]:INT: ' \
  '(-v --verbosity)'{-v,--verbosity}'[see Common Options]:INT: ' \
  '*:file:_files' && ret=0

return ret
