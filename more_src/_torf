#compdef torf
# Documentation: https://github.com/rndusr/torf-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-i --in)'{-i,--in=}'[input torrent file]:file:_files' \
  '(-o --out)'{-o,--out=}'[output torrent file]:file:_files' \
  '*'{-r,--reuse=}'[reuse pieces from existing torrent]:file:_files' \
  '(-R --noreuse)'{-R,--noreuse}'[disable reuse]' \
  '*'{-e,--exclude=}'[exclude files]:pattern' \
  '*--include=[include files]:pattern' \
  '*'{-er,--exclude-regex=}'[exclude regex]:regex' \
  '*'{-ir,--include-regex=}'[include regex]:regex' \
  '(-n --name)'{-n,--name=}'[torrent name]:name' \
  '*'{-t,--tracker=}'[tracker URL]:url' \
  '*'{-w,--webseed=}'[web seed URL]:url' \
  '(-p --private)'{-p,--private}'[create private torrent]' \
  '(-c --comment)'{-c,--comment=}'[comment]:comment' \
  '(-d --date)'{-d,--date=}'[creation date]:date' \
  '(-a --creator)'{-a,--creator=}'[creator string]:creator' \
  '(-s --source)'{-s,--source=}'[source field]:source' \
  '*--merge=[merge metainfo JSON]:json' \
  '(-x --xseed)'{-x,--xseed}'[enable cross-seeding]' \
  '--max-piece-size=[maximum piece size]:size' \
  '(-T --notracker)'{-T,--notracker}'[remove trackers]' \
  '(-W --nowebseed)'{-W,--nowebseed}'[remove web seeds]' \
  '(-P --noprivate)'{-P,--noprivate}'[remove private flag]' \
  '(-C --nocomment)'{-C,--nocomment}'[remove comment]' \
  '(-S --nosource)'{-S,--nosource}'[remove source]' \
  '(-X --noxseed)'{-X,--noxseed}'[remove xseed]' \
  '(-D --nodate)'{-D,--nodate}'[remove date]' \
  '(-A --nocreator)'{-A,--nocreator}'[remove creator]' \
  '(-N --notorrent)'{-N,--notorrent}'[suppress torrent file output]' \
  '(-M --nomagnet)'{-M,--nomagnet}'[suppress magnet output]' \
  '(-V --novalidate)'{-V,--novalidate}'[skip validation]' \
  '(-y --yes)'{-y,--yes}'[overwrite without confirmation]' \
  '(-f --config)'{-f,--config=}'[config file]:file:_files' \
  '(-F --noconfig)'{-F,--noconfig}'[disable config]' \
  '*'{-z,--profile=}'[profile]:profile' \
  '--threads=[threads for hashing]:n' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-m --metainfo)'{-m,--metainfo}'[output metainfo]' \
  '(-u --human)'{-u,--human}'[human-readable output]' \
  '(-U --nohuman)'{-U,--nohuman}'[machine-readable output]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--debug-file=[debug log file]:file:_files' \
  '*:path:_files' && return 0
