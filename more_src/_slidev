#compdef slidev

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build hostable SPA'
      'export:export slides to PDF'
      'format:format a slide file'
      'theme:theme operations'
    )
    _describe -t commands 'command' commands && ret=0

    # Default subcommand is to serve
    _arguments -s -S \
      '--port=[port to listen on]:port' \
      '--open[open browser on start]' \
      '--remote=[allow remote access]:password' \
      '--log=[log level]:level:(error warn info debug)' \
      '--force[force optimization re-bundle]' \
      '--theme=[override theme]:theme' \
      '1:slides file:_files -g "*.md"' && ret=0
    ;;
  (args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '--base=[base path]:path' \
          '--download[allow download as PDF]' \
          '--out=[output directory]:directory:_directories' \
          '--theme=[override theme]:theme' \
          '(- *)'{-h,--help}'[show help]' \
          '1:slides file:_files -g "*.md"' && ret=0
        ;;
      export)
        _arguments -s -S \
          '--format=[output format]:format:(pdf png pptx md)' \
          '--output=[output file]:file:_files' \
          '--timeout=[page timeout in ms]:ms' \
          '--range=[page range]:range' \
          '--dark[use dark theme]' \
          '--with-clicks[export clicks separately]' \
          '--with-toc[export with table of contents]' \
          '--per-slide[export per slide]' \
          '--scale=[export scale]:scale' \
          '--theme=[override theme]:theme' \
          '(- *)'{-h,--help}'[show help]' \
          '1:slides file:_files -g "*.md"' && ret=0
        ;;
    esac
    ;;
esac

return ret
