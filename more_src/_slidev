#compdef slidev
# Documentation: https://sli.dev/builtin/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build hostable SPA'
      'export:export slides to PDF or other formats'
      'format:format a slide file'
      'theme:theme operations'
    )
    _describe -t commands 'command' commands && ret=0

    # Default subcommand is to serve (dev server)
    _arguments -s -S \
      '(-p --port)'{-p+,--port=}'[port to listen on (default 3030)]:port' \
      '--base=[base path (default /)]:path' \
      '(-o --open)'{-o,--open}'[open browser on start]' \
      '--remote=[allow remote access]:password' \
      '--bind=[address to bind (default 0.0.0.0)]:address' \
      '--log=[log level]:level:(error warn info silent)' \
      '(-f --force)'{-f,--force}'[force optimization re-bundle]' \
      '(-t --theme)'{-t+,--theme=}'[override theme]:theme' \
      '1:slides file:_files -g "*.md"' && ret=0
    ;;
  (args)
    case ${words[1]} in
      build)
        _arguments -s -S \
          '(-o --out)'{-o+,--out=}'[output directory (default dist)]:directory:_directories' \
          '--base=[base path (default /)]:path' \
          '--download[allow download as PDF]' \
          '(-t --theme)'{-t+,--theme=}'[override theme]:theme' \
          '--without-notes[exclude speaker notes]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:slides file:_files -g "*.md"' && ret=0
        ;;
      export)
        _arguments -s -S \
          '--output=[output file]:file:_files' \
          '--format=[output format (default pdf)]:format:(pdf png pptx md)' \
          '--timeout=[page timeout in ms (default 30000)]:ms' \
          '--range=[page range]:range' \
          '--dark[use dark theme]' \
          '(-c --with-clicks)'{-c,--with-clicks}'[export with clicks separately]' \
          '(-t --theme)'{-t+,--theme=}'[override theme]:theme' \
          '--omit-background[transparent background]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:slides file:_files -g "*.md"' && ret=0
        ;;
      format)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:slides file:_files -g "*.md"' && ret=0
        ;;
      theme)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(eject)' \
          '*::arg:->theme_args' && ret=0
        case $state in
          (theme_args)
            if [[ ${words[1]} == eject ]]; then
              _arguments -s -S \
                '--dir=[output directory (default theme)]:directory:_directories' \
                '(-t --theme)'{-t+,--theme=}'[override theme]:theme' \
                '1:slides file:_files -g "*.md"' && ret=0
            fi
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
