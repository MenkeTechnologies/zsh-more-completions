#compdef lldpd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-d[do not detach (debug)]' \
  '-D+[debug class]:class:' \
  '-r[receive only]' \
  '-c[CDP enable]' \
  '-cc[CDP v1 only]' \
  '-ccc[CDP v2 only]' \
  '-f[FDP enable]' \
  '-s[SONMP enable]' \
  '-e[EDP enable]' \
  '-l[LLDP-MED enable]' \
  '-M+[manage chassis class]:n:(1 2 3 4 5 6 7 8)' \
  '-i[disable LLDP-MED inventory]' \
  '-k[disable kernel notifier]' \
  '-S+[chassis description]:descr:' \
  '-P+[platform string]:str:' \
  '-x[enable Mac/I XML output]' \
  '-X+[control socket]:file:_files' \
  '-u+[user to run as]:user:_users' \
  '-g+[group to run as]:group:_groups' \
  '-m+[bind to address]:addr:' \
  '-I+[interfaces include]:iface:_net_interfaces' \
  '-C+[interfaces exclude]:iface:_net_interfaces' \
  '-L+[lldpcli path]:file:_files' \
  '-O+[config dir]:dir:_files -/' && ret=0

return ret
