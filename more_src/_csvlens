#compdef csvlens
# Documentation: https://github.com/YS-L/csvlens
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Interactive CSV viewer.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-d --delimiter)'{-d,--delimiter}'[field delimiter (auto for autodetect)]:delimiter' \
  '(-t --tab-separated)'{-t,--tab-separated}'[use tab as delimiter]' \
  '--no-headers[treat first row as data]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive search]' \
  '--columns=[show columns matching regex by default]:regex' \
  '--filter=[apply filter regex on load]:regex' \
  '--find=[highlight matches for regex on load]:regex' \
  '--echo-column=[print column value on exit]:column' \
  '--prompt=[custom status-bar message]:text' \
  '--color-columns[colorize each column differently]' \
  '--colorful[alias for --color-columns]' \
  '--debug[enable debug logging]' \
  '*:csv file:_files -g "*.{csv,tsv,txt}"' && ret=0

return ret
