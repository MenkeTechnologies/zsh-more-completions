#compdef csvlens

# Zsh completion for csvlens (interactive CSV viewer)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-d --delimiter)'{-d,--delimiter}'[specify delimiter character]:delimiter:' \
  '(-t --tab-separated)'{-t,--tab-separated}'[use tab as delimiter]' \
  '--no-headers[treat first row as data instead of header]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive search]' \
  '(-f --filter)'{-f,--filter}'[initial filter to apply]:filter:' \
  '--echo-column[print the value of this column on exit]:column name:' \
  '*:csv file:_files -g "*.{csv,tsv,txt}"' && ret=0

return ret
