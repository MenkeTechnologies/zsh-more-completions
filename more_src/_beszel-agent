#compdef beszel-agent
# Documentation: https://github.com/henrygd/beszel/blob/main/internal/cmd/agent/agent.go
# Reference accessed: 2026-05-27
# Verified: upstream internal/cmd/agent/agent.go flag definitions and subcommands

# Zsh completion for the Beszel monitoring agent.

local curcontext="$curcontext" state line ret=1
local -a subcmds fingerprint_sub

subcmds=(
  'health:check if the agent is running'
  'fingerprint:view or reset the agent fingerprint'
  'update:update to the latest version'
  'help:display usage information'
)

fingerprint_sub=(
  'view:print the current fingerprint (default)'
  'reset:reset the saved fingerprint'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show this help message]' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-k --key)'{-k+,--key=}'[public key(s) for SSH authentication]:key:' \
  '(-l --listen)'{-l+,--listen=}'[address or port to listen on]:address:' \
  '(-u --url)'{-u+,--url=}'[URL of the Beszel hub]:url:' \
  '(-t --token)'{-t+,--token=}'[token to use for authentication]:token:' \
  '(-c --china-mirrors)'{-c,--china-mirrors}'[use gh.beszel.dev mirror for update]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'beszel-agent subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      fingerprint)
        _describe -t commands 'fingerprint action' fingerprint_sub && ret=0
        ;;
      update)
        _arguments \
          '(-c --china-mirrors)'{-c,--china-mirrors}'[use gh.beszel.dev mirror for update]' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
