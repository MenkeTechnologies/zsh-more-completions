#compdef create-just-dom
# Documentation: https://www.npmjs.com/package/create-just-dom
# Reference accessed: 2026-05-24
# Verified: npm view create-just-dom bin; npm readme Usage flags table.

# Zsh completion for create-just-dom - just-dom Vite vanilla scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--ts[use TypeScript Vite vanilla-ts template]' \
  '--typescript[alias for --ts]' \
  '--js[use JavaScript Vite vanilla template]' \
  '--javascript[alias for --js]' \
  '--plugins=[comma-separated plugins]:plugins:(router signals lucide)' \
  '--no-plugins[install just-dom only; no @just-dom/* plugins]' \
  '--css=[CSS framework option]:css:(none tailwind tailwind-daisyui)' \
  '--no-css[same as --css=none]' \
  '--pnpm[use pnpm add in the new folder]' \
  '(-y --yes)'{-y,--yes}'[skip prompts; use TS/no-plugins/no-css defaults]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
