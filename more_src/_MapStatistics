#compdef MapStatistics
# Documentation: https://www.openms.org/documentation/html/TOPP_MapStatistics.html
# OpenMS: computes descriptive statistics about a feature or consensus map

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input file (featureXML or consensusXML)]:file:_files' \
  '-in_type[input file type]:type:(featureXML consensusXML)' \
  '-out[output text file]:file:_files' \
  '-n[number of RT slices for separate statistics]:int:' \
  '-m[show experiment metadata]' \
  '-p[display data processing information]' \
  '-s[calculate summary statistics]' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
