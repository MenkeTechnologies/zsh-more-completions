#compdef watchtower

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--api-token=[API token for HTTP API]:token' \
  '--cleanup[remove old images after updating]' \
  '-c[remove old images after updating]' \
  '--debug[enable debug mode]' \
  '-d[enable debug mode]' \
  '--enable-lifecycle-hooks[enable lifecycle hooks]' \
  '--http-api-metrics[enable HTTP API metrics endpoint]' \
  '--http-api-token=[token for the HTTP API]:token' \
  '--http-api-update[enable HTTP API update endpoint]' \
  '--include-restarting[include restarting containers]' \
  '--include-stopped[include stopped containers]' \
  '-S[include stopped containers]' \
  '--interval=[poll interval in seconds]:seconds' \
  '-i+[poll interval in seconds]:seconds' \
  '--label-enable[only update containers with enable label]' \
  '--lifecycle-hook-timeout=[lifecycle hook timeout]:seconds' \
  '--log-format=[set log format]:format:(Auto LogFmt JSON)' \
  '--log-level=[set log level]:level:(panic fatal error warn info debug trace)' \
  '--monitor-only[only monitor, do not update]' \
  '-m[only monitor, do not update]' \
  '--no-color[disable ANSI color in output]' \
  '--no-pull[do not pull new images]' \
  '--no-restart[do not restart containers]' \
  '--no-startup-message[suppress startup message]' \
  '--notification-email-from=[email from address]:email' \
  '--notification-email-server=[email server]:server:_hosts' \
  '--notification-email-server-port=[email server port]:port' \
  '--notification-email-server-tls-skip-verify[skip TLS verification]' \
  '--notification-email-to=[email to address]:email' \
  '--notification-gotify-token=[gotify app token]:token' \
  '--notification-gotify-url=[gotify URL]:url' \
  '--notification-slack-channel=[Slack channel]:channel' \
  '--notification-slack-hook-url=[Slack webhook URL]:url' \
  '--notification-slack-icon-emoji=[Slack icon emoji]:emoji' \
  '--notification-slack-icon-url=[Slack icon URL]:url' \
  '--notification-slack-identifier=[Slack identifier]:identifier' \
  '--notification-template=[notification template]:template' \
  '--notification-url=[notification URL]:url' \
  '--notifications=[notification type]:type:(email slack msteams gotify shoutrrr)' \
  '--porcelain=[machine-readable output]:format:(v1)' \
  '--remove-volumes[remove volumes on removal]' \
  '--revive-stopped[revive stopped containers]' \
  '--rolling-restart[restart one at a time]' \
  '--run-once[run once then exit]' \
  '-R[run once then exit]' \
  '--schedule=[cron schedule]:cron expression' \
  '-s+[cron schedule]:cron expression' \
  '--scope=[update scope]:scope' \
  '--stop-timeout=[stop timeout]:timeout' \
  '--tlsverify[verify TLS when connecting to Docker]' \
  '--warn-on-head-failure=[warn on HEAD request failure]:strategy:(always never auto)' \
  '*:container name:' && return 0
