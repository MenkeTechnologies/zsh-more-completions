#compdef watchtower
# Documentation: https://containrrr.dev/watchtower/arguments/
# Reference accessed: 2026-05-21
# Verified: upstream docs at containrrr.dev/watchtower/arguments/ and /notifications/

_arguments -s -S \
  '(- *)--help[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--trace[enable trace logging (exposes credentials)]' \
  '--log-level=[set log level]:level:(panic fatal error warn info debug trace)' \
  '(-l --log-format)'{-l,--log-format}'+[console output format]:format:(Auto LogFmt Pretty JSON)' \
  '--no-color[disable ANSI color codes]' \
  '(-H --host)'{-H,--host}'+[Docker daemon socket]:host' \
  '(-a --api-version)'{-a,--api-version}'+[Docker API version]:version' \
  '--tlsverify[verify TLS when connecting to Docker]' \
  '--include-restarting[include restarting containers]' \
  '(-S --include-stopped)'{-S,--include-stopped}'[include created and exited containers]' \
  '--label-enable[only update containers with enable label]' \
  '(-x --disable-containers)'{-x,--disable-containers}'+[exclude containers]:names' \
  '--scope=[update containers matching scope label]:scope' \
  '--no-pull[do not pull new images]' \
  '--no-restart[do not restart containers after updating]' \
  '--monitor-only[monitor and notify only, skip updates]' \
  '(-c --cleanup)'{-c,--cleanup}'[remove old images after updating]' \
  '--remove-volumes[remove anonymous volumes after updating]' \
  '--revive-stopped[start stopped containers with updated images]' \
  '--rolling-restart[restart one container at a time]' \
  '--label-take-precedence[prioritize container labels over CLI args]' \
  '--stop-timeout=[timeout before forcefully stopping container]:duration' \
  '(-i --interval)'{-i,--interval}'+[poll interval seconds]:seconds' \
  '(-s --schedule)'{-s,--schedule}'+[cron schedule]:cron' \
  '(-R --run-once)'{-R,--run-once}'[run once then exit]' \
  '--http-api-update[enable HTTP API update endpoint]' \
  '--http-api-token=[HTTP API token]:token' \
  '--http-api-periodic-polls[keep periodic updates when HTTP API enabled]' \
  '--http-api-metrics[enable Prometheus metrics endpoint]' \
  '--no-startup-message[suppress startup message]' \
  '--warn-on-head-failure=[warn on HEAD pull failure]:strategy:(always never auto)' \
  '(-P --porcelain)'{-P,--porcelain}'+[machine-readable output]:format:(v1)' \
  '--health-check[return success for docker HEALTHCHECK]' \
  '--enable-lifecycle-hooks[enable lifecycle hooks]' \
  '--notifications=[notification type]:type:(email slack msteams gotify shoutrrr)' \
  '--notifications-level=[notification level]:level' \
  '--notifications-hostname=[notification hostname]:hostname' \
  '--notifications-delay=[notification delay]:seconds' \
  '--notification-title-tag=[notification title tag]:tag' \
  '--notification-skip-title[skip notification title]' \
  '--notification-log-stdout[log notifications to stdout]' \
  '*--notification-url=[shoutrrr notification URL]:url' \
  '--notification-template=[notification template]:template' \
  '--notification-report[notification report]' \
  '--notification-email-from=[email from address]:email' \
  '--notification-email-to=[email to address]:email' \
  '--notification-email-server=[email server]:server:_hosts' \
  '--notification-email-server-tls-skip-verify[skip TLS verification]' \
  '--notification-email-server-port=[email server port]:port' \
  '--notification-email-server-user=[email server user]:user' \
  '--notification-email-server-password=[email server password]:password' \
  '--notification-email-delay=[email delay]:seconds' \
  '--notification-email-subjecttag=[email subject tag]:tag' \
  '--notification-slack-hook-url=[Slack webhook URL]:url' \
  '--notification-slack-identifier=[Slack identifier]:identifier' \
  '--notification-slack-channel=[Slack channel]:channel' \
  '--notification-msteams-hook=[MSTeams webhook URL]:url' \
  '--notification-msteams-data[include log data in MSTeams notification]' \
  '--notification-gotify-url=[Gotify URL]:url' \
  '--notification-gotify-token=[Gotify token]:token' \
  '--notification-gotify-tls-skip-verify[skip Gotify TLS verification]' \
  '*:container name:' && return 0
