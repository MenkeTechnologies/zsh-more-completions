#compdef dnseval
# Documentation: https://github.com/farrokhi/dnsdiag/blob/master/dnseval.py
# Evaluate and compare multiple DNS resolvers (dnsdiag)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '(-f --file)'{-f,--file}'+[specify a DNS server list file]:file:_files' \
  '(-c --count)'{-c,--count}'+[number of requests to send]:count' \
  '(-m --cache-miss)'{-m,--cache-miss}'[force a cache miss by prepending a random hostname]' \
  '(-w --wait)'{-w,--wait}'+[max wait time for a reply in seconds]:seconds' \
  '(-t --type)'{-t,--type}'+[DNS request record type]:type:(A AAAA CNAME MX NS PTR SOA TXT SRV CAA)' \
  '(-T --tcp -X --tls -Q --quic -H --doh -3 --http3)'{-T,--tcp}'[use TCP transport instead of UDP]' \
  '(-T --tcp -X --tls -Q --quic -H --doh -3 --http3)'{-X,--tls}'[use TLS transport (DoT)]' \
  '(-T --tcp -X --tls -Q --quic -H --doh -3 --http3)'{-Q,--quic}'[use QUIC transport (DoQ)]' \
  '(-T --tcp -X --tls -Q --quic -H --doh -3 --http3)'{-H,--doh}'[use HTTPS transport (DoH)]' \
  '(-T --tcp -X --tls -Q --quic -H --doh -3 --http3)'{-3,--http3}'[use HTTP/3 transport (DoH3)]' \
  '(-j --json)'{-j,--json}'+[save results to file in JSONL format]:file:_files' \
  '(-p --port)'{-p,--port}'+[DNS server port number]:port' \
  '(-S --srcip)'{-S,--srcip}'+[query source IP address]:ip' \
  '(-e --edns)'{-e,--edns}'[enable EDNS0 in requests]' \
  '(-D --dnssec)'{-D,--dnssec}'[enable DNSSEC desired (DO flag)]' \
  '(-C --color)'{-C,--color}'[enable colorful output]' \
  '(-v --verbose)'{-v,--verbose}'[print full DNS response details]' \
  '--skip-warmup[disable cache warmup]' \
  '*:hostname:_hosts' && ret=0

return ret
