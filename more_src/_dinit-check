#compdef dinit-check dinit-monitor
# Documentation: source-direct extraction from upstream
# davmac314/dinit src/dinit-check.cc + dinit-monitor.cc strcmp()
# argv-walking option chains (dinit uses a custom argv parser, not
# getopt/argparse, so the option set is extracted by grepping for
# all distinct `--long-option` literals + their `-shortform`
# matches).
# Reference accessed: 2026-05-30 via gh api.
# davmac314 dinit R131a — 2-stem multi-binary harvest of the dinit
# service-manager auxiliary binaries (the main `dinit` daemon and
# `dinitctl` client were already covered in older rounds; deliberately
# omitted from this #compdef line).

case $service in

  dinit-check)
    # Validate a dinit service-description directory tree without
    # actually starting any services. Useful for pre-flight checking
    # of service files before deployment.
    _arguments -s -S \
      '(-d --services-dir)'{-d+,--services-dir=}'[service-description directory to check]:dir:_directories' \
      '(-s --system)'{-s,--system}'[use system service paths (/etc/dinit.d)]' \
      '(-u --user)'{-u,--user}'[use user service paths (~/.config/dinit.d)]' \
      '(-p --socket-path)'{-p+,--socket-path=}'[dinit control socket path]:socket:_files' \
      '(-n --online)'{-n,--online}'[also check the live daemon (requires control socket)]' \
      '--env-file=[parse the given env file before loading services]:env-file:_files' \
      '--help[show help]' \
      '*:service name:'
    ;;

  dinit-monitor)
    # Subscribe to a running dinit daemon over its control socket
    # and react to service state-change events by running a command
    # or printing a custom message.
    _arguments -s -S \
      '(-e --exit)'{-e,--exit}'[exit after the first state change]' \
      '(-E --env)'{-E,--env}'[also report environment-update events]' \
      '(-s --system)'{-s,--system}'[connect to the system dinit instance]' \
      '(-u --user)'{-u,--user}'[connect to the user dinit instance]' \
      '(-i --initial)'{-i,--initial}'[also emit events for service state at connect time]' \
      '(-p --socket-path)'{-p+,--socket-path=}'[dinit control socket path]:socket:_files' \
      '(-c --command)'{-c+,--command=}'[command to run on each event (with placeholders)]:command:_command_names -e' \
      '--str-started=[printf-style format for STARTED events]:format:' \
      '--str-stopped=[printf-style format for STOPPED events]:format:' \
      '--str-failed=[printf-style format for FAILED events]:format:' \
      '--str-set=[printf-style format for environment SET events]:format:' \
      '--str-unset=[printf-style format for environment UNSET events]:format:' \
      '--help[show help]' \
      '--version[show version]' \
      '*:service name to subscribe to:'
    ;;

esac
