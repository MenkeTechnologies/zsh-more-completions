_commandkit() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_commandkit_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                dev|start|build|typegen)
                    _arguments \
                        '(-c --config)'{-c,--config}'=[path to commandkit config]:config:_files -g "commandkit.*"' && ret=0 ;;
                create)
                    _arguments \
                        '1:template:(command event)' \
                        '*:template args:' && ret=0 ;;
                info)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_commandkit_commands] )) ||
_commandkit_commands() {
    local -a commands
    commands=(
        'dev:start your bot in development mode (HMR)'
        'start:start your bot in production mode'
        'build:build the project for production'
        'typegen:generate typed command declarations'
        'create:create new files from a template (command/event/plugin)'
        'info:show environment info (useful for bug reports)'
    )
    _describe -t commands 'commandkit command' commands
}

_commandkit "$@"
