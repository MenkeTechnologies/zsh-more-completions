#compdef kaf
# Documentation: https://github.com/birdayz/kaf/blob/master/cmd/kaf/kaf.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kaf - Kafka CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --brokers)'{-b+,--brokers=}'[comma separated list of broker ip:port pairs]:brokers:' \
  '--config=[config file]:file:_files' \
  '--schema-registry=[URL to a Confluent schema registry]:url:' \
  '(-v --verbose)'{-v,--verbose}'[turn on sarama logging]' \
  '(-c --cluster)'{-c+,--cluster=}'[set a temporary current cluster]:cluster:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:handle kaf configuration'
      'consume:consume messages from a topic'
      'group:display information about consumer groups'
      'groups:list groups'
      'node:describe and manage nodes'
      'nodes:list nodes in a cluster'
      'produce:produce records to a topic'
      'query:query topic by key'
      'topic:create and describe topics'
      'topics:list topics'
      'completion:generate completion script'
    )
    _describe -t commands 'kaf command' commands && ret=0
    ;;
  args)
    case $line[1] in
      consume)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--offset=[offset to start consuming]:offset:(oldest newest)' \
          '--output=[output format]:format:(default raw hex json json-each-row)' \
          '(-f --follow)'{-f,--follow}'[continue to consume until interrupted]' \
          '(-n --tail)'{-n+,--tail=}'[print last n messages per partition]:n:' \
          '(-l --limit-messages)'{-l+,--limit-messages=}'[limit messages per partition]:n:' \
          '(-g --group)'{-g+,--group=}'[consumer group to use for consume]:group:' \
          '--commit[commit group offset after receiving messages]' \
          '*--header=[filter messages by header key:value]:header:' \
          '(-p --partitions)'{-p+,--partitions=}'[partitions to consume from]:partitions:' \
          '--proto-include=[path to proto files]:path:_files' \
          '--proto-exclude=[proto exclusions (path prefixes)]:path:' \
          '--proto-type=[fully qualified proto message type]:type:' \
          '--key-proto-type=[fully qualified proto key type]:type:' \
          '--decode-msgpack[enable deserializing msgpack]' \
          '--read-committed[set isolation level to read committed]' \
          '1:topic' && ret=0
        ;;
      produce)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-k --key)'{-k+,--key=}'[key for the record]:key:' \
          '--raw-key[treat --key as base64 and decode it]' \
          '*'{-H+,--header=}'[header in format key:value]:header:' \
          '(-n --repeat)'{-n+,--repeat=}'[repeat records to send]:n:' \
          '(-p --partition)'{-p+,--partition=}'[partition to produce to]:partition:' \
          '--partitioner=[select partitioner]:partitioner:(jvm rand rr hash)' \
          '--timestamp=[select timestamp for record]:timestamp:' \
          '--input=[input format]:format:(default hex json-each-row)' \
          '--input-mode=[scanning input mode]:mode:(line full)' \
          '--line-length-limit=[line length limit in line input mode]:n:' \
          '--template[run data through go template engine]' \
          '--proto-include=[path to proto files]:path:_files' \
          '--proto-exclude=[proto exclusions (path prefixes)]:path:' \
          '--proto-type=[fully qualified proto message type]:type:' \
          '--key-proto-type=[fully qualified proto key type]:type:' \
          '--avro-schema-id=[value schema id for avro encoding]:id:' \
          '--avro-key-schema-id=[key schema id for avro encoding]:id:' \
          '1:topic' && ret=0
        ;;
      topic)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create delete ls describe add-config rm-config set-config update lag)' && ret=0
        ;;
      group)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(describe ls delete delete-offsets peek commit)' && ret=0
        ;;
      node)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(ls)' && ret=0
        ;;
      config)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(import use-cluster get-clusters add-cluster remove-cluster select-cluster current-context add-eventhub)' && ret=0
        ;;
    esac
    ;;
esac

return ret
