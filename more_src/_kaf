#compdef kaf

# Zsh completion for kaf - Kafka CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b+[comma-separated list of brokers]:brokers' \
  '--brokers=[comma-separated list of brokers]:brokers' \
  '--cluster=[cluster name from config]:cluster' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:manage kaf configuration'
      'consume:consume messages from a topic'
      'group:manage consumer groups'
      'node:manage cluster nodes'
      'produce:produce messages to a topic'
      'topic:manage topics'
    )
    _describe -t commands 'kaf command' commands && ret=0
    ;;
  args)
    case $line[1] in
      consume)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[output format]:format:(raw json)' \
          '--follow[follow (like tail -f)]' \
          '-g+[consumer group]:group' \
          '--group=[consumer group]:group' \
          '--limit=[limit messages]:limit' \
          '--offset=[offset to start from]:offset:(oldest newest)' \
          '-p+[partition]:partition' \
          '--partitions=[partitions]:partitions' \
          '--key-encoding=[key encoding]:encoding:(none hex base64)' \
          '--value-encoding=[value encoding]:encoding:(none hex base64)' \
          '1:topic' && ret=0
        ;;
      produce)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-k+[message key]:key' \
          '--key=[message key]:key' \
          '-H+[message header key=value]:header' \
          '--header=[message header]:header' \
          '-p+[partition]:partition' \
          '--partition=[partition]:partition' \
          '--partitioner=[partitioner]:partitioner:(hash manual random round-robin)' \
          '1:topic' && ret=0
        ;;
      topic)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create delete describe ls add-config alter update)' && ret=0
        ;;
      group)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(delete describe ls commit)' && ret=0
        ;;
      node)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(describe ls)' && ret=0
        ;;
      config)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add-cluster current-cluster get-clusters ls select-cluster set-cluster use)' && ret=0
        ;;
    esac
    ;;
esac

return ret
