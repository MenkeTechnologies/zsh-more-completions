#compdef cyrus
# ============================================================================
# _cyrus — zsh completion for the Cyrus programming language compiler
#           (160th language entry — ROUND-NUMBER LANGUAGE MILESTONE)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/cyrus-lang/Cyrus
#   Maintainer : The Cyrus Language project
#   License    : GPL-3.0
#   Stars      : 108
#   Language   : Rust (compiler) / Cyrus (.cyrus source files)
#   Crate      : cli v0.0.4  (workspace member under
#                crates/cyrusc_cli/)
#   Binary     : cyrus  (crates/cyrusc_cli/Cargo.toml [[bin]]
#                         name = "cyrus", path = "./src/main.rs")
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Cyrus is "an experimental systems programming language designed
#   for simplicity, high performance, and ergonomics" — a low-level
#   ahead-of-time-compiled language with explicit ABIs, fixed-size
#   arrays, generics, interfaces, defer, and a Cyrus-Intermediate-
#   Representation (CIR) lowering layer that emits LLVM IR through
#   the `cyrusc_codegen_llvm` backend.  The `cyrus` driver wraps a
#   Cargo-like project lifecycle (new / build / run / clean / fetch)
#   plus low-level compiler passes (object / shared-lib / static-lib
#   emission and lex / parse / semantic dump modes).
#
# CLI ARGUMENT GRAMMAR  (verbatim from crates/cyrusc_cli/src/args.rs
#                       clap-derive Args + Commands enum +
#                       crates/cyrusc_cli/src/options.rs flattened
#                       CliCompilerOptions + CliLinkerOptions)
#   cyrus <SUBCOMMAND> [args...]
#
#   Subcommands (clap-derive renames PascalCase → kebab-case):
#     new <PROJECT_NAME>            Create a new project
#       --lib                         Create a library project
#                                     instead of an application
#
#     run [<FILE>] [-- <PROG_ARGS>...]
#                                   Execute a compiled program
#       (Inherits CliCompilerOptions + CliLinkerOptions below)
#
#     fetch <LIBRARIES>             Fetch a library into the
#                                   vendor directory
#
#     build [<FILE>]                Compile source into an executable
#       -o, --output-path <PATH>      Override output path
#       (Inherits CliCompilerOptions + CliLinkerOptions)
#
#     clean                         Clean the build directory
#                                   (Inherits CliCompilerOptions)
#
#     object [<FILE>]               Generate an object file
#     shared-lib [<FILE>]           Generate a dynamic library
#                                   (shared object)
#     static-lib [<FILE>]           Generate a static library
#     emit-llvm [<FILE>]            Emit `.ll` LLVM IR per module
#     emit-asm  [<FILE>]            Emit `.s` assembly per module
#     emit-bitcode [<FILE>]         Emit `.bc` LLVM bitcode per
#                                   module
#     emit-cir-dump [<FILE>]        Emit textual CIR `.cir` per
#                                   module
#       (All seven of the above take -o, --output-path and inherit
#        CliCompilerOptions)
#
#     lex-only      <FILE>          Lexical analysis only
#     parse-only    <FILE>          Display the program tree
#     semantic-only <FILE>          Check program correctness
#                                   semantically
#                                   (Inherits CliCompilerOptions)
#
#     version                       Print version information
#
#   Inherited compiler options (CliCompilerOptions, flattened into
#   every codegen subcommand):
#         --target <TRIPLE>         Target triple (defaults to host)
#         --cpu <CPU>               Target CPU name
#         --optimize <LEVEL>        Optimization level
#     -L, --library-path <PATH>     Library search path (repeatable)
#     -l, --library <LIB>           Library to link (repeatable)
#         --sources <DIRS>          Source directories (repeatable)
#     -z, --linker-flags <FLAGS>    Linker flags (repeatable)
#     -g                            Generate DWARF debug info
#         --build-dir <PATH>        Build-artifact directory
#         --base-path <PATH>        Base path for command
#         --linker <NAME>           Linker executable
#     -q, --quiet                   Suppress unnecessary output
#                                   (conflicts with --verbose)
#     -V, --verbose                 Increase output verbosity
#                                   (conflicts with --quiet)
#         --disable-modulefs-cache  Disable module-filesystem cache
#         --disable-warnings        Disable all warnings
#         --stdlib <PATH>           Cyrus stdlib path
#         --target-machine          Display target-machine info
#         --sanitize <SAN,...>      Sanitizers (comma-separated)
#         --reloc-mode <MODE>       Relocation model
#         --code-model <MODEL>      Code model
#         --profile <P>             Build profile (debug / release)
#         --abi <NAME>              ABI name-mangling scheme
#                                   (c / cyrus)
#         --jobs <N>                Compilation thread count
#         --module-merge-mode <M>   Module merge mode
#                                   (unified / separate)
#
#   Inherited linker options (CliLinkerOptions, flattened into
#   `run` and `build`):
#         --static                  Produce a fully static ELF
#         --pie                     Enable PIE (conflicts with
#                                   --no-pie)
#         --no-pie                  Disable PIE (conflicts with
#                                   --pie)
#
#   Standard clap auto-flags:
#     -h, --help                    Show help
#
# LANGUAGE-CORPUS POSITION
#   Cyrus is the 160th programming language entry in this completion
#   corpus — ROUND-NUMBER LANGUAGE MILESTONE — closing the 3+1
#   micro-cycle that began at R909 (_mongobar / mongodb 3.0.0
#   Rust=135 OPENS Axis 80 MongoDB Driver Library) and continued
#   through R910 (_vi-mongo / go.mongodb.org/mongo-driver v1.14.0
#   Go=135) and R911 (_abe / mongodb (Node) ^4.9.1 TS-Node=135
#   CLOSES Axis 80 at 1/1/1 three-language symmetry — triple-135
#   landmark and 73rd axis closed).  Cyrus joins Lumina (R908
#   159th), Penne (R904 158th), EndBASIC (R900 157th — R900
#   TRIPLE-9 commit landmark), goboscript (R896 156th), Alan (R892
#   155th), Mech (R888 154th — triple-8 landmark), Lisette (R884
#   153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th
#   — round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th), Imba
#   (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), and Stanza (R812 135th).
#
#   No completion for `cyrus` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `cyrus-*` completions in the corpus target Cyrus
#   IMAP / SASL utilities;  this `cyrus` is the programming-language
#   compiler driver.
# ============================================================================

_cyrus_compiler_options=(
    '--target=[target triple (defaults to host)]:triple:'
    '--cpu=[target CPU name]:cpu:'
    '--optimize=[optimization level]:level:(none o1 o2 o3 os oz)'
    '*'{-L+,--library-path=}'[library search path (repeatable)]:dir:_files -/'
    '*'{-l+,--library=}'[library to link (repeatable)]:lib:'
    '*--sources=[source directories (repeatable)]:dir:_files -/'
    '*'{-z+,--linker-flags=}'[linker flags (repeatable)]:flags:'
    '-g[generate DWARF debug info]'
    '--build-dir=[build-artifact directory]:dir:_files -/'
    '--base-path=[base path for command]:dir:_files -/'
    '--linker=[linker executable]:linker:_command_names -e'
    '(-q --quiet -V --verbose)'{-q,--quiet}'[suppress unnecessary output]'
    '(-q --quiet -V --verbose)'{-V,--verbose}'[increase output verbosity]'
    '--disable-modulefs-cache[disable module filesystem cache]'
    '--disable-warnings[disable all warnings]'
    '--stdlib=[Cyrus stdlib path]:path:_files -/'
    '--target-machine[display target machine info]'
    '--sanitize=[sanitizers (comma-separated)]:sanitizers:'
    '--reloc-mode=[relocation model]:mode:'
    '--code-model=[code model]:model:'
    '--profile=[build profile]:profile:(debug release)'
    '--abi=[ABI name mangling scheme]:abi:(c cyrus)'
    '--jobs=[compilation thread count]:n:'
    '--module-merge-mode=[module merge mode]:mode:(unified separate)'
)

_cyrus_linker_options=(
    '--static[produce a fully static ELF]'
    '(--no-pie)--pie[enable PIE (position-independent executable)]'
    '(--pie)--no-pie[disable PIE]'
)

_cyrus() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_cyrus_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)
                    _arguments \
                        ':project name:' \
                        '--lib[create a library project]' && ret=0 ;;
                run)
                    _arguments \
                        ':Cyrus source file:_files -g "*.cyrus"' \
                        '*: :_normal' \
                        $_cyrus_compiler_options \
                        $_cyrus_linker_options && ret=0 ;;
                fetch)
                    _arguments \
                        ':library name(s):' && ret=0 ;;
                build)
                    _arguments \
                        '(-o --output-path)'{-o+,--output-path=}'[output path]:output:_files' \
                        ':Cyrus source file:_files -g "*.cyrus"' \
                        $_cyrus_compiler_options \
                        $_cyrus_linker_options && ret=0 ;;
                clean)
                    _arguments $_cyrus_compiler_options && ret=0 ;;
                object|shared-lib|static-lib|emit-llvm|emit-asm|emit-bitcode|emit-cir-dump)
                    _arguments \
                        '(-o --output-path)'{-o+,--output-path=}'[output path]:output:_files' \
                        ':Cyrus source file:_files -g "*.cyrus"' \
                        $_cyrus_compiler_options && ret=0 ;;
                lex-only|parse-only)
                    _arguments \
                        ':Cyrus source file:_files -g "*.cyrus"' && ret=0 ;;
                semantic-only)
                    _arguments \
                        ':Cyrus source file:_files -g "*.cyrus"' \
                        $_cyrus_compiler_options && ret=0 ;;
                version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cyrus_commands] )) ||
_cyrus_commands() {
    local -a commands
    commands=(
        'new:create a new project'
        'run:execute a compiled program'
        'fetch:fetch a library into vendor directory'
        'build:compile source code into an executable'
        'clean:clean build directory'
        'object:generate an object file'
        'shared-lib:generate a dynamic library (shared object)'
        'static-lib:generate a static library'
        'emit-llvm:emit LLVM IR (.ll) per module'
        'emit-asm:emit assembly (.s) per module'
        'emit-bitcode:emit LLVM bitcode (.bc) per module'
        'emit-cir-dump:emit textual CIR (.cir) per module'
        'lex-only:lexical analysis only'
        'parse-only:display the program tree'
        'semantic-only:check program correctness semantically'
        'version:print version information'
    )
    _describe -t commands 'cyrus command' commands
}

_cyrus "$@"
