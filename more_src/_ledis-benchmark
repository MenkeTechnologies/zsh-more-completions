#compdef ledis-benchmark
# Documentation: https://github.com/ledisdb/ledisdb/blob/master/cmd/benchmark.go
# Benchmark tool for LedisDB (also works against redis/ssdb)

local ret=1

_arguments -s -S \
  '-ip=[redis/ledis/ssdb server ip]:host:_hosts' \
  '-port=[redis/ledis/ssdb server port]:port:' \
  '-c+[number of clients]:clients:' \
  '-n+[request number]:number:' \
  '-r+[benchmark round number]:rounds:' \
  '-vsize=[kv value size]:bytes:' \
  '-t+[comma-separated list of tests to run]:tests:' && ret=0

return ret
