#compdef R-CMD-config
# _R-CMD-config — R Core Team R CMD config print compiler and linker flags from R install for build setup (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--ldflags[show LDFLAGS]' \
        '--cppflags[show CPPFLAGS]' \
        '--no-user-files[no user files]' \
        '--no-site-files[no site files]' \
        '--all[show all settings]' \
        '*:variable:(CC CFLAGS CPICFLAGS CPPFLAGS CXX CXXFLAGS CXXPICFLAGS CXXSTD CXX98 CXX98FLAGS CXX98PICFLAGS CXX11 CXX11FLAGS CXX11PICFLAGS CXX14 CXX14FLAGS CXX14PICFLAGS CXX17 CXX17FLAGS CXX17PICFLAGS CXX20 CXX20FLAGS CXX20PICFLAGS CXX23 CXX23FLAGS CXX23PICFLAGS F77 FFLAGS FPICFLAGS FC FCFLAGS FCPICFLAGS LD LDFLAGS BLAS_LIBS LAPACK_LIBS DYLIB_EXT DYLIB_LDFLAGS DYLIB_LD AR RANLIB STRIP MAKE TAR TCLTK_CPPFLAGS TCLTK_LIBS LIBR LIBnn R_INCLUDE_DIR R_HOME R_ARCH R_LIBS R_SHARE_DIR R_DOC_DIR R_INCLUDE_DIR JAVA JAVAH JAVAC JAVA_HOME JAR JAVA_CPPFLAGS JAVA_LIBS JAVA_LD_LIBRARY_PATH PCRE_INCLUDE_DIR PCRE_LIBS XML2_CFLAGS XML2_LIBS LZMA_INCLUDE_DIR LZMA_LIBS PROJ_LIBS GIT)'
}

_R-CMD-config "$@"
