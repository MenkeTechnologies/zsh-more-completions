#compdef sfspray
# Documentation: https://github.com/ahay/src/blob/master/system/main/spray.c
# Madagascar: extend a dataset by duplicating in the specified axis (adjoint of sfstack)

local ret=1

_arguments -s -S \
  'axis=[which axis to spray]:axis' \
  'n=[size of the newly created dimension]:n' \
  'd=[sampling of the newly created dimension]:d' \
  'o=[origin of the newly created dimension]:o' \
  'label=[label of the newly created dimension]:label' \
  'unit=[units of the newly created dimension]:unit' \
  '*:RSF file:_files' && ret=0

return ret
