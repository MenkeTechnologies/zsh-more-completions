#compdef kubevela

# Zsh completion for kubevela - Kubernetes application delivery platform

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-e --env)'{-e,--env}'[specify environment name]:environment' \
  '(-n --namespace)'{-n,--namespace}'[specify namespace]:namespace' \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Create scaffold for an application'
      'up:Deploy an application'
      'show:Show details of an application'
      'status:Show status of an application'
      'ls:List applications'
      'delete:Delete an application'
      'env:Manage environments'
      'comp:Manage components'
      'trait:Manage traits'
      'adopt:Adopt existing resources into an application'
      'cluster:Manage clusters'
      'version:Print version information'
      'help:Help about any command'
    )
    _describe -t commands 'kubevela command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      help)
        local -a commands=(
          'init:Create scaffold for an application'
          'up:Deploy an application'
          'show:Show details of an application'
          'status:Show status of an application'
          'ls:List applications'
          'delete:Delete an application'
          'env:Manage environments'
          'comp:Manage components'
          'trait:Manage traits'
          'adopt:Adopt existing resources into an application'
          'cluster:Manage clusters'
          'version:Print version information'
        )
        _describe -t commands 'kubevela command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
