#compdef termusic

# Zsh completion for termusic - terminal music player written in Rust

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --disable-album-art-from-cli)'{-c,--disable-album-art-from-cli}'[disable album art on CLI start]' \
  '(-C --disable-discord)'{-C,--disable-discord}'[disable Discord status]' \
  '(-m --max-depth)'{-m,--max-depth}'[max depth for scanning]:depth' \
  '--music-directory[music directory]:dir:_directories' \
  '(-b --backend)'{-b,--backend}'[audio backend]:backend:(rusty mpv gst)' \
  '*:music file or directory:_files' && ret=0

return ret
