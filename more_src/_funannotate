#compdef funannotate
# _funannotate — Jonathan Palmer funannotate fungal genome annotation pipeline gene prediction repeat masking annotation comparison (nextgenusfs team, Python); argparse subcommands
# upstream: https://github.com/nextgenusfs/funannotate

_funannotate() {
    local -a sub=(
        'clean:remove short contigs'
        'sort:sort assembly contigs'
        'mask:repeat-mask assembly'
        'train:RNA-seq transcript training'
        'predict:gene prediction'
        'update:update annotation'
        'fix:fix annotation'
        'compare:compare multiple genomes'
        'annotate:functional annotation'
        'iprscan:run InterProScan locally'
        'remote:run remote annotation'
        'eggnog:run EggNOG-mapper'
        'phobius:run Phobius locally'
        'antismash:run antiSMASH'
        'outgroups:manage outgroups'
        'database:setup or update databases'
        'check:test installation'
        'species:show available species'
        'util:utility subcommands'
        'tax:show taxonomy info'
        'mergegenes:merge GeneMark and Augustus'
        'tbl2gbk:convert TBL to GBK'
        'test:run test suite'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'funannotate subcommand' sub ;;
        args)
            case $words[1] in
                clean|sort|mask|predict|update|annotate|train) _arguments \
                    '-i+[input genome fasta]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
                    '--input=+[input genome fasta]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
                    '-o+[output dir]:dir:_files -/' \
                    '--out=+[output dir]:dir:_files -/' \
                    '-s+[species]:str:' \
                    '--species=+[species]:str:' \
                    '--cpus=+[N]:n:' \
                    '--isolate=+[isolate]:str:' \
                    '--strain=+[strain]:str:' \
                    '--name=+[locus prefix]:str:' \
                    '--gmap_gff=+[gmap gff]:file:_files' \
                    '--rna_bam=+[rna bam]:file:_files -g "*.bam"' \
                    '--protein_evidence=+[protein fasta]:file:_files' \
                    '--transcript_evidence=+[transcript fasta]:file:_files' \
                    '--repeats2evm[use repeats in evm]' \
                    '--organism=+[org]:o:(fungus other)' \
                    '--SeqCenter=+[name]:str:' \
                    '--SeqAccession=+[accession]:str:' \
                    '--header_length=+[N]:n:' \
                    '--busco_db=+[BUSCO db]:str:' \
                    '--busco_seed_species=+[species]:str:' \
                    '--max_intronlen=+[N]:n:' \
                    '--min_intronlen=+[N]:n:' \
                    '--min_protlen=+[N]:n:' \
                    '--ploidy=+[N]:n:' \
                    '--repeatmasker_species=+[species]:str:' \
                    '--repeatmodeler_lib=+[file]:file:_files' \
                    '--method=+[method]:m:(repeatmasker repeatmodeler tantan)' \
                    '--cleaned[input is already cleaned]' \
                    '--debug[debug mode]' ;;
                compare) _arguments \
                    '-i+[input gbks csv]:str:' \
                    '-o+[output dir]:dir:_files -/' \
                    '--cpus=+[N]:n:' \
                    '--num_orthos=+[N]:n:' \
                    '--proteinortho=+[mode]:m:(local cloud)' \
                    '--bootstrap=+[N]:n:' \
                    '--outgroup=+[outgroup]:str:' ;;
                database) _arguments \
                    '--show-outdated[show outdated databases]' \
                    '--update-pdf[update pdf]' \
                    '--update[update databases]' \
                    '-d+[database dir]:dir:_files -/' \
                    '--database=+[database dir]:dir:_files -/' ;;
                iprscan|antismash|eggnog|phobius) _arguments \
                    '-i+[input dir]:dir:_files -/' \
                    '-m+[method]:str:' \
                    '--cpus=+[N]:n:' ;;
            esac
            ;;
    esac
}

_funannotate "$@"
