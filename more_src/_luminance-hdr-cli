#compdef luminance-hdr-cli
# Documentation: https://luminancehdr.readthedocs.io/en/latest/creating_hdr/command_line/
# Luminance HDR command line: create and tone map HDR images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --verbose)'{-v,--verbose}'[print more messages during execution]' \
  '(-a --align)'{-a,--align}'=[align engine for HDR creation]:engine:(AIS MTB)' \
  '(-e --ev)'{-e,--ev}'=[EV values, one per input file]:ev list' \
  '(-c --config)'{-c,--config}'=[configure HDR creation weight/response/model]:config' \
  '(-l --load)'{-l,--load}'=[load an existing HDR file]:hdr file:_files' \
  '(-s --save)'{-s,--save}'=[save to an HDR file format]:hdr file:_files' \
  '(-g --gamma)'{-g,--gamma}'=[gamma value for tone mapping (default 1)]:value' \
  '(-r --resize)'{-r,--resize}'=[width to resize HDR to]:width' \
  '(-t --tmo)'{-t,--tmo}'=[tone mapping operator]:operator:(ashikhmin drago durand fattal pattanaik reinhard02 reinhard05 mantiuk06 mantiuk08)' \
  '(-p --tmoptions)'{-p,--tmoptions}'=[tone mapping operator parameters]:options' \
  '(-o --output)'{-o,--output}'=[output LDR file name]:ldr file:_files' \
  '(-q --quality)'{-q,--quality}'=[quality of saved LDR file (0-100)]:value' \
  '*:input file:_files' && ret=0

return ret
