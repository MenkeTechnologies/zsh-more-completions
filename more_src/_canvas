_canvas() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _cv_cmds=(
                'run:run a Canvas application'
                'export:export the action log of a Canvas application'
                'import:import an action log into a Canvas application'
                'info:show info about a Canvas application'
            )
            _describe -t commands 'canvas command' _cv_cmds && ret=0
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '1:application directory or *.canvas.js contract:_files' \
                        '--init=[path to contract to copy if app dir missing]:contract:_files -g "*.canvas.js *.canvas.ts *.js *.ts"' \
                        '--port=[HTTP API port (default 8000)]:port:' \
                        '--offline[disable libp2p (run as centralized server only)]' \
                        '*--listen=[internal /ws multiaddr]:multiaddr:' \
                        '*--announce=[external /ws multiaddr]:multiaddr:' \
                        '--replay[erase + rebuild DB by replaying action log]' \
                        '--static=[serve static directory from /]:dir:_files -/' \
                        '*--bootstrap=[initial application peers (multiaddrs)]:multiaddr:' \
                        '--max-connections=[max libp2p connections]:n:' \
                        '--verbose[log messages to stdout]' \
                        '--disable-http-api[disable HTTP API server]' \
                        '--repl[start an action REPL]' \
                        '--network-explorer[serve the network-explorer web UI]' \
                        '--admin=[Ethereum address allowed to migrate (or any)]:address:' \
                        '--connect=[connect GossipLog to a WebSocket URL (disables libp2p)]:ws-url:' \
                        '--help[show help]' && ret=0
                    ;;
                export|info)
                    _arguments \
                        '1:application directory:_files -/' \
                        '--help[show help]' && ret=0
                    ;;
                import)
                    _arguments \
                        '1:application directory or *.canvas.js contract:_files' \
                        '*--files=[input action-log files]:file:_files' \
                        '--replay[replay actions after import]' \
                        '--help[show help]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_canvas "$@"
