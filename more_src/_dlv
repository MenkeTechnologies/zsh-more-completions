#compdef dlv

# Zsh completion for dlv - Delve Go debugger

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'attach:attach to a running process'
  'connect:connect to a headless debug server'
  'core:examine a core dump'
  'dap:start a DAP server'
  'debug:compile and begin debugging main package or specified package'
  'exec:execute a precompiled binary and begin a debug session'
  'test:compile test binary and begin debugging'
  'trace:compile and begin tracing program'
  'version:print version'
)

local -a common_flags=(
  '(- *)'{-h,--help}'[show help]'
  '--accept-multiclient[allow a headless server to accept multiple client connections]'
  '--api-version[select API version when headless]:version:(2)'
  '--backend[backend selection]:backend:(default native lldb rr)'
  '--build-flags[build flags passed to the Go compiler]:flags:'
  '--check-go-version[check that the Go version is compatible]'
  '--headless[run debug server in headless mode]'
  '--init[init file to execute at startup]:file:_files'
  '--listen[address for the debugger to listen on]:addr\:port:'
  '--log[enable debug logging]'
  '--log-dest[write logs to specified file or listener]:destination:_files'
  '--log-output[comma-separated list of components for logging]:components:'
  '--only-same-user[only allow connections from the same user]'
  '--wd[working directory for the program being debugged]:directory:_directories'
  '--redirect[redirect stdin/stdout/stderr]:redirect:'
  '--allow-non-terminal-interactive[allow interactive prompts from non-terminal]'
  '--disable-aslr[disable address space layout randomization]'
)

_arguments -s -S \
  $common_flags \
  '1:subcommand:->subcommand' \
  '*:argument:->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'dlv subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      attach)
        _arguments $common_flags \
          '1:pid:_pids'
        ;;
      connect)
        _arguments $common_flags \
          '1:address:'
        ;;
      core)
        _arguments $common_flags \
          '1:executable:_files' \
          '2:core dump:_files'
        ;;
      debug|test)
        _arguments $common_flags \
          '1:package path:_directories'
        ;;
      exec)
        _arguments $common_flags \
          '1:binary:_files -g "*(-.x)"'
        ;;
      trace)
        _arguments $common_flags \
          '1:package path:_directories'
        ;;
    esac
    ;;
esac

return ret
