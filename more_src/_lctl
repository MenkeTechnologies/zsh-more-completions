#compdef lctl
# Documentation: https://man.archlinux.org/search?q=lctl
# Reference accessed: 2026-05-16

# lctl: Lustre control utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'list_param:list Lustre proc/sys params'
  'get_param:get a param'
  'set_param:set a param'
  'conf_param:set a config param'
  'mark:mark debug log'
  'debug_kernel:flush kernel debug ring buffer'
  'debug_daemon:debug log daemon'
  'debug_file:read/write debug file'
  'debug_list:list debug subsystem masks'
  'filter:set debug log filter'
  'show:show debug log'
  'clear:clear debug log'
  'help:show help'
  'lustre_build_version:show Lustre build version'
  'dl:list Lustre devices'
  'device_list:list Lustre devices'
  'network:network configuration'
  'add_uuid:add UUID mapping'
  'del_uuid:delete UUID mapping'
  'add_peer:add LNet peer'
  'add_route:add LNet route'
  'del_route:delete LNet route'
  'add_interface:add network interface'
  'del_interface:delete network interface'
  'add_conn:add LNet connection'
  'list_nids:list LNet NIDs'
  'replace_nids:replace NIDs'
  'ping:LNet ping'
  'lnetctl:LNet control subcommands'
  'snmp:SNMP info'
  'ldlm_get_state:print LDLM state'
  'route_list:list routes'
  'peer_list:list peers'
  'changelog_register:register changelog user'
  'changelog_deregister:deregister changelog user'
  'fid2path:FID -> path'
  'path2fid:path -> FID'
  'pool_new:create OST pool'
  'pool_add:add OSTs to pool'
  'pool_remove:remove OSTs from pool'
  'pool_destroy:destroy OST pool'
  'ulist_param:undocumented'
  'cleanup:clean up obd device'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'lctl command' commands && ret=0 ;;
esac
return ret
