#compdef dibbler-client
# Documentation: https://man.archlinux.org/search?q=dibbler-client
# Reference accessed: 2026-05-16

# dibbler-client: Dibbler DHCPv6 client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1:action:(run start stop status install uninstall help)' && ret=0
return ret
