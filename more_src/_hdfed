#compdef hdfed
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdfed.1.en.html
# Interactively browse and edit the contents of an HDF file

local ret=1

_arguments -s \
  '-nobackup[make no backup file]' \
  '-batch[read a stream of hdfed commands instead of interactive input]' \
  '-help[output usage information and command list]' \
  '1:hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
