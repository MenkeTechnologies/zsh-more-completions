#compdef clusterloader2 clusterloader
# _clusterloader2 — Kubernetes scale/performance test driver (kubernetes/perf-tests)
# upstream: https://github.com/kubernetes/perf-tests
# Flags from clusterloader2/cmd/clusterloader.go (pflag/EnvFlags).

_clusterloader2() {
    _arguments \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--run-from-cluster[use in-cluster config]' \
        '--nodes=[number of nodes]:n:' \
        '--kubelet-port=[kubelet port]:port:' \
        '--k8s-clients-number=[number of k8s clients]:n:' \
        '--etcd-certificate=[etcd certificate path]:file:_files' \
        '--etcd-key=[etcd key path]:file:_files' \
        '--etcd-insecure-port=[etcd insecure http port]:port:' \
        '--delete-stale-namespaces[delete stale namespaces (deprecated)]' \
        '--delete-automanaged-namespaces=[delete automanaged namespaces]:val:(true false)' \
        '--mastername=[master node name]:name:' \
        '*--masterip=[master node hostname/IP]:ip:' \
        '*--master-internal-ip=[master internal IP]:ip:' \
        '--master-endpoint=[master DNS endpoint]:endpoint:' \
        '--apiserver-pprof-by-client-enabled=[expose apiserver pprof]:val:(true false)' \
        '--skip-cluster-verification[skip cluster verification]' \
        '--provider=[cluster provider]:provider:(gke gce aws skeleton kubemark kind)' \
        '*--provider-configs=[provider configurations]:cfg:' \
        '--kubemark-root-kubeconfig=[kubemark root kubeconfig]:file:_files' \
        '--report-dir=[directory for report files]:dir:_files -/' \
        '*--testconfig=[test config file]:file:_files' \
        '*--testoverrides=[config override file]:file:_files' \
        '--testsuite=[test suite config file]:file:_files' \
        '--port=[port for pprof http server]:port:' \
        '--heap-profile-interval=[heap profile interval (Go duration)]:duration:' \
        '--dry-run[compile config but skip test execution]'
}

_clusterloader2 "$@"
