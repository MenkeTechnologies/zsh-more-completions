#compdef kubeaudit2
# _kubeaudit2 — Shopify kubeaudit2 CLI command-line frontend wrapping the kubeaudit command line tool and a Go package that audits Kubernetes clusters for various different security concerns open-source written in Go usable both as a standalone CLI or as a library detect 12+ security concerns Allow-privilege-escalation default-container-name Drop-Linux-capabilities Privilege-escalation hostNetwork hostPID hostIPC AppArmor Limits Resource-requests-limits NetworkPolicies AutomountServiceAccountToken Privileged ReadOnlyRootFilesystem RunAsNonRoot Seccomp ServiceAccount commands cluster manifest local autofix mtls config exemption all (Shopify team Marc-Etienne M.Léveillé Brittan-Hayward Naomi-Reeves, Go); cobra
# upstream: https://github.com/Shopify/kubeaudit

_kubeaudit2() {
    local -a sub=(
        'all:audit against all auditors'
        'apparmor:audit AppArmor annotations'
        'asat:audit AutomountServiceAccountToken'
        'autofix:autofix manifests'
        'capabilities:audit Linux capabilities'
        'cap:audit capabilities'
        'deprecatedapis:audit deprecated APIs'
        'hostns:audit host namespaces'
        'image:audit container images'
        'limits:audit resource limits'
        'mounts:audit dangerous mounts'
        'netpols:audit network policies'
        'nonroot:audit RunAsNonRoot'
        'privesc:audit AllowPrivEscalation'
        'privileged:audit Privileged'
        'rootfs:audit ReadOnlyRootFilesystem'
        'seccomp:audit Seccomp annotations'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-f+[manifest file]:file:_files -g "*.yaml *.yml *.json"' \
        '--manifest=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-k+[kubeconfig file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '--kubeconfig=+[file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '-c+[context]:str:' \
        '--context=+[name]:str:' \
        '--exitcode=+[code]:n:' \
        '-e+[exit code]:n:' \
        '-l+[min log level]:l:(DEBUG INFO WARN ERROR)' \
        '--minseverity=+[l]:l:(DEBUG INFO WARN ERROR)' \
        '-p+[format]:f:(pretty logrus json)' \
        '--format=+[fmt]:f:(pretty logrus json)' \
        '--no-color[no color]' \
        '--auditors=+[list]:str:' \
        '-i+[image]:str:' \
        '--image=+[image]:str:' \
        '-d+[drop capabilities]:str:' \
        '--drop=+[caps]:str:' \
        '-a+[add capabilities]:str:' \
        '--add=+[caps]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '-o+[output file]:file:_files' \
        '--out=+[file]:file:_files' \
        '--include-comments[include comments]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubeaudit subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_kubeaudit2 "$@"
