#compdef zramctl
# _zramctl-cli — util-linux zramctl zram block device control; create, reset, resize compressed swap/loop devices
# upstream: https://github.com/util-linux/util-linux

_zramctl-cli() {
    _arguments \
        '(-a --algorithm)'{-a,--algorithm}'+[compression algorithm]:algo:(lzo lzo-rle lz4 lz4hc zstd 842)' \
        '(-b --bytes)'{-b,--bytes}'[show sizes in bytes]' \
        '(-f --find)'{-f,--find}'[find first free zram]' \
        '(-n --noheadings)'{-n,--noheadings}'[no header in tabular output]' \
        '(-o --output)'{-o,--output}'+[columns]:cols:' \
        '(-O --output-all)'{-O,--output-all}'[all columns]' \
        '--raw[raw output]' \
        '(-r --reset)'{-r,--reset}'[reset device]' \
        '(-s --size)'{-s,--size}'+[size]:size:' \
        '(-t --streams)'{-t,--streams}'+[concurrent streams]:n:' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:zram device:_files'
}

_zramctl-cli "$@"
