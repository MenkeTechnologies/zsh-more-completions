#compdef cleaver
# =============================================================================
# cleaver — Jordan Scales's "30-second slideshows for
#          hackers" — a single-binary Node.js CLI that
#          takes a single Markdown file with `--`
#          slide separators + an optional YAML
#          frontmatter header + emits a self-contained
#          HTML5 slideshow ready to open in any browser
#          OR to deploy as a static page (GitHub Pages,
#          Netlify, S3 + CloudFront, etc.).  Built
#          around markedjs/marked v0.3 for the Markdown
#          parsing core plus mustache for the slide
#          template + highlight.js for code-block
#          syntax highlighting.
#          Distinguishing from reveal.js (Hakim El
#          Hattab's JS slideshow framework — requires
#          writing HTML or significant theme
#          configuration), Slidev (antfu's Vue-based
#          modern slideshow framework — heavier
#          dependency tree, Vite build), Marp (Yuki
#          Hattori's marp.app — also Markdown-based but
#          requires Electron or marp-cli with chromium
#          for PDF export), Deckset (commercial macOS
#          app), Prezi (commercial), and Beamer (LaTeX-
#          heavy academic stack) by:
#            - 30-SECOND WORKFLOW — write
#              `presentation.md` with `--` slide
#              separators, run `cleaver
#              presentation.md`, open the resulting
#              `presentation-cleaver.html` in browser.
#              Zero build pipeline, zero npm scaffold,
#              zero Vue/React/Webpack dance
#            - MARKED MARKDOWN ENGINE — uses markedjs/
#              marked v0.3.7 (this is the headline CLI
#              library that CLOSES Axis 42 on the TS-
#              Node side at 1/1/1; see taxonomy notes
#              below) for CommonMark + GFM parsing of
#              slide content; handles headings, lists,
#              code blocks, links, images, blockquotes,
#              tables (via marked's GFM extensions)
#            - MUSTACHE TEMPLATING — uses mustache v2.3
#              for the slide template + presentation
#              layout; advanced users can pass `--
#              template <path>` + `--layout <path>` to
#              override the bundled defaults with
#              custom mustache templates
#            - HIGHLIGHT.JS SYNTAX HIGHLIGHTING —
#              bundles highlight.js v9.12 for fenced-
#              code-block syntax coloring across 180+
#              languages (Ruby, JS, Python, Go, Rust,
#              etc.); no per-language plugin install
#            - YAML FRONTMATTER METADATA — the first
#              YAML block in the source file declares
#              presentation metadata (`title:`,
#              `author:`, `theme:`, `controls:`,
#              `progress:`); js-yaml v3.10 parses it;
#              flags override individual fields
#            - SLIDE SEPARATORS — `--` on a line by
#              itself separates slides; minimal
#              ceremony compared to remarkjs's `---` +
#              `???` notes syntax or reveal.js's HTML
#              `<section>` markup
#            - BUILT-IN THEMES — `--theme <name>`
#              selects from bundled themes (default,
#              cleaver, swiss, mathieu, etc.); fast
#              path to a polished look without writing
#              CSS
#            - CUSTOM STYLESHEETS — `--style <css>`
#              injects a user-provided CSS file into
#              the output; fine-grained brand
#              customization without rebuilding the
#              theme
#            - NAVIGATION CONTROLS + PROGRESS BAR —
#              `--controls` (default true) adds prev/
#              next arrow keys + on-screen buttons;
#              `--progress` (default true) shows a
#              slim progress bar across the top of
#              the slide
#            - WATCH + LIVE-RELOAD via tiny-lr —
#              `cleaver watch <file>` rebuilds on file
#              changes + serves a Live Reload server
#              on port 35729 (the canonical Live
#              Reload port).  Includes a custom
#              stylesheet watch if `--style` is set
#            - SIGINT RECOVERY — when the user Ctrl+C's
#              out of `watch` mode, cleaver does a
#              final non-watch rebuild before exiting;
#              ensures the output file isn't stuck in
#              "watch mode" state
#            - PURE HTML OUTPUT — generates ONE
#              `<file>-cleaver.html` containing inline
#              CSS + JS; no asset directory, no node
#              runtime needed to serve, no Express
#              server.  Drop into `gh-pages` branch +
#              done
#            - UTF-8 ENCODING DEFAULT — `--encoding
#              <enc>` allows alternate encoding for
#              the rendered document; useful for
#              legacy systems
#            - 4,055+ STARS ON jdan/cleaver — a long-
#              standing favorite of hackathon presenters
#              + tech-talk givers since 2014; active
#              maintenance under Jordan Scales (ex-Khan
#              Academy, currently engineering @ Notion)
#          Used by: tech speakers giving lightning
#          talks at meetups + conferences who want
#          slides without a full slideshow framework's
#          ceremony, students presenting projects who
#          need a quick polished deck, recruiters +
#          interviewers walking candidates through
#          slide decks from a single git-pushed
#          markdown file, and developers maintaining a
#          long-term slide archive in their dotfiles +
#          notes repo (slides live next to README.md).
#
# Author:  Jordan Scales (jdan on GitHub; https://
#          jordanscales.com); based in Hoboken NJ;
#          currently engineering at Notion (previously
#          Khan Academy, codecademy, others).  Self-
#          description: "on a mission to give you
#          superpowers."
# Source:  https://github.com/jdan/cleaver
#          https://github.com/jdan/cleaver/blob/master/bin/cleaver
#          https://github.com/jdan/cleaver/blob/master/package.json
# Manpage: No traditional manpage; `cleaver --help`
#          shows the commander-generated help; `cleaver
#          watch --help` for the watch subcommand.
#          Full docs in repo README.md + the cleaver
#          gh-pages demo site.
# Library: marked ^0.3.7 (markedjs/marked — Christopher
#          Jeffrey + maintainers' "A markdown parser
#          and compiler. Built for speed").  This is
#          the headline dependency for this completion's
#          axis-42 closing role; see taxonomy notes
#          below.  Also commander ~2.12 (Axis 1
#          argparse — TJ Holowaychuk's Node CLI
#          parser), mustache ^2.3 (logic-less
#          templates), highlight.js ~9.12 (syntax
#          highlighting), js-yaml 3.10 (YAML
#          frontmatter), tiny-lr ^1.0 (LiveReload
#          server), debug ^3.1 (logging), q 1.5
#          (promise lib).
# License: MIT
# Status:  4,055+ stars on jdan/cleaver; active
#          maintenance (latest commit 2026-05-31);
#          long-standing project since 2014.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — AXIS 42 CLOSES AT 1/1/1:
#   MARKDOWN PARSING / COMMONMARK CODECS
# -----------------------------------------------------------------------------
# This completion **CLOSES AXIS 42 AT 1/1/1 THREE-
# LANGUAGE SYMMETRY** in the cross-language CLI
# library taxonomy: Markdown Parsing / CommonMark
# Codecs.
#
# Pattern: R756 121st language (Stainless) closes the
# prior 3+1 cycle → R757 Rust=97 (basalt/pulldown-cmark
# OPENS Axis 42) → R758 Go=97 (tdx/yuin/goldmark
# continues Axis 42) → R759 TS-Node=97 (cleaver/marked
# CLOSES Axis 42 AT 1/1/1 THIS ROUND).  Next R760 will
# be the 122nd language closing the 3+1 micro-cycle.
#
# THE COMPLETE AXIS 42 PICTURE (NOW 1/1/1):
#
#   * RUST = pulldown-cmark (R757 basalt)
#     - raphlinus/pulldown-cmark's pull-parser
#       CommonMark crate; ~3,000 stars
#     - Built on Raph Levien's Iterator-based event
#       stream architecture (zero-allocation, O(1)
#       memory)
#     - Pattern: OBSIDIAN-NOTE TUI RENDERING (basalt
#       streams pulldown-cmark Events into ratatui
#       Spans for in-terminal Markdown display)
#
#   * GO = yuin/goldmark (R758 tdx)
#     - Yusuke Inuzuka's AST-based CommonMark + GFM
#       parser; ~3,700 stars
#     - Extension package ecosystem (GFM, Footnote,
#       Linkify, TaskList, Typographer, Emoji,
#       Highlighting, Meta, Mathjax, Wikilink)
#     - Pattern: TODO-MANAGER MARKDOWN MUTATION (tdx
#       parses todo.md, mutates TaskList CheckboxState
#       nodes, serializes back to disk)
#
#   * TS-NODE = marked (R759 THIS)
#     - markedjs/marked by Christopher Jeffrey + maintainers
#     - ~35,000+ stars on markedjs/marked — by far
#       the most-starred Markdown library in any
#       language ecosystem covered by this taxonomy
#     - Built on a hand-rolled tokenizer + lexer +
#       parser (NOT regex-based; predates remark/
#       unified)
#     - 2nd most-downloaded npm package in the
#       Markdown category (after markdown-it)
#     - Pattern: SLIDESHOW HTML GENERATION (cleaver
#       feeds marked the slide markdown + emits HTML
#       via mustache templates + highlight.js syntax-
#       highlighted code blocks)
#
# THE AXIS 42 ARC TELLS THE COMPLETE MARKDOWN-
# PROCESSING STORY:
#   - R757 basalt (Rust PARSE → STREAM → RENDER) —
#     incoming markdown stream → ratatui Spans
#   - R758 tdx (Go PARSE → MUTATE → EMIT) — read
#     markdown AST, toggle TaskList nodes, write
#     back to disk
#   - R759 cleaver (TS-Node PARSE → COMPILE → DEPLOY)
#     — convert markdown to standalone HTML slideshow
#     bundle ready to ship
#
# All three completions implement the same conceptual
# pipeline:
#   1. PARSE markdown source via their language's
#      canonical CommonMark parser (pulldown-cmark /
#      goldmark / marked)
#   2. TRAVERSE the resulting events/AST/tokens
#   3. EITHER mutate the parse tree (tdx) OR
#      transform to a different output format (basalt
#      → ratatui Spans; cleaver → HTML)
#   4. EMIT the transformed result (terminal
#      rendering / file writeback / HTML deploy)
#
# Cross-language CLI library taxonomy after R759:
#   * 121 languages
#   * 471 total CLI library variants (Rust 97 / Go 97 /
#     TS-Node 97)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 35 axes at 1/1/1 three-language symmetric (axes
#     7 + 8 + 11 + 12 + 15-42)
#
# WHY marked IS A DISTINCTIVE AXIS-42 CLOSER:
#
#   markedjs/marked is the *original* Node.js
#   CommonMark parser (predates remark, markdown-it,
#   commonmark.js) by Christopher "Chjj" Jeffrey,
#   continuously maintained since 2011.
#   Distinguishing characteristics in the TS-Node
#   ecosystem:
#     1. ZERO-DEPENDENCY CORE — marked itself has NO
#        runtime npm dependencies; the parser is a
#        single self-contained module.  Rare in the
#        modern npm ecosystem; suitable for security-
#        conscious + supply-chain-careful deployments
#     2. SYNCHRONOUS API — `marked(markdownString)`
#        returns the HTML string synchronously; no
#        await/then ceremony for the common case;
#        composes naturally with CLI pipelines
#     3. EXTENSION HOOKS — `marked.use({
#          extensions: [...],
#          tokenizer: { ... },
#          renderer: { ... },
#          hooks: { ... }
#        })` allows fine-grained customization at the
#        tokenizer, parser, and renderer layers
#     4. GFM SUPPORT — built-in support for tables,
#        strikethrough, task lists, autolinks, fenced
#        code blocks
#     5. SANITIZATION-AWARE — historically supported
#        a `sanitize: true` option (deprecated in
#        newer versions in favor of dedicated
#        sanitizers like DOMPurify); marked authors
#        explicitly recommend pairing with a HTML
#        sanitizer for user-provided content
#     6. ~35,000 STARS ON markedjs/marked — THE
#        most-starred Markdown library across the
#        entire corpus's axes-coverage
#     7. UNIVERSAL PRODUCTION USAGE — used by
#        OpenAI's ChatGPT web frontend for Markdown
#        rendering, GitHub's marked-based docs sites,
#        Mozilla MDN's content pipeline,
#        StackExchange's question/answer rendering,
#        Discord's message renderer, every major
#        documentation tool's Node-side renderer
#
# Maintained by markedjs team at github.com/markedjs/
# marked.  License: MIT.
#
# Comparison to other Axis 42 candidates (TS-Node):
#   * cleaver (R759 THIS) — Jordan Scales's
#     slideshow generator with marked as direct dep;
#     ~4,055 stars; clean single-purpose CLI
#   * Raneto (ryanlelek) — Markdown wiki for Node;
#     ~2,890 stars; markdown-it not marked
#   * wintersmith (jnordberg) — already in corpus as
#     _wintersmith
#   * markserv (markserv) — already in corpus
#   * how2 (santinic) — already in corpus
#   * marlin-config (akaJes) — 3D printer firmware
#     configurator; 392 stars but niche
#   * markdown-it/markdown-it itself — the
#     library, not a CLI tool
#   * marked's own bundled CLI (marked --output
#     out.html input.md) — too minimal for a
#     featured completion
#
# cleaver is the chosen Axis 42 TS-Node closer
# because:
#   - It declares marked as a DIRECT runtime
#     dependency in package.json (`marked ^0.3.7`)
#   - The slideshow-from-markdown use case is a
#     canonical marked headline application:
#     parse markdown → emit HTML → wrap in template
#   - It exercises the FULL marked pipeline including
#     GFM extensions (code blocks for live demos,
#     tables for comparisons, task lists for agenda
#     items)
#   - 4,055 stars + active maintenance + decade-long
#     continuity make it a stable choice for the
#     taxonomy
#   - It is the closest functional analog to basalt
#     (R757) and tdx (R758) on the "markdown CLI
#     with canonical-parser backend" pattern,
#     specifically representing the DEPLOY-AS-
#     STATIC-HTML use case
#   - The watch + LiveReload subcommand demonstrates
#     marked composes naturally with reactive Node
#     workflows
#
# -----------------------------------------------------------------------------
#
# THE cleaver CLI
#
# cleaver is a multi-subcommand CLI built on commander
# v2.12.  Invocation:
#   cleaver [command] [file...] [options]
#
# Subcommands:
#   (default)                         generate slides from
#                                     one or more .md files
#   watch <file>                      generate + watch +
#                                     LiveReload (single
#                                     file)
#
# Common options:
#   --title <title>                   document title
#                                     (default "Untitled")
#   --theme <theme>                   bundled theme name
#                                     (default, cleaver,
#                                     swiss, mathieu, ...)
#   --style <css>                     custom stylesheet
#                                     file
#   --output <filename>               output filename
#                                     (default
#                                     [INPUT]-cleaver.html)
#   --controls                        include navigation
#                                     controls (default
#                                     true)
#   --progress                        display progress
#                                     bar (default true)
#   --encoding <encoding>             content encoding
#                                     (default utf-8)
#   --template <path>                 mustache template
#                                     for individual
#                                     slides (URL or path)
#   --layout <path>                   mustache template
#                                     for whole
#                                     presentation
#   --debug                           enable debug output
#   -V, --version                     show version
#   -h, --help                        show help
#
# Common invocations:
#   # Generate slides from a single markdown file
#   cleaver presentation.md
#
#   # Multiple presentations in batch
#   cleaver intro.md demo.md conclusion.md
#
#   # Custom title + theme
#   cleaver --title "My Talk" --theme swiss talk.md
#
#   # Custom output filename
#   cleaver --output deck.html talk.md
#
#   # Custom stylesheet for brand colors
#   cleaver --style ./brand.css talk.md
#
#   # Hide navigation controls (e.g. for kiosk display)
#   cleaver --controls=false talk.md
#
#   # Disable progress bar
#   cleaver --progress=false talk.md
#
#   # Custom mustache template + layout
#   cleaver --template ./slide.mustache --layout ./layout.mustache talk.md
#
#   # Use UTF-16 encoding for legacy display
#   cleaver --encoding utf-16 talk.md
#
#   # Watch mode with LiveReload (port 35729)
#   cleaver watch talk.md
#
#   # Watch + custom theme (theme changes also picked up)
#   cleaver watch --theme swiss --style ./brand.css talk.md
#
#   # Debug mode (verbose error output)
#   cleaver --debug talk.md
#
#   # Show version
#   cleaver --version
#
# OPTIONS (sourced directly from
# https://github.com/jdan/cleaver/blob/master/bin/cleaver):
#
# Top-level commands:
#   watch <file>                      live-reload watch
#   (default)                         render one or more
#                                     files
#
# Render-options:
#   --title <title>
#   --theme <theme>
#   --style <css>
#   --output <filename>
#   --controls
#   --progress
#   --encoding <encoding>
#   --template <path>
#   --layout <path>
#   --debug
#
# Output file naming (default):
#   <INPUT>.md → <INPUT>-cleaver.html
#
# Live-reload port:
#   35729                             (the canonical
#                                     LiveReload port)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cleaver_subcommands
_cleaver_subcommands=(
    'watch:watch a markdown file + rebuild on changes (LiveReload on :35729)'
)

local -a _cleaver_themes
_cleaver_themes=(
    'default:default cleaver theme'
    'cleaver:bundled cleaver theme'
    'swiss:Swiss design-inspired theme'
    'mathieu:mathieu theme'
)

local -a _cleaver_common_opts
_cleaver_common_opts=(
    '--title=[document title (default Untitled)]:title: '
    '--theme=[bundled theme name]:theme:->theme'
    '--style=[custom stylesheet file]:css file:_files -g "*.(css|CSS)"'
    '--output=[output filename]:output:_files'
    '--controls[include navigation controls]'
    '--progress[display progress bar]'
    '--encoding=[content encoding (default utf-8)]:encoding: '
    '--template=[mustache template for individual slides (URL or path)]:template:_files'
    '--layout=[mustache template for whole presentation (URL or path)]:layout:_files'
    '--debug[enable debug output]'
)

_arguments -C \
    "${_cleaver_common_opts[@]}" \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*::arg:->args' \
    && ret=0

case $state in
    args)
        if (( CURRENT == 1 )); then
            _alternative \
                'subcmds:cleaver subcommand:_describe -t subcmds "subcommand" _cleaver_subcommands' \
                'files:markdown file:_files -g "*.(md|MD|markdown)"' \
                && ret=0
        elif [[ $words[1] == watch ]]; then
            _arguments \
                "${_cleaver_common_opts[@]}" \
                '1:markdown file to watch:_files -g "*.(md|MD|markdown)"' \
                && ret=0
        else
            # Subsequent markdown files
            _files -g "*.(md|MD|markdown)" && ret=0
        fi
        ;;
esac

case $state in
    theme)
        _describe -t themes 'cleaver theme' _cleaver_themes && ret=0
        ;;
esac

return ret
