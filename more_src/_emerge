#compdef emerge

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --ask)'{-a,--ask}'[prompt before performing actions]' \
  '(-b --buildpkg)'{-b,--buildpkg}'[build binary packages]' \
  '(-B --buildpkgonly)'{-B,--buildpkgonly}'[only build binary packages]' \
  '(-c --clean)'{-c,--clean}'[clean the system]' \
  '(-C --unmerge)'{-C,--unmerge}'[unmerge packages]' \
  '(-D --deep)'{-D,--deep}'[deep dependency resolution]' \
  '(-e --emptytree)'{-e,--emptytree}'[reinstall entire dependency tree]' \
  '(-f --fetchonly)'{-f,--fetchonly}'[fetch only]' \
  '(-F --fetch-all-uri)'{-F,--fetch-all-uri}'[fetch from all URIs]' \
  '(-g --getbinpkg)'{-g,--getbinpkg}'[use binary packages from remote]' \
  '(-G --getbinpkgonly)'{-G,--getbinpkgonly}'[only use binary packages]' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
  '(-k --usepkg)'{-k,--usepkg}'[use binary packages if available]' \
  '(-K --usepkgonly)'{-K,--usepkgonly}'[only use binary packages]' \
  '(-l --changelog)'{-l,--changelog}'[show changelog]' \
  '(-n --noreplace)'{-n,--noreplace}'[skip already installed packages]' \
  '(-N --newuse)'{-N,--newuse}'[reinstall on USE flag changes]' \
  '(-o --onlydeps)'{-o,--onlydeps}'[only install dependencies]' \
  '(-O --nodeps)'{-O,--nodeps}'[do not merge dependencies]' \
  '(-p --pretend)'{-p,--pretend}'[display what would be done]' \
  '(-P --prune)'{-P,--prune}'[prune packages]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-r --resume)'{-r,--resume}'[resume last merge]' \
  '(-s --search)'{-s,--search}'[search for packages]' \
  '(-S --searchdesc)'{-S,--searchdesc}'[search package descriptions]' \
  '(-t --tree)'{-t,--tree}'[show dependency tree]' \
  '(-u --update)'{-u,--update}'[update packages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --select)'{-w,--select}'[add to world set]' \
  '(-W --deselect)'{-W,--deselect}'[remove from world set]' \
  '--autounmask=[autounmask behavior]:behavior:(y n write)' \
  '--backtrack=[backtrack steps]:steps' \
  '--binpkg-changed-deps=[changed deps handling]:behavior:(y n)' \
  '--binpkg-respect-use=[respect USE flags]:behavior:(y n)' \
  '--color=[color output]:enabled:(y n)' \
  '--complete-graph[complete dependency graph]' \
  '--depclean[remove unneeded packages]' \
  '--exclude=[exclude atoms]:atoms' \
  '--info[show Portage information]' \
  '--keep-going[continue after errors]' \
  '--load-average=[load average limit]:load' \
  '--newrepo[reinstall on repo changes]' \
  '--nospinner[disable progress spinner]' \
  '--oneshot[do not add to world set]' \
  '--rebuilt-binaries[use rebuilt binaries]' \
  '--root=[use alternate root]:directory:_directories' \
  '--sync[sync repositories]' \
  '--unmerge[unmerge packages]' \
  '--update[update packages]' \
  '--usepkg-exclude=[exclude from binary packages]:atoms' \
  '--with-bdeps=[include build dependencies]:behavior:(y n)' \
  '--with-test-deps=[include test dependencies]:behavior:(y n)' \
  '*:package atom' && ret=0

return ret
