#compdef geant4 geant4.sh geant4-config
# _geant4 — CERN GEANT4 toolkit for the simulation of the passage of particles through matter setup helper (geant4 team, C++); custom argparse
# upstream: https://github.com/Geant4/geant4

_geant4() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--prefix[show install prefix]' \
        '--datasets[show installed datasets]' \
        '--cflags[show compile flags]' \
        '--libs[show link flags]' \
        '--has-feature=+[feature]:f:(geant4ui geant4vis gdml opengl openinventor qt motif raytracer raytracer-x11 openinventor-xt openinventor-soqt RayTracerX g3tog4 g4opengl-osmesa freetype hdf5 usolids tbb tools-fonts)' \
        '--datadir=+[dataset]:str:' \
        '--list-features[list features]' \
        '--list-datasets[list datasets]' \
        '--check-datasets[check installed datasets]' \
        '--install-datasets[install missing datasets]' \
        '--macro=+[macro file]:file:_files -g "*.mac"' \
        '-m+[macro file]:file:_files -g "*.mac"' \
        '--ui=+[UI session]:u:(tcsh csh tcl tcsh qt batch web-gui win32 xm xaw)' \
        '--vis=+[visualization driver]:v:(OGL OGLI OGLS OGLIQt OGLSQt OGLIX OGLSX HepRep VRML1 VRML2 RayTracer Qt3D OpenInventor)' \
        '--multithreaded[multithreaded mode]' \
        '--num-threads=+[N]:n:' \
        '*:macro:_files -g "*.mac"'
}

_geant4 "$@"
