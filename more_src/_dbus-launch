#compdef dbus-launch

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '--sh-syntax[output Bourne shell syntax]' \
  '--csh-syntax[output C shell syntax]' \
  '--auto-syntax[choose syntax based on $SHELL]' \
  '--binary-syntax[output binary syntax]' \
  '--close-stderr[close stderr in launched bus]' \
  '--exit-with-session[exit when X session ends]' \
  '--exit-with-x11[exit when X session ends]' \
  '--autolaunch=[machine ID]:machine-id:' \
  '--config-file=[config file]:file:_files' \
  '*::program:_command_names -e' \
  '*::args:_normal' && ret=0

return ret
