#compdef gltf_validator
# Documentation: https://github.com/KhronosGroup/glTF-Validator
# Validates glTF assets against the glTF specification

local ret=1

_arguments -s -S \
  '(-o --stdout --no-stdout)'{-o,--stdout,--no-stdout}'[print JSON report to stdout instead of a file]' \
  '(-r --validate-resources --no-validate-resources)'{-r,--validate-resources,--no-validate-resources}'[validate contents of embedded and/or referenced resources]' \
  '(-t --write-timestamp --no-write-timestamp)'{-t,--write-timestamp,--no-write-timestamp}'[write UTC timestamp to the validation report]' \
  '(-p --absolute-path --no-absolute-path)'{-p,--absolute-path,--no-absolute-path}'[write absolute asset path to the validation report]' \
  '(-m --messages --no-messages)'{-m,--messages,--no-messages}'[print issue messages to stderr]' \
  '(-a --all --no-all)'{-a,--all,--no-all}'[print all issue messages to stderr; implies --messages]' \
  '(-c --config)'{-c,--config}'[specify a YAML configuration file with validation options]:config:_files' \
  '--threads[number of threads for directory validation]:count:' \
  '*:glTF file:_files' && ret=0

return ret
