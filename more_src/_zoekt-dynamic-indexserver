#compdef zoekt-dynamic-indexserver zoekt-git-clone zoekt-indexserver zoekt-mirror-bitbucket-server zoekt-mirror-gerrit zoekt-mirror-gitea zoekt-mirror-gitiles zoekt-repo-index zoekt-sourcegraph-indexserver zoekt-test
# Documentation: upstream cmd/zoekt-*/main.go at github.com/sourcegraph/zoekt
# Reference accessed: 2026-05-30
# Sourcegraph zoekt R58 — 10-stem multi-binary harvest completing the
# zoekt sister-binary family started in R57.
# Together R57+R58 = 16 zoekt binaries via source-direct flag.X
# extraction (alongside existing _zoekt + _zoekt-git-index).

local curcontext="$curcontext" state line ret=1

case $service in

  zoekt-dynamic-indexserver)
    # Dynamic indexserver with HTTP control endpoint.
    _arguments -s -S \
      '-repo_dir=[directory for cloned repositories]:directory:_directories' \
      '-index_dir=[directory for index shards]:directory:_directories' \
      '-index_timeout=[max time for indexing jobs (default 1h)]:duration:' \
      '-listen=[server address (default :6060)]:address:' \
      && ret=0
    ;;

  zoekt-git-clone)
    # Clone a git repository into the index workspace.
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-name=[repository name]:name:' \
      '-repoid=[repository id]:N:' \
      '*:git URL:' \
      && ret=0
    ;;

  zoekt-indexserver)
    # Long-running index server (periodic mirror + index).
    _arguments -s -S \
      '-index_timeout=[max time for indexing jobs (default 1h)]:duration:' \
      '-max_log_age=[log rotation age (default 72h)]:duration:' \
      '-fetch_interval=[mirror fetch interval (default 1h)]:duration:' \
      '-mirror_config=[mirror configuration JSON file]:file:_files' \
      '-mirror_duration=[mirror cycle duration (default 24h)]:duration:' \
      '-cpu_fraction=[CPU fraction for indexing (default 0.25)]:fraction:' \
      '-git_index_flags=[extra flags to forward to zoekt-git-index]:flags:' \
      '-data_dir=[data root directory (default $HOME/zoekt-serving)]:directory:_directories' \
      '-index_dir=[index directory (default $data_dir/index/)]:directory:_directories' \
      && ret=0
    ;;

  zoekt-mirror-bitbucket-server)
    # Mirror Bitbucket Server repos.
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-url=[Bitbucket Server URL]:url:' \
      '-disable-tls[disable TLS verification]' \
      '-credentials=[BB credentials file (default .bitbucket-credentials)]:file:_files' \
      '-project=[project to mirror]:project:' \
      '-delete[delete missing repos]' \
      '-name=[only clone repos matching regex]:regex:' \
      '-exclude=[exclude repos matching regex]:regex:' \
      '-type=[repo type filter (NORMAL or PERSONAL)]:type:(NORMAL PERSONAL)' \
      && ret=0
    ;;

  zoekt-mirror-gerrit)
    # Mirror Gerrit repos.
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-name=[only clone repos matching regex]:regex:' \
      '-repo-name-format=[Go template for repo names]:template:' \
      '-exclude=[exclude repos matching regex]:regex:' \
      '-delete[delete missing repos]' \
      '-fetch-meta-config[fetch gerrit meta/config branch]' \
      '-http-credentials=[HTTP credentials file]:file:_files' \
      '-active[mirror only active projects]' \
      '*:Gerrit URL:' \
      && ret=0
    ;;

  zoekt-mirror-gitea)
    # Mirror Gitea repos.
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-url=[Gitea URL (default https://gitea.com)]:url:' \
      '-org=[organization to mirror]:org:' \
      '-user=[user to mirror]:user:' \
      '-token=[API-token file (default $HOME/.gitea-token)]:file:_files' \
      '-forks[also mirror forks]' \
      '-delete[delete missing repos]' \
      '-name=[only clone repos matching regex]:regex:' \
      '-exclude=[exclude repos matching regex]:regex:' \
      '*-topic=[only clone repos with topic (repeatable)]:topic:' \
      '*-exclude_topic=[exclude repos with topic (repeatable)]:topic:' \
      '-no_archived[mirror only non-archived projects]' \
      && ret=0
    ;;

  zoekt-mirror-gitiles)
    # Mirror gitiles/cgit web frontend.
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-name=[only clone repos matching regex]:regex:' \
      '-exclude=[exclude repos matching regex]:regex:' \
      '-type=[which webserver to crawl]:type:(gitiles cgit)' \
      '*:gitiles/cgit URL:' \
      && ret=0
    ;;

  zoekt-repo-index)
    # Repo-tool (Android-style multi-project) indexer.
    _arguments -s -S \
      '-file_limit=[max file size]:N:' \
      '-shard_limit=[max corpus size per shard]:N:' \
      '-parallelism=[parallel indexing processes]:N:' \
      '-rev_prefix=[reference prefix (default refs/remotes/origin/)]:prefix:' \
      '-base_url=[base URL for repo names]:url:' \
      '-repo_cache=[repository cache root]:directory:_directories' \
      '-index=[index directory]:directory:_directories' \
      '-manifest_repo_url=[manifest repository URL]:url:' \
      '-manifest_rev_prefix=[manifest branch prefix (default refs/remotes/origin/)]:prefix:' \
      '-name=[repository name]:name:' \
      '-url=[repository URL]:url:' \
      '-max_sub_projects=[trim N projects in manifest (debug)]:N:' \
      '-incremental[only index if changed (default true)]' \
      '*:manifest path:_files' \
      && ret=0
    ;;

  zoekt-sourcegraph-indexserver)
    # Sourcegraph-managed index server.
    _arguments -s -S \
      '-sourcegraph_url=[Sourcegraph URL]:url:' \
      '-index=[index directory]:directory:_directories' \
      '-listen=[listen address]:address:' \
      '-hostname=[hostname]:hostname:' \
      '-interval=[sync interval]:duration:' \
      '-backoff_duration=[backoff duration]:duration:' \
      '-max_backoff_duration=[max backoff duration]:duration:' \
      '-vacuum_interval=[vacuum interval]:duration:' \
      '-merge_interval=[merge interval]:duration:' \
      '-index_concurrency=[indexing concurrency]:N:' \
      '-merge_target_size=[target compound-shard size]:N:' \
      '-merge_min_size=[min compound-shard size]:N:' \
      '-cpu_fraction=[CPU fraction]:fraction:' \
      '-shard_merging[enable shard merging]' \
      '-merge_min_age=[min shard age before merging]:N:' \
      && ret=0
    ;;

  zoekt-test)
    # Test-search a zoekt shard or directory.
    _arguments -s -S \
      '-mem_profile=[write memory profile to file]:file:_files' \
      '-cpu_profile=[write CPU profile to file]:file:_files' \
      '-repo=[repository to search]:repo:' \
      '-indexDir=[indexDir to load and exit]:directory:_directories' \
      '-case[case-sensitive search]' \
      '*:query:' \
      && ret=0
    ;;

esac

return ret
