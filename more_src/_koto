# 10 flags decoded source-direct from KotoArgs at
# main.rs:61-74 + parse_arguments at main.rs:79-88.
_arguments -s \
  '(-h --help)'{-h,--help}'[show help and exit (manual help-text)]' \
  '(-v --version)'{-v,--version}'[show koto version and exit]' \
  '(-e --eval)'{-e,--eval}'[treat first positional as script source code (not path)]' \
  '(-i --show_instructions)'{-i,--show_instructions}'[show generated VM instructions during compilation]' \
  '(-b --show_bytecode)'{-b,--show_bytecode}'[show bytecode during compilation]' \
  '(-t --tests)'{-t,--tests}'[run @tests blocks before main script]' \
  '(-T --import_tests)'{-T,--import_tests}'[also run @tests in imported modules (implies -t)]' \
  '(-f --format)'{-f,--format}'[format the script (do not run)]' \
  '(-c --config)'{-c+,--config=}'[koto config file path]:file:_files -g "*.koto"' \
  '(-C --print_config)'{-C,--print_config}'[print the default config to stdout]' \
  '1::script (path to .koto file OR script source if -e):_files -g "*.koto"' \
  '*:args forwarded to script via `koto.args`:'
