#compdef mythipxe
# Documentation: (not in upstream MythTV source tree)
# Reference accessed: 2026-05-16
# Verified: no mythipxe directory in mythtv/programs/. Likely a Debian
# packaging helper or distro script, not a MythTV binary. Tool kept per
# "do not delete files" directive with minimal stub.

# mythipxe: not present in upstream MythTV
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0
return ret
