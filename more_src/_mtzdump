#compdef mtzdump
# mtzdump — print header and reflection data from an MTZ file (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input MTZ]:file:_files -g "*.mtz"' \
  'BATCH[print per-batch orientation block]' \
  'HEADER[print header information only]' \
  'LRESO[include 4sin^2/lambda^2 values]' \
  'NREFLECTIONS[number of reflections to list]:n:' \
  'NREF[number of reflections to list]:n:' \
  'RESOLUTION[high and low resolution limits]:lim:' \
  'RESO[high and low resolution limits]:lim:' \
  'SKIP[reflections to skip before listing]:n:' \
  'STARTHKL[first HKL indices to list]:hkl:' \
  'STATS[resolution bin statistics]:opt:' \
  'SYMMETRY[print symmetry information]' \
  'END[terminate input and start dump]' \
  'GO[terminate input and start dump]' \
  'RUN[terminate input and start dump]' \
  '*:argument:_files' && ret=0

return ret
