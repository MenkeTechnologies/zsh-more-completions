#compdef wmc
# Wine message compiler

local ret=1

_arguments -s -S \
  '-B[set output byte-order]:order:(n l)' \
  '-c[set custom bit in message ID]' \
  '-d[non-standard decimal value in header]' \
  '-D[set debug flag]' \
  '-h[show help]' \
  '--help[show help]' \
  '-H[specify header filename]:file:_files -g "*.h"' \
  '-i[inline messagetable in header]' \
  '-o[specify output file]:file:_files -g "*.res"' \
  '-O[set output format]:format:(res pot)' \
  '-P[specify po directory]:directory:_files -/' \
  '-u[input file is in Unicode]' \
  '-U[output Unicode messagetable]' \
  '-v[verbose mode]' \
  '-V[show version]' \
  '--version[show version]' \
  '-W[enable pedantic warnings]' \
  '*:source files:_files -g "*.mc"' && ret=0

return ret
