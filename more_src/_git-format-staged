#compdef git-format-staged
# Documentation: https://man.archlinux.org/search?q=git-format-staged
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-format-staged — rust formatter for git staged hunks

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
