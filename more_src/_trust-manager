#compdef trust-manager
# _trust-manager — cert-manager trust-manager controller (Bundle resources)
# upstream: https://github.com/cert-manager/trust-manager
# Flags from cmd/trust-manager/app/options/options.go on tip.

_trust-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--readiness-probe-port=[health/ready probe port]:port:' \
        '--readiness-probe-path=[health/ready probe path]:path:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-lease-duration=[leader lease duration]:dur:' \
        '--leader-election-renew-deadline=[leader renew deadline]:dur:' \
        '--metrics-port=[metrics bind port]:port:' \
        '--trust-namespace=[namespace where trust-manager runs]:ns:' \
        '--default-package-location=[default package file location]:file:_files' \
        '--secret-targets-enabled=[allow Secret-typed Bundle targets]:bool:(true false)' \
        '--filter-expired-certificates=[filter expired certs from output bundles]:bool:(true false)' \
        '--filter-non-ca-certs=[filter non-CA certs from output bundles]:bool:(true false)' \
        '*--target-namespaces=[csv of namespaces to scope Bundles to]:csv:' \
        '--log-format=[log format]:fmt:(text json)' \
        '--log-level=[log verbosity]:n:' \
        '--webhook-host=[webhook server bind host]:host:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-certificate-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--tls-min-version=[min TLS version]:ver:(VersionTLS10 VersionTLS11 VersionTLS12 VersionTLS13)' \
        '*--tls-cipher-suites=[csv of allowed cipher suites]:csv:' \
        '--cert-manager=[cert-manager mode]:mode:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_trust-manager "$@"
