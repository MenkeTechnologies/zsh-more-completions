#compdef gmtspatial
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtspatial.html
# Source: GenericMappingTools/gmt classic-mode gmtspatial — spatial analysis of lines & polygons.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[nearest-neighbor analysis / decimate]:opts:_default' \
    '-C[clip polygons to map region]' \
    '-D+[detect duplicate lines/polygons]:opts:_default' \
    '-E+[reset polygon handedness]:dir:(+ -)' \
    '-F[force input to closed polygons]' \
    '-I+[polygon intersection]:opts:_default' \
    '-L+[remove superfluous border lines]:opts:_default' \
    '-N+[inside-polygon check]:opts:_default' \
    '-Q+[polygon area / line length + centroid]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[spatial processing (buffer/holes/dateline)]:opts:_default' \
    '-T+[truncate polygons against clip polygon]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[extend segment endpoints]:opts:_default' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-j+[distance computation mode]:mode:_default' \
    '-o+[output column selection]:cols:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
