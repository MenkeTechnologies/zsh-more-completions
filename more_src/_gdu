#compdef gdu
# _gdu — Daniel Milde's gdu (pretty fast Go-based disk-usage analyzer with parallel scan + ncdu-style TUI; SSD-optimized)
# upstream: https://github.com/dundee/gdu
# Flags from cmd/gdu/main.go on tip (cobra/pflag); loads /etc/gdu.yaml then $HOME/.config/gdu/gdu.yaml then $HOME/.gdu.yaml.

_gdu() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '--config-file=[config file path]:file:_files' \
        '(-l --log-file)'{-l+,--log-file=}'[log file path]:file:_files' \
        '(-o --output-file)'{-o+,--output-file=}'[export results to JSON file]:file:_files' \
        '(-f --input-file)'{-f+,--input-file=}'[import results from JSON file]:file:_files' \
        '(-m --max-cores)'{-m+,--max-cores=}'[max CPU cores]:n:' \
        '--sequential[sequential scanning (HDDs)]' \
        '*'{-T+,--type=}'[only include these file types (csv)]:types:' \
        '*'{-E+,--exclude-type=}'[exclude these file types (csv)]:types:' \
        '*'{-i+,--ignore-dirs=}'[paths to ignore (csv)]:dirs:' \
        '*'{-I+,--ignore-dirs-pattern=}'[path patterns to ignore (csv)]:patterns:' \
        '(-X --ignore-from)'{-X+,--ignore-from=}'[file with ignore patterns]:file:_files' \
        '(-H --no-hidden)'{-H,--no-hidden}'[ignore dot directories]' \
        '(-L --follow-symlinks)'{-L,--follow-symlinks}'[follow file symlinks]' \
        '(-A --show-annexed-size)'{-A,--show-annexed-size}'[apparent size for git-annex files]' \
        '(-x --no-cross)'{-x,--no-cross}'[do not cross filesystems]' \
        '--enable-profiling[expose pprof at localhost:6060/debug/pprof/]' \
        '(-D --db)'{-D+,--db=}'[store analysis in *.sqlite or *.badger file]:file:_files' \
        '(-r --read-from-storage)'{-r,--read-from-storage}'[reuse existing database]' \
        '--archive-browsing[browse into zip/jar/tar archives]' \
        '--collapse-path[collapse single-child directory chains]' \
        '(-d --show-disks)'{-d,--show-disks}'[show mounted disks]' \
        '(-a --show-apparent-size)'{-a,--show-apparent-size}'[show apparent size]' \
        '(-B --show-relative-size)'{-B,--show-relative-size}'[show relative size]' \
        '(-c --no-color)'{-c,--no-color}'[disable colors]' \
        '(-C --show-item-count)'{-C,--show-item-count}'[show item count column]' \
        '(-M --show-mtime)'{-M,--show-mtime}'[show latest mtime]' \
        '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
        '--interactive[force interactive mode]' \
        '(-p --no-progress)'{-p,--no-progress}'[suppress non-interactive progress]' \
        '(-u --no-unicode)'{-u,--no-unicode}'[disable Unicode bar]' \
        '(-s --summarize)'{-s,--summarize}'[only show total in non-interactive mode]' \
        '(-t --top)'{-t+,--top=}'[show top X largest files]:n:' \
        '--depth=[max directory depth in non-interactive mode]:n:' \
        '--si[SI decimal prefixes (kB, MB)]' \
        '--no-prefix[no SI/binary prefix in non-interactive mode]' \
        '(-k --show-in-kib)'{-k,--show-in-kib}'[show sizes in KiB]' \
        '--reverse-sort[smallest-to-largest sort]' \
        '--mouse[enable mouse support]' \
        '--no-delete[disable deletions]' \
        '--no-view-file[disable file content view]' \
        '--no-spawn-shell[disable spawn shell]' \
        '--write-config[write current config to file and exit]' \
        '--since=[only include mtime >= WHEN]:when:' \
        '--until=[only include mtime <= WHEN]:when:' \
        '--max-age=[only include mtime no older than DURATION]:dur:' \
        '--min-age=[only include mtime at least DURATION old]:dur:' \
        '1:directory:_files -/'
}

_gdu "$@"
