#compdef spritesheet-js
# Documentation: https://github.com/krzysztof-o/spritesheet.js
# Command-line spritesheet (texture atlas) generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --format)'{-f,--format}'[format of spritesheet]:format:(starling sparrow json pixi.js easel.js cocos2d)' \
  '(-n --name)'{-n,--name}'[name of generated spritesheet]:name' \
  '(-p --path)'{-p,--path}'[path to export directory]:dir:_files -/' \
  '--fullpath[include path in file name]' \
  '--prefix[prefix for image paths (css format only)]:prefix' \
  '--trim[remove transparent whitespaces around images]' \
  '--square[texture should be a square]' \
  '--powerOfTwo[texture width and height should be power of two]' \
  '--validate[check algorithm returned data]' \
  '--algorithm[packing algorithm]:algo:(growing-binpacking binpacking vertical horizontal)' \
  '--width[width for binpacking]:px' \
  '--height[height for binpacking]:px' \
  '--padding[padding between images in spritesheet]:px' \
  '--scale[percentage scale]:percent' \
  '--fuzz[percentage fuzz factor]:percent' \
  '*:image:_files' && ret=0

return ret
