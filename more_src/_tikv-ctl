#compdef tikv-ctl

local curcontext="$curcontext" state line ret=1

_tikv_ctl_commands() {
  local -a commands=(
    'raft:print raft log entry'
    'size:print region size'
    'scan:scan raw keys'
    'print:print the raw value'
    'mvcc:print the MVCC value'
    'diff:diff two regions'
    'compact:compact a column family in a range'
    'compact-cluster:compact the entire cluster'
    'unsafe-recover:unsafe recover commands'
    'recreate-region:recreate a region by given metadata'
    'tombstone:set some regions on the node to tombstone'
    'store:print store info'
    'cluster:print cluster info'
    'bad-regions:get all regions with corrupt raft'
    'modify-tikv-config:modify TiKV config'
    'metrics:print the metrics'
    'region-properties:show region properties'
    'split-region:split region'
    'fail:inject failures'
    'encryption-meta:dump encryption metadata'
    'bad-ssts:list bad SST files'
  )
  _describe -t commands 'tikv-ctl command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--host=[TiKV host]:host:_hosts' \
  '--ca-path=[CA certificate path]:file:_files' \
  '--cert-path=[certificate path]:file:_files' \
  '--key-path=[private key path]:file:_files' \
  '--pd=[PD endpoints]:endpoints:' \
  '(-C --config)'{-C,--config}'[TiKV config file]:file:_files' \
  '(-d --data-dir)'{-d,--data-dir}'[TiKV data directory]:dir:_directories' \
  '--skip-paranoid-checks[skip paranoid checks when opening rocksdb]' \
  '1:command:_tikv_ctl_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      raft)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--region=[region ID]:id:' \
          '--log-index=[raft log index]:index:' \
          && ret=0
        ;;
      size)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--region=[region ID]:id:' \
          '--cf=[column family]:cf:(default write lock)' \
          && ret=0
        ;;
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--from=[start key]:key:' \
          '--to=[end key]:key:' \
          '--limit=[max entries]:limit:' \
          '--cf=[column family]:cf:(default write lock)' \
          '--start-ts=[start timestamp]:ts:' \
          '--commit-ts=[commit timestamp]:ts:' \
          && ret=0
        ;;
      compact)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--from=[start key]:key:' \
          '--to=[end key]:key:' \
          '--region=[region ID]:id:' \
          '--db=[database]:db:(kv raft)' \
          '--cf=[column family]:cf:(default write lock)' \
          '--threads=[number of threads]:threads:' \
          && ret=0
        ;;
      modify-tikv-config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config-name=[config name]:name:' \
          '--config-value=[config value]:value:' \
          && ret=0
        ;;
      split-region)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--region=[region ID]:id:' \
          '--key=[split key]:key:' \
          && ret=0
        ;;
      tombstone|store|cluster|bad-regions|metrics|bad-ssts|encryption-meta)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
