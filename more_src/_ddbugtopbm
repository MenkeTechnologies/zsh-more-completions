#compdef ddbugtopbm
# Documentation: man ddbugtopbm (Netpbm)
# Source: convert a Palm OS DiddleBug bug-report sketch DB to a sequence of PBM images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
