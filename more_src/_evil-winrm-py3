#compdef evil-winrm-py3

# evil-winrm-py3: Python3 port of evil-winrm Ruby tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[target host]:host:' \
  '-u[username]:user:' \
  '-p[password]:pwd:' \
  '-H[NTLM hash]:hash:' \
  '-P[port]:port:' \
  '-U[URL endpoint]:url:' \
  '-s[script(s) to load]:files:_files' \
  '-e[executable(s) to load]:files:_files' \
  '-S[SSL/TLS connection]' \
  '--no-colors[no colored output]' \
  '--spn[Kerberos SPN]:spn:' \
  '-V[verbose]' \
  '*::evil-winrm args:_files' && ret=0
return ret
