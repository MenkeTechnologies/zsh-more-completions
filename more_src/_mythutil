#compdef mythutil
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythutil/mythutil_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythutil: MythTV multi-mode utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '--copyfile[copy a recording file]' \
  '--download[download a file]' \
  '--gencutlist[copy skip list to cutlist]' \
  '--getcutlist[show cutlist]' \
  '--setcutlist=[set cutlist]:list:' \
  '--clearcutlist[clear cutlist]' \
  '--getskiplist[show skip list]' \
  '--setskiplist=[set skip list]:list:' \
  '--clearskiplist[clear skip list]' \
  '--clearseektable[clear seek table]' \
  '--clearbookmarks[clear bookmarks]' \
  '--getmarkup=[get markup from file]:file:_files' \
  '--setmarkup=[set markup from file]:file:_files' \
  '--resched[reschedule]' \
  '--scanimages[scan images]' \
  '--scanvideos[scan videos]' \
  '--event[send event]' \
  '--systemevent[send system event]' \
  '--clearcache[clear cache]' \
  '--queuejob[queue a job]' \
  '--message[send message]' \
  '--notification[send notification]' \
  '--scanmusic[scan music]' \
  '--updateradiostreams[update radio streams]' \
  '--updatemeta[update metadata]' \
  '--extractimage[extract image]' \
  '--calctracklen[calculate track length]' \
  '--findlyrics[find lyrics]' \
  '--checkrecordings[check recordings]' \
  '--cleareit[clear EIT data]' \
  '--fixseektable[fix seek table]' \
  '--pidcounter[count PIDs in media file]' \
  '--pidfilter[filter PIDs in media file]' \
  '--pidprinter[print PSIP PIDs]' \
  '--ptspids=[extract PTS from given PIDs]:pids:' \
  '--noautopts[disable automatic PTS discovery]' \
  '--pids=[PIDs]:pids:' \
  '--packetsize=[TS packet size (188)]:n:' \
  '--xml[XML output]' \
  '--message_text=[message text]:text:' \
  '--timeout=[timeout]:seconds:' \
  '--udpport=[UDP port (6948)]:port:' \
  '--bcastaddr=[broadcast address]:addr:' \
  '--image=[image file]:file:_files' \
  '--origin=[origin]:str:' \
  '--description=[description]:text:' \
  '--extra=[extra data]:data:' \
  '--progress_text=[progress text]:text:' \
  '--progress=[progress value]:n:' \
  '--fullscreen[fullscreen]' \
  '--error[error]' \
  '--visibility=[visibility]:vis:' \
  '--type=[type]:type:' \
  '--force[force]' \
  '--songid=[song ID]:id:' \
  '--title=[title]:title:' \
  '--artist=[artist]:artist:' \
  '--album=[album]:album:' \
  '--genre=[genre]:genre:' \
  '--trackno=[track number]:n:' \
  '--year=[year]:year:' \
  '--rating=[rating]:rating:' \
  '--playcount=[play count]:n:' \
  '--lastplayed=[last played]:date:' \
  '--imagetype=[image type]:type:' \
  '--grabber=[grabber]:grabber:' \
  '--sourceid=[source ID (-1)]:id:' \
  '--video=[video file]:file:_files' \
  '--chanid=[channel ID]:id:' \
  '--starttime=[start time]:time:' \
  '--infile=[input file]:file:_files' \
  '--outfile=[output file]:file:_files' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
