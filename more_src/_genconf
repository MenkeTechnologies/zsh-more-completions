#compdef genconf gmx-genconf
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-genconf.html
# Multiply a coordinate file by stacking copies in a grid arrangement

local ret=1

_arguments -s -S \
  '-f+[input structure file]:structure:_files -g "*.(gro|g96|pdb|brk|ent|esp|tpr)"' \
  '-trj+[trajectory file]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-o+[output structure file]:structure:_files -g "*.(gro|g96|pdb)"' \
  '-nbox+[grid dimensions]:vector:' \
  '-dist+[spacing between grid boxes]:vector:' \
  '-seed+[random seed (0 auto)]:seed:' \
  '-maxrot+[maximum rotation angles in degrees]:vector:' \
  '-rot[random rotation of conformations]' \
  '-renumber[renumber residues]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
