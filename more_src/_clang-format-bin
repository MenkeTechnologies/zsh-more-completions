#compdef clang-format
# _clang-format-bin — LLVM clang-format C/C++/Java/JS formatter (LLVM project, C++); format source code using .clang-format
# upstream: https://github.com/llvm/llvm-project

_clang-format-bin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-i[in-place edit]' \
        '--inplace[in-place edit]' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--Werror[treat warnings as errors]' \
        '-Wno-error=+[disable specific warning]:warning:' \
        '-cursor=+[cursor position]:n:' \
        '-fallback-style=+[fallback style]:style:(LLVM Google Chromium Mozilla WebKit Microsoft GNU None)' \
        '-style=+[style]:style:(file LLVM Google Chromium Mozilla WebKit Microsoft GNU)' \
        '-assume-filename=+[filename for stdin]:str:' \
        '-output-replacements-xml[output replacements XML]' \
        '-sort-includes[sort includes]' \
        '-lines=+[only lines]:str:' \
        '-offset=+[offset]:n:' \
        '-length=+[length]:n:' \
        '-verbose[verbose]' \
        '-dump-config[dump config]' \
        '-list-ignored[list ignored files]' \
        '-files=+[files list]:file:_files' \
        '*:file:_files'
}

_clang-format-bin "$@"
