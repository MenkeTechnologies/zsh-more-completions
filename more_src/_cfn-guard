#compdef cfn-guard

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'validate:validate CloudFormation against rules'
      'parse:parse rules'
      'test:test rules against data'
    )
    _describe -t commands 'cfn-guard command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      validate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-r --rules)'{-r,--rules}'=[rules file or directory]:path:_files' \
          '(-d --data)'{-d,--data}'=[CloudFormation template]:file:_files' \
          '--type=[data type]:(CLOUDFORMATION TERRAFORM K8S)' \
          && ret=0
        ;;
      parse|test)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
