#compdef tuxi
# Documentation: https://man.archlinux.org/search?q=tuxi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r[raw output, no formatting]' \
  '-q[quiet mode]' \
  '*:query:' && ret=0

return ret
