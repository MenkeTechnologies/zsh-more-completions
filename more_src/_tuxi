#compdef tuxi
# Documentation: https://github.com/Bugswriter/tuxi
# Reference accessed: 2026-05-21
# Verified: upstream README usage section.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help message]' \
  '(- *)-v[print version info]' \
  '-r[raw search results (no formatting/colors)]' \
  '-q[quiet - only output search results]' \
  '-a[print all valid answers]' \
  '-u[print top URLs for the query]' \
  '-b[select best answer based on keywords]' \
  '-t[pick answers to test]' \
  '-l[override search language]:lang:' \
  '-d[print debug info]' \
  '-s[save HTML to cache]' \
  '-c[use most recent cached result]' \
  '-p[disable pipe support]' \
  '*:query:' && ret=0

return ret
