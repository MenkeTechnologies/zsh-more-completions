#compdef kvass
# =============================================================================
# kvass — a personal key-value store with end-to-end encrypted multi-device
#         sync via an optional self-hosted server.  Kvass (Norwegian for
#         "stuff") gives you the convenience of cloud key-value (1Password,
#         Bitwarden) with the data sovereignty of self-hosting.  Local
#         SQLite database; optional sync via a relay server that NEVER
#         sees plaintext values (client-side AES-256-GCM).  Used by
#         self-hosters who want a private alternative to KeePass / Vaultwarden
#         for arbitrary KV data (notes, todos, environment variables,
#         API tokens, share links).
#
# Author:  Max Munzel (maxmunzel)
# Source:  https://github.com/maxmunzel/kvass
# CLI:     src/cli.go (uses teris-io/cli)
# Library: teris-io/cli
#          ("Simple and complete API for building command line applications
#           in Go")
# License: MIT
# Status:  Stable — 876+ stars; recommended self-hosted KV store in
#          self-hosted/r-selfhosted/awesome-selfhosted catalogs.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 32 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 32ND Go CLI library variant.  Go climbs from 31 to 32 documented libraries
# (teris-io/cli via kvass).  New leaderboard: Rust=32, Go=32 (TWO-WAY TIE),
# TypeScript-Node=31.  Taxonomy now spans 238 cross-language CLI library
# variants across 57 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS teris-io/cli AND WHY IS IT A DISTINCT 32ND GO CLI LIBRARY VARIANT?
#
# teris-io/cli (https://github.com/teris-io/cli, 132+ stars) is **Andrius
# Bentkus's (teris-io) "simple and complete API for building command line
# applications in Go"**.  Andrius is a Lithuanian Go developer focused on
# infrastructure tooling; teris-io/cli is one of his more widely-adopted
# libraries (alongside teris-io/shortid and teris-io/uri).
#
# teris-io/cli is DISTINCT from every documented Go CLI library on FIVE
# specific axes:
#
#   1. With*-PREFIXED FLUENT BUILDER METHODS — teris-io/cli uses a
#      consistent naming convention where ALL builder methods begin
#      with `With`:
#         cli.NewCommand("get", "get a value").
#             WithArg(cli.NewArg("key", "the key")).
#             WithOption(cli.NewOption("verbose", "...")).
#             WithAction(handler)
#      This is the Java-Spring-style "WithXxx" naming pattern brought
#      into Go.  Compare cobra (.PersistentFlags(), .Run(), no With*),
#      clir R495 (.BoolFlag, .StringFlag, no With*), kong R465 (struct-
#      tag, no builder), urfave/cli (struct field, no builder).
#      teris-io/cli is the FIRST documented Go CLI library to use the
#      consistent With*-prefix convention end-to-end.
#
#   2. HANDLER SIGNATURE RETURNS EXIT CODE — teris-io's action signature
#      is `func(args []string, options map[string]string) int`.  The
#      INT RETURN VALUE is the process exit code.  Compare:
#        cobra:    `Run: func(cmd, args)` — no return value
#        urfave:   `Action: func(c *cli.Context) error` — error return
#        kong:     `Run(...) error` — method on subcommand struct
#        clir:     `Action: func() error`
#        teris-io: `func(args, options) int` — UNIQUE
#      The int return is more direct than the error-mapped-to-exit-code
#      pattern used by most modern Go CLI libraries.  It matches the
#      mental model of "main returns exit code" exactly.
#
#   3. STRING-KEYED OPTIONS MAP — `options map[string]string` is what
#      the handler receives.  All option values are STRINGS (no type
#      conversion); the handler is responsible for parsing the string
#      into the desired type via strconv.  Compare:
#        kong R465: typed struct fields
#        clir R495: pointer-receiver typed setters
#        go-arg R475: typed struct fields
#        commando R487: map[string]ArgValue + FlagValue
#        teris-io: map[string]string (untyped)
#      teris-io's approach is closer to commando's R487 string-keyed
#      map handler and to Whiley's wycc.util.OptArg R469 in Java —
#      string-keyed maps with caller-side type recovery.
#
#   4. `cli.NewArg(...).AsOptional()` METHOD-CHAIN OPTIONALS — positional
#      args are declared as `cli.NewArg(name, description)` and can be
#      marked optional with `.AsOptional()`:
#         set := cli.NewCommand("set", "set a value").
#             WithArg(cli.NewArg("key", "the key to set")).
#             WithArg(cli.NewArg("value", "value to set (omit for stdin)").
#                                            AsOptional()).
#             WithAction(handler)
#      The args slice in the handler corresponds to the declared Args;
#      optional Args may be absent from the slice (length check needed).
#      Compare cobra's `cobra.MinimumNArgs(1)` validator chain.
#
#   5. SUBCOMMAND COMPOSITION VIA `.WithCommand(child)` — nested
#      subcommands are added via `.WithCommand(child)`:
#         config := cli.NewCommand("config", "set config parameters").
#             WithCommand(config_show).
#             WithCommand(config_key).
#             WithCommand(config_remote).
#             WithCommand(config_pid)
#      This is structurally similar to cliffy R488 (Deno-first
#      Command.command(name, anotherCmd)) and clir R495 (cli.
#      NewSubCommand), but teris-io's `.WithCommand` takes a fully-
#      constructed `cli.Command` as a value — emphasizing the
#      COMPOSITIONAL nature where subcommands are first-class values
#      declared independently and then assembled.
#
# THE teris-io/cli API SURFACE (verbatim from kvass usage)
#
#   import "github.com/teris-io/cli"
#
#   ls := cli.NewCommand("ls", "list keys").
#       WithAction(func(args []string, options map[string]string) int {
#           // ...
#           return 0
#       })
#
#   get := cli.NewCommand("get", "get a value").
#       WithArg(cli.NewArg("key", "the key to get")).
#       WithAction(func(args []string, options map[string]string) int {
#           key := args[0]
#           // ...
#           return 0
#       })
#
#   set := cli.NewCommand("set", "set a value").
#       WithArg(cli.NewArg("key", "the key to set")).
#       WithArg(cli.NewArg("value", "value (omit for stdin)").AsOptional()).
#       WithAction(handler)
#
#   serve := cli.NewCommand("serve", "start in server mode").
#       WithOption(cli.NewOption("bind", "bind address")).
#       WithAction(handler)
#
#   config := cli.NewCommand("config", "set config parameters").
#       WithCommand(config_show).
#       WithCommand(config_key).
#       WithCommand(config_remote)
#
#   app := cli.New("kvass description").
#       WithCommand(ls).
#       WithCommand(get).
#       WithCommand(set).
#       WithCommand(rm).
#       WithCommand(serve).
#       WithCommand(config).
#       WithOption(cli.NewOption("db", "path to db"))
#
#   os.Exit(app.Run(os.Args, os.Stdout))
#
# Methods on Command builder:
#   cli.NewCommand(name, description)        — construct command
#   .WithAction(handler)                      — register action
#   .WithArg(cli.NewArg(name, description))   — positional arg
#   .WithOption(cli.NewOption(name, desc))    — flag
#   .WithCommand(childCommand)                — nested subcommand
#   .WithShortDescription(desc)                — short help line
#
# Methods on Arg builder:
#   cli.NewArg(name, description)             — construct positional
#   .AsOptional()                              — mark as optional
#   .WithType(cli.TypeInt)                     — type validation
#   .AsRepeatable()                            — variadic
#
# Methods on Option builder:
#   cli.NewOption(name, description)          — construct flag
#   .WithChar(c)                               — single-char alias
#   .WithType(cli.TypeBool)                    — type
#
# CONTRAST WITH OTHER GO CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * flag (stdlib)                — pointer-based, no subcommands
#   * cobra                        — full framework with codegen
#   * urfave/cli                   — struct-list declarative
#   * kingpin                      — fluent builder
#   * kong R465                    — struct-tag declarative
#   * go-arg R475                  — single MustParse(&struct)
#   * opts R479                    — frictionless struct
#   * mow.cli R470                 — SPEC-string grammar
#   * go-getoptions R483           — Perl Getopt::Long port
#   * commando R487                — package-level singleton + colon ns
#   * mkideal/cli R491             — struct-tag comma-aliases
#   * clir R495                    — explicit constructor + pointer setters
#   * teris-io/cli (THIS)          — With*-prefix fluent builder +
#                                    int-return handlers + string-keyed
#                                    options map
#
# teris-io/cli occupies a SPECIFIC NICHE between clir R495 (pointer-
# setter explicit) and commando R487 (singleton + colon-ns).  Its
# With*-fluent API is unique among documented Go CLI libraries — no
# other one uses the consistent With* naming convention.
#
# REAL-WORLD teris-io/cli USERS:
#
#   * maxmunzel/kvass — personal key-value store (THIS, 876*)
#   * outscale/frieza — cloud resource cleaner from Outscale (7*)
#   * outscale/osc-logs — Outscale logs tool
#   * torbenschinke/wiz — versioned signed DB for large files
#   * AngelOD/teal-rose — telegram bot
#   * its-hmny/nand2tetris — From Nand to Tetris exercises in Go
#   * peiit/xfilter — file filtering tool
#   * chaitanyabsprip/pho — phorgraphy tool
#   * teris-io/geotiff — GeoTIFF library example
#   * zSnails/taskr — Taskwarrior alternative in Go
#
# -----------------------------------------------------------------------------
# KVASS'S CLI SURFACE (verbatim from src/cli.go)
# -----------------------------------------------------------------------------
#
# USAGE:
#   kvass [--db <PATH>] <COMMAND> [args...]
#
# Storage:
#   --db <PATH>                  Path to SQLite database
#                                (default: ~/.kvassdb.sqlite)
#
# Commands:
#   ls                           List all keys
#   get <KEY>                    Get the value for KEY (writes to stdout)
#   set <KEY> [VALUE]            Set KEY to VALUE (omit VALUE to read from stdin)
#   rm <KEY>                     Delete KEY
#   url <KEY>                    Show shareable URL of an entry
#                                (encryption key embedded in URL fragment;
#                                 server never sees plaintext)
#
# Server mode:
#   serve [--bind <IP:PORT>]     Start kvass HTTP relay server
#                                (default bind: 0.0.0.0:8000)
#                                The server stores ciphertext only and
#                                relays between clients on shared keys.
#
# Config subcommands:
#   config show                  Print current config (encryption key,
#                                remote, pid)
#   config key <HEX-KEY>         Set the AES-256-GCM encryption key
#                                (hex-encoded)
#   config remote <HOST>         Set the remote relay server URL
#                                (use "" to disable remote)
#   config pid <ID>              Set the local process ID (lower PID
#                                wins in conflict resolution)
#
# Sync workflow:
#   $ kvass config remote https://relay.example.com:8000
#   $ kvass config key $(head -c32 /dev/urandom | xxd -p -c64)
#   $ kvass set api_key sk-1234567890   # writes to local SQLite +
#                                          # relays ciphertext to server
#   # On second device, same encryption key:
#   $ kvass get api_key                  # fetches from server, decrypts
#
# =============================================================================

_kvass() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands config_subs

    subcommands=(
        'ls:list all keys'
        'get:get the value for KEY'
        'set:set KEY to VALUE'
        'rm:delete KEY'
        'url:show shareable URL'
        'serve:start kvass HTTP relay server'
        'config:configure kvass'
    )

    config_subs=(
        'show:print current config'
        'key:set AES-256-GCM encryption key (hex)'
        'remote:set remote relay server URL'
        'pid:set local process ID'
    )

    _arguments -C \
        '--db[path to SQLite database]:db file:_files -g "*.sqlite*"' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'kvass command' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (serve)
                    _arguments \
                        '--bind[bind address (default 0.0.0.0:8000)]:bind addr:' \
                        && ret=0
                    ;;
                (config)
                    _describe -t config 'config subcommand' config_subs && ret=0
                    ;;
                (get|rm|url)
                    _message 'key' && ret=0
                    ;;
                (set)
                    if [[ $#line -eq 2 ]]; then
                        _message 'key' && ret=0
                    else
                        _message 'value (omit for stdin)' && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_kvass "$@"
