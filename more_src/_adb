#compdef adb
# Documentation: https://developer.android.com/tools/adb
# Source: Android Debug Bridge — host-side device control CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-d -e -s)-d[target the single attached device]' \
    '(-d -e -s)-e[target the single attached emulator]' \
    '(-d -e -s)-s[target device by serial number]:serial:' \
    '-l[include detailed device information]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'devices:list attached devices and connection state'
            'shell:issue device command or open interactive shell'
            'install:install an APK'
            'uninstall:remove a package'
            'push:copy files / dirs to the device'
            'pull:copy files / dirs from the device'
            'forward:set up port forwarding (host -> device)'
            'reverse:set up reverse port forwarding (device -> host)'
            'connect:connect to device via IP:port'
            'disconnect:disconnect from a remote device'
            'pair:pair with a device for wireless debugging'
            'logcat:view device system logs'
            'bugreport:generate a complete bug report'
            'kill-server:terminate the adb server'
            'start-server:start the adb server'
            'root:restart adbd as root'
            'unroot:restart adbd as non-root'
            'remount:remount the system partition as r/w'
            'disable-verity:disable dm-verity checking'
            'enable-verity:re-enable dm-verity checking'
            'get-state:print device state (offline/bootloader/device)'
            'sideload:sideload OTA zip via recovery'
            'sync:synchronize files between device and host'
            'reconnect:reconnect to the device'
            'tcpip:restart adb listening on TCP port'
            'help:print help'
        )
        _describe -t subcmds 'adb command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            push|pull|install|sideload) _files ;;
            *) _default ;;
        esac
        ;;
esac

return ret
