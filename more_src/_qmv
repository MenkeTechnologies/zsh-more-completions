#compdef qmv qcp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-f+[set rename format]:format:(destination-only dual)' \
  '--format=[set rename format]:format:(destination-only dual)' \
  '-o+[set editor option]:option:' \
  '--options=[set editor option]:option:' \
  '-e+[set editor]:editor:_command_names' \
  '--editor=[set editor]:editor:_command_names' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-d[only rename directories]' \
  '--directories[only rename directories]' \
  '*:files and directories:_files' && ret=0

return ret
