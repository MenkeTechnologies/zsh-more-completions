#compdef ament_clang_format
# Documentation: https://github.com/ament/ament_lint/blob/rolling/ament_clang_format/ament_clang_format/main.py
# ament_clang_format - check C/C++ code style using clang-format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[the config file (default: .clang-format)]:config:_files' \
  '--clang-format-version=[the version of clang-format to use]:version:' \
  '--reformat[reformat the files in place]' \
  '--xunit-file=[generate a xunit compliant XML file]:file:_files' \
  '*:path:_files' && ret=0

return ret
