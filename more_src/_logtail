#compdef logtail

# Zsh completion for logtail
# Covers both classic logtail and logtail-dash (Rust version)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[logfile to read/follow]:logfile:_files' \
  '-o[offset file]:offsetfile:_files' \
  '-t[test mode (do not update offset)]' \
  '*:logfile:_files' && ret=0

return ret
