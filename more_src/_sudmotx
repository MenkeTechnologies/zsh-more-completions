#compdef sudmotx
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/dip_moveout/sudmotx.c
# DMO via T-X domain (Kirchhoff) for common-offset gathers

local ret=1

_arguments -s -S \
  'cdpmin=[minimum cdp for which to apply DMO]:cdpmin' \
  'cdpmax=[maximum cdp for which to apply DMO]:cdpmax' \
  'dxcdp=[distance between successive CDPs]:dxcdp' \
  'noffmix=[number of offsets to mix]:noffmix' \
  'offmax=[maximum offset]:offmax' \
  'tmute=[mute time at maximum offset]:tmute' \
  'vrms=[RMS velocity at mute time]:vrms' \
  'verbose=[=1 for diagnostic print]:verbose' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0


return ret
