#compdef prodigy

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'ner.manual:manual NER annotation'
  'ner.correct:correct NER predictions'
  'ner.teach:active learning NER'
  'textcat.manual:manual text classification'
  'textcat.teach:active learning text classification'
  'spans.manual:manual span annotation'
  'db-in:import data to dataset'
  'db-out:export data from dataset'
  'db-merge:merge datasets'
  'stats:show dataset statistics'
  'drop:drop a dataset'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'prodigy command' commands && ret=0
    ;;
  args)
    case $line[1] in
      ner.manual|ner.correct|ner.teach)
        _arguments -s -S \
          '1:dataset:' \
          '2:spacy model or blank:' \
          '3:source:_files' \
          '--label[labels]:labels:' \
          '--patterns[patterns file]:file:_files' \
          '--exclude[exclude dataset]:dataset:' \
          '-F[Python file with custom recipe]:file:_files -g "*.py"' \
          '--help[show help]' && ret=0
        ;;
      textcat.manual|textcat.teach)
        _arguments -s -S \
          '1:dataset:' \
          '2:source:_files' \
          '--label[labels]:labels:' \
          '--exclusive[exclusive categories]' \
          '-F[Python file with custom recipe]:file:_files -g "*.py"' \
          '--help[show help]' && ret=0
        ;;
      db-in)
        _arguments -s -S \
          '1:dataset:' \
          '2:source:_files -g "*.jsonl"' \
          '--help[show help]' && ret=0
        ;;
      db-out)
        _arguments -s -S \
          '1:dataset:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
