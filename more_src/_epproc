#compdef epproc
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/epproc/node11.html
# XMM-Newton SAS epicproc: process EPIC-PN instrument data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--selectccds=[choose which CCDs to process]:flag:(yes no)' \
  '--selectmodes=[choose observation modes]:flag:(yes no)' \
  '--imaging=[enable imaging mode processing]:flag:(yes no)' \
  '--timing=[enable timing mode processing]:flag:(yes no)' \
  '--burst=[enable burst mode processing]:flag:(yes no)' \
  '--timingsrcposition=[source position for timing mode]:pos:' \
  '--instexpids=[instrument exposure identifiers]:ids:' \
  '--withinstexpids=[include instrument exposure IDs]:flag:(yes no)' \
  '--gtiset=[good time interval dataset]:file:_files' \
  '--withgtiset=[apply GTI filtering]:flag:(yes no)' \
  '--runatthkgen=[execute attitude/housekeeping generation]:flag:(yes no)' \
  '--runhkgtigen=[run housekeeping GTI generation]:flag:(yes no)' \
  '--referencepointing=[reference pointing coordinates]:src:' \
  '--ra=[right ascension (degrees)]:ra:' \
  '--dec=[declination (degrees)]:dec:' \
  '--posangle=[position angle (degrees)]:angle:' \
  '--filterevents=[apply event filtering]:flag:(yes no)' \
  '--filterexpression=[custom filter criteria]:expr:' \
  '--flagfilteredevents=[mark filtered events]:flag:(yes no)' \
  '--rungtimerge=[merge GTI intervals]:flag:(yes no)' \
  '--applygti=[apply GTI selections]:flag:(yes no)' \
  '--runevlistcomb=[combine event lists]:flag:(yes no)' \
  '--searchforbadpixels=[detect bad pixels]:flag:(yes no)' \
  '--searchforbadcolumns=[detect bad columns]:flag:(yes no)' \
  '--thresholdlabel=[threshold configuration name]:label:' \
  '--lothresh=[low energy threshold]:thresh:' \
  '--hithresh=[high energy threshold]:thresh:' \
  '--loenergythresh=[low energy boundary]:thresh:' \
  '--hienergythresh=[high energy boundary]:thresh:' \
  '--randomizeposition=[randomize event coordinates]:flag:(yes no)' \
  '--randomizeenergy=[randomize event energy]:flag:(yes no)' \
  '--withoutoftime=[disable time-of-flight correction]:flag:(yes no)' \
  '--withframecti=[apply frame CTI correction]:flag:(yes no)' \
  '--withpatternoffset=[use pattern-based offsets]:flag:(yes no)' \
  '--runepnoise=[execute noise analysis]:flag:(yes no)' \
  '--runepreject=[run event rejection task]:flag:(yes no)' \
  '--runepexposure=[calculate exposures]:flag:(yes no)' \
  '--runepxrlcorr=[apply XRL correction]:flag:(yes no)' \
  '--runepfast=[fast processing mode]:flag:(yes no)' \
  '--withsrccoords=[use source coordinates]:flag:(yes no)' \
  '--srcra=[source celestial RA]:ra:' \
  '--srcdec=[source celestial Dec]:dec:' \
  '--withdefaultcal=[use default calibration]:flag:(yes no)' \
  '--removetemporaries=[delete temporary files]:flag:(yes no)' \
  '*:event file:_files' && ret=0

return ret
