#compdef loudgain

local -a arguments

arguments=(
  '(-a --album)'{-a,--album}'[calculate album gain]'
  '(-k --noclip)'{-k,--noclip}'[prevent clipping]'
  '(-K --maxtpl)'{-K,--maxtpl}'=[max true peak level in dBTP]:dBTP:'
  '(-d --pregain)'{-d,--pregain}'=[pre-gain in dB]:dB:'
  '(-s --tagmode)'{-s,--tagmode}'=[tag mode]:mode:(d i e r s l)'
  '(-L --lowercase)'{-L,--lowercase}'[use lowercase ReplayGain tag names]'
  '(-S --striptags)'{-S,--striptags}'[strip existing ReplayGain tags]'
  '(-I --id3v2version)'{-I,--id3v2version}'=[ID3v2 tag version]:version:(3 4)'
  '(-o --output)'{-o,--output}'[output tab-delimited data to stdout]'
  '(-O --output-new)'{-O,--output-new}'[output new style tab-delimited data]'
  '(-q --quiet)'{-q,--quiet}'[quiet mode]'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
  '*:audio file:_files -g "*.(mp3|flac|ogg|opus|m4a|wv|ape|wav|aiff)"'
)

_arguments -s -S $arguments
