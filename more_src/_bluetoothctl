#compdef bluetoothctl
# Documentation: https://manpages.debian.org/bluetoothctl.1
# Source: BlueZ — interactive Bluetooth control program.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-a --agent)'{-a+,--agent=}'[register agent handler capability]:capability:(NoInputNoOutput DisplayOnly DisplayYesNo KeyboardOnly KeyboardDisplay)' \
    '(-e --endpoints)'{-e,--endpoints}'[register Media endpoints]' \
    '(-m --monitor)'{-m,--monitor}'[enable monitor output]' \
    '(-t --timeout)'{-t+,--timeout=}'[timeout (seconds) for non-interactive mode]:seconds:' \
    '(- *)'{-v,--version}'[display version]' \
    '(- *)'{-h,--help}'[display help]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'advertise:LE advertising data management'
            'monitor:advertisement monitor configuration'
            'scan:start/stop device discovery'
            'gatt:GATT service / characteristic operations'
            'admin:admin policy commands'
            'player:media player control'
            'endpoint:media endpoint management'
            'transport:media transport management'
            'mgmt:management interface commands'
            'assistant:Broadcast Audio Assistant client'
        )
        _describe -t subcmds 'bluetoothctl menu' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
