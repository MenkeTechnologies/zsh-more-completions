#compdef warp-terminal
# Documentation: https://man.archlinux.org/search?q=warp-terminal
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--new-window[open in a new window]' \
  '--new-tab[open in a new tab]' \
  '--new-pane[open in a new pane]' \
  '--cwd=[working directory]:dir:_files -/' \
  '--profile=[Warp profile name]:profile:' \
  '--theme=[Warp theme]:theme:' \
  '*::passthrough:_command_names' && ret=0

return ret
