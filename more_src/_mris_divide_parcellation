#compdef mris_divide_parcellation
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_divide_parcellation
# FreeSurfer: subdivide cortical parcellation units by area or split file

local ret=1

_arguments -s -S \
  '1:subject:' \
  '2:hemi:(lh rh)' \
  '3:source annotation:_files' \
  '4:split file or area threshold:_files' \
  '5:output annotation:_files' && ret=0

return ret
