#compdef newhelp
# Documentation: https://man.archlinux.org/man/newhelp.1.en
# Generate a Performance Co-Pilot help text database

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[base name for output files]:output:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[load an alternative PMNS from file]:pmnsfile:_files' \
  '(-v --version)'{-v+,--version=}'[set output version (deprecated)]:version' \
  '(-V --verbose)'{-V,--verbose}'[print verbose output]' \
  '(-D --debug)'{-D+,--debug=}'[enable diagnostic output]:debug' \
  '*:file:_files' && ret=0

return ret
