#compdef FalseDiscoveryRate
# OpenMS TOPP: estimate the false discovery rate from decoy searches

local ret=1

_arguments -s -S \
  '-in[target-decoy search results (idXML)]:input file:_files' \
  '-out[output file with FDR annotations]:output file:_files' \
  '-PSM[enable PSM-level FDR calculation]:bool:' \
  '-peptide[enable peptide-level FDR computation]:bool:' \
  '-protein[enable protein-level FDR analysis]:bool:' \
  '-proteingroup[include protein group FDR]:bool:' \
  '-FDR:PSM[PSM q-value threshold]:value:' \
  '-FDR:protein[protein q-value threshold]:value:' \
  '-algorithm:no_qvalues[use strict FDR instead of q-values]' \
  '-algorithm:use_all_hits[process all hits, not just first]' \
  '-algorithm:split_charge_variants[treat charge variants separately]' \
  '-algorithm:treat_runs_separately[handle search runs independently]' \
  '-algorithm:add_decoy_peptides[include decoy peptides in output]' \
  '-algorithm:add_decoy_proteins[include decoy proteins in output]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
