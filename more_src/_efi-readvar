#compdef efi-readvar
# Documentation: https://man.archlinux.org/search?q=efi-readvar
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v+[variable name]:var:(PK KEK db dbx MokList MokListX SbatLevel)' \
  '-s+[index of signature list to print]:n:' \
  '-o+[output to file]:file:_files' && ret=0

return ret
