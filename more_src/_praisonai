#compdef praisonai
# Documentation: https://github.com/MervinPraison/PraisonAI
# Reference accessed: 2026-05-22
# Verified: praisonai --help Typer CLI (PyPI package praisonai).

# Zsh completion for praisonai - PraisonAI agents framework CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output-format)'{-o,--output-format}'[output format]:format:(text json stream-json)' \
  '--json[JSON output]' \
  '--no-color[disable colored output]' \
  '(-q --quiet)'{-q,--quiet}'[minimal output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-O --observe)'{-O,--observe}'[enable observability]:backend:' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'praisonai command' \
      'index[index documents into knowledge base]' \
      'query[query knowledge with citations]' \
      'search[search knowledge base]' \
      'app[start AgentOS server]' \
      'config[configuration management]' \
      'traces[trace collection management]' \
      'env[environment and diagnostics]' \
      'session[session management]' \
      'doctor[health checks]' \
      'setup[interactive onboarding]' \
      'run[run agents]' \
      'chat[interactive chat REPL]' \
      'code[terminal code assistant]' \
      'call[voice and call interaction]' \
      'realtime[realtime interaction mode]' \
      'train[model training and fine-tuning]' \
      'ui[launch PraisonAI UI]' \
      'memory[memory management]' \
      'workflow[workflow management]' \
      'tools[tool management]' \
      'knowledge[knowledge base management]' \
      'rag[RAG commands]' \
      'deploy[deployment management]' \
      'agents[agent management]' \
      'skills[skill management]' \
      'eval[evaluation and testing]' \
      'templates[template management]' \
      'mcp[MCP server management]' \
      'serve[API server management]' \
      'browser[browser automation control]' \
      'acp[Agent Client Protocol server]' \
      'cloud[cloud commands]' \
      'dev[development utilities]' \
      'debug[debug interactive flows]' \
      'github[GitHub context and triage]' \
      'bot[messaging bots]' \
      'gateway[multi-bot WebSocket gateway]' \
      'sandbox[sandbox container management]' \
      'claw[PraisonAI dashboard]' \
      'flow[visual workflow builder]' \
      'dashboard[unified dashboard]' \
      'langfuse[Langfuse observability]' \
      'up[start unified PraisonAI stack]' \
      'test[run test suite]' \
      'examples[run example files]' \
      'version[version information]' && ret=0
    ;;
esac

return ret
