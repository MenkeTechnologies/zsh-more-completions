#compdef git-rscp
# Documentation: https://github.com/tj/git-extras/blob/main/Commands.md#git-rscp
# git-extras: copy files from a remote repository working dir to the current dir

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:remote:__git_remotes' \
  '*:file:_files' && ret=0

return ret
