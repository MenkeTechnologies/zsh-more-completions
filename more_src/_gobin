#compdef gobin
# Documentation: https://github.com/myitcv/gobin
# gobin: the project-based Go binary manager / runner

local ret=1

_arguments -s -S \
  '-m[resolve dependencies via the main module instead of the package module]' \
  '-run[run the specified main package, passing remaining args to it]' \
  '-p[print the gobin cache path for each package executable]' \
  '-v[print the module path and version for each package]' \
  '-d[stop after installing to cache; skip install/run/print]' \
  '-u[force checking the network for the latest tagged version]' \
  '-nonet[only check the module download cache]' \
  '-tags=[space-separated build tags to consider satisfied]:tags' \
  '-mod=[control updating of go.mod]:mode:(readonly vendor)' \
  '*:package:_default' && ret=0

return ret
