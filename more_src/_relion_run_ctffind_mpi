#compdef relion_run_ctffind_mpi
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: MPI CTF estimation on micrographs via CTFFIND

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[STAR file or wildcard with input micrographs]:file:_files' \
  '--use_noDW[estimate CTFs from rlnMicrographNameNoDW]' \
  '--o=[directory where all output files will be stored]:dir:_files -/' \
  '--only_make_star[do not estimate CTFs, only join logfiles into a STAR file]' \
  '--only_do_unfinished[only estimate CTFs without a Final-values logfile]' \
  '--do_at_most=[only process up to this many micrographs]:value' \
  '--ctfWin=[size (pixels) of centered window for CTF-estimation]:value' \
  '--localsearch_nominal_defocus=[search defoci around rlnTomoNominalDefocus (A)]:value' \
  '--exp_factor_dose=[exponential factor to limit maxres per unit dose]:value' \
  '--CS=[spherical aberration (mm)]:value' \
  '--HT=[voltage (kV)]:value' \
  '--AmpCnst=[amplitude contrast]:value' \
  '--angpix=[pixel size in the input micrographs (A)]:value' \
  '--ctffind_exe=[location of ctffind executable]:file:_files' \
  '--Box=[size of the boxes to calculate FFTs]:value' \
  '--ResMin=[minimum resolution (A) to include in calculations]:value' \
  '--ResMax=[maximum resolution (A) to include in calculations]:value' \
  '--dFMin=[minimum defocus value (A) to search]:value' \
  '--dFMax=[maximum defocus value (A) to search]:value' \
  '--FStep=[defocus step size (A) for search]:value' \
  '--dAst=[amount of astigmatism (A)]:value' \
  '--is_ctffind4[the executable is CTFFIND4 (version 4.1+)]' \
  '--use_given_ps[use pre-calculated power spectra]' \
  '--do_movie_thon_rings[calculate Thon rings from movie frames]' \
  '--avg_movie_frames=[average over this many movie frames]:value' \
  '--movie_rootname=[rootname plus extension for movies]:name' \
  '--do_phaseshift[estimate the phase shift in the images]' \
  '--phase_min=[minimum phase shift (degrees)]:value' \
  '--phase_max=[maximum phase shift (degrees)]:value' \
  '--phase_step=[step in phase shift (degrees)]:value' \
  '--j=[number of threads (CTFFIND4 only)]:value' \
  '--fast_search[disable slower exhaustive search in CTFFIND4.1]' \
  '*:file:_files' && ret=0

return ret
