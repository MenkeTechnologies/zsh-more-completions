#compdef objcopy
# _objcopy-bin — GNU binutils objcopy; copy + translate object files between formats
# upstream: https://sourceware.org/binutils

_objcopy-bin() {
    _arguments \
        '(-I --input-target)'{-I,--input-target}'+[input BFD target]:target:' \
        '(-O --output-target)'{-O,--output-target}'+[output BFD target]:target:' \
        '(-F --target)'{-F,--target}'+[both targets]:target:' \
        '(-B --binary-architecture)'{-B,--binary-architecture}'+[binary arch]:arch:' \
        '(-S --strip-all)'{-S,--strip-all}'[strip all symbols]' \
        '(-g --strip-debug)'{-g,--strip-debug}'[strip debug symbols]' \
        '--strip-unneeded[strip unneeded symbols]' \
        '(-K --keep-symbol)'{-K,--keep-symbol}'+[keep symbol]:sym:' \
        '(-N --strip-symbol)'{-N,--strip-symbol}'+[strip symbol]:sym:' \
        '(-G --keep-global-symbol)'{-G,--keep-global-symbol}'+[keep only global sym]:sym:' \
        '(-L --localize-symbol)'{-L,--localize-symbol}'+[localize sym]:sym:' \
        '(-W --weaken-symbol)'{-W,--weaken-symbol}'+[weaken sym]:sym:' \
        '(-w --wildcard)'{-w,--wildcard}'[wildcard match]' \
        '(-j --only-section)'{-j,--only-section}'+[only section]:section:' \
        '(-R --remove-section)'{-R,--remove-section}'+[remove section]:section:' \
        '(-p --preserve-dates)'{-p,--preserve-dates}'[preserve dates]' \
        '(-D --enable-deterministic-archives)'{-D,--enable-deterministic-archives}'[deterministic archives]' \
        '-U[ignore]' \
        '(-x --discard-all)'{-x,--discard-all}'[discard all locals]' \
        '(-X --discard-locals)'{-X,--discard-locals}'[discard compiler locals]' \
        '(-i --interleave)'{-i,--interleave}'+[interleave]:n:' \
        '(--interleave-width)--interleave-width+[interleave width]:n:' \
        '(-b --byte)'{-b,--byte}'+[byte]:n:' \
        '--gap-fill+[gap fill value]:n:' \
        '--pad-to+[pad to addr]:addr:' \
        '--set-start+[set start addr]:addr:' \
        '--change-start+[change start by]:n:' \
        '--change-section-address+[section addr change]:str:' \
        '--add-section+[add section]:name=file:_files' \
        '--remove-section+[remove section]:name:' \
        '--rename-section+[rename section]:str:' \
        '--update-section+[update section]:name=file:_files' \
        '--add-symbol+[add symbol]:str:' \
        '--add-gnu-debuglink+[add gnu debuglink]:file:_files' \
        '--keep-file-symbols[keep file symbols]' \
        '--only-keep-debug[only keep debug]' \
        '--decompress-debug-sections[decompress debug sections]' \
        '--compress-debug-sections=+[compress style]:style:(none zlib zlib-gnu zlib-gabi)' \
        '--debug-binary[debug binary mode]' \
        '--input-target+[input target]:target:' \
        '--output-target+[output target]:target:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--help[show help]' \
        '*:file:_files'
}

_objcopy-bin "$@"
