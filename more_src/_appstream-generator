#compdef appstream-generator asgen
# Documentation: https://manpages.debian.org/bookworm/appstream-generator/appstream-generator.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm appstream-generator(1) manpage.

# appstream-generator: build AppStream metadata for distros
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'run:run generator for a suite'
  'cleanup:clean orphaned data'
  'publish:publish data for a suite'
  'remove-found:remove found metadata for a suite'
  'forget:forget about a package'
  'info:show info about a package'
)
_arguments -C \
  '(-w --workspace)'{-w,--workspace=}'[workspace location]:dir:_files -/' \
  '(-c --config)'{-c,--config=}'[configuration file]:file:_files' \
  '--force[enforce the command]' \
  '--verbose[show extra debugging info]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'appstream-generator command' commands && ret=0 ;;
esac
return ret
