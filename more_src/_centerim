#compdef centerim centericq

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '-B+[basedir]:dir:_files -/' \
  '--basedir=[basedir]:dir:_files -/' \
  '-a[ASCII chars only]' \
  '--ascii[ASCII chars only]' \
  '-b[no bidi support]' \
  '-o+[offline mode]:m:' \
  '--offline=[offline mode]:m:' \
  '-d+[debug to file]:file:_files' \
  '--debug=[debug to file]:file:_files' \
  '-D+[debug to fd]:fd:' \
  '--debug-fd=[debug to fd]:fd:' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-s+[status]:s:(online away dnd na occupied free invisible offline)' \
  '--status=[status]:s:' \
  '-r+[rss feeds]:n:' \
  '--rss=[rss feeds]:n:' \
  '*: :' && ret=0

return ret
