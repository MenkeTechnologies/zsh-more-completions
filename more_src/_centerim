#compdef centerim centericq
# Documentation: https://www.mankier.com/1/centerim
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-a[use ASCII chars to draw lines and boxes]' \
  '--ascii[use ASCII chars to draw lines and boxes]' \
  '-b+[base directory]:dir:_files -/' \
  '--basedir=[base directory]:dir:_files -/' \
  '-B+[bind outgoing connections to IP/hostname]:host:' \
  '--bind=[bind outgoing connections to IP/hostname]:host:' \
  '--no-xtitles[disable title changing in xterm/screen]' \
  '-o[start with all protocols offline]' \
  '--offline[start with all protocols offline]' \
  '-s+[type of event to send]:type:(msg url sms)' \
  '--send=[type of event to send]:type:(msg url sms)' \
  '-p+[IM network protocol]:proto:(icq yahoo aim irc jab msn gg lj)' \
  '--proto=[IM network protocol]:proto:(icq yahoo aim irc jab msn gg lj)' \
  '-t+[destination nickname or UIN]:contact:' \
  '--to=[destination nickname or UIN]:contact:' \
  '-n+[mobile number for SMS]:phone:' \
  '--number=[mobile number for SMS]:phone:' \
  '-S+[change status (o,_,a,d,n,c,f,i)]:letter:(o _ a d n c f i)' \
  '--status=[change status (o,_,a,d,n,c,f,i)]:letter:(o _ a d n c f i)' \
  '*: :' && ret=0

return ret
