#compdef pgroll
# Documentation: https://man.archlinux.org/search?q=pgroll
# Reference accessed: 2026-05-16

_pgroll() {
    local line state
    local -a commands
    commands=(
        'init:Initialize pg-roll'
        'start:Start a new migration'
        'complete:Complete a migration'
        'rollback:Rollback a migration'
        'validate:Validate a migration file'
        'create:Create a new migration file'
        'status:Show migration status'
        'migrate:Run migrations'
        'latest:Show latest migration info'
        'pull:Pull migrations'
        'convert:Convert migrations'
        'baseline:Baseline the database'
        'update:Update pg-roll'
    )

    _arguments -C \
        '--json[Output in JSON format]' \
        '(-l --local)'{-l,--local}'[Retrieve latest migration from local directory]:directory:_files -/' \
        '--lock-timeout[Adjust lock timeout]:timeout:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'pgroll command' commands
            ;;
        args)
            case $line[1] in
                latest)
                    _arguments '1:subcommand:(migration schema url)'
                    ;;
            esac
            ;;
    esac
}

_pgroll "$@"
