#compdef pgroll

# Zsh completion for pgroll - PostgreSQL zero-downtime schema migrations

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_pgroll_global_flags=(
  '(- *)--help[show help]'
  '(- *)--version[show version]'
  '(-u --postgres-url)'{-u,--postgres-url}'[PostgreSQL connection URL]:url:'
  '(-s --schema)'{-s,--schema}'[target schema name]:schema:'
  '--lock-timeout=[lock timeout duration]:duration:'
  '--role=[role to use for migrations]:role:'
)

_arguments -s -S -C \
  "${_pgroll_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'init:Initialize pgroll in a database'
      'start:Start a migration'
      'complete:Complete an active migration'
      'rollback:Roll back an active migration'
      'status:Show migration status'
      'latest:Show the latest migration version'
      'migrate:Run up migrations from a directory'
    )
    _describe -t commands 'pgroll commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      start)
        _arguments -s -S \
          "${_pgroll_global_flags[@]}" \
          '--complete[automatically complete migration after start]' \
          '1:migration file:_files -g "*.json"' && ret=0
        ;;
      migrate)
        _arguments -s -S \
          "${_pgroll_global_flags[@]}" \
          '1:migrations directory:_directories' && ret=0
        ;;
      init|complete|rollback|status|latest)
        _arguments -s -S \
          "${_pgroll_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
