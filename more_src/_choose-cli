#compdef choose
# Documentation: https://man.archlinux.org/search?q=choose
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --character-wise)'{-c,--character-wise}'[character-wise selection]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-x --exclusive)'{-x,--exclusive}'[exclusive ranges]' \
  '(-f --field-separator)'{-f+,--field-separator=}'[field separator regex]:re:' \
  '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
  '(-n --non-greedy)'{-n,--non-greedy}'[non-greedy field separator]' \
  '(-o --output-field-separator)'{-o+,--output-field-separator=}'[output separator]:s:' \
  '(--one-indexed)--one-indexed[start at 1]' \
  '*:range:' && ret=0

return ret
