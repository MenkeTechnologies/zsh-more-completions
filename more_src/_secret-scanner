#compdef secret-scanner
# Documentation: https://github.com/grab/secret-scanner
# secret-scanner (grab) - scan git repositories across providers for committed secrets.

local ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-baseurl[specify git provider base URL]:url:' \
  '-commit-depth[number of repository commits to process]:depth:' \
  '-debug[print debugging information]' \
  '-env[.env file with provider base URLs and tokens]:file:_files' \
  '-git[name of git provider]:provider:(github gitlab bitbucket)' \
  '-load[load session file]:file:_files' \
  '-dir[local git repo path to scan]:dir:_files -/' \
  '-log-secret[include matched secret in output file]' \
  '-output[save session to file]:file:_files' \
  '-repos[comma-separated list of repos to scan]:repos:' \
  '-sub-dir[sub-directory within the repository to scan]:dir:_files -/' \
  '-quiet[suppress all output except for errors]' \
  '-skip-tests[skip possible test contexts]' \
  '-use-state[enable scan state persistence]' \
  '-threads[number of concurrent threads]:threads:' \
  '-token[specify git provider token]:token:' && ret=0

return ret
