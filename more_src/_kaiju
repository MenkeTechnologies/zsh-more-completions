#compdef kaiju
# Documentation: https://github.com/bioinformatics-centre/kaiju
# Taxonomic classification of metagenomic sequencing reads

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-t[nodes.dmp taxonomy file]:nodes:_files' \
  '-f[FM-index database file (.fmi)]:fmi:_files' \
  '-i[input sequence file]:input:_files' \
  '-j[second input file (paired-end)]:input:_files' \
  '-o[output file]:output:_files' \
  '-z[number of parallel threads]:threads:' \
  '-a[run mode (mem or greedy)]:mode:(mem greedy)' \
  '-e[number of mismatches allowed in greedy mode]:mismatches:' \
  '-m[minimum match length]:length:' \
  '-s[minimum match score in greedy mode]:score:' \
  '-E[minimum E-value]:evalue:' \
  '-x[enable SEG low complexity filter]' \
  '-X[disable SEG low complexity filter]' \
  '-p[input is protein sequences]' \
  '-v[enable verbose output]' \
  '*:file:_files' && ret=0

return ret
