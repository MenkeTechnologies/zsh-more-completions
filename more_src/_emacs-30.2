#compdef emacs-30.2

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--batch[non-interactive display]' \
  '--chdir=[change to directory]:dir:_files -/' \
  {--daemon,--bg-daemon=-}'[start server in background]:name:' \
  '--fg-daemon=-[start server in foreground]:name:' \
  '--debug-init[enable Emacs Lisp debugger for init]' \
  {--display=,-d+}'[use X server display]:display:' \
  '--module-assertions[assert dynamic modules behavior]' \
  '--dump-file=[read dumped state from file]:file:_files' \
  '--fingerprint[output fingerprint and exit]' \
  '--no-build-details[do not add build details]' \
  '--no-desktop[do not load saved desktop]' \
  {-q,--no-init-file}'[load neither ~/.emacs nor default.el]' \
  {-nl,--no-loadup}'[do not load loadup.el]' \
  '--no-site-file[do not load site-start.el]' \
  '--no-x-resources[do not load X resources]' \
  {-nsl,--no-site-lisp}'[do not add site-lisp directories]' \
  '--no-splash[do not display splash screen]' \
  {-nw,--no-window-system}'[do not communicate with X]' \
  '--init-directory=[Emacs init files directory]:dir:_files -/' \
  {-Q,--quick}'[quick startup options]' \
  '--script=[run file as Emacs Lisp script]:file:_files -g "*.el"' \
  '-x[run as #!/usr/bin/emacs -x script]' \
  {--terminal=,-t+}'[use device for terminal I/O]:device:' \
  {--user=,-u+}'[load ~USER/.emacs]:user:_users' \
  '*'{--directory=,-L+}'[prepend dir to load-path]:dir:_files -/' \
  '*--eval=[evaluate expression]:expr:' \
  '*--execute=[evaluate expression]:expr:' \
  '*--file=[visit file]:file:_files' \
  '*--find-file=[visit file]:file:_files' \
  '*'{--funcall=,-f+}'[call function with no args]:func:' \
  '*--insert=[insert file contents]:file:_files' \
  '--kill[exit without confirmation]' \
  '*'{--load=,-l+}'[load Emacs Lisp file]:file:_files -g "*.(el|elc)"' \
  '*--visit=[visit file]:file:_files' \
  {--background-color=,-bg+}'[window background color]:color:' \
  {-D,--basic-display}'[disable many display features]' \
  {--border-color=,-bd+}'[main border color]:color:' \
  {--border-width=,-bw+}'[main border width]:width:' \
  '--color=-[color mode]:mode:(auto never always ansi8 ansi16)' \
  {--cursor-color=,-cr+}'[cursor color]:color:' \
  {--font=,-fn+}'[default fixed-width font]:font:' \
  {--foreground-color=,-fg+}'[foreground color]:color:' \
  {-fh,--fullheight}'[full height]' \
  {-fs,--fullscreen}'[fullscreen]' \
  {-fw,--fullwidth}'[full width]' \
  {-mm,--maximized}'[maximized]' \
  {--geometry=,-g+}'[window geometry]:geometry:' \
  {-nbi,--no-bitmap-icon}'[do not use gnu icon]' \
  '--iconic[start iconified]' \
  {--internal-border=,-ib+}'[internal border width]:width:' \
  {--line-spacing=,-lsp+}'[line spacing pixels]:pixels:' \
  {--mouse-color=,-ms+}'[mouse cursor color]:color:' \
  '--name=[initial frame title]:name:' \
  {-nbc,--no-blinking-cursor}'[disable blinking cursor]' \
  {-r,-rv,--reverse-video}'[reverse video]' \
  {--title=,-T+}'[initial frame title]:title:' \
  {-vb,--vertical-scroll-bars}'[vertical scroll bars]' \
  '--xrm=[X resources]:xresources:' \
  '--parent-id=[parent window XID]:xid:' \
  '*:file:_files' && ret=0

return ret
