#compdef joyserver
# Documentation: https://manpages.ubuntu.com/manpages/jammy/en/man1/joyserver.1.html
# Reference accessed: 2026-05-16

# joyserver: joystick passthrough server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[joystick device]:device:_files -g "/dev/input/js*"' \
  '-p[listen port]:port:' \
  '-v[verbose]' \
  '*::joyserver args:_files' && ret=0
return ret
