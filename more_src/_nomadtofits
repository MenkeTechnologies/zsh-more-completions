#compdef nomadtofits
# Documentation: http://astrometry.net/doc/build-index.html
# convert the NOMAD catalog to healpixed FITS binary tables

local ret=1

_arguments -s \
  '-h[show help]' \
  '-o+[output filename template (eg nomad_%03i.fits)]:output:_files' \
  '-N+[healpix nside (default 9)]:nside:' \
  '*:input file:_files' && ret=0

return ret
