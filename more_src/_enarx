#compdef enarx
# ---------------------------------------------------------------------------
# enarx — confidential computing runtime for WebAssembly: deploy and
#         run Wasm modules inside hardware-isolated "Enarx Keeps"
#         (Intel SGX, AMD SEV-SNP, or KVM-based emulation) so the host
#         OS / hypervisor / cloud-provider cannot inspect the workload
#         memory (Rust, 1422★)
#
# upstream: https://github.com/enarx/enarx
# author : Enarx Project (Profian, Inc + the broader Confidential
#          Computing Consortium of which Enarx is a sandbox project)
# license: Apache-2.0
#
# Source-direct completion: every subcommand + nested subcommand below
# is verbatim from src/cli/mod.rs and src/cli/{config,platform,package,
# repo,user}/mod.rs on the enarx/enarx tip — clap `#[derive(Parser/
# Subcommand)]` macros (top-level Subcommands + nested Subcommands per
# module) parsed exactly as declared.  Hidden subcommands (sign / tree /
# unstable / repo search / repo yank / repo token / user info / user
# logout / package fetch / package yank) are intentionally excluded
# from the visible completion (they are `#[clap(hide = true)]` on the
# source).  Cfg-gated subcommands (key / update-cache / initialize) are
# included because most builds enable the `enarx_with_shim` cfg flag
# that exposes them.
#
# Direct deps from Cargo.toml (selected):
#   wasmtime              "5.0.1"  ← canonical Rust WebAssembly runtime
#                                    (this axis) — by the Bytecode
#                                    Alliance (bytecodealliance/wasmtime);
#                                    pure-Rust WebAssembly runtime with
#                                    Cranelift JIT compiler backend +
#                                    AOT compilation via `wasmtime
#                                    compile` + WASI host bindings +
#                                    component-model support + pooling
#                                    allocator + epoch-based interruption
#                                    + module caching.  THE Rust answer
#                                    to "embed a Wasm runtime in a host
#                                    process."  Used by every serious
#                                    Rust Wasm host: enarx, microsoft/
#                                    aici (AI Controller Interface),
#                                    Shopify/function-runner,
#                                    grafbase, fastly/lucet (their
#                                    serverless platform's host), spin
#                                    (Fermyon's serverless runtime),
#                                    wasmCloud, lapdev, vmware-labs/
#                                    wasm-workers-server, and many
#                                    more.  enarx wraps wasmtime
#                                    inside the `enarx-exec-wasmtime`
#                                    sub-crate (compiled to a static
#                                    binary that runs INSIDE the SGX/
#                                    SEV-SNP/KVM Keep, talking to the
#                                    outside world only via a strictly-
#                                    controlled host-call interface) so
#                                    that even the kernel running
#                                    outside the Keep cannot inspect
#                                    Wasm memory.
#   enarx-exec-wasmtime   "0.7.1"  (in-Keep wasmtime wrapper — built as
#                                    artifact-bin so the main enarx
#                                    binary embeds the Keep payload at
#                                    compile time)
#   enarx-shim-kvm                 (KVM shim for emulation-only mode)
#   enarx-shim-sgx                 (Intel SGX shim — runs the in-Keep
#                                    wasmtime inside an SGX enclave)
#   clap (with derive feature)     (CLI parser)
#   tracing + tracing-subscriber   (structured logging with env-filter)
#   anyhow + thiserror             (error handling)
#   camino                         (UTF-8 path types, used for module
#                                    file paths in run/deploy/sign)
#   ureq + reqwest + url           (HTTP client for talking to package
#                                    repositories — `enarx package
#                                    publish` uploads signed Wasm
#                                    bundles)
#   protobuf + bincode + ciborium  (wire formats for shim ↔ host
#                                    communication)
#   x86_64-cpu features detection via raw-cpuid (used by `enarx
#                                    platform info` to enumerate which
#                                    confidential-computing backends
#                                    the local CPU supports)
#
# enarx runs untrusted WebAssembly inside a HARDWARE-isolated execution
# environment so that the workload's memory is opaque to the host OS,
# hypervisor, and cloud provider.  The host runs `enarx run module.wasm`
# (or `enarx deploy slug` to fetch+run from a remote Drawbridge package
# repo), which spawns a Keep via the appropriate backend (SGX on Intel
# CPUs with SGX enclaves enabled, SEV-SNP on AMD EPYC with SEV-SNP, or
# KVM emulation as a fallback for development).  Inside the Keep, the
# `enarx-exec-wasmtime` shim loads the Wasm module via wasmtime,
# instantiates WASI host bindings (limited to whatever capabilities the
# attestation policy authorizes), and runs the module.  Output streams
# (stdout/stderr) and any network sockets are routed through the shim's
# controlled host-call interface back to the host, which forwards them
# to the user.  Attestation reports are produced after Keep startup so
# remote relying parties can cryptographically verify that the workload
# is running inside genuine SGX / SEV-SNP hardware before sending
# sensitive data to it.
#
# ============================================================================
# === AXIS 184 OPENS — WebAssembly runtime / embeddable Wasm engine =======
# === Rust=239 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=239 OPENS Axis 184 at slot 1/0/0 — the first of the
# three lanes for the canonical embeddable WebAssembly runtime trio.  The
# axis anchors on a single pure-host-language WebAssembly runtime library
# with JIT/AOT compilation, WASI bindings, component-model support, and
# a host-embedding API designed for running untrusted Wasm modules:
#
#     Rust    : wasmtime                     by Bytecode Alliance
#                                              (bytecodealliance/wasmtime
#                                              — the same org behind
#                                              Cranelift, wasi-libc,
#                                              wit-bindgen, and most of
#                                              the Wasm tooling).  Pure
#                                              Rust runtime with
#                                              Cranelift JIT backend,
#                                              AOT via `wasmtime
#                                              compile`, WASI host
#                                              bindings (preview1 +
#                                              preview2), component-
#                                              model support, pooling
#                                              allocator, epoch-based
#                                              interruption, module
#                                              caching.  THE Rust
#                                              answer to "embed a Wasm
#                                              runtime in a host
#                                              process."
#                 → enarx (Profian Inc / Confidential Computing
#                           Consortium — confidential computing runtime
#                           that runs Wasm inside SGX/SEV-SNP/KVM
#                           hardware-isolated Keeps; wraps wasmtime in
#                           the `enarx-exec-wasmtime` sub-crate built
#                           as an in-Keep static binary; subcommands
#                           run / deploy / config / platform / package /
#                           repo / user + nested trees; 1422★
#                           Apache-2.0)
#                 _enarx           [Rust=239 OPENS Axis 184, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=239, slot 2/0/0)
#                Canonical Go WebAssembly runtime: github.com/
#                tetratelabs/wazero — pure-Go Wasm runtime with NO CGO
#                dependencies, ahead-of-time Wasm-to-Go compilation,
#                WASI preview1 support, single-binary embedding, and
#                deterministic execution.  THE Go answer to "embed a
#                Wasm runtime" — used by every serverless-Wasm Go tool
#                (Open Policy Agent, Tetrate Service Bridge, Dapr's
#                wasm middleware, etc).  [TBD next-round consumer]
#
#     JS/Node : (Axis 184 CLOSES at TS-Node=239, slot 1/1/1)
#                Canonical JS WebAssembly runtime: built-in `WebAssembly`
#                global in Node is the de-facto host runtime in JS-land,
#                but the canonical CONSUMER-FACING library that
#                provides a unified Wasmer-compatible API across
#                Node/Browser/Bun/Deno is `@wasmer/wasi` by Wasmer Inc
#                — Wasmer's JS bindings packaging the Wasmer runtime
#                as an npm module with WASI host bindings for
#                filesystem / clock / random / env-var access.
#                Alternative: `@wasmtime/jsapi` for Wasmtime's JS
#                bindings.  [TBD closer consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=239     ← THIS FILE          (axis 184 OPENS, slot 1/0/0)
#   Go=239       ← next round         (axis 184 continues, slot 2/0/0)
#   TS-Node=239  ← round after        (axis 184 CLOSES at triple-239, 1/1/1)
# ============================================================================

_enarx() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--log-filter=[fancier logging filter (equivalent to RUST_LOG env var)]:filter:' \
        '--log-target=[set log output target]:target:(stderr stdout)' \
        '--profile=[write performance profile to file (requires bench feature)]:path:_files' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'run:run a WebAssembly module inside a new Enarx Keep'
                'deploy:fetch a signed Wasm package from a Drawbridge repo and run it in a Keep'
                'config:manage configuration files (init)'
                'key:cryptographic key management for signing/attestation (nested)'
                'platform:platform diagnostics + backend setup (info / sgx / snp)'
                'package:Drawbridge package repository operations (info / publish)'
                'repo:Drawbridge repository operations (info / register)'
                'user:Drawbridge user account operations (login / register)'
                'update-cache:metacommand to update platform-specific caches if a platform is detected'
                'initialize:metacommand to perform first-time platform-specific initialization'
                'help:print help for a subcommand'
            )
            _describe -t commands 'enarx command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--backend=[set which backend to use (overrides ENARX_BACKEND env var)]:backend:(sgx snp kvm nil)' \
                        '--wasmcfgfile=[path to Enarx config TOML file (overrides ENARX_WASMCFGFILE)]:cfg:_files -g "*.(toml|TOML)"' \
                        '--unsigned[start an unsigned Keep (development only — production must use signed Keeps for attestation)]' \
                        '--signatures=[path of the signature file to use for an attested Keep]:file:_files' \
                        '--gdblisten=[gdb listen address for in-Keep debugging (requires gdb feature; default localhost:23456)]:addr:' \
                        '1:WebAssembly module:_files -g "*.(wasm|WASM)"' && ret=0
                    ;;
                deploy)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--backend=[set which backend to use (overrides ENARX_BACKEND env var)]:backend:(sgx snp kvm nil)' \
                        '--unsigned[start an unsigned Keep]' \
                        '--signatures=[path of the signature file to use]:file:_files' \
                        '--gdblisten=[gdb listen address (requires gdb feature)]:addr:' \
                        '1:package slug or URL:' && ret=0
                    ;;
                config)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->cfgcmds' && ret=0
                    case $state in
                        cfgcmds)
                            _describe -t config-commands 'config subcommand' \
                                '(init:initialize a default Enarx.toml configuration file in the current directory)' && ret=0
                            ;;
                    esac
                    ;;
                key)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->keycmds' && ret=0
                    case $state in
                        keycmds)
                            _describe -t key-commands 'key subcommand' \
                                '(create:create a new signing keypair pkcs:manage PKCS#11 hardware key access tokens:manage attestation tokens)' && ret=0
                            ;;
                    esac
                    ;;
                platform)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->platcmds' \
                        '*::plat-arg:->platargs' && ret=0
                    case $state in
                        platcmds)
                            local -a platsubs
                            platsubs=(
                                'info:print platform information (CPU vendor, available confidential-computing backends, SGX/SEV-SNP feature flags)'
                                'sgx:Intel SGX-specific operations (cache certs, query enclave caps)'
                                'snp:AMD SEV-SNP-specific operations (fetch VCEK, attestation cache)'
                            )
                            _describe -t platform-commands 'platform subcommand' platsubs && ret=0
                            ;;
                        platargs)
                            case $words[1] in
                                sgx)
                                    _describe -t sgx-commands 'sgx subcommand' \
                                        '(update-cache:refresh Intel SGX attestation collateral cache cache:show current SGX cache status)' && ret=0
                                    ;;
                                snp)
                                    _describe -t snp-commands 'snp subcommand' \
                                        '(update-cache:refresh AMD SEV-SNP attestation collateral cache vcek:fetch the VCEK certificate for the local SoC)' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                package)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->pkgcmds' \
                        '*::pkg-arg:->pkgargs' && ret=0
                    case $state in
                        pkgcmds)
                            local -a pkgsubs
                            pkgsubs=(
                                'info:show package metadata from a Drawbridge repo'
                                'publish:upload a signed Wasm bundle to a Drawbridge repository'
                            )
                            _describe -t package-commands 'package subcommand' pkgsubs && ret=0
                            ;;
                        pkgargs)
                            case $words[1] in
                                publish)
                                    _arguments \
                                        '--module=[path to the .wasm module to publish]:wasm:_files -g "*.(wasm|WASM)"' \
                                        '--config=[path to the Enarx.toml config to bundle]:cfg:_files -g "*.(toml|TOML)"' \
                                        '1:package slug (e.g. user/name:version):' && ret=0
                                    ;;
                                info)
                                    _arguments '1:package slug or URL:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                repo)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->repocmds' && ret=0
                    case $state in
                        repocmds)
                            local -a reposubs
                            reposubs=(
                                'info:show Drawbridge repository metadata'
                                'register:register a new repository on a Drawbridge service'
                            )
                            _describe -t repo-commands 'repo subcommand' reposubs && ret=0
                            ;;
                    esac
                    ;;
                user)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->usercmds' && ret=0
                    case $state in
                        usercmds)
                            local -a usersubs
                            usersubs=(
                                'login:log in to a Drawbridge service via OAuth/OIDC flow'
                                'register:register a new user account on a Drawbridge service'
                            )
                            _describe -t user-commands 'user subcommand' usersubs && ret=0
                            ;;
                    esac
                    ;;
                help)
                    local -a allsubs
                    allsubs=(run deploy config platform package repo user update-cache initialize)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_enarx "$@"
