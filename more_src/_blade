#compdef blade
# Documentation: https://man.archlinux.org/search?q=blade
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'check:check the environment'
  'prepare:preparation before experiment'
  'p:preparation (alias)'
  'revoke:undo experiment preparation'
  'r:undo preparation (alias)'
  'create:create a chaos experiment'
  'c:create experiment (alias)'
  'destroy:destroy a chaos experiment'
  'd:destroy experiment (alias)'
  'query:query parameter values'
  'q:query (alias)'
  'status:query experiment status'
  's:query status (alias)'
  'server:start server mode'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'blade subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create|c)
        _arguments \
          '(-a --async)'{-a,--async}'[create asynchronously]' \
          '(-e --endpoint)'{-e,--endpoint=}'[result reporting address]:url:' \
          '(-n --nohup)'{-n,--nohup}'[internal nohup mode]' \
          '--uid=[experiment UID]:uid:' && ret=0
        ;;
      (prepare|p)
        _values 'prepare target' 'jvm' 'cplus' && ret=0
        ;;
      (status|s)
        _arguments \
          '--asc[ascending sort]' \
          '--limit=[limit/offset]:limit:' \
          '--status=[status filter]:status:(Created Success Error Destroyed Running Revoked)' \
          '--target=[target filter]:target:' \
          '--type=[type filter]:type:(attach create destroy detach)' \
          '--uid=[query by UID]:uid:' && ret=0
        ;;
      (query|q)
        _values 'query target' 'disk' 'jvm' 'k8s' 'network' && ret=0
        ;;
    esac
    ;;
esac

return ret
