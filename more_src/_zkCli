#compdef zkCli zkCli.sh
# Documentation: https://man.archlinux.org/search?q=zkCli
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-server[ZooKeeper server to connect to]:host\:port'
    '-timeout[Session timeout in ms]:milliseconds'
    '-r[Read-only mode]'
    '-client-configuration[Client config file]:file:_files'
    '-waitforconnection[Wait for connection before executing]'
)

_arguments -s -S $arguments
