#compdef nextdns
# Documentation: https://github.com/nextdns/nextdns
# Reference accessed: 2026-05-19
# Verified: upstream main.go subcommand table.

# Zsh completion for nextdns (github.com/nextdns/nextdns)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a c=(
      'install:install service init on the system'
      'uninstall:uninstall service init from the system'
      'start:start installed service'
      'stop:stop installed service'
      'restart:restart installed service'
      'status:return service status'
      'log:show service logs'
      'upgrade:upgrade the CLI to the latest version'
      'run:run the daemon'
      'config:manage configuration'
      'activate:setup the system to use NextDNS as a resolver'
      'deactivate:restore the resolver configuration'
      'discovered:display discovered clients'
      'cache-stats:display cache statistics'
      'cache-keys:dump cached entries'
      'trace:display stack trace dump'
      'arp:dump the ARP table'
      'ndp:dump the NDP table'
      'version:show current version'
    )
    _describe -t commands 'nextdns command' c && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
