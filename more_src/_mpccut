#compdef mpccut
# Documentation: https://www.musepack.net/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (verified locally via `mpccut`
#   built-in usage string: "mpccut [-s start_sample] [-e end_sample]
#   <infile.mpc> <outfile.mpc>").

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-s+[start sample]:sample:' \
  '-e+[end sample]:sample:' \
  '1:input file:_files -g "*.mpc"' \
  '2:output file:_files -g "*.mpc"' && ret=0

return ret
