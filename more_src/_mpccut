#compdef mpccut
# Documentation: https://man.archlinux.org/search?q=mpccut
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-s+[start sample]:sample:' \
  '-e+[end sample]:sample:' \
  '1:input file:_files -g "*.mpc"' \
  '2:output file:_files -g "*.mpc"' && ret=0

return ret
