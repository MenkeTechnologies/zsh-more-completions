#compdef scil_volume_math
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_volume_math.html
# Scilpy: perform arithmetic/morphological operations on volumes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--data_type=[output data type]:data_type' \
  '--exclude_background[do not apply operation to background]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:operation:(lower_threshold upper_threshold lower_threshold_eq upper_threshold_eq lower_threshold_otsu upper_threshold_otsu lower_clip upper_clip absolute_value round ceil floor normalize_sum normalize_max log_10 log_e convert invert addition subtraction multiplication division maximum mean std correlation union intersection difference concatenate dilation erosion closing opening blur)' \
  '*:args:_files' && ret=0

return ret
