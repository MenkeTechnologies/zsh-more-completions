#compdef apisix-cli apisix
# _apisix-cli — Apache APISIX apisix-cli CLI command-line management utility for the Apache APISIX cloud-native microservices API Gateway built on NGINX OpenResty Lua handling routes services upstreams consumers SSL plugins admin start stop reload status help quit log-format jq-pipeline (Apache APISIX team, Lua); custom argparse
# upstream: https://apisix.apache.org/

_apisix-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--prefix=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.conf"' \
        '--profile=+[name]:str:' \
        '-g+[global config]:str:' \
        '--global=+[config]:str:' \
        '*:command:(help version init init_etcd start stop quit reload restart test deps config_test compile-deps compile_deps install help_short shell run_db run_etcd ports check_config_yaml format format_apisix audit)'
}

_apisix-cli "$@"
