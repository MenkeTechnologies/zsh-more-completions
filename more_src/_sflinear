#compdef sflinear
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mlinear.c
# Madagascar: 1-D linear interpolation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'sort=[if y, the coordinates need sorting]:flag:(y n)' \
  'niter=[number of iterations]:count' \
  'rect=[smoothing regularization]:radius' \
  'nw=[interpolator size]:size' \
  'pattern=[input file for output grid specification]:file:_files' \
  'n1=[output grid size]:count' \
  'd1=[output sampling]:value' \
  'o1=[output origin]:value' \
  '*:RSF file:_files' && ret=0

return ret
