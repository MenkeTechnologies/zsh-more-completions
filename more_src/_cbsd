#compdef cbsd

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bconstruct-tui:TUI constructor for bhyve VMs'
  'bclone:clone a bhyve VM'
  'bcreate:create a new bhyve VM'
  'bdestroy:destroy a bhyve VM'
  'bexec:execute a command in a bhyve VM via VNC'
  'bget:get bhyve VM settings'
  'bhyve-dsk:manage bhyve disk images'
  'blist:list bhyve VMs'
  'blogin:login to a bhyve VM console'
  'bpause:pause a bhyve VM'
  'brename:rename a bhyve VM'
  'brestart:restart a bhyve VM'
  'bset:set bhyve VM settings'
  'bstart:start a bhyve VM'
  'bstop:stop a bhyve VM'
  'bsuspend:suspend a bhyve VM'
  'jconstruct-tui:TUI constructor for jails'
  'jclone:clone a jail'
  'jcreate:create a new jail'
  'jdestroy:destroy a jail'
  'jexec:execute a command inside a jail'
  'jget:get jail settings'
  'jlist:list jails'
  'jlogin:login to a jail'
  'jrename:rename a jail'
  'jrestart:restart a jail'
  'jset:set jail settings'
  'jstart:start a jail'
  'jstop:stop a jail'
  'jsnapshot:manage jail snapshots'
  'jstatus:show jail status'
  'jail2iso:convert jail to ISO image'
  'baseupdate:update the FreeBSD base'
  'basejail:manage base jails'
  'cbsdsqlro:read-only query on CBSD SQLite database'
  'env:show CBSD environment variables'
  'forms:manage CBSD forms'
  'freejname:get the next available jail name'
  'initenv:initialize the CBSD environment'
  'media:manage media/ISO images'
  'module:manage CBSD modules'
  'natcfg:manage NAT configuration'
  'node:manage cluster nodes'
  'pause:pause all running jails and VMs'
  'pkg:manage packages in jails'
  'puppet:manage Puppet configurations'
  'racct-jail:display jail resource accounting'
  'rclone:clone a jail or VM to a remote node'
  'repo:manage CBSD repositories'
  'restart:restart all jails and VMs'
  'snapshot:manage snapshots'
  'start:start all jails and VMs'
  'stop:stop all jails and VMs'
  'summary:show system summary'
  'sysvol:manage system volumes'
  'task:manage background tasks'
  'trafstat:show traffic statistics'
  'upgrade:upgrade CBSD'
  'version:display CBSD version'
  'vpc:manage virtual private clouds'
  'xen:manage Xen domains'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'cbsd command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (jcreate|bcreate)
        _arguments \
          'jname=:jail/VM name:' \
          'ip4_addr=:IP address:' \
          'host_hostname=:hostname:' \
          'ver=:FreeBSD version:' \
          'baserw=:base read-write:(0 1)' \
          'mount_devfs=:mount devfs:(0 1)' \
          'allow_mount=:allow mount:(0 1)' \
          'allow_devfs=:allow devfs:(0 1)' \
          'allow_nullfs=:allow nullfs:(0 1)' \
          'vnet=:enable vnet:(0 1)' \
          && ret=0
        ;;
      (jstart|jstop|jrestart|jdestroy|jlogin|jexec|bstart|bstop|brestart|bdestroy|blogin)
        _arguments \
          'jname=:jail/VM name:' \
          && ret=0
        ;;
      (jset|jget|bset|bget)
        _arguments \
          'jname=:jail/VM name:' \
          '*:setting=value:' \
          && ret=0
        ;;
      (jsnapshot|snapshot)
        _arguments \
          'jname=:jail/VM name:' \
          'mode=:mode:(list create destroy rollback)' \
          'snapname=:snapshot name:' \
          && ret=0
        ;;
      (pkg)
        _arguments \
          'jname=:jail name:' \
          'mode=:mode:(install delete info bootstrap update upgrade)' \
          '*:package name:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
