#compdef hp-wificonfig
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/hp-wificonfig.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy hp-wificonfig(1) manpage. Qt4 GUI only.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-wificonfig: HPLIP WiFi configuration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' && ret=0
return ret
