#compdef yambo
# Documentation: https://wiki.yambo-code.eu/wiki/index.php/Input_file_generation_and_command_line_options
# yambo — ab initio many-body GW/BSE code: command-line input generation and runlevels

local ret=1

_arguments -s -S \
  '(-h --help)-h[short help]' \
  '-H[long help]' \
  '-F[input file]:input file:_files' \
  '-I[core I/O directory]:core I/O dir:_directories' \
  '-O[additional I/O directory]:I/O dir:_directories' \
  '-C[communications I/O directory]:comm dir:_directories' \
  '-J[job string identifier]:job string:' \
  '-V[input file verbosity]:verbosity:(RL kpt sc qp io gen resp all par)' \
  '-D[DataBases properties]' \
  '-Q[do not launch the text editor]' \
  '-E[environment parallel variables file]:env file:_files' \
  '-W[wall time limitation (1d2h30m format)]:walltime:' \
  '-M[switch off MPI support (serial run)]' \
  '-N[switch off OpenMP support (single thread run)]' \
  '-i[initialization]' \
  '-o[optics (c=chi G-space / b=bse eh-space)]:optics:(c b)' \
  '-x[Hartree-Fock self-energy and local XC]' \
  '-p[GW approximations (p=PPA / c=COHSEX)]:gw:(p c)' \
  '-g[Dyson equation solver (n=newton / s=secant / g=green)]:solver:(n s g)' \
  '-d[dynamical inverse dielectric matrix]' \
  '-b[static inverse dielectric matrix]' \
  '-k[kernel (hartree/alda/lrc/hf/sex)]:kernel:(hartree alda lrc hf sex)' \
  '-y[BSE solver (h/d/s/p/f/i)]:bse solver:(h d s p f i)' \
  '-r[Coulomb potential]' \
  '-l[GoWo QuasiParticle lifetimes]' \
  '-a[ACFDT total energy]' \
  '-s[ScaLapacK test]' \
  '*:input file:_files' && ret=0

return ret
