#compdef xa xa65 dxa printcbm uncpk file2c reloc65 ldo65

local curcontext="$curcontext" state line ret=1

case $service in
  (xa|xa65)
    _arguments -C \
      '(- *)-h[show help]' \
      '--help[show help]' \
      '(- *)--version[show version]' \
      '-o+[output file]:file:_files' \
      '-l+[list file]:file:_files' \
      '-c[do not produce o65]' \
      '-A+[set start addr hex]:n:' \
      '-G+[suppress globals from listing]:p:' \
      '-DSYM=val[define]:macro:' \
      '*-I+[include dir]:dir:_files -/' \
      '-O+[output format]:f:(o65 bin)' \
      '-x[bin output]' \
      '-C[6502 mode]' \
      '-W[6800 mode]' \
      '-w[no warnings]' \
      '-M[MASM compat]' \
      '-R[allow relative addressing]' \
      '-B[show banner]' \
      '-v[verbose]' \
      '-XBT+[bss start]:n:' \
      '-XCH+[code high]:n:' \
      '-XCB+[code base]:n:' \
      '-XBB+[bss base]:n:' \
      '-XDB+[data base]:n:' \
      '-bx+[banner mode]:n:' \
      '*: :_files -g "*.s *.a *.asm"' && ret=0 ;;
  (dxa)
    _arguments -C \
      '-h[help]' \
      '-i+[input addr]:n:' \
      '-o+[output addr]:n:' \
      '-x+[range]:n:' \
      '*: :_files' && ret=0 ;;
  (printcbm)
    _arguments '*: :_files' && ret=0 ;;
  (uncpk)
    _arguments '*: :_files -g "*.cpk"' && ret=0 ;;
  (file2c)
    _arguments -C \
      '-h[help]' \
      '*: :_files' && ret=0 ;;
  (reloc65)
    _arguments -C \
      '-V[show version]' \
      '-X[strip undefs]' \
      '-v[verbose]' \
      '-o+[output]:file:_files' \
      '-bt+[text base]:n:' \
      '-bd+[data base]:n:' \
      '-bb+[bss base]:n:' \
      '-bz+[zero base]:n:' \
      '*: :_files -g "*.o65"' && ret=0 ;;
  (ldo65)
    _arguments -C \
      '-V[show version]' \
      '-v[verbose]' \
      '-o+[output]:file:_files' \
      '-L+[lib path]:dir:_files -/' \
      '*: :_files -g "*.o65"' && ret=0 ;;
esac

return ret
