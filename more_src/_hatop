#compdef hatop

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --unix-socket)'{-s,--unix-socket}'+[unix socket]:file:_files' \
  '(-i --update-interval)'{-i,--update-interval}'+[update interval]:sec:' \
  '(-m --mode)'{-m,--mode}'+[start mode]:mode:(1 2 3 4 5)' \
  '(-n --read-only)'{-n,--read-only}'[read-only mode]' \
  '(-r --command)'{-r,--command}'+[send command]:cmd:' \
  '(-S --hide-state)'{-S,--hide-state}'[hide global state]' \
  '(-c --no-color)'{-c,--no-color}'[disable colors]' && ret=0

return ret
