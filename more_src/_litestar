#compdef litestar

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'info:show information about the detected Litestar app'
  'routes:display information about routes'
  'run:run a Litestar application'
  'schema:OpenAPI schema management'
  'sessions:server-side session management'
  'version:show installed Litestar version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--app=[app import string]:app:' \
  '--app-dir=[app directory]:dir:_files -/' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'litestar subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-r --reload)'{-r,--reload}'[enable auto-reload]' \
          '*'{-R,--reload-dir=}'[reload watch directory]:dir:_files -/' \
          '*'{-I,--reload-include=}'[reload include glob]:glob:' \
          '*'{-E,--reload-exclude=}'[reload exclude glob]:glob:' \
          '(-p --port)'{-p,--port=}'[bind port]:port:' \
          '(-W --wc --web-concurrency)'{-W,--wc=,--web-concurrency=}'[worker count]:n:' \
          '(-H --host)'{-H,--host=}'[bind host]:host:_hosts' \
          '(-F --fd --file-descriptor)'{-F,--fd=,--file-descriptor=}'[file descriptor]:fd:' \
          '(-U --uds --unix-domain-socket)'{-U,--uds=,--unix-domain-socket=}'[unix domain socket]:socket:_files' \
          '(-d --debug)'{-d,--debug}'[enable debug]' \
          '(-P --pdb --use-pdb)'{-P,--pdb,--use-pdb}'[drop into pdb on error]' \
          '--ssl-certfile=[SSL cert file]:file:_files' \
          '--ssl-keyfile=[SSL key file]:file:_files' \
          '--create-self-signed-cert[create self-signed cert]' && ret=0
        ;;
      (routes)
        _arguments \
          '--schema[show schema]' \
          '*--exclude=[exclude routes]:pattern:' && ret=0
        ;;
      (schema)
        _values 'schema action' 'openapi' 'typescript' && ret=0
        ;;
      (sessions)
        _values 'sessions action' 'clear' 'delete' && ret=0
        ;;
      (version)
        _arguments \
          '(-s --short)'{-s,--short}'[short version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
