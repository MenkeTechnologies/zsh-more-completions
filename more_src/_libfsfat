#compdef fsfatinfo fsfatmount
# _libfsfat — libfsfat tools (libyal FAT12 / FAT16 / FAT32 / exFAT parser; fsfatinfo dumps boot sector + FAT chain metadata, fsfatmount FUSE-mounts the filesystem read-only; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E entry filter, -F path filter, -X exclusive; positional argument is the FAT image)
# upstream: https://github.com/libyal/libfsfat
# Flags from libyal/libfsfat fsfattools/fsfatinfo.c on tip.

_libfsfat() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[entry filter]:entry:' \
        '-F+[path filter]:path:' \
        '-X[exclusive]' \
        '*:FAT image:_files'
}

_libfsfat "$@"
