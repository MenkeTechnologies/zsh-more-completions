#compdef cloudfox
# Documentation: https://github.com/BishopFox/cloudfox
# Reference accessed: 2026-05-17
# Verified: BishopFox/cloudfox upstream cmd/aws/, cmd/azure/, cmd/gcp/
# subcommand surface and global flag set (-o/--output, --outdir,
# --wrap, --verbosity, --quiet, --continue-on-error).
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a providers

providers=(
  'aws:Amazon Web Services commands'
  'azure:Azure commands'
  'gcp:Google Cloud Platform commands'
  'kubernetes:Kubernetes commands'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-o+[output format]:format:(brief table json csv all wide)' \
  '--output=[output format]:format:(brief table json csv all wide)' \
  '--outdir=[output directory]:dir:_files -/' \
  '--wrap[wrap table output to terminal width]' \
  '--verbosity=[verbosity level]:n:(1 2 3)' \
  '--quiet[quiet output]' \
  '--continue-on-error[continue on errors]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cloudfox provider' providers && ret=0 ;;
  (args)
    case $line[1] in
      (aws)
        local -a aws_subs=(
          'all-checks:run all AWS checks'
          'access-keys:enumerate access keys'
          'api-gw:enumerate API Gateway'
          'buckets:enumerate S3 buckets'
          'cape:cloud attack path enumeration'
          'cloudformation:enumerate CloudFormation stacks'
          'codebuild:enumerate CodeBuild'
          'databases:enumerate RDS/DynamoDB'
          'ecr:enumerate ECR'
          'ecs-tasks:enumerate ECS tasks'
          'eks:enumerate EKS clusters'
          'elastic-network-interfaces:enumerate ENIs'
          'endpoints:enumerate exposed endpoints'
          'env-vars:enumerate env vars'
          'filesystems:enumerate EFS'
          'iam-simulator:simulate IAM'
          'instances:enumerate EC2 instances'
          'inventory:enumerate inventory'
          'lambda:enumerate Lambda'
          'network-ports:enumerate open network ports'
          'orgs:enumerate AWS Organizations'
          'outbound-assumed-roles:list assumed roles'
          'permissions:enumerate IAM permissions'
          'pmapper:wrap pmapper'
          'principals:enumerate principals'
          'ram:enumerate Resource Access Manager'
          'role-trusts:enumerate role trusts'
          'route53:enumerate Route53'
          'secrets:enumerate Secrets Manager / SSM secrets'
          'sns:enumerate SNS topics'
          'sqs:enumerate SQS queues'
          'tags:enumerate tags'
          'workloads:enumerate workloads'
          'whoami:show current AWS principal'
        )
        _describe -t awscmds 'aws subcommand' aws_subs && ret=0
        _arguments \
          '(-p --profile)'{-p+,--profile=}'[AWS profile]:profile:' \
          '(-l --profile-list)'{-l+,--profile-list=}'[file with profile list]:file:_files' \
          '(-a --all-profiles)'{-a,--all-profiles}'[run on all profiles]' \
          '*--region=[AWS region]:region:' \
          '--cape-jobs=[concurrent jobs]:n:' \
          '--cape-admin-only[only check admin actions]' && ret=0 ;;
      (azure)
        local -a azure_subs=(
          'whoami:show current Azure context'
          'inventory:enumerate inventory'
          'rbac:enumerate RBAC role assignments'
          'storage:enumerate storage accounts'
          'vms:enumerate virtual machines'
        )
        _describe -t azcmds 'azure subcommand' azure_subs && ret=0
        _arguments \
          '(-s --subscription)'{-s+,--subscription=}'[subscription id]:id:' \
          '(-t --tenant)'{-t+,--tenant=}'[tenant id]:id:' \
          '(-r --resource-group)'{-r+,--resource-group=}'[resource group]:rg:' && ret=0 ;;
      (gcp)
        local -a gcp_subs=(
          'whoami:show current GCP context'
          'inventory:enumerate inventory'
          'instances:enumerate Compute Engine instances'
          'buckets:enumerate GCS buckets'
          'secrets:enumerate Secret Manager secrets'
        )
        _describe -t gcpcmds 'gcp subcommand' gcp_subs && ret=0
        _arguments \
          '--project=[GCP project]:project:' \
          '--folder=[GCP folder]:folder:' \
          '--organization=[GCP organization]:org:' && ret=0 ;;
      (kubernetes)
        _arguments '*::sub:(pods secrets services)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
