#compdef suswapbytes
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/data_conversion/suswapbytes.c
# SUSWAPBYTES - swap the bytes in SU data to convert endian byte order

local ret=1

_arguments -s -S \
  'format=[0 foreign to native, 1 native to foreign]:f:(0 1)' \
  'swaphdr=[1 swap header byte order, 0 leave]:s:(0 1)' \
  'swapdata=[1 swap data byte order, 0 leave]:s:(0 1)' \
  'ns=[samples per trace if not set in header]:n:' \
  '*:SU file:_files' && ret=0

return ret
