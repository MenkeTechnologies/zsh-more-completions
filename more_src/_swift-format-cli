#compdef swift-format-cli
# _swift-format-cli — Apple swift-format Swift code formatter CLI alias (Apple, Swift); custom argparse
# upstream: https://github.com/apple/swift-format

_swift-format-cli() {
    local -a sub=(
        'format:format Swift source code'
        'lint:lint Swift source code'
        'dump-configuration:print effective config'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--configuration=+[config file]:file:_files -g ".swift-format *.json"' \
        '--in-place[edit files in place]' \
        '-i[edit files in place]' \
        '--recursive[recursive]' \
        '-r[recursive]' \
        '--ignore-unparsable-files[ignore unparsable files]' \
        '--parallel[parallel]' \
        '-p[parallel]' \
        '--no-color-diagnostics[no color diagnostics]' \
        '--color-diagnostics[color diagnostics]' \
        '--strict[strict]' \
        '-s[strict]' \
        '--debug-print-cumulative-tokens[debug print cumulative tokens]' \
        '--debug-print-token-stream[debug print token stream]' \
        '--debug-disable-pretty-print[debug disable pretty print]' \
        '--debug-dump-token-stream[debug dump token stream]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swift-format subcommand' sub ;;
        args)
            case $words[1] in
                format) _arguments \
                    '--in-place[in place]' \
                    '-i[in place]' \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '--parallel[parallel]' \
                    '-p[parallel]' \
                    '*:file:_files -g "*.swift"' ;;
                lint) _arguments \
                    '--strict[strict]' \
                    '-s[strict]' \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '--parallel[parallel]' \
                    '-p[parallel]' \
                    '*:file:_files -g "*.swift"' ;;
                dump-configuration) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_swift-format-cli "$@"
