#compdef pyinstrument

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[run library module as script]:module' \
  '-c+[program passed in as string]:code' \
  '-o+[save report to file]:output file:_files' \
  '--outfile=[save report to file]:output file:_files' \
  '-r+[renderer]:renderer:(html json pstats speedscope text)' \
  '--renderer=[renderer]:renderer:(html json pstats speedscope text)' \
  '--html[render output as HTML]' \
  '--json[render output as JSON]' \
  '-t[render output as text]' \
  '--text[render output as text]' \
  '--pstats[render output as pstats]' \
  '-p+[path to filter to]:path' \
  '--show=[control what is shown]:filter:(all standard library application)' \
  '--show-all[show all frames]' \
  '--hide=[hide functions matching]:pattern' \
  '--hide-regex=[hide functions matching regex]:regex' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--timeline[show timeline]' \
  '--from-path=[read profiling data from file]:file:_files' \
  '--interval=[profiling interval in seconds]:interval' \
  '--async-mode=[async mode]:mode:(enabled disabled strict)' \
  '*:script:_files -g "*.py"' && ret=0

return ret
