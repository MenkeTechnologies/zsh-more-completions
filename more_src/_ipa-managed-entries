#compdef ipa-managed-entries
# Documentation: https://www.mankier.com/1/ipa-managed-entries
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-p --password)'{-p,--password}'+[password]:pw:' \
  '(-D --binddn)'{-D,--binddn}'+[bind DN]:dn:' \
  '(--list)--list[list entries]' \
  '1:command:(enable disable status)' \
  '*:entry:' && ret=0

return ret
