#compdef crank
# Documentation: https://docs.crossplane.io/latest/cli/command-reference/
# Crossplane CLI (crank binary) for working with Crossplane packages and control planes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--config=[path to the crossplane CLI configuration file]:file:_files' \
  '--verbose[print verbose logging statements]' \
  '*:command:((
    cluster\:"inspect a Crossplane cluster"
    completions\:"get shell completions"
    composition\:"work with Crossplane Compositions"
    config\:"view and update CLI configuration file"
    dependency\:"manage dependencies of control plane Projects"
    function\:"work with functions in control plane Projects"
    operation\:"work with Crossplane Operations"
    project\:"work with control plane Projects"
    resource\:"work with Crossplane resources"
    version\:"print client and server version information"
    xpkg\:"work with Crossplane packages"
    xrd\:"work with Composite Resource Definitions"
  ))' && ret=0

return ret
