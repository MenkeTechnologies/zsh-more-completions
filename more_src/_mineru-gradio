#compdef mineru-gradio
# Documentation: https://opendatalab.github.io/MinerU/usage/cli_tools/
# Start a Gradio web UI for MinerU PDF parsing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--enable-example=[enable example files]:bool:(true false)' \
  '--max-convert-pages=[maximum pages to convert]:pages:' \
  '--server-name=[server name to bind]:name:' && ret=0

return ret
