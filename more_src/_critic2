#compdef critic2
# Documentation: https://aoterodelaroza.github.io/critic2/manual/
# critic2 — analysis of quantum-chemical interactions in molecules and solids

local ret=1

_arguments -s -S \
  '-h[print a short help message and exit]' \
  '-q[quiet: inhibit initial and final messages]' \
  '-t[run the tests only]' \
  '-r[path where critic2 finds its data files]:data path:_directories' \
  '::input file:_files' \
  '::output file:_files' && ret=0

return ret
