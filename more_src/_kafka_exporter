#compdef kafka_exporter
# Documentation: https://github.com/danielqsj/kafka_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*--kafka.server=[address of Kafka server]:address:' \
  '--sasl.enabled[connect using SASL/PLAIN]' \
  '--sasl.handshake[enable SASL handshake]' \
  '--sasl.username=[SASL user name]:username:' \
  '--sasl.password=[SASL user password]:password:' \
  '--sasl.mechanism=[SASL mechanism]:mechanism:(plain scram-sha256 scram-sha512)' \
  '--tls.enabled[connect to Kafka using TLS]' \
  '--tls.ca-file=[TLS CA file]:file:_files' \
  '--tls.cert-file=[TLS certificate file]:file:_files' \
  '--tls.key-file=[TLS key file]:file:_files' \
  '--tls.insecure-skip-tls-verify[skip TLS certificate verification]' \
  '--topic.filter=[regex to filter topics to collect]:regexp:' \
  '--topic.exclude=[regex to exclude topics from collection]:regexp:' \
  '--group.filter=[regex to filter consumer groups to collect]:regexp:' \
  '--group.exclude=[regex to exclude consumer groups from collection]:regexp:' \
  '--use.consumelag.zookeeper[use Zookeeper to calculate consumer lag]' \
  '*--zookeeper.server=[address of Zookeeper server]:address:' \
  '--kafka.version=[Kafka broker version]:version:' \
  '--offset.show-all[show all consumer group offsets including empty ones]' \
  '--concurrent.enable[enable concurrent topic fetching]' \
  '--topic.workers=[number of topic workers]:count:' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--log.sarama[enable Sarama logging]' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
