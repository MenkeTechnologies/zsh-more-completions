#compdef rolldown

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[path to configuration file]:file:_files' \
  '--config=[path to configuration file]:file:_files' \
  '-d+[output directory]:directory:_directories' \
  '--dir=[output directory]:directory:_directories' \
  '--format=[output format]:format:(es cjs iife umd)' \
  '--sourcemap=[generate source map]:sourcemap:(true false inline hidden)' \
  '-w[watch files for changes and rebuild]' \
  '--watch[watch files for changes and rebuild]' \
  '--minify[enable minification]' \
  '*--external=[external modules]:module' \
  '--platform=[target platform]:platform:(browser node neutral)' \
  '*--define=[define global constants]:key=value' \
  '*:input files:_files' && ret=0

return ret
