#compdef rolldown
# Documentation: https://rolldown.rs/apis/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-d --dir)'{-d+,--dir=}'[output directory]:directory:_directories' \
  '(-o --file)'{-o+,--file=}'[single output file]:file:_files' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(esm cjs iife)' \
  '(-n --name)'{-n+,--name=}'[name for UMD/IIFE outputs]:name' \
  '(-m --minify)'{-m,--minify}'[minify output]' \
  '(-s --sourcemap)'{-s+,--sourcemap=}'[sourcemap mode]:mode:(true false inline hidden)' \
  '(-e --external)*'{-e+,--external=}'[external modules]:module' \
  '(-g --globals)*'{-g+,--globals=}'[global variable mapping]:key:value' \
  '(-w --watch)'{-w,--watch}'[rebuild on file changes]' \
  '(-p --platform)'{-p+,--platform=}'[target platform]:platform:(node browser neutral)' \
  '*--environment=[process.env settings]:key:value' \
  '--cwd=[working directory]:dir:_directories' \
  '--tsconfig=[tsconfig.json path]:file:_files' \
  '*:input files:_files' && ret=0

return ret
