#compdef dalton
# Documentation: https://docs.hpc2n.umu.se/software/apps/Dalton/
# Run-script for the Dalton quantum chemistry program (.dal + .mol input)

local ret=1

_arguments -s -S \
  '-h[show help and list of options]' \
  '-b[prepend directory to the basis set search path]:directory:_files -/' \
  '-mb[max usable work memory in megabytes]:megabytes' \
  '-N[number of MPI processes]:processes' \
  '-omp[number of OpenMP threads]:threads' \
  '-o[redirect DALTON.OUT to filename in WRKDIR]:output file:_files' \
  '-w[set the working directory]:wrkdir:_files -/' \
  '-f[extract dal_mol[_pot].tar.gz archive before the run]:archive base' \
  '-get[retrieve listed files after the calculation]:file list' \
  '-put[copy listed files into the scratch directory]:file list' \
  '-noarch[do not create the .tar.gz archive of results]' \
  '-ow[overwrite existing output without renaming]' \
  '*:dalton input file:_files -g "*.dal"' && ret=0

return ret
