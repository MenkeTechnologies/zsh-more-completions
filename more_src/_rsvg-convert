#compdef rsvg-convert
# Documentation: rsvg-convert --help (librsvg)
# Source: librsvg rsvg-convert — convert SVG to PNG / PDF / PS / EPS / SVG.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-d --dpi-x)'{-d,--dpi-x=}'[X pixels per inch (default 96)]:dpi:' \
    '(-p --dpi-y)'{-p,--dpi-y=}'[Y pixels per inch (default 96)]:dpi:' \
    '(-x --x-zoom)'{-x,--x-zoom=}'[horizontal zoom factor]:n:' \
    '(-y --y-zoom)'{-y,--y-zoom=}'[vertical zoom factor]:n:' \
    '(-z --zoom)'{-z,--zoom=}'[uniform zoom factor]:n:' \
    '(-w --width)'{-w,--width=}'[output width]:length:' \
    '(-h --height)'{-h,--height=}'[output height]:length:' \
    '--top=[distance between top edge and image]:length:' \
    '--left=[distance between left edge and image]:length:' \
    '--page-width=[output media width]:length:' \
    '--page-height=[output media height]:length:' \
    '(-f --format)'{-f,--format=}'[output format]:format:(png pdf pdf1.7 pdf1.6 pdf1.5 pdf1.4 ps eps svg)' \
    '(-o --output)'{-o,--output=}'[output filename]:file:_files' \
    '(-i --export-id)'{-i,--export-id=}'[SVG id to export]:id:' \
    '(-l --accept-language)'{-l,--accept-language=}'[language tags (e.g. es-MX,de,en)]:tags:' \
    '(-a --keep-aspect-ratio)'{-a,--keep-aspect-ratio}'[preserve aspect ratio]' \
    '(-b --background-color)'{-b,--background-color=}'[CSS background color]:color:' \
    '(-s --stylesheet)'{-s,--stylesheet=}'[CSS stylesheet file]:file:_files -g "*.css"' \
    '(-u --unlimited)'{-u,--unlimited}'[allow huge SVG files]' \
    '(--keep-image-data --no-keep-image-data)--keep-image-data[keep image data]' \
    '(--keep-image-data --no-keep-image-data)--no-keep-image-data[do not keep image data]' \
    '(- *)--completion=[print shell completion]:shell:(bash elvish fish powershell zsh)' \
    '*:SVG file:_files -g "*.svg"' \
    && ret=0

return ret
