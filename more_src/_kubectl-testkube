#compdef kubectl-testkube testkube

# Zsh completion for Testkube kubectl plugin (tensorchord upstream layout)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--client=[API transport]:mode:(proxy direct cluster)' \
  '--namespace=[Kubernetes namespace]:ns' \
  '--verbose[debug logging]' \
  '--api-uri=[Testkube API base URL]:uri' \
  '--insecure[allow insecure TLS for direct client]' \
  '*--header=[extra HTTP headers for direct client]:header' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      create update get set run delete abort cancel enable disable status download generate init
      upgrade purge watch dashboard view migrate version config debug diagnostics create-ticket
      agent cloud pro mcp docker marketplace login install devbox
    )
    _describe -t commands 'kubectl-testkube command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
