#compdef gauge

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add a non-language plugin'
  'daemonize:run as a daemon'
  'docs:generate documentation using a plugin'
  'format:format spec files'
  'help:help about any command'
  'init:initialize project structure'
  'install:download and install a plugin'
  'list-templates:list available templates'
  'refactor:refactor steps'
  'run:run specs'
  'uninstall:uninstall a plugin'
  'update:update a plugin'
  'validate:check validation/parse errors'
  'version:print versions'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--log-level=[log level]:level:(debug info warning error critical)' \
  '--dir=[project directory]:dir:_files -/' \
  '--verbose[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'gauge subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-p --parallel)'{-p,--parallel}'[run in parallel]' \
          '-n[number of parallel streams]:count:' \
          '(-g --group)'{-g,--group=}'[execution group]:n:' \
          '--env=[environment]:name:' \
          '--tags=[tag expression]:expr:' \
          '--strategy=[parallel strategy]:strategy:(eager lazy)' \
          '--table-rows=[table row range]:range:' \
          '--simple-console[simple console output]' \
          '(-s --sort)'{-s,--sort}'[sort spec files]' \
          '*:specs:_files' && ret=0
        ;;
      (install|update|uninstall)
        _arguments \
          '--plugin-version=[plugin version]:version:' \
          '(-f --file)'{-f,--file=}'[plugin archive]:file:_files' && ret=0
        ;;
      (init)
        _arguments ':template:' && ret=0
        ;;
      (format|validate|refactor)
        _arguments '*:specs:_files' && ret=0
        ;;
      (docs)
        _arguments \
          '*:plugin:' \
          '*:specs:_files' && ret=0
        ;;
      (daemonize)
        _arguments '--api-port=[API port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
