#compdef ibmcloud

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'login:log in to IBM Cloud'
  'logout:log out of IBM Cloud'
  'target:set target account/region/resource-group'
  'api:set API endpoint'
  'config:configure CLI'
  'account:manage IBM Cloud account'
  'iam:identity and access management'
  'resource:manage resources and resource groups'
  'catalog:browse and search the catalog'
  'app:Cloud Foundry application commands'
  'cf:Cloud Foundry CLI passthrough'
  'service:Cloud Foundry service commands'
  'plugin:plugin management'
  'dev:developer tools'
  'cs:Container Service / Kubernetes (alias for ks)'
  'ks:Kubernetes Service / IKS commands'
  'oc:OpenShift commands'
  'cr:Container Registry commands'
  'is:VPC Infrastructure Services'
  'sl:Classic Infrastructure (SoftLayer)'
  'cdb:Cloud Databases commands'
  'cm:Cloud Manager commands'
  'fn:IBM Cloud Functions / OpenWhisk'
  'code-engine:Code Engine commands'
  'ce:Code Engine alias'
  'es:Event Streams (Kafka)'
  'kp:Key Protect commands'
  'project:IBM Cloud Project'
  'schematics:Schematics (Terraform-as-a-Service)'
  'sat:Satellite commands'
  'enterprise:enterprise account management'
  'billing:billing and usage'
  'support:support cases'
  'tg:Transit Gateway'
  'dns:DNS Services'
  'cis:Cloud Internet Services'
  'logging:logging service'
  'monitoring:monitoring service'
  'cdn:Content Delivery Network'
  'ml:Machine Learning'
  'pi:Power Systems Virtual Server'
  'help:show help'
  'version:show CLI version'
  'feedback:send feedback'
  'completion:generate shell completion'
  'doi:DevOps Insights'
  'auth:authentication'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--quiet[suppress non-essential output]' \
  '--no-color[disable colored output]' \
  '--http-timeout=[HTTP timeout in seconds]:secs:' \
  '--trace=[enable trace]:value:(true false FILEPATH)' \
  '-c+[target account]:account-id:' \
  '-g+[resource group]:group:' \
  '-r+[region]:region:' \
  '*--output=[output format]:format:(JSON YAML)' \
  '--debug[enable debug output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ibmcloud subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          {-a+,--apiendpoint=}'[API endpoint]:endpoint:' \
          {-u+,--user=}'[username]:user:_users' \
          {-p+,--password=}'[password]:password:' \
          '--apikey=[API key string or @file]:apikey:' \
          '--sso[single sign-on]' \
          '--no-region[skip region prompt]' \
          {-c+,--account=}'[account ID]:account-id:' \
          {-g+,--resource-group=}'[resource group]:group:' \
          {-r+,--region=}'[region]:region:' \
          '--profile=[profile name]:profile:' \
          '--no-iam[do not use IAM tokens]' && ret=0
        ;;
      (target)
        _arguments \
          {-a+,--accountid=}'[account ID]:account:' \
          {-c+,--cf-account=}'[CF account]:account:' \
          {-o+,--org=}'[CF organization]:org:' \
          {-s+,--space=}'[CF space]:space:' \
          {-g+,--resource-group=}'[resource group]:group:' \
          {-r+,--region=}'[region]:region:' \
          '--cf[also target CF org/space]' \
          '--no-region[unset region]' && ret=0
        ;;
      (account)
        _values 'account action' \
          'list' 'show' 'users' 'orgs' 'org-members' 'org-member-invite' \
          'org-member-remove' 'show-by-id' 'user-invite' 'user-remove' \
          'enterprise-show' 'switch' 'cluster-list' 'invitations' && ret=0
        ;;
      (iam)
        _values 'iam action' \
          'access-groups' 'access-group' 'access-group-create' 'access-group-delete' \
          'access-group-policies' 'access-group-policy-create' 'api-keys' 'api-key-create' \
          'api-key-delete' 'api-key-update' 'authorization-policies' \
          'oauth-tokens' 'roles' 'service-id' 'service-id-create' 'service-id-delete' \
          'service-policies' 'service-policy-create' 'trusted-profiles' 'users' && ret=0
        ;;
      (resource)
        _values 'resource action' \
          'groups' 'group' 'group-create' 'group-update' 'service-instances' \
          'service-instance-create' 'service-instance-delete' 'service-instance-update' \
          'service-keys' 'service-key' 'service-key-create' 'service-key-delete' \
          'service-aliases' 'service-alias-create' 'reclamations' 'tags' && ret=0
        ;;
      (ks|cs)
        _values 'kubernetes action' \
          'cluster-create' 'cluster-rm' 'cluster-ls' 'cluster-config' 'cluster-get' \
          'worker-pools' 'worker-pool-create' 'worker-pool-rebalance' 'worker-add' \
          'worker-rm' 'workers' 'worker-get' 'cluster-update' 'cluster-addons' \
          'cluster-addon-enable' 'cluster-addon-disable' 'alb-list' 'alb-configure-classic' \
          'alb-update' 'volume' 'storage-attachment' 'cluster-master-refresh' \
          'enable-vpa' 'logging-config-create' 'logging-config-rm' 'subnets' && ret=0
        ;;
      (catalog)
        _values 'catalog action' \
          'search' 'service-marketplace' 'service' 'service-show' 'service-plans' \
          'iaas-targeting' 'asset' 'private-catalog' 'utility' && ret=0
        ;;
      (plugin)
        _values 'plugin action' \
          'install' 'uninstall' 'update' 'list' 'repos' 'repo-add' 'repo-remove' \
          'repo-plugins' 'show' 'reset-data' && ret=0
        ;;
      (cr)
        _values 'cr action' \
          'login' 'logout' 'image-list' 'image-rm' 'image-tag' 'images' \
          'images-rm' 'namespace-add' 'namespace-rm' 'namespaces' 'quota' 'token-add' \
          'token-rm' 'tokens' 'plan' 'region-set' 'retention-policy-list' \
          'retention-policy-set' 'vulnerability-assessment' 'webhook-create' 'webhooks' && ret=0
        ;;
      (fn)
        _values 'functions action' \
          'action' 'activation' 'list' 'namespace' 'package' 'rule' \
          'trigger' 'property' 'sdk' 'web' && ret=0
        ;;
      (cf)
        _values 'cf passthrough' 'apps' 'app' 'push' 'restart' 'logs' 'env' 'set-env' \
          'unset-env' 'create-service' 'delete-service' 'services' 'bind-service' \
          'unbind-service' 'spaces' 'orgs' 'target' 'login' 'logout' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'fish' 'zsh' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
