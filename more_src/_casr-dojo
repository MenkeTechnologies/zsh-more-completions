#compdef casr-dojo
# Documentation: https://github.com/ispras/casr/blob/master/docs/usage.md
# Upload new and unique CASR reports to DefectDojo

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-l --log-level)'{-l,--log-level}'=[logging level]:level:(info debug)' \
  '(-u --url)'{-u,--url}'=[DefectDojo base URL]:url' \
  '(-t --token)'{-t,--token}'=[DefectDojo API key]:token' \
  '(-i --input)'{-i,--input}'=[directory searched for CASR reports]:dir:_files -/' \
  '*:params:_files' && ret=0

return ret
