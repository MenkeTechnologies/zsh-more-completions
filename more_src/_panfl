#compdef panfl
# Documentation: https://scorreia.com/software/panflute/guide.html
# panfl: run Python panflute filters as a Pandoc filter

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '(-w -t --write --to)'{-w+,-t+,--write=,--to=}'[output format passed to Pandoc]:format:' \
  '*'{-d+,--dir=}'[search filters in the given directory]:dir:_files -/' \
  '--data-dir[search filters in the default user data directory]' \
  '--no-sys-path[disable searching filters in Python sys.path]' \
  '*:filter:_files' && ret=0

return ret
