#compdef google-chrome google-chrome-stable google-chrome-beta google-chrome-unstable chrome

# Zsh completion for Google Chrome browser

_arguments -s -S \
  '--version[show version]' \
  '--help[show help]' \
  '--new-window[launch URL in new window]' \
  '--incognito[launch in incognito mode]' \
  '--guest[launch in guest mode]' \
  '--app=[launch as app in its own window]:url:' \
  '--app-id=[launch a specific app]:app id:' \
  '--user-data-dir=[directory where browser data is stored]:directory:_files -/' \
  '--profile-directory=[profile sub-directory inside user-data-dir]:name:' \
  '--kiosk[launch in kiosk mode]' \
  '--headless[run without a visible window]' \
  '--disable-gpu[disable GPU hardware acceleration]' \
  '--no-sandbox[disable the sandbox (use with caution)]' \
  '--proxy-server=[specify proxy server]:proxy:' \
  '--proxy-bypass-list=[specify hosts for which to bypass proxy]:list:' \
  '--proxy-auto-detect[autodetect the proxy configuration]' \
  '--proxy-pac-url=[use a PAC file at the given URL]:url:' \
  '--user-agent=[specify user agent]:user-agent:' \
  '--window-size=[specify window size]:width,height:' \
  '--window-position=[specify window position]:x,y:' \
  '--window-name=[specify window name]:name:' \
  '--start-maximized[start window maximized]' \
  '--start-fullscreen[start window in fullscreen mode]' \
  '--disable-web-security[disable same-origin policy (use with caution)]' \
  '--allow-file-access-from-files[allow file access from files]' \
  '--remote-debugging-port=[enable remote debugging on port]:port:' \
  '--remote-debugging-address=[address to use for remote debugging]:address:' \
  '--disable-extensions[disable extensions]' \
  '--load-extension=[load extension from directory]:directory:_files -/' \
  '--disable-plugins[disable all plugins]' \
  '--enable-logging[enable logging]' \
  '--v=[verbose logging level]:level:(0 1 2 3)' \
  '--log-net-log=[log network events to file]:file:_files' \
  '--lang=[language]:lang:' \
  '--disable-background-networking[disable several subsystems which perform network requests in the background]' \
  '--disable-default-apps[disable installation of default apps]' \
  '--disable-sync[disable syncing to Google account]' \
  '--disable-translate[disable the translation feature]' \
  '--enable-features=[enable features]:features:' \
  '--disable-features=[disable features]:features:' \
  '--dump-dom[dump the DOM tree after page load]' \
  '--print-to-pdf=[print to PDF file]:file:_files' \
  '--screenshot=[take screenshot to file]:file:_files' \
  '--virtual-time-budget=[virtual time budget in ms]:ms:' \
  '*:URL or file:_files'
