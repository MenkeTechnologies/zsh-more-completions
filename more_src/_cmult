#compdef cmult
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss22.html
# KAPPA CMULT - multiply an NDF by a scalar

local ret=1

_arguments -C \
  'IN=[input NDF whose pixels are multiplied]:NDF file:_files' \
  'OUT=[output NDF data structure]:NDF file:_files' \
  'SCALAR=[value by which pixels are multiplied]:value:' \
  'TITLE=[title for the output NDF]:title:' \
  '*:NDF file:_files' && ret=0

return ret
