#compdef kubectl-exec-as
# Documentation: https://github.com/jordanwilson230/kubectl-plugins/blob/krew/kubectl-exec-as
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Bash plugin; single-dash
# getopts-style flags only.

_arguments -s -S \
  '-h[show usage]' \
  '-d[enable debug mode (trace each command)]' \
  '-n+[namespace scope for this request]:namespace:' \
  '-u+[username or UID (name|uid[:group|gid])]:user:' \
  '-c+[container name (defaults to first container)]:container:' \
  '*:pod name and command:_default'
