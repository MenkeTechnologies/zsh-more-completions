#compdef kubectl-exec-as
# Documentation: https://github.com/jordanwilson230/kubectl-plugins/blob/krew/kubectl-exec-as
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:pod and command:_default'
