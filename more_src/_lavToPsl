#compdef lavToPsl
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert a blastz lav file to PSL format

local ret=1

_arguments -s -S \
  '-target-strand=[set the target strand to c (default is no strand)]:c' \
  '-bed[output bed instead of psl]' \
  '-scoreFile=[output lav scores to a side file, one score per psl line]:file:_files' \
  '1:input lav:_files -g "*.lav"' \
  '2:output psl:_files -g "*.psl"' && ret=0

return ret
