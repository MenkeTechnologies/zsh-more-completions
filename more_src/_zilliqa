#compdef zilliqa
# _zilliqa — Zilliqa Research zilliqa node binary for the sharded high-throughput Zilliqa blockchain (Zilliqa team, C++); custom argparse
# upstream: https://github.com/Zilliqa/Zilliqa

_zilliqa() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--privk=+[private key]:str:' \
        '-i+[private key]:str:' \
        '--pubk=+[public key]:str:' \
        '-u+[public key]:str:' \
        '--address=+[ip address]:host:_hosts' \
        '-a+[ip address]:host:_hosts' \
        '--port=+[node port]:port:_ports' \
        '-p+[node port]:port:_ports' \
        '--loadconfig=+[config file]:file:_files -g "*.xml"' \
        '-l+[config file]:file:_files -g "*.xml"' \
        '--synctype=+[sync type]:s:(0 1 2 3 4 5 6 7)' \
        '-s+[sync type]:s:(0 1 2 3 4 5 6 7)' \
        '--nodetype=+[type]:t:(normal lookup seed dsguard newlookup level2lookup)' \
        '-n+[type]:t:(normal lookup seed dsguard newlookup level2lookup)' \
        '--logpath=+[log path]:dir:_files -/' \
        '--recovery[recovery mode]' \
        '-r[recovery mode]' \
        '--singleton[singleton mode]' \
        '--no-validate[skip validation]' \
        '--server-port=+[rpc port]:port:_ports' \
        '--ws-server-port=+[ws port]:port:_ports' \
        '--persistencepath=+[persistence dir]:dir:_files -/' \
        '--get-network-historical-db=+[bool]:b:(true false)' \
        '--auto-recover[auto recover]' \
        '--evm-port=+[evm port]:port:_ports'
}

_zilliqa "$@"
