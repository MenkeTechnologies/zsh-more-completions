#compdef ttysnoop ttysnoop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/ttysnoop.py argparse)
# Reference accessed: 2026-05-29
# ttysnoop — observe a TTY in real time by tracing writes to the tty driver (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --noclear)'{-C,--noclear}'[do not clear the screen]' \
  '(-s --datasize)'{-s,--datasize=}'[size of the transmitting buffer (default 256)]:bytes:' \
  '(-c --datacount)'{-c,--datacount=}'[number of times to check for data (default 16)]:N:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:device (e.g. /dev/tty0, /dev/pts/N, or pts number):_files -g "/dev/(tty*|pts/*)"' \
  && ret=0

return ret
