#compdef dmstat
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmstat.html
# Compute statistics of an image or table column

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input stack of files]:infile:_files' \
  'centroid=[calculate centroid of image]:centroid:(yes no)' \
  'median=[calculate median value]:median:(yes no)' \
  'sigma=[calculate population standard deviation]:sigma:(yes no)' \
  'clip=[calculate stats using sigma clipping]:clip:(yes no)' \
  'nsigma=[number of sigma to clip]:nsigma:' \
  'maxiter=[maximum number of iterations]:maxiter:' \
  'verbose=[verbosity level]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
