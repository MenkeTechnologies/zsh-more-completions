#compdef cosmic-greeter
# Documentation: https://github.com/pop-os/cosmic-greeter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cosmic-greeter (COSMIC desktop greeter for greetd).
# The binary is normally launched by greetd; no documented user-facing flags
# beyond standard --help / --version.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0

return ret
