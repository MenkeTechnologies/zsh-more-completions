#compdef bsvd bitcoinsvd bitcoin-svd
# _bsvd — Bitcoin SV bsvd daemon CLI for the Bitcoin SV Node implementation running a full node maintaining the unbounded-block original-Satoshi-protocol blockchain validating transactions network sync STN scaling test net RPC API mining (bitcoin-sv team, C++); custom argparse
# upstream: https://github.com/bitcoin-sv/bitcoin-sv

_bsvd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf bitcoin.conf bsv.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-daemon[run as daemon]' \
        '-pid=+[file]:file:_files' \
        '-testnet[use testnet]' \
        '-stn[use STN scaling test network]' \
        '-regtest[use regtest]' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb minerid all)' \
        '-loglevel=+[level]:l:(info debug trace)' \
        '-shrinkdebugfile[shrink debug]' \
        '-logips[log IPs]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserver[enable RPC server]' \
        '-rpcwait[wait for RPC server]' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-blocksonly[only blocks]' \
        '-maxconnections=+[N]:n:' \
        '-excessiveblocksize=+[bytes]:n:' \
        '-maxstackmemoryusageconsensus=+[bytes]:n:' \
        '-maxstackmemoryusagepolicy=+[bytes]:n:' \
        '-maxscriptsizepolicy=+[bytes]:n:' \
        '-maxscriptnumlengthpolicy=+[bytes]:n:' \
        '-maxopsperscriptpolicy=+[N]:n:' \
        '-maxpubkeyspermultisigpolicy=+[N]:n:' \
        '-genesisactivationheight=+[N]:n:' \
        '-paytxfee=+[BSV/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[file]:file:_files' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:' \
        '-zmqpubhashblock=+[address]:str:' \
        '-zmqpubhashtx=+[address]:str:' \
        '-minerid_enabled[enable minerid]'
}

_bsvd "$@"
