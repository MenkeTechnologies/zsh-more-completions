#compdef ldns-rrsig
# Documentation: https://www.systutorials.com/docs/linux/man/1-ldns-rrsig/
# Reference accessed: 2026-05-19
# Verified: upstream ldns-rrsig(1) manpage (no options; takes domain and optional type).

# ldns-rrsig: print RRSIG inception and expiration dates
local curcontext="$curcontext" ret=1

_arguments -C \
  '1:domain:' \
  '2:type:(A AAAA NS MX CNAME PTR TXT SOA SRV DNSKEY DS RRSIG NSEC NSEC3)' && ret=0

return ret
