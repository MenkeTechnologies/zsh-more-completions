#compdef c2048
# Documentation: https://github.com/mevdschee/2048.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# c2048 - terminal 2048 game (downstream-packaged name; upstream binary is "2048").
# Upstream accepts an optional color-scheme argument plus --version / --help / "test".

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:argument:(blackwhite whiteblack bluered test)'
