#compdef sfzomig
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mzomig.c
# Madagascar: 3-D zero-offset modeling/migration with extended split-step

local ret=1

_arguments -s -S \
  'mode=[mode of operation]:mode' \
  'verb=[verbosity flag]:verb:(y n)' \
  'incore=[in-core execution]:incore:(y n)' \
  'eps=[stability parameter]:eps' \
  'inv=[y=modeling; n=migration]:inv:(y n)' \
  'causal=[y=causal; n=anti-causal]:causal:(y n)' \
  'twoway=[two-way traveltime]:twoway:(y n)' \
  'nrmax=[maximum references]:nrmax' \
  'dtmax=[time error]:dtmax' \
  'pmx=[padding on x]:pmx' \
  'pmy=[padding on y]:pmy' \
  'tmx=[taper on x]:tmx' \
  'tmy=[taper on y]:tmy' \
  'nw=[number of frequency samples]:nw' \
  'dw=[frequency sampling interval]:dw' \
  'ow=[frequency origin]:ow' \
  '*:RSF file:_files' && ret=0

return ret
