#compdef gitlab-ci-linter
# Documentation: https://github.com/orobardet/gitlab-ci-linter
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:lint a .gitlab-ci.yml file (default)'
  'install:install gitlab-ci-linter as a git pre-commit hook'
  'uninstall:remove the git pre-commit hook'
  'help:show help'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-u --gitlab-url)'{-u,--gitlab-url}'=[root URL of the GitLab instance]:url' \
  '(-P --project-path)'{-P,--project-path}'=[GitLab project path]:path' \
  '(-I --project-id)'{-I,--project-id}'=[GitLab project ID]:id' \
  '(-f --ci-file)'{-f,--ci-file}'=[GitLab CI file]:file:_files' \
  '(-d --directory)'{-d,--directory}'=[directory containing CI file]:dir:_directories' \
  '(-p --personal-access-token)'{-p,--personal-access-token}'=[personal access token]:token' \
  '(-n --netrc)'{-n,--netrc}'[retrieve token from .netrc]' \
  '--netrc-file=[custom .netrc file path]:file:_files' \
  '(-t --timeout)'{-t,--timeout}'=[HTTP timeout in seconds]:seconds' \
  '--no-color[disable colored output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-m --merged-yaml)'{-m,--merged-yaml}'[include merged YAML in response]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'gitlab-ci-linter command' commands && ret=0
    ;;
esac

return ret
