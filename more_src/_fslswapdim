#compdef fslswapdim
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# fslswapdim - reorder/flip image axes: fslswapdim <input> <a> <b> <c> [output]

local ret=1

_arguments -s -S \
  '1:input volume:_files' \
  '2:new x axis:(x -x y -y z -z RL LR AP PA SI IS)' \
  '3:new y axis:(x -x y -y z -z RL LR AP PA SI IS)' \
  '4:new z axis:(x -x y -y z -z RL LR AP PA SI IS)' \
  '5:output volume:_files' && ret=0

return ret
