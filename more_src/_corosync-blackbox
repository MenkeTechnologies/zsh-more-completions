#compdef corosync-blackbox
# Documentation: https://man.archlinux.org/search?q=corosync-blackbox
# Reference accessed: 2026-05-16

# corosync-blackbox: dump in-memory FDB (flight data) for corosync diag
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::corosync-blackbox args:_files' && ret=0
return ret
