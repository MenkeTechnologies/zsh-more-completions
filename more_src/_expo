#compdef expo

# Zsh completion for Expo CLI - React Native development

local curcontext="$curcontext" state line ret=1

local -a expo_commands
expo_commands=(
  'start:start a local dev server'
  'login:log in to Expo account'
  'logout:log out of Expo account'
  'register:create a new Expo account'
  'whoami:show current logged-in user'
  'init:create a new project'
  'install:install packages compatible with current SDK'
  'export:export the static files of the app'
  'prebuild:generate native projects'
  'run\:ios:build and run on iOS device or simulator'
  'run\:android:build and run on Android device or emulator'
  'config:show project config'
  'doctor:diagnose issues with the project'
  'upgrade:upgrade project packages'
  'customize:generate static project files'
  'diagnostics:print environment diagnostics'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:_describe -t commands command expo_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      start)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'=[port to start dev server on]:port:' \
          '--clear[clear the Metro bundler cache]' \
          '--dev-client[start in Expo Dev Client mode]' \
          '--scheme=[custom URI scheme]:scheme:' \
          '(-a --android)'{-a,--android}'[open on Android]' \
          '(-i --ios)'{-i,--ios}'[open on iOS]' \
          '(-w --web)'{-w,--web}'[open in web browser]' \
          '--tunnel[start tunnel connection]' \
          '--lan[start on LAN]' \
          '--localhost[start on localhost]' \
          '--offline[run without network]' \
          '--https[start with HTTPS]' \
          '--go[open in Expo Go]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      init)
        _arguments -s -S \
          '1:project name:' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      install)
        _arguments -s -S \
          '*:packages:' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      export)
        _arguments -s -S \
          '--output-dir=[output directory]:directory:_directories' \
          '--platform=[platform to export]:platform:(ios android all)' \
          '--clear[clear bundler cache]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      prebuild)
        _arguments -s -S \
          '--clean[delete native folders before prebuild]' \
          '--platform=[platform to prebuild]:platform:(ios android all)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
