#compdef dpkg-reconfigure
# Documentation: man dpkg-reconfigure(8)
# Source: Debian debconf dpkg-reconfigure (man) — reconfigure an installed package via debconf (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --frontend)'{-f+,--frontend=}'[debconf frontend]:type:(dialog readline gnome kde editor web noninteractive)' \
    '(-p --priority)'{-p+,--priority=}'[minimum question priority]:value:(low medium high critical)' \
    '--terse[terse output]' \
    '--default-priority[use default priority]' \
    '(-u --unseen-only)'{-u,--unseen-only}'[only ask unseen questions]' \
    '--force[reconfigure even if package broken]' \
    '--no-reload[do not reload templates]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '*:package:_default' \
    && ret=0

return ret
