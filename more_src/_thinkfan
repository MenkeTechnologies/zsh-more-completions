#compdef thinkfan

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-n[do not daemonize]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-z[zero-temperature-bias]' \
  '-D[disable depulsing]' \
  '-d+[depulse interval]:ms:' \
  '-c+[config file]:file:_files -g "*.yaml"' \
  '-s+[sleep interval seconds]:sec:' \
  '-b+[bias level 0-100]:bias:' \
  '-p+[pulse interval]:ms:' && ret=0

return ret
