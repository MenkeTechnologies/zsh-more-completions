#compdef thttpd

_arguments -s \
  '-C[config file]:file:_files' \
  '-p[port]:port:' \
  '-d[chdir directory]:dir:_files -/' \
  '-dd[post-chroot directory]:dir:_files -/' \
  '-r[chroot]' \
  '-nor[no chroot]' \
  '-s[symlink check]' \
  '-nos[no symlink check]' \
  '-v[vhost]' \
  '-nov[no vhost]' \
  '-g[global passwd]' \
  '-nog[no global passwd]' \
  '-u[user]:user:_users' \
  '-c[CGI pattern]:pattern:' \
  '-t[throttle file]:file:_files' \
  '-h[bind host]:host:_hosts' \
  '-l[log file]:file:_files' \
  '-i[pid file]:file:_files' \
  '-T[charset]:charset:' \
  '-P[P3P header]:p3p:' \
  '-M[max-age]:seconds:' \
  '-V[show version]' \
  '-D[debug/foreground]'
