#compdef CreateTiledMosaic
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CreateTiledMosaic.cxx — create a tiled mosaic from a 3D image (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input-image)'{-i+,--input-image=}'[input image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-r --rgb-image)'{-r+,--rgb-image=}'[RGB image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-x --mask-image)'{-x+,--mask-image=}'[mask image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-a --alpha)'{-a+,--alpha=}'[alpha value]:n:_default' \
    '(-e --functional-overlay)'{-e+,--functional-overlay=}'[overlay [rgbImage,maskImage,<alpha=1>]]:spec:_default' \
    '(-o --output)'{-o+,--output=}'[output tiled mosaic image]:file:_files' \
    '(-t --tile-geometry)'{-t+,--tile-geometry=}'[tile geometry RxC]:geom:_default' \
    '(-d --direction)'{-d+,--direction=}'[slicing direction]:dir:(0 1 2 x y z)' \
    '(-p --pad-or-crop)'{-p+,--pad-or-crop=}'[pad-or-crop spec]:spec:_default' \
    '(-s --slices)'{-s+,--slices=}'[slices spec]:spec:_default' \
    '(-f --flip-slice)'{-f+,--flip-slice=}'[flip slice axes]:spec:_default' \
    '(-g --permute-axes)'{-g+,--permute-axes=}'[permute axes spec]:spec:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
