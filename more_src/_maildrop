#compdef maildrop

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-w+[max line wrap]:n:' \
  '-d+[deliver to user]:user:_users' \
  '-f+[set sender address]:addr:' \
  '*-A+[append header]:header:' \
  '-a+[explicit virtual user prefix]:prefix:' \
  '-p[preserve message in failure case]' \
  '-D+[set DEFAULT macro]:val:' \
  '-m[embedded mode]' \
  '-M+[deliver to mailbox]:mbox:_files' \
  '-o+[stop processing on this option]:opt:' \
  '*:filter file:_files' && ret=0

return ret
