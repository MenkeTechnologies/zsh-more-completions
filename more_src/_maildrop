#compdef maildrop
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/maildrop.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# maildrop (courier): mail delivery filter/agent
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-a[make Courier Authentication Library usage mandatory]' \
  '*-A+[add header to message]:header (Name\: value)' \
  '-d+[run in delivery mode for user]:user:_users' \
  '-f+[set FROM (envelope sender) address]:address' \
  '-m[run in embedded mode]' \
  '-M+[run in embedded mode with filter file]:filter file:_files' \
  '-D+[reserved for Courier mail server integration]:uuu/ggg' \
  '-V+[initialize VERBOSE variable]:level' \
  '-w+[warn when maildir quota reaches percent]:N' \
  '-W+[custom quota warning message file]:file:_files' \
  '-t+[Dovecot authentication socket]:socket' \
  '*:filter file or arg:_files' && ret=0

return ret
