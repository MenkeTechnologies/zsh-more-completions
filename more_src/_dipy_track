#compdef dipy_track
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_track.html
# DIPY: local fiber tracking from a peaks and metrics (PAM) file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--use_binary_mask[use binary stopping criterion]' \
  '--stopping_thr=[threshold for stopping volume]:thr' \
  '--seed_density=[seeds per voxel dimension]:n' \
  '--minlen=[minimum streamline length in mm]:len' \
  '--maxlen=[maximum streamline length in mm]:len' \
  '--step_size=[tracking step size in mm]:size' \
  '--tracking_method=[direction getter strategy]:method:(eudx deterministic det probabilistic prob closestpeaks cp ptt)' \
  '--pmf_threshold=[ODF function threshold]:thr' \
  '--max_angle=[maximum angle between segments in degrees]:angle' \
  '--sphere_name=[sphere for tracking]:sphere' \
  '--save_seeds[save seed data per streamline]' \
  '--nbr_threads=[thread count]:n' \
  '--random_seed=[random number generator seed]:seed' \
  '--seed_buffer_fraction=[buffer usage fraction]:frac' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_tractogram=[output tractogram file name]:file:_files' \
  '*:input (pam stopping seeding):_files' && ret=0

return ret
