#compdef pdfimages
# Documentation: https://man.archlinux.org/man/pdfimages.1.en
# Reference accessed: 2026-05-30
# pdfimages — extract images from a PDF file (poppler tools). Outputs PPM/PBM/JPEG/JP2/JBIG2/CCITT.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show usage help]' \
  '(- *)-v[show copyright and version]' \
  '-f+[first page to scan]:page:' \
  '-l+[last page to scan]:page:' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-png[change default output format to PNG]' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-tiff[change default output format to TIFF]' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-j[write JPEG images in native format]' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-jp2[write JPEG2000 images as JP2 files]' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-jbig2[write JBIG2 images in native format]' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-ccitt[write CCITT images in native format]' \
  '(-png -tiff -j -jp2 -jbig2 -ccitt -all)-all[write all formats natively (CMYK as TIFF, others as PNG)]' \
  '-1[CCITT 1D Group 3 encoding]' \
  '-2[CCITT 2D Group 3 encoding]' \
  '-4[CCITT Group 4 encoding]' \
  '(-A -P)-A[align CCITT line beginnings on byte boundaries]' \
  '(-A -P)-P[do not align CCITT line beginnings on byte boundaries]' \
  '-X+[CCITT image width in pixels]:N:' \
  '(-W -B)-W[CCITT black=1 white=0]' \
  '(-W -B)-B[CCITT black=0 white=1]' \
  '-M[CCITT data fills from most to least significant bit]' \
  '-list[list images with info instead of writing them]' \
  '-print-filenames[output written filenames to stdout]' \
  '-p[include page numbers in output filenames]' \
  '-opw+[owner password]:password:' \
  '-upw+[user password]:password:' \
  '-q[suppress all messages and errors]' \
  '1:PDF file:_files -g "*.(pdf|PDF)"' \
  '2:image root (prefix for output files):' \
  && ret=0

return ret
