#compdef ab-av1

# ab-av1 — https://github.com/alexheretic/ab-av1 — clap Command enum in src/main.rs:
# sample-encode, vmaf, xpsnr, encode, crf-search, auto-encode, print-completions

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'sample-encode:sample-encode with VMAF/XPSNR scoring'
  'vmaf:score distorted vs reference with VMAF'
  'xpsnr:score distorted vs reference with XPSNR'
  'encode:full ffmpeg encode to output'
  'crf-search:binary-search CRF for target score'
  'auto-encode:auto pick CRF then encode'
  'print-completions:print shell completions'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'ab-av1 subcommand' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
