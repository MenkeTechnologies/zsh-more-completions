#compdef hgen
# Documentation: https://www.ccp4.ac.uk/html/hgen.html
# CCP4 HGEN - generate hydrogen atom positions

local ret=1

_arguments -s -S \
  'XYZIN[input coordinate file]:file:_files' \
  'XYZOUT[output coordinate file]:file:_files' \
  '*:keyword:(HYDROGENS SEPARATE APPEND)' && ret=0

return ret
