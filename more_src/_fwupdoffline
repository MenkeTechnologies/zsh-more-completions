#compdef fwupdoffline fwupd-offline
# Documentation: https://man.archlinux.org/search?q=fwupdoffline
# Reference accessed: 2026-05-16

# fwupd-offline: invoke pending offline firmware updates at boot
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--verbose}'[verbose]' \
  '*::fwupdoffline args:_files' && ret=0
return ret
