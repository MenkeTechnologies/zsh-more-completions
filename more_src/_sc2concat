#compdef sc2concat
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss52.html
# SMURF: concatenate SCUBA-2 files into a larger file.

local ret=1

_arguments -s -S \
  'IN=[input NDF files]:ndf:_files' \
  'OUT=[output concatenated NDFs]:ndf:_files' \
  'OUTBASE=[base name for output NDFs]:base:' \
  'OUTFILES=[text file listing output NDFs]:file:_files' \
  'MAXLEN=[max concatenated length in seconds]:len:' \
  'FLAT=[enable flatfield scaling]:flag:(TRUE FALSE)' \
  'FLATMETH=[flatfield method]:method:(POLYNOMIAL TABLE)' \
  'FLATORDER=[polynomial order for flatfield]:n:' \
  'FLATSNR=[SNR threshold for valid bolometers]:snr:' \
  'FLATUSENEXT=[use previous/following flatfield]:flag:(TRUE FALSE)' \
  'PADSTART=[samples to pad at start]:n:' \
  'PADEND=[samples to pad at end]:n:' \
  'RESIST=[bolometer resistor settings group]:par:_files' \
  'RESPMASK=[mask data using responsivity]:flag:(TRUE FALSE)' \
  'USEDARKS=[use darks for masking]:flag:(TRUE FALSE)' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
