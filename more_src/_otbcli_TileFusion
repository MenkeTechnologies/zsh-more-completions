#compdef otbcli_TileFusion
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_TileFusion.html
# Orfeo ToolBox: concatenate adjacent tiles into a single image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-il[input images to concatenate in lexicographic order]:images:_files' \
  '-cols[number of columns in the tile array]:value:' \
  '-rows[number of rows in the tile array]:value:' \
  '-out[output entire image]:output:_files' \
  '*::arg:_files' && ret=0

return ret
