#compdef 3dSkullStrip
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dSkullStrip.html
# AFNI remove the skull from a T1-weighted anatomical dataset

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-input[input AFNI volume]:dataset:_files' \
  '-prefix[output volume prefix]:prefix' \
  '-o_TYPE[output surface with format]:prefix' \
  '-mask_vol[output mask volume]' \
  '-orig_vol[output masked version, no intensity mod]' \
  '-norm_vol[output masked and normalized (default)]' \
  '-skulls[output surface models of the skull]' \
  '-niter[number of iterations]:n' \
  '-ld[surface density control]:ld' \
  '-shrink_fac[brain vs non-brain intensity threshold]:sf' \
  '-var_shrink_fac[vary shrink factor across iterations]' \
  '-no_var_shrink_fac[disable varying shrink factor]' \
  '-shrink_fac_bot_lim[minimum varying shrink factor]:sfbl' \
  '-exp_frac[speed of expansion]:frac' \
  '-init_radius[initial sphere radius]:rad' \
  '-pushout[consider values above nodes (default)]' \
  '-no_pushout[disable pushout]' \
  '-push_to_edge[aggressive edge push]' \
  '-no_push_to_edge[disable edge push (default)]' \
  '-touchup[include uncovered areas (default)]' \
  '-no_touchup[disable touchup]' \
  '-fill_hole[fill small surface intersection holes]:R' \
  '-NN_smooth[nearest neighbor interpolation frequency]:nn' \
  '-smooth_final[final smoothing iterations]:sm' \
  '-avoid_vent[avoid ventricles (default)]' \
  '-no_avoid_vent[disable ventricle avoidance]' \
  '-avoid_eyes[avoid eyes (default)]' \
  '-no_avoid_eyes[disable eye avoidance]' \
  '-use_edge[use edge detection (default)]' \
  '-no_use_edge[disable edge detection]' \
  '-use_skull[use outer skull to limit expansion]' \
  '-no_use_skull[disable skull usage (default)]' \
  '-spatnorm[perform spatial normalization (default)]' \
  '-no_spatnorm[skip spatial normalization]' \
  '-write_spatnorm[save spatially normalized volume]' \
  '-spatnorm_dxyz[spatial resolution for normalization]:dxyz' \
  '-blur_fwhm[blur dataset after normalization]:fwhm' \
  '-monkey[process monkey brain]' \
  '-marmoset[process marmoset brain]' \
  '-rat[process rat brain]' \
  '-surface_coil[data from surface coil acquisition]' \
  '-perc_int[percentage of segments allowed to intersect]:perc' \
  '-max_inter_iter[iterations to remove intersections]:n' \
  '-debug[debug levels 0-3]:dbg' \
  '*:dataset:_files' && ret=0

return ret
