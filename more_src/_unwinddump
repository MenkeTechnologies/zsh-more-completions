#compdef unwinddump
# Documentation: Apple ld64 src/other/unwinddump.cpp (Apple open source)
# Reference accessed: 2026-05-21
# Verified: local binary strings show only -arch flag accepted.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-arch+[architecture to dump]:arch:(x86_64 arm64 arm64e i386)' \
  '*:Mach-O binary:_files' && ret=0

return ret
