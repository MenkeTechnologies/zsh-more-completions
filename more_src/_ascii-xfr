#compdef ascii-xfr
# Documentation: ascii-xfr usage
# Source: simple ASCII file transfer (used with minicom).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s -r)-s[send]' \
    '(-s -r)-r[receive]' \
    '-e[send End-Of-File character]' \
    '-d[use Control-D as EOF (instead of Control-Z)]' \
    '-v[verbose statistics on stderr]' \
    '-n[do not translate CRLF<->LF]' \
    '-l+[line delay milliseconds]:linedelay:' \
    '-c+[character delay milliseconds]:character delay:' \
    '1:file:_files' \
    && ret=0

return ret
