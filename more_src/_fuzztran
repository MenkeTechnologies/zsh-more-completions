#compdef fuzztran
# Documentation: https://man.archlinux.org/search?q=fuzztran
# Reference accessed: 2026-05-16

# EMBOSS fuzztran: search 6-frame translation of DNA with protein pattern
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input DNA sequence(s)]:DNA USA:_files' \
  '-pattern=[protein pattern (PROSITE notation)]:pattern:' \
  '-frame=[translation frame(s)]:frame:(1 2 3 F -1 -2 -3 R 6)' \
  '-table=[genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-rformat=[report format]:format:(table excel feattable gff3 listfile motif pir simple swiss tagseq)' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
