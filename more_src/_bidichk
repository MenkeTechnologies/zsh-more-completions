#compdef bidichk inamedparam mnd tagalign tagliatelle usetesting
# Documentation: upstream READMEs at github.com/{breml/bidichk,macabu/inamedparam,tommy-muehle/go-mnd,4meepo/tagalign,ldez/tagliatelle,ldez/usetesting}
# Reference accessed: 2026-05-30
# Continuation of Go linter sweep R26 — 6 more single-purpose linters
# wrapping the analysis/passes framework. Most are also runnable via
# `go vet -vettool=$(which TOOL) PKG/...` and through golangci-lint.

local curcontext="$curcontext" state line ret=1

case $service in

  bidichk)
    # breml/bidichk — detect dangerous Unicode bidirectional formatting
    # characters used in Trojan Source attacks (U+202A-U+202E + U+2066-U+2069).
    local -a _runes
    _runes=(
      LEFT-TO-RIGHT-EMBEDDING
      RIGHT-TO-LEFT-EMBEDDING
      POP-DIRECTIONAL-FORMATTING
      LEFT-TO-RIGHT-OVERRIDE
      RIGHT-TO-LEFT-OVERRIDE
      LEFT-TO-RIGHT-ISOLATE
      RIGHT-TO-LEFT-ISOLATE
      FIRST-STRONG-ISOLATE
      POP-DIRECTIONAL-ISOLATE
    )
    _arguments -s -S \
      '--disallowed-runes=[runes to flag (comma-separated; default all 9)]:runes:_values -s , "rune" $_runes' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  inamedparam)
    # macabu/inamedparam — flag interface methods with unnamed parameters.
    _arguments -s -S \
      '-skip-single-param[exempt interfaces with a single unnamed parameter]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  mnd)
    # tommy-muehle/go-mnd — magic-number detector. Default excludes
    # 0/1 + test files + time.Date().
    local -a _checks
    _checks=(argument assign case condition operation return)
    _arguments -s -S \
      '-checks=[analysis types (comma-separated)]:checks:_values -s , "check" $_checks' \
      '-ignored-numbers=[numbers to exclude (comma-separated)]:numbers:' \
      '-ignored-functions=[function regex patterns to skip]:patterns:' \
      '-ignored-files=[file regex patterns to skip]:patterns:' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  tagalign)
    # 4meepo/tagalign — align and optionally sort struct tags.
    _arguments -s -S \
      '-fix[apply alignment fixes automatically]' \
      '-sort[sort tags within structs]' \
      '-order=[tag order (e.g. json,xml)]:order:' \
      '-strict[strict-style alignment (dictionary order, grouped names)]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  tagliatelle)
    # ldez/tagliatelle — struct tag naming-convention linter.
    # Configuration primarily via golangci-lint; standalone surface is
    # minimal (positional only).
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  usetesting)
    # ldez/usetesting — suggest t.TempDir / t.Setenv / t.Chdir / t.Context
    # replacements for os.* and context.Background/TODO calls in tests.
    # Per-detection enable flags configured via golangci-lint primarily;
    # standalone surface is minimal (positional only).
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
