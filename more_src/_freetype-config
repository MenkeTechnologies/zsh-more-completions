#compdef freetype-config
# Documentation: freetype-config --help (FreeType)
# Source: print compile and link flags for libfreetype.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--prefix=-[show or override prefix]::PREFIX:_files -/' \
    '--exec-prefix=-[show or override exec-prefix]::EPREFIX:_files -/' \
    '--version[show libtool version]' \
    '--ftversion[show FreeType version number]' \
    '--libs[show link flags]' \
    '--libtool[show libtool linkage name]' \
    '--cflags[show compile flags]' \
    '--static[show static linkage flags]' \
    && ret=0

return ret
