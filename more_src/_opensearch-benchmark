#compdef opensearch-benchmark

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'aggregate:aggregate test execution results'
  'compare:compare two test executions'
  'download:download a workload or distribution'
  'generate-data:generate synthetic data for a workload'
  'info:show information about a workload or test'
  'list:list workloads, telemetries, plugins, etc.'
  'redline-test:run a redline test'
  'run:run a benchmark'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--workload-path=[path to a workload]:dir:_files -/' \
  '--workload-repository=[workload repository name]:repo:' \
  '--workload=[workload name]:workload:' \
  '--workload-revision=[workload revision]:rev:' \
  '--workload-params=[workload params JSON]:json:' \
  '--test-procedure=[test procedure name]:procedure:' \
  '--test-execution-id=[test execution ID]:id:' \
  '--include-tasks=[include tasks list]:tasks:' \
  '--exclude-tasks=[exclude tasks list]:tasks:' \
  '--baseline=[baseline run id]:id:' \
  '--contender=[contender run id]:id:' \
  '--results-format=[results format]:format:(text markdown csv)' \
  '--results-number-align=[number alignment]:align:(left right decimal)' \
  '--results-file=[results file]:file:_files' \
  '--show-in-results=[results to show]:items:' \
  '--cluster-config-repository=[cluster config repository]:repo:' \
  '--cluster-config-revision=[cluster config revision]:rev:' \
  '--cluster-config-path=[cluster config path]:dir:_files -/' \
  '--cluster-config-instance=[cluster config instance]:instance:' \
  '--cluster-config-instance-params=[cluster config instance params]:json:' \
  '--distribution-version=[OpenSearch distribution version]:version:' \
  '--distribution-repository=[distribution repository]:repo:' \
  '--target-hosts=[target host list]:hosts:' \
  '--target-os=[target OS]:os:(linux darwin windows)' \
  '--target-arch=[target architecture]:arch:(x64 aarch64)' \
  '--revision=[revision to test]:rev:' \
  '--opensearch-plugins=[plugins to install]:plugins:' \
  '--plugin-params=[plugin params]:json:' \
  '--runtime-jdk=[runtime JDK]:version:' \
  '--client-options=[client options]:options:' \
  '--worker-ips=[worker IPs]:ips:' \
  '--enable-worker-coordinator-profiling[enable worker coordinator profiling]' \
  '--pipeline=[pipeline]:pipeline:' \
  '--telemetry=[telemetry devices]:list:' \
  '--telemetry-params=[telemetry params]:json:' \
  '--on-error=[on-error policy]:policy:(continue abort)' \
  '--preserve-install[do not delete benchmark candidate]' \
  '--kill-running-processes[kill running benchmark processes]' \
  '--chart-spec-path=[chart spec path]:dir:_files -/' \
  '--chart-type=[chart type]:type:' \
  '--output-path=[output path]:dir:_files -/' \
  '--limit=[result limit]:n:' \
  '--latency-percentiles=[latency percentiles]:list:' \
  '--throughput-percentiles=[throughput percentiles]:list:' \
  '--randomization-enabled[enable randomization]' \
  '--randomization-repeat-frequency=[randomization repeat frequency]:n:' \
  '--randomization-n=[randomization N]:n:' \
  '--test-iterations=[test iterations]:n:' \
  '--aggregate=[aggregate level]:level:' \
  '--sleep-timer=[sleep timer]:secs:' \
  '--cancel-on-error[cancel on error]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'opensearch-benchmark subcommand' subcommands && ret=0
    ;;
esac

return ret
