#compdef konsole

_arguments -s \
  '--profile=[profile]:profile:' \
  '--layout=[layout file]:file:_files' \
  '--builtin-profile[built-in profile]' \
  '--workdir=[working dir]:dir:_files -/' \
  '(--hold --noclose)'{--hold,--noclose}'[keep open after exit]' \
  '--new-tab[new tab]' \
  '--tabs-from-file=[tabs config]:file:_files' \
  '--background-mode[start in background]' \
  '(--separate --nofork)'{--separate,--nofork}'[separate process]' \
  '--show-menubar[show menubar]' \
  '--hide-menubar[hide menubar]' \
  '--show-toolbars[show toolbars]' \
  '--hide-toolbars[hide toolbars]' \
  '--show-tabbar[show tabbar]' \
  '--hide-tabbar[hide tabbar]' \
  '--fullscreen[fullscreen]' \
  '--notransparency[no transparency]' \
  '--list-profiles[list profiles]' \
  '--list-profile-properties[list properties]' \
  '*-p[property=value]:setting:' \
  '-e[command]:command:_command_names' \
  '--force-reuse[force reuse instance]' \
  '(-T --title)'{-T,--title}'=[title]:title:' \
  '--help[show help]' \
  '--help-all[show all help]' \
  '--version[show version]'
