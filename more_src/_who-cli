#compdef who-cli
# _who-cli — GNU coreutils who show who is logged on CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_who-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[same as -b -d --login -p -r -t -T -u]' \
        '--all[same as -b -d --login -p -r -t -T -u]' \
        '-b[time of last system boot]' \
        '--boot[time of last system boot]' \
        '-d[print dead processes]' \
        '--dead[print dead processes]' \
        '-H[print heading]' \
        '--heading[print heading]' \
        '-l[print system login processes]' \
        '--login[print system login processes]' \
        '--lookup[try to resolve hostnames]' \
        '-m[only current user]' \
        '-p[active processes spawned by init]' \
        '--process[active processes spawned by init]' \
        '-q[count of logged in users]' \
        '--count[count of logged in users]' \
        '-r[current runlevel]' \
        '--runlevel[current runlevel]' \
        '-s[name, line, time (default)]' \
        '--short[name, line, time (default)]' \
        '-t[last system clock change]' \
        '--time[last system clock change]' \
        '-T[print user message status]' \
        '-w[print user message status]' \
        '--mesg[print user message status]' \
        '--message[print user message status]' \
        '--writable[print user message status]' \
        '-u[list users logged in]' \
        '--users[list users logged in]' \
        '*:file:_files'
}

_who-cli "$@"
