#compdef cargo-binstall

_cargo-binstall() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        '--version[Specify the version to install]:version:' \
        '--targets[Override target triple]:target:' \
        '--pkg-url[Override the package URL template]:url:' \
        '--pkg-fmt[Override the package format]:format:(tgz txz zip bin tar)' \
        '--bin-dir[Override the binary directory template]:dir:' \
        {-f,--force}'[Force install, overwriting existing binaries]' \
        '--no-confirm[Do not ask for confirmation]' \
        '--no-symlinks[Do not create symlinks]' \
        '--dry-run[Do not actually install, just show what would happen]' \
        '--no-discover-github-token[Do not discover GitHub token from environment]' \
        '--github-token[Specify a GitHub API token]:token:' \
        '--locked[Require Cargo.lock is up to date]' \
        '--log-level[Set the log level]:level:(trace debug info warn error)' \
        '--manifest-path[Path to Cargo.toml]:path:_files -g "*.toml"' \
        '--no-cleanup[Do not clean up temporary files]' \
        '--no-track[Do not track installed crates]' \
        '--only-signed[Only install signed packages]' \
        '--rate-limit[Set rate limit for API requests]:limit:' \
        '--root[Directory to install packages into]:dir:_directories' \
        '--secure[Require HTTPS for all downloads]' \
        '*--strategies[Strategies to use for finding packages]:strategy:(crate-meta-data quick-install compile)' \
        '*--disable-strategies[Strategies to disable]:strategy:(crate-meta-data quick-install compile)' \
        '--disable-telemetry[Disable telemetry]' \
        '--install-path[Override the installation path]:path:_directories' \
        {-q,--quiet}'[Suppress output]' \
        {-v,--verbose}'[Use verbose output]' \
        {-h,--help}'[Print help information]' \
        '-V[Print version information]' \
        '*:crate name:' && ret=0

    return ret
}

_cargo-binstall "$@"
