#compdef vpa-admission-controller
# _vpa-admission-controller — Vertical Pod Autoscaler admission webhook (kubernetes/autoscaler/vertical-pod-autoscaler)
# upstream: https://github.com/kubernetes/autoscaler/tree/master/vertical-pod-autoscaler
# Flags from pkg/admission-controller/{main,config/config}.go + common/flags.go on tip.

_vpa-admission-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--client-ca-file=[client-cert CA bundle]:file:_files' \
        '--tls-cert-file=[server TLS cert]:file:_files' \
        '--tls-private-key=[server TLS key]:file:_files' \
        '--reload-cert=[reload TLS certs on change]:bool:(true false)' \
        '--tls-ciphers=[allowed TLS cipher list (TLS 1.2)]:list:' \
        '--min-tls-version=[minimum TLS version]:ver:(tls1_2 tls1_3)' \
        '--port=[HTTPS bind port]:port:' \
        '--address=[Prometheus metrics bind address]:host\:port:' \
        '--webhook-service=[Kubernetes Service name for webhook]:name:' \
        '--webhook-address=[external URL for webhook registration]:url:_urls' \
        '--webhook-port=[webhook server port]:port:' \
        '--webhook-timeout-seconds=[apiserver wait timeout]:n:' \
        '--webhook-failure-policy-fail=[set webhook failurePolicy=Fail]:bool:(true false)' \
        '--register-webhook=[create the webhook config on startup]:bool:(true false)' \
        '--webhook-labels=[comma-sep key:value labels on webhook object]:list:' \
        '--register-by-url=[register webhook by URL instead of Service]:bool:(true false)' \
        '--max-allowed-cpu-boost=[max applied CPU for boosted containers]:qty:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--profiling[expose /debug/pprof endpoints]' \
        '--vpa-object-namespace=[namespace to search VPAs in]:ns:' \
        '--ignored-vpa-object-namespaces=[comma-sep namespaces to ignore]:list:' \
        '-v[klog verbosity level]:n:'
}

_vpa-admission-controller "$@"
