#compdef FileFilter
# OpenMS TOPP: extract or manipulate portions of MS data

local ret=1

_arguments -s -S \
  '-in[input file]:input file:_files' \
  '-in_type[input file type]:type:' \
  '-out[output file]:output file:_files' \
  '-out_type[output file type]:type:' \
  '-rt[retention time range to extract min:max]:range:' \
  '-rt_block_mode[RT filtering mode]:mode:(as_is extend_to_preserve_full_cycle shrink_to_preserve_full_cycle)' \
  '-mz[m/z range to extract]:range:' \
  '-int[intensity range to extract]:range:' \
  '-sort[sort output by RT and m/z]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
