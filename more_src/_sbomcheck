#compdef sbomcheck
# Documentation: https://github.com/spdx/ntia-conformance-checker
# validate SPDX SBOM against NTIA and CISA minimum element requirements

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --sbom-spec)'{-s,--sbom-spec}'[SBOM specification of the input file]:spec:(spdx2 spdx3)' \
  '(-c --comply)'{-c,--comply}'[compliance standard to check against]:standard:(fsct3-min ntia)' \
  '--skip-validation[skip validation]' \
  '(-r --output)'{-r,--output}'[type of compliance report output]:output:(html json print quiet)' \
  '(-o --output-file)'{-o,--output-file}'[filepath for compliance report output]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[print more information (debug)]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:sbom file:_files' && ret=0

return ret
