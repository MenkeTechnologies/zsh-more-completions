#compdef nice-cli
# _nice-cli — GNU coreutils nice run program with modified scheduling priority CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_nice-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-n+[adjustment]:n:' \
        '--adjustment=+[adjustment]:n:' \
        '*:command:_command_names'
}

_nice-cli "$@"
