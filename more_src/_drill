#compdef drill
# _drill — Ferran Basora's HTTP load tester written in Rust (Ansible-style YAML benchmark files; histograms + tags)
# upstream: https://github.com/fcsonline/drill
# Flags from src/main.rs (clap) on tip.

_drill() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-b --benchmark)'{-b+,--benchmark=}'[YAML benchmark file (required)]:file:_files' \
        '(-s --stats compare)'{-s,--stats}'[show request statistics (conflicts with --compare)]' \
        '(-r --report compare)'{-r+,--report=}'[write JSON report to file (conflicts with --compare)]:file:_files' \
        '(-c --compare report threshold)'{-c+,--compare=}'[compare against a previous report file (conflicts with --report)]:file:_files' \
        '(-t --threshold report)'{-t+,--threshold=}'[threshold in ms for compare]:ms:' \
        '--relaxed-interpolations[do not panic on missing interpolation]' \
        '--no-check-certificate[disable TLS certificate verification]' \
        '--tags=[only run tasks with these tags]:tags:' \
        '--skip-tags=[skip tasks with these tags]:tags:' \
        '(--list-tags tags skip-tags)--list-tags[list all benchmark tags and exit]' \
        '--list-tasks[list benchmark tasks (filtered by --tags/--skip-tags) and exit]' \
        '(-q --quiet)'{-q,--quiet}'[disable output]' \
        '(-o --timeout)'{-o+,--timeout=}'[per-request timeout (seconds)]:sec:' \
        '(-n --nanosec)'{-n,--nanosec}'[show timing in nanoseconds]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
}

_drill "$@"
