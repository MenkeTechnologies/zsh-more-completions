#compdef sqlline drill
# _drill — Apache Drill sqlline launcher (interactive SQL shell for Drill cluster; -u JDBC URL, -n user, -p password, -d driver class, -e single query, -f script, --output-format CSV|TSV|JSON|table|vertical, --verbose, --color, --silent, --maxWidth, --headerInterval; behaviour shared with phoenix-sqlline since both use the sqlline framework)
# upstream: https://github.com/apache/drill
# Flags from Apache Drill bin/sqlline + jline-utility on tip.

_drill() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-u+[JDBC URL]:url:' \
        '-n+[user]:user:_users' \
        '-p+[password]:password:' \
        '-d+[driver class]:class:' \
        '--verbose[verbose]' \
        '--color[color]' \
        '--silent[silent]' \
        '-e+[query]:query:' \
        '-f+[script file]:file:_files -g "*.sql"' \
        '--output-format+[format]:format:(CSV TSV XML JSON table vertical)' \
        '--maxWidth+[max col width]:n:' \
        '--headerInterval+[N rows]:n:'
}

_drill "$@"
