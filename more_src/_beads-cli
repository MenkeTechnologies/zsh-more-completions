#compdef beads-cli
# Documentation: https://www.npmjs.com/package/@beads/bd
# Reference accessed: 2026-05-23
# Verified: npx @beads/bd --help (binary bd).

# Zsh completion for beads-cli - Beads issue tracker (@beads/bd; see also _bd)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'beads command' \
      'create[create issue]' \
      'create-form[create issue via form]' \
      'list[list issues]' \
      'show[show issue details]' \
      'search[search issues]' \
      'query[query with simple query language]' \
      'update[update issues]' \
      'close[close issues]' \
      'reopen[reopen issues]' \
      'delete[delete issues]' \
      'edit[edit issue in editor]' \
      'comment[add comment]' \
      'comments[view or manage comments]' \
      'assign[assign issue]' \
      'label[manage labels]' \
      'tag[add label]' \
      'link[link issues with dependency]' \
      'dep[manage dependencies]' \
      'children[list child issues]' \
      'priority[set priority]' \
      'note[append note]' \
      'q[quick capture issue ID only]' \
      'promote[promote wisp to permanent bead]' \
      'gate[manage async gates]' \
      'merge-slot[merge-slot gates]' \
      'set-state[set operational state]' \
      'state[query state dimension]' \
      'todo[manage TODO items]' \
      'count[count matching issues]' \
      'status[database overview]' \
      'statuses[list valid statuses]' \
      'types[list valid types]' \
      'history[issue version history]' \
      'diff[changes between commits or branches]' \
      'stale[stale issues]' \
      'lint[check template sections]' \
      'find-duplicates[find similar issues]' \
      'duplicate[mark duplicate]' \
      'duplicates[find and merge duplicates]' \
      'supersede[mark superseded]' \
      'epic[epic management]' \
      'graph[dependency graph]' \
      'swarm[swarm management]' && ret=0
    ;;
esac

return ret
