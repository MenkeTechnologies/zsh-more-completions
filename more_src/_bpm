#compdef bpm
# Documentation: https://man.archlinux.org/search?q=bpm
# Reference accessed: 2026-05-16

# Zsh completion for bpm from bpm-tools — tempo estimation on raw headerless S16LE PCM (stdin). See `bpm -h`.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show bpm usage]' \
  '*: : _message "PCM stream via stdin; use bpm -h"' && ret=0

return ret
