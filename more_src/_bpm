#compdef bpm
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/bpm.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bpm from bpm-tools — tempo estimation on raw headerless S16LE PCM (stdin). See `bpm -h`.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show bpm usage]' \
  '*: : _message "PCM stream via stdin; use bpm -h"' && ret=0

return ret
