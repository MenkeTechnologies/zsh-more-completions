#compdef jtag
# Documentation: https://manpages.debian.org/testing/urjtag/jtag.1.en.html
# UrJTAG - work with JTAG-aware (IEEE 1149.1) hardware via a JTAG adapter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display a short help text and exit]' \
  '(-i --interactive)'{-i,--interactive}'[enter interactive mode after executing command files]' \
  '(-n --norc)'{-n,--norc}'[disable reading ~/.jtag/rc on startup]' \
  '(-q --quiet)'{-q,--quiet}'[do not print help on startup]' \
  '(-v --version)'{-v,--version}'[display version information and exit]' \
  '*:command file:_files' && ret=0

return ret
