#compdef salome-launcher

# salome-launcher: wrapper for launching Salome with environment setup
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-t[terminal mode]' \
  '--shutdown-servers[shut down servers on exit]' \
  '--modules=[modules to load]:modules:' \
  '--port=[Naming Service port]:n:' \
  '*::salome args:_files' && ret=0
return ret
