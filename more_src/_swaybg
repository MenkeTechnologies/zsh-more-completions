#compdef swaybg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --color)'{-c,--color}'[set background color]:color' \
  '(-i --image)'{-i,--image}'[set background image]:image:_files -g "*.{png,jpg,jpeg,bmp,gif,webp}"' \
  '(-m --mode)'{-m,--mode}'[set background mode]:mode:(stretch fill fit center tile)' \
  '(-o --output)'{-o,--output}'[set output]:output' && ret=0

return ret
