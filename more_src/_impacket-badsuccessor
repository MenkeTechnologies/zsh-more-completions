#compdef impacket-badsuccessor
# Documentation: https://github.com/fortra/impacket/blob/master/examples/badsuccessor.py
# dMSA exploitation tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-dmsa-name=[name of dMSA to add]:name' \
  '-action=[action to perform]:action:(add delete modify search)' \
  '-target-ou=[specific OU to check for dMSA creation capabilities]:ou' \
  '-principals-allowed=[username allowed to retrieve the managed password]:user' \
  '-target-account=[target user or computer account DN to set]:dn' \
  '-dns-hostname=[DNS hostname for the dMSA]:hostname' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '-method=[method of adding the computer]:method' \
  '-port=[destination port to connect to (LDAP 389, LDAPS 636)]:port' \
  '-baseDN=[set baseDN for LDAP]:basedn' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-dc-host=[hostname of the domain controller to use]:hostname' \
  '-dc-ip=[IP of the domain controller to use]:ip' \
  '1:account (used to authenticate to DC):' && ret=0

return ret
