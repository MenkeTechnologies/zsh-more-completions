#compdef mrbump
# Documentation: https://www.ccp4.ac.uk/html/mrbump.html
# CCP4 MrBUMP - automated molecular replacement

local ret=1

_arguments -s -S \
  'HKLIN[input structure factor MTZ file]:file:_files' \
  'SEQIN[input sequence file (PIR/Fasta/raw)]:file:_files' \
  'HKLOUT[output MTZ file from Refmac5]:file:_files' \
  'XYZOUT[output PDB coordinate file]:file:_files' \
  'KEYIN[read keywords from file]:file:_files' \
  'PREPDIR[previous run output directory]:dir:_files -/' \
  '*:keyword:(LABIN JOBID ROOTDIR HKLIN SEQIN HKLOUT XYZOUT KEYIN RLEVEL NMASU MRNUM ENSEMNUM INCLUDE LOCALFILE FIXED_XYZIN IGNORE MRPROGRAMS MAPROGRAM MDLUNMOD MDLDPDBCLP MDLPLYALA MDLMOLREP MDLCHAINSAW MDLSCULPTOR SSMSEARCH SCOPSEARCH PQSSEARCH DOFASTA DOHHPRED DOPHMMER HHDBPDB HHINDEX HHSCORE PACK PJOBS NCYC REFTWIN UPDATE ONLYMODELS TRYALL USEACORN ACORNRES BUCCANEER BCYC ARPWARP ACYC SHELXE SCYC SXREBUILD SXRARPW SXRBUCC USEPHS ENANT PDBDIR PDBLOCAL CLUSTER QTYPE QSIZE QSUBCOM CLEAN LITE PICKLE CHECK DEBUG PROXYSERVER PKEYWORD END)' && ret=0

return ret
