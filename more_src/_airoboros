#compdef airoboros
# Documentation: https://github.com/jondurbin/airoboros
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for airoboros - instruction-tuning dataset generation CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'airoboros command' \
      'generate-instructions[generate synthetic instruction data]' \
      'generate-topics[generate synthetic topics]' && ret=0
    ;;
  args)
    _arguments \
      '--config-path[YAML configuration file path]:file:_files' && ret=0
    ;;
esac

return ret
