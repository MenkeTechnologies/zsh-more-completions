#compdef cargo-feature-set
# Documentation: https://github.com/badboy/cargo-feature-set
# Source: badboy/cargo-feature-set src/main.rs — show the resolved feature set per crate from cargo metadata.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '*--features=[space-separated list of features to activate]:features:_default' \
    '(-R --root-deps-only)'{-R,--root-deps-only}'[only show root dependencies]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
