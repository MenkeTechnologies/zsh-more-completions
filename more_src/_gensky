#compdef gensky
# Documentation: https://floyd.lbl.gov/radiance/man_html/gensky.1.html
# Radiance CIE standard sky description generator

local ret=1

_arguments -s \
  '-ang[specify solar altitude and azimuth]:altitude' \
  '-defaults[print default option values]' \
  '-s[sunny sky without sun]' \
  '+s[sunny sky with sun]' \
  '-c[cloudy sky]' \
  '-i[intermediate sky without sun]' \
  '+i[intermediate sky with sun]' \
  '-u[uniform cloudy sky]' \
  '-b[set zenith brightness directly]:brt' \
  '-B[zenith brightness from horizontal diffuse irradiance]:irrad' \
  '-r[override solar radiance calculation]:rad' \
  '-R[solar radiance from horizontal direct irradiance]:irrad' \
  '-t[set turbidity factor]:trb' \
  '-g[set average ground reflectance]:rfl' \
  '-a[site latitude in degrees north]:lat' \
  '-o[site longitude in degrees west]:lon' \
  '-m[standard meridian in degrees west of Greenwich]:mer' \
  '-y[use more accurate solar position algorithm]:year' \
  '*:args:' && ret=0

return ret
