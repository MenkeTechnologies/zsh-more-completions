#compdef ivy_check
# Documentation: https://github.com/microsoft/ivy/blob/master/doc/commands.md
# IVy formal verification proof checker

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'trace=[stop at first failed guarantee and print execution trace]:bool:(true false)' \
  'diagnose=[halt at first failed guarantee and launch counterexample viewer]:bool:(true false)' \
  'summary=[print summary without executing checks]:bool:(true false)' \
  'mutax=[relax restrictions on mutable symbols in axioms]:bool:(true false)' \
  'interference=[when false, disable non-interference check (unsound)]:bool:(true false)' \
  'complete=[logic fragment for checking]:logic:(epr qf fo)' \
  'macro_finder=[enable Z3 macro finder]:bool:(true false)' \
  'incremental=[use Z3 incrementally when verifying invariants]:bool:(true false)' \
  'seed=[random seed for the SMT solver]:int:' \
  'isolate=[specify which isolate to verify]:name:' \
  'show_compiled=[display elaborated IVy code before verification]:bool:(true false)' \
  'pedantic=[enable optional warnings]:bool:(true false)' \
  '*:ivy file:_files -g "*.ivy"' && ret=0

return ret
