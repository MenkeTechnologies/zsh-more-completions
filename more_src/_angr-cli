#compdef angr-cli angr-cli2
# _angr-cli — Yan Shoshitaishvili UCSB angr-cli CLI binary analysis platform command-line frontend to angr framework providing symbolic execution VEX-IR-based-emulation-of-binaries x86-x86_64-arm-arm64-mips-ppc CGC-mode entry-point-analysis simgr-step-explore CFG-construction loop-finding for CTF binary-analysis (angr team, Python); argparse
# upstream: https://angr.io/

_angr-cli() {
    local -a sub=(
        'load:load a binary'
        'cfg:compute control flow graph'
        'symbol:list symbols'
        'sim:run simgr step-explore'
        'find:simulate find target address'
        'explore:explore execution path'
        'disasm:disassemble blocks'
        'gdb-attach:attach to gdb'
        'plugin:load custom analysis plugin'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--base-addr=+[addr]:str:' \
        '--arch=+[a]:a:(x86 amd64 arm aarch64 mips mips64 ppc ppc64 riscv sh4 s390x)' \
        '--load-libs=+[bool]:s:(true false)' \
        '--main-opts=+[opts]:str:' \
        '--lib-opts=+[opts]:str:' \
        '--exclude-sim-procedures=+[list]:str:' \
        '--no-stub[do not use stub library implementations]' \
        '-l+[log level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--log-level=+[level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'angr-cli subcommand' sub ;;
        args)
            case $words[1] in
                load|cfg|disasm|symbol|sim|find|explore) _arguments '*:binary:_files' ;;
            esac
            ;;
    esac
}

_angr-cli "$@"
