#compdef ansible-console
# _ansible-console — Ansible console (interactive REPL that runs ad-hoc Ansible commands against a host pattern; supports cd <group>, list, become, forks, timeout, verbose, help; same -i/-l/-m/-c surface as ansible)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/console.py)
# Flags from ansible cli/console.py on tip.

_ansible-console() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '*-v[verbose]' \
        '-i+[inventory]:inventory:_files' \
        '-l+[limit hosts]:limit:' \
        '-f+[parallel forks]:forks:' \
        '-T+[connection timeout]:seconds:' \
        '-u+[remote user]:user:_users' \
        '-c+[connection]:connection:(local ssh paramiko docker kubectl)' \
        '-b[become]' \
        '-K[ask become pass]' \
        '-k[ask remote ssh pass]' \
        '--become-method+[method]:method:(sudo su pbrun pfexec doas dzdo ksu runas)' \
        '--become-user+[user]:user:_users' \
        '*-e+[extra vars]:key=value:' \
        '--vault-id+[vault id]:vault_id:' \
        '--vault-password-file+[file]:file:_files' \
        '--ask-vault-pass[ask vault pass]' \
        '--step[interactive step]' \
        '-C[check mode]' \
        '1:host pattern:'
}

_ansible-console "$@"
