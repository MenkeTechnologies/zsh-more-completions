#compdef argbash-init
# ============================================================================
#  _argbash-init — argbash-init: bootstrap Argbash bash CLI template
#                  generator (companion to argbash itself)
#
#  Source-direct extraction from
#    https://github.com/matejak/argbash/blob/master/bin/argbash-init
#    https://argbash.readthedocs.io/en/stable/usage.html#macros-reference
#    (Argbash macro library documentation)
#
#  Maintained by Jakub Smolik (matejak/argbash).  argbash is the BASH
#  CLI argument-parser GENERATOR that uses M4 MACRO COMMENTS embedded
#  in bash files to generate POSIX-compliant argument parsing code.
#  Write bash comments like `# ARG_OPTIONAL_SINGLE([output],[o],[help])`
#  at the top of your script, run `argbash mytool.m4 -o mytool.sh`, and
#  argbash REPLACES the macros with full POSIX bash argument parsing
#  logic (positional args, optional flags, value-taking options, boolean
#  toggles, enums, help text generation, error handling).  `argbash-init`
#  is the BOOTSTRAP TOOL that creates an INITIAL TEMPLATE — caller
#  passes `--pos NAME --opt FLAG --opt-bool TOGGLE` and argbash-init
#  emits the corresponding skeleton .m4 file.  Sister tools: argbash
#  (the main generator, IN CORPUS via _argbash; this `_argbash-init`
#  covers the bootstrap helper), bashly (Ruby-based bash CLI generator,
#  YAML-driven), bash-completion (Debian completion framework), getopt
#  (POSIX util-linux's enhanced getopt for shell scripts).
#
#  CLI library taxonomy update: 1st Bash language entry — Jakub
#  Smolik's **Argbash** M4-macro-based bash CLI generator
#  (matejak/argbash).  Bash is a FIRST-TIME addition to the
#  cross-language CLI library taxonomy.
#
#  Argbash is a CODE GENERATOR — unlike runtime CLI libraries
#  (clap/argparse/etc.) that parse args at execution time, Argbash
#  processes M4 MACRO COMMENTS in source files at BUILD TIME and
#  emits PLAIN POSIX BASH ARGUMENT PARSING CODE that runs without
#  any external dependency.  The generated bash code is fully self-
#  contained and portable across every POSIX shell environment.
#  Argbash itself is DOGFOODED — `argbash-init` is itself an Argbash-
#  generated bash script (header contains the same `ARG_*` macros
#  it produces).  Used by adorsys/open-banking-gateway, OpenSCAP
#  release tooling, Stamus Networks Scirius IDS management, smallstep
#  certificates install scripts, sgallagher/sscg (Simple Signed
#  Certificate Generator by Red Hat), edannenberg/kubler (Gentoo
#  container build system), PicGo CI scripts, and countless internal
#  enterprise bash CLI tools that want POSIX-compliant arg parsing
#  without dependencies.
#
#  Argbash macro API (embedded as bash comments before `ARGBASH_GO()`):
#    #!/usr/bin/env bash
#
#    # ARG_POSITIONAL_SINGLE([input],[Input file],[])
#    # ARG_POSITIONAL_MULTI([targets],[Target names],[1])
#    # ARG_POSITIONAL_INF([files],[Input files],[1])
#    # ARG_OPTIONAL_SINGLE([output],[o],[Output file],[out.txt])
#    # ARG_OPTIONAL_REPEATED([include],[I],[Include path])
#    # ARG_OPTIONAL_BOOLEAN([verbose],[v],[Verbose mode],[off])
#    # ARG_OPTIONAL_INCREMENTAL([debug],[d],[Increase debug level])
#    # ARG_OPTIONAL_ACTION([list],[l],[List items],[do_list])
#    # ARG_TYPE_GROUP_SET([format],[FMT],[format],[json,csv,xml])
#    # ARG_DEFAULTS_POS()
#    # ARG_HELP([Description of the tool])
#    # ARG_VERSION([echo "mytool 1.0"])
#    # ARGBASH_GO()
#    # needed because of Argbash --> m4_ignore([
#    ### START OF CODE GENERATED BY Argbash v2.x.x one line above ###
#    # ... (generated bash parsing code goes here) ...
#    ### END OF CODE GENERATED BY Argbash ###
#    # ])
#    # [<-- end of Argbash output]
#
#    # Your tool's logic accessing $_arg_input, $_arg_output, $_arg_verbose
#    main() { ... }
#    main "$@"
#
#  Argbash distinctive features:
#    - CODE GENERATOR — uses GNU M4 macro processor + custom Argbash
#      macro library to transform `ARG_*` comments into runtime bash
#      argument parsing code; NO RUNTIME LIBRARY dependency in the
#      output
#    - M4 MACROS as BASH COMMENTS — `# ARG_OPTIONAL_SINGLE(...)` line
#      starts with `#` so the unprocessed file is still a valid bash
#      script; Argbash's M4 expansion ignores or replaces them
#    - `ARG_POSITIONAL_SINGLE([name],[description],[default])` — single
#      positional argument (no `[]` array syntax for the default in
#      the macro call — the `[…]` brackets are M4's quoting; the
#      DEFAULT becomes a STRING parameter)
#    - `ARG_POSITIONAL_MULTI([name],[description],[count])` — N-valued
#      positional (collects N args into `$_arg_NAME` array)
#    - `ARG_POSITIONAL_INF([name],[description],[min_count])` — infinite
#      positional (collects ALL remaining into `$_arg_NAME` array)
#    - `ARG_OPTIONAL_SINGLE([name],[short],[description],[default])` —
#      value-taking flag (e.g. `--output FILE` or `-o FILE`)
#    - `ARG_OPTIONAL_REPEATED([name],[short],[description])` — repeatable
#      flag (returns array)
#    - `ARG_OPTIONAL_BOOLEAN([name],[short],[description],[default_state])`
#      — boolean toggle with both `--name` and `--no-name` forms
#    - `ARG_OPTIONAL_INCREMENTAL([name],[short],[description])` — counter
#      flag (e.g. `-vvv` for 3-level verbose)
#    - `ARG_OPTIONAL_ACTION([name],[short],[description],[bash_action])` —
#      flag triggering a callback function
#    - `ARG_TYPE_GROUP_SET([name],[type],[option_to_constrain],[csv_values])`
#      — ENUM/CHOICES constraint (e.g. `default,full,minimal`)
#    - `ARG_DEFAULTS_POS()` — toggles whether positionals can be
#      empty (defaults set vs hard-required)
#    - `ARG_HELP([text])` — short help text
#    - `ARG_VERSION([bash_code])` — version action (any bash; usually
#      `echo "tool $version"`)
#    - `ARGBASH_GO()` — REQUIRED MARKER signaling Argbash to start
#      processing macros + insert generated code at this point
#    - GENERATED RESULT VARIABLES — each option becomes `$_arg_NAME`
#      where dashes are replaced with underscores (e.g. `--opt-bool`
#      becomes `$_arg_opt_bool`)
#    - GENERATED `print_help()` FUNCTION — auto-generates terminal-
#      formatted help text from the macros
#    - GENERATED `parse_commandline()` FUNCTION — main parser loop
#      with POSIX-compliant short-option decomposition (e.g. `-vd`
#      → `-v -d`)
#    - GENERATED `die()` HELPER — emits error to stderr + exits with
#      code from `${2:-1}`
#    - GENERATED `begins_with_short_option()` HELPER — for short-option
#      sliding decomposition
#    - SUPPORTS argbash-init BOOTSTRAP — `argbash-init --pos input
#      --opt output --opt-bool verbose --mode default tool.m4` creates
#      starter template
#    - VERSION/HELP ACTION SEPARATION — caller specifies arbitrary
#      bash code as version/help action (e.g. fetch git SHA, query
#      package metadata)
#    - PORTABLE — generated code works on bash 3.2+ (macOS default),
#      bash 4+, bash 5+, dash, ksh (with minor caveats)
#  Distinct from EVERY other CLI library in this taxonomy by being
#  a BUILD-TIME CODE GENERATOR not a runtime parsing library.
#  Closest analog might be R275 Rust clap-derive (compile-time macro
#  generating code from struct attributes — both expand source into
#  generated parser code) but Argbash operates on bash files via M4
#  macros vs clap-derive's Rust proc-macros.  Also distinct from
#  R277 Java picocli (annotation runtime + optional autocompletion
#  script generation), R343 commander.js (JS fluent builder),
#  R322 Java JCommander (annotations + reflection), R270 Haskell
#  optparse-applicative (functional applicative combinator), R272 C
#  POSIX getopt (low-level char-by-char), R382 GNU argp (C struct
#  arrays).  Argbash's approach: GNU M4 MACRO PROCESSOR + `ARG_*`
#  MACROS as BASH COMMENTS + `ARGBASH_GO()` REQUIRED MARKER + GENERATED
#  POSIX BASH CODE with `$_arg_NAME` result variables + GENERATED
#  `print_help()` / `parse_commandline()` / `die()` / `begins_with_
#  short_option()` HELPERS + NO RUNTIME LIBRARY DEPENDENCY in the
#  output (fully self-contained portable bash script) — corpus's
#  **first documented build-time-code-generator Bash CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 126;
#  Bash added to the documented-CLI-language set.
#
#  Surface (verbatim from `bin/argbash-init` macro comments —
#  argbash-init is itself argbash-generated, demonstrating dogfooding):
#
#  Options:
#    -s, --separate                 Separate parsing logic
#                                   (INCREMENTAL: specify twice for
#                                   complete separation; level 0/1/2)
#        --hints                    Write hints to the script template
#        --no-hints                 Disable hints (BOOLEAN, default off)
#        --pos NAME                 Add a single-valued positional
#                                   argument (REPEATABLE)
#        --opt NAME                 Add a single-valued optional
#                                   argument (REPEATABLE)
#        --opt-bool NAME            Add an optional boolean argument
#                                   (REPEATABLE)
#    -m, --mode MODE                Template feature level:
#                                   default | full | minimal
#                                   (default: default; CHOICES enforced
#                                   via ARG_TYPE_GROUP_SET)
#    -v, --version                  Print version (argbash-init v2.x.x)
#    -h, --help                     Show help
#
#  Positional:
#    OUTPUT                         Name of output template file
#                                   (default: `-` for stdout)
#
#  Example workflow:
#    argbash-init --pos input --opt output --opt-bool verbose \
#      --mode default mytool.m4
#    argbash mytool.m4 -o mytool.sh
#    chmod +x mytool.sh
#    ./mytool.sh --help                      # auto-generated help
#    ./mytool.sh --output=foo.txt --verbose foo.in
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also bash CLI generators or argbash users):
#    - argbash (IN CORPUS via _argbash — the MAIN argbash binary;
#      this _argbash-init completion covers the bootstrap helper)
#    - bashly (DannyBen/bashly aka bashly-framework/bashly — Ruby-based
#      bash CLI generator that consumes YAML config and produces bash
#      output; FUTURE candidate but bashly is itself a Ruby tool not
#      Bash, so its CLI surface documents Ruby Thor/etc. not Bash)
#    - shellcheck (IN CORPUS via _shellcheck — bash linter, not a CLI
#      generator)
#    - getopt (POSIX util-linux getopt — enhanced getopt for bash; IN
#      CORPUS via getopt (likely stock); different paradigm — runtime
#      parsing helper, not code generator)
#    - sscg / kubler / scirius / openscap (use argbash but smaller
#      user bases for their release/CI scripts only, not main binaries)
# ============================================================================

_argbash-init() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '*'{-s,--separate}'[separate parsing logic (incremental; specify twice)]' \
    '--hints[write hints to the script template]' \
    '--no-hints[disable hints]' \
    '*--pos=[add single-valued positional argument]:name' \
    '*--opt=[add single-valued optional argument]:name' \
    '*--opt-bool=[add optional boolean argument]:name' \
    '(-m --mode)'{-m,--mode}'=[template feature level]:mode:(default full minimal)' \
    '(-v --version)'{-v,--version}'[print argbash-init version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:output template file:_files'
}

_argbash-init "$@"
