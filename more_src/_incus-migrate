#compdef incus-migrate
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/incus-migrate.1.html
# create an Incus instance from an existing physical or virtual machine

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--rsync-args=[extra arguments to pass to rsync]:args' \
  '--version[print version number]' && ret=0

return ret
