#compdef prismlauncher prism-launcher
# Documentation: https://man.archlinux.org/search?q=prismlauncher
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --dir)'{-d+,--dir=}'[application data directory]:dir:_files -/' \
  '(-l --launch)'{-l+,--launch=}'[launch instance]:instance:' \
  '(-a --profile)'{-a+,--profile=}'[account profile name]:profile:' \
  '(-s --server)'{-s+,--server=}'[server address to join]:server:' \
  '(-w --world)'{-w+,--world=}'[world name to load]:world:' \
  '(-i --import)'{-i+,--import=}'[import instance from URL or file]:source:_files' \
  '(-I --import-target)'{-I+,--import-target=}'[import target name]:name:' \
  '(-S --show)'{-S+,--show=}'[show instance window]:instance:' \
  '(-z --zip)'{-z+,--zip=}'[import zip file]:file:_files -g "*.zip"' \
  '(-O --offline)'{-O+,--offline=}'[launch offline with name]:name:' \
  '(-A --capture)'{-A+,--capture=}'[capture launcher logs to file]:file:_files' \
  '(-n --gameVersion)'{-n+,--gameVersion=}'[game version filter]:version:' \
  '--alive[show alive in stdout]' \
  '*: :' && ret=0

return ret
