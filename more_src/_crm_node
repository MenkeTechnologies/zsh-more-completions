#compdef crm_node

# Pacemaker crm_node: control and query cluster nodes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-n --name)'{-n,--name}'[print local node name]' \
  '(-N --name-for-id)'{-N,--name-for-id=}'[print name for given node ID]:id:' \
  '(-i --cluster-id)'{-i,--cluster-id}'[print local cluster node ID]' \
  '(-l --list)'{-l,--list}'[list cluster members]' \
  '(-p --partition)'{-p,--partition}'[list current partition members]' \
  '(-e --epoch)'{-e,--epoch}'[show cluster membership epoch]' \
  '(-q --quorum)'{-q,--quorum}'[show whether the local node has quorum]' \
  '(-R --remove)'{-R,--remove=}'[remove node from cluster]:node:' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '*::crm_node args:_files' && ret=0
return ret
