#compdef crm_node
# Documentation: https://www.mankier.com/8/crm_node
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_node: cluster node admin (list, remove, quorum, name lookup)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-commands[show command help]' \
  '(- *)--help-additional[show additional options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-Q --quiet)'{-Q,--quiet}'[be less descriptive in output]' \
  '--output-as=[output format]:fmt:(text xml)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '(-i --cluster-id)'{-i,--cluster-id}'[display this node cluster id]' \
  '(-l --list)'{-l,--list}'[display all known cluster members]' \
  '(-n --name)'{-n,--name}'[display the name used by the cluster for this node]' \
  '(-p --partition)'{-p,--partition}'[display members of this partition]' \
  '(-q --quorum)'{-q,--quorum}'[display 1 if partition has quorum, else 0]' \
  '(-N --name-for-id)'{-N+,--name-for-id=}'[display node name for cluster id]:id:' \
  '(-R --remove)'{-R+,--remove=}'[remove a stopped node from Pacemaker config]:node:' \
  '(-f --force)'{-f,--force}'[force operation]' && ret=0
return ret
