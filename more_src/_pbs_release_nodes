#compdef pbs_release_nodes
# PBS: release sister hosts or vnodes assigned to a PBS job

local ret=1

_arguments -s \
  '(-k)-a[release all job vnodes not on the primary execution host]' \
  '-j+[job or subjob whose vnodes are to be released]:job id' \
  '(-a)-k+[number of sister hosts or select statement of vnodes to keep]:keep' \
  '--version[print PBS version information and exit]' \
  '*:vnode:_message "vnode"' && ret=0

return ret
