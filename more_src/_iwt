#compdef iwt
# Documentation: https://github.com/Interested-Deving-1896/incus-windows-toolkit
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: prior file contained the entire iwt.sh source script pasted in
# verbatim (3105 lines); rewritten as a real completion from the
# main() dispatch and show_help() command table in cli/iwt.sh.

# Zsh completion for iwt - Incus Windows Toolkit

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'image:build, pack, and manage Windows VM images'
  'vm:create, start, stop, and manage Windows VMs'
  'disk:live disk image resize (embiggen-disk)'
  'rescue:build and inject Buildroot rescue environments'
  'guest:guest tool management (SvcGuest, serviceman, SrvLib)'
  'apps:Windows app store (install app bundles via winget)'
  'cloud:sync backups to cloud storage (S3, B2, rclone)'
  'cloud-sync:sync backups to cloud storage (alias of cloud)'
  'demo:manage a local incus-demo-server instance'
  'winesapos:fetch, import, and launch winesapOS gaming VMs'
  'fleet:multi-VM orchestration (start-all, stop-all, backup-all)'
  'profiles:install and manage Incus VM profiles'
  'remoteapp:launch Windows apps as seamless Linux windows'
  'tui:launch interactive terminal UI'
  'dashboard:launch web monitoring dashboard'
  'publish:create and manage Incus images from a Windows VM'
  'setup-rootless:configure the system for rootless VM operation'
  'host-exec:run a host command from inside the Windows VM'
  'update:check for updates and self-update'
  'doctor:check system prerequisites'
  'config:manage IWT configuration'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'iwt command' commands && ret=0
    ;;
  args)
    case $line[1] in
      image)
        local -a c=(import build pack list show delete)
        _describe -t subcommands 'image subcommand' c && ret=0
        ;;
      vm)
        local -a c=(
          create delete list show start stop restart console
          template snapshot share net usb gpu assemble upgrade storage
        )
        _describe -t subcommands 'vm subcommand' c && ret=0
        ;;
      disk)
        local -a c=(resize)
        _describe -t subcommands 'disk subcommand' c && ret=0
        ;;
      rescue)
        local -a c=(build inject)
        _describe -t subcommands 'rescue subcommand' c && ret=0
        ;;
      guest)
        local -a c=(serviceman install status)
        _describe -t subcommands 'guest subcommand' c && ret=0
        ;;
      demo)
        local -a c=(install config start stop restart status logs url test help)
        _describe -t subcommands 'demo subcommand' c && ret=0
        ;;
      winesapos)
        local -a c=(fetch import launch list versions help)
        _describe -t subcommands 'winesapos subcommand' c && ret=0
        ;;
      profiles)
        local -a c=(list show apply remove)
        _describe -t subcommands 'profiles subcommand' c && ret=0
        ;;
      publish)
        local -a c=(create list delete)
        _describe -t subcommands 'publish subcommand' c && ret=0
        ;;
      config)
        local -a c=(show edit get set)
        _describe -t subcommands 'config subcommand' c && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
