#compdef sushape
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/decon_shaping/sushape.c
# Wiener shaping filter

local ret=1

_arguments -s -S \
  'w=[w]:w:' \
  'wfile=[wfile]:wfile:' \
  'd=[d]:d:' \
  'dfile=[dfile]:dfile:' \
  'dt=[dt]:dt:' \
  'nshape=[nshape]:nshape:' \
  'pnoise=[pnoise]:pnoise:' \
  'showshaper=[showshaper]:showshaper:' \
  'verbose=[verbose]:verbose:' \
  'showwshaper=[showwshaper]:showwshaper:' \
  '*:file:_files' && ret=0

return ret
