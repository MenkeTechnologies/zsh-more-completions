#compdef rate-mirrors

# Zsh completion for rate-mirrors - find the fastest mirrors for your Linux distro

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'arch:rate Arch Linux mirrors'
  'manjaro:rate Manjaro mirrors'
  'endeavouros:rate EndeavourOS mirrors'
  'artix:rate Artix Linux mirrors'
  'rebornos:rate RebornOS mirrors'
  'cachyos:rate CachyOS mirrors'
  'chaotic-aur:rate Chaotic-AUR mirrors'
  'stdin:rate mirrors from stdin'
)

_arguments -s -S \
  '1:command:->command' \
  '--allow-unencrypted[allow unencrypted (HTTP) connections]' \
  '--concurrency=[number of concurrent tests]:number' \
  '--country=[only test mirrors from specified countries]:countries' \
  '--country-neighbors-per-country=[add N neighbor countries]:count' \
  '--country-test-mirrors-per-country=[number of mirrors to test per country]:count' \
  '--disable-comments[do not write comments to output]' \
  '--disable-comments-in-list[do not write comments inside mirror list]' \
  '--entry-country=[entry country code (for geo-IP)]:country code' \
  '--eps=[epsilon for comparison]:value' \
  '--fetch-mirrors-timeout=[timeout for fetching mirror list]:seconds' \
  '--max-delay=[max mirror synchronization delay]:hours' \
  '--max-jumps=[max number of jumps to a mirror]:jumps' \
  '--min-bytes-per-mirror=[minimum bytes to download per mirror]:bytes' \
  '--min-per-mirror=[minimum time to test per mirror]:seconds' \
  '--per-mirror-timeout=[per-mirror test timeout]:seconds' \
  '--protocol=[only test mirrors with specified protocol]:protocol:(http https)' \
  '--save=[save output to file]:file:_files' \
  '--sort=[sort mirrors by]:criteria:(rate delay score)' \
  '--top-mirrors-number-to-retest=[retest top N mirrors]:number' \
  '--completion=[generate shell completion]:shell:(bash zsh fish)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rate-mirrors command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (arch)
        _arguments -s -S \
          '--completion=[generate shell completion]:shell:(bash zsh fish)' && ret=0
        ;;
      (stdin)
        _arguments -s -S \
          '--path-to-test=[path to download from each mirror]:path' \
          '--comment-prefix=[prefix for comments in mirror list]:prefix' && ret=0
        ;;
    esac
    ;;
esac

return ret
