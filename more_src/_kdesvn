#compdef kdesvn

# kdesvn: KDE Subversion client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-l[open log dialog]:url:' \
  '--log=[open log dialog]:url:' \
  '-d[start diff against]:url:' \
  '--diff=[start diff against]:url:' \
  '--clog[show changelog window]' \
  '--rev=[revision]:rev:' \
  '*:repo URL / working copy:_files' && ret=0
return ret
