#compdef getST getST.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-spn[target SPN]:spn:' \
  '-impersonate[user to impersonate]:user:' \
  '-ts[add timestamp to output]' \
  '-debug[enable debug output]' \
  '-hashes[NTLM hashes (LMHASH\:NTHASH)]:hashes:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos authentication]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[domain controller IP]:ip:_hosts' \
  '-additional-ticket[additional ticket for S4U2Proxy]:file:_files' \
  '-force-forwardable[force forwardable flag]' \
  '-self[only perform S4U2Self]' \
  '1:target (domain/username\:password):' \
  && ret=0

return ret
