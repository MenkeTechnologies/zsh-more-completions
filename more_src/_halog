#compdef halog
# Documentation: https://docs.haproxy.org/3.2/management.html
# HAProxy log statistics reporter (reads HAProxy logs from stdin)

local ret=1

_arguments -s \
  '(-h)-h[show help]' \
  '-H[only match lines containing HTTP logs (ignore TCP)]' \
  '-Q[only match queued requests (any queue)]' \
  '-QS[only match queued requests (server queue)]' \
  '-e[only match lines with errors (status 5xx or negative)]' \
  '-E[only match lines without any error]' \
  '-rt[only match response times larger than value]:ms:' \
  '-RT[only match response times smaller than value]:ms:' \
  '-tcn[only match requests with this termination code]:code:' \
  '-TCN[only match requests without this termination code]:code:' \
  '-hs[only match status codes within min..max]:range:' \
  '-HS[only match status codes not within min..max]:range:' \
  '-v[invert the filtering condition]' \
  '-q[do not report errors or warnings]' \
  '-m[limit output to this number of lines]:lines:' \
  '-c[only count lines that would have been printed]' \
  '-pct[output connect and response time percentiles]' \
  '-st[output number of requests per HTTP status code]' \
  '-cc[output number of requests per cookie code]' \
  '-tc[output number of requests per termination code]' \
  '-srv[output statistics per server (time, requests, errors)]' \
  '-u[output statistics per URL]' \
  '-uc[sort URL stats by request count]' \
  '-ue[sort URL stats by error count]' \
  '-ua[sort URL stats by average response time]' \
  '-ut[sort URL stats by average total time]' \
  '-uao[average response time on valid requests]' \
  '-uto[average total time on valid requests]' \
  '-uba[average bytes returned]' \
  '-ubt[total bytes returned]' \
  '*:file:_files' && ret=0

return ret
