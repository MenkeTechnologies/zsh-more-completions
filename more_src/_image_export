#compdef image_export
# Zsh completion for Plaso image_export tool

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--source=[path to source image]:source:_files' \
  '(-w --write)'{-w,--write}'[destination directory for exported files]:directory:_files -/' \
  '--date-filter=[date filter in format type,start,end]:filter:' \
  '--extension-filter=[comma separated list of file extensions to export]:extensions:' \
  '--names-filter=[comma separated list of file names to export]:names:' \
  '--signature-filter=[comma separated list of file signatures to export]:signatures:' \
  '--include-duplicates[include duplicate files in export]' \
  '--logfile=[path to log file]:file:_files' \
  '--status_view=[status view mode]:view:(linear none window)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:source:_files' && ret=0

return ret
