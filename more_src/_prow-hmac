#compdef prow-hmac
# _prow-hmac — generate or rotate Prow webhook HMAC tokens (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/hmac/main.go (flag).

_prow-hmac() {
    _arguments \
        '-kubeconfig-context=[Prow cluster kubeconfig context]:ctx:' \
        '-dry-run=[dry run]:val:(true false)' \
        '-hook-url=[Prow hook external webhook URL]:url:_urls' \
        '-hmac-token-secret-namespace=[namespace of hmac-token secret]:ns:' \
        '-hmac-token-secret-name=[name of hmac-token secret]:name:' \
        '-hmac-token-key=[key of hmac token in secret]:key:' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files'
}

_prow-hmac "$@"
