#compdef tiptop

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[batch mode, dump info and exit]' \
  '-c[path to configuration file]:config file:_files' \
  '-d[delay between refreshes in seconds]:seconds' \
  '-H[show threads]' \
  '-n[number of iterations before exit]:count' \
  '-p[monitor specific PIDs]:PID' \
  '-s[select sort field on startup]:field' \
  '-u[show only processes for user]:user:_users' \
  '-U[show only processes for user (by UID)]:UID' \
  '-w[output width]:columns' \
  '--help[display help]' \
  '--version[display version]' && ret=0

return ret
