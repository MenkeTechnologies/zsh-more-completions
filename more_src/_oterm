#compdef oterm
# Documentation: https://github.com/ggozad/oterm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for oterm - terminal client for LLMs (Ollama and others)
# Flags sourced from src/oterm/cli/oterm.py (typer.Option definitions).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--help[show help]' \
  '--upgrade[upgrade the database]' \
  '--config[print configuration location]' \
  '--db[print sqlite database file location]' \
  '--data-dir[print data directory path]' && ret=0

return ret
