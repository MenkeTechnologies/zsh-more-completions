#compdef oterm
# Documentation: https://man.archlinux.org/search?q=oterm
# Reference accessed: 2026-05-16

# Zsh completion for oterm - terminal UI for Ollama

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
