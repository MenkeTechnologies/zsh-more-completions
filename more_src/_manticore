#compdef manticore manticore-verifier
# Documentation: https://man.archlinux.org/search?q=manticore
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '--workspace=[workspace directory]:dir:_files -/' \
  '--quick-mode[fast exploration: disable detectors and gas]' \
  '--no-colors[disable colored output]' \
  '--config=[YAML config file]:file:_files' \
  '--core.timeout=[max execution seconds]:secs:' \
  '--core.procs=[parallel exploration procs]:n:' \
  '--core.compress_states=[compress states]:bool:(true false)' \
  '--smt.timeout=[SMT timeout secs]:secs:' \
  '--smt.solver=[SMT solver]:s:(z3 cvc4 yices boolector)' \
  '--smt.memory=[SMT memory MB]:mb:' \
  '--evm.defaultgas=[default gas]:n:' \
  '--evm.oog=[out of gas mode]:m:(complete pedantic concrete ignore)' \
  '--evm.txfail=[tx fail mode]:m:(optimistic pessimistic both)' \
  '--evm.calldata_max_offset=[max calldata offset]:n:' \
  '--evm.calldata_max_size=[max calldata size]:n:' \
  '--evm.ignore_balance[ignore balance]' \
  '--contract=[contract name]:name:' \
  '--solc-remaps=[solc remappings]:remaps:' \
  '--solc-args=[args to solc]:args:' \
  '--solc-bin=[path to solc]:path:_files' \
  '--no-testcases[do not generate test cases]' \
  '--only-alive-testcases[only alive test cases]' \
  '--avoid-constant[avoid constant function calls]' \
  '--exclude-all[skip all detectors]' \
  '--detect-all[run all detectors]' \
  '--exclude=[exclude detector(s) csv]:list:' \
  '--list-detectors[list available detectors]' \
  '--limit-loops[limit symbolic loops]' \
  '--no-truncate[do not truncate strings]' \
  '--profile[enable profiler]' \
  '--policy=[exploration policy]:p:(random uncovered round-robin)' \
  '*:contract or binary:_files' && ret=0

return ret
