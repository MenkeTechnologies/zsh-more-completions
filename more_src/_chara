#compdef chara

autoload -U is-at-least

_chara() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_chara_commands" \
"*::: :->chara" \
&& ret=0
    case $state in
    (chara)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:chara-command-$line[1]:"
        case $line[1] in
            (say)
_arguments "${_arguments_options[@]}" : \
'-t+[Choose bubble type to use. Default to round]:BUBBLE_TYPE:(think round cowsay ascii unicode)' \
'--bubble-type=[Choose bubble type to use. Default to round]:BUBBLE_TYPE:(think round cowsay ascii unicode)' \
'-w+[Max width of speech bubble. Default to terminal width]:WIDTH:_default' \
'--width=[Max width of speech bubble. Default to terminal width]:WIDTH:_default' \
'-c+[Choose built-in chara]:CHARA:(aya chocobo cirno clefairy cow eevee ferris ferris1 flareon goldeen growlithe kirby kitten mario mew nemo pikachu piplup psyduck remilia-scarlet seaking togepi tux wartortle)' \
'--chara=[Choose built-in chara]:CHARA:(aya chocobo cirno clefairy cow eevee ferris ferris1 flareon goldeen growlithe kirby kitten mario mew nemo pikachu piplup psyduck remilia-scarlet seaking togepi tux wartortle)' \
'-f+[Choose custom chara file]:FILE:_files' \
'--file=[Choose custom chara file]:FILE:_files' \
'-r[Choose random chara]' \
'--random[Choose random chara]' \
'-a[Print all built-in charas]' \
'--all[Print all built-in charas]' \
'-h[Print help]' \
'--help[Print help]' \
'*::message -- Messages that chara want to say/think. If empty, read from standard input:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-s+[Shell syntax to use. Infer current shell when missing, fallback to bash]:SHELL:(bash elvish fish powershell zsh)' \
'--shell=[Shell syntax to use. Infer current shell when missing, fallback to bash]:SHELL:(bash elvish fish powershell zsh)' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(print)
_arguments "${_arguments_options[@]}" : \
'-c+[Choose built-in chara]:CHARA:(aya chocobo cirno clefairy cow eevee ferris ferris1 flareon goldeen growlithe kirby kitten mario mew nemo pikachu piplup psyduck remilia-scarlet seaking togepi tux wartortle)' \
'--chara=[Choose built-in chara]:CHARA:(aya chocobo cirno clefairy cow eevee ferris ferris1 flareon goldeen growlithe kirby kitten mario mew nemo pikachu piplup psyduck remilia-scarlet seaking togepi tux wartortle)' \
'-f+[Choose custom chara file]:FILE:_files' \
'--file=[Choose custom chara file]:FILE:_files' \
'-r[Choose random chara]' \
'--random[Choose random chara]' \
'-a[Print all built-in charas]' \
'--all[Print all built-in charas]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(convert)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':image -- PNG file path:_files' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_chara__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:chara-help-command-$line[1]:"
        case $line[1] in
            (say)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(print)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(convert)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_chara_commands] )) ||
_chara_commands() {
    local commands; commands=(
'say:Make the character say something. Default to cow' \
'completions:Generate completions for shell. Default to current shell' \
'list:List all built-in charas' \
'print:Print only the character. Default to cow' \
'convert:TODO\: Convert pixel-arts PNG to chara files' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'chara commands' commands "$@"
}
