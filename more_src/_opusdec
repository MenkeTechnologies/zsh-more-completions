#compdef opusdec

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--quiet[quiet output]' \
  '--rate=[output sample rate]:rate:' \
  '--gain=[apply gain dB]:db:' \
  '--no-dither[disable dithering]' \
  '--float[output 32-bit float]' \
  '--force-wav[force WAV output]' \
  '--packet-loss=[simulate packet loss percent]:pct:' \
  '--save-range=[save range coder data]:file:_files' \
  '*:input:_files'
