#compdef create-farm
# Documentation: https://www.npmjs.com/package/create-farm
# Reference accessed: 2026-05-24
# Verified: npx create-farm --help.

# Zsh completion for create-farm - Farm bundler project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-m --manager)'{-m,--manager=}'[package manager]:manager:' \
  '(-t --template)'{-t,--template=}'[project template]:template:' \
  '(-f --force)'{-f,--force}'[force overwrite existing files]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':project name:' && ret=0

return ret
