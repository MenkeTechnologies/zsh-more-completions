#compdef s6-notify-fd-from-socket s6-notify-socket-from-fd s6-notifyoncheck
# Documentation: source-direct extraction from upstream skarnet/s6
# src/supervision/s6-notify-{fd-from-socket,socket-from-fd}.c +
# s6-notifyoncheck.c USAGE strings + skalibs GOL_main gol_bool +
# gol_arg tables (these binaries use the long-options getopt
# variant rather than subgetopt_r).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 readiness-notification R123b — 3-stem multi-binary
# harvest of the s6 service-readiness notification adapters. These
# bridge between the s6 "write to notification-fd" readiness
# protocol and the sd_notify(3)-style UNIX socket protocol used by
# systemd-aware daemons. Sister tools to the supervision-tree
# wait/state-listen family in `_s6-svdt` (R123).

case $service in

  s6-notify-fd-from-socket)
    # Adapter: receive sd_notify-style READY=1 datagram on a UNIX
    # socket, then signal readiness on the s6 notification-fd.
    # Useful for wrapping systemd-aware daemons under s6.
    _arguments -s -S \
      '(--doublefork)'{-f,--no-doublefork}'[single-fork the adapter helper (default is double-fork)]' \
      '(-f --no-doublefork)--doublefork[double-fork the adapter helper (default)]' \
      '(-3 --notification-fd)'{-3+,--notification-fd=}'[notification fd number (default: read from ./notification-fd)]:fd:' \
      '(-t --timeout)'{-t+,--timeout=}'[max time to wait for the sd_notify datagram in ms]:ms:' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-notify-socket-from-fd)
    # Inverse adapter: receive the s6 notification-fd readiness
    # signal, then emit a systemd-style sd_notify READY=1 datagram
    # on a UNIX socket. Useful when running an s6-supervised daemon
    # under a systemd-aware parent supervisor.
    _arguments -s -S \
      '(--doublefork)'{-f,--no-doublefork}'[single-fork the adapter helper (default is double-fork)]' \
      '(-f --no-doublefork)--doublefork[double-fork the adapter helper (default)]' \
      '(-k --keep-environment)'{-k,--keep-environment}'[do NOT unset NOTIFY_SOCKET before exec of prog]' \
      '(-d --notification-fd)'{-d+,--notification-fd=}'[notification fd number to read from (default 1)]:fd:' \
      '(-t --timeout)'{-t+,--timeout=}'[max time to wait for the readiness signal in ms]:ms:' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-notifyoncheck)
    # Wrap a long-running service with a periodic external check.
    # Repeatedly runs a check program; signals s6 readiness only
    # after the first successful check. Used for services whose
    # readiness cannot be self-reported (e.g. databases).
    _arguments -s -S \
      '(-d --doublefork)'{-d,--doublefork}'[double-fork the check helper (default is single-fork)]' \
      '(-3 --notification-fd)'{-3+,--notification-fd=}'[notification fd number (default: read from ./notification-fd)]:fd:' \
      '(-s --initial-sleep)'{-s+,--initial-sleep=}'[ms to wait before first check (default 10)]:ms:' \
      '(-T --global-timeout)'{-T+,--global-timeout=}'[ms across all check attempts (default 0=infinite)]:ms:' \
      '(-t --local-timeout)'{-t+,--local-timeout=}'[ms per individual check attempt]:ms:' \
      '(-w --waiting-time)'{-w+,--waiting-time=}'[ms between check attempts (default 1000)]:ms:' \
      '(-n --tries)'{-n+,--tries=}'[max number of check attempts (default 0=infinite)]:tries:' \
      '(-c --check-program)'{-c+,--check-program=}'[check program (execline string; requires S6_USE_EXECLINE)]:execline-script:' \
      '*:program and arguments:_command_names -e'
    ;;

esac
