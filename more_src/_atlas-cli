#compdef atlas-cli atlas

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'accessLists:manage IP allowlist'
  'accessLogs:return access logs for a cluster'
  'alerts:manage alerts'
  'api:Atlas Administration API'
  'auditing:database auditing settings'
  'auth:manage CLI authentication'
  'backups:manage cloud backups'
  'cloudProviders:manage cloud provider access via AWS IAM'
  'clusters:manage clusters'
  'completion:generate autocompletion scripts'
  'config:configure and manage user profiles'
  'customDbRoles:manage custom DB roles'
  'customDns:manage DNS for AWS clusters'
  'dataFederation:data federation management'
  'dbusers:manage database users'
  'deployments:manage deployments'
  'events:manage organization/project events'
  'federatedAuthentication:Atlas Federated Authentication'
  'integrations:configure third-party integrations'
  'kubernetes:manage Kubernetes resources'
  'liveMigrations:manage Live Migration to Atlas'
  'local:manage MongoDB Atlas local instances'
  'logs:download host logs'
  'maintenanceWindows:manage maintenance windows'
  'metrics:get MongoDB process metrics'
  'networking:manage network peering'
  'organizations:manage Atlas organizations'
  'performanceAdvisor:analyze slow queries'
  'plugin:manage AtlasCLI plugins'
  'privateEndpoints:manage Atlas private endpoints'
  'processes:manage MongoDB processes'
  'projects:manage Atlas projects'
  'security:manage security configuration'
  'setup:login, authenticate, create, and access clusters'
  'streams:manage Atlas Stream Processing'
  'teams:manage Atlas teams'
  'users:manage Atlas users'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*--profile=[user profile]:profile:' \
  '*-P+[user profile]:profile:' \
  '--debug[debug output]' \
  '*--output=[output format]:format:(json json-path go-template go-template-file)' \
  '-o+[output format]:format:(json json-path go-template go-template-file)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'atlas subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (clusters)
        _values 'clusters action' \
          'create' 'delete' 'describe' 'list' 'pause' 'start' 'update' 'upgrade' \
          'connectionStrings' 'failover' 'indexes' 'onlineArchives' 'sampleData' \
          'searchIndexes' 'tags' 'watch' 'advancedSettings' 'availableRegions' \
          'restarts' 'cloudBackups' 'restores' && ret=0
        ;;
      (projects)
        _values 'projects action' \
          'create' 'delete' 'describe' 'list' 'update' 'apiKeys' 'invitations' \
          'settings' 'teams' 'users' && ret=0
        ;;
      (organizations|orgs)
        _values 'organizations action' \
          'create' 'delete' 'describe' 'list' 'apiKeys' 'invitations' 'users' && ret=0
        ;;
      (dbusers)
        _values 'dbusers action' \
          'create' 'delete' 'describe' 'list' 'update' 'certs' && ret=0
        ;;
      (alerts)
        _values 'alerts action' 'acknowledge' 'describe' 'list' 'unacknowledge' 'settings' && ret=0
        ;;
      (auth)
        _values 'auth action' \
          'login' 'logout' 'register' 'whoami' && ret=0
        ;;
      (backups)
        _values 'backups action' \
          'snapshots' 'restores' 'schedule' 'compliancePolicy' \
          'exports' && ret=0
        ;;
      (kubernetes)
        _values 'kubernetes action' \
          'config' 'operator' && ret=0
        ;;
      (deployments)
        _values 'deployments action' \
          'connect' 'delete' 'list' 'logs' 'pause' 'search' 'setup' 'start' && ret=0
        ;;
      (config)
        _values 'config action' \
          'delete' 'describe' 'edit' 'list' 'rename' 'set' 'show' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'fish' 'zsh' 'powershell' && ret=0
        ;;
      (setup)
        _arguments \
          '--clusterName=[name of cluster]:name:' \
          '--provider=[cloud provider]:provider:(AWS GCP AZURE)' \
          '--region=[region]:region:' \
          '--username=[DB user]:user:_users' \
          '--password=[DB password]:password:' \
          '--currentIp[add current IP to access list]' \
          '--accessListIp=[allowlist IP]:ip:' \
          '--mdbVersion=[MongoDB version]:version:' \
          '--tier=[cluster tier]:tier:(M0 M2 M5 M10 M20 M30 M40 M50 M60 M80 M140 M200 M300)' \
          '--watch[wait until ready]' && ret=0
        ;;
    esac
    ;;
esac

return ret
