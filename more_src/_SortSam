#compdef SortSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/SortSam.java
# Picard: sort a SAM/BAM/CRAM file by the requested order

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file to sort]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[sorted output file]:file:_files' \
  '(-SO --SORT_ORDER)'{-SO,--SORT_ORDER}'=[output sort order]:order:(queryname coordinate duplicate unsorted)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--COMPRESSION_LEVEL=[compression level for output]:n:' \
  '--MAX_RECORDS_IN_RAM=[records kept in RAM before spilling]:n:' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--CREATE_MD5_FILE=[create MD5 digest for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' \
  '--QUIET=[suppress job-summary info on stderr]:b:(true false)' && ret=0

return ret
