#compdef juicefs

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'format:format a volume'
  'config:change config of a volume'
  'mount:mount a volume'
  'umount:unmount a volume'
  'gateway:start an S3-compatible gateway'
  'webdav:start a WebDAV server'
  'sync:sync between two storage systems'
  'rmr:remove directories recursively'
  'mkdir:create directories with POSIX semantics'
  'info:show internal information for paths or inodes'
  'bench:run benchmarks on a path'
  'objbench:run benchmark on object storage'
  'gc:garbage collect unreferenced objects'
  'fsck:check consistency of a volume'
  'profile:show real-time performance statistics'
  'stats:show runtime statistics'
  'status:show status of a volume'
  'warmup:build cache for target directories/files'
  'dump:dump metadata into a JSON file'
  'load:load metadata from a previously dumped JSON file'
  'version:show version'
  'quota:manage directory quotas'
  'destroy:destroy an existing volume'
  'debug:collect and display system information'
  'clone:clone a file or directory'
  'summary:show tree summary of a directory'
  'compact:trigger compaction of slices'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --verbose --debug)'{-v,--verbose,--debug}'[enable debug log]' \
  '(-q --quiet)'{-q,--quiet}'[only warning and errors]' \
  '--trace[enable trace log]' \
  '--no-agent[disable pprof agent]' \
  '--pyroscope=[pyroscope address]:URL' \
  '--no-color[disable colors]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      format)
        _arguments \
          '--block-size=[block size in KiB]:size' \
          '--capacity=[volume capacity limit]:size' \
          '--inodes=[volume inode limit]:count' \
          '--compress=[compression algorithm]:algorithm:(none lz4 zstd)' \
          '--shards=[store slices into N shards]:count' \
          '--storage=[object storage type]:type:(file s3 gs wasabi oss cos obs bos ks3 qingstor ufile minio)' \
          '--bucket=[bucket URL]:URL' \
          '--access-key=[access key for object storage]:key' \
          '--secret-key=[secret key for object storage]:key' \
          '--encrypt-rsa-key=[RSA key for data encryption]:key file:_files' \
          '--trash-days=[number of days to keep deleted files]:days' \
          '--hash-prefix[add a hash prefix to name of objects]' \
          '--force[overwrite existing volume format]' \
          '--no-update[do not update existing volume]' \
          '1:metadata URL' \
          '2:volume name' && ret=0
        ;;
      mount)
        _arguments \
          '-d[run in background]' \
          '-o[FUSE mount options]:options' \
          '--attr-cache=[attribute cache timeout]:seconds' \
          '--entry-cache=[file entry cache timeout]:seconds' \
          '--dir-entry-cache=[directory entry cache timeout]:seconds' \
          '--enable-xattr[enable extended attributes]' \
          '--enable-ioctl[enable ioctl]' \
          '--root-squash=[map root to given uid\:gid]:uid\:gid' \
          '--prefetch=[number of blocks to prefetch]:count' \
          '--writeback[upload objects in background]' \
          '--upload-delay=[delayed upload duration]:duration' \
          '--cache-dir=[directory for cached objects]:directory:_files -/' \
          '--cache-size=[size of cached objects in MiB]:size' \
          '--free-space-ratio=[minimum free space ratio]:ratio' \
          '--cache-partial-only[cache only random/small reads]' \
          '--read-only[mount in read-only mode]' \
          '--no-bgjob[disable background jobs]' \
          '--open-cache=[open cache timeout]:seconds' \
          '--backup-meta=[backup metadata interval]:duration' \
          '--heartbeat=[heartbeat interval]:duration' \
          '--no-usage-report[do not send usage report]' \
          '--sub-dir=[mount a sub-directory]:path' \
          '--metrics=[address to export metrics]:address' \
          '--consul=[consul address]:address' \
          '--max-uploads=[maximum number of parallel uploads]:count' \
          '--max-deletes=[maximum number of parallel deletes]:count' \
          '--buffer-size=[read/write buffer size in MiB]:size' \
          '--get-timeout=[timeout for GET requests]:duration' \
          '--put-timeout=[timeout for PUT requests]:duration' \
          '1:metadata URL' \
          '2:mountpoint:_files -/' && ret=0
        ;;
      umount)
        _arguments \
          '(-f --force)'{-f,--force}'[force unmount even if busy]' \
          '1:mountpoint:_files -/' && ret=0
        ;;
      sync)
        _arguments \
          '--start=[first key to sync]:key' \
          '--end=[last key to sync]:key' \
          '--threads=[number of concurrent threads]:count' \
          '--http-port=[HTTP port for progress]:port' \
          '--update[update existing files]' \
          '--force-update[force update existing files]' \
          '--perms[preserve permissions]' \
          '--dirs[sync directories]' \
          '--dry[dry run]' \
          '--delete-src[delete source objects after sync]' \
          '--delete-dst[delete destination objects not in source]' \
          '--check-all[verify all files]' \
          '--check-new[verify new files]' \
          '--exclude=[exclude patterns]:patterns' \
          '--include=[include patterns]:patterns' \
          '--manager=[manager address]:address' \
          '--worker=[comma-separated worker addresses]:addresses' \
          '--bwlimit=[bandwidth limit in Mbps]:Mbps' \
          '--no-https[do not use HTTPS]' \
          '--limit=[limit number of objects]:count' \
          '1:source' \
          '2:destination' && ret=0
        ;;
      gc)
        _arguments \
          '--delete[delete garbage data]' \
          '--compact[compact all slices]' \
          '--threads=[number of threads]:count' \
          '1:metadata URL' && ret=0
        ;;
      fsck)
        _arguments \
          '--sync-dir-stat[sync directory stats]' \
          '--repair[repair found issues]' \
          '--recursive[check recursively]' \
          '--path=[path to check]:path' \
          '1:metadata URL' && ret=0
        ;;
      status|info|dump|load|config|destroy|quota|bench|profile|stats|warmup|debug|clone|summary|compact|gateway|webdav|rmr|mkdir|objbench|version)
        _arguments '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
