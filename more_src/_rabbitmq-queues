#compdef rabbitmq-queues
# Documentation: https://www.rabbitmq.com/docs/man/rabbitmq-queues.8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:general help'
  'grow:add replica on node for matching quorum queues'
  'rebalance:rebalance queue leader replicas'
  'shrink:remove replicas on node'
  'add_member:add quorum queue member'
  'delete_member:remove quorum queue member'
  'quorum_status:quorum status of queue'
  'peek:show details of message at position'
  'check_if_cluster_has_classic_queue_mirroring_policy:detect mirroring policies'
  'check_if_node_is_quorum_critical:health check for quorum-critical node'
)

_arguments -C \
  '-n+[node name]:node:' \
  '(-q --quiet)'{-q,--quiet}'[reduce messages]' \
  '(-s --silent)'{-s,--silent}'[suppress messages]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '(-l --longnames)'{-l,--longnames}'[FQDN node names]' \
  '--erlang-cookie=[shared secret]:cookie:' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rabbitmq-queues subcommand' subcommands && ret=0
    ;;
esac

return ret
