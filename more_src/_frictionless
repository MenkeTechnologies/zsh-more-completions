#compdef frictionless

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'describe:describe dataset'
  'extract:extract data'
  'transform:transform with pipeline'
  'validate:validate data'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--trusted[allow unsafe paths in config]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'frictionless command' commands && ret=0
    ;;
  (args)
    _arguments '*:path or options:_files' && ret=0
    ;;
esac

return ret
