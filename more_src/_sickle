#compdef sickle
# Documentation: https://github.com/najoshi/sickle
# windowed adaptive quality trimming for paired/single-end FASTQ

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    se\:"single-end read trimming"
    pe\:"paired-end read trimming"
  ))' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      se)
        _arguments -s -S \
          '(-f --fastq-file)'{-f,--fastq-file}'[input FASTQ file]:fastq:_files' \
          '(-o --output-file)'{-o,--output-file}'[output trimmed FASTQ file]:fastq:_files' \
          '(-t --qual-type)'{-t,--qual-type}'[quality value type]:type:(illumina solexa sanger)' \
          '(-q --qual-threshold)'{-q,--qual-threshold}'[quality threshold for trimming]:threshold:' \
          '(-l --length-threshold)'{-l,--length-threshold}'[minimum length threshold]:length:' \
          '(-x --no-fiveprime)'{-x,--no-fiveprime}'[disable 5-prime end trimming]' \
          '(-n --trunc-n)'{-n,--trunc-n}'[truncate reads at first N position]' \
          '(-g --gzip-output)'{-g,--gzip-output}'[enable gzipped output]' && ret=0
        ;;
      pe)
        _arguments -s -S \
          '(-f --pe-file1)'{-f,--pe-file1}'[first paired-end input file]:fastq:_files' \
          '(-r --pe-file2)'{-r,--pe-file2}'[second paired-end input file]:fastq:_files' \
          '(-c --pe-combo)'{-c,--pe-combo}'[combined/interleaved input file]:fastq:_files' \
          '(-o --output-pe1)'{-o,--output-pe1}'[first trimmed output file]:fastq:_files' \
          '(-p --output-pe2)'{-p,--output-pe2}'[second trimmed output file]:fastq:_files' \
          '(-m --output-combo)'{-m,--output-combo}'[single interleaved output file]:fastq:_files' \
          '(-M --output-combo-all)'{-M,--output-combo-all}'[interleaved output preserving pairs with N records]:fastq:_files' \
          '(-s --output-single)'{-s,--output-single}'[file for unpaired reads]:fastq:_files' \
          '(-t --qual-type)'{-t,--qual-type}'[quality value type]:type:(illumina solexa sanger)' \
          '(-q --qual-threshold)'{-q,--qual-threshold}'[quality threshold for trimming]:threshold:' \
          '(-l --length-threshold)'{-l,--length-threshold}'[minimum length threshold]:length:' \
          '(-x --no-fiveprime)'{-x,--no-fiveprime}'[disable 5-prime end trimming]' \
          '(-n --trunc-n)'{-n,--trunc-n}'[truncate reads at first N position]' \
          '(-g --gzip-output)'{-g,--gzip-output}'[enable gzipped output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
