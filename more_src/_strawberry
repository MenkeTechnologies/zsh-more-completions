#compdef strawberry

_arguments -s \
  '(-p --play)'{-p,--play}'[play]' \
  '(-t --play-pause)'{-t,--play-pause}'[play/pause]' \
  '(-u --pause)'{-u,--pause}'[pause]' \
  '(-s --stop)'{-s,--stop}'[stop]' \
  '(-q --stop-after-current)'{-q,--stop-after-current}'[stop after current]' \
  '(-r --previous)'{-r,--previous}'[previous]' \
  '(-f --next)'{-f,--next}'[next]' \
  '(-v --volume)'{-v,--volume}'=[volume %]:n:' \
  '--volume-up[volume up]' \
  '--volume-down[volume down]' \
  '--volume-increase-by=[%]:n:' \
  '--volume-decrease-by=[%]:n:' \
  '--seek-to=[seconds]:n:' \
  '--seek-by=[seconds]:n:' \
  '--restart-or-previous[restart or previous]' \
  '(-c --create)'{-c,--create}'=[playlist name]:name:' \
  '(-a --append)'{-a,--append}'[append]' \
  '(-l --load)'{-l,--load}'[load]' \
  '(-k --play-track)'{-k,--play-track}'=[track]:n:' \
  '(-o --show-osd)'{-o,--show-osd}'[show OSD]' \
  '(-y --toggle-pretty-osd)'{-y,--toggle-pretty-osd}'[toggle pretty OSD]' \
  '(-g --language)'{-g,--language}'=[lang]:lang:' \
  '--quiet[quiet]' \
  '--verbose[verbose]' \
  '--log-levels=[levels]:levels:' \
  '--version[show version]' \
  '*:url:_files'
