#compdef clojure-lsp

# Zsh completion for clojure-lsp - Language Server Protocol for Clojure

local curcontext="$curcontext" state line ret=1

_clojure-lsp_commands() {
  local -a commands=(
    'listen:start clojure-lsp as a language server (default)'
    'clean-ns:clean namespaces in project'
    'diagnostics:analyze project and find diagnostics'
    'format:format code following cljfmt rules'
    'rename:rename a symbol or a namespace'
    'references:find references of a symbol or a keyword'
    'dump:dump project analysis data'
    'server-info:show server configuration'
    'completion:generate shell completion script'
  )
  _describe -t commands 'clojure-lsp command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-s --settings)'{-s,--settings}'[settings in EDN format]:edn' \
  '--log-path[log file path]:file:_files' \
  '--trace[enable trace logs between client and server]' \
  '--trace-level[trace level]:level:(off messages verbose)' \
  '1: :_clojure-lsp_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      clean-ns|format|diagnostics)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --project-root)'{-p,--project-root}'[project root]:dir:_directories' \
          '(-n --namespace)'{-n,--namespace}'[namespaces to analyze]:namespace' \
          '--filenames[filenames to analyze]:files:_files' \
          '--ns-exclude-regex[exclude namespaces regex]:regex' \
          '--dry[dry run mode]' \
          '--raw[raw output]' && ret=0
        ;;
      rename)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --project-root)'{-p,--project-root}'[project root]:dir:_directories' \
          '--from[qualified symbol or namespace to rename]:from' \
          '--to[qualified symbol or namespace to rename to]:to' \
          '--dry[dry run mode]' && ret=0
        ;;
      references)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --project-root)'{-p,--project-root}'[project root]:dir:_directories' \
          '--from[qualified symbol to find references of]:from' && ret=0
        ;;
      dump)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --project-root)'{-p,--project-root}'[project root]:dir:_directories' \
          '--output[output format]:format:(edn json)' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
