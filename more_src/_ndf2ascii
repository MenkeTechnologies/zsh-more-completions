#compdef ndf2ascii
# Documentation: https://starlink.eao.hawaii.edu/docs/sun55.htx/sun55ss11.html
# CONVERT NDF2ASCII - convert an NDF to a text file

local ret=1

_arguments -C \
  'IN=[input NDF data structure]:NDF file:_files' \
  'OUT=[output text file]:text file:_files' \
  'COMP=[NDF component to copy]:component:(Data Quality Variance)' \
  'FITS=[write the FITS extension to the file start]:flag:(TRUE FALSE)' \
  'FIXED=[allocate fixed characters per data value]:flag:(TRUE FALSE)' \
  'NOPEREC=[number of data values per record (FIXED)]:count:' \
  'RECLEN=[maximum record length in bytes]:length:' \
  '*:NDF file:_files' && ret=0

return ret
