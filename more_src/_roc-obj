#compdef roc-obj
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/roc-obj.1.html
# roc-obj - ROCm code object extraction and scripting tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '(-t --target-id)'{-t,--target-id}'=[only extract code objects whose Target ID matches REGEXP]:regexp' \
  '(-o --outdir)'{-o,--outdir}'=[set the output directory]:dir:_files -/' \
  '(-d --disassemble)'{-d,--disassemble}'[disassemble extracted code objects]' \
  '*:executable:_files' && ret=0

return ret
