#compdef tidal-hifi
# Documentation: https://man.archlinux.org/search?q=tidal-hifi
# Reference accessed: 2026-05-16

# Zsh completion for tidal-hifi - TIDAL Hi-Fi desktop client

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--disable-gpu[disable GPU acceleration]' \
  '--enable-features[enable Chromium features]:features' \
  '--disable-features[disable Chromium features]:features' \
  '--no-sandbox[disable sandbox]' \
  '--proxy-server[set proxy server]:proxy'
