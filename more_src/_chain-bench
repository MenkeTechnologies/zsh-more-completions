#compdef chain-bench
# Documentation: https://github.com/aquasecurity/chain-bench
# Reference accessed: 2026-05-17
# Verified: aquasecurity/chain-bench upstream — single-subcommand
# tool (`scan`) with --repository-url, --access-token,
# --scm-platform, -o/--output, --output-type, --template, -v flags.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -v/--version (chain-bench has `version` subcommand and
# -v as verbosity); fabricated --config-path (real config flag is
# via env / scan flags).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'scan:scan repository for supply chain CIS benchmark'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chain-bench command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '--repository-url=[repository URL]:url:' \
          '--access-token=[SCM access token]:token:' \
          '--scm-platform=[SCM platform]:platform:(github gitlab)' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '--output-type=[output format]:type:(json table)' \
          '--template=[custom output template]:file:_files' \
          '-v+[verbosity level]:n:' && ret=0 ;;
    esac ;;
esac
return ret
