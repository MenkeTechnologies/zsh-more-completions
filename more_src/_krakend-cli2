#compdef krakend-cli2 krakend2
# _krakend-cli2 — KrakenD Linux Foundation krakend-cli2 CLI command-line frontend wrapping the KrakenD ultra-performant API Gateway with middleware Linux Foundation open-source written in Go originally extension of luraproject CNCF Sandbox API gateway aggregating multiple backends transforming responses caching rate-limiting auth-JWT mTLS Lua-plugins built-in-circuit-breaker run check check-plan audit help version completion validate run-loop in-memory routes-rate-limiting service-discovery (Linux Foundation KrakenD team Albert Lombarte Daniel Pérez, Go); cobra
# upstream: https://www.krakend.io/

_krakend-cli2() {
    local -a sub=(
        'check:check configuration validity'
        'check-plan:check enterprise plan'
        'audit:audit configuration'
        'help:show help'
        'run:run KrakenD server'
        'version:show version'
        'completion:generate shell completion'
        'validate:validate config syntax'
        'test-plugin:test a plugin'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug mode]' \
        '--debug[debug]' \
        '-c+[config file]:file:_files -g "krakend.json *.json *.yaml *.yml *.toml"' \
        '--config=+[file]:file:_files -g "krakend.json *.json *.yaml *.yml *.toml"' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--prefix=+[path]:str:' \
        '-l+[log level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--log-level=+[l]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '-f+[fmt]:str:' \
        '--format=+[fmt]:f:(json yaml toml)' \
        '-i[indent JSON]' \
        '--indent[indent]' \
        '-r[render config]' \
        '--render[render config]' \
        '-t+[plugin name]:str:' \
        '-s+[plugin scope]:str:' \
        '--severity=+[s]:s:(LOW MEDIUM HIGH CRITICAL)' \
        '--rules=+[rules]:str:' \
        '*-r+[rule]:str:' \
        '--rule=+[id]:str:' \
        '*--ignore=+[id]:str:' \
        '-x+[ignore rule]:str:' \
        '--ignore=+[ids]:str:' \
        '-o+[output]:o:(text json yaml)' \
        '--output=+[fmt]:f:(text json yaml)' \
        '--no-color[no color]' \
        '--lint-no-network[no network lint]' \
        '--lint-no-deprecation[no deprecation]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krakend subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                check|audit|validate) _arguments '*:file:_files -g "*.json *.yaml *.yml *.toml"' ;;
            esac
            ;;
    esac
}

_krakend-cli2 "$@"
