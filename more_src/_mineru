#compdef mineru
# Documentation: https://opendatalab.github.io/MinerU/usage/cli_tools/
# Open source tool to parse PDF and images into markdown and structured JSON

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --path)'{-p,--path}'=[input file path or directory]:path:_files' \
  '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
  '--api-url=[MinerU FastAPI base URL]:url:' \
  '(-m --method)'{-m,--method}'=[parsing method]:method:(auto txt ocr)' \
  '(-b --backend)'{-b,--backend}'=[parsing backend]:backend:(pipeline vlm-engine hybrid-engine vlm-http-client hybrid-http-client)' \
  '--effort=[hybrid parsing effort]:effort:(medium high)' \
  '(-l --lang)'{-l,--lang}'=[document language]:lang:' \
  '(-u --url)'{-u,--url}'=[OpenAI-compatible backend URL]:url:' \
  '(-s --start)'{-s,--start}'=[starting page number]:page:' \
  '(-e --end)'{-e,--end}'=[ending page number]:page:' \
  '(-f --formula)'{-f,--formula}'=[enable formula parsing]:bool:(true false)' && ret=0

return ret
