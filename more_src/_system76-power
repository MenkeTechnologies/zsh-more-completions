#compdef system76-power
# Documentation: https://man.archlinux.org/search?q=system76-power
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'daemon:run system76-power daemon'
  'profile:query or set power profile'
  'graphics:graphics management'
  'charge-thresholds:set battery charge thresholds'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[no output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'system76-power command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (profile) _values 'profile' 'battery' 'balanced' 'performance' && ret=0 ;;
      (graphics) _values 'subcommand' 'switchable' 'integrated' 'nvidia' 'hybrid' 'compute' 'power' && ret=0 ;;
      (charge-thresholds)
        _arguments \
          '--list-profiles[list profiles]' \
          '--profile=[profile name]:p:(full_charge balanced max_lifespan)' \
          '*: :' && ret=0 ;;
    esac ;;
esac

return ret
