#compdef tetview
# Documentation: https://wias-berlin.de/software/tetgen/tetview.switches.html
# TetView: visualization tool for TetGen meshes and piecewise linear complexes

local ret=1

_arguments -s -S \
  '-X+[x position of the left-top of the window in pixels]:x:' \
  '-Y+[y position of the left-top of the window in pixels]:y:' \
  '-W+[width of the window in pixels (default 500)]:width:' \
  '-V[verbose mode: each command outputs more information]' \
  '-Q[no terminal output unless an error occurs]' \
  '*:mesh file:_files -g "*.(node|poly|smesh|ele|face)"' && ret=0

return ret
