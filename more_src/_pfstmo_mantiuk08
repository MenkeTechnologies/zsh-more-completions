#compdef pfstmo_mantiuk08
# Documentation: http://pfstools.sourceforge.net/man1/pfstmo_mantiuk08.1.html
# pfstools: Mantiuk 2008 display adaptive tone mapping operator

local ret=1

_arguments -s -S \
  '(-d --display-function)'{-d,--display-function}'=[display function spec]:df-spec' \
  '(-s --display-size)'{-s,--display-size}'=[display size / viewing distance spec]:size-spec' \
  '(-c --color-saturation)'{-c,--color-saturation}'=[adjust color saturation after tone mapping]:float' \
  '(-e --contrast-enhancement)'{-e,--contrast-enhancement}'=[enhance contrast before tone mapping]:float' \
  '(-y --white-y)'{-y,--white-y}'=[input luminance mapped to display max]:float' \
  '(-f --fps)'{-f,--fps}'=[frame rate of input sequence]:fps:(25 30 60)' \
  '(-o --output-tone-curve)'{-o,--output-tone-curve}'=[write tone-curves to a text file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '(-q --quiet)'{-q,--quiet}'[do not display progress report]' \
  '(-h --help)'{-h,--help}'[print list of command line options]' && ret=0

return ret
