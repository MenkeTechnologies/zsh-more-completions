#compdef whistle
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)--help[show help]' \
  '(-p --port)'{-p,--port}'=[proxy port]:port:' \
  '(-m --middlewares)'{-m,--middlewares}'=[middleware modules]:middlewares:' \
  '(-u --uipath)'{-u,--uipath}'=[web UI path]:UI path:' \
  '(-t --timeout)'{-t,--timeout}'=[request timeout in ms]:timeout (ms):' \
  '(-n --username)'{-n,--username}'=[username for authentication]:username:' \
  '(-w --password)'{-w,--password}'=[password for authentication]:password:' \
  '(-l --localUIHost)'{-l,--localUIHost}'=[local UI host]:host:_hosts' \
  '(-L --pluginHost)'{-L,--pluginHost}'=[plugin host]:host:_hosts' \
  '(-N --addon)'{-N,--addon}'=[addon modules]:addon:' \
  '--socksPort=[SOCKS proxy port]:port:' \
  '--httpPort=[HTTP proxy port]:port:' \
  '--httpsPort=[HTTPS proxy port]:port:' \
  '(-S --storage-dir)'{-S,--storage-dir}'=[storage directory]:directory:_directories' \
  '(-C --copy)'{-C,--copy}'=[copy settings from host]:host:_hosts' \
  '(-c --certDir)'{-c,--certDir}'=[custom certificate directory]:directory:_directories' \
  '--host=[bind host]:host:_hosts' \
  '--authKey=[authentication key]:key:' \
  '--guestName=[guest username]:name:' \
  '--guestPassword=[guest password]:password:' && ret=0
return ret
