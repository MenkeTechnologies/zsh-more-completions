#compdef oidc-add
# Documentation: https://manpages.debian.org/experimental/oidc-agent-cli/oidc-add.1.en.html
# oidc-add - load and unload account configurations into oidc-agent

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[display help information]' \
  '--usage[show brief usage message]' \
  '(-V --version)'{-V,--version}'[print program version]' \
  '--always-allow-idtoken[always allow id-token requests without manual approval]' \
  '(-a --loaded)'{-a,--loaded}'[list currently loaded account configurations]' \
  '(-c --confirm)'{-c,--confirm}'[require user confirmation when applications request tokens]' \
  '(-l --list)'{-l,--list}'[list all configured account configurations]' \
  '--pw-cmd=[command from which the agent can read the encryption password]:command' \
  '--pw-env=[read the encryption password from the passed environment variable]:env var' \
  '--pw-file=[use the first line of FILE as the encryption password]:file:_files' \
  '--pw-gpg=[use specified GPG key for encryption]:key id' \
  '--pw-keyring[store the used encryption password in the systems keyring]' \
  '--pw-prompt=[change password prompt mode]:mode:(cli gui)' \
  '--pw-store=[keep the encryption password encrypted in memory for TIME seconds]:seconds' \
  '(-p --print)'{-p,--print}'[print encrypted account configuration and exit]' \
  '--remote[use remote central oidc-agent instead of the local one]' \
  '(-r --remove)'{-r,--remove}'[remove account configuration instead of adding it]' \
  '(-R --remove-all)'{-R,--remove-all}'[remove all currently loaded account configurations]' \
  '--seccomp[enable seccomp system call filtering]' \
  '(-t --lifetime)'{-t,--lifetime=}'[maximum lifetime in seconds when adding the configuration]:seconds' \
  '(-x --lock)'{-x,--lock}'[lock agent]' \
  '(-X --unlock)'{-X,--unlock}'[unlock agent]' \
  '(-g --debug)'{-g,--debug}'[set log level to DEBUG]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
  '*:account shortname:' && ret=0

return ret
