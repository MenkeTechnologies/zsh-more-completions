#compdef kubectl-dba kubedb
# _kubectl-dba — kubectl plugin for KubeDB (kubedb/cli)
# upstream: https://github.com/kubedb/cli
# Subcommands from pkg/cmds/root.go (cobra).

_kubectl-dba() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:ns:' \
        '--context=[kubeconfig context name]:context:' \
        '--kubeconfig=[path to kubeconfig file]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_kubectl-dba_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                describe)
                    _arguments \
                        '1:DB type:(mongodb postgres mysql mariadb elasticsearch redis kafka mssql)' \
                        '2:DB instance name:' && ret=0 ;;
                connect)
                    _arguments \
                        '1:DB type:(mongodb postgres mysql mariadb elasticsearch redis)' \
                        '2:DB instance name:' && ret=0 ;;
                data)
                    _arguments \
                        '1: :(insert verify drop)' \
                        '2:DB type:(mongodb postgres mysql mariadb redis)' \
                        '3:DB instance name:' && ret=0 ;;
                debug)
                    _arguments \
                        '1:DB type:(mongodb postgres mysql mariadb elasticsearch redis)' \
                        '2:DB instance name:' && ret=0 ;;
                exec)
                    _arguments \
                        '1:DB instance name:' \
                        '*::exec command:' && ret=0 ;;
                monitor)
                    _arguments \
                        '1:DB type:(mongodb postgres mysql mariadb)' \
                        '2:DB instance name:' && ret=0 ;;
                mssql)
                    _arguments \
                        '*:mssql arg:' && ret=0 ;;
                pause|resume|restart)
                    _arguments \
                        '1:DB instance name:' && ret=0 ;;
                show-credentials)
                    _arguments \
                        '1:DB instance name:' && ret=0 ;;
                remote-replica)
                    _arguments '*:remote-replica args:' && ret=0 ;;
                completion|options|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kubectl-dba_commands] )) ||
_kubectl-dba_commands() {
    local -a commands
    commands=(
        'describe:show details of a KubeDB resource (mongodb / postgres / mysql / ...)'
        'connect:open a database client connected to the named instance'
        'data:insert / verify / drop sample data in a KubeDB instance'
        'debug:print debug-level info for a KubeDB instance'
        'exec:exec into the database container of a KubeDB instance'
        'monitor:install / uninstall the monitoring stack'
        'mssql:MS SQL Server-specific helpers'
        'pause:pause reconciliation for a KubeDB instance'
        'resume:resume reconciliation for a KubeDB instance'
        'restart:restart a KubeDB instance'
        'show-credentials:print the auto-generated credentials for a KubeDB instance'
        'remote-replica:manage cross-cluster replicas'
        'completion:emit shell completion script'
        'options:print global options'
        'version:print kubedb / kubectl-dba version'
    )
    _describe -t commands 'kubectl-dba command' commands
}

_kubectl-dba "$@"
