#compdef nix-locate

# Zsh completion for nix-locate - Nix file database (nix-index)

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --db)'{-d,--db}'=[path to the database]:path:_directories' \
  '(-1 --at-root)'{-1,--at-root}'[only match at root of package output]' \
  '(-t --type)'{-t,--type}'=[restrict match to file type]:type:(d x r s)' \
  '(-w --whole-name)'{-w,--whole-name}'[only match whole path names]' \
  '--top-level[only show matches from top-level packages]' \
  '--minimal[only print attribute names]' \
  '(-r --regex)'{-r,--regex}'[treat pattern as regular expression]' \
  '--no-group[do not group results by package]' \
  '--hash=[package hash]:hash' \
  '(-p --package)'{-p,--package}'=[restrict to package matching regex]:package' \
  '*:pattern' \
  && return 0
