#compdef nix-locate
# Documentation: https://github.com/nix-community/nix-index
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-locate - Nix file database (nix-index)

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --db)'{-d,--db}'[directory where the index is stored]:directory:_directories' \
  '--at-root[treat pattern as absolute package-root path]' \
  '(-t --type)'{-t,--type}'[filter by file type]:type:(r x d s)' \
  '(-w --whole-name)'{-w,--whole-name}'[match exact basename]' \
  '--all[print all matches including non-toplevel packages]' \
  '--minimal[print only attribute names]' \
  '(-r --regex)'{-r,--regex}'[treat pattern as regex]' \
  '--no-group[disable grouping of paths by matching component]' \
  '--color[color output]:when:(auto always never)' \
  '--hash[filter by package hash]:hash:' \
  '(-p --package)'{-p,--package}'[filter matches by package name pattern]:pattern:' \
  '1:pattern:' \
  && return 0
