#compdef keto-cli keto
# _keto-cli — Ory Keto Zanzibar-style access control server CLI alias (ory team, Go); cobra
# upstream: https://github.com/ory/keto

_keto-cli() {
    local -a sub=(
        'help:show help'
        'serve:run the server'
        'migrate:migrate database'
        'migrate:status:show migration status'
        'migrate:sql:run SQL migrations'
        'migrate:down:roll back migrations'
        'migrate:up:apply migrations'
        'namespace:list:list namespaces'
        'namespace:get:get namespace'
        'namespace:migrate:run namespace migrations'
        'namespace:parse:parse namespace config'
        'namespace:validate:validate namespace config'
        'namespace:set:set namespace config'
        'check:check relation tuple'
        'expand:expand relation tuple'
        'list:list relation tuples'
        'create:create relation tuple'
        'delete:delete relation tuple'
        'delete-all:delete all matching tuples'
        'parse:parse OPL config'
        'relation-tuple:get:get tuple'
        'relation-tuple:create:create tuple'
        'relation-tuple:delete:delete tuple'
        'relation-tuple:parse:parse from txt'
        'status:show server status'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.{yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{yaml,yml}"' \
        '--read-remote=+[read API URL]:url:_urls' \
        '--write-remote=+[write API URL]:url:_urls' \
        '--remote=+[server URL]:url:_urls' \
        '--insecure-nohttps-disable-protocol[insecure no https]' \
        '--insecure-disable-transport-security[insecure no TLS]' \
        '--format=+[output format]:f:(default json json-pretty yaml)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'keto subcommand' sub ;;
        args)
            case $words[1] in
                check|expand) _arguments \
                    '1:namespace:' \
                    '2:object:' \
                    '3:relation:' \
                    '4:subject:' \
                    '--max-depth=+[depth]:n:' ;;
                create|delete|relation-tuple:create|relation-tuple:delete) _arguments \
                    '*:tuple file:_files' ;;
                list) _arguments \
                    '--namespace=+[namespace]:str:' \
                    '--object=+[object]:str:' \
                    '--relation=+[relation]:str:' \
                    '--subject-id=+[subject id]:str:' \
                    '--page-size=+[size]:n:' \
                    '--page-token=+[token]:str:' ;;
                migrate:status|migrate:sql|migrate:down|migrate:up) _arguments \
                    '--yes[skip confirmation]' \
                    '-y[skip confirmation]' \
                    '--config=+[config file]:file:_files' ;;
                serve) _arguments \
                    '--sqa-opt-out[opt out of telemetry]' \
                    '--watch-courier[watch courier]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_keto-cli "$@"
