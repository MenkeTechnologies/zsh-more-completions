#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/jasonish/evebox/blob/main/src/bin/evebox.rs
# clap Command builder + per-subcommand setup functions in
# src/cli/{agent,oneshot,print,config,elastic,sqlite,update,util}.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _evebox_cmds
_evebox_cmds=(
    'server:start EveBox dashboard server'
    'agent:run EveBox agent (tail Suricata EVE files)'
    'oneshot:one-shot import + dashboard in browser'
    'print:print info subcommand'
    'config:configuration management'
    'elastic:Elasticsearch backend operations'
    'sqlite:SQLite backend operations'
    'update:update evebox software'
    'util:utility subcommands'
    'version:display version'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '*-v[increase verbosity (count)]' \
    '*--verbose[increase verbosity (count)]' \
    '(-D --data-directory)'{-D+,--data-directory=}'[data directory (env: EVEBOX_DATA_DIRECTORY)]:dir:_directories' \
    '(-C --config-directory)'{-C+,--config-directory=}'[config directory (env: EVEBOX_CONFIG_DIRECTORY)]:dir:_directories' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'evebox subcommand' _evebox_cmds && ret=0
        ;;
    args)
        case $words[1] in
            server)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-c --config)'{-c+,--config=}'[configuration filename]:file:_files' \
                    '--host=[bind hostname/IP (default 127.0.0.1, env: EVEBOX_HTTP_HOST)]:host:_hosts' \
                    '(-p --port)'{-p+,--port=}'[bind port (default 5636, env: EVEBOX_HTTP_PORT)]:port:' \
                    '*-v[increase verbosity]' \
                    && ret=0
                ;;
            agent)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-c --config)'{-c+,--config=}'[agent config file]:file:_files' \
                    '*-v[increase verbosity]' \
                    && ret=0
                ;;
            oneshot)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--no-open[do not open browser]' \
                    '*:EVE JSON file:_files -g "*.json"' \
                    && ret=0
                ;;
            elastic)
                local -a _el_sub
                _el_sub=(
                    'import:import EVE events into Elasticsearch'
                )
                if (( CURRENT == 2 )); then
                    _describe -t elastic-cmd 'elastic subcommand' _el_sub
                fi
                ret=0
                ;;
            sqlite)
                local -a _sq_sub
                _sq_sub=(
                    'info:show database info'
                    'check:check database integrity'
                )
                if (( CURRENT == 2 )); then
                    _describe -t sqlite-cmd 'sqlite subcommand' _sq_sub
                fi
                ret=0
                ;;
            config)
                local -a _cf_sub
                _cf_sub=(
                    'list:list config'
                    'set:set config value'
                )
                if (( CURRENT == 2 )); then
                    _describe -t config-cmd 'config subcommand' _cf_sub
                fi
                ret=0
                ;;
        esac
        ;;
esac

return ret
