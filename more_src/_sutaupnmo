#compdef sutaupnmo
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/stretching_moveout_resamp/sutaupnmo.c
# NMO for an arbitrary velocity function of tau and CDP

local ret=1

_arguments -s -S \
  'tnmo=[NMO times corresponding to velocities in vnmo]:tnmo' \
  'vnmo=[NMO velocities corresponding to times in tnmo]:vnmo' \
  'cdp=[CDPs for which vnmo and tnmo are specified]:cdp' \
  'smute=[samples with NMO stretch exceeding smute are zeroed]:smute' \
  'lmute=[length in samples of linear ramp for stretch mute]:lmute' \
  'sscale=[=1 to divide output samples by NMO stretch factor]:sscale:(0 1)' \
  '*:file:_files' && ret=0

return ret
