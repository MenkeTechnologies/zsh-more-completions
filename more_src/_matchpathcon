#compdef matchpathcon
# _matchpathcon — SELinux matchpathcon (lookup the file context that SELinux policy associates with a given pathname; -f file_contexts to use instead of installed default, -p prefix, -m file type letter (a|b|c|d|l|s|p), -V validate, -n no translation, -N no-newline; positional argument is one or more pathnames)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libselinux/utils/matchpathcon.c on tip.

_matchpathcon() {
    _arguments \
        '-h[show help]' \
        '-V[validate]' \
        '-f+[file_contexts]:file:_files' \
        '-p+[prefix]:prefix:' \
        '-m+[file type]:type:(a b c d l s p)' \
        '-n[no translation]' \
        '-N[no newline]' \
        '*:path:_files'
}

_matchpathcon "$@"
