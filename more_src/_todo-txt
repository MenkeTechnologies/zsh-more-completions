#compdef todo-txt todo.sh
# Zsh completion for todo-txt / todo.sh (Todo.txt CLI)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-@[Hide context names in list output]' \
  '-+[Hide project names in list output]' \
  '-d[Use a specific configuration file]:config file:_files' \
  '-f[Force action without confirmation]' \
  '-h[Display help message]' \
  '-p[Plain mode, turn off colors]' \
  '-P[Hide priority labels in list output]' \
  '-a[Do not auto-archive after done]' \
  '-n[Preserve line numbers]' \
  '-t[Prepend current date on add]' \
  '-v[Verbose mode]' \
  '-vv[Extra verbose mode]' \
  '-V[Display version]' \
  '-x[Disable TODOTXT_FINAL_FILTER]' \
  '1:command:->command' \
  '*:argument:->args' && ret=0

case "$state" in
  command)
    local -a commands=(
      'add:Add a todo item (a)'
      'addm:Add multiple todo items'
      'addto:Add a line of text to a file'
      'append:Append text to a todo item (app)'
      'archive:Move done items to done.txt'
      'command:Run remaining args using only built-in commands'
      'del:Delete a todo item (rm)'
      'depri:Remove priority from a todo item (dp)'
      'do:Mark a todo item as done'
      'done:List done items'
      'help:Show help'
      'list:List todo items (ls)'
      'listaddons:List installed addons'
      'listall:List items from todo.txt and done.txt (lsa)'
      'listcon:List all contexts (lsc)'
      'listfile:List contents of a file (lf)'
      'listpri:List items with a given priority (lsp)'
      'listproj:List all projects (lsprj)'
      'move:Move a todo item to another file (mv)'
      'prepend:Prepend text to a todo item (prep)'
      'pri:Set priority of a todo item (p)'
      'replace:Replace text of a todo item'
      'report:Add todo and done item counts to report.txt'
      'shorthelp:Show one-line usage of all commands'
    )
    _describe -t commands 'todo.txt command' commands && ret=0
    ;;
  args)
    case "${words[2]}" in
      addto|listfile)
        _arguments '2:file:_files' && ret=0
        ;;
      move|mv)
        _arguments '2:item number:' '3:destination file:_files' && ret=0
        ;;
      pri|p)
        _arguments '2:item number:' '3:priority:(A B C D E F)' && ret=0
        ;;
      *)
        _message 'argument' && ret=0
        ;;
    esac
    ;;
esac
return ret
