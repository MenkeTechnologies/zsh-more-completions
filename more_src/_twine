#compdef twine
# Documentation: https://twine.readthedocs.io/en/stable/
# Reference accessed: 2026-05-21
# Verified: upstream twine readthedocs docs.

# Zsh completion for twine (Python package upload tool)

_twine() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'upload:upload distributions to a repository'
    'check:check distribution metadata'
    'register:pre-register a package name'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'twine command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        upload)
          _arguments -s -S \
            '(-r --repository)'{-r,--repository}'[repository to upload to]:repository name:' \
            '--repository-url=[repository URL]:URL:' \
            '-s[sign files to upload using GPG]' \
            '--sign[sign files to upload using GPG]' \
            '--sign-with=[GPG program to sign with]:program:_command_names' \
            '-i+[GPG identity to sign with]:identity:' \
            '--identity=[GPG identity to sign with]:identity:' \
            '-u+[username for authentication]:username:' \
            '--username=[username for authentication]:username:' \
            '-p+[password for authentication]:password:' \
            '--password=[password for authentication]:password:' \
            '--non-interactive[do not prompt for credentials]' \
            '-c+[comment for distribution]:comment:' \
            '--comment=[comment for distribution]:comment:' \
            '--config-file=[path to .pypirc]:file:_files' \
            '--cert=[CA bundle path]:certificate file:_files' \
            '--client-cert=[SSL client certificate]:certificate file:_files' \
            '--verbose[show verbose output]' \
            '--disable-progress-bar[disable progress bar]' \
            '--skip-existing[skip files that already exist on the server]' \
            '--attestations[upload attestations]' \
            '*:distribution files:_files -g "*.{tar.gz,whl,egg,zip}"' \
            && ret=0
          ;;
        check)
          _arguments -s -S \
            '--strict[fail on warnings]' \
            '*:distribution files:_files -g "*.{tar.gz,whl,egg,zip}"' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_twine "$@"
