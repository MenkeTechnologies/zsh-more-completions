#compdef tap-postgres
# Documentation: https://sdk.meltano.com/en/latest/cli.html
# tap-postgres - Singer tap for PostgreSQL (Meltano Singer SDK)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display the package version]' \
  '*--config=[config file path or ENV for environment variables]:file:_files' \
  '--catalog=[use a Singer catalog file with the tap]:file:_files' \
  '--state=[use a bookmarks file for incremental replication]:file:_files' \
  '--discover[run the tap in discovery mode]' \
  '--test=[run a sync test]:mode:(all schema disabled)' \
  '--about[display package metadata and settings]' \
  '--format=[output style for --about]:format:(json markdown)' \
  '*:argument:_files' && ret=0

return ret
