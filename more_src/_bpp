#compdef bpp
# Documentation: https://github.com/bpp/bpp/blob/master/src/bpp.c
# BPP: Bayesian species delimitation / phylogenomics. Flags mirror long_options in bpp.c (getopt_long_only).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--quiet[suppress progress output]' \
  '--cfile=[run analysis with control file]:control file:_files' \
  '--resume=[resume from checkpoint file]:checkpoint:_files' \
  '--simulate=[run simulator (formerly MCcoal)]:control file:_files' \
  '--msci-create=[run MSci network generator]:defs file:_files' \
  '--summary=[summarize results without recomputing]:control file:_files' \
  '--arch=[force SIMD architecture]:arch:(cpu sse avx avx2 neon)' \
  '--tree=[starting tree file]:tree:_files' \
  '--constraint=[topology constraint file]:constraint:_files' \
  '--full[full output]' \
  '--comply[strict standards compliance]' \
  '--keep-labels[preserve node labels]' \
  '--extend=[extend an existing run]:n:' \
  '--points=[number of points]:n:' \
  '--bfdriver=[Bayes-factor driver]:driver:' \
  '--theta_mode=[theta update mode]:mode:' \
  '--wrate_mode=[w-rate update mode]:mode:' \
  '*:control file:_files' && ret=0

return ret
