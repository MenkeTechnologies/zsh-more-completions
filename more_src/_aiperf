#compdef aiperf
# Documentation: https://docs.nvidia.com/aiperf/tutorials/configuration/user-interface
# NVIDIA AIPerf for benchmarking throughput and latency of generative AI models

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --model)'{-m,--model}'=[model to benchmark]:model:' \
  '--url=[server endpoint address]:url:' \
  '--endpoint-type=[API endpoint type]:type:(chat completions embeddings rankings)' \
  '--concurrency=[number of concurrent requests]:n:' \
  '--request-count=[total requests to send]:n:' \
  '--request-rate=[target request rate]:rate:' \
  '--streaming[enable streaming responses]' \
  '(--ui --ui-type)'{--ui,--ui-type}'=[progress display format]:ui:(dashboard simple none)' \
  '--verbose[increase logging verbosity]' \
  '--extra-verbose[further increase logging detail]' \
  '1:command:(profile)' \
  '*::arg:->args' && ret=0

return ret
