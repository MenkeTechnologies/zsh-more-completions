#compdef telepresence
# Documentation: https://github.com/telepresenceio/telepresence
# Reference accessed: 2026-05-21
# Verified: upstream telepresence v2 repository (telepresence.io docs hosting
# moved; canonical source is the GitHub repo).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'connect:connect to traffic manager'
  'quit:quit the daemons'
  'status:show status'
  'version:show version'
  'list:list intercepts/agents'
  'intercept:intercept a service'
  'leave:leave an intercept'
  'login:log in to Ambassador'
  'logout:log out'
  'license:license commands'
  'config:config commands'
  'gather-logs:gather logs'
  'helm:install/uninstall traffic manager'
  'cluster-id:print cluster id'
  'completion:generate shell completion'
  'curl:proxy curl into cluster'
  'dashboard:open Ambassador Cloud dashboard'
  'genyaml:generate sample YAML'
  'loglevel:set log level'
  'gather-traces:gather traces'
  'upload-traces:upload traces'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--use-namespace=[namespace]:ns:' \
  '*--no-report[no report]' \
  '*--output=[format]:f:(default json yaml)' \
  '*-v[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'telepresence command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (intercept)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port]:port:' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
          '(--service)--service=[service]:svc:' \
          '(--mount)--mount=[mount path]:p:' \
          '(--env-file)--env-file=[env file]:file:_files' \
          '(--env-json)--env-json=[env json]:file:_files' \
          '(--http-header)*--http-header=[HTTP header filter]:h:' \
          '(--http-meta)*--http-meta=[HTTP meta filter]:m:' \
          '(--http-path-equal)--http-path-equal=[path]:p:' \
          '(--http-path-prefix)--http-path-prefix=[path]:p:' \
          '(--http-path-regex)--http-path-regex=[regex]:r:' \
          '(--global)--global[global intercept]' \
          '(--preview-url)--preview-url[preview URL]' \
          '(--ingress-host)--ingress-host=[ingress host]:h:' \
          '(--ingress-port)--ingress-port=[ingress port]:p:' \
          '(--ingress-tls)--ingress-tls[ingress TLS]' \
          '(--ingress-l5)--ingress-l5=[L5 host]:h:' \
          '(-d --docker-run)*'{-d+,--docker-run=}'[run container]:image:' \
          '(--docker-mount)*--docker-mount=[mount]:m:' \
          '(-e --env)*'{-e+,--env=}'[env]:e:' \
          '(--mechanism)--mechanism=[mechanism]:m:(http tcp)' \
          '(--allow-conflicting-mounts)--allow-conflicting-mounts[allow conflicting]' \
          '(--detailed-output)--detailed-output[detailed]' \
          '*: :' && ret=0 ;;
      (connect)
        _arguments \
          '(-c --context)'{-c+,--context=}'[k8s context]:ctx:' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
          '(--mapped-namespaces)--mapped-namespaces=[mapped ns csv]:list:' \
          '(--manager-namespace)--manager-namespace=[manager ns]:ns:' \
          '(--also-proxy)*--also-proxy=[CIDR]:c:' \
          '(--never-proxy)*--never-proxy=[CIDR]:c:' \
          '*: :' && ret=0 ;;
      (helm)
        _arguments \
          '1:subcommand:(install upgrade uninstall)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
