#compdef conda-recipe-manager
# Documentation: https://github.com/conda/conda-recipe-manager/blob/main/conda_recipe_manager/commands/README.md
# conda-recipe-manager: tools to manage and manipulate conda recipe files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(convert patch rattler-bulk-build bump-recipe graph)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      convert)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'=[write converted recipe to file]:file:_files' \
          '(-m --min-success-rate)'{-m,--min-success-rate}'=[minimum success threshold for bulk operations]:rate:' \
          '(-t --truncate)'{-t,--truncate}'[reduce logging for CI environments]' \
          '(-d --debug)'{-d,--debug}'[enable debugging output to STDERR]' \
          '*:path:_files' && ret=0
        ;;
      bump-recipe)
        _arguments -s -S \
          '(-b --build-num)'{-b,--build-num}'[increment the build number by 1]' \
          '(-d --dry-run)'{-d,--dry-run}'[preview changes without saving to file]' \
          '(-t --target-version)'{-t,--target-version}'=[new version to target]:version:' \
          '(-i --retry-interval)'{-i,--retry-interval}'=[network retry interval in seconds]:seconds:' \
          '*:path:_files' && ret=0
        ;;
      rattler-bulk-build)
        _arguments -s -S \
          '(-m --min-success-rate)'{-m,--min-success-rate}'=[minimum success threshold for bulk operations]:rate:' \
          '(-t --truncate)'{-t,--truncate}'[reduce logging for CI environments]' \
          '(-l --debug-log)'{-l,--debug-log}'=[write detailed debug log to file]:file:_files' \
          '*:path:_files -/' && ret=0
        ;;
      patch|graph)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
