#compdef fluent3DMeshToFoam
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/
# Converts a Fluent mesh to OpenFOAM format

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-scale+[geometry scaling factor - default is 1]:factor:' \
  '-includedAngle+[feature angle with which to split cyclics]:angle:' \
  '-ignoreCellGroups+[specify cell groups to ignore]:names:' \
  '-ignoreFaceGroups+[specify face groups to ignore]:names:' \
  '-cubit[special parsing of (incorrect) cubit files]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':Fluent mesh file:_files' && ret=0

return ret
