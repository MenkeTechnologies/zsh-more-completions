#compdef pdfgrep
# Documentation: https://pdfgrep.org/doc.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pdfgrep - grep for PDF files

_arguments -s -S \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-F --fixed-strings)'{-F,--fixed-strings}'[interpret pattern as fixed strings]' \
  '(-P --perl-regexp)'{-P,--perl-regexp}'[use Perl compatible regular expressions]' \
  '(-e --regexp)'{-e+,--regexp=}'[use pattern]:pattern:' \
  '(-f --file)'{-f+,--file=}'[obtain patterns from file]:file:_files' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case distinctions]' \
  '(-c --count)'{-c,--count}'[print only a count of matches per file]' \
  '(-p --page-count)'{-p,--page-count}'[print only page numbers with matches]' \
  '--color=[use color in output]:color:(auto always never)' \
  '--colour=[use color in output]:colour:(auto always never)' \
  '(-L --files-without-match)'{-L,--files-without-match}'[print only names of PDFs without matches]' \
  '(-l --files-with-matches)'{-l,--files-with-matches}'[print only names of PDFs with matches]' \
  '(-m --max-count)'{-m+,--max-count=}'[stop reading after N matches per file]:N:' \
  '(-o --only-matching)'{-o,--only-matching}'[print only the matched parts of matching lines]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output (exit code only)]' \
  '(-H --with-filename)'{-H,--with-filename}'[print filename with output lines]' \
  '(-h --no-filename)'{-h,--no-filename}'[suppress filename output]' \
  '(-n --page-number)'{-n,--page-number}'[print page number with output lines]' \
  '(-Z --null)'{-Z,--null}'[print NUL byte after filename]' \
  '--match-prefix-separator=[separator between prefix and match]:separator:' \
  '(-A --after-context)'{-A+,--after-context=}'[lines after matching text]:N:' \
  '(-B --before-context)'{-B+,--before-context=}'[lines before matching text]:N:' \
  '(-C --context)'{-C+,--context=}'[lines of context]:N:' \
  '(-r --recursive)'{-r,--recursive}'[search directories recursively]' \
  '(-R --dereference-recursive)'{-R,--dereference-recursive}'[recursive search following symlinks]' \
  '--include=[search only files matching pattern]:pattern:' \
  '--exclude=[skip files matching pattern]:pattern:' \
  '--cache[cache search results]' \
  '--password=[use password to decrypt PDFs]:password:' \
  '--page-range=[only search the given page range]:range:' \
  '--debug[show debug output]' \
  '--warn-empty[warn about empty files]' \
  '--unac[remove accents before matching]' \
  ':pattern:' \
  '*:PDF file:_files -g "*.pdf"'
