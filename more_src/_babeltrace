#compdef babeltrace
# Documentation: https://babeltrace.org/docs/v2.0/man1/babeltrace2.1/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --list)'{-l,--list}'[list available formats]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '--no-delta[do not print delta timestamps]' \
  '--clock-cycles[print timestamps in clock cycles]' \
  '--clock-offset=[clock offset in seconds]:seconds:' \
  '--clock-offset-ns=[clock offset in nanoseconds]:nanoseconds:' \
  '--clock-seconds[print timestamps as seconds since epoch]' \
  '--clock-date[print date with timestamps]' \
  '--clock-gmt[use GMT for timestamps]' \
  '--clock-force-correlate[force clock correlation]' \
  '(-n --names)'{-n,--names}'=[print field names]:names:(payload context scope header all none)' \
  '(-f --fields)'{-f,--fields}'=[print additional fields]:fields:(trace trace\:hostname trace\:domain trace\:procname trace\:vpid loglevel emf callsite all)' \
  '(-w --output)'{-w,--output}'=[output trace path]:path:_files -/' \
  '(-o --output-format)'{-o,--output-format}'=[output format]:format:(text ctf dummy)' \
  '(-i --input-format)'{-i,--input-format}'=[input format]:format:(ctf lttng-live)' \
  '*:trace path:_files -/' && ret=0

return ret
