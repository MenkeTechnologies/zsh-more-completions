# _kaldi — Daniel Povey Kaldi open-source speech recognition toolkit with WFST and DNN acoustic modeling (kaldi-asr team, C++); custom argparse
# upstream: https://github.com/kaldi-asr/kaldi

_kaldi() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--config=+[config file]:file:_files -g "*.conf *.config"' \
        '--print-args=+[bool]:b:(true false)' \
        '--verbose=+[verbosity]:n:' \
        '--allow-downsample=+[bool]:b:(true false)' \
        '--allow-upsample=+[bool]:b:(true false)' \
        '--blank-symbol=+[blank]:str:' \
        '--frame-shift=+[ms]:n:' \
        '--frame-length=+[ms]:n:' \
        '--sample-frequency=+[Hz]:n:' \
        '--low-freq=+[Hz]:n:' \
        '--high-freq=+[Hz]:n:' \
        '--num-mel-bins=+[N]:n:' \
        '--num-ceps=+[N]:n:' \
        '--use-energy=+[bool]:b:(true false)' \
        '--snip-edges=+[bool]:b:(true false)' \
        '--cmn-window=+[N]:n:' \
        '--ivector-period=+[N]:n:' \
        '--ivector-extraction-config=+[config]:file:_files' \
        '--decoder-type=+[type]:t:(faster latgen nnet3 gmm)' \
        '--max-active=+[N]:n:' \
        '--beam=+[F]:f:' \
        '--lattice-beam=+[F]:f:' \
        '--acoustic-scale=+[F]:f:' \
        '--word-symbol-table=+[file]:file:_files -g "*.int *.txt"' \
        '--model-in=+[model]:file:_files -g "*.mdl"' \
        '--feats-in=+[feats]:file:_files -g "*.ark *.scp"' \
        '--feature-type=+[type]:t:(mfcc plp fbank wav)' \
        '--num-threads=+[N]:n:' \
        '--gpu-id=+[N]:n:' \
        '--use-gpu=+[mode]:m:(yes no optional wait)' \
        '*:input file:_files'
}

_kaldi "$@"
