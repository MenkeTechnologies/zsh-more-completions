#compdef vmq-passwd
# Documentation: https://docs.vernemq.com/configuring-vernemq/file-auth
# VerneMQ password file management tool

local ret=1

_arguments -s -S \
  '(-c -cf -D -U)-c[create a new password file, do not overwrite existing file]' \
  '(-c -cf -D -U)-cf[create a new password file, overwrite if it already exists]' \
  '(-c -cf -D -U)-D[delete the specified user from the password file]' \
  '(-c -cf -D -U)-U[convert plaintext passwords to hashed format in place]' \
  '1:passwordfile:_files' \
  '2:username' && ret=0

return ret
