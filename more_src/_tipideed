#compdef tipideed
# _tipideed — skarnet tipidee HTTP/1.1 server daemon (per-connection HTTP server intended to run under s6-ipcserver/s6-tcpserver; reads its configuration from a pre-compiled cdb)
# upstream: https://github.com/skarnet/tipidee
# Flags from src/tipideed/tipideed.c on tip.

_tipideed() {
    _arguments \
        '-f+[cdb config file (default /etc/tipidee.cdb)]:file:_files' \
        '-d+[base directory]:dir:_files -/' \
        '-R[reject HTTP/0.9 requests]' \
        '-U[do not perform privilege drop]'
}

_tipideed "$@"
