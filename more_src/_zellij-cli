#compdef zellij
# Documentation: https://man.archlinux.org/search?q=zellij
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'options:override config options'
  'setup:setup zellij and check config'
  'list-sessions:list active sessions'
  'ls:list sessions'
  'attach:attach to session'
  'a:attach to session'
  'kill-session:kill specific session'
  'k:kill session'
  'kill-all-sessions:kill all sessions'
  'ka:kill all sessions'
  'delete-session:delete a session'
  'd:delete session'
  'delete-all-sessions:delete all sessions'
  'da:delete all sessions'
  'edit:open file in editor pane'
  'e:edit file'
  'action:send command to current session'
  'ac:action shorthand'
  'pipe:send data to plugins'
  'run:run command in new pane'
  'r:run command'
  'plugin:load a plugin'
  'convert-config:convert old config'
  'convert-layout:convert old layout'
  'convert-theme:convert old theme'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--max-panes=[max panes]:n:' \
  '*--data-dir=[data dir]:dir:_files -/' \
  '*--server[run server-only]' \
  '*-s+[session name]:s:' \
  '*--session=[session name]:s:' \
  '*-l+[layout]:layout:' \
  '*--layout=[layout]:layout:' \
  '*-c+[config file]:file:_files -g "*.kdl *.yaml *.yml"' \
  '*--config=[config file]:file:_files' \
  '*--config-dir=[config dir]:dir:_files -/' \
  '*-d+[debug]:b:' \
  '*--debug[debug mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zellij command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (attach|a)
        _arguments \
          '(-c --create)'{-c,--create}'[create if not exists]' \
          '(--create-background-if-not-exists)--create-background-if-not-exists[create in background if missing]' \
          '(--force-run-commands)--force-run-commands[force run commands]' \
          '(--index)--index=[index]:n:' \
          '*:session:' && ret=0 ;;
      (kill-session|k|delete-session|d)
        _arguments '*:session:' && ret=0 ;;
      (run|r)
        _arguments \
          '(-d --direction)'{-d+,--direction=}'[split direction]:d:(right down)' \
          '(--cwd)--cwd=[cwd]:dir:_files -/' \
          '(-f --floating)'{-f,--floating}'[floating pane]' \
          '(-i --in-place)'{-i,--in-place}'[in place]' \
          '(-c --close-on-exit)'{-c,--close-on-exit}'[close on exit]' \
          '(-s --start-suspended)'{-s,--start-suspended}'[start suspended]' \
          '(-n --name)'{-n+,--name=}'[pane name]:n:' \
          '(--width)--width=[width]:w:' \
          '(--height)--height=[height]:h:' \
          '(-x)-x+[x position]:x:' \
          '(-y)-y+[y position]:y:' \
          '(--pinned)--pinned=[pinned]:b:(true false)' \
          '*: :_command_names -e' && ret=0 ;;
      (edit|e)
        _arguments \
          '(-d --direction)'{-d+,--direction=}'[split direction]:d:(right down)' \
          '(-l --line-number)'{-l+,--line-number=}'[line]:n:' \
          '(-f --floating)'{-f,--floating}'[floating]' \
          '(-i --in-place)'{-i,--in-place}'[in place]' \
          '(--cwd)--cwd=[cwd]:dir:_files -/' \
          '(--width)--width=[width]:w:' \
          '(--height)--height=[height]:h:' \
          '(-x)-x+[x]:x:' \
          '(-y)-y+[y]:y:' \
          '(--pinned)--pinned=[pinned]:b:(true false)' \
          '*: :_files' && ret=0 ;;
      (action|ac)
        _arguments \
          '1:action:(write write-chars resize focus-next-pane focus-previous-pane move-focus move-focus-or-tab move-pane move-pane-backwards clear dump-screen edit-scrollback scroll-up scroll-down scroll-to-bottom scroll-to-top page-scroll-up page-scroll-down half-page-scroll-up half-page-scroll-down toggle-fullscreen toggle-pane-frames toggle-active-sync-tab new-pane edit toggle-floating-panes close-pane rename-pane undo-rename-pane go-to-next-tab go-to-previous-tab close-tab go-to-tab go-to-tab-name new-tab rename-tab undo-rename-tab move-tab next-swap-layout previous-swap-layout query-tab-names start-or-reload-plugin launch-or-focus-plugin launch-plugin rename-session start-or-reload-plugin)' \
          '*: :' && ret=0 ;;
      (pipe)
        _arguments \
          '(-n --name)'{-n+,--name=}'[pipe name]:n:' \
          '(-p --plugin)'{-p+,--plugin=}'[plugin]:p:' \
          '(-a --plugin-configuration)*'{-a+,--plugin-configuration=}'[k=v config]:v:' \
          '(--floating-panes)--floating-panes[floating]' \
          '(--in-place)--in-place[in place]' \
          '(-l --launch-new)'{-l,--launch-new}'[launch new]' \
          '(--name)--name=[name]:n:' \
          '*: :' && ret=0 ;;
      (plugin)
        _arguments \
          '(-c --configuration)*'{-c+,--configuration=}'[k=v]:v:' \
          '(-f --floating)'{-f,--floating}'[floating]' \
          '(-i --in-place)'{-i,--in-place}'[in place]' \
          '(--width)--width=[width]:w:' \
          '(--height)--height=[height]:h:' \
          '*: :' && ret=0 ;;
      (setup)
        _arguments \
          '(--dump-config)--dump-config[dump default config]' \
          '(--clean)--clean[start with clean state]' \
          '(--check)--check[check config]' \
          '(--dump-layout)--dump-layout=[dump layout]:layout:(default strider compact)' \
          '(--dump-swap-layout)--dump-swap-layout=[dump swap layout]:layout:' \
          '(--generate-completion)--generate-completion=[shell]:shell:(bash zsh fish elvish powershell nushell)' \
          '(--generate-auto-start)--generate-auto-start=[shell]:shell:(bash zsh fish)' \
          '*: :' && ret=0 ;;
      (options)
        _arguments \
          '(--simplified-ui)--simplified-ui=[simplified UI]:b:(true false)' \
          '(--theme)--theme=[theme]:t:' \
          '(--default-mode)--default-mode=[mode]:m:(normal locked resize tab scroll renametab session move prompt tmux)' \
          '(--default-shell)--default-shell=[shell]:shell:_command_names -e' \
          '(--default-cwd)--default-cwd=[cwd]:dir:_files -/' \
          '(--default-layout)--default-layout=[layout]:l:' \
          '(--mouse-mode)--mouse-mode=[mouse]:b:(true false)' \
          '(--pane-frames)--pane-frames=[pane frames]:b:(true false)' \
          '(--mirror-session)--mirror-session=[mirror]:b:(true false)' \
          '(--on-force-close)--on-force-close=[on close]:a:(quit detach)' \
          '(--scrollback-lines)--scrollback-lines=[scrollback]:n:' \
          '(--scrollback-editor)--scrollback-editor=[editor]:e:' \
          '(--copy-command)--copy-command=[copy cmd]:c:' \
          '(--copy-clipboard)--copy-clipboard=[clipboard]:c:(system primary)' \
          '(--copy-on-select)--copy-on-select=[copy on select]:b:(true false)' \
          '(--scroll-buffer-size)--scroll-buffer-size=[buffer]:n:' \
          '(--styled-underlines)--styled-underlines=[styled underlines]:b:(true false)' \
          '(--serialize-pane-viewport)--serialize-pane-viewport=[serialize]:b:(true false)' \
          '(--scrollback-lines-to-serialize)--scrollback-lines-to-serialize=[lines]:n:' \
          '(--disable-session-metadata)--disable-session-metadata=[b]:b:(true false)' \
          '(--support-kitty-keyboard-protocol)--support-kitty-keyboard-protocol=[b]:b:(true false)' \
          '(--web-server-ip)--web-server-ip=[ip]:i:' \
          '(--web-server-port)--web-server-port=[port]:port:' \
          '(--web-sharing)--web-sharing=[sharing]:s:(on off disabled)' \
          '(--stacked-resize)--stacked-resize=[b]:b:(true false)' \
          '*: :' && ret=0 ;;
      (convert-config|convert-layout|convert-theme)
        _arguments '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
