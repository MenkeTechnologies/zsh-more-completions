#compdef kooha
# Documentation: https://man.archlinux.org/search?q=kooha
# Reference accessed: 2026-05-16

# Zsh completion for Kooha - screen recorder for GNOME

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' && ret=0

return ret
