#compdef kooha
# Documentation: https://github.com/SeaDve/Kooha
# Reference accessed: 2026-05-19
# Verified: upstream repo — Kooha (GTK screen recorder) exposes no CLI
# flags beyond --help/--version (experimental features via env vars). STUB.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' && ret=0

return ret
