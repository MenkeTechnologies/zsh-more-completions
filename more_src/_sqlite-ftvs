#compdef sqlite-ftvs

# sqlite-ftvs: full-text vector search helper for SQLite
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[database file]:file:_files -g "*.(db|sqlite|sqlite3)"' \
  '-q[query string]:query:' \
  '-k[top-k results]:n:' \
  '*::sqlite-ftvs args:_files' && ret=0
return ret
