#compdef pamgauss
# Documentation: man pamgauss (Netpbm)
# Source: Netpbm pamgauss — create a two-dimensional Gaussian function as a PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-sigma=[standard deviation]:number:' \
    '-maxval=[output maxval]:number:' \
    '-tupletype=[output tuple type]:string:(GRAYSCALE RGB BLACKANDWHITE)' \
    '-maximize[scale to maxval (vs sum=maxval)]' \
    '-oversample=[oversampling factor]:number:' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:width height:' \
    && ret=0

return ret
