#compdef jiff-cli
# Documentation: source-direct extraction from upstream
# BurntSushi/jiff crates/jiff-cli/ (**Rust `lexopt`
# library** — token-level CLI parser; corpus's first
# documented lexopt CLI):
#   crates/jiff-cli/main.rs lines 1-30 (main fn opens
#     with env-based logger setup + dispatches to
#     `cmd::run(&mut lexopt::Parser::from_env())`)
#   crates/jiff-cli/cmd/mod.rs lines 1-19 (top-level
#     dispatch: USAGE string + `match cmd { "generate"
#     => generate::run(p) }`)
#   crates/jiff-cli/cmd/generate/mod.rs lines 1-40
#     (generate subcommand: 6 sub-subcommands —
#     crc32 / jiff-tzdb / shared / unit-designator-
#     match / windows-zones / zoneinfo)
#   crates/jiff-cli/args/mod.rs line 3 (`use lexopt::
#     {Arg, Parser, ValueExt}`)
#   crates/jiff-cli/args/mod.rs lines 5-13 (Configurable
#     trait — custom trait for distributed arg-handler
#     dispatch)
#   crates/jiff-cli/args/mod.rs lines 15-72 (configure
#     fn: while-let imperative parser loop with
#     iteration-through-targets-to-claim arg)
#   crates/jiff-cli/args/mod.rs lines 79-91 (next_as_command
#     fn: handles -h/--help and parses first positional
#     as command name)
#   crates/jiff-cli/args/mod.rs lines 121-193 (Usage
