#compdef antctl

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'get:get information about a resource'
  'log-level:manage log verbosity'
  'version:show antctl version'
  'check:run installation/cluster verification'
  'supportbundle:collect cluster/controller/agent support bundle'
  'query:query Antrea network policy or endpoint state'
  'trace-packet:perform OVS packet tracing'
  'traceflow:start a Traceflow and retrieve result'
  'tf:alias of traceflow'
  'packetcapture:initiate packet capture'
  'pc:alias of packetcapture'
  'proxy:run as a reverse proxy for Antrea APIs'
  'upgrade:upgrade CRD objects to storage version'
  'mc:multicluster commands'
  'set:set log levels'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '-v[verbose log level]:level:' \
  '--log_dir=[log directory]:dir:_files -/' \
  '--server=[Antrea API server URL]:url:' \
  '--insecure[skip TLS verify]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'antctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get)
        local -a get_targets=(
          featuregates
          controllerinfo ci
          agentinfo ai
          networkpolicy netpol
          appliedtogroup atg
          addressgroup ag
          podinterface pi
          ovsflows of
          flowrecords
          recordmetrics
          podmulticaststats
          memberlist ml
          bgppolicy
          bgppeers
          bgproutes
        )
        _values 'resource' $get_targets && ret=0 ;;
      (check)
        _arguments '*::sub:(installation cluster)' && ret=0 ;;
      (query)
        _arguments '*::sub:(endpoint networkpolicyevaluation)' && ret=0 ;;
      (traceflow|tf)
        _arguments \
          '(-S --source)'{-S+,--source=}'[source pod or IP]:src:' \
          '(-D --destination)'{-D+,--destination=}'[destination pod or IP]:dst:' \
          '(-f --flow)'{-f+,--flow=}'[flow string spec]:flow:' \
          '--live[live Traceflow]' \
          '--dropped-only[only show dropped]' \
          '--timeout=[timeout]:duration:' \
          '--wait[wait for completion]' && ret=0 ;;
      (mc)
        _arguments '*::sub:(get create delete deploy init add leader-cluster member-cluster)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
