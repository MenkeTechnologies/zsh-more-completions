#compdef logspout
# Documentation: https://man.archlinux.org/search?q=logspout
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-version[show version]' \
  '-debug[enable debug]' \
  '-loglevel+[log level]:l:(debug info warn error)' \
  '-tls+[tls config]:c:(skip require enforce)' \
  '-port+[listen port]:port:' \
  '-routes+[routes file]:file:_files' \
  '*: :' && ret=0

return ret
