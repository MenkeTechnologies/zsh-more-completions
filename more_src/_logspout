#compdef logspout
# Documentation: https://github.com/gliderlabs/logspout
# Reference accessed: 2026-05-19
# Verified: upstream README. logspout is configured via environment
# variables (DEBUG, BACKLOG, TAIL, HTTP_PORT, ROUTESPATH, SYSLOG_*,
# MULTILINE_*, LOGSPOUT_TLS_*, etc.) and a destination URI argument,
# not traditional CLI flags. Keeping a minimal completion for the
# URI positional and the few generic Go flags accepted.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '*:route URI:' && ret=0

return ret
