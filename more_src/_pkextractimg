#compdef pkextractimg
# Documentation: https://pktools.nongnu.org/html/pkextractimg.html
# extract pixel values to raster sample

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Raster input dataset containing band information]:file:_files' \
  '(-s --sample)'{-s,--sample}'[Raster dataset with categorical values to sample the input raster data]:file:_files' \
  '(-o --output)'{-o,--output}'[Output sample dataset]:file:_files' \
  '(-c --class)'{-c,--class}'[Class(es) to extract from input sample image. Leave empty to extract a]:value:' \
  '(-t --threshold)'{-t,--threshold}'[Probability threshold for selecting samples (randomly). Provide probab]:value:' \
  '(-f --f)'{-f,--f}'[Output sample dataset format]:value:' \
  '(-ft --ftype)'{-ft,--ftype}'[Field type (only Real or Integer)]:value:' \
  '(-lt --ltype)'{-lt,--ltype}'[Label type\: In16 or String]:value:' \
  '(-b --band)'{-b,--band}'[Band index(es) to extract (0 based). Leave empty to use all bands]:value:' \
  '(-sband --startband)'{-sband,--startband}'[Start band sequence number]:value:' \
  '(-eband --endband)'{-eband,--endband}'[End band sequence number]:value:' \
  '(-bndnodata --bndnodata)'{-bndnodata,--bndnodata}'[Band in input image to check if pixel is valid (used for srcnodata)]:value:' \
  '(-srcnodata --srcnodata)'{-srcnodata,--srcnodata}'[Invalid value(s) for input image]:value:' \
  '(-bn --bname)'{-bn,--bname}'[For single band input data, this extra attribute name will correspond]:value:' \
  '(-cn --cname)'{-cn,--cname}'[Name of the class label in the output vector dataset]:value:' \
  '(-down --down)'{-down,--down}'[Down sampling factor]:value:' \
  '*:file:_files' && ret=0

return ret
