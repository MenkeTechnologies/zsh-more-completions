#compdef sss_groupadd
# Documentation: https://man.archlinux.org/search?q=sss_groupadd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '(-g --gid)'{-g,--gid}'+[group GID]:gid:' \
  '1:group_name:_groups' && ret=0

return ret
