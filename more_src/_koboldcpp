#compdef koboldcpp
# Documentation: https://raw.githubusercontent.com/LostRuins/koboldcpp/concedo/koboldcpp.py
# Reference accessed: 2026-05-19
# Verified: upstream koboldcpp.py argparse definitions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--model=[GGUF model file to load]:file:_files -g "*.{gguf,bin,ggml}"' \
  '--mmproj=[multimodal projector file]:file:_files' \
  '--lora=[LoRA adapter file]:file:_files' \
  '--sdmodel=[Stable Diffusion model file]:file:_files' \
  '--whispermodel=[whisper.cpp speech-to-text model]:file:_files' \
  '--ttsmodel=[TTS model file]:file:_files' \
  '--embeddingsmodel=[embeddings model file]:file:_files' \
  '--port=[server port]:port:' \
  '--host=[bind host]:host:_hosts' \
  '--multiuser=[multi-user concurrent requests]:n:' \
  '--threads=[CPU threads]:n:' \
  '--blasthreads=[BLAS threads]:n:' \
  '--contextsize=[context window size]:n:' \
  '--blasbatchsize=[BLAS batch size]:n:' \
  '--ropeconfig=[RoPE config (frequency scale)]:cfg:' \
  '--gpulayers=[GPU layer offload count]:n:' \
  '--usecublas[NVIDIA CUDA acceleration]' \
  '--usecuda[NVIDIA CUDA acceleration]' \
  '--usevulkan[Vulkan acceleration]' \
  '--usecpu[CPU only, no GPU]' \
  '--noblas[disable BLAS]' \
  '--nommap[disable memory mapping]' \
  '--usemmap[force memory mapping]' \
  '--usemlock[force memory lock]' \
  '--nofastforward[disable fast forwarding]' \
  '--quiet[suppress console output]' \
  '--debugmode=[debug mode level]:level:(0 1 2)' \
  '--launch[auto-open browser]' \
  '--skiplauncher[skip launcher GUI]' \
  '--smartcontext[smart context shifting]' \
  '--noshift[disable context shifting]' \
  '--flashattention[enable flash attention]' \
  '--quantkv=[KV cache quantization]:level:(0 1 2)' \
  '--password=[API key for auth]:key:' \
  '--admin[enable runtime model switching]' \
  '--adminpassword=[admin auth password]:pass:' \
  '--admindir=[admin model directory]:dir:_files -/' \
  '--ssl=[SSL cert,key paths]:paths:' \
  '--nocertify[disable SSL certificate validation]' \
  '--websearch[enable websearch]' \
  '--cli[interactive CLI mode]' \
  '--prompt=[direct prompt to model]:prompt:' \
  '--benchmark[benchmark mode]' \
  '--showgui[show GUI launcher]' \
  '--config=[config file]:file:_files -g "*.kcpps"' \
  '*::extra:_files' && ret=0

return ret
