#compdef dirvish
# Documentation: https://man.archlinux.org/search?q=dirvish
# Reference accessed: 2026-05-16

_arguments -s \
  '--vault=[vault[:branch]]:vault:' \
  '--branch=[branch name]:branch:' \
  '--config=[config file]:file:_files' \
  '--image=[image name]:name:' \
  '--image-time=[image timestamp]:date:' \
  '--reference=[reference branch/image]:ref:' \
  '--init[initialize new vault]' \
  '--expire=[expire date]:date:' \
  '--summary=[summary level]:level:(short long)' \
  '--reset=[reset option]:option:' \
  '(--dry-run --no-run)'{--dry-run,--no-run}'[do not actually run]' \
  '(- *)--version[show version]'
