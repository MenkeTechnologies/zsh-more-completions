#compdef nessus-cli2 nessuscli2
# _nessus-cli2 — Tenable Nessus nessus-cli2 CLI command-line frontend wrapping the Tenable Nessus Professional Essentials Expert vulnerability scanner CLI providing fix update fetch backup restore status report restart adduser rmuser passwd uuid software-update database licenses register agent linking-key plugins refresh download check-update bug-report-generator service certificate (Tenable Nessus team, C); custom argparse
# upstream: https://www.tenable.com/products/nessus

_nessus-cli2() {
    local -a sub=(
        'fix:fix database operations'
        'update:check for updates'
        'fetch:fetch plugins'
        'backup:backup operations'
        'restore:restore operations'
        'status:show status'
        'report:report operations'
        'restart:restart service'
        'adduser:add user'
        'rmuser:remove user'
        'passwd:change user password'
        'uuid:show UUID'
        'software-update:software update operations'
        'database:database operations'
        'licenses:license operations'
        'register:register Nessus'
        'agent:agent operations'
        'linking-key:linking key operations'
        'plugins:plugins operations'
        'refresh:refresh plugins'
        'download:download operations'
        'check-update:check for update'
        'bug-report-generator:generate bug report'
        'service:service operations'
        'managed:managed operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--secure[secure mode]' \
        '--all[apply to all]' \
        '--proxy=+[host:port]:_hosts' \
        '--proxy-user=+[user]:_users' \
        '--proxy-password=+[password]:str:' \
        '--proxy-agent=+[name]:str:' \
        '--ca-bundle=+[file]:file:_files -g "*.pem *.crt"' \
        '--feed-host=+[host]:_hosts' \
        '--register-only[register only]' \
        '--update-host=+[host]:_hosts' \
        '--license=+[file]:file:_files -g "*.license *.txt"' \
        '--code=+[activation code]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--admin[admin user]' \
        '--name=+[name]:str:' \
        '--host=+[host]:_hosts' \
        '--port=+[port]:n:' \
        '--ca-path=+[dir]:dir:_files -/' \
        '--cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--key=+[file]:file:_files -g "*.pem *.key"' \
        '--scanner-name=+[name]:str:' \
        '--groups=+[names]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nessuscli subcommand' sub ;;
        args)
            case $words[1] in
                fix) _arguments '1:op:(--list --secure --set --reset --unsecure)' '*:setting:' ;;
                bug-report-generator) _arguments '--scrub --quiet --full' ;;
            esac
            ;;
    esac
}

_nessus-cli2 "$@"
