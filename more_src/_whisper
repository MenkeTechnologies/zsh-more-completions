#compdef whisper

# Zsh completion for OpenAI Whisper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--model=[model size to use]:model:(tiny tiny.en base base.en small small.en medium medium.en large large-v1 large-v2 large-v3)' \
  '--model_dir=[path to save model files]:directory:_directories' \
  '--device=[device to use]:device:(cpu cuda)' \
  '--output_dir=[directory to save output]:directory:_directories' \
  '-o+[directory to save output]:directory:_directories' \
  '--output_format=[output format]:format:(txt vtt srt tsv json all)' \
  '-f+[output format]:format:(txt vtt srt tsv json all)' \
  '--verbose=[verbose output]:verbose:(True False)' \
  '--task=[task to perform]:task:(transcribe translate)' \
  '--language=[language of audio]:language' \
  '--temperature=[sampling temperature]:temperature' \
  '--best_of=[number of candidates for beam search]:num' \
  '--beam_size=[number of beams for beam search]:num' \
  '--patience=[patience value for beam search]:patience' \
  '--length_penalty=[length penalty for beam search]:penalty' \
  '--suppress_tokens=[token IDs to suppress]:tokens' \
  '--initial_prompt=[optional text to provide as prompt]:prompt' \
  '--condition_on_previous_text=[condition on previous text]:bool:(True False)' \
  '--fp16=[use fp16 inference]:bool:(True False)' \
  '--temperature_increment_on_fallback=[temperature increment on failure]:increment' \
  '--compression_ratio_threshold=[compression ratio threshold]:threshold' \
  '--logprob_threshold=[log probability threshold]:threshold' \
  '--no_speech_threshold=[no speech probability threshold]:threshold' \
  '--word_timestamps=[extract word-level timestamps]:bool:(True False)' \
  '--prepend_punctuations=[punctuations to merge with next word]:punctuations' \
  '--append_punctuations=[punctuations to merge with previous word]:punctuations' \
  '--threads=[number of CPU threads]:threads' \
  '--clip_timestamps=[comma-separated clip timestamps]:timestamps' \
  '--hallucination_silence_threshold=[skip silent periods]:seconds' \
  '*:audio file:_files -g "*(#i).(wav|mp3|flac|ogg|m4a|wma|aac|opus|webm|mp4|mkv|avi)"' && ret=0

return ret
