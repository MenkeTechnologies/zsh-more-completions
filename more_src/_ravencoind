#compdef ravencoind ravencoin-daemon
# _ravencoind — Ravencoin Core ravencoind daemon CLI for the X16R-based asset-issuance fork of Bitcoin running a full node maintaining the blockchain validating asset transactions network sync RPC API memory pool wallet (RavenProject team, C++); custom argparse
# upstream: https://github.com/RavenProject/Ravencoin

_ravencoind() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf raven.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-daemon[run as daemon]' \
        '-pid=+[file]:file:_files' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb assets all)' \
        '-loglevel=+[level]:l:(info debug trace)' \
        '-shrinkdebugfile[shrink debug]' \
        '-logips[log IPs]' \
        '-logtimestamps[log timestamps]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserver[enable RPC server]' \
        '-rpcwait[wait for RPC server]' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-blocksonly[only blocks]' \
        '-maxconnections=+[N]:n:' \
        '-maxuploadtarget=+[MiB]:n:' \
        '-paytxfee=+[RVN/kB]:f:' \
        '-minfee=+[RVN/kB]:f:' \
        '-prune=+[MiB or 0]:n:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[name]:str:' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:' \
        '-zmqpubraweth=+[address]:str:' \
        '-zmqpubrawmessage=+[address]:str:' \
        '-zmqpubrawasset=+[address]:str:' \
        '-zmqpubhashasset=+[address]:str:' \
        '-zmqpubsequence=+[address]:str:' \
        '-gen[generate]' \
        '-genproclimit=+[N]:n:' \
        '-keypool=+[N]:n:' \
        '-walletbroadcast[broadcast wallet]' \
        '-walletnotify=+[command]:str:' \
        '-messaging[enable messaging]' \
        '-disable-messaging[disable messaging]' \
        '-restrictedassets[enable restricted assets]'
}

_ravencoind "$@"
