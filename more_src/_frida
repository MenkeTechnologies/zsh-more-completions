#compdef frida

# Zsh completion for Frida - dynamic instrumentation toolkit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-D+[connect to device with the given ID]:device ID' \
  '--device=[connect to device with the given ID]:device ID' \
  '-U[connect to USB device]' \
  '--usb[connect to USB device]' \
  '-R[connect to remote frida-server]' \
  '--remote[connect to remote frida-server]' \
  '-H+[connect to remote frida-server on host]:host' \
  '--host=[connect to remote frida-server on host]:host' \
  '-f+[spawn FILE]:target:_files' \
  '--file=[spawn FILE]:target:_files' \
  '-F[attach to frontmost application]' \
  '--attach-frontmost[attach to frontmost application]' \
  '-n+[attach to NAME]:process name' \
  '--attach-name=[attach to NAME]:process name' \
  '-N+[attach to IDENTIFIER]:identifier' \
  '--attach-identifier=[attach to IDENTIFIER]:identifier' \
  '-p+[attach to PID]:pid' \
  '--attach-pid=[attach to PID]:pid' \
  '-W+[wait for and attach to NAME]:pattern' \
  '--await=[wait for and attach to NAME]:pattern' \
  '--stdio=[stdio behavior]:behavior:(inherit pipe)' \
  '--aux=[set auxiliary option]:option' \
  '--realm=[realm to attach in]:realm:(native emulated)' \
  '--runtime=[script runtime to use]:runtime:(qjs v8)' \
  '--debug[enable debug mode]' \
  '--squelch-crash[suppress crash reporter]' \
  '-l+[load SCRIPT]:script:_files -g "*.js"' \
  '--load=[load SCRIPT]:script:_files -g "*.js"' \
  '-P+[load PARAMETERS]:params file:_files -g "*.json"' \
  '--parameters=[load PARAMETERS]:params file:_files -g "*.json"' \
  '-C+[load codeshare URI]:uri' \
  '--codeshare=[load codeshare URI]:uri' \
  '-e+[evaluate CODE]:code' \
  '--eval=[evaluate CODE]:code' \
  '-q[be quiet]' \
  '--quiet[be quiet]' \
  '--no-pause[do not pause after spawn]' \
  '-o+[output to FILE]:file:_files' \
  '--output=[output to FILE]:file:_files' \
  '--eternalize[eternalize the script]' \
  '--exit-on-error[exit on script error]' \
  '--kill-on-exit[kill target on exit]' \
  '--auto-perform[auto-perform Java.perform]' \
  '--auto-reload[auto-reload script on changes]' \
  '*:target' && ret=0

return ret
