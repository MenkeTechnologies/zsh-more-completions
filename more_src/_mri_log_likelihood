#compdef mri_log_likelihood
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mri_log_likelihood/mri_log_likelihood.cpp
# Compute the log likelihood of a volume given an atlas

local ret=1

_arguments -s -S \
  '-DEBUG_VOXEL[set debugging voxel coordinates]:x:y:z:' \
  '-ORIG[original volume file to read]:file:_files' \
  '-V[set diagnostic number]:num:' \
  '-U[display usage]' \
  '*:file:_files' && ret=0

return ret
