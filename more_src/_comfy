#compdef comfy sloglint
# Documentation: upstream READMEs at github.com/{Comfy-Org/comfy-cli,go-simpler/sloglint}
# Reference accessed: 2026-05-30
# Mixed pivot R27 — out of pure Go-linter territory.
# comfy: Python-based CLI manager for ComfyUI (binary is `comfy`,
# installed via `pip install comfy-cli`).
# sloglint: Go log/slog style linter — standalone surface minimal,
# configuration is golangci-lint primary.

local curcontext="$curcontext" state line ret=1

case $service in

  comfy)
    # Comfy-Org/comfy-cli — manage and run ComfyUI from the terminal.
    local -a _subcmds
    _subcmds=(
      'install:set up ComfyUI and ComfyUI-Manager locally'
      'launch:run the installed ComfyUI server'
      'env:display environment information + server status'
      'run:execute a workflow against a local ComfyUI server'
      'set-default:establish default workspace location'
      'which:display target workspace path'
      'pr-cache:manage PR cache (list/clean)'
      'node:manage custom nodes (install/update/remove/snapshot/bisect)'
      'model:manage models (download/list/remove)'
      'generate:call hosted partner models without local ComfyUI'
      'manager:control ComfyUI-Manager behavior'
      'tracking:opt out of analytics'
    )
    local -a _workspace_opts
    _workspace_opts=(
      '--workspace=[target specific ComfyUI installation]:path:_directories'
      '--recent[use most recently executed/installed ComfyUI]'
      '--here[use ComfyUI in current directory]'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      '--install-completion[install shell completion]' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'comfy subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          install)
            _arguments \
              "$_workspace_opts[@]" \
              '--skip-manager[do not install ComfyUI-Manager]' \
              '--fast-deps[use uv for faster dependency resolution]' \
              '--pr=[install a specific PR (#NUM or user:branch)]:pr:' && ret=0
            ;;
          launch)
            _arguments \
              "$_workspace_opts[@]" \
              '--background[run as background process]' \
              '--frontend-pr=[test a frontend pull request]:pr:' \
              '*:: :_normal' && ret=0
            ;;
          pr-cache)
            local -a _prcache
            _prcache=(
              'list:list cached PRs'
              'clean:clean a specific PR or all'
            )
            _describe -t commands 'pr-cache action' _prcache && ret=0
            ;;
          node)
            local -a _nodecmds
            _nodecmds=(
              'show:display node info'
              'simple-show:simplified node info display'
              'install:install custom node'
              'update:update nodes (`update all` for all)'
              'reinstall:reinstall a custom node'
              'fix:repair node installation'
              'uninstall:remove a custom node'
              'install-deps:install workflow dependencies'
              'deps-in-workflow:generate workflow dependency list'
              'uv-sync:resolve all custom-node deps via unified resolver'
              'save-snapshot:backup current node configuration'
              'restore-snapshot:restore from snapshot'
              'bisect:identify problematic custom nodes'
            )
            _arguments -C -s -S \
              '(-): :->nodecmd' \
              '(-)*:: :->nodecmd_args' && ret=0
            case $state in
              nodecmd)
                _describe -t commands 'comfy node subcommand' _nodecmds && ret=0
                ;;
              nodecmd_args)
                case $words[1] in
                  show|simple-show)
                    _arguments \
                      '1:filter:(installed enabled all disabled not-installed snapshot snapshot-list)' && ret=0
                    ;;
                  install-deps|deps-in-workflow)
                    _arguments \
                      '--workflow=[workflow file]:file:_files -g "*.(json|png)"' \
                      '--output=[output file]:file:_files' && ret=0
                    ;;
                  bisect)
                    _arguments \
                      '1:bisect action:(start good bad reset)' && ret=0
                    ;;
                  restore-snapshot)
                    _arguments \
                      '1:snapshot name:' && ret=0
                    ;;
                  install|reinstall|uninstall)
                    _arguments \
                      '--channel=[node channel]:channel:' \
                      '--uv-compile[use unified dependency resolver]' \
                      '--no-uv-compile[override default uv-compile setting]' \
                      '*:node name:' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          model)
            local -a _modelcmds
            _modelcmds=(
              'download:fetch model from CivitAI/HuggingFace/URL'
              'list:display available models'
              'remove:delete models'
            )
            _arguments -C -s -S \
              '(-): :->modelcmd' \
              '(-)*:: :->modelcmd_args' && ret=0
            case $state in
              modelcmd)
                _describe -t commands 'comfy model subcommand' _modelcmds && ret=0
                ;;
              modelcmd_args)
                case $words[1] in
                  download)
                    _arguments \
                      '--url=[model URL]:url:' \
                      '--set-civitai-api-token=[CivitAI API token]:token:' \
                      '--set-hf-api-token=[Hugging Face API token]:token:' && ret=0
                    ;;
                  remove)
                    _arguments \
                      '--model-names=[model names to delete (comma-separated)]:names:' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          generate)
            local -a _gencmds
            _gencmds=(
              'list:browse available models'
              'schema:view parameters for a specific model'
              'resume:retrieve async results by job ID'
              'flux:Flux family generation'
              'flux-pro:Flux Pro generation'
              'ideogram:Ideogram generation'
              'dalle:DALL·E generation'
              'recraft:Recraft generation'
              'stability:Stability generation'
              'runway:Runway video generation'
              'kling:Kling video generation'
              'luma:Luma generation'
              'pika:Pika generation'
              'vidu:Vidu generation'
              'hailuo:Hailuo generation'
              'seedance:Seedance generation'
              'gemini-flash-image:Gemini Flash Image (nano-banana)'
            )
            _arguments -C -s -S \
              '(-): :->gencmd' \
              '(-)*:: :->gencmd_args' && ret=0
            case $state in
              gencmd)
                _describe -t commands 'comfy generate subcommand' _gencmds && ret=0
                ;;
              gencmd_args)
                case $words[1] in
                  schema)
                    _arguments '1:model name:' && ret=0
                    ;;
                  resume)
                    _arguments \
                      '1:model name:' \
                      '2:job ID:' && ret=0
                    ;;
                  *)
                    _arguments \
                      '--prompt=[text prompt]:prompt:' \
                      '--download=[save output to file]:filename:_files' \
                      '--async[return immediately with job ID]' \
                      '*--image=[reference image path/URL (repeatable)]:image:_files' \
                      '--api-key=[Comfy API key (or COMFY_API_KEY env)]:key:' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          manager)
            local -a _mgrcmds
            _mgrcmds=(
              'disable:turn off manager entirely'
              'enable-gui:enable with new GUI'
              'disable-gui:enable without GUI'
              'enable-legacy-gui:enable with legacy interface'
              'clear:clear startup actions'
              'migrate-legacy:convert git-cloned Manager to pip package'
              'uv-compile-default:set unified resolver as default'
            )
            _arguments -C -s -S \
              '(-): :->mgrcmd' \
              '(-)*:: :->mgrcmd_args' && ret=0
            case $state in
              mgrcmd)
                _describe -t commands 'comfy manager subcommand' _mgrcmds && ret=0
                ;;
              mgrcmd_args)
                case $words[1] in
                  uv-compile-default)
                    _arguments '1:enable:(true false)' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          tracking)
            _arguments '1:action:(disable)' && ret=0
            ;;
          set-default)
            _arguments '1:workspace path:_directories' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  sloglint)
    # go-simpler/sloglint — log/slog style linter. Standalone surface
    # is minimal; configuration is golangci-lint primary.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
