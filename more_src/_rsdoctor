#compdef rsdoctor
# Documentation: https://rsdoctor.rs/guide/start/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'analyze:open the Rsdoctor analysis report from a manifest'
  'bundle-diff:compare two manifest.json files in the Rsdoctor UI'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rsdoctor command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (analyze)
        _arguments \
          '--profile=[path to manifest.json]:file:_files -g "manifest.json"' \
          '--port=[port to serve report on]:port:' \
          '--host=[host to serve on]:host:_hosts' \
          '--open[open the report in browser]' && ret=0 ;;
      (bundle-diff)
        _arguments \
          '--baseline=[baseline manifest.json]:file:_files -g "manifest.json"' \
          '--current=[current manifest.json]:file:_files -g "manifest.json"' \
          '--port=[port to serve diff on]:port:' \
          '--open[open the diff in browser]' && ret=0 ;;
    esac ;;
esac

return ret
