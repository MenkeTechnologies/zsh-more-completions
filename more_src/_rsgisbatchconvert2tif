#compdef rsgisbatchconvert2tif
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisbatchconvert2tif RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[A search string where for the input files (e.g., '\''./images/*.kea'\''). The search string much contain at least one * wildcard.]:value:_files' \
  '(-o --output)'{-o,--output}'[Output directory where output GeoTIFF files will be written.]:value:_files' \
  '--chkimgs[Only convert images which are not already]' \
  '*:file:_files' && ret=0

return ret
