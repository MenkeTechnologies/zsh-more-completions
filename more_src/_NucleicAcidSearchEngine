#compdef NucleicAcidSearchEngine
# Documentation: https://www.openms.org/documentation/html/TOPP_NucleicAcidSearchEngine.html
# OpenMS: identifies oligonucleotides from MS/MS spectra via database search

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input spectral data file (mzML or d)]:file:_files' \
  '-database[FASTA sequence database]:file:_files' \
  '-digest[pre-digested sequence database (oms)]:file:_files' \
  '-out[output mzTab results file]:file:_files' \
  '-id_out[idXML file for TOPPView visualization]:file:_files' \
  '-db_out[SQLite database output file]:file:_files' \
  '-digest_out[digested sequence database output]:file:_files' \
  '-lfq_out[label-free quantification targets (TSV)]:file:_files' \
  '-precursor:mass_tolerance[precursor mass tolerance]:double:' \
  '-precursor:mass_tolerance_unit[unit]:unit:(Da ppm)' \
  '-precursor:min_charge[minimum charge state]:int:' \
  '-precursor:max_charge[maximum charge state]:int:' \
  '-precursor:include_unknown_charge[include spectra with unknown charge]' \
  '-precursor:use_avg_mass[use average vs monoisotopic masses]' \
  '-precursor:use_adducts[account for salt adducts]' \
  '-precursor:potential_adducts[adduct definitions]:adducts:' \
  '-precursor:isotopes[isotope peak misassignment correction]:isotopes:' \
  '-fragment:mass_tolerance[fragment mass tolerance]:double:' \
  '-fragment:mass_tolerance_unit[unit]:unit:(Da ppm)' \
  '-fragment:ions[ion types to generate]:ions:' \
  '-modifications:fixed[fixed modifications (Modomics)]:mods:' \
  '-modifications:variable[variable modifications]:mods:' \
  '-modifications:variable_max_per_oligo[max variable mods per sequence]:int:' \
  '-modifications:resolve_ambiguities[resolve ambiguous mods via a-B ions]' \
  '-oligo:min_size[minimum sequence length]:int:' \
  '-oligo:max_size[maximum sequence length]:int:' \
  '-oligo:missed_cleavages[allowed missed cleavages]:int:' \
  '-oligo:enzyme[RNase selection]:enzyme:' \
  '-fdr:decoy_pattern[decoy sequence identifier string]:pattern:' \
  '-fdr:cutoff[FDR q-value threshold]:double:' \
  '-fdr:remove_decoys[exclude decoy hits from output]' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
