#compdef mini
# Documentation: https://mini-swe-agent.com/latest/usage/mini/
# Reference accessed: 2026-05-22
# Verified: src/minisweagent/run/mini.py Typer options.

# Zsh completion for mini - mini-SWE-agent local coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --model)'{-m,--model}'[model to use]:model:' \
  '--model-class[agent model class]:class:' \
  '--agent-class[agent implementation class]:class:' \
  '--environment-class[environment class]:class:' \
  '(-t --task)'{-t,--task}'[task or problem statement]:task:' \
  '(-y --yolo)'{-y,--yolo}'[run without confirmation]' \
  '(-l --cost-limit)'{-l,--cost-limit}'[cost limit USD, 0 disables]:usd:' \
  '(-c --config)*'{-c,--config}'[config file or key=value override]:config:' \
  '(-o --output)'{-o,--output}'[trajectory output file]:file:_files' \
  '--exit-immediately[exit when agent finishes without prompt]' && ret=0

return ret
