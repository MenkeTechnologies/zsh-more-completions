#compdef pandoc-plot
# _pandoc-plot — pandoc filter to render figures from code blocks (LaurentRDC/pandoc-plot)
# upstream: https://github.com/LaurentRDC/pandoc-plot
# Flags from executable/Main.hs.

_pandoc-plot() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(- *)--full-version[show full version info]' \
        '(- *)--manual[show full manual]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'toolkits:show available rendering toolkits'
                'clean:clean output directories'
                'write-example-config:write example config to file'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                clean) _arguments '--config=[config file]:file:_files' '1:input file:_files' ;;
                toolkits) _arguments '--config=[config file]:file:_files' ;;
                write-example-config) _arguments '1:output file:_files' ;;
            esac
            ;;
    esac
}

_pandoc-plot "$@"
