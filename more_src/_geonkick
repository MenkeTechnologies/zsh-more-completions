#compdef geonkick
# Documentation: https://github.com/quamplex/geonkick
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Geonkick: percussion synthesizer (kick drum / bass / hat) - Qt GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '*:geonkick preset file:_files -g "*.(gkit|gkik)"' && ret=0
return ret
