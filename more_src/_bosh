#compdef bosh

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'alias-env:save environment alias'
  'unalias-env:remove environment alias'
  'create-env:create or update an environment'
  'delete-env:delete an environment'
  'environment:show current environment'
  'environments:list environments'
  'log-in:log into the director'
  'log-out:log out of the director'
  'stemcells:list stemcells'
  'upload-stemcell:upload a stemcell'
  'delete-stemcell:delete a stemcell'
  'repack-stemcell:repack a stemcell'
  'inspect-local-stemcell:inspect a local stemcell'
  'releases:list releases'
  'upload-release:upload a release'
  'delete-release:delete a release'
  'export-release:export a release'
  'inspect-release:inspect a release'
  'inspect-local-release:inspect a local release'
  'create-release:create a release'
  'finalize-release:finalize a release'
  'init-release:initialize a release directory'
  'reset-release:reset release working state'
  'generate-job:generate a job in a release'
  'generate-package:generate a package in a release'
  'vendor-package:vendor a package'
  'sha2ify-release:rewrite release using SHA-256'
  'blobs:list release blobs'
  'add-blob:add a release blob'
  'remove-blob:remove a release blob'
  'sync-blobs:sync release blobs'
  'upload-blobs:upload release blobs'
  'cloud-config:show cloud config'
  'update-cloud-config:update cloud config'
  'cpi-config:show CPI config'
  'update-cpi-config:update CPI config'
  'runtime-config:show runtime config'
  'update-runtime-config:update runtime config'
  'configs:list configs'
  'config:show a config'
  'update-config:update a config'
  'delete-config:delete a config'
  'diff-config:diff a config'
  'deploy:deploy a manifest'
  'deployment:show current deployment'
  'deployments:list deployments'
  'delete-deployment:delete a deployment'
  'manifest:show deployment manifest'
  'undeploy:undeploy a deployment'
  'instances:list deployment instances'
  'vms:list deployment VMs'
  'recreate:recreate instances'
  'restart:restart instances'
  'start:start instances'
  'stop:stop instances'
  'ignore:ignore an instance'
  'unignore:unignore an instance'
  'logs:fetch logs'
  'variables:list deployment variables'
  'pcap:capture packets on instances'
  'disks:list disks'
  'attach-disk:attach a disk'
  'delete-disk:delete a disk'
  'orphan-disk:orphan a disk'
  'orphan-disks:list orphaned disks'
  'delete-vm:delete a VM'
  'orphaned-vms:list orphaned VMs'
  'snapshots:list snapshots'
  'take-snapshot:take a snapshot'
  'delete-snapshot:delete a snapshot'
  'delete-snapshots:delete snapshots'
  'errands:list errands'
  'run-errand:run an errand'
  'task:show task details'
  'tasks:list tasks'
  'cancel-task:cancel a task'
  'cancel-tasks:cancel tasks'
  'event:show event details'
  'events:list events'
  'locks:list director locks'
  'cloud-check:run cloud check'
  'fix-rendered-templates:re-render and apply templates'
  'update-resurrection:enable/disable resurrector'
  'create-recovery-plan:create a recovery plan'
  'recover:recover from incident'
  'ssh:SSH into instances'
  'scp:SCP files to/from instances'
  'curl:curl through director'
  'interpolate:interpolate a manifest'
  'clean-up:clean up unused resources'
  'help:show help'
  'packages:list packages'
  'pkgcaches:show package caches'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-e --environment)'{-e,--environment=}'[director environment]:env:' \
  '--ca-cert=[CA cert]:file:_files' \
  '--client=[UAA client name]:client:' \
  '--client-secret=[UAA client secret]:secret:' \
  '(-d --deployment)'{-d,--deployment=}'[deployment name]:deployment:' \
  '--config=[BOSH config file]:file:_files' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive]' \
  '--json[JSON output]' \
  '--tty[force tty]' \
  '--no-color[disable color]' \
  '*--column=[output column]:column:' \
  '--parallel=[parallel ops]:n:' \
  '--sha2[use SHA-256]' \
  '*'{-v,--var=}'[set variable key=val]:var:' \
  '*--var-file=[variable from file key=path]:var:' \
  '*'{-l,--vars-file=}'[variables file]:file:_files' \
  '--vars-store=[variables store path]:file:_files' \
  '*--vars-env=[variables from env prefix]:prefix:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bosh subcommand' subcommands && ret=0
    ;;
esac

return ret
