#compdef pktvisor-cli
# Documentation: https://github.com/orb-community/pktvisor
# Terminal UI client querying a running pktvisord metrics web server

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '--version[show client version]' \
  '-p+[query pktvisord webserver on the given port]:port' \
  '-H+[query pktvisord webserver on the given host]:host:_hosts' \
  '-P+[pktvisor policy to query]:policy' \
  '--tls[use TLS to communicate with pktvisord webserver]' \
  '--tls-noverify[do not verify TLS certificate]' && ret=0

return ret
