#compdef dwglayers
# Documentation: https://github.com/LibreDWG/libredwg/blob/master/programs/dwglayers.1
# LibreDWG: print the list of layers in a DWG

local ret=1

_arguments -s -S \
  '(-x --extnames)'{-x,--extnames}'[print EXTNAMES (r13-r14 only), space instead of _]' \
  '(-f --flags)'{-f,--flags}'[also print flags: frozen, ON/OFF, locked]' \
  '(-o --on)'{-o,--on}'[print only ON layers]' \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '--version[output version information and exit]' \
  '*:DWG file:_files -g "*.(dwg|DWG)"' && ret=0

return ret
