#compdef rsgischkgdalfile
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# A utility which can be used to check whether a GDAL

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input file search path (i.e., '\''/path/to/*.kea'\'')]:value:_files' \
  '--vec[Specify that the input file is a]' \
  '--rmerr[Delete error files from system.]' \
  '--printnames[Print file names as checking]' \
  '--printerrs[Print the error messages for the images]' \
  '--nbands[Check the number of bands is correct. Ignored if 0; Default.]:value:_files' \
  '--epsg[The EPSG code for the projection of the images.]:value:_files' \
  '--chkproj[Check that a projection is defined]' \
  '--readimg[Check the image by reading part of it.]' \
  '--chksum[Check the image by calculating a checksum from the image pixel values.]' \
  '--vecmulti[Specifies that the vector file has multiple files (e.g., shapefile) and they should all be deleted if error and --rmerr is selected.]' \
  '--nosort[Do not sort the list of files.]' \
  '(-d --modate)'{-d,--modate}'[If provided, only files modified after this date]:value:_files' \
  '*:file:_files' && ret=0

return ret
