#compdef chklref
# Documentation: chklref --help
# Source: check for unused labels and bibitems in a LaTeX source file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)'{-v,--version}'[print version]' \
    '(-t --tex)'{-t+,--tex=}'[TeX compiler to use (default pdflatex)]:compiler:_command_names -e' \
    '--tex-options=[quoted string of options to pass to the TeX compiler]:opts:' \
    '(-d --debug)'{-d,--debug}'[debug mode (do not clean .chk file)]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode (do not print TeX output)]' \
    '--parse-only[use existing .chk file (skip TeX compile)]' \
    '1:tex file:_files -g "*.tex"' \
    && ret=0

return ret
