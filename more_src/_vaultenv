#compdef vaultenv
# Documentation: https://github.com/channable/vaultenv
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--host=[Vault host]:host:_hosts' \
  '--port=[Vault port]:port:' \
  '--addr=[full Vault address (with scheme)]:url:' \
  '--no-connect-tls[disable TLS]' \
  '--connect-tls[enable TLS]' \
  '--no-validate-certs[skip certificate validation]' \
  '--validate-certs[validate certificates]' \
  '--token=[Vault token]:token:' \
  '--kubernetes-role=[Kubernetes auth role]:role:' \
  '--github-token=[GitHub token for auth]:token:' \
  '--auth-backend=[custom auth backend]:backend:' \
  '(--secrets-file --secret-file)'{--secrets-file=,--secret-file=}'[secret specification file]:file:_files' \
  '--no-inherit-env[do not inherit parent env]' \
  '--inherit-env[inherit parent env]' \
  '--inherit-env-blacklist=[comma-separated names to exclude]:names:' \
  '--retry-base-delay-milliseconds=[retry base delay in ms]:n:' \
  '--retry-attempts=[max retry attempts]:n:' \
  '--max-concurrent-requests=[max concurrent HTTP connections]:n:' \
  '--use-path[search PATH for the executable]' \
  '--log-level=[log level]:level:(error info)' \
  '--duplicate-variable-behavior=[duplicate var handling]:behavior:(error keep overwrite)' \
  '*::cmd_and_args:_command_names' && ret=0

return ret
