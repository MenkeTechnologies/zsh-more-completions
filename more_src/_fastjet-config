#compdef fastjet-config
# Documentation: https://www.fastjet.fr/repo/doxygen-3.4.0/INSTALL_source.html
# fastjet-config - query FastJet build/link flags

local ret=1

_arguments -s -S \
  '--help[print help and exit]' \
  '--version[print FastJet version and exit]' \
  '--prefix[get the FastJet installation directory]' \
  '--cxxflags[compilation flags for C++ programs]' \
  '--libs[flags to pass to the linker]' \
  '--shared[use shared (vs static) lib]' \
  '--plugins[also link the FastJet plugins]' \
  '--rpath[add -rpath to FastJet lib dir at link-time]' \
  '--runpath[add runpath to FastJet lib dir (ELF only)]' \
  '--list-plugins[list all available plugins]' \
  '--config[show summary of how FastJet was configured]' && ret=0

return ret
