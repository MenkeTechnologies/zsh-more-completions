#compdef otbcli_FastNLMeans
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_FastNLMeans.html
# Orfeo ToolBox: denoise an image with the fast non-local means filter

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to denoise]:image:_files' \
  '-out[output image]:output:_files' \
  '-patchradius[patch radius (size 2*r+1)]:value:' \
  '-searchradius[search window radius (size 2*r+1)]:value:' \
  '-sig[noise standard deviation]:value:' \
  '-thresh[similarity score factor]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
