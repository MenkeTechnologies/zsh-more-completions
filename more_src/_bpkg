#compdef bpkg
# Zsh completion for bpkg - Bash package manager
# https://github.com/bpkg/bpkg

local -a commands=(
  'install:install a bash package'
  'update:update installed packages'
  'list:list installed packages'
  'init:initialize a new package'
  'run:run a package script'
  'package:show package info'
  'term:open package term'
  'source:source a package'
  'suggest:suggest packages'
  'getdeps:install package dependencies'
  'show:show information about a package'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'bpkg command' commands
    ;;
  args)
    case $words[1] in
      install)
        _arguments \
          '-g[install globally]' \
          '-s[skip dependencies]' \
          '*:package (user/repo or URL):'
        ;;
      run)
        _arguments '*:script name:'
        ;;
    esac
    ;;
esac
