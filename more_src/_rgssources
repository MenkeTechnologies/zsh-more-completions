#compdef rgssources
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgssources/node33.html
# Construct a list of sources to be processed by the RGS pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--filemode=[open a previous source list for editing or create new]:mode' \
  '--changeprime=[modify the prime source index in modify mode]:bool:(yes no)' \
  '--changeattitude=[update the stored attitude in modify mode]:bool:(yes no)' \
  '--srclist=[name of the RGS source list file]:file:_files' \
  '--instexpid=[instrument and exposure identifier]:id' \
  '--writeobskwds=[write observation-specific keywords to header]:bool:(yes no)' \
  '--writeexpkwds=[write exposure-specific keywords to header]:bool:(yes no)' \
  '--clobberonlabel=[behavior on source label conflicts]:value' \
  '--primestyle=[way the prime source is specified]:style' \
  '--primelabel=[LABEL column value for the primary source]:label' \
  '--primeindex=[PRIMESRC keyword index value]:n' \
  '--attstyle=[way the attitude is calculated]:style' \
  '--meanset=[attitude history file for mean calculation]:file:_files' \
  '--medianset=[attitude history file for median calculation]:file:_files' \
  '--attra=[right ascension for user-input attitude]:ra' \
  '--attdec=[declination for user-input attitude]:dec' \
  '--attapos=[position angle for user-input attitude]:value' \
  '--expmediantable=[table with exposure-median keywords]:table' \
  '--addusersource=[add a source with a command-line position]:bool:(yes no)' \
  '*:param=value:_default' && ret=0

return ret
