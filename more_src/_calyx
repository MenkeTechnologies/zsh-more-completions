#compdef calyx
# ============================================================================
#  _calyx — Calyx: Intermediate Language for Hardware Accelerator Generators
#
#  Source-direct extraction from
#    https://github.com/calyxir/calyx/blob/main/src/cmdline.rs
#    https://github.com/google/argh (the argh library itself)
#
#  Maintained by the Calyx project (calyxir/calyx), originally from
#  Cornell Capra group.  597 GH stars.  Calyx is an INTERMEDIATE
#  LANGUAGE for hardware accelerator generators — sits between
#  high-level languages (Dahlia, Filament) and hardware description
#  languages (Verilog, FIRRTL, MLIR).  Backends emit Verilog (default),
#  FIRRTL, MLIR, Xilinx XML/SV interface code, resource usage reports,
#  and (with serialize feature) sexp dumps.
#
#  CLI library taxonomy update: 8th Rust CLI library — google/argh.
#  calyx uses `use argh::FromArgs` — argh is Google's Rust CLI parser
#  OPTIMIZED FOR CODE SIZE.  Distinct from R275 Rust clap-derive
#  (proc-macro), R330 Rust bpaf (functional combinator).  argh uses
#  `#[argh(...)]` attribute DSL on struct fields, DOC COMMENTS as help
#  text, and enum variants with `#[argh(subcommand)]` for subcommand
#  dispatch.  Smaller feature set than clap-derive — no env var
#  fallback, no value enum derive macros, no conditional groups.
#  Optimized for: SMALLER compiled binary + FASTER compile times
#  (matters for tools like Fuchsia OS components where each binary
#  bundles its own parser).  1916 GH stars on google/argh.  Brings
#  cross-language CLI library taxonomy variant count to 83; Rust
#  ecosystem now has 8 documented CLI libraries — extends its lead.
#
#  Surface (verbatim from src/cmdline.rs `Opts` struct + subcommands):
#
#  Top-level options:
#    -o <file>                   Output file (default: stdout)
#    -l <path> (repeatable)      Primitives library path (env:
#                                CALYX_PRIMITIVES_DIR)
#    -m <mode>                   Compilation mode
#    -b <backend>                Backend: verilog (default) / firrtl /
#                                mlir / resources / xilinx-xml /
#                                xilinx-sv-interface / primitive-uses /
#                                sexp (with `serialize` feature)
#    -p <pass> (repeatable)      Run this pass during execution
#    -d <pass> | --disable-pass  Disable pass (repeatable)
#    -x <opt> | --extra-opt      Extra options passed to the context
#    -i <ord> | --insert         Establish relative ordering of passes
#    --log <level>               Log level (default: warn)
#    --synthesis                 Enable synthesis mode
#    --disable-verify            Disable verification checks
#    --nested                    Emit nested assignments (Verilog backend)
#    --emit-primitive-extmodules Emit extmodules (FIRRTL backend)
#    --dump-ir                   Print IR after every pass
#    --version                   Print version information
#    <file>                      Positional: input calyx program (.futil)
#
#  Subcommands:
#    pass-help [name]            Help information about passes (alias or name)
#    format <file>               Format a calyx file in place
#
#  Dup-skipped neighbors during hunt (already in corpus):
#    - termscp (veeso/termscp 2962 stars, SCP terminal — IN CORPUS)
#    - bin (w4/bin 668 stars, paste service — DUP, generic name)
#    - sunwalker-box (purplesyringa 30 stars — narrow)
# ============================================================================

_calyx() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '-o[output file]:output:_files' \
    '*-l[primitives library path (repeatable)]:lib path:_directories' \
    '-m[compilation mode]:mode' \
    '-b[backend]:backend:(verilog firrtl mlir resources xilinx-xml xilinx-sv-interface primitive-uses sexp)' \
    '*-p[run this pass]:pass' \
    '*-d[disable pass]:pass' \
    '*--disable-pass[disable pass]:pass' \
    '*-x[extra context option]:option' \
    '*--extra-opt[extra context option]:option' \
    '*-i[relative ordering of passes]:ordering' \
    '*--insert[relative ordering of passes]:ordering' \
    '--log[log level]:level:(off error warn info debug trace)' \
    '--synthesis[enable synthesis mode]' \
    '--disable-verify[disable verification checks]' \
    '--nested[emit nested assignments (Verilog backend)]' \
    '--emit-primitive-extmodules[emit extmodules (FIRRTL backend)]' \
    '--dump-ir[print IR after every pass]' \
    '--version[print version information]' \
    '1: :->cmd_or_file' \
    '*:: :->subargs'

  case $state in
    cmd_or_file)
      local -a verbs
      verbs=(
        'pass-help:help information about passes'
        'format:format a calyx file'
      )
      _alternative \
        'commands:calyx subcommand:(($verbs))' \
        'files:calyx source file:_files -g "*.futil"'
      ;;
    subargs)
      case $line[1] in
        pass-help)
          _message 'pass alias or name'
          ;;
        format)
          _files -g '*.futil'
          ;;
      esac
      ;;
  esac
}

_calyx "$@"
