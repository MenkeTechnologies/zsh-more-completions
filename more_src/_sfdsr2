#compdef sfdsr2
# Documentation: https://ahay.org/RSF/sfdsr2.html
# Madagascar: 2-D prestack modeling/migration with double square-root operator

local ret=1

_arguments -s \
  'slowness=[auxiliary input file name]:file:_files' \
  'inv=[if y, modeling; if n, migration (y/n)]:bool:(y n)' \
  'verb=[verbosity flag (y/n)]:bool:(y n)' \
  'eps=[stability parameter]:float:' \
  'nt=[taper size]:int:' \
  'nr=[maximum number of references]:int:' \
  'dt=[time error]:float:' \
  'npad=[padding on offset wavenumber]:int:' \
  'nw=[length of frequency axis (for modeling)]:int:' \
  'dw=[frequency sampling (for modeling)]:float:' \
  'w0=[frequency origin (for modeling)]:float:' \
  '*:rsf file:_files' && ret=0

return ret
