#compdef oclif

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:generate a new CLI project'
  'generate:command:add a command to an existing CLI'
  'generate:hook:add a hook to an existing CLI'
  'manifest:generate oclif.manifest.json'
  'pack:pack CLI into tarballs'
  'pack:deb:pack CLI into a deb package'
  'pack:macos:pack CLI into a macOS installer'
  'pack:tarballs:pack CLI into tarballs'
  'pack:win:pack CLI into a Windows installer'
  'upload:upload packed CLI assets'
  'promote:promote a release channel'
  'readme:generate README.md from commands'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'oclif command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (generate)
        _arguments \
          '--defaults[use default values for prompts]' \
          '1:output directory:_directories' && ret=0
        ;;
      (manifest)
        _arguments '1:path:_directories' && ret=0
        ;;
      (readme)
        _arguments \
          '--dir=[directory of README]:directory:_directories' \
          '--multi[generate multi-page docs]' \
          '--aliases[include aliases in output]' && ret=0
        ;;
      (pack:tarballs)
        _arguments \
          '-r+[root directory]:directory:_directories' \
          '--root=[root directory]:directory:_directories' \
          '-t+[target platforms]:targets' \
          '--targets=[target platforms]:targets' \
          '--xz[also compress with xz]' && ret=0
        ;;
      (promote)
        _arguments \
          '--channel=[channel to promote to]:channel' \
          '--version=[version to promote]:version' \
          '--sha=[Git SHA to promote]:sha' \
          '--indexes[update channel indexes]' \
          '--win[promote Windows installer]' \
          '--macos[promote macOS installer]' && ret=0
        ;;
    esac
    ;;
esac

return ret
