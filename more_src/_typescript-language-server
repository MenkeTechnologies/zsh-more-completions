#compdef typescript-language-server

# Zsh completion for typescript-language-server

_arguments -s -S \
  '--stdio[use stdio transport]' \
  '--node-ipc[use Node IPC transport]' \
  '--socket=[use socket transport]:port:' \
  '--pipe=[use named pipe transport]:pipe name:' \
  '--tsserver-path=[path to tsserver]:path:_files' \
  '--tsserver-log-file=[tsserver log file]:file:_files' \
  '--tsserver-log-verbosity=[tsserver log level]:level:(off terse normal requestTime verbose)' \
  '--log-level=[log level]:level:(off error warn info log)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]'
