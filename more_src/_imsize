#compdef imsize
# imsize: print the sky region covered by a FITS or IRAF image (WCSTools)

local ret=1

_arguments -s -S \
  '-b[initial center RA and Dec in B1950 (FK4)]:RA:_message RA' \
  '-c[print object name, center, system, and size for getimage]' \
  '-d[print object name, center, and size as input to getimage]' \
  '-j[initial center RA and Dec in J2000 (FK5)]:RA:_message RA' \
  '-v[print more information about process]' \
  '*:FITS file:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
