#compdef ksubdomain
# Documentation: https://github.com/boy-hack/ksubdomain
# Stateless asynchronous subdomain enumeration and verification.

local ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1:command:((
    enum\:"enumerate subdomains by bruteforce"
    e\:"enumerate subdomains by bruteforce"
    verify\:"verify a list of domains resolve"
    v\:"verify a list of domains resolve"
    test\:"test max packet send rate of local device"
    device\:"show available network devices"
    help\:"show help"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      enum|e)
        _arguments -s -S \
          '(-d --domain)'{-d,--domain}'[target domain (repeatable)]:domain' \
          '--ds[batch domain file]:file:_files' \
          '--domain-list[batch domain file]:file:_files' \
          '(-f --filename)'{-f,--filename}'[wordlist file (built-in used by default)]:file:_files' \
          '--use-ns-records[read NS records and add to DNS resolvers]' \
          '(-b --bandwidth)'{-b,--bandwidth}'[bandwidth limit, e.g. 5m, 10m, 100m (default 3m)]:bandwidth' \
          '(-r --resolvers)'{-r,--resolvers}'[DNS servers (built-in used by default)]:file:_files' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' && ret=0
        ;;
      verify|v)
        _arguments -s -S \
          '(-d --domain)'{-d,--domain}'[domain (repeatable)]:domain' \
          '(-f --filename)'{-f,--filename}'[read domain list from file]:file:_files' \
          '--stdin[read from stdin]' \
          '(-b --bandwidth)'{-b,--bandwidth}'[bandwidth limit, e.g. 5m, 10m, 100m (default 3m)]:bandwidth' \
          '(-r --resolvers)'{-r,--resolvers}'[DNS servers (built-in used by default)]:file:_files' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
