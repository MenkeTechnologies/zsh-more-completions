#compdef fend
# Documentation: https://printfn.github.io/fend/documentation/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fend: arbitrary-precision unit-aware calculator.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-e --eval)'{-e,--eval}'[evaluate a specified expression]:expression:' \
  '(-f --file)'{-f,--file}'[read and evaluate a file]:file:_files' \
  '--default-config[show the default configuration file]' \
  '*:expression:' && return 0
