#compdef fend
# Documentation: https://man.archlinux.org/search?q=fend
# Reference accessed: 2026-05-16

# Zsh completion for fend - arbitrary-precision unit-aware calculator

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-e --exchange-rate-source)'{-e,--exchange-rate-source}'[set exchange rate source]:source:(ecb un)' \
  '--no-trailing-newline[do not print trailing newline]' \
  '*:expression:' && return 0
