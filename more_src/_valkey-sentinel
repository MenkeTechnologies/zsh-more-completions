#compdef valkey-sentinel
# Documentation: https://valkey.io/topics/sentinel/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# valkey-sentinel: Valkey HA sentinel
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--sentinel[sentinel mode (default)]' \
  '*:sentinel.conf:_files -g "*.conf"' && ret=0
return ret
