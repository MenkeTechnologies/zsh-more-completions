#compdef telegraf

# Zsh completion for telegraf - InfluxData plugin-driven agent for metrics

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files' \
  '--config-directory=[config directory]:dir:_directories' \
  '--debug[enable debug logging]' \
  '--quiet[suppress log messages]' \
  '--test[gather metrics once and print]' \
  '--test-wait=[wait time for test in seconds]:seconds:' \
  '--once[gather metrics once and exit]' \
  '--usage=[show usage for a plugin]:plugin:' \
  '--input-filter=[input plugins to enable]:plugins:' \
  '--input-list[list available input plugins]' \
  '--output-filter=[output plugins to enable]:plugins:' \
  '--output-list[list available output plugins]' \
  '--aggregator-filter=[aggregator plugins to enable]:plugins:' \
  '--processor-filter=[processor plugins to enable]:plugins:' \
  '--sample-config[print sample configuration]' \
  '--pprof-addr=[pprof address]:addr:' \
  '--watch-config=[watch config for changes]:notify method:(inotify poll)' \
  '--pidfile=[PID file path]:file:_files' \
  '--plugin-directory=[plugin directory]:dir:_directories' \
  '--unprotected[do not protect secrets in memory]'
