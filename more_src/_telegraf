#compdef telegraf
# Documentation: https://docs.influxdata.com/telegraf/v1/commands/
# Reference accessed: 2026-05-21
# Verified: upstream InfluxData docs.

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'config:generate and migrate Telegraf configurations'
  'secrets:manage secrets in secret stores'
  'plugins:print available plugins'
  'version:print current version'
)

_arguments -C -s -S \
  '--help[show help]' \
  '--version[show version (deprecated, use version subcommand)]' \
  '--config=[load a specific configuration file]:file:_files' \
  '--config-directory=[load additional *.conf from directory]:dir:_directories' \
  '--once[gather metrics once, write them, exit]' \
  '--test[gather metrics once and print to stdout]' \
  '--test-wait=[seconds to wait for service inputs in test/once]:seconds:' \
  '--debug[enable debug logging]' \
  '--quiet[run in quiet mode]' \
  '--usage=[print plugin usage information]:plugin:' \
  '--pidfile=[write PID to file]:file:_files' \
  '--pprof-addr=[enable pprof listening on address]:addr:' \
  '--watch-config=[restart telegraf when config changes]:method:(inotify poll)' \
  '--password=[unlock secret stores]:password:' \
  '--unprotected[disable in-memory secret protection]' \
  '--old-env-behavior[use pre-v1.27 env replacement behavior]' \
  '--input-filter=[enable specific input plugins (colon-separated)]:plugins:' \
  '--output-filter=[enable specific output plugins]:plugins:' \
  '--aggregator-filter=[enable specific aggregator plugins]:plugins:' \
  '--processor-filter=[enable specific processor plugins]:plugins:' \
  '--secretstore-filter=[enable specific secret stores]:plugins:' \
  '--section-filter=[filter configuration sections]:sections:' \
  '--input-list[print available input plugins]' \
  '--output-list[print available output plugins]' \
  '--deprecation-list[print deprecated plugins/options]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'telegraf command' commands && ret=0 ;;
esac

return ret
