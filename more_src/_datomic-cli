#compdef datomic-cli
# _datomic-cli — Cognitect Datomic database CLI alias (cognitect team, Clojure/Java); custom argparse
# upstream: https://docs.datomic.com/cloud/operation/cli-tools.html

_datomic-cli() {
    local -a sub=(
        'analytics:analytics commands'
        'cli-config:configure cli'
        'cloud:cloud system commands'
        'cloud:list-systems:list cloud systems'
        'cloud:show-system:show system info'
        'cloud:update-stack:update cloudformation stack'
        'cloud:apply-update-policy:apply update policy'
        'cloud:update-runtime:update runtime'
        'cloud:update-storage:update storage'
        'cloud:delete-stack:delete stack'
        'cloud:create-storage:create storage stack'
        'cloud:create-compute:create compute stack'
        'cloud:create-system:create new system'
        'cloud:upgrade-aws-cli:upgrade aws cli'
        'cloud:upgrade-base:upgrade base stack'
        'cloud:bastion:start:start bastion'
        'cloud:bastion:stop:stop bastion'
        'cloud:bastion:status:bastion status'
        'cloud:access:start access tunnel'
        'cloud:billing:show billing'
        'cloud:gateway:start gateway'
        'cloud:monitor:show monitoring'
        'cloud:scaling:show scaling'
        'cloud:reset:reset cloud system'
        'cloud:divert-system:divert system to new compute'
        'client:create-client:scaffold client config'
        'pro:start:start datomic pro transactor'
        'pro:stop:stop transactor'
        'pro:status:transactor status'
        'pro:restore-db:restore database'
        'pro:backup-db:backup database'
        'pro:create-db:create database'
        'pro:list-dbs:list databases'
        'pro:delete-db:delete database'
        'analytics:run:run analytics query'
        'analytics:stop:stop analytics'
        'tools:upgrade-base-schema:upgrade base schema'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--region=+[aws region]:str:' \
        '--profile=+[aws profile]:str:' \
        '--system=+[system name]:str:' \
        '--config=+[config file]:file:_files' \
        '--dry-run[dry run]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datomic subcommand' sub ;;
        args)
            case $words[1] in
                cloud:create-system) _arguments \
                    '--name=+[system name]:str:' \
                    '--region=+[region]:str:' \
                    '--instance-type=+[instance type]:str:' \
                    '--storage-size=+[storage size]:n:' \
                    '--template-version=+[template version]:str:' ;;
                cloud:update-stack|cloud:update-runtime|cloud:update-storage|cloud:delete-stack) _arguments \
                    '--system=+[system name]:str:' \
                    '--region=+[region]:str:' ;;
                pro:create-db|pro:delete-db|pro:restore-db|pro:backup-db) _arguments \
                    '--name=+[db name]:str:' ;;
            esac
            ;;
    esac
}

_datomic-cli "$@"
