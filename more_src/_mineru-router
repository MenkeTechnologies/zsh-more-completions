#compdef mineru-router
# Documentation: https://opendatalab.github.io/MinerU/usage/cli_tools/
# Multi-GPU orchestration router for MinerU

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--host=[host to bind]:host:' \
  '--port=[port to bind]:port:' \
  '--upstream-url=[upstream worker URL]:url:' \
  '--local-gpus=[local GPU ids]:gpus:' \
  '--enable-vlm-preload=[preload VLM model]:bool:(true false)' && ret=0

return ret
