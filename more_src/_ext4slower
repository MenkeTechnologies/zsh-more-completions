#compdef ext4slower ext4slower-bpfcc xfsslower xfsslower-bpfcc zfsslower zfsslower-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/ext4slower.py + xfsslower.py + zfsslower.py argparse — identical 4-flag shape)
# Reference accessed: 2026-05-29
# {ext4,xfs,zfs}slower — trace slow {ext4,XFS,ZFS} filesystem I/O operations (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-j --csv)'{-j,--csv}'[just print fields: comma-separated values]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:min_ms (minimum I/O duration to trace, default 10):' \
  && ret=0

return ret
