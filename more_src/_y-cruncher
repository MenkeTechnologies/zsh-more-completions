#compdef y-cruncher

# y-cruncher: multithreaded constant computer + RAM stress tester
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-bench[run benchmark]' \
  '-stress[run stress test]' \
  '-pi[compute Pi]' \
  '-e[compute e]' \
  '-config[run with config file]:file:_files -g "*.cfg"' \
  '-test[unit test]' \
  '-out[output dir]:dir:_files -/' \
  '*::y-cruncher args:_files' && ret=0
return ret
