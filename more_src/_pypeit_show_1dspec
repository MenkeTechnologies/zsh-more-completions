#compdef pypeit_show_1dspec
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Plot a 1D spectrum from a PypeIt spec1d file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--list[list the extensions with spectra]' \
  '(--obj)--exten=[extension number to visualize]:exten' \
  '(--exten)--obj=[object identifier for plotting]:obj' \
  '--extract=[extraction methodology]:method:(BOX OPT)' \
  '--flux[show the flux-calibrated spectrum]' \
  '(-m --unmasked)'{-m,--unmasked}'[display only unmasked data points]' \
  '*:spec1d file:_files -g "*.fits"' && ret=0

return ret
