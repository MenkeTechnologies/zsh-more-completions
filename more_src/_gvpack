#compdef gvpack
# Documentation: man gvpack(1) (graphviz)
# Source: GraphViz gvpack — merge and pre-laid-out graphs into a single graph.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[array packing (optional col/row-major, alignment)]:opts:' \
    '-g[graph-level pack to prevent overlap]' \
    '*-G-[graph attribute (name=value)]:name=value:' \
    '-m+[output-point margin]:margin:' \
    '-n[node-level pack; ignore clusters]' \
    '-o+[output file]:file:_files' \
    '-s+[root graph name (default root)]:name:' \
    '-u[do not pack; just combine into a single graph]' \
    '-v[verbose]' \
    '(- *)-?[show usage]' \
    '*:laid-out DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
