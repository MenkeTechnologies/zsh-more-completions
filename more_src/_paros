#compdef paros
# Documentation: https://man.archlinux.org/search?q=paros
# Reference accessed: 2026-05-16

# Paros: legacy web application security proxy (Java)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-port[listen port]:port:' \
  '-config[config file]:file:_files' \
  '*::paros args:_files' && ret=0
return ret
