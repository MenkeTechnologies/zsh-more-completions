#compdef sdreport
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# sdreport - rDock report data fields from an SD file.

local ret=1

_arguments -s -S \
  '-l[list format output]' \
  '-t+[tabulate selected fields]:fields:' \
  '-c+[CSV format output fields]:fields:' \
  '-s[summary statistics per unique ligand ID]' \
  '-sup[supplier format tabulation]' \
  '-id+[data field used as ligand ID]:field:' \
  '-nh[do not output column headings]' \
  '-o[use v3.00 score field names]' \
  '-norm[use normalised score field names]' \
  '*:file:_files' && ret=0

return ret
