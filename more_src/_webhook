#compdef webhook
# Documentation: https://github.com/adnanh/webhook/blob/master/docs/Webhook-Parameters.md
# Reference accessed: 2026-05-21
# Verified: upstream Webhook-Parameters.md flag list.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*-hooks=[Path to the hooks definition file (repeatable)]:file:_files -g "*.{json,yaml,yml}"' \
  '-ip=[IP address to listen on (default 0.0.0.0)]:address' \
  '-port=[Port to listen on (default 9000)]:port' \
  '-socket=[Unix socket or Windows named pipe path]:socket:_files' \
  '-verbose[Show verbose output]' \
  '-nopanic[Do not panic on hook loading errors]' \
  '-hotreload[Watch hooks file for changes and reload]' \
  '-secure[Use HTTPS instead of HTTP]' \
  '-cert=[Path to the HTTPS certificate PEM file]:file:_files -g "*.pem"' \
  '-key=[Path to the HTTPS certificate private key PEM file]:file:_files -g "*.pem"' \
  '-template[Parse hooks file as a Go template]' \
  '*-header=[Response header (name=value, repeatable)]:header' \
  '-urlprefix=[URL prefix for served hooks (default hooks)]:prefix' \
  '-http-methods=[Comma-separated allowed HTTP methods]:methods' \
  '-logfile=[Path to the log file]:file:_files' \
  '-pidfile=[Path to the PID file]:file:_files' \
  '-debug[Show debug output]' \
  '-list-cipher-suites[List available TLS cipher suites]' \
  '-cipher-suites=[Comma-separated TLS cipher suites]:suites' \
  '-tls-min-version=[Minimum TLS version (default 1.2)]:version:(1.0 1.1 1.2 1.3)' \
  '-x-request-id[Use X-Request-Id header as request ID]' \
  '-x-request-id-limit=[Truncate X-Request-Id length]:limit' \
  '-setuid=[Set UID after binding]:uid' \
  '-setgid=[Set GID after binding]:gid' \
  '-max-multipart-mem=[Max bytes for multipart parsing]:bytes' \
  '-version[Display version]' && ret=0

return ret
