#compdef nsc

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add assets such as accounts, users, clusters'
      'delete:delete assets such as accounts, users'
      'describe:describe assets such as accounts, users'
      'edit:edit assets such as accounts, users'
      'env:manage operator environments'
      'export:export assets'
      'generate:generate credentials'
      'import:import assets'
      'init:initialize an operator'
      'keys:manage keys'
      'list:list assets'
      'pull:pull an account JWT from account server'
      'push:push an account JWT to account server'
      'revocations:manage revocations'
      'select:set the current operator or account'
      'tool:NATS tools'
      'update:update this tool'
      'validate:validate assets'
    )
    _describe -t commands 'nsc command' commands && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments '1:type:(operator account user signing-key import export server cluster)' && ret=0
        ;;
      delete|describe|edit|list)
        _arguments '1:type:(operator account user export import)' && ret=0
        ;;
      generate)
        _arguments '1:type:(creds nkey config activation)' && ret=0
        ;;
      keys)
        _arguments '1:action:(list migrate)' && ret=0
        ;;
      env)
        _arguments \
          '-s[set operator]:operator' \
          '-a[set account]:account' && ret=0
        ;;
    esac
    ;;
esac

return ret
