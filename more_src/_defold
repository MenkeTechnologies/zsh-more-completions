#compdef defold
# Documentation: https://github.com/defold/defold/blob/dev/com.dynamo.cr/com.dynamo.cr.bob/src/com/dynamo/bob/Bob.java
# Documentation: https://defold.com/manuals/bob/
# Reference accessed: 2026-05-27
# Verified: upstream Bob.java getCommandLineOptions() and bob manual subcommand list (defold/defold)

local curcontext="$curcontext" state line ret=1

local -a _defold_subcommands
_defold_subcommands=(
  'build:build all project data (default command)'
  'bundle:create platform-specific application bundle'
  'clean:delete built files in the build directory'
  'distclean:delete all files in the build directory'
  'resolve:resolve all external library dependencies'
)

local -a _defold_platforms
_defold_platforms=(
  x86_64-win32
  x86_64-linux
  arm64-linux
  x86_64-macos
  arm64-macos
  arm64-ios
  x86_64-ios
  armv7-android
  arm64-android
  js-web
  wasm-web
  wasm_pthread-web
)

_arguments -C -s -S \
  '(-r --root)'{-r+,--root=}'[build root directory (default current directory)]:directory:_files -/' \
  '(-o --output)'{-o+,--output=}'[output directory (default build/default)]:directory:_files -/' \
  '(-i --input)'{-i+,--input=}'[DEPRECATED: use --root instead]:directory:_files -/' \
  '*--build-input=[project resource path to build instead of game.project]:path:' \
  '*--build-input-file=[file containing project resource paths to build]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-a --archive)'{-a,--archive}'[build archive]' \
  '(-ea --exclude-archive)'{-ea,--exclude-archive}'[exclude resource archives from application bundle]' \
  '(-e --email)'{-e+,--email=}'[user email]:email:' \
  '(-u --auth)'{-u+,--auth=}'[user auth token]:token:' \
  '(-p --platform)'{-p+,--platform=}'[target platform]:platform:($_defold_platforms)' \
  '(-bo --bundle-output)'{-bo+,--bundle-output=}'[bundle output directory]:directory:_files -/' \
  '(-bf --bundle-format)'{-bf+,--bundle-format=}'[application bundle formats]:format:' \
  '(-mp --mobileprovisioning)'{-mp+,--mobileprovisioning=}'[iOS mobileprovisioning profile]:file:_files' \
  '--identity=[iOS sign identity]:identity:' \
  '(-ce --certificate)'{-ce+,--certificate=}'[DEPRECATED: use --keystore instead]:file:_files' \
  '(-pk --private-key)'{-pk+,--private-key=}'[DEPRECATED: use --keystore instead]:file:_files' \
  '(-ks --keystore)'{-ks+,--keystore=}'[Android deployment keystore]:file:_files' \
  '(-ksp --keystore-pass)'{-ksp+,--keystore-pass=}'[Android keystore password]:password:' \
  '(-ksa --keystore-alias)'{-ksa+,--keystore-alias=}'[Android signing key alias]:alias:' \
  '(-kp --key-pass)'{-kp+,--key-pass=}'[Android deployment key password]:password:' \
  '(-d --debug)'{-d,--debug}'[DEPRECATED: use --variant=debug instead]' \
  '--variant=[engine variant]:variant:(debug release headless)' \
  '--strip-executable[strip dmengine of debug symbols]' \
  '--with-symbols[generate symbol file (if applicable)]' \
  '(-tp --texture-profiles)'{-tp+,--texture-profiles=}'[DEPRECATED: use --texture-compression]:value:' \
  '(-tc --texture-compression)'{-tc,--texture-compression}'[use texture compression as specified]' \
  '--exclude-build-folder=[DEPRECATED: use .defignore file instead]:folder:' \
  '(-br --build-report)'{-br+,--build-report=}'[DEPRECATED: use --build-report-json]:file:_files' \
  '(-brjson --build-report-json)'{-brjson+,--build-report-json=}'[JSON build report file path]:file:_files' \
  '(-brhtml --build-report-html)'{-brhtml+,--build-report-html=}'[HTML build report file path]:file:_files' \
  '--build-server=[native extension build server URL]:url:' \
  '*--build-server-header=[additional build server header]:header:' \
  '--use-async-build-server[DEPRECATED: async build is now default]' \
  '--defoldsdk=[Defold SDK version sha1 to use]:sha1:' \
  '--binary-output=[location for built engine binary]:directory:_files -/' \
  '--use-vanilla-lua[DEPRECATED: use --use-uncompressed-lua-source]' \
  '--use-uncompressed-lua-source[use uncompressed Lua source instead of bytecode]' \
  '--use-lua-bytecode-delta[use bytecode delta compression]' \
  '--archive-resource-padding=[resource alignment in game archive]:bytes:' \
  '(-l --liveupdate)'{-l+,--liveupdate=}'[publish liveupdate content (yes/no)]:flag:(yes no)' \
  '--with-sha1[generate or verify sha1 signatures (web bundling)]' \
  '(-ar --architectures)'{-ar+,--architectures=}'[comma-separated architectures for platform]:archs:' \
  '*--settings=[path to game project settings file]:file:_files' \
  '--version[print version number]' \
  '--build-artifacts=[build artifact types (engine,plugins,library)]:artifacts:' \
  '*--ne-build-dir=[native extension build dir]:directory:_files -/' \
  '--ne-output-name=[native extension library target name]:name:' \
  '--resource-cache-local=[path to local resource cache]:directory:_files -/' \
  '--resource-cache-remote=[URL to remote resource cache]:url:' \
  '--resource-cache-remote-user=[username for remote resource cache]:user:' \
  '--resource-cache-remote-pass=[password or token for remote resource cache]:password:' \
  '--max-cpu-threads=[max threads bob.jar can use]:count:' \
  '--experimental-path-minification[minimize resource path names]' \
  '--debug-ne-upload[output files sent to build server]' \
  '--debug-output-spirv=[force build SPIR-V shaders]:value:(true false)' \
  '--debug-output-wgsl=[force build WGSL shaders]:value:(true false)' \
  '--debug-output-hlsl=[force build HLSL shaders]:value:(true false)' \
  '--debug-output-msl=[force build Metal shaders]:value:(true false)' \
  '--debug-output-glsl=[force build GLSL shaders]:value:(true false)' \
  '*: :->cmd' && ret=0

case $state in
  cmd)
    _describe -t commands 'defold subcommand' _defold_subcommands && ret=0
    ;;
esac

return ret
