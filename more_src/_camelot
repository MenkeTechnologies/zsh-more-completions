#compdef camelot
# PDF table extraction tool

local ret=1

_arguments -s -S \
  '1:command:(lattice stream)' \
  '-p[specify pages]:pages:' \
  '-f[specify output format]:format:(csv json excel html markdown sqlite)' \
  '-o[specify output file]:output file:_files' \
  '-T[specify table areas]:areas:' \
  '-C[specify column separators]:columns:' \
  '-M[specify margins]:margins:' \
  '-split[split along separators]' \
  '-flag[flag superscripts]' \
  '-strip[strip characters]:characters:' \
  '-mt[specify margin tolerance]:tolerance:' \
  '-cp[specify copy text]:copy text:' \
  '--plot[plot table boundaries]' \
  '--password=[PDF password]:password:' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
