#compdef virtctl-cli virtctl2
# _virtctl-cli — KubeVirt Authors virtctl-cli CLI command-line client for the KubeVirt Kubernetes-native virtual-machine workload-management providing console vnc start stop migrate pause unpause restart expose image-upload guestfs soft-reboot fs-freeze memory-dump permitted-devices USB redirection plugin-system (KubeVirt team, Go); cobra
# upstream: https://kubevirt.io/

_virtctl-cli() {
    local -a sub=(
        'console:open VM console'
        'vnc:open VM VNC connection'
        'start:start a VM'
        'stop:stop a VM'
        'restart:restart a VM'
        'pause:pause a VM'
        'unpause:unpause a VM'
        'migrate:trigger live migration'
        'migrate-cancel:cancel migration'
        'expose:create service'
        'image-upload:upload disk image'
        'guestfs:open guestfs shell'
        'soft-reboot:soft reboot a VM'
        'fslist:list filesystems'
        'fsfreeze:freeze filesystem'
        'fsthaw:thaw filesystem'
        'permitted-devices:list permitted devices'
        'memory-dump:trigger memory dump'
        'usbredir:USB redirection'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'virtctl-cli subcommand' sub ;;
        args)
            _arguments '*:vm name:'
            ;;
    esac
}

_virtctl-cli "$@"
