#compdef spamprobe
# Documentation: https://manpages.debian.org/testing/spamprobe/spamprobe.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian testing spamprobe(1) manpage at the URL above.

# spamprobe: Bayesian spam classifier
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'help:list valid commands or detailed command descriptions'
  'create-db:initialize new database'
  'create-config:generate default configuration file'
  'receive:score message and update databases'
  'train:score and update only difficult messages'
  'score:score message without database modification'
  'summarize:print summary and score for each message'
  'find-spam:display spam messages with scores'
  'find-good:display non-spam messages with scores'
  'auto-train:efficiently build database from mixed files'
  'good:reclassify all messages as non-spam'
  'train-good:reclassify difficult/incorrect messages as non-spam'
  'spam:reclassify all messages as spam'
  'train-spam:reclassify difficult/incorrect messages as spam'
  'remove:delete term counts from database'
  'cleanup:remove old unused terms by age/frequency'
  'purge:immediately delete low-count terms'
  'purge-terms:delete terms matching regular expression'
  'edit-term:manually set term counts'
  'dump:display database contents (human-readable)'
  'tokenize:extract tokens from message'
  'export:output database in comma-separated format'
  'import:load exported database data'
)
_arguments -C \
  '-V[show version]' \
  '-a[non-ASCII char replacement (default z)]:char:' \
  '-c[create database directory if missing]' \
  '-C[minimum weighted count threshold for terms]:n:' \
  '-d[database location (optional bdb:/hash:/split: prefix)]:dir:_files -/' \
  '-D[shared baseline database directory]:dir:_files -/' \
  '-g[header field name (default X-SpamProbe)]:field:' \
  '-h[include words from HTML tags in word counts]' \
  '-H[header scanning mode]:mode:(all nox none normal)' \
  '-l[spam probability threshold (default 0.7)]:threshold:' \
  '-m[force mbox format for receive mode]' \
  '-M[treat entire input as single message]' \
  '-o[special option]:option:(graham honor-status-header orig-score suspicious-tags tokenized)' \
  '-p[max words per phrase (default 2)]:n:' \
  '-P[purge terms after N messages]:n:' \
  '-r[word repeat limit in top words array]:n:' \
  '-R[exit code based on message classification]' \
  '-s[in-memory term cache size (default 2500)]:n:' \
  '-T[output top terms associated with messages]' \
  '-v[verbose/debugging output]' \
  '-w[significant words for scoring]:n:' \
  '-x[extend term array for high-probability terms]' \
  '-X[safer scoring (equivalent to -w5 -r5 -x)]' \
  '-Y[assume traditional Berkeley mailbox format]' \
  '-7[ignore high-bit characters]' \
  '-8[store all characters including high-bit set]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'spamprobe command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac
return ret
