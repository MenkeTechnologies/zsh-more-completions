#compdef spamprobe
# Documentation: https://manpages.debian.org/buster/spamprobe/spamprobe.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian buster spamprobe(1) manpage OPTIONS + COMMANDS.
# Removed from prior file: bogus man.archlinux.org search URL.

# spamprobe: Bayesian spam classifier
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'help:show help'
  'create-db:create empty database'
  'create-config:create config file'
  'receive:classify and train on input'
  'train:train as either good or spam'
  'score:score messages without training'
  'summarize:summarize tokens in messages'
  'find-spam:identify spam from input'
  'find-good:identify good from input'
  'auto-train:re-train where score disagrees with prior'
  'good:train as good'
  'train-good:train as good without classifying first'
  'spam:train as spam'
  'train-spam:train as spam without classifying first'
  'remove:remove messages from database'
  'cleanup:remove obsolete tokens'
  'purge:purge old tokens'
  'purge-terms:purge tokens matching pattern'
  'edit-term:adjust counts for a token'
  'dump:dump database contents'
  'tokenize:show tokens for input'
  'export:export database as text'
  'import:import database from text'
)
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-a[token separator character]:char:' \
  '-c[create new database if absent]' \
  '-C[term cache size]:n:' \
  '-d[database directory (optional TYPE\: prefix)]:dir:_files -/' \
  '-D[alternate config/data directory]:dir:_files -/' \
  '-g[message field to extract]:field:' \
  '-H[advanced option]:key=value:' \
  '-l[log level]:n:' \
  '-m[multiple messages in one file]' \
  '-M[mbox format input]' \
  '-o[set option]:key=value:' \
  '-p[number of times to train (max iterations)]:n:' \
  '-P[parallel jobs]:n:' \
  '-r[show N most interesting terms]:n:' \
  '-R[show all terms]' \
  '-s[max tokens per message]:n:' \
  '-T[show timings]' \
  '-v[verbose output]' \
  '-w[word count threshold]:n:' \
  '-x[suppress training of headers]' \
  '-X[suppress training of body]' \
  '-Y[suppress all training]' \
  '-7[treat input as 7-bit ASCII]' \
  '-8[treat input as 8-bit]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'spamprobe command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac
return ret
