#compdef 3dBlurInMask
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dBlurInMask.html
# AFNI Gaussian blur a dataset only within a mask region

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-input[dataset to smooth and output]:dataset:_files' \
  '-FWHM[smoothness amount in millimeters]:f' \
  '-FWHMdset[read dataset for variable blur amounts]:dataset:_files' \
  '-mask[blur only within masked region]:dataset:_files' \
  '-Mmask[multi-mask dataset with separate masks]:dataset:_files' \
  '-automask[create automask from input dataset]' \
  '-preserve[retain original values outside mask]' \
  '-prefix[output dataset prefix]:prefix' \
  '-quiet[suppress verbose progress reporting]' \
  '-float[save output as floats]' \
  '-FWHMxyz[different smoothing per spatial direction]:fx' \
  '*:dataset:_files' && ret=0

return ret
