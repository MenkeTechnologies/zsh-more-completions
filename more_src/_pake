#compdef pake
# Documentation: https://github.com/tw93/Pake/blob/main/bin/helpers/cli-program.ts
# Turn any web page into a desktop app with Rust (pake-cli)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--name=[application name]:name' \
  '--identifier=[application identifier / bundle ID]:id' \
  '--icon=[application icon]:icon:_files' \
  '--width=[window width]:width' \
  '--height=[window height]:height' \
  '--use-local-file[use local file packaging]' \
  '--fullscreen[start in full screen]' \
  '--hide-title-bar[hide title bar (macOS)]' \
  '--multi-arch[build for both Intel and M1 (macOS)]' \
  '*--inject=[inject local CSS/JS files into the page]:file:_files' \
  '--debug[debug build with more output]' \
  '--proxy-url=[proxy URL for all network requests]:url' \
  '--user-agent=[custom user agent]:ua' \
  '--targets=[build target format for your system]:targets' \
  '--app-version=[app version]:version' \
  '--always-on-top[keep window always on top]' \
  '--maximize[start window maximized]' \
  '--dark-mode[force app to use dark mode]' \
  '--disabled-web-shortcuts[disable webpage shortcuts]' \
  '--activation-shortcut=[shortcut key to activate app]:shortcut' \
  '--show-system-tray[show system tray in app]' \
  '--system-tray-icon=[custom system tray icon]:icon:_files' \
  '--hide-on-close=[hide window on close instead of exiting]:bool:(true false)' \
  '--title=[window title]:title' \
  '--incognito[launch app in incognito/private mode]' \
  '--wasm[enable WebAssembly support]' \
  '--enable-drag-drop[enable drag and drop functionality]' \
  '--keep-binary[keep raw binary alongside installer]' \
  '--multi-instance[allow multiple app instances]' \
  '--multi-window[allow multiple windows within one instance]' \
  '--start-to-tray[start app minimized to tray]' \
  '--force-internal-navigation[keep every link inside the Pake window]' \
  '--internal-url-regex=[regex of URLs considered internal]:regex' \
  '--safe-domain=[comma-separated domains kept inside the app]:domains' \
  '--enable-find[enable in-page Find UI]' \
  '--installer-language=[installer language]:lang' \
  '--zoom=[initial page zoom level (50-200)]:zoom' \
  '--min-width=[minimum window width]:width' \
  '--min-height=[minimum window height]:height' \
  '--ignore-certificate-errors[ignore certificate errors]' \
  '--iterative-build[rapid build mode (app only)]' \
  '--new-window[allow sites to open new windows]' \
  '--install[auto-install app to /Applications after build (macOS)]' \
  '--camera[request camera permission (macOS)]' \
  '--microphone[request microphone permission (macOS)]' \
  '1:web URL to package:_urls' && ret=0

return ret
