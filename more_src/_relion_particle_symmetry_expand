#compdef relion_particle_symmetry_expand
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: expand a particle STAR file over a point group or helical symmetry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input particle STAR file]:file:_files' \
  '--o=[output expanded particle STAR file]:file:_files' \
  '--sym=[symmetry point group]:group' \
  '--twist=[helical twist (deg)]:value' \
  '--rise=[helical rise (A)]:value' \
  '--angpix=[pixel size (A)]:value' \
  '--asu=[number of asymmetrical units to expand]:value' \
  '--frac_sampling=[number of samplings within a single asymmetrical unit]:value' \
  '--frac_range=[range of the rise to be sampled]:value' \
  '*:file:_files' && ret=0

return ret
