#compdef cgmanager
# Documentation: https://man.archlinux.org/search?q=cgmanager
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --sigstop)'{-m,--sigstop}'[send SIGSTOP after starting]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '(-c --check)'{-c,--check}'+[control check]:opts:' \
  '(-M --mount)'{-M,--mount}'[mount cgroup hierarchy]' \
  '(-Y --nomount)'{-Y,--nomount}'[do not mount]' \
  '(-x --skiproot)'{-x,--skiproot}'[skip running as root]' \
  '(-t --transition)'{-t,--transition}'[transition]' && ret=0

return ret
