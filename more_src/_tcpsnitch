#compdef tcpsnitch
# Documentation: https://github.com/GregoryVds/tcpsnitch (bin/tcpsnitch bash getopts)
# Reference accessed: 2026-05-29
# tcpsnitch — trace sockets API usage via LD_PRELOAD. Records tcp_info + pcap per socket.
# Works on Linux and Android (API 23+). Required positional: <app> command.
# Two modes: Linux (run app directly) or Android (-a launch + -k kill+pull).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help text]' \
  '--version[print tcpsnitch version]' \
  '-a[instrument and launch app on connected Android device]' \
  '-k+[kill instrumented Android package and pull traces]:package:' \
  '-b+[dump tcp_info every N bytes (0 = no dump, default 0)]:bytes:' \
  '-c[activate pcap trace capture (Linux only)]' \
  '-d+[directory to save traces (default random /tmp dir)]:dir:_directories' \
  '-f+[file log verbosity (0-5, default 2)]:level:(0 1 2 3 4 5)' \
  '-l+[stderr log verbosity (0-5, default 2)]:level:(0 1 2 3 4 5)' \
  '-n[do not send traces to web server (tcpsnitch.org)]' \
  '-p[pedantic mode (ask confirmation questions)]' \
  '-t+[dump to JSON every N milliseconds (default 1000)]:msec:' \
  '-u+[dump tcp_info every N microseconds (0 = no dump, default 0)]:usec:' \
  '-v[activate verbose output]' \
  '*:app + args (Linux: command to run; Android: see -a/-k):_command_names' \
  && ret=0

return ret
