#compdef dunamai

local curcontext="$curcontext" state line ret=1
local -a commands vcs_choices style_choices

commands=(
  'from:generate version from a VCS'
  'check:check if a version is valid for a given style'
)

vcs_choices=(any git mercurial darcs subversion bazaar fossil pijul)
style_choices=(pep440 semver pvp)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'dunamai command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (from)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '1: :->vcs' \
          '*::vcsarg:->vcsargs' && ret=0
        case $state in
          (vcs)
            _values 'vcs' $vcs_choices && ret=0 ;;
          (vcsargs)
            _arguments \
              '(-h --help)'{-h,--help}'[show help]' \
              '--metadata[include metadata in version]' \
              '--no-metadata[exclude metadata from version]' \
              '--dirty[include dirty flag if working tree dirty]' \
              '--ignore-untracked[ignore untracked files when checking dirty (Git only)]' \
              '--tagged-metadata[include tagged metadata if any]' \
              '--pattern=[regex pattern matching version tags]:pattern:' \
              '--pattern-prefix=[prefix added to default pattern]:prefix:' \
              '--format=[custom output format string]:format:' \
              '--style=[output version style]:style:(pep440 semver pvp)' \
              '--latest-tag[use latest tag, not highest]' \
              '--highest-tag[use highest tag, not latest]' \
              '--strict[fail if no tag matches pattern]' \
              '--path=[path to repository]:path:_files -/' \
              '--debug[print debug info]' \
              '--bump[increment version toward next release]' \
              '--full-commit[use full commit hash (Git/Mercurial)]' \
              '--commit-length=[length of short commit hash]:n:' \
              '--commit-prefix=[prefix to commit hash]:prefix:' \
              '--escape-with=[character used for branch escape]:char:' \
              '--tag-branch=[remote branch for tags (Git only)]:branch:' \
              '--tag-dir=[directory under repo for tags (Subversion only)]:dir:' && ret=0 ;;
        esac ;;
      (check)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--style=[style to validate against]:style:(pep440 semver pvp)' \
          '*::version:' && ret=0 ;;
    esac ;;
esac

return ret
