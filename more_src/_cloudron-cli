#compdef cloudron-cli
# _cloudron-cli — Cloudron self-hostable PaaS CLI alias (cloudron team, JavaScript); commander
# upstream: https://docs.cloudron.io/cli

_cloudron-cli() {
    local -a sub=(
        'login:login to cloudron'
        'logout:logout'
        'profile:show profile'
        'list:list apps'
        'install:install app'
        'uninstall:uninstall app'
        'update:update app'
        'configure:configure app'
        'restore:restore app'
        'restart:restart app'
        'stop:stop app'
        'start:start app'
        'open:open app in browser'
        'logs:show app logs'
        'inspect:inspect app'
        'status:show app status'
        'exec:exec command in app'
        'push:push file to app'
        'pull:pull file from app'
        'machine:show machine info'
        'machine:create:create dns and ssh'
        'machine:eventlog:show event log'
        'machine:backup:list:list backups'
        'machine:backup:create:create backup'
        'machine:logs:show machine logs'
        'machine:migrate:migrate machine'
        'machine:reboot:reboot machine'
        'machine:reload:reload machine'
        'machine:retire:retire machine'
        'machine:ssh:ssh to machine'
        'machine:status:show machine status'
        'machine:update:update cloudron'
        'machine:upgrade:upgrade plan'
        'build:build cloudron app'
        'submit:submit app to store'
        'init:scaffold cloudron manifest'
        'createOAuthAppCredentials:create oauth app creds'
        'updateOAuthAppCredentials:update oauth app creds'
        'subscribe:subscribe webhook'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cloudron subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--app-store-id=+[app store id]:str:' \
                    '--image=+[image]:str:' \
                    '--location=+[subdomain]:str:' \
                    '-l+[subdomain]:str:' \
                    '--domain=+[domain]:str:' \
                    '-d+[domain]:str:' \
                    '--allow-inbound-from=+[ip]:str:' \
                    '--debug[debug]' ;;
                exec) _arguments \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--tty[allocate tty]' \
                    '-t[allocate tty]' \
                    '*:command:' ;;
                logs) _arguments \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--follow[follow logs]' \
                    '-f[follow logs]' \
                    '--lines=+[lines]:n:' ;;
            esac
            ;;
    esac
}

_cloudron-cli "$@"
