#compdef binocle
# Documentation: https://man.archlinux.org/search?q=binocle
# Reference accessed: 2026-05-16

# sharkdp/binocle — src/options.rs (clap): FILENAME plus --backing file|mmap.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--backing=[read backing]:mode:(file mmap)' \
  '1:input file:_files' && ret=0

return ret
