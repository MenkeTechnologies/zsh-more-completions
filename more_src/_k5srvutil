#compdef k5srvutil

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list keytab entries'
  'change:change service keys'
  'delold:delete old keys'
  'delete:delete a key'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-i[interactive mode]' \
  '-f+[keytab file]:file:_files' \
  '-k[keep old keys]' \
  '-e+[enctypes list]:enctypes:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'k5srvutil command' commands && ret=0 ;;
esac

return ret
