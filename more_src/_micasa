#compdef micasa
# Documentation: https://micasa.dev/docs/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for micasa - modal TUI for home maintenance, projects, vendors

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'demo:load sample data for exploration'
)

_arguments -C \
  '(- *)'{-h,--help}'[help]' \
  '1: :->cmd' && ret=0

case $state in
  (cmd) _describe -t commands 'micasa command' commands && ret=0 ;;
esac

return ret
