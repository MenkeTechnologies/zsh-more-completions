#compdef mdbook-build

# Zsh completion for mdbook build subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[output directory]:directory:_directories' \
  '--dest-dir=[output directory]:directory:_directories' \
  '-o[open browser after building]' \
  '--open[open browser after building]' \
  '1:directory:_directories' && ret=0

return ret
