#compdef mdbook-build
# Documentation: https://rust-lang.github.io/mdBook/cli/build.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mdbook build subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dest-dir)'{-d+,--dest-dir=}'[output directory]:directory:_directories' \
  '(-o --open)'{-o,--open}'[open the book in a web browser after building]' \
  '1:directory:_directories' && ret=0

return ret
