#compdef bicep

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a Bicep file'
  'decompile:decompile an ARM template to Bicep'
  'decompile-params:decompile a parameters file'
  'format:format a Bicep file'
  'generate-params:generate parameters file'
  'lint:lint a Bicep file'
  'publish:publish a Bicep file to a registry'
  'restore:restore external modules'
  'jsonrpc:run the JSON-RPC interface'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'bicep command' commands && ret=0
    ;;
  args)
    case $words[1] in
      build)
        _arguments \
          {-h,--help}'[show help]' \
          '--outdir=[output directory]:directory:_files -/' \
          '--outfile=[output file]:file:_files' \
          '--stdout[write output to stdout]' \
          '--no-restore[do not restore external modules]' \
          '--diagnostics-format=[diagnostic format]:format:(default sarif)' \
          '1:bicep file:_files -g "*.bicep"' && ret=0
        ;;
      decompile)
        _arguments \
          {-h,--help}'[show help]' \
          '--outdir=[output directory]:directory:_files -/' \
          '--outfile=[output file]:file:_files' \
          '--stdout[write output to stdout]' \
          '--force[overwrite existing output]' \
          '1:ARM template file:_files -g "*.json"' && ret=0
        ;;
      format)
        _arguments \
          {-h,--help}'[show help]' \
          '--outdir=[output directory]:directory:_files -/' \
          '--outfile=[output file]:file:_files' \
          '--stdout[write output to stdout]' \
          '--newline=[newline style]:style:(Auto LF CRLF)' \
          '--indent-kind=[indent type]:type:(Space Tab)' \
          '--indent-size=[indent size]:size' \
          '--insert-final-newline[insert final newline]' \
          '1:bicep file:_files -g "*.bicep"' && ret=0
        ;;
      lint)
        _arguments \
          {-h,--help}'[show help]' \
          '--diagnostics-format=[diagnostic format]:format:(default sarif)' \
          '1:bicep file:_files -g "*.bicep"' && ret=0
        ;;
      publish)
        _arguments \
          {-h,--help}'[show help]' \
          '--target=[target registry]:target' \
          '--documentation-uri=[documentation URI]:uri' \
          '--with-source[include source]' \
          '--force[force publish]' \
          '1:bicep file:_files -g "*.bicep"' && ret=0
        ;;
      restore)
        _arguments \
          {-h,--help}'[show help]' \
          '--force[force restore]' \
          '1:bicep file:_files -g "*.bicep"' && ret=0
        ;;
      generate-params)
        _arguments \
          {-h,--help}'[show help]' \
          '--outdir=[output directory]:directory:_files -/' \
          '--outfile=[output file]:file:_files' \
          '--stdout[write output to stdout]' \
          '--output-format=[output format]:format:(json bicepparam)' \
          '--include-params=[which params to include]:scope:(all required-only)' \
          '--no-restore[do not restore external modules]' \
          '1:bicep file:_files -g "*.bicep"' && ret=0
        ;;
      decompile-params)
        _arguments \
          {-h,--help}'[show help]' \
          '--outdir=[output directory]:directory:_files -/' \
          '--outfile=[output file]:file:_files' \
          '--stdout[write output to stdout]' \
          '--bicep-file=[Bicep file]:file:_files -g "*.bicep"' \
          '1:parameters file:_files -g "*.json"' && ret=0
        ;;
    esac
    ;;
esac

return ret
