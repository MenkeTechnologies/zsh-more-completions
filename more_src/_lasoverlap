#compdef lasoverlap
# LAStools: check flightline overlap and vertical/horizontal differences

local ret=1

_arguments -s -S \
  '-version[display tool version]' \
  '-gui[launch graphical interface]' \
  '-demo[run in evaluation mode]' \
  '-step+[grid cell size for raster analysis]:size' \
  '-min_diff+[map differences within range to white]:n' \
  '-max_diff+[map differences beyond range to saturated color]:n' \
  '-values[output numeric values instead of color]' \
  '-no_diff[suppress difference raster generation]' \
  '-no_over[suppress overlap raster generation]' \
  '-recover_flightlines[recover flight line info from GPS timestamps]' \
  '-recover_flightlines_interval+[minimum GPS time gap threshold]:seconds' \
  '-files_are_flightlines[treat each file as separate flight line]' \
  '-intensity[analyze intensity differences]' \
  '-counter[analyze point count differences]' \
  '-highest[use maximum values per cell]' \
  '-lowest[use minimum values per cell]' \
  '-average[compute per-cell averages first]' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge input files]' \
  '-otif[output as GeoTIFF]' \
  '-opng[output as PNG]' \
  '-oasc[output as ASCII raster]' \
  '-cores+[parallel processing on n cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
