#compdef tparse
# Documentation: https://man.archlinux.org/search?q=tparse
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-ver -version)'{-ver,-version}'[Show version]' \
  '(-follow)'-follow'[Follow nested packages]' \
  '(-smallscreen)'-smallscreen'[Compact output]' \
  '(-trim)'-trim'[Trim long names]' \
  '(-notests)'-notests'[Skip tests]' \
  '(-nocolor)'-nocolor'[Disable colors]' \
  '(-testname)'-testname+'[Filter tests by regex]:pattern:' \
  '*:packages:_files -/'
