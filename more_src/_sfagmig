#compdef sfagmig
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Magmig.c
# Madagascar: angle-gather constant-velocity time migration

local ret=1

_arguments -s -S \
  'vel=[velocity]:vel' \
  'ng=[number of reflection angles]:ng' \
  'dg=[reflection angle sampling]:dg' \
  'g0=[reflection angle origin]:g0' \
  'na=[number of dip angles]:na' \
  'amax=[maximum dip angle]:amax' \
  '*:RSF file:_files' && ret=0

return ret
