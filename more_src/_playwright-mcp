#compdef playwright-mcp mcp-server-playwright
# Documentation: https://github.com/microsoft/playwright-mcp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--browser=[browser to use]:browser:(chrome firefox webkit msedge)' \
  '--headless[run in headless mode]' \
  '--executable-path=[path to browser executable]:file:_files' \
  '--port=[listen port for SSE transport]:port:' \
  '--host=[bind address]:host:_hosts' \
  '--allowed-hosts=[comma-separated allowed hosts]:hosts:' \
  '--allowed-origins=[semicolon-separated trusted origins]:origins:' \
  '--blocked-origins=[semicolon-separated blocked origins]:origins:' \
  '--allow-unrestricted-file-access[allow file access outside workspace]' \
  '--isolated[keep profile in memory only]' \
  '--user-data-dir=[path to persistent profile directory]:dir:_directories' \
  '--storage-state=[path to storage state file]:file:_files' \
  '--viewport-size=[browser viewport (e.g. 1280x720)]:WxH:' \
  '--device=[device to emulate]:device:' \
  '--user-agent=[custom user agent string]:UA:' \
  '--config=[path to configuration file]:file:_files' \
  '--cdp-endpoint=[connect to existing Chrome DevTools endpoint]:url:' \
  '--timeout-action=[action timeout in ms]:ms:' \
  '--timeout-navigation=[navigation timeout in ms]:ms:' \
  '*::arguments:_default'
