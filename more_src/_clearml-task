#compdef clearml-task
# Documentation: https://github.com/clearml/clearml
# Reference accessed: 2026-05-23
# Verified: clearml-task --help (ClearML launch CLI).

# Zsh completion for clearml-task - ClearML remote task launcher

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show clearml-task version]' \
  '--project[project name]:project:' \
  '--name[task name]:name:' \
  '--tags[tags]:tags:' \
  '--repo[repository URL]:url:' \
  '--branch[git branch]:branch:' \
  '--commit[git commit]:commit:' \
  '--folder[local folder]:directory:_files -/' \
  '--script[entry script]:file:_files' \
  '--binary[binary entrypoint]:file:_files' \
  '--module[python module]:module:' \
  '--cwd[working directory]:directory:_files -/' \
  '--args[task arguments]:args:' \
  '--queue[execution queue]:queue:' \
  '--requirements[requirements file]:file:_files' \
  '--packages[packages to install]:packages:' \
  '--docker[docker image]:image:' \
  '--docker_args[docker arguments]:args:' \
  '--output-uri[output URI]:uri:' \
  '--task-type[task type]:type:' \
  '--skip-task-init[skip task initialization]' \
  '--base-task-id[base task ID]:id:' \
  '--pipeline[create pipeline task]' \
  '--pipeline-version[pipeline version]:version:' && ret=0

return ret
