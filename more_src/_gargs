#compdef gargs
# Documentation: https://github.com/brentp/gargs/blob/master/README.md
# gargs - better(?) xargs in go: run command templates in parallel with serialized output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help and exit]' \
  '(-p --procs)'{-p,--procs}'=[number of processes to use]:procs:' \
  '(-s --sep -n --nlines)'{-s,--sep}'=[regex to split line to fill multiple template place-holders]:regex:' \
  '(-n --nlines -s --sep)'{-n,--nlines}'=[lines to consume for each command]:nlines:' \
  '(-r --retry)'{-r,--retry}'=[times to retry a command if it fails]:retry:' \
  '(-o --ordered)'{-o,--ordered}'[keep output in order of input]' \
  '(-v --verbose)'{-v,--verbose}'[print commands to stderr as they are executed]' \
  '(-e --stop-on-error)'{-e,--stop-on-error}'[stop all processes on any error]' \
  '(-d --dry-run)'{-d,--dry-run}'[print but do not run the commands]' \
  '(-l --log)'{-l,--log}'=[file to log commands]:log file:_files' \
  '--version[display version and exit]' \
  '*:command template:_command_names' && ret=0

return ret
