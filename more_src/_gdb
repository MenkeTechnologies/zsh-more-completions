#compdef gdb gdbtui
# Documentation: man 1 gdb (man7.org)
# Reference accessed: 2026-05-29
# GNU Debugger.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display options]' \
  '(- *)--version[show version]' \
  '(-s --symbols)'{-s,--symbols=}'[load symbol table from file]:file:_files' \
  '--write[allow writing to executable and core files]' \
  '(-e --exec)'{-e,--exec=}'[executable file for examination]:file:_files' \
  '--se=[file as both symbol table and executable]:file:_files' \
  '(-c --core)'{-c,--core=}'[core dump file]:file:_files' \
  '(-x --command)'{-x,--command=}'[execute GDB commands from file]:file:_files' \
  '*'{-ex,--eval-command=}'[run a single GDB command]:command:' \
  '*-iex[execute command before loading the program]:command:' \
  '*--init-eval-command=[execute command before loading the program]:command:' \
  '*'{-d,--directory=}'[add directory to source file search path]:dir:_directories' \
  '--nh[skip initialization files in home directory]' \
  '(-n --nx)'{-n,--nx}'[ignore all .gdbinit files]' \
  '(-q --quiet --silent)'{-q,--quiet,--silent}'[suppress startup messages]' \
  '--batch[run non-interactively, exit after processing commands]' \
  '--batch-silent[batch mode with all output suppressed]' \
  '--args[pass following arguments to the debugged program]:*:program args:_command_names -e' \
  '--pid=[attach to running process by PID]:pid:_pids' \
  '-p[attach to running process by PID]:pid:_pids' \
  '--tui[open terminal user interface]' \
  '--readnow[load all symbols immediately]' \
  '--readnever[skip symbol file loading]' \
  '--cd=[set working directory for GDB]:dir:_directories' \
  '(-D --data-directory)'{-D,--data-directory=}'[GDB auxiliary files directory]:dir:_directories' \
  '(-f --fullname)'{-f,--fullname}'[output full file path and line number (Emacs mode)]' \
  '(-l --no-extended-prompt)'{-l,--no-extended-prompt}'[do not use extended prompt]' \
  '--return-child-result[exit with the child process exit status]' \
  '--statistics[print statistics about cmd execution]' \
  '--configuration[print details about GDB configuration]' \
  '--baud=[serial baud rate]:rate:' \
  '-b[serial baud rate]:rate:' \
  '*:program:_files -g "*(*)" "*.(out|exe)"' && ret=0

return ret
