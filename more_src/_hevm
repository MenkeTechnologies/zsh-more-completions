#compdef hevm

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'symbolic:symbolically execute a contract'
  'exec:execute a transaction'
  'test:run Solidity tests'
  'equivalence:check equivalence of two contracts'
  'version:show version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'hevm command' commands && ret=0
    ;;
  args)
    case $line[1] in
      symbolic)
        _arguments -s -S \
          '--code[contract bytecode]:bytecode:' \
          '--address[contract address]:address:' \
          '--caller[caller address]:address:' \
          '--value[call value]:value:' \
          '--rpc[RPC URL]:url:' \
          '--block[block number]:block:' \
          '--sig[function signature]:signature:' \
          '--arg[function arguments]:args:' \
          '--smttimeout[SMT timeout]:seconds:' \
          '--max-iterations[max loop iterations]:count:' \
          '--solver[SMT solver]:solver:(z3 cvc5 bitwuzla)' \
          '--help[show help]' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '--code[contract bytecode]:bytecode:' \
          '--address[contract address]:address:' \
          '--caller[caller address]:address:' \
          '--value[call value]:value:' \
          '--calldata[raw calldata]:calldata:' \
          '--gas[gas limit]:gas:' \
          '--rpc[RPC URL]:url:' \
          '--block[block number]:block:' \
          '--trace[enable trace output]' \
          '--help[show help]' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--root[project root]:directory:_directories' \
          '--match[test name pattern]:pattern:' \
          '--verbose[verbose output]:level:' \
          '--fuzz-runs[number of fuzz runs]:count:' \
          '--depth[max symbolic depth]:depth:' \
          '--rpc[RPC URL for forked tests]:url:' \
          '--smttimeout[SMT timeout]:seconds:' \
          '--solver[SMT solver]:solver:(z3 cvc5 bitwuzla)' \
          '--help[show help]' && ret=0
        ;;
      equivalence)
        _arguments -s -S \
          '--code-a[first contract bytecode]:bytecode:' \
          '--code-b[second contract bytecode]:bytecode:' \
          '--sig[function signature]:signature:' \
          '--smttimeout[SMT timeout]:seconds:' \
          '--solver[SMT solver]:solver:(z3 cvc5 bitwuzla)' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
