#compdef mcfly

# Zsh completion for mcfly - fly through your shell history

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:Print shell integration script'
  'search:Search and run a command from your history'
  'add:Add a command to the history database'
  'train:Train the McFly network on your history'
  'move-db:Move the McFly database to a new location'
  'help:Print help'
)

_arguments -s -S \
  '--debug[enable debug mode]' \
  '--light[use a light color scheme]' \
  '--key-scheme[set key scheme]:scheme:(emacs vim)' \
  '--fuzzy[use fuzzy searching]:N:' \
  '--results[number of results to show]:N:' \
  '--delete-without-confirm[delete entry without confirmation]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments ':shell:(bash zsh fish)' && ret=0
        ;;
      add)
        _arguments \
          '--exit[exit code of the command]:code:' \
          '--when[time the command was run]:time:' \
          '--train[train the neural network on this data]' \
          '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
