#compdef ape

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new Ape project'
  'compile:compile smart contracts'
  'test:run tests'
  'console:launch an interactive console'
  'run:run a script'
  'accounts:manage accounts'
  'networks:manage networks'
  'plugins:manage plugins'
  'pm:package manager'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbosity=[log verbosity]:level:(DEBUG INFO SUCCESS WARNING ERROR)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ape command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--github[use GitHub template]' \
          '1:project directory:_directories' && ret=0
        ;;
      (compile)
        _arguments \
          '--size[show compiled contract sizes]' \
          '--force[force recompile]' \
          '-f[force recompile]' \
          '--config-override=[override config values]:overrides' \
          '*:contract files:_files -g "*.{sol,vy}"' && ret=0
        ;;
      (test)
        _arguments \
          '-s[stop on first failure]' \
          '--showinternal[show internal frames in tracebacks]' \
          '-w[watch for file changes]' \
          '--watch[watch for file changes]' \
          '--network=[run tests on network]:network' \
          '--gas[show gas report]' \
          '--coverage[show coverage report]' \
          '-x[stop on first failure]' \
          '-k+[run tests matching expression]:expression' \
          '*:test files:_files -g "*.py"' && ret=0
        ;;
      (run)
        _arguments \
          '--network=[network to use]:network' \
          '-I[run in interactive mode after script]' \
          '--interactive[run in interactive mode after script]' \
          '1:script:_files -g "*.py"' && ret=0
        ;;
      (console)
        _arguments '--network=[network to connect to]:network' && ret=0
        ;;
      (accounts)
        local -a account_cmds=(
          'list:list available accounts'
          'import:import an account'
          'generate:generate a new account'
          'delete:delete an account'
          'export:export an account'
          'change-password:change account password'
        )
        _arguments '1:account command:_describe -t account-cmds "account command" account_cmds' && ret=0
        ;;
      (networks)
        local -a network_cmds=('list:list available networks' 'run:run a network')
        _arguments '1:network command:_describe -t network-cmds "network command" network_cmds' && ret=0
        ;;
      (plugins)
        local -a plugin_cmds=(
          'list:list installed plugins'
          'install:install a plugin'
          'uninstall:uninstall a plugin'
          'update:update a plugin'
        )
        _arguments '1:plugin command:_describe -t plugin-cmds "plugin command" plugin_cmds' && ret=0
        ;;
      (pm)
        local -a pm_cmds=(
          'list:list installed packages'
          'install:install a package'
          'uninstall:uninstall a package'
          'compile:compile a package'
        )
        _arguments '1:pm command:_describe -t pm-cmds "pm command" pm_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
