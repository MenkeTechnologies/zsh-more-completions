#compdef lottietoqml
# Documentation: https://doc.qt.io/qt-6/qtlottie-overview.html
# Reference accessed: 2026-05-19
# Verified: `lottietoqml --help` on Homebrew install (Qt 6 lottietoqml tool).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[displays help on commandline options]' \
  '(- *)--help-all[displays help including Qt options]' \
  '(-c --curve-renderer)'{-c,--curve-renderer}'[use the curve renderer in generated QML]' \
  '(-p --optimize-paths)'{-p,--optimize-paths}'[optimize paths for the curve renderer]' \
  '(-t --type-name)'{-t,--type-name}'+[use <typename> for Shape]:typename:' \
  '--copyright-statement=[comment at start of generated file]:string:' \
  '--asset-output-directory=[override asset output directory]:directory:_files -/' \
  '--asset-output-prefix=[override asset output prefix]:prefix:' \
  '--keep-external-paths[retain external file paths in QML output]' \
  '(-v --view)'{-v,--view}'[display the generated QML in a window]' \
  '1:input Lottie JSON:_files -g "*.json"' \
  '2::output QML:_files -g "*.qml"' && ret=0

return ret
