#compdef lottietoqml

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  {-c,--curve-renderer}'[use curve renderer in generated QML]' \
  {-p,--optimize-paths}'[optimize paths for curve renderer]' \
  '1:input Lottie JSON:_files -g "*.json"' \
  '2::output QML:_files -g "*.qml"' && ret=0

return ret
