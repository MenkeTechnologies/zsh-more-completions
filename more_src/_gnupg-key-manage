#compdef gnupg-key-manage

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'identify:identify the input'
  'delete-expired:delete expired keys (defaults to X.509)'
)

_arguments -C \
  '--pgp[select PGP keys]' \
  '--x509[select X.509 keys]' \
  '--all[work on the entire keyring]' \
  '--with-secret[work on secret keys too]' \
  {-n,--dry-run}'[print only what would be done]' \
  {-v,--verbose}'[verbose mode]' \
  '--debug[enable debug output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'gnupg-key-manage command' subcommands && ret=0
    ;;
esac

return ret
