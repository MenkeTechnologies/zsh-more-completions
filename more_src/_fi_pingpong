#compdef fi_pingpong
# Documentation: https://ofiwg.github.io/libfabric/main/man/fi_pingpong.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fi_pingpong: libfabric ping-pong test.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[domain name]:name:' \
  '-p[fabric provider]:provider:(sockets tcp verbs psm3 usnic shm udp efa)' \
  '-e[endpoint type]:type:(msg dgram rdm)' \
  '-I[iterations]:n:' \
  '-S[message size in bytes (or all)]:size:' \
  '-B[source port (server)]:port:' \
  '-P[destination port (client)]:port:' \
  '-c[enable receiver data integrity verification]' \
  '*:server host:_hosts' && ret=0
return ret
