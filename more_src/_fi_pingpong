#compdef fi_pingpong

# fi_pingpong: libfabric ping-pong test
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '-d[domain]:name:' \
  '-p[provider]:provider:' \
  '-e[endpoint type]:type:(MSG DGRAM RDM)' \
  '-I[iterations]:n:' \
  '-S[size]:bytes:' \
  '-B[port]:port:' \
  '-P[server hint]:host:_hosts' \
  '-c[server connect]:host:_hosts' \
  '*::fi_pingpong args:_files' && ret=0
return ret
