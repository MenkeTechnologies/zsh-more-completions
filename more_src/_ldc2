#compdef ldc2
# Documentation: https://manpages.opensuse.org/Tumbleweed/ldc/ldc2.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-c[compile only, do not link]' \
  '-of=[set output file]:output file:_files' \
  '-od=[set output directory]:directory:_directories' \
  '-op[preserve source paths for output files]' \
  '-o-[do not write object file]' \
  '-oq[fully qualified module names for output files]' \
  '-output-bc[write LLVM bitcode]' \
  '-output-ll[write LLVM IR]' \
  '-output-o[write object files (default)]' \
  '-output-s[write assembly]' \
  '-I=[add import directory]:directory:_directories' \
  '-J=[add string import directory]:directory:_directories' \
  '-L=[pass option to linker]:option' \
  '-nodefaultlib[do not link default standard library]' \
  '-d[allow deprecated features]' \
  '--dw[warn on deprecated features]' \
  '--de[error on deprecated features]' \
  '-w[treat warnings as errors]' \
  '--wi[warnings as messages]' \
  '-g[generate debug information]' \
  '--gc[debug info for non-D debuggers]' \
  '--gline-tables-only[line tables only]' \
  '-O[optimize]' \
  '-O0[disable optimization]' \
  '-O1[minimal optimization]' \
  '-O2[standard optimization]' \
  '-O3[maximum optimization]' \
  '-Os[optimize for size]' \
  '-Oz[further reduce code size]' \
  '--release[compile in release mode]' \
  '-unittest[compile and run unit tests]' \
  '-D[generate documentation]' \
  '-Dd=[doc output directory]:directory:_directories' \
  '-Df=[doc output file]:file:_files' \
  '-H[generate D interface file]' \
  '-Hd=[interface file directory]:directory:_directories' \
  '-Hf=[interface file]:file:_files' \
  '-X[generate JSON output]' \
  '-Xf=[JSON output file]:file:_files' \
  '-lib[generate library instead of object files]' \
  '-shared[generate shared library]' \
  '-singleobj[single combined object file]' \
  '-m32[generate 32-bit code]' \
  '-m64[generate 64-bit code]' \
  '--mtriple=[set target triple]:triple' \
  '--mcpu=[set target CPU]:cpu' \
  '--mattr=[set target attributes]:attributes' \
  '--march=[set architecture]:arch' \
  '--float-abi=[set float ABI]:abi:(default soft softfp hard)' \
  '-betterC[omit some runtime info and helper functions]' \
  '-conf=[use configuration file]:config file:_files' \
  '-v[verbose]' \
  '-vv[very verbose]' \
  '--vcolumns[print column numbers in diagnostics]' \
  '--verrors=[limit error messages]:count' \
  '-vtls[show thread-local storage variables]' \
  '-vgc[show GC allocations]' \
  '-vtemplates[show template instantiation statistics]' \
  '--profile=[enable profiling]:type:(gc)' \
  '-lowmem[reduce memory at cost of compile time]' \
  '--preview=[enable preview feature]:feature' \
  '--revert=[revert feature]:feature' \
  '--transition=[enable transition checking]:feature' \
  '--checkaction=[action on check failure]:action:(D C halt context)' \
  '-allinst[generate code for all template instantiations]' \
  '--run[compile and run immediately]' \
  '*:D source file:_files -g "*.d"' && ret=0

return ret
