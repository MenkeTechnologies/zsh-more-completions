#compdef adnshost adnsresfilter adnstest
# _adns — adns CLI family (Ian Jackson's lightweight async DNS resolver library; adnshost looks up names/types in parallel, adnsresfilter rewrites resolv.conf entries, adnstest exercises the library; -t type, -p print stats, -v verbose, --version; positional arguments are the qnames)
# upstream: https://www.chiark.greenend.org.uk/~ian/adns/
# Flags from adns client/adnshost.c on tip.

_adns() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t+[qtype]:type:(A AAAA NS MX TXT CNAME PTR SOA HINFO SRV RP)' \
        '-p[print stats]' \
        '-v[verbose]' \
        '-i+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '*:qname:_hosts'
}

_adns "$@"
