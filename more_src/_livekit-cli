#compdef lk livekit-cli
# Documentation: https://github.com/livekit/livekit-cli
# Reference accessed: 2026-05-27
# Verified: upstream cmd/lk/main.go global flags and per-subcommand files (room.go,
# app.go, agent.go, cloud.go, docs.go, project.go, token.go, egress.go, ingress.go,
# sip.go, phone_number.go, replay.go, perf.go, join.go, dispatch.go).
# Coverage note: top-level subcommands enumerated; per-subcommand inner commands
# captured for the heavily-used trees (room, token, egress, project, cloud, app);
# nested-leaf flag enumeration intentionally limited - lk exposes hundreds of
# flags across the subcommand tree and the upstream binary supports its own
# completion via "lk --completion".

local curcontext="$curcontext" state line ret=1

local -a _lk_subcommands
_lk_subcommands=(
  'app:initialize and manage applications'
  'agent:create and manage agents'
  'cloud:interact with LiveKit Cloud services'
  'docs:read or search LiveKit documentation'
  'project:add or remove projects and view project properties'
  'room:create or delete rooms and manage existing room properties'
  'token:create access tokens with granular capabilities'
  'join-room:join a room as a participant (alias of room join)'
  'dispatch:create or manage agent dispatches'
  'egress:record or stream media from LiveKit to elsewhere'
  'ingress:create and manage ingress (RTMP/WHIP/URL pull)'
  'sip:create and manage SIP trunks and dispatch rules'
  'number:search, purchase, and manage phone numbers'
  'replay:play back, seek, and manage replay recordings'
  'perf:performance testing and load simulations'
  'create-ingress:create an ingress (legacy)'
  'update-ingress:update an ingress (legacy)'
  'list-ingress:list ingresses (legacy)'
  'demo:launch demo flow'
  'simulcast:simulcast helpers'
  'help:show help'
)

_arguments -C \
  '--url=[URL to LiveKit instance]:url:' \
  '--api-key=[API key]:key:' \
  '--api-secret=[API secret]:secret:' \
  '--dev[use developer credentials for local LiveKit server]' \
  '--project=[name of a configured project]:name:' \
  '--subdomain=[subdomain of a configured project]:subdomain:' \
  '--config=[TOML config file in working directory]:file:_files -g "*.toml"' \
  '--curl[print curl commands for API actions]' \
  '--verbose[verbose logging]' \
  '(-y --yes)'{-y,--yes}'[assume yes for confirmations]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'lk subcommand' _lk_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      room)
        local -a _room_sub
        _room_sub=(
          'create:create a room'
          'list:list or search active rooms'
          'update:modify properties of an active room'
          'delete:delete a room'
          'join:join a room as a participant'
        )
        _arguments \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '1: :->room_cmd' \
          '*:: :->room_args' && ret=0
        case $state in
          room_cmd) _describe -t commands 'room subcommand' _room_sub && ret=0 ;;
          room_args)
            case $line[1] in
              create)
                _arguments \
                  '--room-egress-file=[RoomCompositeRequest JSON file]:file:_files -g "*.json"' \
                  '--participant-egress-file=[ParticipantEgress JSON file]:file:_files -g "*.json"' \
                  '--track-egress-file=[AutoTrackEgress JSON file]:file:_files -g "*.json"' \
                  '--agents-file=[agents configuration JSON file]:file:_files -g "*.json"' \
                  '--room-preset=[name of the room configuration preset]:preset:' \
                  '--min-playout-delay=[minimum playout delay (ms)]:ms:' \
                  '--max-playout-delay=[maximum playout delay (ms)]:ms:' \
                  '--sync-streams[place A/V in same stream for sync]' \
                  '--empty-timeout=[seconds to keep room open before any join]:seconds:' \
                  '--departure-timeout=[seconds to keep room open after last leaves]:seconds:' \
                  '*:room name:' && ret=0
                ;;
              join)
                _arguments \
                  '(-i --identity)'{-i+,--identity=}'[participant identity]:id:' \
                  '(-r --room)'{-r+,--room=}'[room name]:name:' \
                  '--publish-demo[publish demo video as a loop]' \
                  '*--publish=[file or stream to publish as a track]:source:_files' \
                  '--publish-data=[publish user data to the room]:data:' \
                  '--publish-dtmf=[publish DTMF digits]:digits:' \
                  '--fps=[FPS of video file]:fps:' \
                  '--h26x-streaming-format=[H.264/265 streaming format]:fmt:(annex-b length-prefixed)' \
                  '--attach-frame-metadata[parse H264/H265 SEI frame metadata]' \
                  '--exit-after-publish[exit after stream completes]' \
                  '*--attribute=[participant attribute key=value]:kv:' \
                  '--attribute-file=[read attributes from a JSON file]:file:_files -g "*.json"' \
                  '--auto-subscribe[automatically subscribe to published tracks]' \
                  '*:room name:' && ret=0
                ;;
              *) _arguments '*::arg:' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      token)
        _arguments \
          '--create[ability to create or delete rooms]' \
          '--list[ability to list rooms]' \
          '--join[ability to join a room]' \
          '--admin[ability to moderate a room]' \
          '--egress[ability to interact with Egress]' \
          '--ingress[ability to interact with Ingress]' \
          '--inference[ability to perform inference]' \
          '(-r --room)'{-r+,--room=}'[room name]:name:' \
          '(-i --identity)'{-i+,--identity=}'[participant identity]:id:' \
          '--token-only[output only the access token]' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '1: :(create)' && ret=0
        ;;
      egress)
        local -a _egress_sub
        _egress_sub=(
          'start:start an egress (room-composite, participant, track, track-composite, web)'
          'list:list active egresses'
          'update-layout:update web egress layout'
          'update-stream:update streaming endpoints'
          'stop:stop an egress'
          'test-template:test egress template locally'
        )
        _arguments \
          '1: :->egress_cmd' \
          '*:: :->egress_args' && ret=0
        case $state in
          egress_cmd) _describe -t commands 'egress subcommand' _egress_sub && ret=0 ;;
          egress_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      project)
        local -a _project_sub
        _project_sub=(
          'add:add a new project'
          'list:list all configured projects'
          'remove:remove an existing project from config'
          'set-default:set the default project'
        )
        _arguments \
          '1: :->project_cmd' \
          '*:: :->project_args' && ret=0
        case $state in
          project_cmd) _describe -t commands 'project subcommand' _project_sub && ret=0 ;;
          project_args)
            case $line[1] in
              add)
                _arguments \
                  '--url=[LiveKit server URL]:url:' \
                  '--api-key=[project API key]:key:' \
                  '--api-secret=[project API secret]:secret:' \
                  '--default[set as default project]' \
                  '*:project name:' && ret=0
                ;;
              *) _arguments '*:project name:' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      cloud)
        local -a _cloud_sub
        _cloud_sub=(
          'auth:authenticate LiveKit Cloud account'
        )
        _arguments \
          '1: :->cloud_cmd' \
          '*:: :->cloud_args' && ret=0
        case $state in
          cloud_cmd) _describe -t commands 'cloud subcommand' _cloud_sub && ret=0 ;;
          cloud_args)
            case $line[1] in
              auth)
                _arguments \
                  '(-R --revoke)'{-R,--revoke}'[revoke authentication]' \
                  '(-t --timeout)'{-t+,--timeout=}'[seconds before giving up]:seconds:' && ret=0
                ;;
              *) _arguments '*::arg:' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      app)
        local -a _app_sub
        _app_sub=(
          'create:bootstrap a new application from a template'
          'list-templates:list available templates'
          'env:fill environment variables from .env.example and project credentials'
        )
        _arguments \
          '1: :->app_cmd' \
          '*:: :->app_args' && ret=0
        case $state in
          app_cmd) _describe -t commands 'app subcommand' _app_sub && ret=0 ;;
          app_args)
            case $line[1] in
              env)
                _arguments \
                  '(-w --write)'{-w,--write}'[write env vars to file]' \
                  '(-o --overwrite)'{-o,--overwrite}'[replace destination file]' \
                  '(-d --destination)'{-d+,--destination=}'[destination file path]:file:_files' \
                  '(-e --example)'{-e+,--example=}'[example file path]:file:_files' && ret=0
                ;;
              *) _arguments '*::arg:' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      agent)
        local -a _agent_sub
        _agent_sub=(
          'create:create a new agent project'
          'deploy:deploy an agent'
          'status:show agent status'
          'logs:tail agent logs'
          'list:list deployed agents'
          'delete:delete an agent'
          'restart:restart an agent'
          'update:update an agent'
          'rollback:rollback an agent deployment'
          'versions:list agent versions'
          'secrets:manage agent secrets'
          'dockerfile:print the agent Dockerfile'
          'create-dockerfile:create a Dockerfile for the agent'
        )
        _arguments \
          '1: :->agent_cmd' \
          '*:: :->agent_args' && ret=0
        case $state in
          agent_cmd) _describe -t commands 'agent subcommand' _agent_sub && ret=0 ;;
          agent_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      ingress)
        local -a _ingress_sub
        _ingress_sub=(
          'create:create a new ingress'
          'update:update an existing ingress'
          'list:list active ingresses'
          'delete:delete an ingress'
        )
        _arguments \
          '1: :->ing_cmd' \
          '*:: :->ing_args' && ret=0
        case $state in
          ing_cmd) _describe -t commands 'ingress subcommand' _ingress_sub && ret=0 ;;
          ing_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      sip)
        local -a _sip_sub
        _sip_sub=(
          'inbound:inbound SIP trunk commands'
          'outbound:outbound SIP trunk commands'
          'dispatch:SIP dispatch rule commands'
          'participant:create a SIP participant'
        )
        _arguments \
          '1: :->sip_cmd' \
          '*:: :->sip_args' && ret=0
        case $state in
          sip_cmd) _describe -t commands 'sip subcommand' _sip_sub && ret=0 ;;
          sip_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      number)
        local -a _num_sub
        _num_sub=(
          'search:search for available phone numbers'
          'purchase:purchase phone numbers'
          'list:list owned phone numbers'
          'get:get a phone number by id'
          'update:update a phone number'
          'release:release a phone number'
        )
        _arguments \
          '1: :->num_cmd' \
          '*:: :->num_args' && ret=0
        case $state in
          num_cmd) _describe -t commands 'number subcommand' _num_sub && ret=0 ;;
          num_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      replay)
        local -a _replay_sub
        _replay_sub=(
          'list:list available replays'
          'playback:start replay playback'
          'seek:seek within a replay'
          'close:close a replay session'
          'export:export a replay'
          'delete:delete a replay'
        )
        _arguments \
          '1: :->rep_cmd' \
          '*:: :->rep_args' && ret=0
        case $state in
          rep_cmd) _describe -t commands 'replay subcommand' _replay_sub && ret=0 ;;
          rep_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      dispatch)
        local -a _disp_sub
        _disp_sub=(
          'list:list agent dispatches'
          'get:get an agent dispatch'
          'create:create an agent dispatch'
          'delete:delete an agent dispatch'
        )
        _arguments \
          '1: :->disp_cmd' \
          '*:: :->disp_args' && ret=0
        case $state in
          disp_cmd) _describe -t commands 'dispatch subcommand' _disp_sub && ret=0 ;;
          disp_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      docs)
        local -a _docs_sub
        _docs_sub=(
          'overview:show docs overview'
          'search:search the docs'
          'get-page:fetch a docs page'
          'code-search:search code examples'
        )
        _arguments \
          '1: :->docs_cmd' \
          '*:: :->docs_args' && ret=0
        case $state in
          docs_cmd) _describe -t commands 'docs subcommand' _docs_sub && ret=0 ;;
          docs_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      perf)
        local -a _perf_sub
        _perf_sub=(
          'load-test:run a load test'
          'run-all:run all performance tests'
        )
        _arguments \
          '1: :->perf_cmd' \
          '*:: :->perf_args' && ret=0
        case $state in
          perf_cmd) _describe -t commands 'perf subcommand' _perf_sub && ret=0 ;;
          perf_args) _arguments '*::arg:' && ret=0 ;;
        esac
        ;;
      *)
        _arguments '*::arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
