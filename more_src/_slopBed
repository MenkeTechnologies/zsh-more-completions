#compdef slopBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/slop.html
# increase the size of each feature by a defined amount (bedtools slop)

local ret=1

_arguments -s -S \
  '-i[input BED/GFF/VCF file]:file:_files' \
  '-g[genome file defining chromosome lengths]:file:_files' \
  '-b[increase entry by same bp in each direction]:bp' \
  '-l[bp to subtract from the start coordinate]:bp' \
  '-r[bp to add to the end coordinate]:bp' \
  '-s[apply directional logic based on strand]' \
  '-pct[define -l and -r as a fraction of feature length]' \
  '-header[print the header from the input file before results]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
