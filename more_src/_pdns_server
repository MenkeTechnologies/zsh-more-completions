#compdef pdns_server
# Documentation: https://doc.powerdns.com/authoritative/manpages/pdns_server.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '--daemon[run as daemon]' \
  '--guardian[run inside guardian]' \
  '--control-console[control socket monitor mode]' \
  '--loglevel=[logging verbosity]:level:' \
  '--config=[config display mode]:mode:(default diff check)' \
  '(- *)--config[show current config]' \
  '(- *)--help[show help]'
