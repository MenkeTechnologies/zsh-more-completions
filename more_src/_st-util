#compdef st-util

local -a arguments

arguments=(
  '--help[show help message]'
  '--version[show version information]'
  '(-p --listen_port)'{-p,--listen_port}'=[set GDB server listen port]:port:'
  '(-m --multi)'{-m,--multi}'[allow multiple GDB connections]'
  '--no-reset[do not reset the target on connection]'
  '--connect-under-reset[connect under reset]'
  '--hot-plug[connect without halting the target]'
  '--freq=[set SWD frequency in KHz]:freq:'
  '--serial=[select device by serial number]:serial:'
  '--semihosting[enable semihosting]'
  '-v[increase verbosity]'
  '(-1 --stlinkv1)'{-1,--stlinkv1}'[use ST-Link V1]'
)

_arguments -s -S $arguments
