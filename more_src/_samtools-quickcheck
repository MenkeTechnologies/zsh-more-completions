#compdef samtools-quickcheck
# Documentation: http://www.htslib.org/doc/samtools-quickcheck.html
# samtools quickcheck: Quickly check that input files appear intact

local ret=1

_arguments -s -S \
  '(-v)'-v'[Verbose output\: will additionally print the names of all input files t]' \
  '(-q)'-q'[Quiet mode\: disables warning messages on stderr about files that fail.]' \
  '(-u)'-u'[Expect unmapped input data, so do not require targets in the header.]' \
  '*:file:_files' && ret=0

return ret
