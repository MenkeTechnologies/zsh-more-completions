#compdef meme-chip
# Documentation: https://meme-suite.org/meme/doc/meme-chip.html
# MEME Suite: motif analysis pipeline for large sequence sets (ChIP-seq)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default memechip_out), fail if exists]:dir:_files -/' \
  '-oc[output directory (default memechip_out), overwrite if exists]:dir:_files -/' \
  '-neg[control sequences in FASTA format]:file:_files' \
  '-order[order of the Markov background model]:order:' \
  '-bfile[background model file]:file:_files' \
  '-psp-gen[create a position-specific prior]' \
  '*-db[database of known motifs]:file:_files' \
  '-filter-thresh[E-value threshold for filtering]:fthr:' \
  '-time[maximum runtime in minutes]:minutes:' \
  '-minw[minimum motif width]:width:' \
  '-maxw[maximum motif width]:width:' \
  '-ccut[trim sequences to this central region size]:size:' \
  '-group-thresh[motif clustering threshold]:gthr:' \
  '-group-weak[secondary clustering threshold]:wthr:' \
  '-old-clustering[use the alternate seed-selection clustering]' \
  '-noecho[suppress echoing of the command]' \
  '-seed[random number seed]:seed:' \
  '-meme-nmotifs[number of motifs MEME should find]:num:' \
  '-meme-searchsize[MEME search size]:searchsize:' \
  '-meme-norand[do not randomize MEME sequence order]' \
  '-meme-p[number of parallel processors for MEME]:np:' \
  '-meme-brief[MEME output reduction threshold]:nbrief:' \
  '-meme-mod[MEME site distribution model]:mod:(oops zoops anr)' \
  '-meme-minsites[minimum sites for MEME motifs]:sites:' \
  '-meme-maxsites[maximum sites for MEME motifs]:sites:' \
  '-meme-pal[force MEME to find palindromes only]' \
  '-streme-pvt[STREME stopping p-value threshold]:p-value:' \
  '-streme-nmotifs[number of motifs STREME should find]:count:' \
  '-streme-align[STREME sequence alignment]:align:(left center right)' \
  '-streme-totallength[STREME maximum total sequence length]:len:' \
  '-centrimo-ethresh[CentriMo enrichment E-value threshold]:E-value:' \
  '-centrimo-local[perform local CentriMo enrichment analysis]' \
  '-centrimo-score[CentriMo minimum match score]:score:' \
  '-centrimo-maxreg[CentriMo maximum region size]:region:' \
  '-centrimo-noseq[exclude sequence IDs from CentriMo output]' \
  '-centrimo-flip[reflect CentriMo reverse-strand positions]' \
  '-spamo-skip[skip the SpaMo analysis]' \
  '-fimo-skip[skip the FIMO analysis]' \
  '*:sequence file:_files' && ret=0

return ret
