#compdef virsh-cli2 virsh2
# _virsh-cli2 — libvirt virsh-cli2 CLI command-line frontend wrapping the virsh open-source command line interface for the libvirt virtualization management library which provides a unified interface to multiple hypervisors KVM Xen QEMU LXC VMware Hyper-V VirtualBox bhyve OpenVZ Power Hypervisor written in C originally Red Hat connect domain network storage pool volume secret nodedev nwfilter interface snapshot checkpoint vol-create vol-clone vol-resize start shutdown reboot reset suspend resume save restore migrate destroy define undefine list dumpxml console attach-disk attach-interface detach-disk vcpucount setvcpus setmem (libvirt Red Hat team Daniel P. Berrange Jiri Denemark Eric Blake, C); custom argparse
# upstream: https://libvirt.org/

_virsh-cli2() {
    local -a sub=(
        'list:list domains'
        'start:start a domain'
        'shutdown:shutdown a domain'
        'reboot:reboot a domain'
        'reset:reset a domain'
        'suspend:suspend a domain'
        'resume:resume a domain'
        'save:save domain state'
        'restore:restore from save'
        'destroy:forcefully stop a domain'
        'create:create from XML'
        'define:define a domain'
        'undefine:remove a domain definition'
        'edit:edit a domain XML'
        'dumpxml:dump domain XML'
        'console:open console'
        'autostart:set autostart'
        'attach-disk:attach a disk'
        'detach-disk:detach a disk'
        'attach-interface:attach NIC'
        'detach-interface:detach NIC'
        'attach-device:attach a device'
        'detach-device:detach a device'
        'setmem:set memory'
        'setmaxmem:set max memory'
        'setvcpus:set vCPUs'
        'vcpuinfo:show vCPU info'
        'vcpucount:show vCPU count'
        'vcpupin:pin vCPU'
        'domstats:show domain stats'
        'dominfo:show domain info'
        'domstate:show domain state'
        'domid:show domain ID'
        'domuuid:show domain UUID'
        'domname:show domain name'
        'screenshot:take screenshot'
        'send-key:send keystroke'
        'send-process-signal:send signal'
        'migrate:migrate a domain'
        'snapshot-create:create snapshot'
        'snapshot-create-as:create snapshot from args'
        'snapshot-list:list snapshots'
        'snapshot-revert:revert to snapshot'
        'snapshot-delete:delete snapshot'
        'snapshot-current:show current snapshot'
        'checkpoint-create:create checkpoint'
        'checkpoint-list:list checkpoints'
        'pool-list:list storage pools'
        'pool-define:define a storage pool'
        'pool-create:create a storage pool'
        'pool-destroy:destroy a storage pool'
        'pool-undefine:undefine a storage pool'
        'pool-start:start a storage pool'
        'pool-edit:edit a storage pool'
        'pool-dumpxml:dump pool XML'
        'pool-info:pool info'
        'pool-build:build storage pool'
        'pool-refresh:refresh pool'
        'vol-create:create a volume'
        'vol-create-as:create a volume from args'
        'vol-create-from:create vol from another'
        'vol-clone:clone a volume'
        'vol-resize:resize a volume'
        'vol-delete:delete a volume'
        'vol-info:volume info'
        'vol-list:list volumes'
        'vol-dumpxml:dump volume XML'
        'vol-pool:show pool of a volume'
        'net-list:list networks'
        'net-define:define a network'
        'net-create:create a network'
        'net-destroy:destroy a network'
        'net-undefine:undefine a network'
        'net-start:start a network'
        'net-edit:edit network XML'
        'net-dumpxml:dump network XML'
        'net-info:network info'
        'net-autostart:set network autostart'
        'iface-list:list host interfaces'
        'nodeinfo:show node info'
        'nodecpustats:show node CPU stats'
        'nodememstats:show node mem stats'
        'capabilities:show host capabilities'
        'connect:connect to hypervisor'
        'uri:show connection URI'
        'sysinfo:show system info'
        'cd:change directory in shell'
        'pwd:show shell pwd'
        'quit:exit virsh'
        'exit:exit virsh'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[connection URI]:str:' \
        '--connect=+[uri]:str:' \
        '-d+[debug level]:n:' \
        '--debug=+[N]:n:' \
        '-l+[log file]:file:_files' \
        '--log=+[file]:file:_files' \
        '-r[readonly]' \
        '--readonly[readonly]' \
        '-t[print timing info]' \
        '--timing[print timing]' \
        '-e+[escape char]:str:' \
        '--escape=+[c]:str:' \
        '-k+[keepalive interval]:n:' \
        '--keepalive-interval=+[sec]:n:' \
        '-K+[keepalive count]:n:' \
        '--keepalive-count=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'virsh subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_virsh-cli2 "$@"
