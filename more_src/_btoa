#compdef btoa
# Documentation: man btoa(1)
# Source: nss-dev/nss cmd/btoa/btoa.c (master) — NSS binary-to-ASCII base64 encoder (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input file]:file:_files' \
    '-o+[output file]:file:_files' \
    '-w+[wrap output as PEM (c=CERTIFICATE, type=custom)]:type:(c CERTIFICATE)' \
    && ret=0

return ret
