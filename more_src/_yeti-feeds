#compdef yeti-feeds yeti-cli
# _yeti-feeds — Yeti threat-intelligence platform yeti-feeds CLI managing feed configuration scheduling import/export of indicators IOC entities sources observables-tags processing across MISP/STIX/TAXII (yeti-platform team, Python); argparse
# upstream: https://github.com/yeti-platform/yeti

_yeti-feeds() {
    local -a sub=(
        'list:list configured feeds'
        'run:run a feed now'
        'enable:enable a feed'
        'disable:disable a feed'
        'create:create new feed'
        'edit:edit feed config'
        'delete:delete feed'
        'reset:reset feed cursor'
        'import:import observables from file'
        'export:export observables'
        'logs:show feed logs'
        'status:show feed status'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.toml *.ini"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.toml *.ini"' \
        '--db=+[uri]:str:' \
        '--auth=+[user:pass]:str:' \
        '--api-key=+[key]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yeti-feeds subcommand' sub ;;
        args)
            case $words[1] in
                run|enable|disable|delete|edit|reset|logs) _arguments '*:feed name:' ;;
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--type=+[t]:t:(stix taxii misp http csv json plaintext rss otx tlp ews)' \
                    '--source-url=+[url]:str:' \
                    '--schedule=+[cron]:str:' ;;
                import|export) _arguments \
                    '--format=+[f]:f:(csv json stix2 misp txt)' \
                    '--tag=+[tag csv]:str:' \
                    '*:file:_files' ;;
            esac
            ;;
    esac
}

_yeti-feeds "$@"
