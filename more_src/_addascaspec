#compdef addascaspec
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/addascaspec.html
# Add ASCA-style spectra with their backgrounds, ARFs and RMFs

local ret=1

_arguments -s -S \
  '(-h)-h[print help message]' \
  '(-q)-q[display commands to spawn without executing]' \
  '1:list_file:_files' \
  '2:out_spec:_files' \
  '3:out_response:_files' \
  '4:outbgd:_files' \
  '5:errmeth:(Poiss-0 Poiss-1 Poiss-2 Poiss-3 Gauss)' && ret=0

return ret
