#compdef sortreplicas
# Documentation: https://www.ks.uiuc.edu/Research/namd/current/ug/node67.html
# sortreplicas - reorder NAMD replica-exchange trajectories by replica index

local ret=1

_arguments -s \
  '1:job output root (path with %s or %d):_files' \
  '2:number of replicas:' \
  '3:runs per frame:' \
  '4:final step (optional, truncate after step):' && ret=0

return ret
