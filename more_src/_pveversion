#compdef pveversion
# _pveversion — Proxmox Server Solutions pveversion show Proxmox VE software versions of installed packages (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-manager.git

_pveversion() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose package list]' \
        '--verbose[verbose package list]'
}

_pveversion "$@"
