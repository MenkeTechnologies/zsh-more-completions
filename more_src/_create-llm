#compdef create-llm
# Documentation: https://www.npmjs.com/package/create-llm
# Reference accessed: 2026-05-24
# Verified: npm view create-llm bin; npm readme CLI Reference section.

# Zsh completion for create-llm - LLM training project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--template=[model template]:template:(nano tiny small base custom)' \
  '--tokenizer=[tokenizer type]:tokenizer:(bpe wordpiece unigram)' \
  '--skip-install[skip npm/pip installation]' \
  '(-y --yes)'{-y,--yes}'[skip prompts; use defaults]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':project name:' && ret=0

return ret
