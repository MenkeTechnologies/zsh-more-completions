#compdef ss-local ss-server ss-redir ss-tunnel ss-manager
# Documentation: https://man.archlinux.org/search?q=ss-local
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[verbose mode]' \
  '-s+[server host or IP]:host:_hosts' \
  '-p+[server port]:port:' \
  '-l+[local port]:port:' \
  '-k+[server password]:pw:' \
  '-m+[encryption method]:method:(rc4-md5 aes-128-gcm aes-192-gcm aes-256-gcm aes-128-cfb aes-192-cfb aes-256-cfb aes-128-ctr aes-192-ctr aes-256-ctr camellia-128-cfb camellia-192-cfb camellia-256-cfb bf-cfb chacha20-ietf-poly1305 xchacha20-ietf-poly1305 salsa20 chacha20 chacha20-ietf)' \
  '-f+[pid file]:file:_files' \
  '-t+[timeout seconds]:secs:' \
  '-c+[config JSON]:file:_files -g "*.json"' \
  '-a+[run as user]:user:_users' \
  '-b+[local bind address]:addr:' \
  '-n+[max open files]:n:' \
  '-d+[DNS server addresses csv]:dns:' \
  '-L+[tunnel destination]:host:port:' \
  '-u[enable UDP relay]' \
  '-U[enable UDP relay only]' \
  '-T[disable TCP relay]' \
  '-6[IPv6 first]' \
  '-A[OTA mode (deprecated)]' \
  '--mtu=[MTU]:n:' \
  '--no-delay[enable TCP_NODELAY]' \
  '--mptcp[multipath TCP]' \
  '--reuse-port[SO_REUSEPORT]' \
  '--fast-open[TCP fast open]' \
  '--tcp-incoming-sndbuf=[in sndbuf]:n:' \
  '--tcp-incoming-rcvbuf=[in rcvbuf]:n:' \
  '--tcp-outgoing-sndbuf=[out sndbuf]:n:' \
  '--tcp-outgoing-rcvbuf=[out rcvbuf]:n:' \
  '--manager-address=[manager address]:addr:' \
  '--manager-socket=[manager socket]:file:_files' \
  '--executable=[ss-server bin]:cmd:_command_names' \
  '--workdir=[working dir]:dir:_files -/' \
  '--acl=[ACL file]:file:_files' \
  '--key=[base64 key]:key:' \
  '--password=[password]:pw:' \
  '--plugin=[SIP003 plugin]:plugin:' \
  '--plugin-opts=[SIP003 plugin options]:opts:' && ret=0

return ret
