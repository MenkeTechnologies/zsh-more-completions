#compdef ss-local ss-server ss-redir ss-tunnel ss-manager
# Documentation: https://github.com/shadowsocks/shadowsocks-libev/tree/master/doc
# Reference accessed: 2026-05-21
# Verified: upstream asciidoc man pages for ss-local, ss-server, ss-redir,
# ss-tunnel, and ss-manager. This file is a union of all five binaries'
# flags; -L belongs only to ss-tunnel, -d/--executable/--workdir/--manager-address
# to ss-manager and ss-server, -T (tproxy) to ss-redir.
# Removed fabricated flags: -A OTA mode, --manager-socket.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose mode]' \
  '-s+[server host or IP]:host:_hosts' \
  '-p+[server port]:port' \
  '-l+[local port]:port' \
  '-k+[server password]:pw' \
  '-m+[encryption method]:method:(rc4-md5 aes-128-gcm aes-192-gcm aes-256-gcm aes-128-cfb aes-192-cfb aes-256-cfb aes-128-ctr aes-192-ctr aes-256-ctr camellia-128-cfb camellia-192-cfb camellia-256-cfb bf-cfb chacha20-ietf-poly1305 xchacha20-ietf-poly1305 salsa20 chacha20 chacha20-ietf)' \
  '-f+[run as daemon with pid file]:file:_files' \
  '-t+[timeout seconds]:secs' \
  '-c+[config JSON]:file:_files -g "*.json"' \
  '-a+[run as user]:user:_users' \
  '-b+[local bind address]:addr' \
  '-i+[network interface]:iface' \
  '-n+[max open files]:n' \
  '-L+[tunnel destination (ss-tunnel only)]:addr:port' \
  '-d+[DNS server addresses (ss-server, ss-manager only)]:dns' \
  '-D+[working directory (ss-manager only)]:dir:_files -/' \
  '-T[use tproxy (ss-redir only)]' \
  '-u[enable UDP relay]' \
  '-U[enable UDP relay only, disable TCP]' \
  '-6[IPv6 first]' \
  '--mtu=[MTU]:n' \
  '--no-delay[enable TCP_NODELAY]' \
  '--mptcp[multipath TCP]' \
  '--reuse-port[SO_REUSEPORT]' \
  '--fast-open[TCP fast open]' \
  '--tcp-incoming-sndbuf=[incoming sndbuf]:n' \
  '--tcp-incoming-rcvbuf=[incoming rcvbuf]:n' \
  '--tcp-outgoing-sndbuf=[outgoing sndbuf]:n' \
  '--tcp-outgoing-rcvbuf=[outgoing rcvbuf]:n' \
  '--manager-address=[manager UNIX domain socket address (ss-server, ss-manager)]:addr' \
  '--executable=[ss-server binary path (ss-manager only)]:cmd:_command_names' \
  '--acl=[ACL config file]:file:_files' \
  '--key=[base64 key]:key' \
  '--password=[password]:pw' \
  '--plugin=[SIP003 plugin]:plugin' \
  '--plugin-opts=[SIP003 plugin options]:opts' && ret=0

return ret
