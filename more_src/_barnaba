#compdef barnaba
# Documentation: https://github.com/srnas/barnaba/blob/master/README.rst
# Analyse nucleic-acid structures and trajectories (baRNAba)

local ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:(ERMSD RMSD ESCORE SS_MOTIF DS_MOTIF ANNOTATE DUMP TORSION JCOUPLING SEC_STRUCTURE SNIPPET ENM)' \
  '--ref[reference structure]:file:_files' \
  '--pdb[input PDB file(s)]:file:_files -g "*.pdb"' \
  '--top[topology file]:file:_files' \
  '--trj[trajectory file]:file:_files' \
  '--query[query motif structure]:file:_files' \
  '--l1[length of first strand]:n' \
  '--l2[length of second strand]:n' \
  '--seq[sequence to match]:seq' \
  '--ann[pairing/stacking annotation files]:file:_files' \
  '--shape[SHAPE reactivity file]:file:_files' \
  '--ff[force field for scoring]:ff' \
  '--dumpG[dump G vectors]' \
  '--dumpR[dump R vectors]' \
  '--backbone[compute backbone torsion angles]' \
  '--sugar[compute sugar torsion angles]' \
  '--pucker[compute pseudorotation/pucker angles]' \
  '(-o --output)'{-o,--output}'[output prefix]:prefix' \
  '*:file:_files' && ret=0

return ret
