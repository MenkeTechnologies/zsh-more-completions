#compdef httm
# Documentation: https://github.com/kimono-koans/httm
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httm - interactive, file-level Time Machine-like tool for ZFS/btrfs/nilfs2.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --browse)'{-b,--browse}'[interactive browse mode]' \
  '(-s --single)'{-s,--single}'[display only the last snapshot]' \
  '(-l --last-snap)'{-l,--last-snap}'[recover last unique version]' \
  '(-d --deleted)'{-d,--deleted}'[search for deleted files]' \
  '(-R --recursive)'{-R,--recursive}'[recurse into directories]' \
  '(-n --newline)'{-n,--newline}'[newline-delimited output]' \
  '--null[null-delimited output]' \
  '--json[JSON formatted output]' \
  '--omit-ditto[omit versions with same contents as live]' \
  '--no-filter[do not filter identical files]' \
  '--no-snap[do not show snapshot versions]' \
  '--no-live[do not show live version]' \
  '(-S --snapshot)'{-S,--snapshot}'[snapshot the dataset of mounted file]' \
  '(-r --restore)'{-r,--restore}'[restore a file interactively]' \
  '(-p --preview)'{-p,--preview}'[preview file contents interactively]' \
  '(-a --all-datasets)'{-a,--all-datasets}'[search all local pools]' \
  '--alt-store=[use alternative backup stores]:store:(restic timemachine)' \
  '--map-aliases=[map remote to local paths]:aliases:' \
  '--roll-forward[roll forward to previous snapshot]' \
  '--install-zsh-hot-keys[install zsh key bindings]' \
  '--debug[enable debug output]' \
  '*:file:_files' && return 0
