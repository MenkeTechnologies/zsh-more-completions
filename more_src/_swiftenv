#compdef swiftenv

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'install:install a Swift version'
      'uninstall:uninstall a Swift version'
      'versions:list installed Swift versions'
      'version:show current Swift version'
      'version-name:show current Swift version name'
      'global:set or show the global Swift version'
      'local:set or show the local Swift version'
      'rehash:rehash swiftenv shims'
      'which:show path to a Swift command'
      'completions:output shell completions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments \
          '--list[list available versions]' \
          '--snapshots[list available snapshots]' \
          '--skip-existing[skip if already installed]' \
          '--clean[clean build artifacts after install]' \
          '1:version:' && ret=0
        ;;
      (uninstall)
        _arguments '1:version:compadd $(swiftenv versions --bare 2>/dev/null)' && ret=0
        ;;
      (global|local)
        _arguments '1:version:compadd $(swiftenv versions --bare 2>/dev/null)' && ret=0
        ;;
      (which)
        _arguments '1:command:(swift swiftc swift-build swift-test swift-run swift-package)' && ret=0
        ;;
    esac
    ;;
esac

return ret
