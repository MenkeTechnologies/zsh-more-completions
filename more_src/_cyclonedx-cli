#compdef cyclonedx

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add file/license/note to BOM'
  'analyze:analyze BOM'
  'convert:convert BOM format/version'
  'diff:diff between two BOMs'
  'help:show help'
  'keygen:generate signing keys'
  'merge:merge multiple BOMs'
  'sign:sign BOM'
  'validate:validate BOM'
  'verify:verify BOM signature'
  'vex:VEX commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cyclonedx command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (convert)
        _arguments \
          '--input-file=[input file]:file:_files' \
          '--input-format=[input format]:f:(autodetect xml json protobuf)' \
          '--output-file=[output file]:file:_files' \
          '--output-format=[output format]:f:(autodetect xml json protobuf)' \
          '--output-version=[BOM version]:v:(v1_2 v1_3 v1_4 v1_5 v1_6)' \
          '*: :_files' && ret=0 ;;
      (validate)
        _arguments \
          '--input-file=[input file]:file:_files' \
          '--input-format=[input format]:f:(autodetect xml json protobuf)' \
          '--input-version=[input version]:v:' \
          '--fail-on-errors[fail on errors]' \
          '*: :_files' && ret=0 ;;
      (analyze)
        _arguments \
          '--input-file=[input file]:file:_files' \
          '--input-format=[input format]:f:' \
          '--multiple-component-versions[multi versions]' \
          '--output-format=[output format]:f:(text json)' \
          '*: :_files' && ret=0 ;;
      (diff)
        _arguments \
          '--from=[from BOM]:file:_files' \
          '--to=[to BOM]:file:_files' \
          '--from-format=[from format]:f:' \
          '--to-format=[to format]:f:' \
          '--output-format=[output format]:f:(text json)' \
          '--component-versions[component versions]' \
          '--component-hashes[component hashes]' \
          '*: :_files' && ret=0 ;;
      (merge)
        _arguments \
          '*--input-files=[input files csv]:list:_files' \
          '--input-format=[format]:f:' \
          '--output-file=[output file]:file:_files' \
          '--output-format=[format]:f:' \
          '--hierarchical[hierarchical merge]' \
          '*: :_files' && ret=0 ;;
      (sign|verify)
        _arguments \
          '--input-file=[file]:file:_files' \
          '--key-file=[key file]:file:_files' \
          '*: :_files' && ret=0 ;;
      (vex)
        _arguments \
          '1:subcommand:(extract apply)' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
