#compdef midicsv
# Documentation: https://www.fourmilab.ch/webtools/midicsv/
# translate a Standard MIDI File into a CSV file

local ret=1

_arguments -s -S \
  '-u[print how-to-call information]' \
  '-v[print verbose debugging information on standard error]' \
  '*:midi file:_files -g "*.(mid|midi)"' && ret=0

return ret
