#
# THE icon-gen CLI — commander + sharp + libvips
#
# icon-gen's CLI is in src/bin/cli.ts.  Uses tj/commander.js
# for argv parsing.
#
# Source:
#     import { Command } from 'commander';
#     const program = new Command();
#     program
#         .option('-i, --input <Path>', '...')
#         .option('-o, --output <Path>', '...')
#         .option('-r, --report', '...')
#         .option('--ico', '...')
#         .option('--ico-name <Name>', '...')
#         .option('--ico-sizes [Sizes]', '...', parseSizes)
#         .option('--icns', '...')
#         .option('--icns-name <Name>', '...')
#         .option('--icns-sizes [Sizes]', '...', parseSizes)
#         .option('--favicon', '...')
#         .option('--favicon-name <Name>', '...')
#         .option('--favicon-png-sizes [Sizes]', '...', parseSizes)
#         .option('--favicon-ico-sizes [Sizes]', '...', parseSizes)
#         .version(version, '-v, --version');
#
# Flags:
#   -i, --input PATH                   path of the SVG file
#                                       OR PNG file directory
#   -o, --output PATH                  path of the output
#                                       directory
#   -r, --report                       display process reports
#       --ico                          output Windows ICO file
#                                       (default sizes)
#       --ico-name NAME                ICO output basename
#       --ico-sizes SIZES              PNG sizes for ICO
#                                       (comma-separated)
#       --icns                         output macOS ICNS file
#                                       (default sizes)
#       --icns-name NAME               ICNS output basename
#       --icns-sizes SIZES             PNG sizes for ICNS
#                                       (comma-separated)
#       --favicon                      output Favicon PNG + ICO
#                                       set (default sizes)
#       --favicon-name NAME            Favicon name prefix
#       --favicon-png-sizes SIZES      PNG sizes for Favicon
#                                       (comma-separated)
#       --favicon-ico-sizes SIZES      PNG sizes for Favicon ICO
#                                       (comma-separated)
#   -v, --version                      show version
#   -h, --help                         show help
#                                       (commander default)
#
# sharp is used internally for:
#   1. Rasterizing the source SVG to PNGs at each target size
#      (via libvips's librsvg integration)
#   2. Converting input PNGs to the exact sizes required
#   3. Color profile + alpha channel handling
#   The PNG buffers are then packaged into .ico / .icns
#   container formats by separate logic.
#
# Five-axis distinctness from image-rs/image (R677) +
# disintegration/imaging (R678):
#
#   1. LIBVIPS C BINDINGS — distinct implementation
#      philosophy from pure Rust / pure Go.
#
#   2. PROMISE-BASED ASYNC PIPELINE — vs sync.
#
#   3. STREAMING via Stream API — Node.js-idiomatic.
#
#   4. 50+ OPERATIONS — broader than image-rs (15) or
#      imaging (30).
#
#   5. LOVELL-FULLER / sharp ECOSYSTEM PROVENANCE — corporate-
#      sponsored full-time maintainer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/akabekobeko/npm-icon-gen/blob/master/src/bin/cli.ts
# commander Command.option / version definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[path of the SVG file or PNG directory]:path:_files' \
    '(-o --output)'{-o+,--output=}'[output directory]:directory:_files -/' \
    '(-r --report)'{-r,--report}'[display process reports]' \
    '--ico[output Windows ICO file (default sizes)]' \
    '--ico-name=[ICO output file basename]:name:_default' \
    '--ico-sizes=[PNG sizes for ICO (comma-separated)]:sizes:_default' \
    '--icns[output macOS ICNS file (default sizes)]' \
    '--icns-name=[ICNS output file basename]:name:_default' \
    '--icns-sizes=[PNG sizes for ICNS (comma-separated)]:sizes:_default' \
    '--favicon[output Favicon PNG + ICO set (default sizes)]' \
    '--favicon-name=[Favicon file prefix]:name:_default' \
    '--favicon-png-sizes=[PNG sizes for Favicon (comma-separated)]:sizes:_default' \
    '--favicon-ico-sizes=[PNG sizes for Favicon ICO (comma-separated)]:sizes:_default' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
