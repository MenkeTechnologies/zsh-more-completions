#compdef map2img
# Documentation: https://mapserver.org/utilities/map2img.html
# Create a map image from a MapServer mapfile (renamed from shp2img in MapServer 8.0)

local ret=1

_arguments -s \
  '-m[map file to operate on (required)]:mapfile:_files' \
  '-i[override the IMAGETYPE value to pick output format]:format:' \
  '-o[output filename (stdout if not provided)]:image:_files' \
  '-e[extents to render]:minx miny maxx maxy:' \
  '-s[output image size]:sizex sizey:' \
  '-l[layers / groups to enable (quoted, space separated)]:layers:' \
  '-all_debug[set debug level for map and all layers]:level:' \
  '-map_debug[set map debug level]:level:' \
  '-layer_debug[set layer debug level]:layer_name level:' \
  '-c[draw map n number of times]:n:' \
  '-p[pause for n seconds after reading the map]:n:' \
  '-d[change DATA value for layer]:layername datavalue:' \
  '-conf[filename of the MapServer configuration file]:filename:_files' && ret=0

return ret
