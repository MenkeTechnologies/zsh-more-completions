#compdef gz-log
# Documentation: https://gazebosim.org/docs
# Gazebo Transport log record/playback tool

local ret=1
local line state

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '(-v --verbose)'{-v,--verbose}'[set verbosity level]' \
  '1:command:(record playback)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      record)
        _arguments -s -S \
          '--file=[name of the log file]:file:_files' \
          '--force[overwrite a file if it exists]' \
          '--pattern=[regex of topics to match]:pattern' && ret=0
        ;;
      playback)
        _arguments -s -S \
          '--file=[name of the log file]:file:_files' \
          '--pattern=[regex of topics to match]:pattern' \
          '--remap=[rename a topic while playing back FROM:=TO]:remap' \
          '--wait=[ms to wait between advertisement and publishing]:ms' \
          '-f[fast playback without waiting between messages]' && ret=0
        ;;
    esac
    ;;
esac

return ret
