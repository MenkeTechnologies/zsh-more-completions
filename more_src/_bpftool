#compdef bpftool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-j[generate JSON output]' \
  '--json[generate JSON output]' \
  '-p[generate pretty JSON output]' \
  '--pretty[generate pretty JSON output]' \
  '-d[enable debug output]' \
  '--debug[enable debug output]' \
  '-m[open object file as map]' \
  '--mapcompat[open object file as map]' \
  '-n[dry run]' \
  '--nomount[do not mount BPF filesystem]' \
  '-f[show file names of pinned objects]:path:_files' \
  '1:object:->objects' \
  '*::: :->args' && ret=0

case "$state" in
  objects)
    local -a objects=(
      'prog:manage BPF programs'
      'map:manage BPF maps'
      'link:manage BPF links'
      'cgroup:manage cgroup BPF programs'
      'perf:manage perf-related BPF programs'
      'net:manage networking BPF programs'
      'feature:inspect BPF features'
      'btf:manage BTF data'
      'gen:BPF code generation'
      'struct_ops:manage struct_ops'
      'iter:manage iterators'
    )
    _describe 'object' objects && ret=0
    ;;
  args)
    case "${line[1]}" in
      prog|map|link|cgroup|perf|net|feature|btf|gen|struct_ops|iter)
        local -a subcmds=(show list dump pin load attach detach help)
        _describe 'command' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
