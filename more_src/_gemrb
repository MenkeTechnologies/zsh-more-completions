#compdef gemrb
# Documentation: https://gemrb.org/Manual.html
# Reference accessed: 2026-05-16

# GemRB: open-source engine for Infinity Engine games (BG/IWD/PST)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-c[config file]:file:_files -g "*.cfg"' \
  '-q[disable audio]' \
  '*:GemRB config / game dir:_files -/' && ret=0
return ret
