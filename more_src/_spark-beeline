#compdef spark-beeline

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u+[JDBC URL to connect to]:url:' \
  '-r[reconnect to last saved connect url]' \
  '-n+[username to connect as]:user:_users' \
  '-p+[password to connect as]:password:' \
  '-d+[driver class to use]:class:' \
  '-i+[script file for initialization]:file:_files' \
  '-e+[query to execute]:query:' \
  '-f+[script file to execute]:file:_files' \
  {-w+,--password-file=}'[password file to read password from]:file:_files' \
  '*--hiveconf=[use value for given property]:property=value:' \
  '*--hivevar=[hive variable name and value]:name=value:' \
  '--property-file=[file with connection properties]:file:_files' \
  '--color=[control whether color is used for display]:flag:(true false)' \
  '--showHeader=[show column names in query results]:flag:(true false)' \
  '--headerInterval=[interval between header rows]:rows:' \
  '--fastConnect=[skip building table/column list for tab-completion]:flag:(true false)' \
  '--autoCommit=[enable/disable automatic transaction commit]:flag:(true false)' \
  '--verbose=[show verbose error messages and debug info]:flag:(true false)' \
  '--showWarnings=[display connection warnings]:flag:(true false)' \
  '--showDbInPrompt=[display the current database name in the prompt]:flag:(true false)' \
  '--showNestedErrs=[display nested errors]:flag:(true false)' \
  '--numberFormat=[format numbers using DecimalFormat pattern]:pattern:' \
  '--force=[continue running script even after errors]:flag:(true false)' \
  '--maxWidth=[maximum width of the terminal]:width:' \
  '--maxColumnWidth=[maximum width when displaying columns]:width:' \
  '--silent=[be more silent]:flag:(true false)' \
  '--autosave=[automatically save preferences]:flag:(true false)' \
  '--outputformat=[format mode for result display]:format:(table vertical csv2 tsv2 dsv csv tsv)' \
  '--incremental=[fetch incrementally for lower latency]:flag:(true false)' \
  '--incrementalBufferRows=[buffer size when --incremental=true]:rows:' \
  '--truncateTable=[truncate table column when it exceeds length]:flag:(true false)' \
  '--delimiterForDSV=[delimiter for DSV output]:delim:' \
  '--isolation=[transaction isolation level]:level:' \
  '--nullemptystring=[print null as empty string]:flag:(true false)' \
  '--maxHistoryRows=[maximum rows in beeline history]:n:' && ret=0

return ret
