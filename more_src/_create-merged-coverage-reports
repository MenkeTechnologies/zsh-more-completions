#compdef create-merged-coverage-reports
# Documentation: https://github.com/alexgavrusev/create-merged-coverage-reports#readme
# Reference accessed: 2026-05-24
# Verified: npm view create-merged-coverage-reports bin; GitHub README at the URL above.

# Zsh completion for create-merged-coverage-reports - merge Istanbul JSON coverage reports

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-v --version)'{-v,--version}'[output the version number]' \
  '(-c --coverageFileGlob)'{-c,--coverageFileGlob=}'[glob for json coverage files]:glob:' \
  '(-o --outputDirectory)'{-o,--outputDirectory=}'[output directory for merged reports]:directory:_directories' \
  '(-r --reporters)'{-r,--reporters=}'[reporters for merged coverage]:reporter:' \
  '(-h --help)'{-h,--help}'[display help for command]' && ret=0

return ret
