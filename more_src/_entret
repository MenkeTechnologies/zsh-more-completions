#compdef entret
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/entret.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS entret: retrieve sequence entries in full text format.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompts]' \
  '-debug[debug]' \
  '-verbose[verbose]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal]' \
  '-die[dying]' \
  '-version[version]' \
  '-sequence=[input sequence(s) USA]:USA:_files' \
  '-firstonly[read one sequence and stop]' \
  '-outfile=[output file]:file:_files' \
  '-sformat1=[input sequence format]:fmt:' \
  '-sbegin1=[start of sequence]:n:' \
  '-send1=[end of sequence]:n:' \
  '-sreverse1[reverse if DNA]' \
  '-sask1[ask for begin/end/reverse]' \
  '-snucleotide1[sequence is nucleotide]' \
  '-sprotein1[sequence is protein]' \
  '-slower1[lower case]' \
  '-supper1[upper case]' \
  '-scircular1[circular sequence]' \
  '-squick1[id and sequence only]' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '*:USA:_files' && ret=0
return ret
