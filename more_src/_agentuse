#compdef agentuse
# ============================================================================
# agentuse - AI agents on autopilot: define in markdown, run on cron / CI / CD
#            / Docker / serverless (Node/Bun, Apache-2.0)
#
# Author : agentuse contributors
# Upstream: https://github.com/agentuse/agentuse
# npm    : agentuse
#
# agentuse loads agent definitions from markdown files and runs
# them against any AI model (Anthropic, OpenAI, Bedrock, OpenAI-
# compatible) through the Vercel AI SDK + MCP. Each agent run is
# a session: agentuse assigns it a ULID, persists tool calls +
# messages to a local session store, and can resume from suspended
# state (approval-gated, manual interruption, or scheduled re-
# entry). Designed to run unattended: built-in cron scheduler
# (croner), CI/CD wrappers, Slack/socket-mode channels, and an
# HTTP serve mode for remote triggering.
#
# Subcommand tree (commander.js):
#   run <file> [prompt...]   - Execute an agent markdown file
#   provider                 - Manage AI provider auth + custom endpoints
#                              (subcommands: help, add, login, logout, list,
#                                            setup-github)
#   auth                     - Hidden alias for `provider`
#   sessions                 - Manage AgentUse sessions
#                              (list, show <id>, resume <id>, path)
#   serve                    - Start the HTTP server for remote runs
#                              (serve | serve ps | serve log)
#   models                   - List recommended AI models
#   skills                   - List available skills
#   agents                   - List available agents in the project
#   add                      - Install skills/agents from repo/path
#   benchmark                - Hidden internal benchmark harness
#
# The ULID lane is built on `ulid ^3.0.1` (declared verbatim at
# upstream package.json HEAD), the canonical Node ULID library by
# Alizain Feerasta + contributors (github.com/ulid/javascript,
# 3400+ stars). The reference JavaScript implementation of the
# ULID spec: 48-bit Unix-ms timestamp + 80-bit randomness encoded
# as 26 Crockford-Base32 characters, with both a stateless
# `ulid()` function and a monotonic factory
# `monotonicFactory(rand?)` to prevent timestamp-collision sort-
# inversions when minting multiple IDs in the same millisecond.
# agentuse uses ULID as the session identifier - every "run" of
# an agent gets a ULID that doubles as both unique key + sort key
# in the on-disk session store (newest sessions always sort last).
#
# ----------------------------------------------------------------------------
# AXIS 219 :: ULID (Universally Unique Lexicographically Sortable Identifier)
# Round 1357 :: TS-Node slot 3 of 4 :: CLOSES Axis 219 (212th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : dylanhart/ulid-rs                  [R1355 _idt]
#   Go      : oklog/ulid                         [R1356 _lmstfy]
#   TS/Node : ulid/javascript                    [R1357 THIS FILE]
#
# ulid/javascript is the *spec-reference* implementation of ULID
# in the JS ecosystem - same pattern observed across many axes
# this hunt: the reference impl ships in JavaScript first (often
# by the spec author themselves), then Rust + Go reimplement to
# spec. Compare: graphql-js (GraphQL Foundation), vscode-language-
# server-node (Microsoft, LSP spec), @modelcontextprotocol/sdk
# (Anthropic, MCP spec), matrix-js-sdk (matrix.org, Matrix spec).
# Spec authors gravitate to JS for spec implementations because
# the type system is permissive enough to round-trip any wire
# format without ceremony, and the npm distribution model means
# every downstream language can pull the spec impl as a runtime
# reference for compliance testing.
#
# All three lanes of this axis target the same byte-for-byte wire
# format (Feerasta, 2016): ULIDs generated by any one library
# parse identically with the other two. lmstfy (Go server) can
# mint a job ULID that idt (Rust CLI) inspects and agentuse
# (Node agent runner) resumes a session against - the ID format
# is the contract, the libraries are interchangeable.
#
# Axis 219 caps off with the "creative ULID use" pattern: idt
# (Rust) uses ULID as one format among many in an ID-tool Swiss-
# army-knife; lmstfy (Go) uses ULID as a Redis sorted-set sort
# key for queue ordering; agentuse (Node) uses ULID as a session
# identifier whose lexicographic order doubles as wall-clock
# order. Same spec, three different operational consumers.
# ============================================================================

_agentuse() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_agentuse_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                run)        _agentuse_run ;;
                provider)   _agentuse_provider ;;
                auth)       _agentuse_provider ;;
                sessions)   _agentuse_sessions ;;
                serve)      _agentuse_serve ;;
                models)     _arguments '(-v --verbose)'{-v,--verbose}'[show detailed model information]' '(- *)'{-h,--help}'[help]' ;;
                skills)     _arguments '(-v --verbose)'{-v,--verbose}'[show skill file paths]' '(- *)'{-h,--help}'[help]' ;;
                agents)     _arguments '(-v --verbose)'{-v,--verbose}'[show model information]' '(-j --json)'{-j,--json}'[output as JSON]' '(- *)'{-h,--help}'[help]' ;;
                add)        _agentuse_add ;;
                benchmark)  _arguments '(- *)'{-h,--help}'[help]' '*: :' ;;
            esac
            ;;
    esac

    return ret
}

_agentuse_cmds() {
    local -a cmds
    cmds=(
        'run:Run an AI agent from a markdown file or URL, optionally appending a prompt'
        'provider:Manage providers and authentication credentials'
        'auth:Hidden alias for `provider`'
        'sessions:Manage AgentUse sessions'
        'serve:Start an HTTP server to run agents via API'
        'models:List recommended AI models'
        'skills:List available skills'
        'agents:List available agents in the project'
        'add:Add skills and agents from a GitHub repo, git URL, or local path'
        'benchmark:Internal benchmark harness (hidden)'
    )
    _describe -t commands 'agentuse command' cmds
}

_agentuse_run() {
    _arguments \
        '(-q --quiet)'{-q,--quiet}'[suppress info messages]' \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '--no-tty[disable TUI output for non-interactive use]' \
        '--compact[use compact single-line header instead of ASCII logo]' \
        '--timeout[maximum execution time in seconds (default 300)]:seconds:' \
        '(-C --directory)'{-C,--directory}'[run as if started in <path>]:path:_files -/' \
        '--env-file[path to custom .env file]:file:_files' \
        '(-m --model)'{-m,--model}'[override the model specified in the agent file]:model:' \
        '--session-id[resume from an existing session id]:id:' \
        '--json[output result as JSON (implies --quiet --no-tty)]' \
        '(- *)'{-h,--help}'[help]' \
        '1:agent file:_files -g "*.md"' \
        '*:prompt:'
}

_agentuse_provider() {
    local -a sub
    sub=(
        'help:Show authentication help and configuration options'
        'add:Add a custom provider endpoint (OpenAI-compatible)'
        'login:Login to a provider'
        'logout:Logout from a provider or remove a custom provider'
        'list:List stored credentials'
        'setup-github:Set up long-lived OAuth token for GitHub Actions (1 year)'
    )
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:->sub' \
        '*::arg:->args'

    case $state in
        sub) _describe -t commands 'provider subcommand' sub ;;
        args)
            case $words[1] in
                add)    _arguments '--key[optional API key for the endpoint]:key:' '(- *)'{-h,--help}'[help]' '1:name:' ;;
                logout) _arguments '--oauth[remove only OAuth credentials]' '--api[remove only API key credentials]' '(- *)'{-h,--help}'[help]' ;;
                setup-github) _arguments '--repo[GitHub repository owner/repo (auto-detected from git)]:repo:' '(- *)'{-h,--help}'[help]' ;;
            esac
            ;;
    esac
}

_agentuse_sessions() {
    local -a sub
    sub=(
        'list:List sessions'
        'show:Show session details'
        'resume:Resume a suspended or ended session'
        'path:Show session storage path'
    )
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:->sub' \
        '*::arg:->args'

    case $state in
        sub) _describe -t commands 'sessions subcommand' sub ;;
        args)
            case $words[1] in
                list)
                    _arguments \
                        '(-s --subagents)'{-s,--subagents}'[include subagent sessions]' \
                        '(-j --json)'{-j,--json}'[output as JSON]' \
                        '--all[show sessions across all projects]' \
                        '--project[show sessions for a project path]:path:_files -/' \
                        '(- *)'{-h,--help}'[help]'
                    ;;
                show)
                    _arguments \
                        '(-j --json)'{-j,--json}'[output as JSON]' \
                        '(-f --full)'{-f,--full}'[show full tool input/output (not truncated)]' \
                        '--project[search a project path]:path:_files -/' \
                        '--all-search[search all projects if not in selected project]' \
                        '(- *)'{-h,--help}'[help]' \
                        '1:session id:'
                    ;;
                resume)
                    _arguments \
                        '--approve[approve a suspended approval request]:comment:' \
                        '--reject[reject a suspended approval request]:comment:' \
                        '--comment[send a reviewer comment to a suspended approval request]:comment:' \
                        '--tool-result[JSON result for a suspended non-approval await_* tool]:json:' \
                        '--prompt[instruction for continuing an ended session]:text:' \
                        '--project[search a project path]:path:_files -/' \
                        '--all-search[search all projects if not in selected project]' \
                        '(-C --directory)'{-C,--directory}'[run as if started in <path>]:path:_files -/' \
                        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
                        '(- *)'{-h,--help}'[help]' \
                        '1:session id:'
                    ;;
                path)
                    _arguments \
                        '--project[show storage path for a project path]:path:_files -/' \
                        '(- *)'{-h,--help}'[help]'
                    ;;
            esac
            ;;
    esac
}

_agentuse_serve() {
    local -a sub
    sub=(
        'ps:Show the running agentuse serve daemon'
        'log:Show the log file for the running agentuse serve daemon'
    )
    _arguments \
        '(-p --port)'{-p,--port}'[port to listen on (default 12233)]:port:' \
        '(-H --host)'{-H,--host}'[host to bind to (default 127.0.0.1)]:host:' \
        '--public-url[externally reachable base URL used in approval review links]:url:' \
        '--default[in multi-project mode, the project id for POST /run when no project field is supplied]:id:' \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '--no-auth[disable API key requirement for exposed hosts (dangerous)]' \
        '--no-log-file[disable the per-server log file]' \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:->sub' \
        '*::arg:->args'

    case $state in
        sub) _describe -t commands 'serve subcommand' sub ;;
        args)
            case $words[1] in
                ps)  _arguments '--json[output as JSON]' '(- *)'{-h,--help}'[help]' ;;
                log) _arguments '(-f --follow)'{-f,--follow}'[follow the log as it grows]' '--path[print only the log file path and exit]' '(- *)'{-h,--help}'[help]' ;;
            esac
            ;;
    esac
}

_agentuse_add() {
    _arguments \
        '--force[overwrite existing skills/agents without prompting]' \
        '--all[install all skills and agents without prompting]' \
        '--list[list available skills and agents without installing]' \
        '(-s --skill)'{-s,--skill}'[install specific skill(s) by name]:name:' \
        '(-a --agent)'{-a,--agent}'[install specific agent(s) by path]:path:_files' \
        '(- *)'{-h,--help}'[help]' \
        '*:source (repo, git URL, or local path):'
}

_agentuse "$@"
