#compdef spotless
# _spotless — DiffPlug spotless gradle/maven multi-language formatter CLI alias (diffplug team, Java); gradle plugin
# upstream: https://github.com/diffplug/spotless

_spotless() {
    local -a sub=(
        'apply:format and apply changes'
        'check:check formatting'
        'diagnose:diagnose configuration'
        'help:show help'
        'tasks:list spotless tasks'
        'spotlessApply:gradle alias for apply'
        'spotlessCheck:gradle alias for check'
        'spotlessJava:format Java'
        'spotlessJavaApply:apply Java formatting'
        'spotlessJavaCheck:check Java formatting'
        'spotlessKotlin:format Kotlin'
        'spotlessKotlinApply:apply Kotlin formatting'
        'spotlessKotlinCheck:check Kotlin formatting'
        'spotlessScala:format Scala'
        'spotlessScalaApply:apply Scala formatting'
        'spotlessScalaCheck:check Scala formatting'
        'spotlessGroovy:format Groovy'
        'spotlessGroovyApply:apply Groovy formatting'
        'spotlessGroovyCheck:check Groovy formatting'
        'spotlessGroovyGradle:format Gradle Groovy'
        'spotlessKotlinGradle:format Gradle Kotlin'
        'spotlessFormat:format misc'
        'spotlessFormatApply:apply misc format'
        'spotlessFormatCheck:check misc format'
        'spotlessMisc:format misc'
        'spotlessJson:format Json'
        'spotlessJsonApply:apply Json'
        'spotlessJsonCheck:check Json'
        'spotlessSql:format Sql'
        'spotlessSqlApply:apply Sql'
        'spotlessSqlCheck:check Sql'
        'spotlessTypescript:format Typescript'
        'spotlessTypescriptApply:apply Typescript'
        'spotlessTypescriptCheck:check Typescript'
        'spotlessYaml:format Yaml'
        'spotlessYamlApply:apply Yaml'
        'spotlessYamlCheck:check Yaml'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--info[info]' \
        '-i[info]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--stacktrace[stack trace]' \
        '-s[stack trace]' \
        '--build-file=+[build file]:file:_files -g "*.{gradle,gradle.kts,xml}"' \
        '-b+[build file]:file:_files -g "*.{gradle,gradle.kts,xml}"' \
        '-Pspotless.target=+[target]:str:' \
        '-Pspotless.formatter=+[formatter]:f:(google-java-format eclipse-java prettier ktlint scalafmt rome biome)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spotless subcommand' sub ;;
        args)
            case $words[1] in
                apply|check|spotlessApply|spotlessCheck) _arguments \
                    '*:target:_files' \
                    '--rerun-tasks[rerun tasks]' ;;
            esac
            ;;
    esac
}

_spotless "$@"
