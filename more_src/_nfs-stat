#compdef nfs-stat
# Documentation: https://github.com/sahlberg/libnfs/blob/master/utils/nfs-stat.c
# Reference accessed: 2026-05-19
# Verified: libnfs utils/nfs-stat.c — usage is "nfs-stat <file>" where <file>
# is an nfs:// URL referencing a file served over NFS.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '1:NFS URL:_files' && ret=0

return ret
