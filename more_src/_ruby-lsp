#compdef ruby-lsp

# Zsh completion for ruby-lsp - Ruby language server

_arguments -s -S \
  '--debug[launch with debug flags]' \
  '--time-index[measure indexing time]' \
  '--branch=[checkout specified branch]:branch:' \
  '--experimental[enable experimental features]' \
  '--doctor[run diagnostics]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
