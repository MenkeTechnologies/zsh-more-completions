#compdef dooit
# Documentation: https://man.archlinux.org/search?q=dooit
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[path to config.py]:file:_files' \
  '--db=[path to sqlite database]:file:_files' \
  '(-h --help)'{-h,--help}'[help]' \
  '*::words: _default'
