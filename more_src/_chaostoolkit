#compdef chaostoolkit
# Documentation: https://chaostoolkit.org/reference/usage/cli/
# Chaos Toolkit CLI to run chaos engineering experiments

local ret=1
local curcontext="$curcontext" state line

_arguments -s -C \
  '(- *)--version[display version information]' \
  '--verbose[enable debug-level output]' \
  '--no-version-check[skip checking for toolkit updates]' \
  '--change-dir=[switch to directory before execution]:dir:_files -/' \
  '--no-log-file[disable file-based logging]' \
  '--log-file=[custom log file path]:file:_files' \
  '--log-format=[console output format]:format:(string json)' \
  '--settings=[custom settings file]:file:_files' \
  '(- *)--help[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'discover[discover capabilities and experiments]' \
      'info[display information about the environment]' \
      'init[initialize a new experiment from discovered capabilities]' \
      'run[execute experiments from local or remote sources]' \
      'settings[manage toolkit configuration values]' \
      'validate[verify experiment file integrity]' \
      'report[generate a report from a journal]' && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s \
          '--journal-path=[path where to save the journal]:file:_files' \
          '--dry[run the experiment without executing activities]' \
          '--no-validation[do not validate the experiment before running]' \
          '--no-verify-tls[do not verify TLS certificate]' \
          '--rollback-strategy=[rollback runtime strategy]:strategy:(default always never deviated)' \
          '*--var=[override configuration value key=value]:var' \
          '*--var-file=[file with configuration substitution values]:file:_files' \
          '--hypothesis-strategy=[hypothesis execution strategy]:strategy:(default before-method-only after-method-only during-method-only continuously)' \
          '--hypothesis-frequency=[pace at which to run the hypothesis]:frequency' \
          '--fail-fast[fail experiment as soon as hypothesis deviates]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:experiment:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
