#compdef cdk

# Zsh completion for AWS CDK CLI (Cloud Development Kit)

local curcontext="$curcontext" state line ret=1

local -a cdk_commands
cdk_commands=(
  'init:create a new CDK project'
  'list:list all stacks in the app'
  'synth:synthesize and print the CloudFormation template'
  'synthesize:synthesize and print the CloudFormation template'
  'bootstrap:deploy the CDK toolkit stack'
  'deploy:deploy the specified stacks'
  'destroy:destroy the specified stacks'
  'diff:compare deployed stack with current state'
  'metadata:display metadata for the specified stack'
  'acknowledge:acknowledge a notice so it does not show again'
  'notices:display relevant notices for the application'
  'context:manage cached context values'
  'docs:open CDK documentation'
  'doctor:check your CDK project for potential problems'
  'watch:watch for changes and deploy'
  'import:import existing resources into a CDK stack'
  'migrate:migrate existing resources to CDK'
  'gc:garbage collect unused assets'
)

local -a cdk_global_flags
cdk_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version number]'
  '--debug[enable debug logging]'
  '--trace[print trace for stack warnings]'
  '--strict[do not construct stacks with warnings]'
  '--lookups[allow lookups]:bool:(true false)'
  '--ignore-errors[ignore synthesis errors]:bool:(true false)'
  '--json[use JSON output instead of YAML]'
  '--verbose[show debug logs]'
  '-v[show debug logs]'
  '--ci[force CI detection on]'
  '--no-color[remove color from output]'
  '-a=[cdk app command]:app command:'
  '--app=[cdk app command]:app command:'
  '-c=[set context key-value pair]:key=value:'
  '--context=[set context key-value pair]:key=value:'
  '-p=[use the indicated AWS profile]:profile:'
  '--profile=[use the indicated AWS profile]:profile:'
  '--proxy=[use the indicated proxy]:proxy url:'
  '--ca-bundle-path=[path to CA bundle]:ca bundle:_files'
  '-i[path to ec2creds]:bool:(true false)'
  '--ec2creds[path to ec2creds]:bool:(true false)'
  '--role-arn=[ARN of role to assume]:role arn:'
  '-o=[directory where synthesized output is written]:output dir:_directories'
  '--output=[directory where synthesized output is written]:output dir:_directories'
  '--notices=[show relevant notices]:bool:(true false)'
  '--no-version-reporting[disable version reporting]'
  '--path-metadata[include path metadata]:bool:(true false)'
  '--asset-metadata[include asset metadata]:bool:(true false)'
  '--staging[copy assets to output directory]:bool:(true false)'
)

_arguments -s -S \
  $cdk_global_flags \
  '1:command:_describe -t commands command cdk_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          $cdk_global_flags \
          '-l=[template language]:language:(typescript javascript python java csharp fsharp go)' \
          '--language=[template language]:language:(typescript javascript python java csharp fsharp go)' \
          '--list[list available templates]' \
          '--generate-only[generate project files only]' \
          '1:template:' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          $cdk_global_flags \
          '--all[deploy all stacks]' \
          '-e[deploy exclusively specified stacks]' \
          '--exclusively[deploy exclusively specified stacks]' \
          '-R[require manual approval for security changes]' \
          '--require-approval=[level of change requiring approval]:level:(never any-change broadening)' \
          '--notification-arns=[ARNs of SNS topics]:arns:' \
          '--tags=[tags to add to the stack]:tags:' \
          '--execute=[execute the changeset]:bool:(true false)' \
          '--change-set-name=[name of the CloudFormation change set]:name:' \
          '--method=[deployment method]:method:(change-set direct)' \
          '-f[always deploy even if templates are identical]' \
          '--force[always deploy even if templates are identical]' \
          '--parameters=[parameters for CloudFormation]:params:' \
          '--outputs-file=[path to file for stack outputs]:file:_files' \
          '--previous-parameters=[use previous values for unspecified params]:bool:(true false)' \
          '--progress=[display progress]:style:(bar events)' \
          '--rollback=[rollback on failure]:bool:(true false)' \
          '--no-rollback[do not rollback on failure]' \
          '--hotswap[attempt hotswap deployment]' \
          '--hotswap-fallback[fall back to full deploy if hotswap fails]' \
          '--watch[continuously watch for changes]' \
          '--logs[show CloudWatch logs]:bool:(true false)' \
          '--concurrency=[max concurrent stack deployments]:number:' \
          '--asset-parallelism=[max parallel asset uploads]:bool:(true false)' \
          '--asset-prebuild=[build all assets before deploying]:bool:(true false)' \
          '*:stack:' && ret=0
        ;;
      destroy)
        _arguments -s -S \
          $cdk_global_flags \
          '--all[destroy all stacks]' \
          '-e[destroy exclusively specified stacks]' \
          '--exclusively[destroy exclusively specified stacks]' \
          '-f[skip destroy confirmation]' \
          '--force[skip destroy confirmation]' \
          '*:stack:' && ret=0
        ;;
      diff)
        _arguments -s -S \
          $cdk_global_flags \
          '-e[diff exclusively specified stacks]' \
          '--exclusively[diff exclusively specified stacks]' \
          '--context-lines=[number of context lines]:lines:' \
          '--template=[path to template file]:template:_files' \
          '--strict[fail with exit code 1 on diff]' \
          '--security-only[only diff security changes]' \
          '--fail[fail with exit code 1 on diff]' \
          '--processed[compare against processed template]' \
          '--quiet[do not print stack name]' \
          '--change-set=[create changeset to get accurate diff]:bool:(true false)' \
          '*:stack:' && ret=0
        ;;
      synth|synthesize)
        _arguments -s -S \
          $cdk_global_flags \
          '-e[synth exclusively specified stacks]' \
          '--exclusively[synth exclusively specified stacks]' \
          '--validation[validate after synthesis]:bool:(true false)' \
          '--quiet[do not output synthesized template]' \
          '-q[do not output synthesized template]' \
          '*:stack:' && ret=0
        ;;
      bootstrap)
        _arguments -s -S \
          $cdk_global_flags \
          '--bootstrap-bucket-name=[name of the S3 bucket]:bucket:' \
          '--bootstrap-kms-key-id=[KMS key ID]:key id:' \
          '--bootstrap-customer-key[create customer managed KMS key]' \
          '--qualifier=[string to distinguish multiple bootstraps]:qualifier:' \
          '--public-access-block-configuration=[block public access]:bool:(true false)' \
          '--tags=[tags for bootstrap stack]:tags:' \
          '--execute=[execute bootstrap]:bool:(true false)' \
          '--trust=[ARNs of accounts to trust]:account arns:' \
          '--trust-for-lookup=[ARNs of accounts trusted for lookups]:account arns:' \
          '--cloudformation-execution-policies=[managed policy ARNs]:policy arns:' \
          '--force[overwrite existing bootstrap stack]' \
          '--termination-protection=[enable termination protection]:bool:(true false)' \
          '--show-template[print the bootstrap template and exit]' \
          '--template=[use the given template]:template:_files' \
          '--previous-parameters=[use previous values]:bool:(true false)' \
          '*:environment:' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          $cdk_global_flags \
          '-l[display environment information]' \
          '--long[display environment information]' \
          '--show-dependencies[show dependency info]' \
          '*:stack:' && ret=0
        ;;
      watch)
        _arguments -s -S \
          $cdk_global_flags \
          '-e[watch exclusively specified stacks]' \
          '--exclusively[watch exclusively specified stacks]' \
          '--hotswap[attempt hotswap deployment]' \
          '--hotswap-fallback[fall back to full deploy]' \
          '--no-hotswap[always do full deploy]' \
          '--logs[show CloudWatch logs]:bool:(true false)' \
          '--concurrency=[max concurrent deployments]:number:' \
          '*:stack:' && ret=0
        ;;
      import)
        _arguments -s -S \
          $cdk_global_flags \
          '--record-resource-mapping=[file to save mapping]:file:_files' \
          '--resource-mapping=[file with resource mapping]:file:_files' \
          '-f[skip confirmation]' \
          '--force[skip confirmation]' \
          '*:stack:' && ret=0
        ;;
      context)
        _arguments -s -S \
          $cdk_global_flags \
          '-e=[context key to reset]:key:' \
          '--reset=[context key to reset]:key:' \
          '--clear[clear all context values]' \
          '--force[force reset even with errors]' && ret=0
        ;;
      *)
        _arguments -s -S $cdk_global_flags '*:stack:' && ret=0
        ;;
    esac
    ;;
esac

return ret
