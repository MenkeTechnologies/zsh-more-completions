#compdef bru
# Documentation: https://docs.usebruno.com/bru-cli/overview
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# @usebruno/cli — collection-oriented API client (see `bru --help`)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '-v[verbose logging]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      run:collections
      request:send single
      'collection:manage collection'
      'env:environment'
      'vars:variables'
      'license:license info'
      'install:install browser'
    )
    _describe -t commands 'bru command' cmds && ret=0
    ;;
  (rest)
    _arguments '*:args:_default' && ret=0
    ;;
esac

return ret
