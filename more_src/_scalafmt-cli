#compdef scalafmt-cli
# _scalafmt-cli — Scalameta scalafmt Scala code formatter CLI alias (Scalameta / scalafmt team, Scala); custom argparse
# upstream: https://github.com/scalameta/scalafmt

_scalafmt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".scalafmt.conf"' \
        '-c+[config file]:file:_files -g ".scalafmt.conf"' \
        '--config-str=+[inline config]:str:' \
        '--stdin[read from stdin]' \
        '--stdout[write to stdout]' \
        '--respect-project-filters[respect project filters]' \
        '--non-interactive[non interactive]' \
        '--mode=+[mode]:m:(any diff changed)' \
        '--diff[only diff]' \
        '--diff-branch=+[diff branch]:str:' \
        '-i[in place edit]' \
        '--in-place[in place edit]' \
        '--test[test format]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--check[check format]' \
        '--report-error-on-empty-output=+[report error on empty output]:b:(true false)' \
        '--list[list files]' \
        '--debug[debug]' \
        '--print-tree[print tree]' \
        '--exclude=+[exclude regex]:list:' \
        '-e+[exclude regex]:list:' \
        '--encoding=+[encoding]:str:' \
        '--debug-shotgun-blame[debug shotgun blame]' \
        '*:file:_files -g "*.scala *.sbt *.sc"'
}

_scalafmt-cli "$@"
