#compdef fastly

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'acl:manage ACL containers'
  'acl-entry:manage ACL entries'
  'alerts:manage alerts'
  'auth-token:manage auth tokens'
  'backend:manage service backends'
  'compute:manage Compute@Edge services'
  'config:manage CLI configuration'
  'config-store:manage config stores'
  'config-store-entry:manage config store entries'
  'dashboard:manage dashboards'
  'deploy:deploy a Compute@Edge package'
  'dictionary:manage edge dictionaries'
  'dictionary-item:manage dictionary items'
  'domain:manage service domains'
  'domain-v1:manage v1 domains'
  'enable-product:enable product on a service'
  'healthcheck:manage health checks'
  'kv-store:manage KV stores'
  'kv-store-entry:manage KV store entries'
  'log-tail:tail logs in real time'
  'logging:manage logging endpoints'
  'objectstore:manage object stores (deprecated)'
  'pops:list points of presence'
  'profile:manage CLI profiles'
  'purge:purge cached content by URL or surrogate key'
  'resource-link:manage resource links'
  'secret-store:manage secret stores'
  'secret-store-entry:manage secret store entries'
  'service:manage services'
  'service-auth:manage user-service authorization'
  'service-version:manage service versions'
  'sso:manage SSO settings'
  'stats:report runtime statistics'
  'tls-config:manage TLS configurations'
  'tls-custom:manage custom TLS certificates'
  'tls-platform:manage platform TLS'
  'tls-private-key:manage TLS private keys'
  'tls-subscription:manage TLS subscriptions'
  'update:update CLI to latest version'
  'user:manage user accounts'
  'vcl:manage custom VCL'
  'version:show CLI version'
  'whoami:show current user info'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--accept-defaults[accept all default options]' \
  '--auto-yes[answer yes to confirmations]' \
  '--debug-mode[enable debug mode]' \
  '--endpoint=[Fastly API endpoint]:url:' \
  '--non-interactive[non-interactive mode]' \
  '--profile=[CLI profile to use]:profile:' \
  '--quiet[silence non-essential output]' \
  '--token=[Fastly API token]:token:' \
  '--verbose[enable verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fastly subcommand' subcommands && ret=0
    ;;
esac

return ret
