#compdef litex_read_verilog
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex/tools/litex_read_verilog.py
# LiteX Verilog-to-Migen instance importer (usage: litex_read_verilog verilog_file [module])

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:Verilog file:_files -g "*.(v|sv)"' \
  '2:module name:' && ret=0

return ret
