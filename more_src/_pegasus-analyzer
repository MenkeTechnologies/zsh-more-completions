#compdef pegasus-analyzer
# Documentation: https://pegasus.isi.edu/documentation/manpages/pegasus-analyzer.html
# pegasus-analyzer - debug a workflow by analyzing failed jobs and their logs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a usage summary with all available options]' \
  '(-q --quiet)'{-q,--quiet}'[print only output and error filenames, not contents]' \
  '(-s --strict)'{-s,--strict}'[get jobs output and error filenames from the submit file]' \
  '(-S --summary)'{-S,--summary}'[print only the jobs breakdown status summary and exit]' \
  '(-m --monitord)'{-m,--monitord}'[invoke pegasus-monitord before analyzing jobstate.log]' \
  '(-v --verbose)'{-v,--verbose}'[set the log level for pegasus-analyzer]' \
  '(-o --output-dir)'{-o,--output-dir}'=[alternative location for monitoring log files]:dir:_files -/' \
  '--dag=[path to the DAG file]:file:_files' \
  '(-d -i --dir --input-dir)'{-d,-i,--dir,--input-dir}'=[look for jobstate.log in this input directory]:dir:_files -/' \
  '(-p --print)'{-p,--print}'=[extra information to print for failed jobs]:info' \
  '--debug-job=[debug a particular Pegasus Lite job]:job' \
  '--debug-dir=[a particular debug_dir directory to be used]:dir:_files -/' \
  '--local-executable=[local path to the user executable]:path:_files' \
  '--type=[workflow type to debug]:type' \
  '(-c --conf)'{-c,--conf}'=[specify an alternative property file]:file:_files' \
  '--files[run pegasus-analyzer using files in the workflow directory]' \
  '--top-dir=[enable information about sub-workflows]:dir:_files -/' \
  '(-T --traverse-all)'{-T,--traverse-all}'[go through all descendant workflows]' \
  '(-r --recurse)'{-r,--recurse}'[automatically recurse into sub workflows on failure]' \
  '(-I --indent)'{-I,--indent}'=[set indent length for hierarchical workflow results]:length' \
  '(-j --json)'{-j,--json}'[return output in a JSON serializable data structure]' \
  '*:rundir:_files -/' && ret=0

return ret
