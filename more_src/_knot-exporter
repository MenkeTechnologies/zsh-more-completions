#compdef knot-exporter
# Documentation: https://github.com/CZ-NIC/knot-exporter
# Prometheus exporter for Knot DNS server and query statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-web-listen-addr=[address to listen on]:addr' \
  '-web-listen-port=[port to listen on]:port' \
  '-knot-socket-path=[path to Knot control socket]:file:_files' \
  '-knot-socket-timeout=[socket timeout in milliseconds]:ms' \
  '-no-meminfo[disable memory usage collection]' \
  '-no-global-stats[disable global statistics collection]' \
  '-no-zone-stats[disable zone statistics collection]' \
  '-no-zone-status[disable zone status collection]' \
  '-no-zone-serial[disable zone serial collection]' \
  '-zone-timers[enable SOA timer collection]' \
  '-debug[enable debug logging]' \
  '-version[show version information]' && ret=0

return ret
