#compdef sampleproc

local -a arguments

arguments=(
    '-p[Process ID to sample]:pid:'
    '-n[Number of samples]:count:'
    '-t[Time between samples in seconds]:seconds:'
    '-o[Output file]:file:_files'
    '-f[Full thread names]'
    '-h[Show help]'
    '*:process:_pids'
)

_arguments -s -S $arguments
