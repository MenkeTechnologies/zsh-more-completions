#compdef sampleproc
# Documentation: macOS sampleproc(1m) man page (DTraceToolkit-derived)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sampleproc(1m): sample which process is on each CPU. Uses DTrace.
# Synopsis per man page: `sampleproc [hertz]` -- single optional positional.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '1:hertz (sampling rate, default 100):' && ret=0
return ret
