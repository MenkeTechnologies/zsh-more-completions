#compdef impacket-secretsdump-py

# Impacket secretsdump.py (alternate invocation): dump SAM/LSA/NTDS
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-system[SYSTEM hive file]:file:_files' \
  '-bootkey[bootkey hex]:hex:' \
  '-security[SECURITY hive file]:file:_files' \
  '-sam[SAM hive file]:file:_files' \
  '-ntds[NTDS.dit file]:file:_files' \
  '-history[dump password history]' \
  '-pwd-last-set[show last password set date]' \
  '-resumefile[checkpoint file]:file:_files' \
  '-outputfile[output dump prefix]:prefix:' \
  '-use-vss[use Volume Shadow Copy]' \
  '-just-dc-user[only one user]:user:' \
  '-just-dc[only dump DC NTDS hashes]' \
  '-just-dc-ntlm[dump only NTLM hashes (no kerberos keys)]' \
  '-pwd-last-set[print last set date]' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[Kerberos AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-ts[print timestamps]' \
  '*:target user[:password]@host:' && ret=0
return ret
