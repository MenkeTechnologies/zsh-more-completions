#compdef impacket-secretsdump-py
# Documentation: https://github.com/fortra/impacket/blob/master/examples/secretsdump.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-secretsdump-py: alternate console-script name for secretsdump.py; same flags
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '-system[SYSTEM hive file]:file:_files' \
  '-bootkey[boot key (hex)]:hex:' \
  '-security[SECURITY hive file]:file:_files' \
  '-sam[SAM hive file]:file:_files' \
  '-ntds[NTDS.dit file]:file:_files' \
  '-resumefile[resume from this file]:file:_files' \
  '-outputfile[output file prefix]:file:_files' \
  '-use-vss[use VSS for online NTDS extraction]' \
  '-exec-method[remote exec method]:method:(smbexec wmiexec mmcexec)' \
  '-just-dc[only NTDS.dit secrets]' \
  '-just-dc-ntlm[only NTLM hashes from NTDS]' \
  '-just-dc-user[dump only this user]:user:' \
  '-pwd-last-set[show password last set]' \
  '-user-status[show account status flags]' \
  '-history[show password history hashes]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (hex)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '1:target (DOMAIN/user[:password]@host):' && ret=0
return ret
