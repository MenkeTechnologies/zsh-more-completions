#compdef treemd
# Documentation: https://github.com/Epistates/treemd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for treemd Markdown tree tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '*:Markdown:_files -g "*.md"' && ret=0

return ret
