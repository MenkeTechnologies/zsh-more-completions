#compdef blackduck blackduck-cli detect-cli
# _blackduck — Black Duck Detect open-source/code scanner CLI (Synopsys / Black Duck Software, Java); custom argparse
# upstream: https://github.com/blackducksoftware/synopsys-detect

_blackduck() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--diagnostic[diagnostic mode]' \
        '--diagnosticExtended[diagnostic extended mode]' \
        '--diagnosticPath=+[diagnostic output path]:dir:_files -/' \
        '--blackduck.url=+[blackduck url]:url:_urls' \
        '--blackduck.api.token=+[blackduck api token]:str:' \
        '--blackduck.username=+[username]:str:_users' \
        '--blackduck.password=+[password]:str:' \
        '--blackduck.trust.cert[trust SSL]' \
        '--blackduck.timeout=+[timeout seconds]:n:' \
        '--blackduck.proxy.host=+[proxy host]:host:_hosts' \
        '--blackduck.proxy.port=+[proxy port]:port:' \
        '--blackduck.proxy.username=+[proxy username]:str:_users' \
        '--blackduck.proxy.password=+[proxy password]:str:' \
        '--detect.project.name=+[project name]:str:' \
        '--detect.project.version.name=+[project version]:str:' \
        '--detect.project.version.phase=+[phase]:p:(DEVELOPMENT PLANNING PRERELEASE RELEASED DEPRECATED ARCHIVED)' \
        '--detect.project.version.distribution=+[distribution]:d:(EXTERNAL SAAS INTERNAL OPENSOURCE)' \
        '--detect.project.tags=+[project tags]:list:' \
        '--detect.project.group.name=+[group name]:str:_groups' \
        '--detect.project.user.groups=+[user groups]:list:_groups' \
        '--detect.policy.check.fail.on.severities=+[fail on severities]:list:(BLOCKER CRITICAL MAJOR MINOR TRIVIAL UNSPECIFIED)' \
        '--detect.policy.check.fail.on.names=+[fail on policy names]:list:' \
        '--detect.bom.aggregate.name=+[aggregate name]:str:' \
        '--detect.binary.scan.file.path=+[binary scan path]:file:_files' \
        '--detect.binary.scan.search.depth=+[binary scan search depth]:n:' \
        '--detect.docker.image=+[docker image]:str:' \
        '--detect.docker.image.id=+[docker image id]:str:' \
        '--detect.docker.tar=+[docker tar]:file:_files -g "*.tar"' \
        '--detect.source.path=+[source path]:dir:_files -/' \
        '--detect.output.path=+[output path]:dir:_files -/' \
        '--detect.tools=+[tools enabled]:list:(ALL DETECTOR DOCKER SIGNATURE_SCAN BINARY_SCAN POLARIS IMPACT_ANALYSIS)' \
        '--detect.tools.excluded=+[tools excluded]:list:' \
        '--detect.tools.included=+[tools included]:list:' \
        '--detect.detector.types.excluded=+[detector types excluded]:list:' \
        '--detect.detector.types.included=+[detector types included]:list:' \
        '--detect.detector.search.depth=+[detector search depth]:n:' \
        '--detect.cleanup=+[cleanup]:b:(true false)' \
        '--detect.risk.report.pdf=+[generate risk report pdf]:b:(true false)' \
        '--detect.notices.report=+[generate notices report]:b:(true false)' \
        '--detect.timeout=+[detect timeout seconds]:n:' \
        '--detect.parallel.processors=+[parallel processors]:n:' \
        '--detect.code.location.name=+[code location name]:str:' \
        '--detect.report.timeout=+[report timeout]:n:' \
        '--detect.wait.for.results[wait for results]' \
        '*:arg:'
}

_blackduck "$@"
