#compdef ohai
# _ohai — Chef Ohai system info collector CLI alias (chef team, Ruby); custom argparse
# upstream: https://github.com/chef/ohai

_ohai() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d+[plugin path]:dir:_files -/' \
        '--directory=+[plugin path]:dir:_files -/' \
        '-l+[log level]:l:(debug info warn error fatal)' \
        '--log_level=+[log level]:l:(debug info warn error fatal)' \
        '-L+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-o+[output format]:f:(json yaml)' \
        '--format=+[output format]:f:(json yaml)' \
        '*:attribute:'
}

_ohai "$@"
