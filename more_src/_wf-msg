#compdef wf-msg
# Documentation: https://man.archlinux.org/search?q=wf-msg
# Reference accessed: 2026-05-16

# wf-msg: emit a message/notification through Wayfire
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:wf-msg args:_files' && ret=0
return ret
