#compdef csmith
# Documentation: https://github.com/csmith-project/csmith
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Random C program generator. Full option list via `csmith -hh`; common flags wired here.

_arguments -s -S \
  '-h[short help]' \
  '-hh[extended help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--seed=[PRNG seed]:n:' \
  '-s+[PRNG seed]:n:' \
  '--output=[output file]:file:_files' \
  '-o+[output file]:file:_files' \
  '--max-funcs=[max number of functions]:n:' \
  '--max-pointer-depth=[max pointer depth]:n:' \
  '--max-struct-fields=[max struct fields]:n:' \
  '--max-union-fields=[max union fields]:n:' \
  '--max-expr-complexity=[max expression complexity]:n:' \
  '--max-block-depth=[max block nesting]:n:' \
  '--max-array-dim=[max array dimensions]:n:' \
  '--max-array-len-per-dim=[max array length per dim]:n:' \
  '--no-arrays[disable arrays]' \
  '--no-bitfields[disable bitfields]' \
  '--no-checksum[disable checksum]' \
  '--no-comma-operators[disable comma operators]' \
  '--no-compound-assignment[disable compound assignment]' \
  '--no-consts[disable consts]' \
  '--no-embedded-assigns[disable embedded assignments]' \
  '--no-jumps[disable goto/break/continue]' \
  '--no-longlong[disable long long]' \
  '--no-int8[disable int8 type]' \
  '--no-uint8[disable uint8 type]' \
  '--no-math64[disable 64-bit math]' \
  '--no-pointers[disable pointers]' \
  '--no-structs[disable structs]' \
  '--no-unions[disable unions]' \
  '--no-volatiles[disable volatiles]' \
  '--no-volatile-pointers[disable volatile pointers]' \
  '--no-builtins[disable builtin functions]' \
  '--paranoid[paranoid output]' \
  '--quiet[suppress messages]' \
  '--concise[reduce comment output]'
