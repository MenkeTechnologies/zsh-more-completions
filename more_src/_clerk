#compdef clerk
# Documentation: https://clerk.com/docs/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_clerk() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--verbose[Show detailed output (enables debug messages)]'
        '--mode[Explicitly set the interaction mode]:mode:(human agent)'
        '(-h --help)'{-h,--help}'[Display help for the command]'
        '(-v --version)'{-v,--version}'[Show the CLI version]'
    )

    subcmds=(
        'init:Initialize Clerk in your project'
        'auth:Manage authentication'
        'whoami:Show the current logged-in user'
        'apps:Manage your Clerk applications'
        'env:Manage environment variables'
        'config:Manage instance configuration as code'
        'api:Authenticated client for the Clerk Backend API'
        'users:Manage Clerk users'
        'doctor:Validate project integration and flag common issues'
        'open:Open Clerk resources in your browser'
        'link:Link the current project to a specific Clerk application'
        'unlink:Unlink the project from its Clerk application'
        'enable:Enable Clerk features on the linked instance'
        'disable:Disable Clerk features on the linked instance'
        'update:Update the CLI to the latest version'
        'help:Help about any command'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'clerk commands' subcmds
            ;;
        args)
            case $line[1] in
                auth)
                    local -a auth_subcmds
                    auth_subcmds=(
                        'login:Log in to Clerk'
                        'logout:Log out from Clerk'
                    )
                    _describe -t commands 'auth subcommands' auth_subcmds
                    ;;
                apps)
                    local -a apps_subcmds
                    apps_subcmds=(
                        'list:List your Clerk applications'
                        'create:Create a new Clerk application'
                    )
                    _describe -t commands 'apps subcommands' apps_subcmds
                    ;;
                env)
                    local -a env_subcmds
                    env_subcmds=(
                        'pull:Pull environment variables'
                    )
                    _describe -t commands 'env subcommands' env_subcmds
                    ;;
                config)
                    local -a config_subcmds
                    config_subcmds=(
                        'pull:Pull instance configuration'
                        'patch:Patch instance configuration'
                    )
                    _describe -t commands 'config subcommands' config_subcmds
                    ;;
                api)
                    local -a api_subcmds
                    api_subcmds=(
                        'ls:List available API endpoints'
                    )
                    _describe -t commands 'api subcommands' api_subcmds
                    ;;
                users)
                    local -a users_subcmds
                    users_subcmds=(
                        'list:List Clerk users'
                        'create:Create a new Clerk user'
                    )
                    _describe -t commands 'users subcommands' users_subcmds
                    ;;
            esac
            ;;
    esac
}

_clerk "$@"
