#compdef pgcli mssqlcli
# Documentation: https://man.archlinux.org/search?q=pgcli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (pgcli)
    _arguments -C \
      '(- *)--help[show help]' \
      '(--version)--version[show version]' \
      '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[port]:port:' \
      '(-U --user --username)'{-U+,--user=,--username=}'[user]:user:_users' \
      '(-W --password)'{-W,--password}'[force password]' \
      '(-w --no-password)'{-w,--no-password}'[no password]' \
      '(-d --dbname)'{-d+,--dbname=}'[database]:db:' \
      '(--single-connection)--single-connection[single connection]' \
      '(-v --version)'{-v,--version}'[version]' \
      '(-D --dsn)'{-D+,--dsn=}'[DSN]:dsn:' \
      '(--list-dsn)--list-dsn[list DSN]' \
      '(--row-limit)--row-limit=[row limit]:n:' \
      '(--application-name)--application-name=[app name]:s:' \
      '(--less-chatty)--less-chatty[less chatty]' \
      '(--prompt)--prompt=[prompt format]:s:' \
      '(--prompt-dsn)--prompt-dsn=[prompt DSN]:s:' \
      '(--list)--list[list databases]' \
      '(--auto-vertical-output)--auto-vertical-output[auto vertical]' \
      '(--warn)--warn=[confirm-on-write]:b:(all moderate off)' \
      '(--ssh-tunnel)--ssh-tunnel=[SSH tunnel]:s:' \
      '(--log-file)--log-file=[log file]:file:_files' \
      '*: :' && ret=0 ;;
  (mssqlcli)
    _arguments -C \
      '(- *)--help[show help]' \
      '(-S --server)'{-S+,--server=}'[server]:host:_hosts' \
      '(-d --database)'{-d+,--database=}'[database]:db:' \
      '(-U --username)'{-U+,--username=}'[user]:user:_users' \
      '(-P --password)'{-P+,--password=}'[password]:pass:' \
      '(-E --integrated)'{-E,--integrated}'[integrated auth]' \
      '(-N --encrypt)'{-N,--encrypt}'[encrypt]' \
      '(-C --trust-server-certificate)'{-C,--trust-server-certificate}'[trust cert]' \
      '(--row-limit)--row-limit=[row limit]:n:' \
      '(--less-chatty)--less-chatty[less chatty]' \
      '(--prompt)--prompt=[prompt format]:s:' \
      '(--logfile)--logfile=[log file]:file:_files' \
      '(--mssqlclirc)--mssqlclirc=[config]:file:_files' \
      '(--auto-vertical-output)--auto-vertical-output[auto vertical]' \
      '(--row-limit)--row-limit=[row limit]:n:' \
      '*: :' && ret=0 ;;
esac

return ret
