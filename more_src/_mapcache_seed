#compdef mapcache_seed
# Documentation: https://mapserver.org/mapcache/seed.html
# Seed, delete or transfer tiles for MapCache tilesets

local ret=1

_arguments -s \
  '(-b --non-interactive)'{-b,--non-interactive}'[print progress messages on new lines]' \
  '(-c --config)'{-c,--config}'[path to the mapcache.xml configuration file]:file:_files' \
  '(-C --cache)'{-C,--cache}'[override cache used by selected tileset]:cache:' \
  '(-D --dimension)'{-D,--dimension}'[specify a dimension (DIMENSION=VALUE), repeatable]:dimension:' \
  '(-e --extent)'{-e,--extent}'[bounding box of the area to seed]:minx,miny,maxx,maxy:' \
  '(-f --force)'{-f,--force}'[force recreation of existing tiles]' \
  '(-g --grid)'{-g,--grid}'[name of the grid that must be seeded]:grid:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-H --header)'{-H,--header}'[set an HTTP header (HEADER=VALUE), repeatable]:header:' \
  '(-i --iteration-mode)'{-i,--iteration-mode}'[iteration mode]:mode:(drill-down scanline)' \
  '(-L --log-failed)'{-L,--log-failed}'[log failed tiles to file]:file:_files' \
  '(-m --mode)'{-m,--mode}'[seeder mode]:mode:(seed delete transfer)' \
  '(-M --metasize)'{-M,--metasize}'[override metatile size while seeding]:metasize:' \
  '(-n --nthreads)'{-n,--nthreads}'[number of parallel request threads]:nthreads:' \
  '(-o --older)'{-o,--older}'[only seed tiles older than timestamp or now]:timestamp:' \
  '(-p --nprocesses)'{-p,--nprocesses}'[number of parallel request processes]:nprocesses:' \
  '(-P --percent)'{-P,--percent}'[percent of failed requests allowed before abort]:percent:' \
  '(-q --quiet)'{-q,--quiet}'[do not print progress messages to stdout]' \
  '(-R --retry-failed)'{-R,--retry-failed}'[retry failed requests logged by --log-failed]:file:_files' \
  '(-t --tileset)'{-t,--tileset}'[name of the tileset that must be seeded]:tileset:' \
  '(-v --verbose)'{-v,--verbose}'[print verbose debugging info]' \
  '(-x --transfer)'{-x,--transfer}'[tileset to transfer when in transfer mode]:tileset:' \
  '(-z --zoom)'{-z,--zoom}'[start and end zoom levels]:minzoom,maxzoom:' \
  '(-d --ogr-datasource)'{-d,--ogr-datasource}'[OGR connection to the spatial source]:datasource:_files' \
  '(-l --ogr-layer)'{-l,--ogr-layer}'[OGR layer to use]:layer:' \
  '(-s --ogr-sql)'{-s,--ogr-sql}'[OGR SQL expression to apply]:sql:' \
  '(-w --ogr-where)'{-w,--ogr-where}'[SQL where expression to filter values]:where:' && ret=0

return ret
