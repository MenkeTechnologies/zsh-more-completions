#compdef mf2t
# Documentation: https://pieter.vanoostrum.org/en/midi2text-mf2t-t2mf/
# translate a Standard MIDI File to a readable text file

local ret=1

_arguments -s -S \
  '-m[merge partial sysex into a single sysex message]' \
  '-n[write notes in symbolic rather than numeric form]' \
  '-b[write event times as bar:beat:click]' \
  '-t[write event times as bar:beat:click]' \
  '-v[use a slightly more verbose output]' \
  '-f+[fold long text and hex entries at n characters]:columns' \
  '::midi file:_files -g "*.(mid|midi)"' \
  '::text file:_files' && ret=0

return ret
