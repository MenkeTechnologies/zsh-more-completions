#compdef jobex
# Documentation: https://www.turbomole.org/turbomole/documentation/
# TURBOMOLE driver script for geometry optimizations and ab initio molecular dynamics

local ret=1

_arguments -s -S \
  '-ri[use the RI approximation for Coulomb (ridft/rdgrad)]' \
  '-rijk[use RI-JK-SCF as reference for RI-MP2]' \
  '-ex[force use of egrad/excited-state gradients]' \
  '-level[level of theory for the optimization]:level:(scf dft mp2 cc2)' \
  '-c[maximum number of optimization cycles]:cycles' \
  '-gcart[Cartesian gradient convergence threshold (10^-n)]:n' \
  '-statpt[use statpt for the relaxation step]' && ret=0

return ret
