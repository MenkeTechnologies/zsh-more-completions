#compdef victoria-traces
# Documentation: https://docs.victoriametrics.com/victoriatraces/
# VictoriaTraces - fast database for distributed traces

local ret=1

_arguments -s -S \
  '-storageDataPath=[directory path for storing data]:path:_files -/' \
  '-retentionPeriod=[how long to keep trace data]:period' \
  '-retention.maxDiskSpaceUsageBytes=[max disk space before dropping old partitions]:bytes' \
  '-retention.maxDiskUsagePercent=[max filesystem usage percent before dropping partitions]:percent' \
  '-futureRetention=[how far into the future to accept trace spans]:period' \
  '-maxBackfillAge=[reject spans older than this value]:duration' \
  '-httpListenAddr=[TCP address for incoming HTTP requests]:addr' \
  '-otlpGRPCListenAddr=[TCP address for accepting OTLP gRPC requests]:addr' \
  '-maxConcurrentInserts=[maximum concurrent insert requests]:count' \
  '-insert.maxQueueDuration=[maximum wait time in queue for inserts]:duration' \
  '-search.maxConcurrentRequests=[maximum concurrent search requests]:count' \
  '-search.maxQueryDuration=[maximum query execution duration]:duration' \
  '-search.maxQueryLen=[maximum query length in bytes]:bytes' \
  '-memory.allowedPercent=[allowed memory percentage for caches]:percent' \
  '-logNewStreams[log creation of new streams]' \
  '-logIngestedRows[log all ingested trace spans]' \
  '-loggerLevel=[minimum error logging level]:level' \
  '-tls[enable TLS for incoming HTTP requests]' \
  '-tlsCertFile=[path to TLS certificate file]:file:_files' \
  '-tlsKeyFile=[path to TLS key file]:file:_files' \
  '-httpAuth.username=[username for HTTP Basic Auth]:username' \
  '-httpAuth.password=[password for HTTP Basic Auth]:password' \
  '-forceFlushAuthKey=[auth key for forced flush endpoint]:key' \
  '-forceMergeAuthKey=[auth key for forced merge endpoint]:key' \
  '-version[display version]' \
  '-help[show all supported flags]' && ret=0

return ret
