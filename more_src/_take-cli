#compdef take-cli
# _take-cli — zsh oh-my-zsh take helper CLI alias for mkdir+cd (ohmyzsh team, shell)
# upstream: https://github.com/ohmyzsh/ohmyzsh/blob/master/lib/functions.zsh

_take-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-p[make parents as needed]' \
        '*:directory:_files -/'
}

_take-cli "$@"
