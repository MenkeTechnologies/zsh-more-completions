#compdef memerror
# Documentation: https://man.archlinux.org/man/memerror.1.en
# Translate an error code to a string (libmemcached)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-q --quiet)'{-q,--quiet}'[operate quietly]' \
  '(-v --verbose)'{-v,--verbose}'[operate more verbosely]' \
  '(-d --debug)'{-d,--debug}'[enable debug/verbose mode]' \
  '*:error code:_default' && ret=0

return ret
