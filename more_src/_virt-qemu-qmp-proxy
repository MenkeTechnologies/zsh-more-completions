#compdef virt-qemu-qmp-proxy
# Documentation: https://libvirt.org/manpages/virt-qemu-qmp-proxy.html
# expose a QMP proxy server to a QEMU guest managed by libvirt

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display command line help information]' \
  '(-v --verbose)'{-v,--verbose}'[show all QMP commands and replies]' \
  '(-c --connect)'{-c,--connect}'[URI for connecting to the libvirt QEMU driver]:uri' \
  '1:domain:' \
  '2:qmp socket path:_files' && ret=0

return ret
