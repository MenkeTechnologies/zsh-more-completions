#compdef mcli
# Documentation: https://docs.mosaicml.com/projects/mcli/en/latest/training/common_commands.html
# Databricks Mosaic AI Training CLI for submitting and managing runs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(init run get describe logs stop delete update interactive connect set unset watchdog ping diagnostics version)' \
  '*::arg:->args' && ret=0

return ret
