# _coq2 — INRIA Coq Team coq2 CLI command-line frontend wrapping the Coq formal proof management system originally developed at INRIA now Coq Team Rocq Project formal proof management system providing a formal language to write mathematical definitions executable algorithms and theorems together with an environment for semi-interactive development of machine-checked proofs written in OCaml originally Thierry Coquand Gerard Huet now Coq team Pierre Letouzey Maxime Dénès Calculus of Inductive Constructions coqc coqtop coqide coqdep coqdoc coq_makefile coqchk coqwc dependency-checker compilation-checker compile load checker include require R Q nis (INRIA Coq Team Thierry Coquand Pierre Letouzey Maxime Dénès, OCaml); custom argparse
# upstream: https://coq.inria.fr/

_coq2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-bt[backtrace]' \
        '--bt[backtrace]' \
        '-debug[debug]' \
        '--debug[debug]' \
        '-color=+[c]:c:(yes no auto emacs)' \
        '--color=+[c]:c:(yes no auto emacs)' \
        '-noinit[no init]' \
        '-nois[no IS]' \
        '-init-file=+[file]:file:_files -g "*.v *.coq"' \
        '-emacs[Emacs mode]' \
        '-batch[batch mode]' \
        '-time[time each command]' \
        '-profile[profile]' \
        '-where[print Coqlib]' \
        '-config[print config]' \
        '-coqlib=+[dir]:dir:_files -/' \
        '-async-proofs=+[m]:m:(off lazy on)' \
        '-async-proofs-cache=+[m]:m:(force on)' \
        '-async-proofs-j=+[N]:n:' \
        '-async-proofs-private-flags=+[flags]:str:' \
        '-async-queries-always-delegate[delegate queries]' \
        '-async-proofs-never-reopen-branch[no reopen branch]' \
        '-async-proofs-tactic-error-resilience=+[r]:str:' \
        '-async-proofs-command-error-resilience=+[r]:str:' \
        '-I+[dir]:dir:_files -/' \
        '*-I+[dir]:dir:_files -/' \
        '-include=+[dir]:dir:_files -/' \
        '*-include=+[dir]:dir:_files -/' \
        '-Q+[dir lib]:str:' \
        '*-Q+[dir lib]:str:' \
        '-R+[dir lib]:str:' \
        '*-R+[dir lib]:str:' \
        '-top=+[name]:str:' \
        '-load-vernac-source=+[file]:file:_files -g "*.v"' \
        '*-l+[file]:file:_files -g "*.v"' \
        '-load-vernac-source-verbose=+[file]:file:_files -g "*.v"' \
        '-load-ml-source=+[file]:file:_files -g "*.ml"' \
        '-load-ml-object=+[file]:file:_files -g "*.cmo"' \
        '-require-import=+[lib]:str:' \
        '-rifrom=+[dir lib]:str:' \
        '-require-export=+[lib]:str:' \
        '-refrom=+[dir lib]:str:' \
        '-set=+[opt]:str:' \
        '*-set=+[opt]:str:' \
        '-unset=+[opt]:str:' \
        '*-unset=+[opt]:str:' \
        '-w+[w]:str:' \
        '-wfail[w fail]' \
        '-print-mod-uid[print module uid]' \
        '-output-context[output context]' \
        '-vio2vo[vio to vo]' \
        '-mangle-names=+[prefix]:str:' \
        '-load-vernac-object=+[name]:str:' \
        '*-l+[name]:str:' \
        '-rebuild[rebuild]' \
        '-impredicative-set[impredicative set]' \
        '-indices-matter[indices matter]' \
        '-type-in-type[type in type]' \
        '-allow-sprop[allow SProp]' \
        '-disallow-sprop[disallow SProp]' \
        '-output-directory=+[dir]:dir:_files -/' \
        '-o+[output]:file:_files -g "*.vo"' \
        '-fail[fail on error]' \
        '-fail-on-error[fail on error]' \
        '-quick[quick compile]' \
        '-vio[vio mode]' \
        '-schedule-vio2vo=+[N]:n:' \
        '-print-version[print version]' \
        '-print-mod[print mod]' \
        '-list-tags[list tags]' \
        '-impredicative-set[impredicative set]' \
        '-vos[vos mode]' \
        '-vok[vok mode]' \
        '-rebuild[rebuild]' \
        '-update-Make[update Make]' \
        '*:coq file:_files -g "*.v *.vo"'
}

_coq2 "$@"
