#compdef selscan
# Documentation: https://github.com/szpiech/selscan
# selscan: haplotype-based scans for recent positive selection (iHS, nSL, XP-EHH, EHH)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ehh=[calculate EHH for specified locus]:locus' \
  '--ihs[compute integrated haplotype score]' \
  '--nsl[calculate nSL statistic]' \
  '--xpehh[cross-population EHH analysis]' \
  '--xpnsl[cross-population nSL statistic]' \
  '--ihh12[compute iHH12 metric]' \
  '--vcf=[VCF file with haplotype data]:file:_files -g "*.vcf*"' \
  '--vcf-ref=[reference VCF for cross-population analyses]:file:_files -g "*.vcf*"' \
  '--hap=[haplotype file (0/1 coded)]:file:_files' \
  '--map=[map file (chr, locus id, genetic pos, physical pos)]:file:_files' \
  '--tped=[TPED format file]:file:_files -g "*.tped"' \
  '--thap=[IMPUTE-format haplotype file]:file:_files' \
  '--out=[output filename basename]:basename' \
  '--threads=[number of processing threads]:int' \
  '--multi-param=[JSON file with multiple parameter sets]:file:_files -g "*.json"' \
  '--cutoff=[EHH decay threshold]:double' \
  '--maf=[minimum allele frequency for core SNPs]:double' \
  '--max-extend=[maximum EHH extension distance in bp]:int' \
  '--max-gap=[maximum allowed SNP gap in bp]:int' \
  '--ehh-win=[window size around query locus in bp]:int' \
  '--unphased[use multilocus genotypes]' \
  '--pmap[use physical distances instead of genetic map]' \
  '--trunc-ok[accept EHH curves reaching sequence end before cutoff]' \
  '--keep-low-freq[include low-frequency variants]' && ret=0

return ret
