#compdef docker-machine-nfs

# Zsh completion for docker-machine-nfs
# Upstream: Activates NFS on docker-machine
# Conservative fallback — run `docker-machine-nfs --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
