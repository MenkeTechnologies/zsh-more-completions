#compdef simple_switch
# Documentation: https://github.com/p4lang/behavioral-model/blob/main/docs/simple_switch.md
# P4 bmv2 simple_switch reference target

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help message]' \
  '*'{-i+,--interface=}'[attach network interface as port (PORT@IFACE)]:port@iface' \
  '--pcap=-[generate pcap files for interfaces]::directory:_files -/' \
  '--use-files=[read/write packets from files with wait time]:wait' \
  '--packet-in=[receive packets on nanomsg socket]:addr' \
  '--thrift-port=[TCP port for the Thrift runtime server]:port' \
  '--device-id=[device ID for IPC messages (default 0)]:id' \
  '--nanolog=[IPC socket for nanomsg pub/sub logs]:addr' \
  '--log-console[enable logging on stdout]' \
  '--log-file=[enable logging to given file]:file:_files' \
  '(-L --log-level)'{-L+,--log-level=}'[set log level]:level:(trace debug info warn error off)' \
  '--log-flush[flush logger to disk after every message]' \
  '--log-file-max-size=[maximum log file size before rotation]:bytes' \
  '--log-file-max-files=[maximum rotated backup files to keep]:count' \
  '--notifications-addr=[nanomsg address for notifications]:addr' \
  '--debugger[activate debugger]' \
  '--debugger-addr=[nanomsg address for debugger communication]:addr' \
  '--restore-state=[restore state from file]:file:_files' \
  '--dump-packet-data=[bytes of packet data to dump per packet]:bytes' \
  '--no-p4[start the switch without an input configuration]' \
  '--max-port-count=[maximum interfaces that can bind to switch]:count' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '--json-version[display max bmv2 JSON version supported]' \
  '--drop-port=[choose a numerical value for the drop port (default 511)]:port' \
  '--priority-queues=[number of priority queues per port]:count' \
  '*:P4 JSON:_files' && ret=0

return ret
