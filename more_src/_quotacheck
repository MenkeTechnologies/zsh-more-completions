#compdef quotacheck
# Documentation: man quotacheck(8) (BSD)
# Source: BSD quotacheck — filesystem quota consistency checker.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a)-a[check all filesystems with mount-option file]' \
    '-g[only group quotas]' \
    '-u[only user quotas]' \
    '-v[report calculated-vs-recorded discrepancies]' \
    '*:filesystem:_files -/' \
    && ret=0

return ret
