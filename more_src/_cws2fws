#compdef cws2fws
# Documentation: https://github.com/matthiaskramm/swftools
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cws2fws (swftools): convert compressed SWF to uncompressed SWF.
# Synopsis: cws2fws infile.swf outfile.swf (positional args only).

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input SWF:_files -g "*.swf"' \
  '2:output SWF:_files -g "*.swf"' && ret=0

return ret
