#compdef tmxrasterizer
# Documentation: https://github.com/mapeditor/tiled/blob/master/src/tmxrasterizer/main.cpp
# Render Tiled (.tmx/.world) maps to images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-s --scale)'{-s,--scale}'[scale of the output image (default 1)]:scale' \
  '(-t --tilesize)'{-t,--tilesize}'[size in pixels at which a tile is rendered]:size' \
  '--size[output image fits within SIZE x SIZE square]:size' \
  '(-a --anti-aliasing)'{-a,--anti-aliasing}'[activate anti-aliasing for primitive edges]' \
  '--no-smoothing[use nearest neighbour instead of smooth blending]' \
  '--ignore-visibility[ignore all layer visibility flags and render all layers]' \
  '*--hide-layer[layer to omit from the output image]:layer' \
  '*--show-layer[show only specified layers]:layer' \
  '--hide-tile-layers[do not render tile layers]' \
  '--hide-object-layers[do not render object layers]' \
  '--hide-image-layers[do not render image layers]' \
  '*--hide-object[object to omit from the output image]:object' \
  '*--show-object[show only specified objects]:object' \
  '--advance-animations[advance tile animations by given duration in ms]:ms' \
  '--frames[number of frames to export]:count' \
  '--frame-duration[duration of each frame in ms (default 100)]:ms' \
  '*:file:_files' && ret=0

return ret
