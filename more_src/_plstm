#compdef plstm
# Documentation: https://docs.siesta-project.org/projects/siesta/en/stable/reference/plstm.html
# SIESTA slice LDOS files to simulate STM images (Tersoff-Hamann)

local ret=1

_arguments -s -S \
  '-h[print help]' \
  '-d[print debugging info]' \
  '-i[constant-current calculation, current in e/bohr**3]:current:' \
  '-z[constant-height calculation, height in bohr]:height:' \
  '-s[spin code (q,x,y,z,s)]:spin code:(q x y z s)' \
  "-v[tip spin direction as normalized 'ux uy uz']:vector:" \
  '-X[multiple copies of plot domain along X]:NX:' \
  '-Y[multiple copies of plot domain along Y]:NY:' \
  '-o[set output file name overriding conventions]:output file:_files' \
  '-H[stop after computing ranges of heights and currents]' \
  '-I[stop after computing ranges of heights and currents]' \
  '*:LDOS file:_files' && ret=0

return ret
