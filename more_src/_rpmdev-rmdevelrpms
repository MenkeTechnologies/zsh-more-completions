#compdef rpmdev-rmdevelrpms
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-rmdevelrpms.py
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools Python optparse source.

# rpmdev-rmdevelrpms: find -devel RPMs installed without their parent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-l --list-only)'{-l,--list-only}'[output condensed list, do not remove]' \
  '--qf=[query format for output]:format:' \
  '--queryformat=[query format for output]:format:' \
  '(-y --yes)'{-y,--yes}'[remove without prompting (root only)]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0
return ret
