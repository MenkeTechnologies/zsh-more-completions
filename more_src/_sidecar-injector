#compdef sidecar-injector
# Documentation: https://man.archlinux.org/search?q=sidecar-injector
# Reference accessed: 2026-05-16

# sidecar-injector: legacy Istio sidecar injection webhook (folded into istiod)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--monitoringAddr=[monitoring addr]:addr:' \
  '--log_as_json[log as json]' \
  '--log_caller=[log caller scope]:scope:' \
  '--log_output_level=[log output level]:level:' \
  '--log_stacktrace_level=[log stacktrace level]:level:' \
  '--log_target=[log target]:target:' \
  '*::sidecar-injector args:_files' && ret=0
return ret
