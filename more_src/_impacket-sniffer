#compdef impacket-sniffer
# Documentation: https://github.com/fortra/impacket/blob/master/examples/sniffer.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-sniffer: simple raw socket sniffer; positional list of protocols (default: icmp tcp udp)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:protocol:(icmp tcp udp)' && ret=0
return ret
