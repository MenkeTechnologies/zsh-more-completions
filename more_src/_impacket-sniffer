#compdef impacket-sniffer

# Impacket sniffer.py: simple packet sniffer for educational tests
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[turn debug output on]' \
  '-iface[network interface]:iface:' \
  '-protocol[protocol filter]:proto:(tcp udp icmp arp ip)' \
  '*::sniffer args:_files' && ret=0
return ret
