#compdef scylla-manager sctool
# _scylla-manager — ScyllaDB scylla-manager sctool CLI command-line frontend wrapping the Scylla Manager open-source ScyllaDB Cassandra-compatible administration centralized backup repair maintenance task scheduling Apache Cassandra compatibility cluster CRUD restore continuous repair-status-progress storage backup-target locations rate-limit health (ScyllaDB team, Go); cobra
# upstream: https://manager.docs.scylladb.com/

_scylla-manager() {
    local -a sub=(
        'cluster:cluster management'
        'task:task management'
        'backup:backup operations'
        'restore:restore operations'
        'repair:repair operations'
        'progress:fetch progress'
        'status:show status'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-cert-file=+[file]:file:_files' \
        '--api-key-file=+[file]:file:_files' \
        '--api-ca-file=+[file]:file:_files' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml"' \
        '-c+[cluster id]:str:' \
        '--cluster=+[id]:str:' \
        '-l+[location]:str:' \
        '--location=+[loc]:str:' \
        '--snapshot-tag=+[tag]:str:' \
        '--rate-limit=+[N]:n:' \
        '--retention=+[N]:n:' \
        '--retention-days=+[N]:n:' \
        '--retention-map=+[map]:str:' \
        '--upload-parallel=+[N]:n:' \
        '--enabled=+[bool]:s:(true false)' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scylla-manager subcommand' sub ;;
        args)
            case $words[1] in
                cluster) _arguments \
                    '1:op:(add delete list update auth-token)' \
                    '--name=+[name]:str:' \
                    '--host=+[host:port]:str:' \
                    '--auth-token=+[token]:str:' ;;
                task) _arguments \
                    '1:op:(list show start stop progress delete update)' \
                    '*:task id:' ;;
                backup|restore|repair) _arguments \
                    '--dc=+[list]:str:' \
                    '--keyspace=+[list]:str:' \
                    '--show-tables[show tables]' \
                    '--dry-run[dry run]' ;;
            esac
            ;;
    esac
}

_scylla-manager "$@"
