#compdef cksfv
# Documentation: https://manpages.debian.org/bookworm/cksfv/cksfv.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[strip dirnames from filenames in sfv output]' \
  '-c[use stdout for progress and final result]' \
  '-C[change directory before verification]:directory:_directories' \
  '-f[verify checksums in given sfv file]:sfv file:_files -g "*.sfv(-.)"' \
  '-g[chdir to sfv file path and verify checksums]:sfv file:_files -g "*.sfv(-.)"' \
  '-i[ignore case in filenames]' \
  '-L[follow symlinks when recursing]' \
  '-q[quiet mode (errors only)]' \
  '-v[verbose mode (default)]' \
  '-r[recurse and check .sfv files in each dir]' \
  '-R[recurse and read checksum for each file]' \
  '--help[display help]' \
  '*:file:_files' && ret=0

return ret
