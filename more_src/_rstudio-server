#compdef rstudio-server

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start the server'
  'stop:stop server and sessions'
  'restart:restart to apply config changes'
  'reload:reload configuration'
  'status:report status'
  'offline:take server offline'
  'online:bring server back online'
  'add-user:add to licensed users'
  'list-users:list users with license info'
  'lock-user:lock a user'
  'unlock-user:unlock a user'
  'set-admin:set admin status'
  'active-sessions:list active R sessions'
  'suspend-session:suspend a session'
  'suspend-all:suspend all sessions'
  'force-suspend-session:force suspend session'
  'force-suspend-all:force suspend all sessions'
  'kill-session:kill a session'
  'kill-all:kill all sessions'
  'list-nodes:list cluster nodes'
  'reset-cluster:reset load-balance state'
  'delete-node:delete a node'
  'license-manager:license operations'
  'run-diagnostics:run diagnostics'
  'test-config:validate server config'
  'upload-minidump:upload crash dump'
  'verify-installation:verify installation'
  'version:print server version'
  'install-vs-code:install VS Code server'
  'install-vs-code-ext:install RStudio VS Code extension'
  'encrypt-password:encrypt DB password'
  'migrate-db:migrate SQLite to PostgreSQL'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rstudio-server subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (license-manager)
        _values 'license action' \
          'activate' 'activate-file' 'activate-offline' 'activate-offline-request' \
          'acquire-lease-verbose' 'begin-evaluation-offline' 'begin-evaluation-request' \
          'deactivate' 'deactivate-offline' 'clear-license-server' \
          'extend-evaluation' 'extend-evaluation-offline' 'initialize' \
          'license-server' 'verify' 'status' && ret=0
        ;;
      (add-user|lock-user|unlock-user|set-admin)
        _arguments ':user:_users' && ret=0
        ;;
      (suspend-session|force-suspend-session|kill-session)
        _arguments ':pid:_pids' && ret=0
        ;;
    esac
    ;;
esac

return ret
