#compdef t-coffee
# Documentation: https://man.archlinux.org/search?q=t-coffee
# Reference accessed: 2026-05-16

# T-Coffee: consistency-based multiple sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-other_pg[show other programs available]' \
  '-version[show version]' \
  '-in[input sequence file(s)]:file:_files' \
  '-seq[sequence input file]:file:_files' \
  '-aln[alignment input]:file:_files' \
  '-method[methods used to compute pairwise alignments]:methods:' \
  '-mode[mode preset]:mode:(regular expresso 3dcoffee psicoffee rcoffee mcoffee saracoffee accurate)' \
  '-template_file[template file (e.g. PDB list)]:file:_files' \
  '-evaluate[evaluate an existing alignment]' \
  '-output[output format(s)]:fmt:(score_ascii score_html clustalw_aln fasta_aln msf_aln phylip_aln sam pir_aln stockholm_aln)' \
  '-outfile[output file]:file:_files' \
  '-output_format[output format]:fmt:' \
  '-tree[guide tree file or method]:val:' \
  '-newtree[output guide tree]:file:_files' \
  '-usetree[use a previously computed tree]:file:_files' \
  '-distance_matrix_mode[distance matrix algorithm]:mode:(quick slow ktup idmat)' \
  '-multi_core[multicore mode]:mode:(template_evaluation tree job no)' \
  '-n_core[number of cores]:n:' \
  '-quiet[reduce output]' \
  '-stdout=[stdout/file]:val:' \
  '-no_warning[silence warnings]' \
  '-thread[number of threads]:n:' \
  '-cache[cache directory]:dir:_files -/' \
  '-pdb[3D structure mode]' \
  '-blast[blast for related sequences]:val:' \
  '-runname[output base name]:name:' \
  '*::t-coffee options:_files' && ret=0
return ret
