#compdef age-plugin-tkey
# Documentation: https://github.com/quite/age-plugin-tkey
# age plugin for keeping keys with a Tillitis TKey USB security key

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--generate[generate a new identity]' \
  '--output[write generated identity to file]:output file:_files' \
  '--no-touch[generate identity that does not require physical touch]' && ret=0

return ret
