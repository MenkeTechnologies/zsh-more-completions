#compdef yak
# Documentation: https://github.com/lh3/yak
# yak: yet another k-mer analyzer for trio binning and QV evaluation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'yak subcommand' \
      'count[count k-mers]' \
      'recount[count existing k-mers]' \
      'cntasm[collate counts per dataset]' \
      'subtract[subtract k-mer sets]' \
      'isec[intersect k-mer sets]' \
      'print[print k-mers for k<=31]' \
      'qv[evaluate quality values]' \
      'triobin[trio binning]' \
      'trioeval[evaluate phasing accuracy with trio]' \
      'inspect[k-mer hash tables]' \
      'chkerr[check errors]' \
      'sexchr[count sex-chromosome-specific k-mers]' \
      'version[print version number]' && ret=0
    ;;
esac

return ret
