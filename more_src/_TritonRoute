#compdef TritonRoute
# Documentation: https://github.com/The-OpenROAD-Project/TritonRoute
# UCSD detailed router (TritonRoute) with LEF/DEF interface

local ret=1

_arguments -s -S \
  '-lef[LEF file]:lef:_files -g "*.lef"' \
  '-def[DEF file]:def:_files -g "*.def"' \
  '-guide[route guide file]:guide:_files' \
  '-output[output DEF file]:output:_files -g "*.def"' \
  '*:file:_files' && ret=0

return ret
