#compdef sdldlz80

# sdldlz80: SDCC Z80 linker
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '*::sdldlz80 args:_files' && ret=0
return ret
