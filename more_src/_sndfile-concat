#compdef sndfile-concat
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-concat.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy sndfile-concat(1) manpage. No flags; usage is
# `sndfile-concat infile1 infile2 ... outfile`. Output format follows
# first input.

local -a arguments

arguments=(
    '*:sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
)

_arguments -s -S $arguments
