#compdef calcurse

# completions for calcurse calendar and todo manager

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-v,--version}'[show version and exit]'
  {-a,--appointment-list}'[print appointments for current day]'
  {-c+,--calendar=}'[specify calendar file]:file:_files'
  {-D+,--directory=}'[specify data directory]:directory:_directories'
  {-d+,--day=}'[print appointments for given date or range]:date'
  {-g,--gc}'[run garbage collector]'
  {-i+,--import=}'[import data from ical file]:file:_files'
  {-x+,--export=}'[export data]:format:(ical pcal)'
  '--export-uid[include UIDs on export]'
  {-l+,--limit=}'[limit number of results]:number'
  {-n,--next}'[print next appointment]'
  {-r+,--range=}'[specify range of days]:range'
  {-s+,--startday=}'[set start day of the week]:day'
  {-S+,--regex=}'[search with regex]:pattern'
  {-t+,--todo=}'[print todo list, filter by priority]:priority'
  '--filter-type=[filter by type]:type:(event apt recur-event recur-apt todo)'
  '--filter-hash=[filter by hash]:hash'
  '--filter-pattern=[filter by pattern]:pattern'
  '--filter-start-from=[start date filter]:date'
  '--filter-start-to=[end date filter]:date'
  '--filter-start-after=[filter after date]:date'
  '--filter-start-before=[filter before date]:date'
  '--filter-start-range=[filter date range]:range'
  '--filter-end-from=[end date from]:date'
  '--filter-end-to=[end date to]:date'
  '--filter-priority=[filter by priority]:priority'
  '--filter-completed[show completed todos]'
  '--filter-uncompleted[show uncompleted todos]'
  '--format-apt=[format for appointments]:format'
  '--format-recur-apt=[format for recurring appointments]:format'
  '--format-event=[format for events]:format'
  '--format-recur-event=[format for recurring events]:format'
  '--format-todo=[format for todos]:format'
  '--read-only[do not save modifications]'
  '--status[show status of running calcurse]'
  '--daemon[run notification daemon in background]'
  '*:file:_files'
)

_arguments -s -S $arguments
