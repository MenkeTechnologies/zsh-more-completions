#compdef nox-cli
# _nox-cli — wntrblm Nox Python testing automation CLI alias (wntrblm / Theacodes, Python); argparse
# upstream: https://github.com/wntrblm/nox

_nox-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--list-sessions[list sessions]' \
        '-l[list sessions]' \
        '--list[list sessions]' \
        '--sessions=+[run sessions]:list:' \
        '-s+[run sessions]:list:' \
        '-e+[run sessions]:list:' \
        '--keywords=+[only sessions with keywords]:str:' \
        '-k+[only sessions with keywords]:str:' \
        '--tags=+[only sessions matching tags]:list:' \
        '-t+[only sessions matching tags]:list:' \
        '--posargs=+[positional args]:str:' \
        '--python=+[python versions]:list:' \
        '-p+[python versions]:list:' \
        '--noxfile=+[noxfile]:file:_files -g "noxfile.py *.py"' \
        '-f+[noxfile]:file:_files -g "noxfile.py *.py"' \
        '--envdir=+[envdir]:dir:_files -/' \
        '--no-stop-on-first-error[no stop on first error]' \
        '--stop-on-first-error[stop on first error]' \
        '--error-on-missing-interpreters[error on missing interpreters]' \
        '--no-error-on-missing-interpreters[no error on missing interpreters]' \
        '--error-on-external-run[error on external run]' \
        '--no-error-on-external-run[no error on external run]' \
        '--report=+[report file]:file:_files' \
        '-r+[report file]:file:_files' \
        '--non-interactive[no input prompts]' \
        '--default-venv-backend=+[default venv backend]:b:(virtualenv venv uv conda mamba micromamba none)' \
        '--force-venv-backend=+[force venv backend]:b:(virtualenv venv uv conda mamba micromamba none)' \
        '--reuse-existing-virtualenvs[reuse venvs]' \
        '-R[reuse venvs]' \
        '--no-reuse-existing-virtualenvs[no reuse venvs]' \
        '--no-install[skip install commands]' \
        '--no-venv[no virtualenv]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--add-timestamp[add timestamps]' \
        '--db[use db]' \
        '--force-color[force color]' \
        '--no-color[no color]' \
        '*:session:'
}

_nox-cli "$@"
