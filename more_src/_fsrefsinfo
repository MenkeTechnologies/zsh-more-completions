#compdef fsrefsinfo
# Documentation: https://github.com/libyal/libfsrefs
# Source: libyal/libfsrefs manuals/fsrefsinfo.1 — display info about a Windows ReFS (Resilient File System) volume.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show allocation information]' \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
