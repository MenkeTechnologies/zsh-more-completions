#compdef mariadb-service-convert
# Documentation: https://man7.org/linux/man-pages/man1/mariadb-service-convert.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# mariadb-service-convert: emit systemd service file based on my.cnf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '*::mariadb-service-convert args:_files' && ret=0
return ret
