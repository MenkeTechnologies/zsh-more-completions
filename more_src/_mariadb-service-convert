#compdef mariadb-service-convert
# Documentation: https://man.archlinux.org/search?q=mariadb-service-convert
# Reference accessed: 2026-05-16

# mariadb-service-convert: emit systemd service file based on my.cnf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '*::mariadb-service-convert args:_files' && ret=0
return ret
