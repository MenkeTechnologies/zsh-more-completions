#compdef openapi-diff
# Documentation: https://github.com/OpenAPITools/openapi-diff
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--html=[export differences as HTML]:file:_files' \
  '--markdown=[export as Markdown]:file:_files' \
  '--asciidoc=[export as AsciiDoc]:file:_files' \
  '--json=[export as JSON]:file:_files' \
  '--text=[export as plain text]:file:_files' \
  '--fail-on-incompatible[exit non-zero on incompatible changes]' \
  '--fail-on-changed[exit non-zero on any API change]' \
  '--state[output only diff state]' \
  '--header=[add custom header for auth]:property=value:' \
  '--query=[add query parameter for auth]:property=value:' \
  '--config-file=[YAML configuration file]:file:_files' \
  '--config-prop=[override behavior via key:value]:key:value:' \
  '(-l --log)'{-l,--log}'=[log level]:level:(TRACE DEBUG INFO WARN ERROR OFF)' \
  '--debug[set log level to DEBUG]' \
  '--info[set log level to INFO]' \
  '--warn[set log level to WARN]' \
  '--error[set log level to ERROR]' \
  '--trace[set log level to TRACE]' \
  '--off[disable logging]' \
  '1:old spec:_files' \
  '2:new spec:_files'
