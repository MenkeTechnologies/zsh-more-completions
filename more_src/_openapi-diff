#compdef openapi-diff

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '(-f --format)'{-f,--format}'=[Output format]:format:(text json yaml markdown html)' \
  '--fail-on-incompatible[Exit non-zero on incompatible changes]' \
  '1:old spec:_files' \
  '2:new spec:_files'
