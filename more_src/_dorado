#compdef dorado
# Documentation: https://github.com/nanoporetech/dorado
# dorado - Oxford Nanopore basecaller

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--reference=[align to reference index during basecalling]:file:_files' \
  '(-x --device)'{-x,--device}'=[GPU/CPU device spec]:device' \
  '--estimate-poly-a[enable poly(A) tail length estimation]' \
  '--resume-from=[continue basecalling from checkpoint]:file:_files' \
  '1:subcommand:(basecaller duplex download aligner summary barcoding correct polish trim demux)' \
  '*::args:_files' && ret=0

return ret
