#compdef maf-convert
# Documentation: https://gitlab.com/mcfrith/last/-/raw/main/doc/maf-convert.rst
# Read alignments in MAF format and write them in another format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a help message and exit]' \
  '(-s --subject)'{-s,--subject=}'[use the Nth sequence in each alignment as the reference/subject]:n:' \
  '(-p --protein)'{-p,--protein}'[specify that the alignments are of proteins, rather than nucleotides]' \
  '(-j --join)'{-j,--join=}'[join alignments that are co-linear, separated by at most N letters]:n:' \
  '(-J --Join)'{-J,--Join=}'[join alignments that are co-linear and nearest in each sequence]:n:' \
  '(-n --noheader)'{-n,--noheader}'[omit any header lines from the output]' \
  '(-d --dictionary)'{-d,--dictionary}'[include a dictionary of sequence lengths in the sam header]' \
  '(-f --dictfile)'{-f,--dictfile=}'[get a sequence dictionary from DICTFILE]:dictfile:_files' \
  '(-r --readgroup)'{-r,--readgroup=}'[specify read group information]:readgroup:' \
  '(-l --linesize)'{-l,--linesize=}'[write CHARS characters per line]:chars:' \
  '1:format:(axt bed blast blasttab blasttab+ chain gff html psl sam tab)' \
  '*:maf file:_files' && ret=0

return ret
