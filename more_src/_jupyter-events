#compdef jupyter-events
# Documentation: https://github.com/jupyter/jupyter_events/blob/main/jupyter_events/cli.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jupyter-events is a click CLI with one subcommand: validate.
# Removed from prior file: fabricated traitlets-style flags
# (--debug, --generate-config, -y, --log-level, --config) that do
# not exist in the click-based jupyter_events CLI.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'validate:Validate a schema against the Jupyter Events meta-schema'
)

_arguments -C \
  '(- *)--version[Show the version and exit]' \
  '(- *)--help[Show help message and exit]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'jupyter-events subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      validate)
        _arguments \
          '--help[Show help message and exit]' \
          '1:schema (JSON/YAML string or file):_files'
        ;;
    esac
    ;;
esac

return ret
