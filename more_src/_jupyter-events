#compdef jupyter-events

local -a arguments

arguments=(
    '--help[Show help message]'
    '--debug[Set debug level for logging]'
    '--generate-config[Generate default config file]'
    '-y[Answer yes to any prompts]'
    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)'
    '--config=[Load this config file]:config file:_files'
)

_arguments -s -S $arguments
