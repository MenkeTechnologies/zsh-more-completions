#compdef pure-ftpd-init
# Documentation: https://man.archlinux.org/search?q=pure-ftpd-init
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start pure-ftpd'
  'stop:stop pure-ftpd'
  'restart:restart pure-ftpd'
  'reload:reload configuration'
  'status:show status'
  'condrestart:restart if running'
  'force-reload:force reload'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pure-ftpd-init command' commands && ret=0 ;;
esac

return ret
