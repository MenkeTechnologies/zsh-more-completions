#compdef dnsreplay
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnsreplay.1.html
# Replay recorded DNS questions and answers to a nameserver and report match rate

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show summary of options]' \
  '--ecs-mask=[mask out first octet of forwarded EDNS IP]:value:' \
  '--ecs-stamp=[add original IP as EDNS Client Subnet option]:flag:(0 1)' \
  '--packet-limit=[stop after replaying NUM packets]:num:' \
  '--pcap-dns-port=[look at packets to/from this PCAP port]:port:_ports' \
  '--quiet=[minimize output verbosity]:flag:(0 1)' \
  '--recursive=[only replay queries with RD flag set]:flag:(0 1)' \
  '--source-from-pcap=[send replayed queries from PCAP source IP/port]:flag:(0 1)' \
  '--source-ip=[send replayed queries from this source IP]:ip:_hosts' \
  '--source-port=[send replayed queries from this source port]:port:_ports' \
  '--speedup=[replay with this speedup factor]:factor:' \
  '--timeout-msec=[wait at least MSEC ms for a reply]:msec:' \
  '1:filename:_files' \
  '2:address:_hosts' \
  '3:port:_ports' && ret=0

return ret
