#compdef gut
# Documentation: https://man.archlinux.org/search?q=gut
# Reference accessed: 2026-05-16

# gut-cli / git-gut — Rust git ergonomics wrapper; verbs mirror `gut --help` (commit, branches, undo, etc.).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'commit:creates commits with helper flows'
  'branch:branch utilities'
  'merge:merge helper'
  'rebase:rebase helper'
  'stash:stash shortcuts'
  'undo:undo last gut operations'
  'sync:pull/push orchestration'
  'hooks:install helper hooks'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'gut' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
