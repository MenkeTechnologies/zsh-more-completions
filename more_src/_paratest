#compdef paratest

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-p --processes)'{-p,--processes}'=[Parallel worker count]:count:' \
  '(-f --functional)'{-f,--functional}'[Only functional tests]' \
  '(-u --unit)'{-u,--unit}'[Only unit tests]' \
  '(-c --configuration)'{-c,--configuration}'=[PHPUnit config path]:file:_files' \
  '(--testsuite)'--testsuite+'[Specific testsuite]:name:' \
  '(--coverage-clover)'--coverage-clover+'[Clover output file]:file:_files' \
  '--colors[color output]' \
  '*:path or filter:_files'
