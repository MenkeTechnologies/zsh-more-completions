#compdef paratest
# Documentation: https://github.com/paratestphp/paratest/blob/7.x/src/Options.php
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --processes)'{-p+,--processes=}'[number of parallel processes]:count:' \
  '--max-processes=[max processes in auto mode]:count:' \
  '(-f --functional)'{-f,--functional}'[enable functional/per-test parallelization]' \
  '(-m --max-batch-size)'{-m+,--max-batch-size=}'[max batch size]:size:' \
  '--no-test-tokens[disable TEST_TOKEN env vars]' \
  '--passthru-php=[args passed to underlying PHP process]:args:' \
  '--runner=[runner implementation]:runner:' \
  '--tmp-dir=[temp directory for ParaTest files]:dir:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--shard=[run shard <current>/<total>]:shard:' \
  '--shard-test-distribution=[distribution strategy]:strategy:' \
  '--shard-test-distribution-seed=[seed for random distribution]:seed:' \
  '--configuration=[PHPUnit config path (forwarded)]:file:_files' \
  '--bootstrap=[PHPUnit bootstrap (forwarded)]:file:_files' \
  '--group=[PHPUnit group (forwarded)]:group:' \
  '--filter=[PHPUnit filter (forwarded)]:filter:' \
  '--coverage-clover=[Clover output file (forwarded)]:file:_files' \
  '--coverage-html=[HTML coverage dir (forwarded)]:dir:_directories' \
  '--coverage-text=[text coverage output (forwarded)]:file:_files' \
  '--colors=[color output (forwarded)]:mode:(never auto always)' \
  '*:path or filter:_files'
