#compdef clickhouse-git-import
# Documentation: https://github.com/ClickHouse/ClickHouse/blob/master/programs/git-import/git-import.cpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# clickhouse-git-import: dump a git repository to TSV files for import to ClickHouse.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--skip-commits-without-parents=[skip commits without parents]:bool:(0 1)' \
  '--skip-commits-with-duplicate-diffs=[skip commits with duplicate diffs]:bool:(0 1)' \
  '--skip-commit=[skip a specific commit (repeatable)]:sha:' \
  '--skip-paths=[regex for paths to skip]:regex:' \
  '--skip-commits-with-messages=[regex for commit messages to skip]:regex:' \
  '--diff-size-limit=[skip diffs over this size]:bytes:' \
  '--stop-after-commit=[stop after this commit hash]:sha:' \
  '--threads=[number of threads]:n:' \
  '*::extra args:_default' && ret=0
return ret
