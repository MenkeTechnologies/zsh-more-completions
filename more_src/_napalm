#compdef napalm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'configure:apply configuration to a device'
  'validate:validate device state'
  'call:call a getter or method on a device'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --user)'{-u,--user=}'[username]:user:_users' \
  '(-p --password)'{-p,--password=}'[password]:password:' \
  '(-v --vendor)'{-v,--vendor=}'[device vendor]:vendor:(eos ios iosxr junos nxos nxos_ssh)' \
  '(-o --optional_args)'{-o,--optional_args=}'[driver optional args]:args:' \
  '--debug[enable debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'napalm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (configure)
        _arguments \
          '--strategy=[merge strategy]:strategy:(replace merge)' \
          '--dry-run[do not commit]' \
          ':hostname:_hosts' \
          ':config:_files' && ret=0
        ;;
      (validate)
        _arguments \
          ':hostname:_hosts' \
          ':validation:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      (call)
        _arguments \
          '--method-kwargs=[method keyword args]:kwargs:' \
          ':hostname:_hosts' \
          ':method:' && ret=0
        ;;
    esac
    ;;
esac

return ret
