#compdef aclgen

# aerleon — `aclgen` uses Abseil flags; users typically rely on --helpfull.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--help[short help]' \
  '--helpfull[list all flags]' \
  '--helpshort[short help]' \
  '--helpxml[XML help]' \
  '*:args:_default' && ret=0

return ret
