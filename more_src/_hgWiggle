#compdef hgWiggle
# UCSC kent: fetch wiggle data from database or file and output as ascii, bed or stats

local ret=1

_arguments -s -S \
  '(-h --help)-help[display more examples and extra options]' \
  '-db=[use specified database]:db' \
  '-chr=[examine data only on chrN]:chr' \
  '-chrom=[same as -chr]:chr' \
  '-position=[examine data in window start-end (1-relative)]:position' \
  '-chromLst=[file with list of chroms to examine]:file:_files' \
  '-doAscii[perform the default ascii output, in addition to other outputs]' \
  '-lift=[lift ascii output positions by D (0 default)]:d' \
  '-rawDataOut[output just the data values, nothing else]' \
  '-htmlOut[output stats or histogram in HTML instead of plain text]' \
  '-doStats[perform stats measurement, default output text]' \
  '-doBed[output bed format]' \
  '-bedFile=[constrain output to ranges specified in bed]:file:_files -g "*.bed"' \
  '-dataConstraint=[comparison operator for data values]:dc' \
  '-ll=[lowerLimit compare data values to F]:f' \
  '-ul=[upperLimit compare data values to F]:f' \
  '*:track name:' && ret=0

return ret
