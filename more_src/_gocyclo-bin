#compdef gocyclo
# _gocyclo-bin — Go cyclomatic complexity analyzer (Stéphane Roucheray, Go); reports functions over threshold
# upstream: https://github.com/fzipp/gocyclo

_gocyclo-bin() {
    _arguments \
        '-over+[threshold]:n:' \
        '-top+[top N functions]:n:' \
        '-avg[show average]' \
        '-avg-short[show average short form]' \
        '-total[show total]' \
        '-total-short[show total short form]' \
        '-ignore+[ignore regex]:regex:' \
        '*:file or dir:_files'
}

_gocyclo-bin "$@"
