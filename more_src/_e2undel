#compdef e2undel
# Documentation: https://man.archlinux.org/search?q=e2undel
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d+[device]:dev:_files' \
  '-s+[save dir]:dir:_files -/' \
  '-a[show all files]' \
  '-l[show user list]' \
  '-t[try file type match]' && ret=0

return ret
