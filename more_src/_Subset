#compdef Subset
# Documentation: https://github.com/senbox-org/snap-engine/blob/master/snap-gpf/src/main/java/org/esa/snap/core/gpf/common/SubsetOp.java
# ESA SNAP gpt Subset operator - create a spatial/spectral subset of a product

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PbandNames=-[the list of source bands]:bands' \
  '-PtiePointGridNames=-[the list of tie-point grid names]:grids' \
  '-Pregion=-[subset region in pixel coords x,y,width,height]:region' \
  '-PreferenceBand=-[band used to indicate the pixel coordinates]:band' \
  '-PgeoRegion=-[subset region in geographical coords (WKT)]:wkt' \
  '-PsubSamplingX=-[pixel sub-sampling step in X]:step' \
  '-PsubSamplingY=-[pixel sub-sampling step in Y]:step' \
  '-PfullSwath=-[extend the subset region to the full swath]:bool:(true false)' \
  '-PvectorFile=-[file from which the polygon is read]:file:_files' \
  '-PpolygonRegion=-[subset region in geographical coords (WKT)]:wkt' \
  '-PcopyMetadata=-[whether to copy the source product metadata]:bool:(true false)' \
  '*:source product:_files' && ret=0

return ret
