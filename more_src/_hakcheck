#compdef hakcheck
# _hakcheck — hakluke hakcheck CLI fast minimal CIDR-range to IP expansion enumeration utility written in Go reading CIDR blocks single IPs or hostname-list on stdin emitting per-host enumeration with concurrent goroutines for pipeline chaining downstream with httpx hakrevdns naabu in bug-bounty recon workflows (hakluke team, Go); pflag
# upstream: https://github.com/hakluke/hakcheck

_hakcheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-r+[retries]:n:' \
        '--retries=+[N]:n:' \
        '*:input file:_files'
}

_hakcheck "$@"
