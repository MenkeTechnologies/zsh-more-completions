#compdef opam-publish
# Documentation: https://github.com/ocaml-opam/opam-publish/blob/master/src/publishMain.ml
# Documentation: https://github.com/ocaml-opam/opam-publish/blob/master/README.md
# Reference accessed: 2026-05-27
# Verified: upstream ocaml-opam/opam-publish master branch src/publishMain.ml cmdliner Term

# opam-publish is a single command (no init/tag/submit subcommands).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-f --force)'{-f,--force}'[overwrite an existing package version]' \
  '--tag=[git tag to publish]:tag:' \
  '-v+[set version of the package]:version:' \
  '(-n --dry-run)'{-n,--dry-run}'[do not actually submit the PR]' \
  '(-o --output-patch)'{-o+,--output-patch=}'[write the patch to a file instead of submitting]:file:_files' \
  '--no-browser[do not open the PR in the browser]' \
  '--repo=[opam repository to submit to (owner/name)]:repo:' \
  '(-b --target-branch)'{-b+,--target-branch=}'[opam repository target branch]:branch:' \
  '--packages-directory=[subdirectory containing packages in the repository]:dir:' \
  '(-t --title)'{-t+,--title=}'[pull-request title]:title:' \
  '--msg-file=[pull-request message file]:file:_files' \
  '--no-confirmation[do not ask for confirmation (non-interactive only)]' \
  '*--exclude=[exclude package(s) from the submission]:package:' \
  '--pre-release[mark submitted packages as pre-release]' \
  '--token=[GitHub access token]:token:' \
  '--version[print version information]' \
  '--help[show help]::format:(auto pager groff plain)' \
  '*:source-or-package:_files' && ret=0

return ret
