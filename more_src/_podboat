#compdef podboat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,-V,--version}'[show version]' \
  '-a[set autodownload]' \
  '-C[set config file]:config file:_files' \
  '-q[set queue file]:queue file:_files' \
  '-l[set log level]:level:(1 2 3 4 5 6)' \
  '-d[set download directory]:directory:_files -/' \
  '-p[set max parallel downloads]:number:' && ret=0

return ret
