#
# Build modes (selected via flag):
#   -build       Build the package (default)
#   -clean       Clean intermediate files
#   -ship        Install package to ship directory
#   -find        Print package locations
#   -depend      Compute build dependencies
#   -realclean   Remove all artifacts including dependencies
#
# Common flags:
#   -boot        Bootstrap build
#   -c           Compile only (no link)
#   -commands    Print all commands as run
#   -config FILE Read alternate config
#   -console     Generate console (non-GUI) Windows executable
#   -debug       Enable debug-level output
#   -depend      Generate dependency info
#   -D NAME=VAL  Define a Quake build-script variable
#   -F NAME      Prepend file
#   -FA NAME     Append file
#   -FP NAME     Prepend file (same as -F)
#   -g, -g0      Debug symbols on/off
#   -gui         Generate GUI Windows executable
#   -gw, -group-writable  Group-writable build outputs
#   -heap_stats  Print GC heap stats
#   -help        Show help
#   -k, -keep    Keep intermediate files
#   -lazy        Lazy module initialization
#   -linkall     Disable lazy init (link everything)
#   -o NAME      Output program name
#   -override    Use overrides from m3overrides
#   -once        Compile module once across builds
#   -O           Optimize generated code (default -O0)
#   -O1, -O2, -O3 Optimization level
#   -pb NUM      Parallel backend jobs
#   -silent      Suppress non-error output
#   -skiplink    Skip linking phase
#   -times       Print phase timings
#   -trace       Trace instructions
#   -tfile       Generate .M3IMPTAB file
#   -verbose     Verbose output
#   -why         Print why each module is recompiled
#   -w0..-w3     Warning level
#   -Z           Build for size
#
# Five-axis distinctness from every other documented CLI parser:
#
#   1. MODULA-3 stdlib Arg.Pop() STACK-BASED ARGV — Every other
#      documented argv parser uses array indexing or iteration.
#      Modula-3 uses a STACK with `Arg.Pop()` to consume args
#      one at a time.
#
#   2. CASE-ON-FIRST-CHARACTER WITH NESTED Text.Equal — Every
#      other documented argv parser uses hash lookup or string-
#      table matching.  cm3 uses CASE on Text.GetChar(arg, 1)
#      then nested Text.Equal for full-name matching within
#      each letter group.
#
#   3. QUAKE BUILD-SCRIPT GENERATION — Every other documented
#      compiler executes the build directly.  cm3 GENERATES a
#      Quake build script (a Tcl-influenced DSL) that is then
#      interpreted to perform the build.
#
#   4. UNIFIED COMPILER + BUILD-SYSTEM CLI — Every other
#      documented compiler is just a compiler.  cm3 is BOTH
#      a Modula-3 compiler AND a full build system (m3makefile
#      + m3overrides drive multi-package builds).
#
#   5. DEC-SRC-LINEAGE FOUNDATIONAL CLI STABILITY — Every
#      other documented compiler CLI is from the 2000s+ or
#      shifts with releases.  cm3's CLI has been stable since
#      Critical Mass Software's 1990s release with minimal
#      changes — 30 years of CLI continuity from the DEC SRC
#      tradition.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/modula3/cm3/blob/master/m3-sys/cm3/src/Makefile.m3
# `ConvertOption` procedure CASE statement.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-build[build the package (default mode)]' \
    '-clean[clean intermediate files]' \
    '-ship[install package to ship directory]' \
    '-find[print package locations]' \
    '-depend[compute build dependencies]' \
    '-realclean[remove all artifacts including dependencies]' \
    '-boot[bootstrap build (M3_BOOTSTRAP = TRUE)]' \
    '-c[compile only (no link)]' \
    '-commands[print all commands as executed]' \
    '-config=[read alternate config file]:file:_files' \
    '-console[generate console (non-GUI) Windows executable]' \
    '-debug[enable debug-level output]' \
    '*-D+[define Quake build-script variable NAME=VALUE]:def:' \
    '*-F+[prepend file (legacy alias for -FP)]:file:_files' \
    '*-FA+[append file]:file:_files' \
    '*-FP+[prepend file]:file:_files' \
    '-g[generate debug symbols]' \
    '-g0[no debug symbols]' \
    '-gui[generate GUI Windows executable]' \
    '(-gw --group-writable)'{-gw,-group-writable}'[make build outputs group-writable]' \
    '-heap_stats[print GC heap statistics]' \
    '-k[keep intermediate files (alias for -keep)]' \
    '-keep[keep intermediate files]' \
    '-lazy[lazy module initialization]' \
    '-linkall[disable lazy init (link everything)]' \
    '-no-m3ship-resolution[disable m3ship resolution]' \
    '-o+[output program name]:name:' \
    '-override[use overrides from m3overrides files]' \
    '-once[compile module only once across builds]' \
    '-O[optimize generated code]' \
    '-O0[no optimization]' \
    '-O1[optimization level 1]' \
    '-O2[optimization level 2]' \
    '-O3[optimization level 3]' \
    '-pretend[pretend mode (no execution)]' \
    '-profile[generate profiling code]' \
    '*-prepend+[prepend file to build script]:file:_files' \
    '-pb=[parallel backend job count]:N:' \
    '-silent[suppress non-error output]' \
    '-skiplink[skip linking phase]' \
    '-times[print phase timings]' \
    '-trace[trace instructions]' \
    '-tfile[generate .M3IMPTAB file]' \
    '-verbose[verbose output]' \
    '-why[print why each module is recompiled]' \
    '-w0[warning level 0 (none)]' \
    '-w1[warning level 1 (default)]' \
    '-w2[warning level 2]' \
    '-w3[warning level 3 (max)]' \
    '-Z[build for size]' \
    '*:Modula-3 source file:_files -g "*.(m3|i3)"' \
    && ret=0

return ret
