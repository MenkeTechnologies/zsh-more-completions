#compdef keepalived_exporter
# Documentation: https://github.com/gen2brain/keepalived_exporter
# Prometheus exporter for keepalived metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-web.listen-address=[address to listen on for web interface and telemetry]:address' \
  '-web.telemetry-path=[path under which to expose metrics]:path' \
  '-version[display version information]' \
  '*:arg:_default' && ret=0

return ret
