#compdef akuity
# Documentation: https://docs.akuity.io/reference/cli/akuity/
# akuity - command line interface for the Akuity Platform

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--insecure-skip-tls-verify[do not check the server certificate for validity]' \
  '--no-color[disable colored output]' \
  '--server=[server url of the Akuity cloud]:url' \
  '1:command:((
    login\:"log in to the Akuity Platform"
    logout\:"log out of the Akuity Platform"
    argocd\:"manage Argo CD instances and clusters"
    kargo\:"manage Kargo instances and agents"
    config\:"manage CLI configuration"
    organization\:"manage organizations"
    whoami\:"show the current authenticated user"
    version\:"show the akuity CLI version"
  ))' \
  '*::arg:->args' && ret=0

return ret
