#compdef vcfremoveaberrantgenotypes
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfremoveaberrantgenotypes.md
# Strip samples whose reported genotype disagrees with observation counts (AO, RO)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
