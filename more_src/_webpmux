#compdef webpmux
# _webpmux — Google WebP webpmux mux/demux WebP files CLI (Google, C); custom argparse
# upstream: https://github.com/webmproject/libwebp

_webpmux() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-get+[get info or chunk]:str:(frame fragment icc xmp exif loop)' \
        '-set+[set chunk]:str:(loop icc xmp exif bgcolor)' \
        '-duration+[set frame duration]:str:' \
        '-strip+[strip chunk]:str:(icc xmp exif)' \
        '-frame+[add frame]:file:_files -g "*.webp"' \
        '-loop+[loop count]:n:' \
        '-bgcolor+[bgcolor A,R,G,B]:str:' \
        '-o+[output file]:file:_files' \
        '-info[show info]' \
        '*:file:_files -g "*.webp"'
}

_webpmux "$@"
