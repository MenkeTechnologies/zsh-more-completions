#compdef devto-cli
# _devto-cli — DEV.to community publish-from-CLI tool alias (forem team, JavaScript); commander
# upstream: https://github.com/forem/dev-to-cli

_devto-cli() {
    local -a sub=(
        'auth:save API key'
        'logout:clear API key'
        'whoami:show current user'
        'articles:list:list your articles'
        'articles:list-published:list published articles'
        'articles:list-unpublished:list drafts'
        'articles:get:get article'
        'articles:create:create article'
        'articles:update:update article'
        'articles:publish:publish draft'
        'articles:unpublish:unpublish article'
        'articles:delete:delete article'
        'articles:from-file:create from markdown file'
        'comments:list:list comments on article'
        'comments:get:get comment'
        'comments:create:create comment'
        'comments:reply:reply to comment'
        'comments:delete:delete comment'
        'comments:update:update comment'
        'reactions:create:create reaction'
        'reactions:remove:remove reaction'
        'tags:list:list tags'
        'tags:followed:list followed tags'
        'tags:popular:list popular tags'
        'users:get:get user'
        'users:get-me:get current user'
        'users:following:list following'
        'users:followers:list followers'
        'organizations:get:get org'
        'organizations:articles:list org articles'
        'organizations:listings:list org listings'
        'organizations:users:list org users'
        'listings:list:list listings'
        'listings:get:get listing'
        'listings:create:create listing'
        'listings:update:update listing'
        'podcast-episodes:list:list podcast episodes'
        'readinglist:list:list reading list'
        'webhooks:list:list webhooks'
        'webhooks:create:create webhook'
        'webhooks:delete:delete webhook'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-key=+[api key]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'devto subcommand' sub ;;
        args)
            case $words[1] in
                articles:from-file|articles:create) _arguments \
                    '1:markdown file:_files -g "*.md"' \
                    '--title=+[title]:str:' \
                    '--description=+[description]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '--canonical-url=+[canonical url]:url:_urls' \
                    '--series=+[series]:str:' \
                    '--published[publish immediately]' \
                    '--main-image=+[image url]:url:_urls' \
                    '--organization-id=+[org id]:n:' ;;
                articles:get|articles:update|articles:publish|articles:unpublish|articles:delete) _arguments \
                    '1:article id:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_devto-cli "$@"
