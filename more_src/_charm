#compdef charm

# Zsh completion for charm (Charm Cloud CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'backup-keys:backup your Charm account keys'
  'completion:generate shell completion'
  'crypt:use Charm encryption'
  'fs:cloud file storage'
  'id:print your Charm ID'
  'import-keys:import Charm account keys'
  'jwt:print a JWT'
  'keys:browse or print linked SSH keys'
  'kv:key-value store'
  'link:link a machine to your Charm account'
  'migrate-account:migrate account to another key'
  'name:username for your account'
  'serve:start a self-hosted Charm Cloud server'
  'where:print the Charm data path'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'charm command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (kv)
        local -a kv_cmds=(
          'delete:delete a key'
          'get:get a value for a key'
          'keys:list keys'
          'list:list key-value pairs'
          'reset:reset the key-value store'
          'set:set a value for a key'
          'sync:sync the key-value store'
        )
        _arguments '1:kv command:->kv_cmd' '*::kv arg:' && ret=0
        if [[ $state == kv_cmd ]]; then
          _describe -t commands 'kv command' kv_cmds && ret=0
        fi
        ;;
      (fs)
        local -a fs_cmds=(
          'cat:output the content of a file'
          'cp:copy a file'
          'ls:list files'
          'mv:move a file'
          'rm:remove a file'
          'tree:print a file tree'
        )
        _arguments '1:fs command:->fs_cmd' '*::fs arg:' && ret=0
        if [[ $state == fs_cmd ]]; then
          _describe -t commands 'fs command' fs_cmds && ret=0
        fi
        ;;
      (serve)
        _arguments \
          '--http-port[HTTP server port]:port:' \
          '--ssh-port[SSH server port]:port:' \
          '--stats-port[stats server port]:port:' \
          '--health-port[health server port]:port:' \
          '--data-dir[data directory]:dir:_files -/' && ret=0
        ;;
      (name)
        _arguments '1:username:' && ret=0
        ;;
    esac
    ;;
esac

return ret
