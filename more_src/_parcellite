#compdef parcellite

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[daemon mode]' \
  '--daemon[daemon mode]' \
  '-n[no icon mode]' \
  '--no-icon[no icon mode]' \
  '-c[print clipboard contents]' \
  '--clipboard[print clipboard contents]' \
  '-p[print primary selection contents]' \
  '--primary[print primary selection contents]' && return 0
