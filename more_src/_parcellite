#compdef parcellite
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/parcellite.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)--help[show help options]' \
  '(-n --no-icon)'{-n,--no-icon}'[do not use status icon]' \
  '(-c --clipboard)'{-c,--clipboard}'[print clipboard contents]' \
  '(-p --primary)'{-p,--primary}'[print primary selection contents]' \
  '*::text:' && return 0
