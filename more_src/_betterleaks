#compdef betterleaks
# Documentation: https://man.archlinux.org/search?q=betterleaks
# Reference accessed: 2026-05-16

# Zsh completion for betterleaks
# Upstream: Secrets scanner built for configurability and speed
# Conservative fallback — run `betterleaks --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
