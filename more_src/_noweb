#compdef noweb notangle noweave cpif noindex sl2h htmltoc nountangle nuweb
# Documentation: https://man.archlinux.org/search?q=noweb
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (notangle)
    _arguments -C \
      '-R+[root chunk]:chunk:' \
      '-L+[line directive format]:fmt:' \
      '-t+[tab stops]:n:' \
      '-filter+[filter]:filter:' \
      '-markup+[markup syntax]:m:' \
      '*: :_files -g "*.nw *.noweb"' && ret=0 ;;
  (noweave)
    _arguments -C \
      '-autodefs+[autodefs lang]:lang:(c c++ awk f77 f90 icon icn java lisp ml ocaml pascal perl python ruby scheme tcl tex)' \
      '-delay[delay structural elements]' \
      '-filter+[filter]:filter:' \
      '-html[HTML output]' \
      '-index[generate index]' \
      '-latex[LaTeX output]' \
      '-latex+[LaTeX options]:opts:' \
      '-n[no LaTeX wrapper]' \
      '-noindex[no index]' \
      '-x[cross-references]' \
      '-t+[tab stops]:n:' \
      '*: :_files -g "*.nw *.noweb"' && ret=0 ;;
  (cpif)
    _arguments -C \
      '*: :_files' && ret=0 ;;
  (htmltoc|sl2h)
    _arguments '*: :_files -g "*.html *.htm"' && ret=0 ;;
  (nountangle)
    _arguments -C \
      '-R+[root chunk]:chunk:' \
      '*: :_files -g "*.nw"' && ret=0 ;;
  (noindex)
    _arguments '*: :_files' && ret=0 ;;
  (noweb)
    _arguments -C \
      '-l+[language]:lang:' \
      '-o+[output file]:file:_files' \
      '-t+[tab stops]:n:' \
      '*: :_files -g "*.nw *.noweb"' && ret=0 ;;
  (nuweb)
    _arguments -C \
      '-c[verify code only]' \
      '-d[create dot file]' \
      '-l[force listing]' \
      '-n[no listing]' \
      '-o[overwrite]' \
      '-p+[output dir]:dir:_files -/' \
      '-r[no comparison]' \
      '-s[silent mode]' \
      '-t+[tab stop]:n:' \
      '-v[verbose]' \
      '*: :_files -g "*.w *.nuweb"' && ret=0 ;;
esac

return ret
