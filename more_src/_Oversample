#compdef Oversample
# Documentation: https://step.esa.int/main/wp-content/help/versions/10.0.0/snap-toolboxes/eu.esa.microwavetbx.sar.op.utilities.ui/operators/OverSampleOp.html
# ESA SNAP gpt Oversample operator - upsample image via frequency domain zero-padding

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PoutputImageBy=[method for determining upsampled image dimension]:method' \
  '-PoutputImageRows=[row size of the upsampled image]:rows' \
  '-PoutputImageColumns=[column size of the upsampled image]:columns' \
  '-PusePRFTileSize=[tile size in processing is PRF by image width]:flag:(true false)' \
  '-PwidthRatio=[ratio of upsampled to source image width]:ratio' \
  '-PheightRatio=[ratio of upsampled to source image height]:ratio' \
  '-PrangeSpacing=[range pixel spacing of the upsampled image]:spacing' \
  '-PazimuthSpacing=[azimuth pixel spacing of the upsampled image]:spacing' \
  '*:graph xml:_files' && ret=0

return ret
