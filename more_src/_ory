#compdef ory

# Zsh completion for Ory CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quiet[be quiet with output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:manage authentication'
      'create:create Ory resources'
      'delete:delete Ory resources'
      'get:get Ory resources'
      'import:import Ory resources'
      'introspect:introspect tokens'
      'is:check identity status'
      'list:list Ory resources'
      'lint:lint Ory config files'
      'open:open Ory pages in browser'
      'parse:parse data'
      'patch:patch Ory resources'
      'perform:perform OAuth2 flows'
      'proxy:run local development proxy'
      'revoke:revoke tokens'
      'tunnel:run development tunnel'
      'update:update Ory resources'
      'use:set active project'
      'validate:validate config'
      'version:show version'
    )
    _describe -t commands 'ory command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(login logout)' && ret=0
        ;;
      create|delete|get|list|update|import|patch)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--project=[project ID or slug]:project' \
          '--format=[output format]:format:(json yaml default)' \
          '1:resource:(project identity oauth2-client relationships event-stream)' && ret=0
        ;;
      proxy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--project=[project ID or slug]:project' \
          '--port=[port to listen on]:port' \
          '--open[open browser]' \
          '--no-jwt[disable JWT session]' \
          '--default-redirect-url=[default redirect URL]:url' \
          '1:upstream URL' && ret=0
        ;;
      tunnel)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--project=[project ID or slug]:project' \
          '--port=[port to listen on]:port' \
          '--dev[enable development mode]' \
          '1:application URL' && ret=0
        ;;
      use)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(project)' && ret=0
        ;;
    esac
    ;;
esac

return ret
