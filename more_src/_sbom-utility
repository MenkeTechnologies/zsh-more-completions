#compdef sbom-utility
# Documentation: https://github.com/CycloneDX/sbom-utility
# CycloneDX/SPDX SBOM validate, query, trim, patch and diff utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input-file)'{-i,--input-file}'=[input BOM file (- for stdin)]:file:_files' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '--format=[output format]:format:(txt csv md json)' \
  '--indent=[JSON indent spaces]:spaces:' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '--where=[filter results using regex]:filter:' \
  '--config-schema=[custom schema config file]:file:_files' \
  '--config-license=[custom license policy config file]:file:_files' \
  '1:command:->cmds' \
  '*::arg:_files' && ret=0

case $state in
  cmds)
    _values 'sbom-utility command' \
      'validate[validate BOM against JSON schema]' \
      'trim[remove JSON fields from BOM]' \
      'patch[apply RFC 6902 JSON patches to BOM]' \
      'diff[compare two BOM versions]' \
      'query[extract data using SQL-style syntax]' \
      'component[component subcommands]' \
      'license[license list and policy subcommands]' \
      'resource[list components and services]' \
      'schema[list supported formats and versions]' \
      'vulnerability[list VEX/VDR data]' \
      'completion[generate shell completion script]' \
      'help[show usage information]' && ret=0
    ;;
esac

return ret
