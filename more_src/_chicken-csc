#compdef csc csi chicken chicken-csc chicken-csi

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-c[compile to object file]' \
  '-C+[pass option to cc]:opt:' \
  '-cc+[C compiler]:cc:_command_names' \
  '-cxx+[C++ compiler]:cxx:_command_names' \
  '-debug+[debug flag]:flag:' \
  '-D+[define symbol]:sym:' \
  '-explicit-use[disable implicit unit use]' \
  '-I+[search path]:dir:_files -/' \
  '-J[create extension stub]' \
  '-j+[generate java imports]:lib:' \
  '-k[keep intermediate files]' \
  '-l+[link library]:lib:' \
  '-L+[library path]:dir:_files -/' \
  '-M[no main procedure]' \
  '-o+[output file]:file:_files' \
  '-O+[optimization level]:level:(0 1 2 3 4 5)' \
  '-P[generate platform-independent code]' \
  '-prefix+[add prefix]:prefix:' \
  '-prologue+[file to prepend]:file:_files' \
  '-q[quiet]' \
  '-R+[require extension]:ext:' \
  '-s[shared library]' \
  '-static[fully static link]' \
  '-strip[strip binary]' \
  '-target+[cross-compile target]:target:' \
  '-uses+[uses unit]:unit:' \
  '-v[verbose]' \
  '-w[no warnings]' \
  '-X+[also process expression]:expr:' \
  '-emit-import-library+[import library file]:file:_files' \
  '-feature+[feature]:feature:' \
  '*:file:_files -g "*.{scm,c,o}"' && ret=0

return ret
