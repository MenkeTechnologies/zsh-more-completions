#compdef yb-admin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'get_universe_config:get universe configuration'
  'change_config:change Raft config of a tablet'
  'change_master_config:change master Raft config'
  'list_tablet_servers:list tablet servers in a tablet'
  'list_all_tablet_servers:list all tablet servers'
  'list_all_masters:list all masters'
  'list_tablets:list tablets for table'
  'list_tables:list all tables'
  'list_namespaces:list all namespaces'
  'compact_table:compact a table'
  'flush_table:flush a table'
  'modify_table_placement_info:modify table placement'
  'modify_placement_info:modify cluster placement'
  'add_read_replica_placement_info:add read replicas'
  'modify_read_replica_placement_info:modify read replicas'
  'delete_read_replica_placement_info:delete read replicas'
  'set_preferred_zones:set preferred zones'
  'list_leader_counts:list leader counts'
  'master_leader_stepdown:step down master leader'
  'leader_stepdown:step down tablet leader'
  'dump_masters_state:dump master state'
  'list_tablet_server_log_locations:list TS log locations'
  'list_tablets_for_tablet_server:list TS tablets'
  'set_load_balancer_enabled:enable/disable load balancer'
  'create_database_snapshot:create snapshot of YSQL database'
  'create_keyspace_snapshot:create snapshot of YCQL keyspace'
  'create_snapshot:create table snapshot'
  'list_snapshots:list snapshots'
  'restore_snapshot:restore snapshot'
  'delete_snapshot:delete snapshot'
  'export_snapshot:export snapshot to file'
  'import_snapshot:import snapshot from file'
  'import_snapshot_selective:import selective tables'
  'list_snapshot_restorations:list snapshot restorations'
  'create_snapshot_schedule:create snapshot schedule'
  'list_snapshot_schedules:list snapshot schedules'
  'delete_snapshot_schedule:delete snapshot schedule'
  'edit_snapshot_schedule:edit snapshot schedule'
  'restore_snapshot_schedule:restore from schedule'
  'is_load_balancer_idle:check load balancer status'
  'add_transaction_tablet:add transaction tablet'
  'create_transaction_table:create transaction table'
  'backfill_indexes_for_table:backfill indexes'
  'rotate_universe_key:rotate encryption key'
  'rotate_universe_key_in_memory:rotate key in memory'
  'add_universe_keys_to_all_masters:propagate keys'
  'all_masters_have_universe_key_in_memory:check key state'
  'is_encryption_enabled:check encryption status'
  'enable_encryption_at_rest:enable encryption'
  'disable_encryption_at_rest:disable encryption'
  'create_cdc_stream:create CDC stream'
  'list_cdc_streams:list CDC streams'
  'delete_cdc_stream:delete CDC stream'
  'setup_universe_replication:setup xCluster replication'
  'alter_universe_replication:alter xCluster replication'
  'delete_universe_replication:delete xCluster replication'
  'set_universe_replication_enabled:enable/disable replication'
  'list_universe_replications:list replications'
  'get_replication_status:get replication status'
  'set_xcluster_consistency_level:set consistency level'
  'change_blacklist:add/remove from blacklist'
  'change_leader_blacklist:leader blacklist'
  'get_load_balancer_state:load balancer state'
  'get_is_load_balancer_idle:idle status'
  'ysql_catalog_version:get YSQL catalog version'
  'split_tablet:split a tablet'
  'unsafe_promote_auto_flags:promote auto flags'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--master_addresses=[comma-separated master addresses]:addrs:' \
  '--init_master_addrs=[discovery master address]:addr:' \
  '--timeout_ms=[RPC timeout]:ms:' \
  '--certs_dir_name=[TLS certs directory]:dir:_files -/' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'yb-admin subcommand' subcommands && ret=0
    ;;
esac

return ret
