#compdef kickstart

# Zsh completion for kickstart (project scaffolding tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --ssh-identity)'{-s,--ssh-identity}'[SSH identity for git clone]:identity file:_files' \
  '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_directories' \
  '--no-input[do not prompt for input, use defaults]' \
  '--vcs[version control to initialize]:vcs:(git none)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:template (path or URL):_files' && ret=0

return ret
