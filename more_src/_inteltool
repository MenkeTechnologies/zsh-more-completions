#compdef inteltool
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/inteltool/inteltool.c
# coreboot Intel chipset register dump tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-g --gpios)'{-g,--gpios}'[dump southbridge GPIO registers]' \
  '(-G --gpio-diffs)'{-G,--gpio-diffs}'[show GPIO differences from defaults]' \
  '(-m --mchbar)'{-m,--mchbar}'[dump northbridge memory controller registers]' \
  '(-r --rcba)'{-r,--rcba}'[dump southbridge RCBA registers]' \
  '(-p --pmbase)'{-p,--pmbase}'[dump southbridge power management registers]' \
  '(-l --lpc)'{-l,--lpc}'[dump southbridge LPC/eSPI interface registers]' \
  '(-e --epbar)'{-e,--epbar}'[dump northbridge EPBAR registers]' \
  '(-d --dmibar)'{-d,--dmibar}'[dump northbridge DMIBAR registers]' \
  '(-P --pciexpress)'{-P,--pciexpress}'[dump northbridge PCIEXBAR registers]' \
  '(-M --msrs)'{-M,--msrs}'[dump CPU MSRs]' \
  '--cpu-range[set CPU cores range for -M]:range:' \
  '(-A --ambs)'{-A,--ambs}'[dump AMB registers]' \
  '(-s --spi)'{-s,--spi}'[dump southbridge SPI and bios_cntrl registers]' \
  '(-S --spd)'{-S,--spd}'[create a file storing current timings]' \
  '(-a --all)'{-a,--all}'[dump all known safe registers]' \
  '(-f --gfx)'{-f,--gfx}'[dump graphics registers (unsafe)]' \
  '(-R --ahci)'{-R,--ahci}'[dump AHCI registers]' \
  '(-x --sgx)'{-x,--sgx}'[dump SGX status]' \
  '(-t --tme)'{-t,--tme}'[dump TME status]' \
  '(-k --keylocker)'{-k,--keylocker}'[dump Key Locker status]' \
  '--pcr[dump all registers of a PCR port]:port:' && ret=0

return ret
