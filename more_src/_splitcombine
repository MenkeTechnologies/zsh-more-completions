#compdef splitcombine
# Documentation: https://bio3d.colorado.edu/imod/doc/man/splitcombine.html
# Produce command files for running volcombine in parallel

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-comfile -c -CommandFile)'{-comfile,-c,-CommandFile}'[Volcombine command file (default volcombine.com). If this]:file:_files' \
  '(-local -l -LocalTempPath)'{-local,-l,-LocalTempPath}'[The path to the master temporary directory that was placed...]:file:_files' \
  '(-global -g -GlobalTempPath)'{-global,-g,-GlobalTempPath}'[The path by which all machines can access the master...]:file:_files' \
  '(-tempdir -t -TemporaryDirectory)'{-tempdir,-t,-TemporaryDirectory}'[Local directory for temporary files other than sum*.rec,...]:file:_files' \
  '-StandardInput[read parameters from standard input]' \
  '-Usage[print usage]' \
  '*:file:_files' && ret=0

return ret
