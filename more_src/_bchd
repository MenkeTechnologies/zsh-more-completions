#compdef bchd
# _bchd — Bitcoin Cash bchd alternative Go-based full-node implementation of Bitcoin Cash CLI maintaining the blockchain validating CashAddr CashScript transactions network sync RPC API memory pool wallet (gcash team, Go); flag
# upstream: https://github.com/gcash/bchd

_bchd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-C+[config file]:file:_files -g "*.conf bchd.conf"' \
        '--configfile=+[config file]:file:_files -g "*.conf bchd.conf"' \
        '-d+[data dir]:dir:_files -/' \
        '--datadir=+[data dir]:dir:_files -/' \
        '--logdir=+[log dir]:dir:_files -/' \
        '--testnet[use testnet]' \
        '--testnet4[use testnet4]' \
        '--simnet[use simnet]' \
        '--regtest[use regtest]' \
        '--addrindex[address index]' \
        '--txindex[transaction index]' \
        '--cpuprofile=+[file]:file:_files' \
        '--memprofile=+[file]:file:_files' \
        '--debuglevel=+[level]:l:(error warn info debug trace)' \
        '--listen=+[host:port]:str:' \
        '--externalip=+[ip]:str:' \
        '--addpeer=+[host:port]:str:' \
        '--connect=+[host:port]:str:' \
        '--nodnsseed[no DNS seed]' \
        '--maxpeers=+[N]:n:' \
        '--banduration=+[d]:str:' \
        '--banthreshold=+[N]:n:' \
        '--whitelist=+[csv]:str:' \
        '--rpcuser=+[user]:str:' \
        '--rpcpass=+[password]:str:' \
        '--rpclimituser=+[user]:str:' \
        '--rpclimitpass=+[password]:str:' \
        '--rpccert=+[file]:file:_files -g "*.cert *.pem"' \
        '--rpckey=+[file]:file:_files -g "*.key *.pem"' \
        '--rpclisten=+[host:port]:str:' \
        '--grpclisten=+[host:port]:str:' \
        '--norpc[disable RPC server]' \
        '--norest[disable REST]' \
        '--maxorphantx=+[N]:n:' \
        '--blockmaxsize=+[bytes]:n:' \
        '--blockmaxweight=+[bytes]:n:' \
        '--blockminsize=+[bytes]:n:' \
        '--blockprioritysize=+[bytes]:n:' \
        '--miningaddr=+[addr]:str:' \
        '--blocknotify=+[command]:str:' \
        '--generate[enable CPU mining]' \
        '--proxy=+[host:port]:str:' \
        '--proxyuser=+[user]:str:' \
        '--proxypass=+[password]:str:' \
        '--onion=+[host:port]:str:' \
        '--tor[use Tor]' \
        '--noonion[no onion]' \
        '--upnp[use UPnP]' \
        '--minrelaytxfee=+[BCH/kB]:f:' \
        '--limitfreerelay=+[KB/min]:n:' \
        '--norelaypriority[no relay priority]' \
        '--allowoldforks[allow old forks]' \
        '--slpindex[enable SLP index]'
}

_bchd "$@"
