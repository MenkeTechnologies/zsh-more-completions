#compdef bigBedInfo bigWigInfo
# _bigBedInfo — UCSC Kent Lab bigBedInfo and bigWigInfo show header info for indexed bigBed bigWig binary file (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigBed.html

_bigBedInfo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '-chroms[show chromosomes]' \
        '-zooms[show zoom levels]' \
        '-extraIndex[show extra indexes]' \
        '-as[show autoSql]' \
        '*:bigBed file:_files -g "*.bb *.bigbed *.bw *.bigwig"'
}

_bigBedInfo "$@"
