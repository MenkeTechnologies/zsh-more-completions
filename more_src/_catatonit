#compdef catatonit
# _catatonit — minimal container init / PID 1 reaper (openSUSE/catatonit)
# upstream: https://github.com/openSUSE/catatonit
# Flags from catatonit.c getopt_long longopts on tip.

_catatonit() {
    _arguments \
        '-g[forward signals to pid1 process group]' \
        '-h[show help]' \
        '-L[print license information]' \
        '-P[pause mode: run nothing, quit on SIGINT]' \
        '(-V --version)'{-V,--version}'[print version information]' \
        '*:program and args:_command_names -e'
}

_catatonit "$@"
