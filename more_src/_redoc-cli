#compdef redoc-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build definition into HTML file'
  'bundle:bundle spec into HTML file'
  'serve:serve rendered spec'
)

_arguments -C \
  '(-t --template)'{-t,--template=}'[handlebars page template]:file:_files' \
  '*--templateOptions=[template option]:opt:' \
  '*--options=[ReDoc option]:opt:' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'redoc-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (build|bundle)
        _arguments \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' \
          '--title=[page title]:title:' \
          '--disableGoogleFont[disable Google Font]' \
          '--cdn[use CDN]' \
          ':spec:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
      (serve)
        _arguments \
          '--title=[page title]:title:' \
          '(-s --ssr)'{-s,--ssr}'[server-side rendering]' \
          '(-h --host)'{-h,--host=}'[host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[port]:port:' \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '--disable-google-font[disable Google Font]' \
          ':spec:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
