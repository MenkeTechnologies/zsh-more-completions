#compdef FuncotateSegments
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037224992-FuncotateSegments-BETA
# Functional annotation for copy-number segment files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-O --output)'{-O,--output}'=[output file]:output:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '--segments=[input segment file (tab-separated, must have a call column)]:file:_files' \
  '--alias-to-key-mapping=[mapping between an alias and backend key values]:mapping:' \
  '--ref-version=[reference version (hg19, hg38)]:version:(hg19 hg38)' \
  '*--data-sources-path=[path to a data source folder]:dir:_files -/' \
  '--output-file-format=[output file format]:format:(VCF MAF SEG)' \
  '--transcript-selection-mode=[transcript selection mode]:mode:(BEST_EFFECT CANONICAL ALL)' \
  '--transcript-list=[file of transcript IDs to use]:file:_files' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:file:_files' && ret=0

return ret
