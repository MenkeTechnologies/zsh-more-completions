#compdef botkube
# Documentation: https://docs.botkube.io/cli/commands/botkube_install/
# botkube - CLI to install and manage the Botkube agent

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--atomic[roll back changes if install/upgrade fails]' \
  '(-y --auto-approve)'{-y,--auto-approve}'[skip interactive approval for upgrades]' \
  '--chart-name=[Helm chart name]:name' \
  '--dependency-update[update missing dependencies before chart installation]' \
  '--description=[custom description]:desc' \
  '--disable-openapi-validation[skip validation against the Kubernetes OpenAPI schema]' \
  '--dry-run[simulate installation without applying changes]' \
  '--force[force resource updates via replacement strategy]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--kubecontext=[kubeconfig context to use]:context' \
  '--namespace=[installation namespace]:namespace' \
  '--no-hooks[disable pre/post install/upgrade hooks]' \
  '--release-name=[Helm release name]:name' \
  '--render-subchart-notes[include subchart notes in output]' \
  '--repo=[chart repository URL or local path]:repo' \
  '--reset-values[reset to the chart built-in values during upgrade]' \
  '--reuse-values[merge previous release values with command-line overrides]' \
  '*--set=[set values on the command line]:value' \
  '*--set-file=[set values from files]:file:_files' \
  '*--set-json=[set JSON values on the command line]:json' \
  '*--set-literal=[set literal string values]:value' \
  '*--set-string=[set string values on the command line]:value' \
  '--skip-crds[skip CRD installation]' \
  '--timeout=[maximum installation monitoring duration]:duration' \
  '(-f --values)'{-f,--values}'=[specify values via YAML file or URL]:file:_files' \
  '--version=[Botkube version to install]:version' \
  '(-w --watch)'{-w,--watch}'[monitor installation status until completion]' \
  '1:command:((
    install\:"install or upgrade the Botkube agent"
    uninstall\:"uninstall the Botkube agent"
    migrate\:"migrate the installation to Botkube Cloud"
    config\:"manage Botkube configuration"
    telemetry\:"manage telemetry settings"
    version\:"show the Botkube CLI version"
  ))' \
  '*::arg:->args' && ret=0

return ret
