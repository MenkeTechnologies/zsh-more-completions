#compdef terraform-mcp-server

# https://formulae.brew.sh/formula/terraform-mcp-server
local curcontext="$curcontext" state line ret=1

local -a _tfmcp_server_cmds
_tfmcp_server_cmds=(
  'stdio:run JSON-RPC MCP server on stdio'
  'streamable-http:run StreamableHTTP MCP server'
  'http:deprecated alias for streamable-http'
)

_arguments -C -s -S \
  '--log-file[path to log file]:file:_files' \
  '--log-level[log level]:level:(trace debug info warn error fatal panic)' \
  '--log-format[log format]:format:(text json)' \
  '--toolsets[enabled toolsets (comma-separated)]:toolsets' \
  '--tools[specific tools (comma-separated); mutually exclusive with non-default toolsets]:tools' \
  '::command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'terraform-mcp-server command' _tfmcp_server_cmds && ret=0
    ;;
  args)
    case $line[1] in
      stdio)
        _message -e arguments 'stdio server uses persistent flags only'
        ret=0
        ;;
      streamable-http|http)
        _arguments -s -S \
          '--transport-host[bind host]:host' \
          '(-p --transport-port)'{-p,--transport-port}'[listen port]:port' \
          '--heartbeat-interval[HTTP heartbeat interval (e.g. 30s)]:interval' \
          '--mcp-endpoint[HTTP path for MCP endpoint]:path' \
          && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
