#compdef virt-sanlock-cleanup
# Documentation: https://man.archlinux.org/search?q=virt-sanlock-cleanup
# Reference accessed: 2026-05-16

# virt-sanlock-cleanup: cleanup orphaned sanlock resource leases
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::virt-sanlock-cleanup args:_files' && ret=0
return ret
