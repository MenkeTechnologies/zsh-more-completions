#compdef trivy-db
# _trivy-db — Aqua Security trivy vulnerability database builder (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy-db

_trivy-db() {
    local -a sub=(
        'build:build vulnerability database'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--update-interval=+[update interval]:dur:' \
        '--only-update=+[only update sources]:list:' \
        '--no-color[no color]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trivy-db subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--cache-dir=+[cache dir]:dir:_files -/' \
                    '--output-dir=+[output dir]:dir:_files -/' \
                    '--update-interval=+[update interval]:dur:' \
                    '--only-update=+[only update sources]:list:' ;;
            esac
            ;;
    esac
}

_trivy-db "$@"
