#compdef cargo-clone

# Zsh completion for cargo-clone (JanLikar/cargo-clone): Clone crates.io sources.
# Standalone binary wraps the same Clap tree as `cargo clone`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color=[terminal coloring]:when:(auto always never)' \
  '(-q --quiet)'{-q,--quiet}'[less output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--registry=[registry name from Cargo config]:registry' \
  '--index=[registry index URL]:url' \
  '--local-registry=[local registry path]:path:_directories' \
  '--git[clone from repository in package metadata]' \
  '*:crate spec (name[@version]):' \
  '::directory:_directories'
