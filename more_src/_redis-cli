#compdef redis-cli
# Documentation: https://redis.io/docs/latest/develop/connect/cli/
# Source: redis/redis src/redis-cli.c — official Redis client CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[server hostname (default 127.0.0.1)]:host:_hosts' \
    '-p[server port (default 6379)]:port:' \
    '-s[server UNIX socket]:socket:_files' \
    '-a[server password]:password:' \
    '-u[server URI]:uri:' \
    '-r[execute command N times]:repeat:' \
    '-i[interval seconds between -r repeats]:seconds:' \
    '-n[DB number]:db:' \
    '-x[read last argument from stdin]' \
    '-c[cluster mode (follow MOVED/ASK redirects)]' \
    '-t[server-side timeout (seconds)]:seconds:' \
    '-d[delimiter between command args (CSV mode)]:delim:' \
    '-D[delimiter between responses (CSV mode)]:delim:' \
    '-e[exit on connection error]' \
    '--no-auth-warning[do not show auth-passed-on-CLI warning]' \
    '--user=[ACL username]:user:' \
    '--pass=[ACL password]:password:' \
    '--askpass[prompt for password]' \
    '--no-raw[force raw-output disable]' \
    '--quoted-input[force quoted-input mode]' \
    '--csv[CSV output]' \
    '--json[JSON output (RESP3)]' \
    '--quoted-json[quoted JSON output]' \
    '--show-pushes=[show out-of-band pushes (yes/no)]:flag:(yes no)' \
    '--stat[continuous server-stats panel]' \
    '--latency[continuous latency monitoring]' \
    '--latency-history[latency every -i seconds with reset]' \
    '--latency-dist[latency distribution (spectrum)]' \
    '--lru-test=[LRU sim with N keys]:keys:' \
    '--replica[simulate REPLICA listening to PSYNC]' \
    '--rdb=[transfer RDB to local file]:file:_files' \
    '--functions-rdb=[transfer functions-only RDB]:file:_files' \
    '--pipe[send raw command stream via PIPE]' \
    '--pipe-timeout=[pipe-mode timeout seconds]:seconds:' \
    '--bigkeys[scan and report biggest keys]' \
    '--memkeys[scan and report memory usage of keys]' \
    '--memkeys-samples=[memkeys sample count]:n:' \
    '--hotkeys[scan and report hottest keys]' \
    '--scan[scan keys (use --pattern to filter)]' \
    '--pattern=[KEYS pattern (with --scan)]:pattern:' \
    '--quoted-pattern=[quoted pattern (with --scan)]:pattern:' \
    '--intrinsic-latency=[run intrinsic latency test for N seconds]:seconds:' \
    '--slowlog[start slow-log monitor]' \
    '--cluster[cluster sub-mode]:subcommand:(create check call info reshard rebalance fix add-node del-node import backup help)' \
    '--cluster-replicas=[replicas-per-master for create/add-node]:n:' \
    '--tls[use TLS]' \
    '--sni=[TLS Server Name Indication]:host:_hosts' \
    '--cacert=[TLS CA cert]:file:_files' \
    '--cacertdir=[TLS CA cert directory]:dir:_directories' \
    '--insecure[do not verify server cert]' \
    '--cert=[client cert]:file:_files' \
    '--key=[client key]:file:_files' \
    '--tls-ciphers=[TLS ciphers]:list:' \
    '--tls-ciphersuites=[TLSv1.3 ciphersuites]:list:' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*:command:' \
    && ret=0

return ret
