#compdef podofonooc
# Documentation: https://github.com/podofo/podofo/blob/master/tools/podofonooc/podofonooc.cpp
# podofonooc - remove optional content (layers) from a PDF document

local ret=1

_arguments -s -S \
  '1:input PDF file:_files -g "*.pdf"' \
  '2:output PDF file:_files -g "*.pdf"' \
  '*:optional content name:' && ret=0

return ret
