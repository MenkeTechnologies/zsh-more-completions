#compdef RNALfold
# Documentation: https://man.archlinux.org/search?q=RNALfold
# Reference accessed: 2026-05-16

# ViennaRNA RNALfold: compute locally stable secondary structures of long RNAs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-L --span)'{-L,--span=}'[maximum base pair span (window size)]:span:' \
  '(-T --temp)'{-T,--temp=}'[folding temperature in C]:temp:' \
  '(-z --zscore)'{-z,--zscore}'[compute z-scores]:thresh:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-G --gquad)'{-G,--gquad}'[allow G-quadruplexes]' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '--paramFile=[parameter file]:file:_files' \
  '--auto-id[auto-generate sequence IDs]' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
