#compdef applytopup
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/diffusion/topup/applytopup/index.html
# applytopup - apply topup-estimated field to unwarp images

local ret=1

_arguments -s -S \
  '--imain=[comma-separated list of input image files]:files:_files' \
  '--datain=[acquisition parameters text file]:file:_files' \
  '--inindex=[comma-separated indices into datain for imain files]:indices:' \
  '--topup=[topup output basename]:basename:_files' \
  '--out=[output basename]:basename:_files' \
  '--method=[resampling method (jac/lsr)]:method:(jac lsr)' \
  '--interp=[interpolation for jac method (trilinear/spline)]:interp:(trilinear spline)' \
  '--datatype=[output data type (char/short/int/float/double)]:type:(char short int float double)' \
  '--verbose[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
