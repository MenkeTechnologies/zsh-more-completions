#compdef liquidwar
# Documentation: https://www.gnu.org/software/liquidwar/
# Reference accessed: 2026-05-16

# Liquid War 5: 2D real-time fluid combat
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--fullscreen[start fullscreen]' \
  '--windowed[start windowed]' \
  '--width=[window width]:n:' \
  '--height=[window height]:n:' \
  '--no-sound[disable sound]' \
  '--debug[debug mode]' \
  '*::liquidwar args:_files' && ret=0
return ret
