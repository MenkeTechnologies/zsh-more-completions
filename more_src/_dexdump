#compdef dexdump dexlist
# Documentation: https://man.archlinux.org/search?q=dexdump
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (dexdump)
    _arguments -C \
      '-a[print annotations]' \
      '-c[verify checksum]' \
      '-d[disassemble code]' \
      '-e[external/extended info]' \
      '-f[show file header]' \
      '-h[show file headers only]' \
      '-i[ignore checksum failures]' \
      '-l+[output layout]:l:(plain xml)' \
      '-m[disassembly with mnemonic]' \
      '-n[disassembly canonical]' \
      '-o+[output file]:file:_files' \
      '-t+[temp file]:file:_files' \
      '*: :_files -g "*.dex *.apk"' && ret=0 ;;
  (dexlist)
    _arguments -C \
      '-h[help]' \
      '-m[show methods]' \
      '*: :_files -g "*.dex *.apk"' && ret=0 ;;
esac

return ret
