#compdef krak2
# Documentation: https://github.com/Storyyeller/Krakatau
# Krakatau v2 Java bytecode assembler/disassembler

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --out)'{-o,--out}'[output location (dir, .jar, .zip, .j, .class)]:out:_files' \
  '(-r --roundtrip)'{-r,--roundtrip}'[produce bitwise-identical reassembly output]' \
  '1:command:(dis asm decompile)' \
  '*:file:_files' && ret=0

return ret
