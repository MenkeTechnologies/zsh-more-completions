#compdef loco

local curcontext="$curcontext" state line ret=1

_loco_commands() {
  local -a commands=(
    'new:create a new Loco app'
    'start:start the application'
    'generate:generate application components'
    'g:generate application components (alias)'
    'db:database commands'
    'routes:list application routes'
    'middleware:list application middleware'
    'task:run a task'
    'scheduler:run the scheduler'
    'doctor:check application health'
    'version:display version information'
  )
  _describe -t commands 'loco command' commands
}

_loco_generate_commands() {
  local -a commands=(
    'model:generate a model'
    'migration:generate a migration'
    'scaffold:generate a scaffold'
    'controller:generate a controller'
    'task:generate a task'
    'scheduler:generate a scheduler'
    'worker:generate a worker'
    'mailer:generate a mailer'
    'deployment:generate deployment configuration'
  )
  _describe -t commands 'generate subcommand' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-e --environment)'{-e,--environment}'[specify environment]:environment' \
  '1:command:_loco_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      start)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --environment)'{-e,--environment}'[specify environment]:environment' \
          '(-b --binding)'{-b,--binding}'[server binding address]:address' \
          '(-p --port)'{-p,--port}'[server port]:port' \
          '--server-and-worker[start both server and worker]' \
          '--no-banner[do not display the banner]' && ret=0
        ;;
      generate|g)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --environment)'{-e,--environment}'[specify environment]:environment' \
          '1:subcommand:_loco_generate_commands' \
          '*::arg:->generate_args' && ret=0
        case $state in
          generate_args)
            _arguments -s -S \
              '(-h --help)'{-h,--help}'[show help]' \
              '*:name' && ret=0
            ;;
        esac
        ;;
      db)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --environment)'{-e,--environment}'[specify environment]:environment' \
          '*:subcommand' && ret=0
        ;;
      task)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --environment)'{-e,--environment}'[specify environment]:environment' \
          '*:task name' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:app name' && ret=0
        ;;
      routes|middleware|doctor|version|scheduler)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-e --environment)'{-e,--environment}'[specify environment]:environment' && ret=0
        ;;
    esac
    ;;
esac

return ret
