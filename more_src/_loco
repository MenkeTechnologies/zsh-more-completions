#compdef loco
# Documentation: https://loco.rs/docs/the-app/your-project/
# Reference accessed: 2026-06-01
# Verified: upstream src/cli.rs at github.com/loco-rs/loco

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-e --environment)'{-e+,--environment=}'[specify environment]:environment' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'start:start the app (alias: s)'
      's:start the app'
      'db:perform DB operations'
      'routes:describe all application endpoints'
      'middleware:describe all application middlewares'
      'task:run a custom task (alias: t)'
      't:run a custom task'
      'jobs:manage jobs queue'
      'scheduler:run the scheduler'
      'generate:code generation (alias: g)'
      'g:code generation'
      'doctor:validate and diagnose configurations'
      'version:display the app version'
      'watch:watch and restart the app (alias: w)'
      'w:watch and restart the app'
    )
    _describe -t commands 'loco command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      start|s)
        _arguments \
          '(-w --worker)'{-w+,--worker=}'[start worker; optional comma list of tags]:tags' \
          '(-s --server-and-worker)'{-s,--server-and-worker}'[start server and worker in same process]' \
          '(-a --all)'{-a,--all}'[start server, worker, and scheduler in same process]' \
          '(-b --binding)'{-b+,--binding=}'[server bind address]:address' \
          '(-p --port)'{-p+,--port=}'[server port]:port' \
          '(-n --no-banner)'{-n,--no-banner}'[disable the banner display]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      db)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '1: :->db_cmd' \
          '*::arg:->db_args' && ret=0
        case $state in
          db_cmd)
            local -a db_cmds=(
              'create:create the database'
              'migrate:run pending migrations'
              'down:reverse migrations'
              'reset:drop, create, and migrate'
              'status:show migration status'
              'entities:generate entities from the database'
              'truncate:truncate all tables'
              'seed:seed data into the database'
              'schema:display database schema'
            )
            _describe -t commands 'db command' db_cmds && ret=0
            ;;
        esac
        ;;
      routes)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      middleware)
        _arguments \
          '(-c --config)'{-c,--config}'[print middleware configurations]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      task|t)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1::task name' \
          '*:params (key:value)' && ret=0
        ;;
      jobs)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '1: :->jobs_cmd' \
          '*::arg:' && ret=0
        case $state in
          jobs_cmd)
            local -a jobs_cmds=(
              'cancel:cancel a job by ID'
              'tidy:cleanup completed jobs'
              'purge:purge all jobs'
              'dump:dump jobs to a file'
              'import:import jobs from a file'
              'requeue:requeue failed jobs'
            )
            _describe -t commands 'jobs command' jobs_cmds && ret=0
            ;;
        esac
        ;;
      scheduler)
        _arguments \
          '(-n --name)'{-n+,--name=}'[run a specific job by name]:name' \
          '(-t --tag)'{-t+,--tag=}'[run jobs with a specific tag]:tag' \
          '(-c --config)'{-c+,--config=}'[scheduler config file]:file:_files' \
          '(-l --list)'{-l,--list}'[show all configured jobs]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      generate|g)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '1: :->gen_cmd' \
          '*::arg:' && ret=0
        case $state in
          gen_cmd)
            local -a gen_cmds=(
              'model:generate a model'
              'migration:generate a migration'
              'scaffold:generate a scaffold'
              'controller:generate a controller'
              'task:generate a task'
              'scheduler:generate a scheduler'
              'worker:generate a worker'
              'mailer:generate a mailer'
              'data:generate seed data'
              'deployment:generate deployment configuration'
              'override:override generated template'
            )
            _describe -t commands 'generate component' gen_cmds && ret=0
            ;;
        esac
        ;;
      doctor)
        _arguments \
          '(-c --config)'{-c,--config}'[print current configurations]' \
          '(-p --production)'{-p,--production}'[run production checks]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      watch|w)
        _arguments \
          '(-w --worker)'{-w+,--worker=}'[start worker; optional comma list of tags]:tags' \
          '(-s --server-and-worker)'{-s,--server-and-worker}'[start server and worker in same process]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      version)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
