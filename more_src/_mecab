#compdef mecab

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-r+,--rcfile=}'[resource file]:file:_files' \
  {-d+,--dicdir=}'[system dictionary directory]:dir:_files -/' \
  {-u+,--userdic=}'[user dictionary file]:file:_files' \
  {-l+,--lattice-level=}'[lattice info level (deprecated)]:level:' \
  {-D,--dictionary-info}'[show dictionary information and exit]' \
  {-O+,--output-format-type=}'[output format type]:type:(wakati none yomi chasen chasen2 simple)' \
  {-a,--all-morphs}'[output all morphs]' \
  {-N+,--nbest=}'[output N best results]:n:' \
  {-p,--partial}'[partial parsing mode]' \
  {-m,--marginal}'[output marginal probability]' \
  {-M+,--max-grouping-size=}'[max grouping size for unknown words]:n:' \
  {-F+,--node-format=}'[user-defined node format]:fmt:' \
  {-U+,--unk-format=}'[user-defined unknown node format]:fmt:' \
  {-B+,--bos-format=}'[beginning-of-sentence format]:fmt:' \
  {-E+,--eos-format=}'[end-of-sentence format]:fmt:' \
  {-S+,--eon-format=}'[end-of-NBest format]:fmt:' \
  {-x+,--unk-feature=}'[feature for unknown word]:feat:' \
  {-b+,--input-buffer-size=}'[input buffer size]:size:' \
  {-P,--dump-config}'[dump MeCab parameters]' \
  {-C,--allocate-sentence}'[allocate new memory for input sentence]' \
  {-t+,--theta=}'[temperature parameter theta]:theta:' \
  {-c+,--cost-factor=}'[cost factor]:cost:' \
  {-o+,--output=}'[output file]:file:_files' \
  '*:input file:_files' && ret=0

return ret
