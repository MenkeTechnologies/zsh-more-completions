#compdef rubocop-cli
# _rubocop-cli — Bozhidar Batsov rubocop Ruby static code analyzer/formatter CLI alias (rubocop team, Ruby); custom argparse
# upstream: https://github.com/rubocop/rubocop

_rubocop-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose-version[verbose version]' \
        '-V[verbose version]' \
        '--list-target-files[list files to be inspected]' \
        '-L[list files to be inspected]' \
        '--auto-correct[autocorrect]' \
        '-a[autocorrect]' \
        '--autocorrect[autocorrect]' \
        '--auto-correct-all[autocorrect all incl unsafe]' \
        '-A[autocorrect all]' \
        '--autocorrect-all[autocorrect all]' \
        '--safe-auto-correct[safe autocorrect]' \
        '--safe-autocorrect[safe autocorrect]' \
        '--disable-uncorrectable[insert disable comments]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--format=+[formatter]:f:(progress simple clang fuendoc emacs files html json junit markdown offenses pacman quiet tap worst)' \
        '-f+[formatter]:f:(progress simple clang fuendoc emacs files html json junit markdown offenses pacman quiet tap worst)' \
        '--out=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--display-cop-names[show cop name]' \
        '-D[show cop name]' \
        '--extra-details[show extra details]' \
        '-E[show extra details]' \
        '--display-style-guide[show style guide URL]' \
        '-S[show style guide URL]' \
        '--display-time[show inspection time]' \
        '--display-only-failed[only show failures]' \
        '--display-only-fail-level-offenses[only show fail-level offenses]' \
        '--display-only-correctable[only correctable]' \
        '--display-only-safe-correctable[only safe correctable]' \
        '--show-cops=+[show config for cops csv]:str:' \
        '--show-docs-url[show docs url]' \
        '--except=+[except cops csv]:str:' \
        '--only=+[only cops csv]:str:' \
        '--only-guide-cops[only style guide cops]' \
        '--lint[lint cops only]' \
        '-l[lint cops only]' \
        '--config=+[config file]:file:_files -g ".rubocop.{yml,yaml}"' \
        '-c+[config file]:file:_files -g ".rubocop.{yml,yaml}"' \
        '--force-default-config[force default config]' \
        '--force-exclusion[force exclusion]' \
        '--only-recognized-file-types[only recognized file types]' \
        '--ignore-parent-exclusion[ignore parent exclusion]' \
        '--ignore-unrecognized-cops[ignore unrecognized cops]' \
        '--ignore-disable-comments[ignore disable comments]' \
        '--stdin=+[filename]:file:_files' \
        '--stderr[output to stderr]' \
        '--require=+[ruby file to require]:file:_files -g "*.rb"' \
        '-r+[ruby file to require]:file:_files -g "*.rb"' \
        '--cache=+[cache]:c:(true false)' \
        '-C+[cache]:c:(true false)' \
        '--cache-root=+[cache dir]:dir:_files -/' \
        '--no-parallel[no parallel]' \
        '--parallel[parallel]' \
        '-P[parallel]' \
        '--fail-fast[fail fast]' \
        '--fail-level=+[level]:l:(info refactor convention warning error fatal autocorrect A)' \
        '--no-fail-fast[disable fail fast]' \
        '--server[start server]' \
        '--no-server[disable server]' \
        '--restart-server[restart server]' \
        '--stop-server[stop server]' \
        '--server-status[server status]' \
        '--exit-code-on-failure[exit non-zero on warnings]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--auto-gen-config[generate config exclusions]' \
        '--no-auto-gen-config[disable auto-gen-config]' \
        '--regenerate-todo[regenerate todo]' \
        '--exclude-limit=+[limit]:n:' \
        '--auto-gen-only-exclude[generate only exclude entries]' \
        '--no-exclude-limit[no exclude limit]' \
        '--list-cops[list cops]' \
        '-l[list cops]' \
        '--no-offense-counts[skip offense counts]' \
        '--no-auto-gen-timestamp[skip timestamp]' \
        '--init[init config]' \
        '*:files or dirs:_files'
}

_rubocop-cli "$@"
