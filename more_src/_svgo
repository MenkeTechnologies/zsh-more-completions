#compdef svgo
# Documentation: https://github.com/svg/svgo/blob/main/lib/svgo/coa.js
# Reference accessed: 2026-05-21
# Verified: upstream commander.js definitions in lib/svgo/coa.js.
# Removed from prior file: fabricated -h/--help flag (svgo does not register one).

# Zsh completion for svgo (SVG Optimizer)

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '*'{-i,--input}'+[input file(s), "-" for STDIN]:input:_files' \
  '(-s --string)'{-s+,--string=}'[input SVG data string]:svg data:' \
  '(-f --folder)'{-f+,--folder=}'[input folder of *.svg]:folder:_files -/' \
  '*'{-o,--output}'+[output file or folder]:output:_files' \
  '(-p --precision)'{-p+,--precision=}'[fractional digits]:integer:' \
  '--config=[custom config file (.js/.mjs/.cjs)]:file:_files' \
  '--datauri=[output as Data URI]:format:(base64 enc unenc)' \
  '--multipass[run multiple optimization passes]' \
  '--pretty[pretty-print SVG output]' \
  '--indent=[indent count for pretty print]:integer:' \
  '--eol=[line break type]:eol:(lf crlf)' \
  '--final-newline[ensure file ends with newline]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into subfolders]' \
  '*--exclude=[exclude file pattern]:pattern:' \
  '(-q --quiet)'{-q,--quiet}'[only error messages]' \
  '--show-plugins[list available plugins]' \
  '--no-color[plain text output]' \
  '*:svg file:_files -g "*.svg"' && return 0
