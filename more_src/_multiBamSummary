#compdef multiBamSummary
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/multiBamSummary.html
# deepTools: compute read coverages for genomic regions across multiple BAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:((bins\:"genome-wide coverage in equal-sized windows" BED-file\:"coverage for regions in a BED file"))' \
  '(-b --bamfiles)'{-b,--bamfiles}'[indexed BAM files]:bam:_files -g "*.bam"' \
  '(-o -out --outFileName)'{-o,-out,--outFileName}'[output .npz file]:file:_files' \
  '--BED[region file (BED format)]:file:_files' \
  '(-l --labels)'{-l,--labels}'[custom sample labels]:labels:' \
  '--smartLabels[auto-generate labels from filenames]' \
  '(-bs --binSize)'{-bs,--binSize}'[window size in bases]:size:' \
  '(-n --distanceBetweenBins)'{-n,--distanceBetweenBins}'[gap between bins]:n:' \
  '(-r --region)'{-r,--region}'[limit to genomic region]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[exclude regions (BED/GTF)]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--genomeChunkSize[processor chunk size]:n:' \
  '--outRawCounts[tab-delimited counts file]:file:_files' \
  '--scalingFactors[DESeq2-style scaling factors file]:file:_files' \
  '(-e --extendReads)'{-e,--extendReads}'[extend reads to fragment length]:length:' \
  '--ignoreDuplicates[skip duplicate reads]' \
  '--minMappingQuality[mapping quality threshold]:qual:' \
  '--centerReads[center reads on fragments]' \
  '--samFlagInclude[include by SAM flag]:flag:' \
  '--samFlagExclude[exclude by SAM flag]:flag:' \
  '--minFragmentLength[minimum fragment length]:length:' \
  '--maxFragmentLength[maximum fragment length]:length:' \
  '--metagene[compute on merged exons]' \
  '--transcriptID[GTF transcript feature name]:id:' \
  '--exonID[GTF exon feature name]:id:' \
  '--transcript_id_designator[identifier key for regions]:key:' && ret=0

return ret
