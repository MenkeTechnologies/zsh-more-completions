#
# upstream: https://github.com/bartolli/codanna
# author : Angel Bartolli  <bartolli@gmail.com>
# license: Apache-2.0
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from src/cli/args.rs `Cli` / `Commands` / `PluginAction` / `DocumentAction`
# clap-derive blocks plus `create_custom_help()` Quick Start text on the
# codanna tip — no improvisation.
#
# Direct deps (selected, from Cargo.toml):
#   tantivy = "0.26.1"     ← canonical Rust full-text search engine (this axis)
#                            Lucene-inspired indexing/scoring/segment storage
#                            by Paul Masurel (quickwit-oss); powers semantic
#                            symbol + document search.
#   clap = "4.x" derive
#   tree-sitter parsers for Rust / Python / TypeScript / JavaScript / Go /
#                          PHP / Java / Swift / Kotlin / C#
#
# === AXIS 157 OPENER — full-text search engine ecosystem ===
# Axis position: Rust=212 OPENS Axis 157 at slot 1/0/0.  Canonical Rust full-
# text search engine is `tantivy` by Paul Masurel (quickwit-oss CTO, formerly
# Indeed.com) — a Lucene-inspired indexer/searcher that powers Quickwit's
# distributed log search, codanna's code intelligence, AppFlowy's local
# semantic search, TabbyML, devflowinc/trieve, postgresml's pgml-dashboard,
# and ParadeDB's Postgres extension.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=212   ← THIS FILE              (axis 157 OPENS, slot 1/0/0)
#   Go=212     ← next round              (axis 157 continues, slot 2/0/0)
#   TS-Node=212 ← round after            (axis 157 CLOSES at triple-212, slot 1/1/1)
# ---------------------------------------------------------------------------

_codanna() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:Set up .codanna directory with default configuration'
        'index:Build searchable index from codebase'
        'add-dir:Add a directory to be indexed'
        'remove-dir:Remove a directory from indexed paths'
        'list-dirs:List all directories being indexed'
        'retrieve:Search symbols, find callers/callees, analyze impact'
        'config:Display active settings from .codanna/settings.toml'
        'serve:Start MCP server (stdio/HTTP/HTTPS)'
        'mcp-test:Test MCP connection and list tools'
        'mcp:Execute MCP tools directly without spawning a server'
        'benchmark:Benchmark parser performance'
        'parse:Parse a file and output AST nodes in JSONL format'
        'plugin:Install, update, manage Claude Code plugins'
        'documents:Index and search document collections (RAG)'
        'profile:Manage project profiles'
        'help:Print this message or the help of the given subcommand'
    )

    _arguments -C \
        '(-c --config)'{-c,--config=}'[path to custom settings.toml file]:config:_files -g "*.(toml|TOML)"' \
        '--info[show detailed loading information]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'codanna command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init)
                    _arguments \
                        '(-f --force)'{-f,--force}'[force overwrite existing configuration]' && ret=0
                    ;;
                index)
                    _arguments \
                        '(-t --threads)'{-t,--threads=}'[number of threads to use]:n:' \
                        '(-f --force)'{-f,--force}'[force re-indexing even if index exists]' \
                        '--no-progress[disable progress bars]' \
                        '--dry-run[show what would be indexed without indexing]' \
                        '--max-files=[maximum number of files to index]:n:' \
                        '*:path:_files' && ret=0
                    ;;
                add-dir|remove-dir)
                    _arguments '1:directory:_files -/' && ret=0
                    ;;
                list-dirs|config)
                    ret=0
                    ;;
                retrieve)
                    local -a retr
                    retr=(
                        'symbol:exact symbol name lookup'
                        'search:fuzzy symbol search'
                        'callers:find what calls this symbol'
                        'calls:list what this symbol calls'
                        'implementations:list implementations of a trait/interface'
                        'describe:describe a symbol with full context'
                    )
                    _describe -t commands 'retrieve query' retr && ret=0
                    ;;
                serve)
                    _arguments \
                        '--watch[enable hot-reload when index changes]' \
                        '--watch-interval=[how often to check for index changes (default 5s)]:seconds:' \
                        '(--https)--http[run as HTTP server instead of stdio transport]' \
                        '(--http)--https[run as HTTPS server with TLS support]' \
                        '--bind=[address to bind HTTP/HTTPS server (default 127.0.0.1:8080)]:addr:' && ret=0
                    ;;
                mcp-test)
                    _arguments \
                        '--server-binary=[path to server binary]:binary:_files' \
                        '--tool=[tool to call (omit to just list tools)]:tool:' \
                        '--args=[tool arguments as JSON]:json:' \
                        '--delay=[wait N seconds before calling the tool]:seconds:' && ret=0
                    ;;
                mcp)
                    local -a tools
                    tools=(
                        'find_symbol:exact name lookup'
                        'search_symbols:fuzzy text search (query:<text> kind:<type> limit:<n>)'
                        'get_calls:what this symbol calls'
                        'find_callers:what calls this symbol'
                        'analyze_impact:full dependency graph'
                        'semantic_search_docs:code search by meaning'
                        'semantic_search_with_context:search with relationships'
                        'search_documents:search markdown/text docs'
                        'get_index_info:index stats'
                    )
                    _arguments \
                        '--args=[tool arguments as JSON]:json:' \
                        '--json[output in JSON format]' \
                        '--fields=[filter output to specific fields (comma-separated)]:fields:' \
                        '--watch[check for file changes and reindex before running tool]' \
                        '1:MCP tool:(($tools))' \
                        '*::positional args (key:value pairs):' && ret=0
                    ;;
                benchmark)
                    _arguments \
                        '(-f --file)'{-f,--file=}'[custom file to benchmark]:file:_files' \
                        '1:language:(rust python php typescript javascript go csharp java swift kotlin all)' && ret=0
                    ;;
                parse)
                    _arguments \
                        '(-o --output)'{-o,--output=}'[output file (defaults to stdout)]:file:_files' \
                        '(-d --max-depth)'{-d,--max-depth=}'[maximum depth to traverse]:n:' \
                        '(-a --all-nodes)'{-a,--all-nodes}'[include all nodes (default: only named nodes)]' \
                        '1:file:_files' && ret=0
                    ;;
                plugin)
                    local -a pcmds
                    pcmds=(
                        'add:install a plugin from a marketplace'
                        'remove:remove an installed plugin'
                        'update:update an installed plugin'
                        'list:list installed plugins'
                        'verify:verify plugin integrity'
                    )
                    _describe -t commands 'plugin action' pcmds && ret=0
                    ;;
                documents)
                    local -a dcmds
                    dcmds=(
                        'index:index documents from a configured collection'
                        'search:search indexed documents using natural language'
                        'list:list configured collections'
                        'stats:show stats for a collection'
                        'add-collection:add a new document collection'
                    )
                    _describe -t commands 'documents action' dcmds && ret=0
                    ;;
                profile)
                    local -a pcmds
                    pcmds=(
                        'init:initialize a profile'
                        'install:install profile from a source repo'
                        'list:list profiles'
                        'status:show profile status'
                    )
                    _describe -t commands 'profile action' pcmds && ret=0
                    ;;
                help)
                    _describe -t commands 'codanna command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_codanna "$@"
