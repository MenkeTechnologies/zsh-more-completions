#compdef mq
# Documentation: https://man.archlinux.org/search?q=mq
# Reference accessed: 2026-05-16

# https://mqlang.org — markdown query language (`mq` runner + `mq-lsp`)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1:query string:' \
  '*:markdown files:_files -g "*.md"'
