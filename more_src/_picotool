#compdef picotool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version information]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'info:display information from a RP2040 device or UF2/ELF file'
      'load:load data onto a RP2040 device'
      'save:save data from a RP2040 device'
      'verify:verify data on a RP2040 device'
      'reboot:reboot a RP2040 device'
      'version:display picotool version'
      'help:show help for a command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (info)
        _arguments \
          '-a[show all information]' \
          '(-b --bus)'{-b,--bus}'=[USB bus number]:bus:' \
          '(-d --address)'{-d,--address}'=[USB device address]:address:' \
          '(-f --force)'{-f,--force}'[force operation]' \
          '-p[show build attributes (pins)]' \
          '-l[show basic information]' \
          '--all[show all information]' \
          '*:file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (load)
        _arguments \
          '(-v --verify)'{-v,--verify}'[verify after loading]' \
          '(-x --execute)'{-x,--execute}'[execute after loading]' \
          '(-n --no-overwrite)'{-n,--no-overwrite}'[do not overwrite existing flash contents]' \
          '(-N --no-overwrite-unsafe)'{-N,--no-overwrite-unsafe}'[do not overwrite bootrom]' \
          '(-u --update)'{-u,--update}'[skip write if contents match]' \
          '(-o --offset)'{-o,--offset}'=[load at offset]:offset:' \
          '(-b --bus)'{-b,--bus}'=[USB bus number]:bus:' \
          '(-d --address)'{-d,--address}'=[USB device address]:address:' \
          '(-f --force)'{-f,--force}'[force operation]' \
          '1:firmware file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (save)
        _arguments \
          '-p[save program only]' \
          '--all[save all flash contents]' \
          '--range=[save address range]:start end:' \
          '(-b --bus)'{-b,--bus}'=[USB bus number]:bus:' \
          '(-d --address)'{-d,--address}'=[USB device address]:address:' \
          '(-f --force)'{-f,--force}'[force operation]' \
          '1:output file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (verify)
        _arguments \
          '(-b --bus)'{-b,--bus}'=[USB bus number]:bus:' \
          '(-d --address)'{-d,--address}'=[USB device address]:address:' \
          '(-f --force)'{-f,--force}'[force operation]' \
          '(-o --offset)'{-o,--offset}'=[verify at offset]:offset:' \
          '--range=[verify address range]:start end:' \
          '1:firmware file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (reboot)
        _arguments \
          '(-a --application)'{-a,--application}'[reboot into application]' \
          '(-u --usb)'{-u,--usb}'[reboot into BOOTSEL mode]' \
          '(-b --bus)'{-b,--bus}'=[USB bus number]:bus:' \
          '(-d --address)'{-d,--address}'=[USB device address]:address:' \
          '(-f --force)'{-f,--force}'[force operation]' && ret=0
        ;;
    esac
    ;;
esac

return ret
