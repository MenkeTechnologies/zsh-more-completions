#compdef terraform-docs
# Documentation: https://github.com/terraform-docs/terraform-docs (cmd/root.go cobra rootCmd)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'asciidoc:generate AsciiDoc output'
  'completion:generate shell completions'
  'json:generate JSON output'
  'markdown:generate Markdown output'
  'pretty:generate colorized pretty output'
  'tfvars:generate terraform.tfvars output'
  'toml:generate TOML output'
  'xml:generate XML output'
  'yaml:generate YAML output'
  'version:show version'
  'help:show help for a subcommand'
)

local -a _common_flags
_common_flags=(
  '(-c --config)'{-c,--config=}'[config file name]:file:_files'
  '--recursive[update submodules recursively]'
  '--recursive-path=[submodules path to recursively update]:path:_directories'
  '--recursive-include-main[include the main module]'
  '*--recursive-exclude=[exclude directories from recursive update]:dir:_directories'
  '*--show=[show section]:section:(header footer inputs modules outputs providers requirements resources data-sources all)'
  '*--hide=[hide section]:section:(header footer inputs modules outputs providers requirements resources data-sources all)'
  '--output-file=[file path to insert output into]:file:_files'
  '--output-mode=[output to file method]:mode:(inject replace)'
  '--output-template=[output template]:tmpl:'
  '--output-check[check if output file is up to date]'
  '--sort[sort items]'
  '--sort-by=[sort items by criteria]:criteria:(name required type)'
  '--header-from=[relative path of header file]:file:_files'
  '--footer-from=[relative path of footer file]:file:_files'
  '--lockfile[read .terraform.lock.hcl if it exists]'
  '--output-values[inject output values into outputs]'
  '--output-values-from=[inject output values from file]:file:_files'
  '--read-comments[use comments as description when description is empty]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --version)'{-v,--version}'[show version]'
)

_arguments -C \
  $_common_flags \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'terraform-docs subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      asciidoc|markdown|pretty|tfvars|toml|json|xml|yaml)
        _arguments \
          $_common_flags \
          '*:module directory:_directories' && ret=0
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
