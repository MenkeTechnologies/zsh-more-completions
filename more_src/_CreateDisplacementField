#compdef CreateDisplacementField
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CreateDisplacementField.cxx — stack scalar components into a displacement-field image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:EnforceZeroBoundaryFlag:(0 1)' \
    '*:component image(s) then OutputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    && ret=0

return ret
