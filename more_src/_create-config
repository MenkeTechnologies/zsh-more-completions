#compdef create-config
# Documentation: https://github.com/eslint/create-config
# Reference accessed: 2026-05-23
# Verified: upstream README (@eslint/create-config npm package).

# Zsh completion for create-config - scaffold ESLint flat config files

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[shareable config package on npm]:package:' \
  '--eslintrc[use eslintrc-style legacy shared config]' \
  '*::args:' && ret=0

return ret
