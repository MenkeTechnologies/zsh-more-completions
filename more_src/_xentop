#compdef xentop
# Documentation: https://man.archlinux.org/search?q=xentop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --delay)'{-d,--delay}'+[delay between updates seconds]:sec:' \
  '(-n --networks)'{-n,--networks}'[show network info]' \
  '(-x --vbds)'{-x,--vbds}'[show VBD info]' \
  '(-r --repeat-header)'{-r,--repeat-header}'[repeat header each line]' \
  '(-v --vcpus)'{-v,--vcpus}'[show VCPU info]' \
  '(-b --batch)'{-b,--batch}'[batch (non-curses) output]' \
  '(-i --iterations)'{-i,--iterations}'+[number of iterations]:n:' \
  '(-f --full-name)'{-f,--full-name}'[show full domain names]' && ret=0

return ret
