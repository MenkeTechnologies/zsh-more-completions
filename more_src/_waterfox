#compdef waterfox waterfox-bin
# Documentation: https://wiki.mozilla.org/Firefox/CommandLineOptions
# Reference accessed: 2026-05-17
# Verified: Mozilla wiki Firefox CommandLineOptions (Waterfox inherits
# the Firefox CLI surface).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --screenshot/--window-size (these are headless mode flags
# but using `headless` subcommand syntax, not bare).

# waterfox: Firefox-based browser
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-P[launch named profile]:profile:' \
  '-profile[start with profile at path]:path:_files -/' \
  '-ProfileManager[open profile manager]' \
  '-CreateProfile[create new profile]:name:' \
  '-allow-downgrade[allow downgrade]' \
  '-migration[run migration wizard]' \
  '-new-instance[allow multiple instances]' \
  '-no-remote[disable remote connections]' \
  '-override[override INI]:file:_files' \
  '-browser[open browser window]' \
  '-foreground[bring to foreground]' \
  '-wait-for-browser[wait for browser to start]' \
  '-headless[run headless]' \
  '-new-tab[URL in new tab]:url:' \
  '-new-window[URL in new window]:url:' \
  '--kiosk[kiosk URL]:url:' \
  '-preferences[open preferences]' \
  '-private[private browsing]' \
  '-private-window[private window]:url:' \
  '-safe-mode[safe mode]' \
  '-search[search term]:term:' \
  '-setDefaultBrowser[set as default browser]' \
  '-url[open URL]:url:' \
  '-devtools[open dev tools]' \
  '-inspector[open inspector]:url:' \
  '-jsdebugger[open JS debugger]' \
  '-jsconsole[open JS console]' \
  '-purgecaches[purge caches]' \
  '-start-debugger-server[debugger port]:port:' \
  '*:url or file:_files' && ret=0
return ret
