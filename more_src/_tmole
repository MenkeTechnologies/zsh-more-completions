#compdef tmole tunnelmole
# _tmole — Tunnelmole local tunnel client (robbie-cahill/tunnelmole-client)
# upstream: https://github.com/robbie-cahill/tunnelmole-client
# Flags from bin/tunnelmole.ts (commander).

_tmole() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '--set-api-key=[set the Tunnelmole API key for the current account]:apiKey:'
        '--unreserve-subdomain=[release a reserved subdomain]:subdomain:'
        '1:local port:'
        '2:as:(as)'
        '3:subdomain.tunnelmole.net:'
    )
    _arguments -s $args
}

_tmole "$@"
