#compdef esl-ssdraw
# Easel: create postscript secondary structure diagrams

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-d[draw default alignment summary diagrams]' \
  '-f[with --indi, force creation even if predicted size exceeds 100 Mb]' \
  '--mask=[read mask from file and draw positions differently]:file:_files' \
  '--small[memory-saving mode; requires Pfam Stockholm format]' \
  '--rf[add page showing reference sequence from #=GC RF]' \
  '--info[add page colored by information content]' \
  '--mutinfo[add page coloring basepaired positions by mutual information]' \
  '--ifreq[add page showing fraction of sequences with insertions]' \
  '--iavglen[add page showing average insertion length]' \
  '--dall[add page showing fraction of sequences with gaps]' \
  '--dint[add page showing fraction of internal gaps]' \
  '--prob[add page colored by average posterior probability]' \
  '--span[add page colored by fraction of spanning sequences]' \
  '--indi[add pages displaying aligned nucleotides per sequence]' \
  '--no-leg[omit legend from all pages]' \
  '--no-head[omit header from all pages]' \
  '--no-foot[omit footer from all pages]' \
  '--mask-col[display mask as black/pink squares in single-page diagram]' \
  '--mask-diff=[compare two masks with color-coded overlap]:file:_files' \
  '--no-pp[do not draw posterior probability diagrams with --indi]' \
  '--no-bp[do not color basepaired nucleotides by type]' \
  '--no-ol[do not outline nucleotides differing from consensus]' \
  '--no-ntpp[do not draw nucleotides on individual PP diagrams]' \
  '--no-cnt[do not draw consensus nucleotides on statistics]' \
  '--cthresh=[capitalization threshold for consensus nucleotides]:x' \
  '--cambig[use least ambiguous IUPAC codes for consensus]' \
  '--athresh=[threshold for IUPAC consensus calculation]:x' \
  '--mask-u[masked column style as squares]' \
  '--mask-x[masked column style as x'\''s]' \
  '--mask-a[alternative style of square or x masks]' \
  '--dfile=[read draw file specifying numerical values]:file:_files' \
  '--efile=[read expert draw file specifying colors and nucleotides]:file:_files' \
  '--ifile=[read insert information from file]:file:_files' \
  '--tabfile=[create tab-delimited per-position statistics file]:file:_files' \
  '*:alignment file:_files' && ret=0

return ret
