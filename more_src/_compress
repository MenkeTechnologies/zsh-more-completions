#compdef compress
# Documentation: https://man.archlinux.org/search?q=compress
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c[write to stdout]' \
  '-f[force overwrite]' \
  '-v[verbose]' \
  '-b+[max bits per code (9..16)]:bits:' \
  '*:file:_files' && ret=0

return ret
