#compdef compress
# Documentation: https://man.archlinux.org/man/compress.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c[write output to stdout, do not modify files]' \
  '-f[force overwrite of output files]' \
  '-k[keep input files instead of removing them]' \
  '-r[operate recursively on directories]' \
  '-v[display percentage of reduction for each file]' \
  '-V[print version and patchlevel to stderr]' \
  '-b+[max bits per code (9-16, default 16)]:bits:' \
  '*:file:_files' && ret=0

return ret
