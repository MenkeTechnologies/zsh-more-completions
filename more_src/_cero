#compdef cero
# Documentation: https://man.archlinux.org/search?q=cero
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[concurrency level]:concurrency:'
  '-d[timeout in seconds]:seconds:'
  '-p[port to connect to]:port:'
  '-t[number of seconds before timeout]:seconds:'
  '-v[verbose output]'
  '*:host:'
)

_arguments -s -S $arguments
