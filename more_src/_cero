#compdef cero
# Documentation: https://github.com/glebarez/cero
# Reference accessed: 2026-05-17
# Verified: upstream README at the URL above.

# cero: scrape domain names from TLS certificates of remote hosts
local -a arguments
arguments=(
  '-c+[concurrency level (default 100)]:concurrency:'
  '-d[output only valid domain names (strip IPs, wildcards, gibberish)]'
  '-p+[TLS ports (comma-separated, default 443)]:ports:'
  '-t+[TLS connection timeout seconds (default 4)]:seconds:'
  '-v[verbose: addr -- [results], errors to stderr]'
  '*:host:'
)
_arguments -s -S $arguments
