#compdef imhol
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imhol.html
# MIRIAD imhol - compute amplitude and phase from holography images

local ret=1

_arguments -s -S \
  'in=[real and imaginary holographic images]:in:_files' \
  'mag=[output intensity image and optional error image]:mag:_files' \
  'phase=[output position angle image and optional error image]:phase:_files' \
  'sigma=[mean standard deviation of the noise in the images]:sigma' \
  'sncut=[signal-to-noise ratio threshold for blanking]:sncut' \
  'pacut=[phase error threshold for blanking]:pacut' \
  'options=[bias removal, output units and error handling choices]:options' \
  '*:image:_files' && ret=0

return ret
