#compdef vig_optimize
# Documentation: https://www.systutorials.com/docs/linux/man/1-vig_optimize/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '-v[verbose]' \
  '-p+[number of CP per image pair]:n:' \
  '-r[radial]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
