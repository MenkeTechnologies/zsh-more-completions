#compdef AverageImages
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/AverageImages.cxx — average a list of NIfTI images (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3)' \
    '2:Outputfname.nii.gz:_files -g "*.{nii,nii.gz}"' \
    '3:Normalize:(0 1 2)' \
    '*:input images:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
