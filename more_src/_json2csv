#compdef json2csv

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-i --input)'{-i,--input}'=[input JSON file]:input file:_files -g "*.json"' \
  '(-o --output)'{-o,--output}'=[output CSV file]:output file:_files -g "*.csv"' \
  '(-f --fields)'{-f,--fields}'=[fields to include]:fields' \
  '(-c --fields-config)'{-c,--fields-config}'=[fields config file]:config file:_files -g "*.json"' \
  '(-u --unwind)'{-u,--unwind}'=[field to unwind/flatten]:field' \
  '--unwind-blank[blank out repeated fields when unwinding]' \
  '(-v --default-value)'{-v,--default-value}'=[default value for missing fields]:value' \
  '(-q --quote)'{-q,--quote}'=[quote character]:char' \
  '(-Q --double-quote)'{-Q,--double-quote}'[escape quotes with double quotes]' \
  '(-d --delimiter)'{-d,--delimiter}'=[field delimiter]:delimiter' \
  '(-e --eol)'{-e,--eol}'=[end of line character]:eol' \
  '(-E --excel-strings)'{-E,--excel-strings}'[wrap strings for Excel]' \
  '(-H --no-header)'{-H,--no-header}'[do not include header row]' \
  '--include-empty-rows[include empty rows]' \
  '--flatten-objects[flatten nested objects]' \
  '--flatten-arrays[flatten arrays]' \
  '--flatten-separator=[separator for flattened keys]:separator' \
  '(-n --ndjson)'{-n,--ndjson}'[treat input as newline-delimited JSON]' \
  '(-s --no-streaming)'{-s,--no-streaming}'[disable streaming mode]' \
  '(-p --pretty)'{-p,--pretty}'[prettify output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
