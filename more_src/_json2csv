#compdef json2csv
# Documentation: https://github.com/juanjoDiaz/json2csv/blob/main/docs/parsers/cli.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (@json2csv/cli --help output).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-i --input)'{-i,--input}'=[path to incoming JSON file (default stdin)]:input file:_files -g "*.json"' \
  '(-o --output)'{-o,--output}'=[path to resulting CSV file (default stdout)]:output file:_files -g "*.csv"' \
  '(-c --config)'{-c,--config}'=[file with a valid JSON configuration]:config file:_files -g "*.json"' \
  '(-n --ndjson)'{-n,--ndjson}'[treat the input as NewLine-Delimited JSON]' \
  '(-s --no-streaming)'{-s,--no-streaming}'[process whole JSON array in memory]' \
  '(-f --fields)'{-f,--fields}'=[list of fields to process]:fields:' \
  '(-v --default-value)'{-v,--default-value}'=[default value for missing fields]:value:' \
  '(-q --quote)'{-q,--quote}'=[character(s) to use as quote mark]:char:' \
  '(-Q --escaped-quote)'{-Q,--escaped-quote}'=[character(s) to use as an escaped quote]:char:' \
  '(-d --delimiter)'{-d,--delimiter}'=[character(s) to use as delimiter]:delimiter:' \
  '(-e --eol)'{-e,--eol}'=[character(s) to use as End-of-Line]:eol:' \
  '(-E --excel-strings)'{-E,--excel-strings}'[wrap strings to force Excel to interpret as string]' \
  '(-H --no-header)'{-H,--no-header}'[disable the column name header]' \
  '(-a --include-empty-rows)'{-a,--include-empty-rows}'[include empty rows in the resulting CSV]' \
  '(-b --with-bom)'{-b,--with-bom}'[include BOM character at the beginning of the CSV]' \
  '(-p --pretty)'{-p,--pretty}'[print output as a pretty table]' \
  '--unwind=[create multiple rows from a single JSON document]:paths:' \
  '--unwind-blank[when unwinding, blank out instead of repeating data]' \
  '--flatten-objects[flatten nested objects]' \
  '--flatten-arrays[flatten nested arrays]' \
  '--flatten-separator=[flattened keys separator]:separator:' \
  '(- *)'{-h,--help}'[output usage information]' && ret=0

return ret
