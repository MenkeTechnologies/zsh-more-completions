#compdef ezno
# _ezno — fast & correct TypeScript type checker / compiler (kaleidawave/ezno)
# upstream: https://github.com/kaleidawave/ezno
# Subcommands from src/cli.rs (lahl Endpoints).

_ezno() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_ezno_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                check)
                    _arguments \
                        '--advanced-numbers[enable more support for number intrinsics]' \
                        '--compact-diagnostics[emit diagnostics in compact form]' \
                        '--timings[print time taken per step]' \
                        '--watch[watch input files and re-check on change]' \
                        '--max-diagnostics=[max diagnostics (number, "all", or "0")]:max:' \
                        '--definition-file=[type definition file to include]:file:_files -g "*.d.ts"' \
                        '1:entrypoint (file or directory):_files' && ret=0 ;;
                build)
                    _arguments \
                        '--advanced-numbers[test for number intrinsics]' \
                        '--tree-shake[enable tree-shaking]' \
                        '--minify[remove whitespace from output]' \
                        '--source-maps[generate source maps]' \
                        '--compact-diagnostics[emit diagnostics in compact form]' \
                        '--timings[print time taken per step]' \
                        '--watch[watch input files and rebuild on change]' \
                        '--max-diagnostics=[max diagnostics (number, "all", or "0")]:max:' \
                        '--definition-file=[type definition file to include]:file:_files -g "*.d.ts"' \
                        '1:entrypoint (file or directory):_files' && ret=0 ;;
                parse|format)
                    _arguments \
                        '1:input file:_files -g "*.(js|ts|jsx|tsx|mjs|cjs)"' && ret=0 ;;
                repl|info|upgrade) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ezno_commands] )) ||
_ezno_commands() {
    local -a commands
    commands=(
        'check:type-check the given entrypoint'
        'build:compile the project (experimental)'
        'repl:start an interactive REPL'
        'info:print information about the ezno binary'
        'parse:parse a file and print the AST (experimental)'
        'format:format source code (experimental)'
        'upgrade:download the latest ezno binary (experimental)'
    )
    _describe -t commands 'ezno command' commands
}

_ezno "$@"
