#compdef mri_robust_register
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_robust_register
# mri_robust_register - robust intensity-based registration of two volumes

local ret=1

_arguments -s -S \
  '--mov[input movable volume to be aligned]:file:_files' \
  '--dst[input target volume]:file:_files' \
  '--lta[output registration transform]:file:_files' \
  '--sat[manually set outlier sensitivity]:sat:' \
  '--satit[automatically detect sensitivity]' \
  '--mapmov[output aligned and resampled image]:file:_files' \
  '--mapmovhdr[output aligned image without resampling]:file:_files' \
  '--weights[output weights/outliers]:file:_files' \
  '--iscale[estimate intensity scale factor]' \
  '--iscaleout[output intensity scale value to file]:file:_files' \
  '--iscalein[input initial intensity scale value]:file:_files' \
  '--transonly[translation-only registration]' \
  '--affine[12-parameter affine transform]' \
  '--ixform[use initial transform]:file:_files' \
  '--initorient[use moments for orientation]' \
  '--noinit[skip transform initialization]' \
  '--vox2vox[output VOX2VOX format]' \
  '--maxit[max iterations per resolution]:n:' \
  '--highit[max iterations at highest resolution]:n:' \
  '--epsit[iteration stopping threshold]:eps:' \
  '--nomulti[disable multiscale processing]' \
  '--wlimit[outlier limit for auto-detection]:limit:' \
  '--subsample[subsample if dimension exceeds value]:n:' \
  '--floattype[convert to float internally]' \
  '--doubleprec[use double precision]' \
  '--maskmov[mask source volume]:file:_files' \
  '--maskdst[mask target volume]:file:_files' \
  '--halfmov[output halfway source volume]:file:_files' \
  '--halfdst[output halfway target volume]:file:_files' \
  '--halfweights[output halfway weights]:file:_files' \
  '--halfmovlta[output source-to-halfway transform]:file:_files' \
  '--halfdstlta[output target-to-halfway transform]:file:_files' \
  '--verbose[verbosity level control]:level:' \
  '--debug[enable debug output]' && ret=0

return ret
