#compdef eodag
# Documentation: https://eodag.readthedocs.io/en/stable/cli_user_guide.html
# Earth Observation Data Access Gateway command-line client

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:command:->cmds' && ret=0

case $state in
  cmds)
    if (( CURRENT == 2 )); then
      _values 'eodag command' \
        'search[search products on a provider]' \
        'download[download search results]' \
        'list[list available collections]' \
        'discover[fetch external product types from a provider]' \
        'deploy-wsgi-app[deploy eodag as a WSGI app]' \
        'serve-rest[start eodag HTTP REST server]' \
        'serve-rpc[start eodag RPC server]' \
        'version[print eodag version]'
    else
      case $words[2] in
        search)
          _arguments -s \
            '(-f --conf)'{-f,--conf}'=[user configuration file]:file:_files' \
            '(-l --locs)'{-l,--locs}'=[locations configuration file]:file:_files' \
            '(-p --provider)'{-p,--provider}'=[search on a specific provider]:provider:' \
            '(-b --box)'{-b,--box}'=[bounding box minlon minlat maxlon maxlat]:box:' \
            '(-g --geom)'{-g,--geom}'=[WKT geometry]:wkt:' \
            '(-s --start)'{-s,--start}'=[start sensing time (ISO8601)]:date:' \
            '(-e --end)'{-e,--end}'=[end sensing time (ISO8601)]:date:' \
            '(-c --collection)'{-c,--collection}'=[collection to search]:collection:' \
            '--instruments=[filter by instruments]:instruments:' \
            '--platform=[filter by platform]:platform:' \
            '--constellation=[filter by constellation]:constellation:' \
            '--processing-level=[filter by processing level]:level:' \
            '--sensor-type=[filter by sensor type]:type:' \
            '--cloud-cover=[max cloud cover percentage 0-100]:percent:' \
            '--id=[search by product id]:id:' \
            '--locations=[custom location query arguments]:locations:' \
            '*'{-q,--query}'=[custom query-string arguments]:query:' \
            '--cruncher=[apply a result cruncher]:cruncher:' \
            '*--cruncher-args=[cruncher parameters]:args:' \
            '--storage=[output geojson file]:file:_files' \
            '--limit=[number of items to return]:limit:' \
            '--page=[result page to retrieve]:page:' \
            '--all[retrieve all matching products]' \
            '--count[include total count with search]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        download)
          _arguments -s \
            '--search-results=[path to serialized search result]:file:_files' \
            '*--stac-item=[URL/path of STAC item to download]:item:' \
            '(-f --conf)'{-f,--conf}'=[user configuration file]:file:_files' \
            '--quicklooks[download only quicklooks]' \
            '--output-dir=[download directory]:dir:_files -/' \
            '--max-workers=[max number of parallel workers]:workers:' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        list)
          _arguments -s \
            '(-p --provider)'{-p,--provider}'=[list collections from a provider]:provider:' \
            '--instruments=[filter by instruments]:instruments:' \
            '--platform=[filter by platform]:platform:' \
            '--constellation=[filter by constellation]:constellation:' \
            '--processing-level=[filter by processing level]:level:' \
            '--sensor-type=[filter by sensor type]:type:' \
            '--no-fetch[skip fetching providers for new collections]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        discover)
          _arguments -s \
            '(-p --provider)'{-p,--provider}'=[fetch only the given provider]:provider:' \
            '--storage=[file to store external collections config]:file:_files' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
    fi
    ;;
esac

return ret
