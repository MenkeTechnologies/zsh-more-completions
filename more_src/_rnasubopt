#compdef rnasubopt

# ViennaRNA RNAsubopt: enumerate suboptimal secondary structures
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-e --deltaEnergy)'{-e,--deltaEnergy=}'[energy range in kcal/mol]:range:' \
  '(-s --sorted)'{-s,--sorted}'[sort structures by energy]' \
  '(-p --stochBT)'{-p,--stochBT=}'[stochastic backtracing - N samples]:n:' \
  '(-z --zuker)'{-z,--zuker}'[Zuker-style suboptimals]' \
  '(-l --logML)'{-l,--logML}'[log multiloop energy]' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[circular RNA]' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '--paramFile=[parameter file]:file:_files' \
  '--auto-id[auto-generate sequence IDs]' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
