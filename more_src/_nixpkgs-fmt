#compdef nixpkgs-fmt
# Documentation: https://github.com/nix-community/nixpkgs-fmt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--check[check if files are formatted without modifying]' \
  '--parse[show parse tree]' \
  '--explain[explain formatting decisions]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:nix file:_files -g "*.nix"' && ret=0

return ret
