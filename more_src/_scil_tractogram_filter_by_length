#compdef scil_tractogram_filter_by_length
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_filter_by_length.html
# Filter streamlines by length

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--minL=[minimum length of streamlines, in mm]:mm' \
  '--maxL=[maximum length of streamlines, in mm]:mm' \
  '--no_empty[prevent writing empty output files]' \
  '--display_counts[show streamline counts before and after filtering]' \
  '--out_rejected=[save filtered-out streamlines to file]:file:_files' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '--indent=[indentation for JSON formatting]:indent' \
  '--sort_keys[alphabetically sort JSON output keys]' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[overwrite output files without confirmation]' \
  '1:in_tractogram:_files' \
  '2:out_tractogram:_files' && ret=0

return ret
