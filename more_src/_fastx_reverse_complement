#compdef fastx_reverse_complement
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_reverse_complement.1.en.html
# FASTX-Toolkit: produce the reverse-complement of FASTA/Q sequences

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
