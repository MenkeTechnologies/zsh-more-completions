#compdef kyua
# Testing framework for infrastructure software

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'about:show information about kyua'
  'config:inspect configuration'
  'db-exec:execute SQL on results database'
  'db-migrate:upgrade results database schema'
  'debug:run test in debug mode'
  'help:show help information'
  'list:list test cases'
  'report:generate reports from results'
  'report-html:generate HTML report'
  'report-junit:generate JUnit report'
  'test:run tests'
)

_arguments -s -S \
  '1:command:->command' \
  '--config=[specify config file]:file:_files' \
  '--logfile=[specify log file]:file:_files' \
  '--loglevel=[specify log level]:level:(debug info warning error)' \
  '--variable=[set configuration variable]:key=value:' \
  '-h[show help]' \
  '--help[show help]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'kyua command' commands && ret=0
    ;;
esac

return ret
