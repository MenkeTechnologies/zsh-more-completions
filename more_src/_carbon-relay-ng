#compdef carbon-relay-ng
# Fast carbon relay and aggregator with online admin interfaces

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-block-profile-rate=[set block profile rate]:rate' \
  '-cpuprofile=[write CPU profile to file]:_files' \
  '-mem-profile-rate=[memory profile rate, 0 to disable]:rate' \
  '1:config:_files' && ret=0

return ret
