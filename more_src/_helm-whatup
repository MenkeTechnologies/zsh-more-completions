#compdef helm-whatup
# Documentation: https://github.com/fabmation-gmbh/helm-whatup
# helm whatup: determine if an update is available for installed charts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--color[colorize the repositories from where the chart has been installed]' \
  '--ignore-deprecation[skip charts marked as DEPRECATED]' \
  '--ignore-repo[ignore error if no repo for a chart is found]' \
  '--devel[use development versions too]' \
  '(-q --short)'{-q,--short}'[output short (quiet) listing format]' \
  '(-d --date)'{-d,--date}'[sort by release date]' \
  '(-r --reverse)'{-r,--reverse}'[reverse the sort order]' \
  '(-a --all)'{-a,--all}'[show all releases]' \
  '--uninstalled[show uninstalled releases]' \
  '--superseded[show superseded releases]' \
  '--uninstalling[show releases currently being uninstalled]' \
  '--deployed[show deployed releases]' \
  '--failed[show failed releases]' \
  '--pending[show pending releases]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[list releases across all namespaces]' \
  '--version[show version information]' \
  '--only-source-updates[only show updates where Chart and App versions match]' \
  '(-m --max)'{-m,--max}'=[maximum number of releases to fetch]:max:' \
  '--offset=[next release name to offset from start]:offset:' \
  '(-o --output)'{-o,--output}'=[output format]:format:(table json yaml)' && ret=0

return ret
