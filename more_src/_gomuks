#compdef gomuks

# Zsh completion for gomuks - terminal Matrix client

_arguments -s -S \
  '--data-dir=[set data directory]:directory:_files -/' \
  '--cache-dir=[set cache directory]:directory:_files -/' \
  '--config=[set config file path]:config file:_files' \
  '--debug[enable debug logging]' \
  '--cleardb[clear the local database]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
