#compdef stig

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'add:add torrents'
  'details:show torrent details'
  'filelist:list torrent files'
  'help:show help'
  'limit:set rate limits'
  'list:list torrents'
  'log:show log messages'
  'move:move torrent data'
  'pause:pause torrents'
  'peerlist:list peers'
  'priority:set file priorities'
  'remove:remove torrents'
  'rename:rename torrent files'
  'set:change settings'
  'sort:set sort order'
  'start:start torrents'
  'stop:stop torrents'
  'tab:manage tabs'
  'trackerlist:list trackers'
  'version:show version'
)

_arguments -C \
  '(- *)--help[display help and exit]' \
  '(- *)--version[display version and exit]' \
  '--tui[start TUI interface]' \
  '--notui[CLI only mode]' \
  {-c,--connect=}'[connect to transmission-daemon]:host\:port:' \
  {-s,--ssl}'[use SSL/TLS]' \
  '--no-ssl[do not use SSL/TLS]' \
  {-r,--rcfile=}'[RC configuration file]:file:_files' \
  '--no-rcfile[do not read RC file]' \
  {-d,--debug=}'[enable debug logging for module]:module:' \
  '--profile-file=[write profiling data to file]:file:_files' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add)
        _arguments '*:torrent:_files' && ret=0
        ;;
      (move)
        _arguments ':destination:_files -/' && ret=0
        ;;
      (help)
        _describe -t subcommands 'subcommand' subcommands && ret=0
        ;;
    esac
    ;;
esac

return ret
