#compdef hisat2

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-x+[index basename]:index:' \
  '-1+[mate 1 reads]:file:_files' \
  '-2+[mate 2 reads]:file:_files' \
  '-U+[unpaired reads]:file:_files' \
  '--sra-acc=[SRA accession]:accession:' \
  '-S+[output SAM file]:file:_files' \
  '-q[reads are FASTQ (default)]' \
  '-f[reads are FASTA]' \
  '-r[reads are raw one-per-line]' \
  '-c[reads given on command line]' \
  '-s+[skip first N reads]:count:' \
  '-u+[stop after N reads]:count:' \
  '-5+[trim N bases from 5'\'' end]:bases:' \
  '-3+[trim N bases from 3'\'' end]:bases:' \
  '--phred33[qualities are Phred+33]' \
  '--phred64[qualities are Phred+64]' \
  '--int-quals[qualities are integers]' \
  '--n-ceil=[function for max Ns]:func:' \
  '--ignore-quals[treat all qualities as 30]' \
  '--nofw[do not align forward strand]' \
  '--norc[do not align reverse-complement strand]' \
  '--pen-cansplice=[penalty for canonical splice sites]:penalty:' \
  '--pen-noncansplice=[penalty for non-canonical splice sites]:penalty:' \
  '--pen-canintronlen=[penalty for canonical intron length]:func:' \
  '--pen-noncanintronlen=[penalty for non-canonical intron length]:func:' \
  '--min-intronlen=[minimum intron length]:length:' \
  '--max-intronlen=[maximum intron length]:length:' \
  '--known-splicesite-infile=[known splice sites]:file:_files' \
  '--novel-splicesite-outfile=[output novel splice sites]:file:_files' \
  '--novel-splicesite-infile=[input novel splice sites]:file:_files' \
  '--no-temp-splicesite[disable temp splice sites]' \
  '--no-spliced-alignment[disable spliced alignment]' \
  '--rna-strandness=[RNA strandness]:type:(unstranded FR RF F R)' \
  '--dta[downstream transcriptome assembly]' \
  '--dta-cufflinks[cufflinks-compatible output]' \
  '--no-softclip[disable soft-clipping]' \
  '--no-discordant[disable discordant alignments]' \
  '--no-mixed[disable mixed alignments]' \
  '-I+[minimum fragment length]:length:' \
  '-X+[maximum fragment length]:length:' \
  '--fr[forward/reverse orientation]' \
  '--rf[reverse/forward orientation]' \
  '--ff[forward/forward orientation]' \
  '--no-unal[suppress unaligned reads]' \
  '--un+[write unaligned reads]:file:_files' \
  '--al+[write aligned reads]:file:_files' \
  '--un-conc+[write pairs that did not align]:file:_files' \
  '--al-conc+[write pairs that aligned]:file:_files' \
  '--summary-file=[summary file]:file:_files' \
  '--new-summary[new summary style]' \
  '-k+[report up to N alignments]:count:' \
  '--min-score=[minimum alignment score]:func:' \
  '-p+[number of threads]:threads:' \
  '--reorder[reorder SAM records]' \
  '--mm[memory-mapped I/O]' \
  '--qc-filter[filter reads by quality]' \
  '--seed=[random seed]:seed:' \
  '--non-deterministic[use non-deterministic seed]' \
  '--remove-chrname[remove chr from reference names]' \
  '--add-chrname[add chr to reference names]' \
  '*:reads:_files' && ret=0

return ret
