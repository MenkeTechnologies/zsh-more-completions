#compdef cloudflare-speed-cli
# Documentation: https://github.com/kavehtehrani/cloudflare-speed-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (clap CLI definition).

_arguments -s -S \
  '--base-url=[Cloudflare speed service URL]:url:' \
  '--json[JSON result; no TUI]' \
  '--text[text summary; no TUI]' \
  '--silent[only with --json; minimal output]' \
  '--download-duration=[download phase]:duration:' \
  '--upload-duration=[upload phase]:duration:' \
  '--idle-latency-duration=[latency probe duration]:duration:' \
  '--concurrency=[parallel workers (HTTP)]:count:' \
  '--download-bytes-per-req=[bytes per download request]:bytes:' \
  '--upload-bytes-per-req=[bytes per upload request]:bytes:' \
  '--probe-interval-ms=[latency probe interval ms]:ms:' \
  '--probe-timeout-ms=[probe timeout ms]:ms:' \
  '--experimental[reserved experimental flag]' \
  '--export-json=[write JSON results]:file:_files' \
  '--export-csv=[write CSV results]:file:_files' \
  '--auto-save=[true/false persist results]:bool:(true false)' \
  '--interface=[bind network interface]:iface:' \
  '--source=[bind source IP]:ip:' \
  '--proxy=[HTTP/HTTPS/SOCKS5 proxy URL]:url:' \
  '--certificate=[custom TLS cert PEM/DER]:file:_files' \
  '--test-on-launch=[auto-start on open]:bool:(true false)' \
  '--comments=[annotate run]:text:' \
  '--compare-ip-versions[IPv4 vs IPv6 comparison]' \
  '--traceroute[traceroute to Cloudflare edge]' \
  '--traceroute-max-hops=[max hops]:hops:' \
  '--ipv4-only[force IPv4]' \
  '--ipv6-only[force IPv6]' \
  '--skip-diagnostics[skip DNS/TLS checks]' \
  '--udp-packets=[UDP loss probe count]:count:' \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]'
