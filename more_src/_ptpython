#compdef ptpython

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-i[run script and enter interactive mode]:script:_files' \
  '--interactive[run script and enter interactive mode]:script:_files' \
  '--vi[use vi key bindings]' \
  '--config-file[config file]:file:_files' \
  '--config-dir[config directory]:dir:_directories' \
  '--history-file[history file]:file:_files' \
  '--light-bg[optimize colors for light background]' \
  '--dark-bg[optimize colors for dark background]' \
  '*:script:_files' && ret=0

return ret