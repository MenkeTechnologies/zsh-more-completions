#compdef ptpython
# Documentation: https://github.com/prompt-toolkit/ptpython
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --interactive)'{-i,--interactive}'[run script and enter interactive mode]' \
  '--vi[use vi key bindings]' \
  '--asyncio[run an asyncio event loop for top-level await]' \
  '--config-file=[config file]:file:_files' \
  '--history-file=[history file]:file:_files' \
  '--light-bg[optimize colors for light background]' \
  '--dark-bg[optimize colors for dark background]' \
  '*:script:_files -g "*.py"' && ret=0

return ret
