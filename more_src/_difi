#compdef difi
# Documentation: https://man.archlinux.org/search?q=difi
# Reference accessed: 2026-05-16

# https://github.com/oug-t/difi — API diff visualizer (`difi --help`)
_arguments -s -S \
  '--help[help]' \
  '-V[version]' \
  '--version[version]' \
  '(-c --config)'{-c,--config}'=-[OpenAPI paths YAML]:file:_files' \
  '*:positional args:_default'
