#compdef bhyvectl
# _bhyvectl — FreeBSD bhyvectl (low-level control + introspection of a running bhyve VM; --vm picks target, --get-stats / --get-* introspect, --destroy tears down a VM stub, --inject-* injects interrupts/exceptions, --force-reset/--force-poweroff, --get-vcpu-state, --set-* tweak runtime state)
# upstream: https://cgit.freebsd.org/src (usr.sbin/bhyvectl)
# Flags from FreeBSD usr.sbin/bhyvectl/bhyvectl.c on tip.

_bhyvectl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--vm=*[vm name]:vm:' \
        '--destroy[destroy vm]' \
        '--get-stats[get cpu stats]' \
        '--get-msr=*[MSR]:msr:' \
        '--get-cpu-topology[print cpu topology]' \
        '--get-rtc-time[print RTC]' \
        '--set-rtc-time=*[time]:time:' \
        '--get-pinfo[print platform info]' \
        '--get-suspended[print suspended state]' \
        '--get-stage-state[stage state]' \
        '--force-reset[force reset]' \
        '--force-poweroff[force poweroff]' \
        '--inject-nmi[inject NMI]' \
        '--inject-extint=*[vector]:vec:' \
        '--inject-exception=*[type:vector]:typevec:' \
        '--vcpu=*[vcpu index]:vcpu:' \
        '--set-mem=*[size]:size:' \
        '--get-vmexit-stats[exit stats]' \
        '--ipi-only[ipi only]'
}

_bhyvectl "$@"
