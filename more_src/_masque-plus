_masque-plus() {
    _arguments -s -S \
        '--endpoint=[endpoint to connect (IPv4/IPv6 host[:port])]:endpoint:' \
        '--bind=[local SOCKS5 bind (default 127.0.0.1:1080)]:ip:port:' \
        '--renew[force renewal of config.json]' \
        '--scan[scan/auto-select a default endpoint]' \
        '-4[force IPv4 endpoint list with --scan]' \
        '-6[force IPv6 endpoint list with --scan]' \
        '--connect-timeout=[overall connect/process up timeout (default 15m)]:duration:' \
        '--range4=[comma-separated IPv4 CIDRs to scan]:cidr:' \
        '--range6=[comma-separated IPv6 CIDRs to scan]:cidr:' \
        '--ping[ping each candidate before connect (default true)]' \
        '--scan-timeout=[per-endpoint scan timeout (default 5s)]:duration:' \
        '--scan-max=[maximum endpoints to try during scan (default 30)]:n:' \
        '--scan-verbose-child[print MASQUE child process logs during scan]' \
        '--scan-tunnel-fail-limit=[tunnel fail occurrence threshold (default 2)]:n:' \
        '--scan-ordered[scan candidates in CIDR order]' \
        '--test-url=[connectivity test URL]:url:' \
        '--connect-port=[MASQUE connect port (default 443)]:port:' \
        '--dns=[comma-separated DNS servers]:dns:' \
        '--dns-timeout=[DNS query timeout (default 2s)]:duration:' \
        '--initial-packet-size=[initial QUIC packet size (default 1242)]:bytes:' \
        '--keepalive-period=[QUIC keepalive period (default 30s)]:duration:' \
        '--local-dns[do not use the tunnel for DNS]' \
        '--mtu=[MTU for MASQUE connection (default 1280)]:bytes:' \
        '--no-tunnel-ipv4[disable IPv4 inside the MASQUE tunnel]' \
        '--no-tunnel-ipv6[disable IPv6 inside the MASQUE tunnel]' \
        '--password=[proxy auth password]:pass:' \
        '--username=[proxy auth username]:user:' \
        '--reconnect-delay=[reconnect attempt delay (default 1s)]:duration:' \
        '--sni=[SNI address for MASQUE (default consumer-masque.cloudflareclient.com)]:sni:' \
        '--ipv6[use IPv6 for MASQUE connection]' \
        '--rtt[placeholder flag, not used]' \
        '--reserved=[placeholder flag, not used]:val:' \
        '--version[print version + exit]'
}

_masque-plus "$@"
