#compdef benthos

local -a subcommands
subcommands=(
  'blobl:Interact with blob storage'
  'create:Create a new config'
  'echo:Echo parsed config to stdout'
  'lint:Lint a config file'
  'list:List available components'
  'run:Run a Benthos pipeline'
  'streams:Run in streams mode'
  'studio:Open Benthos Studio'
  'test:Run config unit tests'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '--log.level=[Logging level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
  '--set=[Override config field]:override:' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-c --config)'{-c,--config}'[Config file]:file:_files' \
          '(-r --resources)'{-r,--resources}'[Resource config file]:file:_files' \
          '(-t --templates)'{-t,--templates}'[Template directory]:dir:_directories' \
          '--set=[Override config field]:override:' \
          '--env-file=[Environment file]:file:_files' \
          '--chilled[Only exit on fatal errors]' \
          '--watcher[Enable file watcher for config changes]'
        ;;
      create)
        _arguments \
          '(-s --small)'{-s,--small}'[Create small example]' \
          '1:output:_files'
        ;;
      lint)
        _arguments '1:config:_files'
        ;;
      test)
        _arguments '1:config:_files'
        ;;
      list)
        _arguments \
          '--format=[Output format]:format:(text json)' \
          '1:component type:(inputs outputs processors caches rate-limits buffers metrics tracers)'
        ;;
      streams)
        _arguments \
          '--no-api[Disable REST API]' \
          '--prefix-stream-endpoints[Prefix endpoints with stream ID]' \
          '*:config files:_files'
        ;;
    esac
    ;;
esac
