#compdef lsqkab
# Documentation: https://www.ccp4.ac.uk/html/lsqkab.html
# CCP4: least-squares superposition of two coordinate sets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZINM[rotating (work) coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZINF[reference coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate file]:output:_files' \
  'RMSTAB[output RMS distance file]:output:_files' \
  'DELTAS[output atomic difference file]:output:_files' \
  '*:keyword:(FIT MATCH OUTPUT ROTATE TRANSLATE RADIUS CELL TITLE END)' && ret=0

return ret
