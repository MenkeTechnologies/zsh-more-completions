#compdef apt-build

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'update:retrieve new package lists'
  'upgrade:upgrade packages'
  'world:rebuild your system'
  'install:build and install packages'
  'source:download and extract source'
  'info:info on a buildable package'
  'remove:remove packages'
  'clean-build:erase built packages'
  'clean-sources:clean source dirs'
  'build-source:build source without installing'
  'update-source:update sources, rebuild if missing'
  'build-repository:rebuild the repository'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nowrapper[run without wrapper]' \
  '--remove-builddep[remove build deps]' \
  '--no-source[skip source download]' \
  '--build-dir=[build directory]:dir:_files -/' \
  '--build-only[build only, no install]' \
  '--rebuild[force rebuild]' \
  '--reinstall[force reinstall]' \
  '--build-command=[build command]:cmd:' \
  '--patch=[patch file]:file:_files' \
  '(-p --patch-strip)'{-p,--patch-strip=}'[patch strip level]:n:' \
  '(-y --yes)'{-y,--yes}'[assume yes]' \
  '--purge[purge on remove]' \
  '--noupdate[skip update]' \
  '--sources-list=[sources.list file]:file:_files' \
  '--apt-get=[apt-get binary]:path:_files' \
  '--apt-cache=[apt-cache binary]:path:_files' \
  '--force-yes[force yes]' \
  '--source[fetch source]' \
  '--repository-dir=[repository dir]:dir:_files -/' \
  '--target-release=[target release]:rel:' \
  '--config=[config file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'apt-build subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|remove|info|source|build-source)
        _arguments '*:package:' && ret=0
        ;;
    esac
    ;;
esac

return ret
