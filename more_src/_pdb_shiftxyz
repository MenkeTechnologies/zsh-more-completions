#compdef pdb_shiftxyz
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Shifts the coordinates of the PDB file by a given amount

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[coordinate shift x,y,z, e.g. -1.0,2.0,3.0]:x,y,z shift' \
  '*:PDB file:_files' && ret=0

return ret
