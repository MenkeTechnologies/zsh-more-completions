#compdef endpoint_storage
# _endpoint_storage — Neon endpoint storage service (per-compute file upload/download API used for LFC prewarm data; backed by S3-compatible storage)
# upstream: https://github.com/neondatabase/neon
# Flags from endpoint_storage/src/main.rs on tip (clap-derive); must supply either a config file argument or --config inline JSON.

_endpoint_storage() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '--no-s3-check-on-startup[skip S3 permissions check at startup (requires --config)]' \
        '--config=[inline JSON config (mutually exclusive with positional config file)]:json:' \
        '*:config-file:_files'
}

_endpoint_storage "$@"
