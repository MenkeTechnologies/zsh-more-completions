#compdef ModelSegments
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/ModelSegments.java
# Models segmented copy ratios from denoised copy ratios and segmented minor-allele fractions from allelic counts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--denoised-copy-ratios=[Input files containing denoised copy ratios (output of DenoiseReadCounts).]:value:_files' \
  '--allelic-counts=[Input files containing allelic counts (output of CollectAllelicCounts).]:value:_files' \
  '--normal-allelic-counts=[Input file containing allelic counts for a matched normal (output of CollectAllelicCoun...]:value:_files' \
  '--segments=[Input Picard interval-list file specifying segments.]:value:_files' \
  '--output-prefix=[Prefix for output filenames.]:value:_files' \
  '(--output -O)'{--output,-O}'[Output directory. This will be created if it does not exist.]:value:_files' \
  '*:argument:_files' && ret=0

return ret
