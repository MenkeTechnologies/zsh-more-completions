#compdef pamstretch
# Documentation: man pamstretch (Netpbm)
# Source: Netpbm pamstretch — scale up a PNM or PAM image by interpolating between pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-xscale=[X-axis integer scale]:X:' \
    '-yscale=[Y-axis integer scale]:Y:' \
    '(-blackedge -dropedge)-blackedge[fill right/bottom edges with black]' \
    '(-blackedge -dropedge)-dropedge[drop unfinished right/bottom edges]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:N + Netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
