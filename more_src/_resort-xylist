#compdef resort-xylist
# Documentation: https://astrometry.net/doc/readme.html
# sort a star list balancing background-subtracted and raw flux

local ret=1

_arguments -s \
  '-h[show help]' \
  '-f+[flux column name (default FLUX)]:flux column:' \
  '-b+[background column name (default BACKGROUND)]:background column:' \
  '-d[sort in descending order (default ascending)]' \
  '-v[add verboseness]' \
  '1:input:_files' \
  '2:output:_files' && ret=0

return ret
