#compdef casr-core
# Documentation: https://github.com/ispras/casr/blob/master/docs/usage.md
# Analyze coredumps for security assessment with CASR

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-m --mode)'{-m,--mode}'=[mode]:mode:(online offline)' \
  '(-f --file)'{-f,--file}'=[path to input core file]:file:_files' \
  '(-o --output)'{-o,--output}'=[path to save report in JSON format]:file:_files' \
  '--stdout[print CASR report to stdout]' \
  '(-e --executable)'{-e,--executable}'=[path to executable]:file:_files' && ret=0

return ret
