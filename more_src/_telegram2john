#compdef telegram2john ios7tojohn itunes_backup2john
# Documentation: https://github.com/openwall/john (bleeding-jumbo branch)
#                — sources read directly from run/*.py and run/*.pl
# Reference accessed: 2026-05-30
# John the Ripper *2john helpers, round 6 (final mop-up). Extends rounds
# 144-148 with the last 3 fresh JtR helpers from the broader run/ directory
# that survived the 404 attrition. The bleeding-jumbo branch listings
# include several speculatively-named files (openvpn2john, putty2john,
# raw2john, vdi2john, wallet2john, whirlpool2john, wincreds2john,
# sxc2john, dominosec2john, o5logon2john, odf2john, racf2john) that all
# 404 on direct fetch — those are deferred per the source-404 precedent.
# Surfaces transcribed from upstream source rather than from Debian
# dyn-redirect manpages (which 404).

local curcontext="$curcontext" state line ret=1

case $service in

  telegram2john)
    # run/telegram2john.py — extracts hashes from Telegram Desktop local data.
    # Accepts a Telegram data directory (which the script searches
    # recursively) OR individual userconfig.xml / map0 / map1 / key_datas
    # files. Strips trailing quote characters from paths.
    #   Linux:   ~/.local/share/TelegramDesktop
    #   Windows: C:/Users/Name/AppData/Roaming/Telegram Desktop
    _arguments -s -S \
      '*:Telegram data dir or userconfig.xml/map0/map1/key_datas:_files' \
      && ret=0
    ;;

  ios7tojohn)
    # run/ios7tojohn.pl — Apple iOS 7 restrictions-password plist parser.
    # Outputs PBKDF2-HMAC-SHA1 hashes. Handles both single-line and
    # multi-line XML <data> elements.
    _arguments -s -S \
      '*:iOS 7 restrictions .plist file:_files -g "*.plist"' \
      && ret=0
    ;;

  itunes_backup2john)
    # run/itunes_backup2john.pl — iTunes backup Manifest.plist parser.
    # Output formats vary by iOS version:
    #   Pre-iOS 10:   $itunes_backup$*9*<wpky>*<iter>*<salt>**
    #   iOS 10.x+:    $itunes_backup$*10*<wpky>*<iter>*<salt>*<dpic>*<dpsl>
    # WPKY = 40 bytes, SALT = 20 bytes, DPSL = 20 bytes when present.
    _arguments -s -S \
      '*:iTunes backup Manifest.plist:_files -g "Manifest.plist|*.plist"' \
      && ret=0
    ;;

esac

return ret
