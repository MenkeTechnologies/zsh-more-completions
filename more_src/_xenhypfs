#compdef xenhypfs
# Documentation: https://man.archlinux.org/search?q=xenhypfs
# Reference accessed: 2026-05-16

# xenhypfs: FUSE filesystem exposing Xen hypervisor internals
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'ls:list a directory'
  'cat:show file contents'
  'write:write to a file'
  'tree:show full hierarchy'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xenhypfs command' commands && ret=0 ;;
esac
return ret
