#compdef slackpkg

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'update:update package list / GPG key'
  'check-updates:check for new updates'
  'install:install a package'
  'upgrade:upgrade an installed package'
  'reinstall:reinstall a package'
  'remove:remove an installed package'
  'blacklist:add or remove packages from blacklist'
  'download:download but do not install'
  'info:show package info'
  'search:search for a package'
  'file-search:search for a file in packages'
  'clean-system:remove non-official packages'
  'upgrade-all:upgrade all installed packages'
  'install-new:install new packages added by Slackware team'
  'new-config:resolve .new config files'
  'generate-template:generate template of installed packages'
  'install-template:install template'
  'remove-template:remove template'
  'help:show help'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '-batch=[batch mode (on or off)]:flag:(on off)' \
  '-default_answer=[default answer y or n]:ans:(y n)' \
  '-only_new_dotnew=[install only new .new files]:flag:(on off)' \
  '-spinning=[spinner display]:flag:(on off)' \
  '-postinst=[postinstall]:flag:(on off)' \
  '-dialog=[dialog mode]:flag:(on off)' \
  '-mirror=[mirror URL]:url:' \
  '-checkmd5=[md5 verify]:flag:(on off)' \
  '-checkgpg=[gpg verify]:flag:(on off)' \
  '-checksize=[size verify]:flag:(on off)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'slackpkg command' commands && ret=0 ;;
esac

return ret
