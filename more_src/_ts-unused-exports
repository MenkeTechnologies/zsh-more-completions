#compdef ts-unused-exports
# Documentation: https://github.com/pzavolinsky/ts-unused-exports
# ts-unused-exports - find unused exported symbols in a TypeScript project

local ret=1

_arguments -s -S \
  '--allowUnusedEnums[allow unused enums]' \
  '--allowUnusedTypes[allow unused type or interface]' \
  '--excludeDeclarationFiles[exclude .d.ts files when looking for unused exports]' \
  '--excludePathsFromReport=[exclude files from output matching path segments or regex]:paths' \
  '--exitWithCount[exit code is the count of files that have unused exports]' \
  '--exitWithUnusedTypesCount[exit code is the total count of unused exported types]' \
  '--findCompletelyUnusedFiles[find files where all exports are unused]' \
  '--ignoreFiles=[ignore files with filenames matching the given regex]:regex' \
  '--ignoreLocallyUsed[do not report exports used within their own file]' \
  '--ignoreProductionFiles[only scan test files]' \
  '--ignoreTestFiles[only scan production files]' \
  '--maxIssues=[succeed for up to a given number of modules with unused exports]:n' \
  '--searchNamespaces[search for unused exports within namespaces]' \
  '--showLineNumber[show the line number and column of the unused export]' \
  '--silent[do not write on stdout on success]' \
  '*:tsconfig:_files -g "*.json"' && ret=0

return ret
