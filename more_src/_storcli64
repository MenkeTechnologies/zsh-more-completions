#compdef storcli
# Documentation: https://docs.broadcom.com/doc/12352476
# Reference accessed: 2026-05-17
# Verified: Broadcom (LSI) StorCLI Reference Guide command surface
# (show, add, delete, flush, flash, expand, init, consistency,
# patrolread, spinup, spindown, start, stop, pause, resume, set, get,
# import, transform, replace, rebuild). storcli verbs are not flag-
# prefixed; -h/help and -v/v print help/version.
# Removed from prior file: bogus man.archlinux.org search URL.

# storcli: Broadcom (LSI) RAID command line interface
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)help[show help]' \
  '(- *)-v[show version]' \
  '(- *)v[show version]' \
  'show[show ctrl/PD/LD/encl/all]' \
  'add[create VD / dimmer setting]' \
  'delete[delete VD]' \
  'flush[flush ctrl cache]' \
  'flash[flash firmware]' \
  'expand[expand virtual drive]' \
  'init[initialize VD]' \
  'consistency[VD consistency check]' \
  'patrolread[patrol read]' \
  'spinup[spinup drives]' \
  'spindown[spindown drives]' \
  'start[start operation]' \
  'stop[stop operation]' \
  'pause[pause operation]' \
  'resume[resume operation]' \
  'set[set parameter]' \
  'get[get parameter]' \
  'import[import foreign config]' \
  'transform[transform RAID level]' \
  'replace[replace member]' \
  'rebuild[rebuild operation]' \
  '*:storcli args:' && ret=0
return ret
