#compdef nfacct
# _nfacct — netfilter nfacct (manage kernel netfilter accounting objects independent of iptables/nftables rules; subcommands: list (or -l), add NAME, delete NAME, get NAME, restore (from stdin), flush, monitor; flags: -j JSON, -a show all, -n no header, -z reset counters, -V version, -h help)
# upstream: https://git.netfilter.org/nfacct
# Subcommands from netfilter/nfacct src/nfacct.c on tip.

_nfacct() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-j[JSON]' \
        '-a[show all]' \
        '-n[no header]' \
        '-z[reset]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'nfacct command' '(list add delete get restore flush monitor help)' ;;
        args) _arguments '*:name:' ;;
    esac
}

_nfacct "$@"
