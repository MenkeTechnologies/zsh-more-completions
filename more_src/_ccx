#compdef ccx
# Documentation: http://www.dhondt.de/ccx_2.21.pdf
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-i+[input deck name without .inp extension]:input name:_files' \
  '-o+[output name]:output name:' \
  '(-v --version)'{-v,--version}'[show version information]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
