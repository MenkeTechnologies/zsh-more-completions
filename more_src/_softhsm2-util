#compdef softhsm2-util

# Zsh completion for softhsm2-util - SoftHSM2 utility

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--init-token[initialize a token]' \
  '--show-slots[show available slots]' \
  '--delete-token[delete a token]' \
  '--import=[import a key pair from file]:key file:_files' \
  '--export=[export a key pair to file]:output file:_files' \
  '--free[show number of free slots]' \
  '--slot=[slot number to use]:slot number' \
  '--label=[token label]:label' \
  '--so-pin=[security officer PIN]:PIN' \
  '--pin=[user PIN]:PIN' \
  '--id=[key identifier in hex]:hex id' \
  '--token=[token label to use]:token label' \
  '--module=[PKCS#11 module path]:module:_files' \
  '--mechanism=[key mechanism]:mechanism:(RSA DSA EC EDDSA AES DES3 GENERIC)' \
  '--force-pin-change[force PIN change on first login]' && ret=0

return ret
