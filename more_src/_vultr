#compdef vultr-cli

_vultr_commands() {
    local -a commands
    commands=(
        'account:Display account information'
        'apps:Display applications'
        'backups:Display backups'
        'bare-metal:Commands for bare metal servers'
        'block-storage:Commands for block storage'
        'cdn:Commands for CDN'
        'container-registry:Commands for container registry'
        'database:Commands for managed databases'
        'dns:Commands for DNS'
        'firewall:Commands for firewall'
        'instance:Commands for cloud instances'
        'iso:Commands for ISOs'
        'kubernetes:Commands for Kubernetes'
        'load-balancer:Commands for load balancers'
        'marketplace:Commands for marketplace'
        'network:Commands for private networks'
        'object-storage:Commands for object storage'
        'os:Display available operating systems'
        'plans:Display available plans'
        'regions:Display available regions'
        'reserved-ip:Commands for reserved IPs'
        'script:Commands for startup scripts'
        'snapshot:Commands for snapshots'
        'ssh-key:Commands for SSH keys'
        'user:Commands for user management'
        'version:Display CLI version'
        'vpc:Commands for VPCs'
        'vpc2:Commands for VPC 2.0'
    )
    _describe -t commands 'vultr-cli command' commands
}

_vultr() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--config[Path to config file]:file:_files' \
        '--output[Output format]:format:(json text)' \
        '1:command:_vultr_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                instance)
                    _arguments \
                        '1:action:(create delete get list start stop restart reinstall bandwidth ipv4 ipv6 reverse-dns backup restore update label tag plan upgrade user-data)' \
                        '--region[Region ID]:region:' \
                        '--plan[Plan ID]:plan:' \
                        '--os[Operating system ID]:os:' \
                        '--label[Instance label]:label:' \
                        '--hostname[Instance hostname]:hostname:' \
                        '--snapshot[Snapshot ID]:snapshot:' \
                        '--ssh-keys[SSH key IDs]:keys:' \
                        '--script-id[Startup script ID]:script:'
                    ;;
                kubernetes)
                    _arguments \
                        '1:action:(create delete get list config node-pool)' \
                        '--region[Region]:region:' \
                        '--label[Cluster label]:label:' \
                        '--version[Kubernetes version]:version:'
                    ;;
                dns)
                    _arguments \
                        '1:action:(domain record)' \
                        '--domain[Domain name]:domain:'
                    ;;
                database)
                    _arguments \
                        '1:action:(create delete get list plan user db maintenance backup restore connection-pool read-replica)' \
                        '--region[Region]:region:' \
                        '--plan[Plan ID]:plan:' \
                        '--label[Database label]:label:' \
                        '--type[Database type]:type:(mysql pg redis kafka mongodb opensearch)'
                    ;;
                block-storage)
                    _arguments \
                        '1:action:(create delete get list attach detach resize label)' \
                        '--region[Region]:region:' \
                        '--size[Size in GB]:size:' \
                        '--label[Label]:label:'
                    ;;
                firewall)
                    _arguments \
                        '1:action:(group rule)' \
                        '--description[Description]:desc:'
                    ;;
                snapshot)
                    _arguments \
                        '1:action:(create delete get list)' \
                        '--instance[Instance ID]:instance:'
                    ;;
                ssh-key)
                    _arguments \
                        '1:action:(create delete get list update)' \
                        '--name[Key name]:name:' \
                        '--key[SSH public key]:key:'
                    ;;
            esac
            ;;
    esac
}

_vultr "$@"
