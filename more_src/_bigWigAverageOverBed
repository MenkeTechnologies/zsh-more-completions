#compdef bigWigAverageOverBed
# compute average score of bigWig over each bed (may have introns)

local ret=1

_arguments -s -S \
  '-stats=[write overall statistics to a .ra file]:ra file:_files' \
  '-bedOut=[output bed echoing input with mean column appended]:bed:_files' \
  '-sampleAroundCenter=[sample N-base region centered on bed item]:n' \
  '-minMax[include columns for min and max observed values]' \
  '-tsv[include TSV header]' \
  '1:in bw:_files -g "*.(bw|bigWig)"' \
  '2:in bed:_files -g "*.bed"' \
  '3:out tab:_files' && ret=0

return ret
