#compdef askalono
# _askalono — license identifier for source files (jpeddicord/askalono)
# upstream: https://github.com/jpeddicord/askalono
# Subcommands + flags from cli/src/commands.rs (clap derive).

_askalono() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --cache)'{-c+,--cache=}'[path to the compiled license cache file]:file:_files' \
        '--format=[output format]:format:(text json)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_askalono_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                identify|id)
                    _arguments \
                        '(-o --optimize)'{-o,--optimize}'[try to locate the license within the file]' \
                        '(-b --batch)'{-b,--batch}'[read filenames from stdin]' \
                        '(-m --multiple)'{-m,--multiple}'[detect multiple licenses in the same file]' \
                        '1:file to identify:_files' && ret=0 ;;
                crawl)
                    _arguments \
                        '--follow[follow symlinks]' \
                        '--glob=[glob pattern (defaults to license-like names)]:glob:' \
                        '1:directory to crawl:_files -/' && ret=0 ;;
                cache)
                    _arguments \
                        '1: :(load-spdx)' \
                        '--store[also store original license texts in the cache]' \
                        '*:SPDX details directory:_files -/' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_askalono_commands] )) ||
_askalono_commands() {
    local -a commands
    commands=(
        'identify:identify the license in a single file'
        'id:alias of identify'
        'crawl:walk a directory and identify likely license files'
        'cache:manage the compiled license cache (load-spdx)'
    )
    _describe -t commands 'askalono command' commands
}

_askalono "$@"
