#compdef MassTraceExtractor
# OpenMS TOPP: extract mass traces from centroided LC-MS data

local ret=1

_arguments -s -S \
  '-in[input centroided mzML file]:input file:_files' \
  '-out[output featureXML file with mass traces]:output file:_files' \
  '-algorithm:common:noise_threshold_int[intensity cutoff for noise]:value:' \
  '-algorithm:common:chrom_peak_snr[minimum signal-to-noise ratio]:value:' \
  '-algorithm:mtd:mass_error_ppm[permissible m/z deviation in ppm]:value:' \
  '-algorithm:mtd:trace_termination_criterion[trace extension stop criterion]:mode:(outlier sample_rate)' \
  '-algorithm:mtd:min_trace_length[shortest mass trace duration (s)]:value:' \
  '-algorithm:mtd:max_trace_length[longest mass trace duration (s)]:value:' \
  '-algorithm:mtd:quant_method[measurement approach for mass traces]:method:(area median max_height)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
