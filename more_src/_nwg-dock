#compdef nwg-dock

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p[position]:position:(bottom top left right)' \
  '-o[output name]:output:' \
  '-s[icon size]:size:' \
  '-l[layer]:layer:(overlay top bottom background)' \
  '-mb[margin bottom]:pixels:' \
  '-mt[margin top]:pixels:' \
  '-ml[margin left]:pixels:' \
  '-mr[margin right]:pixels:' \
  '-d[run as daemon]' \
  '-r[resident mode]' \
  '-nows[do not show workspace switcher]' \
  '-nolauncher[do not show launcher button]' \
  '-x[exclusive zone]' \
  '-ico[icon theme]:theme:' && ret=0

return ret
