#compdef vdo-cli
# _vdo-cli — Red Hat VDO Virtual Data Optimizer manager CLI alias (RedHatStorage/vdo team, Python); argparse
# upstream: https://github.com/dm-vdo/vdo

_vdo-cli() {
    local -a sub=(
        'activate:activate VDO volume'
        'changeWritePolicy:change write policy'
        'create:create VDO volume'
        'deactivate:deactivate VDO volume'
        'disableCompression:disable compression'
        'disableDeduplication:disable deduplication'
        'enableCompression:enable compression'
        'enableDeduplication:enable deduplication'
        'growLogical:grow logical size'
        'growPhysical:grow physical size'
        'list:list all VDOs'
        'modify:modify VDO config'
        'printConfigFile:print config file'
        'remove:remove VDO volume'
        'start:start VDO volume'
        'status:show VDO status'
        'stop:stop VDO volume'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--all[all]' \
        '-a[all]' \
        '--confFile=+[config file]:file:_files' \
        '-f+[config file]:file:_files' \
        '--debug[debug]' \
        '--logfile=+[log file]:file:_files' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vdo subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--device=+[device]:_files -g "/dev/*"' \
                    '--vdoLogicalSize=+[size]:str:' \
                    '--vdoSlabSize=+[size]:str:' \
                    '--vdoAckThreads=+[n]:n:' \
                    '--vdoBioRotationInterval=+[n]:n:' \
                    '--vdoBioThreads=+[n]:n:' \
                    '--vdoCpuThreads=+[n]:n:' \
                    '--vdoHashZoneThreads=+[n]:n:' \
                    '--vdoLogicalThreads=+[n]:n:' \
                    '--vdoPhysicalThreads=+[n]:n:' \
                    '--blockMapCacheSize=+[size]:str:' \
                    '--blockMapPeriod=+[n]:n:' \
                    '--compression=+[bool]:b:(enabled disabled)' \
                    '--deduplication=+[bool]:b:(enabled disabled)' \
                    '--emulate512=+[bool]:b:(enabled disabled)' \
                    '--writePolicy=+[policy]:p:(sync async async-unsafe auto)' \
                    '--sparseIndex=+[bool]:b:(enabled disabled)' \
                    '--indexMem=+[size]:str:' \
                    '--maxDiscardSize=+[size]:str:' \
                    '--force[force]' \
                    '--activate=+[bool]:b:(enabled disabled)' \
                    '--uuid=+[uuid]:str:' ;;
            esac
            ;;
    esac
}

_vdo-cli "$@"
