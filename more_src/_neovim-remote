#compdef nvr neovim-remote

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--serverlist[list running neovim instances]' \
  '--servername[connect to a specific server]:address:' \
  '-cc[execute command before :edit]:command:' \
  '-c[execute command after :edit]:command:' \
  '-d[diff mode]' \
  '-l[set arglist]' \
  '-o[open files in horizontal splits]' \
  '-O[open files in vertical splits]' \
  '-p[open files in tabs]' \
  '-t[jump to tag]:tag:' \
  '-q[open quickfix file]:file:_files' \
  '--remote[open files in remote neovim]' \
  '--remote-wait[open and wait for files to be closed]' \
  '--remote-silent[open silently without errors]' \
  '--remote-wait-silent[open, wait, and silence errors]' \
  '--remote-tab[open files in new tabs]' \
  '--remote-tab-wait[open in tabs and wait]' \
  '--remote-tab-silent[open in tabs silently]' \
  '--remote-tab-wait-silent[open in tabs, wait, silence]' \
  '--remote-send[send key sequences]:keys:' \
  '--remote-expr[evaluate expression]:expression:' \
  '--nostart[do not start neovim if not running]' \
  '-s[source a vim script]:script file:_files' \
  '*:file:_files' && ret=0

return ret
