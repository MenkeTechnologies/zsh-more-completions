#compdef terminalizer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a global config directory'
  'config:generate a config file in the current directory'
  'record:record a terminal session'
  'play:play a recorded session'
  'render:render a recording to GIF'
  'share:share a recording online'
  'generate:generate web player for a recording'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'terminalizer command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (record)
        _arguments \
          '-d+[directory to start recording in]:directory:_directories' \
          '--dir=[directory to start recording in]:directory:_directories' \
          '-c+[config file]:config file:_files -g "*.yml"' \
          '--config=[config file]:config file:_files -g "*.yml"' \
          '-k[skip prompts and use defaults]' \
          '--skip-sharing[skip sharing prompt]' \
          '-s+[shell command to record]:command' \
          '--command=[shell command to record]:command' \
          '1:output file:_files -g "*.yml"' && ret=0
        ;;
      (play)
        _arguments \
          '-r[play in real-time speed]' \
          '--real-timing[play in real-time speed]' \
          '-s+[playback speed]:speed' \
          '--speed-factor=[playback speed]:speed' \
          '1:recording file:_files -g "*.yml"' && ret=0
        ;;
      (render)
        _arguments \
          '-o+[output file]:output file:_files -g "*.gif"' \
          '--output=[output file]:output file:_files -g "*.gif"' \
          '-q+[quality (1-100)]:quality' \
          '--quality=[quality (1-100)]:quality' \
          '-s+[number of repeat loops]:count' \
          '--step=[number of repeat loops]:count' \
          '1:recording file:_files -g "*.yml"' && ret=0
        ;;
      (share)
        _arguments '1:recording file:_files -g "*.yml"' && ret=0
        ;;
      (generate)
        _arguments \
          '-o+[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '1:recording file:_files -g "*.yml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
