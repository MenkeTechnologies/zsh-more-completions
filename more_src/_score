#compdef score-compose score-humanitec score-k8s

local -a _score_commands
_score_commands=(
  'init:initialize a score project'
  'generate:generate platform configuration'
  'run:generate and deploy'
  'check:validate score files'
  'resources:manage resources'
  'completion:generate shell completion'
  'help:help about any command'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--quiet[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'score commands' _score_commands
    ;;
  args)
    case "$words[1]" in
      init)
        _arguments \
          '(-f --file)'{-f,--file}'[score file]:file:_files' \
          '--no-sample[do not create sample score file]' \
          '(-p --project)'{-p,--project}'[project directory]:dir:_directories'
        ;;
      generate)
        _arguments \
          '(-f --file)'{-f,--file}'[score file]:file:_files' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--override-file[override file]:file:_files' \
          '--override-property[override property]:property' \
          '(-p --project)'{-p,--project}'[project directory]:dir:_directories' \
          '--image[container image override]:image' \
          '--env-file[environment file]:file:_files' \
          '--build[build context]:context'
        ;;
      run)
        _arguments \
          '(-f --file)'{-f,--file}'[score file]:file:_files' \
          '--override-file[override file]:file:_files' \
          '--override-property[override property]:property' \
          '(-p --project)'{-p,--project}'[project directory]:dir:_directories'
        ;;
      check)
        _arguments \
          '(-f --file)'{-f,--file}'[score file]:file:_files' \
          '--schema-version[schema version]:version'
        ;;
      resources)
        _arguments '1:subcommand:(list get-outputs)'
        ;;
    esac
    ;;
esac
