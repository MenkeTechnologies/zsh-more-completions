#compdef USalign
# Documentation: https://github.com/pylelab/USalign
# US-align - universal structure alignment of proteins, RNAs, DNAs and complexes

local ret=1

_arguments -s -S \
  '-mol[molecule type to align]:type:(auto protein RNA)' \
  '-mm[multimeric alignment mode]:mode' \
  '-ter[terminus handling]:ter' \
  '-TMscore[TM-score superposition mode for complexes]:mode' \
  '-atom[atom name used for alignment]:atom' \
  '-split[split input structures by chain or model]:split' \
  '-chain1[chain ID in structure 1]:chain' \
  '-chain2[chain ID in structure 2]:chain' \
  '-chainmap[enable chain mapping]:map' \
  '-fast[fast but slightly inaccurate fTM-align alignment]' \
  '-byresi[TM-score superposition without re-alignment]:mode' \
  '-cp[circular permutation alignment]' \
  '-mirror[align mirror image of structure 1]:mirror' \
  '-se[sequence order semi-independent alignment]' \
  '-seq[TM-score superposition guided by sequence alignment]' \
  '-infmt1[input format of structure 1]:fmt' \
  '-infmt2[input format of structure 2]:fmt' \
  '-o[output superposed structure to file]:file:_files' \
  '-m[output rotation matrix to file]:file:_files' \
  '-rasmol[output rasmol superposition script]:file:_files' \
  '-chimerax[output UCSF ChimeraX superposition script]:file:_files' \
  '-outfmt[output format]:fmt' \
  '-do[output distances of aligned residue pairs]' \
  '-het[how to handle HETATM records]:het' \
  '-d[TM-score scaled by an assigned d0]:d0' \
  '-dir[align all structures in a directory]:dir:_files -/' \
  '-dir1[directory of structures for input 1]:dir:_files -/' \
  '-dir2[directory of structures for input 2]:dir:_files -/' \
  '*:structure:_files' && ret=0

return ret
