#compdef marian-decoder
# Documentation: https://marian-nmt.github.io/docs/cmd/marian-decoder/
# Marian neural machine translation decoder

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--version[show version number]' \
  '(-c --config)'{-c,--config}'=[load configuration file(s)]:file:_files' \
  '(-w --workspace)'{-w,--workspace}'=[preallocate GPU workspace in MB]:mb' \
  '--log=[write logging information to file]:file:_files' \
  '--log-level=[set verbosity]:level:(trace debug info warn err critical off)' \
  '--seed=[random number generator seed]:seed' \
  '--quiet[suppress stderr logging]' \
  '--quiet-translation[suppress translation logging]' \
  '(-m --models)'{-m,--models}'=[paths to model files]:files:_files' \
  '--type=[model type]:type:(amun nematus s2s multi-s2s transformer)' \
  '--dim-vocabs=[maximum vocabulary size]:n' \
  '--dim-emb=[embedding vector size]:n' \
  '--dim-rnn=[RNN hidden state size]:n' \
  '--enc-type=[encoder type]:type:(bidirectional bi-unidirectional alternating)' \
  '--enc-cell=[RNN cell type]:cell:(gru lstm tanh)' \
  '--dec-cell=[decoder cell type]:cell:(gru lstm tanh)' \
  '--transformer-heads=[multi-head attention heads]:n' \
  '--transformer-dim-ffn=[feed-forward network size]:n' \
  '--layer-normalization[enable layer normalization]' \
  '--tied-embeddings[tie target and output embeddings]' \
  '(-i --input)'{-i,--input}'=[input file path(s)]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file path]:file:_files' \
  '(-v --vocabs)'{-v,--vocabs}'=[vocabulary file paths]:files:_files' \
  '(-b --beam-size)'{-b,--beam-size}'=[beam search size]:n' \
  '(-n --normalize)'{-n,--normalize}'=[length normalization factor]:factor' \
  '--max-length=[maximum sentence length]:n' \
  '--max-length-factor=[maximum target length multiplier]:factor' \
  '--word-penalty=[penalty per word in translation]:val' \
  '--allow-unk[permit unknown words in output]' \
  '--n-best[generate n-best list]' \
  '--alignment=[return word alignment data]:mode' \
  '--tsv[enable tab-separated input format]' \
  '(-d --devices)'{-d,--devices}'=[GPU device IDs to use]:ids' \
  '--cpu-threads=[CPU thread count for computation]:n' \
  '--mini-batch=[batch size for translation]:n' \
  '--mini-batch-words=[batch size by word count]:n' \
  '--fp16[mixed precision with float16]' \
  '--precision=[parameter precision]:prec' \
  '--shortlist=[use softmax shortlist]:file:_files' \
  '--output-sampling[Gumbel noise for output layer]' \
  '*:file:_files' && ret=0

return ret
