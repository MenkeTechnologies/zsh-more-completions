#compdef arch-audit
# Documentation: https://gitlab.archlinux.org/archlinux/arch-audit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '*'{-q,--quiet}'[quiet]' \
  '*'{-r,--recursive}'[recursive]' \
  '(-t --show-testing)'{-t,--show-testing}'[show testing]' \
  '(-u --upgradable)'{-u,--upgradable}'[upgradable only]' \
  '(-C --color)'{-C,--color}'=[color]:mode:(auto always never)' \
  '(-b --dbpath)'{-b,--dbpath}'=[db path]:dir:_files -/' \
  '(-f --format)'{-f,--format}'=[format]:fmt:' \
  '--json[JSON output]' \
  '--source=[security tracker]:src:' \
  '--proxy=[proxy URL]:url:' \
  '--no-proxy[no proxy]' \
  '--sort=[sort fields]:list:' \
  '(-c --show-cve)'{-c,--show-cve}'[show CVEs]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t cmds 'subcommand' '(completions:generate completions)' && ret=0 ;;
  (args)
    case $line[1] in
      (completions) _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0 ;;
    esac ;;
esac

return ret
