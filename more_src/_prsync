#compdef prsync

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-h+,--hosts=}'[hosts file ([user@]host[:port] per line)]:file:_files' \
  {-H+,--host=}'[host string]:host:_hosts' \
  {-l+,--user=}'[username]:user:_users' \
  {-p+,--par=}'[max number of parallel connections]:n:' \
  {-o+,--outdir=}'[output directory for stdout files]:dir:_files -/' \
  {-e+,--errdir=}'[output directory for stderr files]:dir:_files -/' \
  {-t+,--timeout=}'[timeout in seconds]:seconds:' \
  {-O+,--options=}'[SSH options]:options:' \
  {-A,--askpass}'[ask for password]' \
  {-x+,--extra-args=}'[extra command-line arguments]:args:' \
  {-X+,--extra-arg=}'[passthrough single command-line argument]:arg:' \
  {-r,--recursive}'[recursive copy]' \
  {-a,--archive}'[use rsync archive mode]' \
  {-z,--compress}'[use rsync compression]' \
  '1:local:_files' \
  '2:remote:' && ret=0

return ret
