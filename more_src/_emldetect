#compdef emldetect
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/emldetect/node5.html
# XMM-Newton SAS: EPIC maximum likelihood multi-source PSF fitting

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--imagesets=[names of input EPIC fits images or event lists]:files:_files' \
  '--boxlistset=[name of input eboxdetect source list]:file:_files' \
  '--mllistset=[name of output emldetect source list]:file:_files' \
  '--withexpimage=[use exposure maps]:flag:(yes no)' \
  '--expimagesets=[names of exposure maps]:files:_files' \
  '--withdetmask=[use only pixels inside detection mask]:flag:(yes no)' \
  '--detmasksets=[names of detection masks]:files:_files' \
  '--bkgimagesets=[names of background images]:files:_files' \
  '--withsourcemap=[write source maps]:flag:(yes no)' \
  '--sourceimagesets=[names of source maps]:files:_files' \
  '--mergedlistset=[name of merged source list]:file:_files' \
  '--mlmin=[minimum detection likelihood threshold]:like:' \
  '--dmlextmin=[required likelihood improvement for extent]:thresh:' \
  '--scut=[source selection radius]:radius:' \
  '--ecut=[source cut-out radius for PSF-fitting]:radius:' \
  '--ecf=[energy conversion factors]:ecf:' \
  '--xidecf=[XID-band energy conversion factors]:ecf:' \
  '--useevents=[photon mode flag]:flag:(yes no)' \
  '--fitposition=[fit source positions]:flag:(yes no)' \
  '--fitextent=[fit source extent]:flag:(yes no)' \
  '--fitcounts=[fit source counts]:flag:(yes no)' \
  '--fitnegative=[allow negative fitted count rates]:flag:(yes no)' \
  '--determineerrors=[determine statistical errors]:flag:(yes no)' \
  '--withxidband=[write XID band output]:flag:(yes no)' \
  '--usecalpsf=[read PSF from calibration database]:flag:(yes no)' \
  '--extentmodel=[model function for source extent]:model:(gaussian beta)' \
  '--psfmodel=[model PSF]:model:' \
  '--minextent=[minimum allowed extent parameter]:value:' \
  '--maxextent=[maximum allowed extent parameter]:value:' \
  '--withhotpixelfilter=[ignore brightest pixel contribution]:flag:(yes no)' \
  '--nmaxfit=[max neighbouring sources for fitting]:n:' \
  '--nmulsou=[allow splitting source into multiple]:n:' \
  '--pimin=[lower energy boundaries of images]:ev:' \
  '--pimax=[upper energy boundaries of images]:ev:' \
  '--xidfixed=[run on XID-band with fixed positions]:flag:(yes no)' \
  '--withthreshold=[multi-PSF fitting only above threshold]:flag:(yes no)' \
  '--threshold=[threshold value for multi-PSF fitting]:value:' \
  '--threshcolumn=[input column for threshold]:col:' \
  '--withtwostage=[use two-stage multi-PSF fitting]:flag:(yes no)' \
  '--imagebuffersize=[memory requirements parameter]:size:' \
  '--withimagebuffersize=[allow user-defined imagebuffersize]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
