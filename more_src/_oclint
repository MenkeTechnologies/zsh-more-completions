#compdef oclint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*-rc=[set rule configuration]:NAME=VALUE:' \
  '-max-priority-1=[max P1 violations]:n:' \
  '-max-priority-2=[max P2 violations]:n:' \
  '-max-priority-3=[max P3 violations]:n:' \
  '-disable-rule=[disable a rule]:rule:' \
  '-enable-rule=[enable a rule]:rule:' \
  '-rule=[load specific rules]:rule:' \
  '-rules-path=[directory with rules]:dir:_files -/' \
  '-disable-clang-static-analyzer[disable clang static analyzer]' \
  '-enable-clang-static-analyzer[enable clang static analyzer]' \
  '-enable-global-analysis[enable analysis across translation units]' \
  '-allow-duplicated-violations[allow duplicate violations]' \
  '-list-enabled-rules[list enabled rules]' \
  '-list-disabled-rules[list disabled rules]' \
  '-no-analytics[disable analytics]' \
  '-o=[output file]:file:_files' \
  '-p=[compile_commands.json directory]:dir:_files -/' \
  '-report-type=[report format]:format:(text html xml json pmd)' \
  '-extra-arg=[extra clang arg]:arg:' \
  '-extra-arg-before=[extra clang arg before]:arg:' \
  '-include=[include path]:path:_files' \
  '-i=[ignore path regex]:regex:' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|m|mm|h|hpp|hxx)"' && ret=0

return ret
