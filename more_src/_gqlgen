local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
    'init:initialize gqlgen config and generate models'
    'generate:generate code from GraphQL schema'
    'version:show gqlgen version'
    'completion:generate shell completion'
    'help:show help for any command'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--config=[gqlgen config file]:file:_files -g "gqlgen.{yml,yaml}"' \
    '--verbose[verbose output]' \
    '1: :->cmd' \
    '*::arg:->args' && ret=0

case $state in
    (cmd) _describe -t cmds 'gqlgen command' commands && ret=0 ;;
    (args)
        case $line[1] in
            (init)
                _arguments \
                    '--config=[config file path]:file:_files' \
                    '--server=[server output file]:file:_files' \
                    '--schema=[schema output file]:file:_files' && ret=0 ;;
            (generate)
                _arguments \
                    '--config=[config file path]:file:_files -g "gqlgen.{yml,yaml}"' \
                    '--verbose[verbose output]' && ret=0 ;;
            (completion)
                _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
        esac ;;
esac

return ret
