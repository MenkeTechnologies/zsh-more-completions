#compdef jco

local curcontext="$curcontext" state line ret=1

_jco_commands() {
  local -a commands=(
    'transpile:transpile a WebAssembly component to JS'
    'run:run a WebAssembly component'
    'serve:serve a WebAssembly HTTP component'
    'componentize:create a component from a JS module'
    'new:create a new component project'
    'wit:extract or create WIT definitions'
    'types:generate TypeScript types for a component'
    'stubgen:generate stub implementations'
    'embed:embed component type information'
  )
  _describe -t commands 'jco command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:_jco_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      transpile)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-dir)'{-o,--out-dir}'[output directory]:dir:_files -/' \
          '(-n --name)'{-n,--name}'[component name]:name' \
          '*--map[map an import]:mapping' \
          '--instantiation[instantiation mode]:mode:(async sync)' \
          '--valid-lifting-optimization[enable valid lifting optimization]' \
          '--tracing[enable tracing]' \
          '--no-wasi-shim[disable WASI shim]' \
          '--no-namespaced-exports[disable namespaced exports]' \
          '--multi-memory[enable multi-memory support]' \
          '--tla-compat[enable top-level await compatibility]' \
          '--base64-cutoff[base64 encoding cutoff size]:size' \
          '--js[generate JS output instead of MJS]' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      componentize)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-dir)'{-o,--out-dir}'[output directory]:dir:_files -/' \
          '*:js module:_files -g "*.(js|mjs)"' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:project name' && ret=0
        ;;
      wit)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-dir)'{-o,--out-dir}'[output directory]:dir:_files -/' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      types)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-dir)'{-o,--out-dir}'[output directory]:dir:_files -/' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      stubgen)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-dir)'{-o,--out-dir}'[output directory]:dir:_files -/' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      embed)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
    esac
    ;;
esac

return ret
