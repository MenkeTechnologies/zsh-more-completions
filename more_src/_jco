#compdef jco
# Documentation: https://github.com/bytecodealliance/jco
# Reference accessed: 2026-05-19
# Verified: jco --help / jco transpile --help / jco componentize
# --help from @bytecodealliance/jco (npx).

local curcontext="$curcontext" state line ret=1

_jco_commands() {
  local -a commands=(
    'componentize:create a component from a JavaScript module'
    'transpile:transpile a WebAssembly component to JS + core Wasm'
    'types:generate types for the given WIT'
    'guest-types:(experimental) generate guest types for the given WIT'
    'run:run a WASI Command component'
    'serve:serve a WASI HTTP component'
    'opt:optimize a Wasm component (wasm-opt)'
    'wit:extract the WIT from a WebAssembly component'
    'print:print the WebAssembly WAT text for a binary file'
    'metadata-show:extract producer metadata for a Wasm binary'
    'metadata-add:add producer metadata for a Wasm binary'
    'parse:parse the Wasm text format into a binary file'
    'new:create a component adapted from a core Wasm module'
    'embed:embed the component typing section into a core Wasm module'
    'help:display help for command'
  )
  _describe -t commands 'jco command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[display help for command]' \
  '(- *)'{-V,--version}'[output the version number]' \
  '1:command:_jco_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      transpile)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--name=[custom output name]:name:' \
          '(-o --out-dir)'{-o,--out-dir}'=[output directory]:dir:_files -/' \
          '(-m --minify)'{-m,--minify}'[minify the JS output]' \
          '(-O --optimize)'{-O,--optimize}'[optimize the component first]' \
          '--no-typescript[do not output TypeScript .d.ts types]' \
          '--valid-lifting-optimization[optimize binary validations]' \
          '--import-bindings=[bindings mode for imports]:mode:(js optimized hybrid direct-optimized)' \
          '--async-mode=[use async imports and exports]:mode:(sync jspi)' \
          '--async-wasi-imports[async component imports from WASI interfaces]' \
          '--async-wasi-exports[async component exports from WASI interfaces]' \
          '*--async-imports=[async component imports]:imports:' \
          '*--async-exports=[async component exports]:exports:' \
          '--tracing[emit tracing calls on function entry/exit]' \
          '(-b --base64-cutoff)'{-b,--base64-cutoff}'=[inline core Wasm under this byte size as base64]:bytes:' \
          '--tla-compat[enable compatibility for environments without top-level await]' \
          '--no-nodejs-compat[disable Node.js compatibility without a fetch global]' \
          '*'{-M,--map}'=[specifier=./output custom import mappings]:mapping:' \
          '--no-wasi-shim[disable automatic WASI import rewriting]' \
          '--stub[generate a stub implementation from a WIT file]' \
          '--js[output JS instead of core WebAssembly]' \
          '(-I --instantiation)'{-I,--instantiation}'=[output for custom module instantiation]:mode:(async sync)' \
          '(-q --quiet)'{-q,--quiet}'[disable output summary]' \
          '--no-namespaced-exports[disable namespaced exports for typescript]' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      componentize)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-w --wit)'{-w,--wit}'=[WIT path to build with]:path:_files' \
          '(-n --world-name)'{-n,--world-name}'=[WIT world to build]:name:' \
          '--aot[enable Weval AOT compilation of JS]' \
          '--aot-min-stack-size-bytes=[min stack size used during AOT]:number:' \
          '--weval-bin=[custom weval binary to use]:path:_files' \
          '*'{-d,--disable}'=[disable WASI features]:feature:(clocks http random stdio fetch-event all)' \
          '*--enable=[enable WASI features]:feature:(clocks http random stdio fetch-event all)' \
          '--debug[configure jco for debug]' \
          '--preview2-adapter=[custom preview2 adapter path]:path:_files' \
          '--engine=[use a specific StarlingMonkey build]:path:_files' \
          '(-o --out)'{-o,--out}'=[output component file]:file:_files' \
          '*:js source:_files -g "*.(js|mjs)"' && ret=0
        ;;
      run|serve)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:wasm component:_files -g "*.wasm"' && ret=0
        ;;
      types|guest-types|wit)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-dir)'{-o,--out-dir}'=[output directory]:dir:_files -/' \
          '*:path:_files' && ret=0
        ;;
      opt|new|embed|print|parse|metadata-show|metadata-add)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
