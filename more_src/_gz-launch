#compdef gz-launch
# Documentation: https://gazebosim.org/docs
# Gazebo launch file runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-all[show all help]' \
  '--version[display version information]' \
  '(-v --verbose)'{-v,--verbose}'=[verbose level]:level:(0 1 2 3 4)' \
  '*:launch file:_files' && ret=0

return ret
