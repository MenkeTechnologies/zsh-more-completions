#compdef rails_best_practices
# Documentation: https://github.com/flyerhzm/rails_best_practices
# code metric tool for Rails projects

local ret=1

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[enable debug mode with stack traces]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(html text yml)' \
  '--without-color[output plain text without color]' \
  '--with-textmate[open files in TextMate from HTML output]' \
  '--with-vscode[open files in VS Code from HTML output]' \
  '--with-sublime[open files in Sublime Text from HTML output]' \
  '--with-mvim[open files in MacVim from HTML output]' \
  '--with-github=[link to GitHub repository]:repo' \
  '--with-hg[display Mercurial commit and username]' \
  '--with-git[display Git commit and username]' \
  '--last-modified[only analyze last modified files]' \
  '--revision=[git revision to analyze]:revision' \
  '--template=[custom ERB template for output]:template:_files' \
  '--output-file=[HTML output file location]:file:_files' \
  '--silent[suppress output messages]' \
  '--vendor[include vendor directory files]' \
  '--spec[include spec directory files]' \
  '--test[include test directory files]' \
  '--features[include features directory files]' \
  '(-e --exclude)'{-e+,--exclude=}'[exclude directories or patterns]:patterns' \
  '(-o --only)'{-o+,--only=}'[analyze only matching file patterns]:patterns' \
  '(-g --generate)'{-g,--generate}'[generate configuration YAML file]' \
  '(-c --config)'{-c+,--config=}'[configuration file location]:config:_files' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:path:_files' && ret=0

return ret
