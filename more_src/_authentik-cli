#compdef authentik-cli authentikctl ak
# _authentik-cli — Goauthentik authentik-cli authentikctl ak CLI command-line frontend wrapping the authentik Identity Provider self-hosted SSO MFA portal supporting LDAP RADIUS SAML OIDC OAuth2 SCIM provisioning user group enrollment application source provider policy event-listeners flow-stage-binding token-creation events (Goauthentik team, Python); click
# upstream: https://goauthentik.io/

_authentik-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user operations'
        'group:group operations'
        'application:application operations'
        'source:source operations'
        'provider:provider operations'
        'flow:authentication flow operations'
        'stage:stage operations'
        'policy:policy operations'
        'event:event operations'
        'token:token operations'
        'tenant:tenant operations'
        'outpost:outpost operations'
        'crypto:crypto certificate operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--token=+[token]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml table csv)' \
        '--format=+[format]:f:(json yaml table csv)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'authentik-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|group|application|source|provider|flow|stage|policy|tenant|outpost|crypto|token|event) _arguments '1:op:(list get create update delete enable disable bind unbind)' '*:id:' ;;
            esac
            ;;
    esac
}

_authentik-cli "$@"
