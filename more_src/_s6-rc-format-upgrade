#compdef s6-rc-format-upgrade
# _s6-rc-format-upgrade — s6-rc format-upgrade helper (in-place upgrade of a live /run/s6-rc/compiled directory when the s6-rc on-disk format changes between versions)
# upstream: https://github.com/skarnet/s6-rc
# Flags from src/s6-rc/s6-rc-format-upgrade.c on tip.

_s6-rc-format-upgrade() {
    _arguments \
        '-v+[verbosity (default 1)]:n:' \
        '-t+[timeout (ms)]:ms:' \
        '-l+[live directory (default /run/s6-rc)]:dir:_files -/' \
        '-b[only check (do not perform upgrade)]' \
        '1:newdb:_files -/'
}

_s6-rc-format-upgrade "$@"
