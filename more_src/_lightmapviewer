#compdef lightmapviewer
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--print[print the content of the lightmap]' \
  '--extract[extract lightmap contents to current dir]' \
  '*:input lightmap file:_files' && ret=0

return ret
