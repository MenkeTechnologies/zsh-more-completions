#compdef fastq_to_fasta
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastq_to_fasta.1.en.html
# FASTX-Toolkit: convert a FASTQ file to FASTA format

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-r[rename sequence identifiers to numbers]' \
  '-n[keep sequences with unknown (N) nucleotides]' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA output file (default STDOUT)]:output file:_files' && ret=0

return ret
