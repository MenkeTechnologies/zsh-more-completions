#compdef mysqltuner mysqltuner.pl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--port=[MySQL port]:port:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--user=[MySQL username]:username:' \
  '--pass=[MySQL password]:password:' \
  '--defaults-file=[defaults file]:file:_files' \
  '--mysqladmin=[path to mysqladmin]:mysqladmin:_files' \
  '--mysqlcmd=[path to mysql]:mysql:_files' \
  '--forcemem=[amount of RAM in MB]:megabytes:' \
  '--forceswap=[amount of swap in MB]:megabytes:' \
  '--skipsize[skip sizing recommendations]' \
  '--skippassword[skip password checks]' \
  '--checkversion[check for updates]' \
  '--updateversion[update MySQLTuner]' \
  '--buffers[show buffer information]' \
  '--dbstat[show database statistics]' \
  '--idxstat[show index statistics]' \
  '--sysstat[show system statistics]' \
  '--pfstat[show performance schema statistics]' \
  '--bannedports=[banned ports]:ports:' \
  '--maxportallowed=[max port allowed]:port:' \
  '--outputfile=[output file]:file:_files' \
  '--json[output as JSON]' \
  '--prettyjson[output as pretty JSON]' \
  '--silent[silent mode]' \
  '--nogood[remove OK recommendations]' \
  '--noinfo[remove informational recommendations]' \
  '--nocolor[disable color output]' \
  '--noprocess[skip process list]' \
  '--notbstat[skip table statistics]' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' \
  '--template=[report template]:template:' \
  '--cvefile=[CVE file]:file:_files' && ret=0

return ret
