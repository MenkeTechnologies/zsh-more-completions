#compdef mysqltuner mysqltuner.pl
# Documentation: https://github.com/major/MySQLTuner-perl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--port=[MySQL port]:port:' \
  '(-u --user)'{-u,--user=}'[MySQL username]:username:' \
  '(-p --pass --password)'{-p,--pass=,--password=}'[MySQL password]:password:' \
  '--userenv=[env var holding username]:env var:' \
  '--passenv=[env var holding password]:env var:' \
  '--ssl-ca=[SSL CA file]:file:_files' \
  '--protocol=[MySQL connection protocol]:protocol:' \
  '--defaults-file=[my.cnf defaults file]:file:_files' \
  '--defaults-extra-file=[extra defaults file]:file:_files' \
  '--login-path=[mysql_config_editor login path]:path:' \
  '--mysqladmin=[path to mysqladmin]:mysqladmin:_files' \
  '--mysqlcmd=[path to mysql]:mysql:_files' \
  '--server-log=[path to MySQL server log]:file:_files' \
  '(--pipe --nopipe)'{--pipe,--nopipe}'[use named pipes (Windows)]' \
  '--pipe_name=[named pipe name]:name:' \
  '--forcemem=[force amount of RAM (MB)]:megabytes:' \
  '--forceswap=[force amount of swap (MB)]:megabytes:' \
  '(--skipsize --noskipsize)'{--skipsize,--noskipsize}'[skip sizing recommendations]' \
  '(--skippassword --noskippassword)'{--skippassword,--noskippassword}'[skip password security checks]' \
  '--passwordfile=[password dictionary file]:file:_files' \
  '--max-password-checks=[max passwords to test]:count:' \
  '(--checkversion --nocheckversion)'{--checkversion,--nocheckversion}'[check for tuner updates]' \
  '(--updateversion --noupdateversion)'{--updateversion,--noupdateversion}'[update MySQLTuner script]' \
  '(--buffers --nobuffers)'{--buffers,--nobuffers}'[show global/per-thread buffers]' \
  '(--dbstat --nodbstat)'{--dbstat,--nodbstat}'[per-database statistics]' \
  '(--tbstat --notbstat)'{--tbstat,--notbstat}'[per-table statistics]' \
  '(--colstat --nocolstat)'{--colstat,--nocolstat}'[per-column statistics]' \
  '(--idxstat --noidxstat)'{--idxstat,--noidxstat}'[per-index statistics]' \
  '(--sysstat --nosysstat)'{--sysstat,--nosysstat}'[system statistics]' \
  '(--pfstat --nopfstat)'{--pfstat,--nopfstat}'[performance_schema statistics]' \
  '(--plugininfo --noplugininfo)'{--plugininfo,--noplugininfo}'[plugin information]' \
  '(--myisamstat --nomyisamstat)'{--myisamstat,--nomyisamstat}'[MyISAM statistics]' \
  '(--structstat --nostructstat)'{--structstat,--nostructstat}'[schema structure stats]' \
  '(--noprocess)--noprocess[skip processlist analysis]' \
  '(--nondedicated)--nondedicated[non-dedicated database server]' \
  '(--experimental)--experimental[enable experimental checks]' \
  '--cvefile=[CVE list file]:file:_files' \
  '--sysbench-file=[sysbench results file]:file:_files' \
  '--compare-file=[JSON file to compare against]:file:_files' \
  '--outputfile=[stdout capture file]:file:_files' \
  '--reportfile=[final report file]:file:_files' \
  '--template=[report template]:template file:_files' \
  '--dumpdir=[directory for dumps]:dir:_directories' \
  '--schemadir=[schema audit directory]:dir:_directories' \
  '--feature=[only run specific feature]:feature:' \
  '--dbgpattern=[debug regex pattern]:pattern:' \
  '(--json --nojson)'{--json,--nojson}'[JSON output]' \
  '(--prettyjson --noprettyjson)'{--prettyjson,--noprettyjson}'[pretty JSON output]' \
  '(--silent --nosilent)'{--silent,--nosilent}'[silent mode]' \
  '(--nobad)--nobad[hide BAD recommendations]' \
  '(--nogood)--nogood[hide OK recommendations]' \
  '(--noinfo)--noinfo[hide informational recommendations]' \
  '(--color --nocolor)'{--color,--nocolor}'[colored output]' \
  '(--noprettyicon)--noprettyicon[plain icons]' \
  '(-v --verbose --noverbose)'{-v,--verbose,--noverbose}'[verbose output]' \
  '(--debug --nodebug)'{--debug,--nodebug}'[debug output]' \
  '(--cloud --nocloud)'{--cloud,--nocloud}'[cloud provider mode]' \
  '(--azure --noazure)'{--azure,--noazure}'[Azure provider mode]' \
  '--ssh-host=[SSH host]:hostname:_hosts' \
  '--ssh-user=[SSH username]:username:' \
  '--ssh-password=[SSH password]:password:' \
  '--ssh-identity-file=[SSH identity file]:file:_files' \
  '--container=[container name]:container:' \
  '--ignore-tables=[tables to ignore]:tables:' \
  '--bannedports=[banned ports list]:ports:' \
  '--maxportallowed=[max port allowed]:port:' \
  '--defaultarch=[default architecture (32/64)]:arch:(32 64)' \
  '(--noask)--noask[do not prompt for input]' && ret=0

return ret
