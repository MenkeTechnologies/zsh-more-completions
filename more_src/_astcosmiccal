#compdef astcosmiccal
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astcosmiccal.html
# astcosmiccal — perform cosmological calculations

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '--cite[show BibTeX citation for this program]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for this directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for this user]' \
  '--config[read configuration file immediately]:file:_files' \
  '(-H --H0)'{-H,--H0}'[current expansion rate (Hubble constant)]:value' \
  '(-l --olambda)'{-l,--olambda}'[cosmological constant density per critical density]:value' \
  '(-m --omatter)'{-m,--omatter}'[matter density per critical density]:value' \
  '(-r --oradiation)'{-r,--oradiation}'[radiation density per critical density]:value' \
  '(-z --redshift)'{-z,--redshift}'[redshift of interest]:redshift' \
  '(-y --velocity)'{-y,--velocity}'[velocity of interest in km/s]:velocity' \
  '(-O --obsline)'{-O,--obsline}'[redshift from spectral line and observed wavelength]:line' \
  '(-a --absmagconv)'{-a,--absmagconv}'[conversion to absolute magnitude]' \
  '(-A --angulardimdist)'{-A,--angulardimdist}'[angular diameter distance (Mpc)]' \
  '(-b --lookbacktime)'{-b,--lookbacktime}'[look back time to redshift (Gyr)]' \
  '(-c --criticaldensity)'{-c,--criticaldensity}'[critical density at redshift]' \
  '(-C --criticaldensitynow)'{-C,--criticaldensitynow}'[critical density now]' \
  '(-d --properdistance)'{-d,--properdistance}'[proper distance to redshift (Mpc)]' \
  '(-e --usedredshift)'{-e,--usedredshift}'[used redshift in this run]' \
  '(-g --age)'{-g,--age}'[age of universe at redshift (Gyr)]' \
  '(-G --agenow)'{-G,--agenow}'[age of universe now (Gyr)]' \
  '(-L --luminositydist)'{-L,--luminositydist}'[luminosity distance to redshift (Mpc)]' \
  '(-s --arcsectandist)'{-s,--arcsectandist}'[tangential distance of 1 arcsec at redshift (kpc)]' \
  '(-u --distancemodulus)'{-u,--distancemodulus}'[distance modulus at redshift]' \
  '(-v --volume)'{-v,--volume}'[comoving volume to redshift (Mpc^3)]' \
  '(-Y --usedvelocity)'{-Y,--usedvelocity}'[used velocity (km/s) for this run]' \
  '(-i --lineatz)'{-i,--lineatz}'[wavelength of line at redshift]:line' \
  '--listlines[list known spectral lines and rest wavelengths]' \
  '--listlinesatz[list known spectral lines at given redshift]' && ret=0

return ret
