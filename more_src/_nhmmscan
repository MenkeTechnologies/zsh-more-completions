#compdef nhmmscan
# Documentation: https://man.archlinux.org/search?q=nhmmscan
# Reference accessed: 2026-05-16

# HMMER nhmmscan: search nucleic-acid sequence against nhmmer HMM database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output file]:file:_files' \
  '--tblout[per-target hits table]:file:_files' \
  '--dfamtblout[Dfam-style table]:file:_files' \
  '--aliscoresout[per-alignment scores file]:file:_files' \
  '--acc[show accessions]' \
  '--noali[no alignments]' \
  '-E[reporting E-value]:Eval:' \
  '-T[reporting score]:bits:' \
  '--incE[inclusion E-value]:Eval:' \
  '--incT[inclusion score]:bits:' \
  '--cut_ga[GA cutoffs]' \
  '--cut_nc[NC cutoffs]' \
  '--cut_tc[TC cutoffs]' \
  '--max[no filters]' \
  '--nobias[no bias filter]' \
  '--toponly[only top strand]' \
  '--bottomonly[only bottom strand]' \
  '--seed[random seed]:n:' \
  '--qformat[input format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam)' \
  '--cpu[CPU threads]:n:' \
  '*:HMM database and sequence file:_files' && ret=0
return ret
