#compdef NVEncC NVEncC64
# Documentation: https://github.com/rigaya/NVEnc/blob/master/NVEncC_Options.en.md
# rigaya NVENC-based hardware video encoder (H.264/HEVC/AV1)

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,-\?,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--option-list[list all available options]' \
  '--check-device[show available GPU devices]' \
  '--check-hw[verify GPU encoding capability]' \
  '--check-features[display GPU feature information]' \
  '(-i --input)'{-i,--input}'+[set input filename]:file:_files' \
  '(-o --output)'{-o,--output}'+[set output filename]:file:_files' \
  '(-d --device)'{-d,--device}'+[GPU device ID]:id:' \
  '(-c --codec)'{-c,--codec}'+[output codec]:codec:(h264 hevc av1 raw)' \
  '--raw[read raw YUV input]' \
  '--y4m[read Y4M input]' \
  '--avs[read Avisynth script]' \
  '--vpy[read VapourSynth script]' \
  '--avhw[hardware decode with GPU]' \
  '--avsw=[software decode with libavcodec]:codec:' \
  '--qvbr=[constant quality mode]:value:' \
  '--cbr=[constant bitrate kbps]:kbps:' \
  '--vbr=[variable bitrate kbps]:kbps:' \
  '--cqp=[QP values for I:P:B frames]:qp:' \
  '(-u --preset)'{-u,--preset}'+[quality preset]:preset:(default performance quality P1 P2 P3 P4 P5 P6 P7)' \
  '--tune=[encoder tuning]:tune:(hq uhq lowlatency ultralowlatency lossless)' \
  '--profile=[codec profile]:profile:' \
  '--level=[codec level]:level:' \
  '--output-depth=[bit depth]:depth:(8 10)' \
  '--output-csp=[color space]:csp:(yuv420 yuv422 yuv444 rgb)' \
  '--max-bitrate=[maximum bitrate kbps]:kbps:' \
  '--vbv-bufsize=[VBV buffer size kbps]:kbps:' \
  '--multipass=[multipass mode]:mode:(none 2pass-quarter 2pass-full)' \
  '--gop-len=[maximum GOP length]:len:' \
  '(-b --bframes)'{-b,--bframes}'+[consecutive B frames]:n:' \
  '--ref=[reference frame distance]:n:' \
  '--lookahead=[lookahead frame range]:n:' \
  '--audio-copy[copy audio tracks]' \
  '--audio-codec=[encode audio with codec]:codec:' \
  '--audio-bitrate=[audio bitrate kbps]:kbps:' \
  '--audio-samplerate=[audio sampling frequency]:hz:' \
  '--vpp-deinterlace=[deinterlacing]:mode:(none normal bob)' \
  '--vpp-resize=[resize filter]:filter:' \
  '--vpp-colorspace[color space conversion]' \
  '--vpp-denoise-dct[DCT-based noise reduction]' \
  '(-f --output-format)'{-f,--output-format}'+[mux format]:format:' \
  '--colormatrix=[color matrix]:matrix:(bt709 smpte170m)' \
  '--transfer=[transfer characteristic]:transfer:' && ret=0

return ret
