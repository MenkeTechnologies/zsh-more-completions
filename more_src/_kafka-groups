#compdef kafka-groups

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--list[List all groups]'
    '--describe[Describe a group]'
    '--delete[Delete a group]'
    '--group[Group ID]:group:'
    '--all-groups[Apply to all groups]'
    '--members[Describe members of the group]'
    '--offsets[Describe the group and list all topic partitions and their offsets]'
    '--state[Filter by group state]:state:'
    '--type[Filter by group type]:type:'
    '--verbose[Provide additional information if available]'
)

_arguments -s -S $arguments
