#compdef fbterm

# Zsh completion for fbterm - fast framebuffer based terminal emulator

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-n,--font-names}'[specify font names]:font name:' \
  {-s,--font-size}'[specify font size]:font size:' \
  '--font-width[specify font width]:font width:' \
  '--font-height[specify font height]:font height:' \
  '--color-foreground[foreground color index]:color index (0-255):' \
  '--color-background[background color index]:color index (0-255):' \
  '--text-encodings[specify text encodings]:encodings:' \
  '--cursor-shape[cursor shape]:shape:(0 1 2)' \
  '--cursor-interval[cursor blink interval in ms]:interval (ms):' \
  '--screen-rotate[screen rotation]:rotation:(0 1 2 3)' \
  {-i,--input-method}'[specify input method]:input method name:' \
  '--ambiguous-wide[treat ambiguous-width characters as wide]' \
  '--:command to run:_command_names -e'
