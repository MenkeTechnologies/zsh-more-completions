#compdef appium2 appium-cli
# _appium2 — Appium project appium2 CLI command-line frontend for the Appium 2 cross-platform mobile-automation server supporting iOS Android driver-management UIAutomator2 XCUITest Espresso WebDriverIO server plugin install update list activate deactivate downloading drivers plugins for mobile-app testing (Appium team, JavaScript); commander
# upstream: https://appium.io/

_appium2() {
    local -a sub=(
        'server:start the Appium server'
        'driver:driver management'
        'plugin:plugin management'
        'setup:initial setup'
        'extension:extension management'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--log-level=+[l]:l:(debug info warn error fatal)' \
        '--address=+[host]:_hosts' \
        '-a+[address]:_hosts' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--base-path=+[path]:str:' \
        '--callback-address=+[host]:_hosts' \
        '--callback-port=+[port]:n:' \
        '--allow-cors[allow CORS]' \
        '--allow-insecure=+[features]:str:' \
        '--deny-insecure=+[features]:str:' \
        '--config=+[file]:file:_files -g "*.json *.yaml *.yml *.toml"' \
        '--driver=+[driver]:d:(uiautomator2 espresso xcuitest mac2 windows safari chromium gecko)' \
        '--use-drivers=+[list]:str:' \
        '--use-plugins=+[list]:str:' \
        '--default-capabilities=+[file]:file:_files' \
        '--no-perms-check[no perms check]' \
        '--strict-caps[strict capabilities]' \
        '--keep-alive-timeout=+[sec]:n:' \
        '--session-override[override existing sessions]' \
        '--tmp-dir=+[dir]:dir:_files -/' \
        '--log-no-colors[no log colors]' \
        '--log-timestamp[timestamp log]' \
        '--log-filters=+[file]:file:_files' \
        '--debug-log-spacing[debug log spacing]' \
        '--allow-cors[allow CORS]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appium subcommand' sub ;;
        args)
            case $words[1] in
                driver|plugin) _arguments \
                    '1:op:(install uninstall update list run)' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_appium2 "$@"
