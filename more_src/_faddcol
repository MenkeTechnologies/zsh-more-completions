#compdef faddcol
# Copies a list of columns from one FITS table extension to another

local ret=1

_arguments -s \
  "infile=[FITS file to which columns are added]:file:_files" \
  "colfile=[FITS file from which columns are taken]:file:_files" \
  "colname=[list of column names to copy]:" \
  "delkey=[delete matching keywords first]:bool:(yes no)" \
  "history=[add HISTORY keywords]:bool:(yes no)" \
  "casesen=[case sensitive column names]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
