#compdef tendermint

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--home=[Node home directory]:directory:_directories' \
  '--log_level=[Log level filter]:level:' \
  '--log_format=[Log format]:format:(plain json)' \
  '--trace[Dump INFO logs to STDERR]' \
  '--genesis=[Genesis JSON path]:file:_files' \
  '--node=[Remote node RPC]:url:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:Initialize configuration'
      'node:Run full node'
      'unsafe_reset_all:Wipe blockchain data'
      'unsafe_reset_priv_validator:Reset signing state'
      'show:Dump node state'
      'testnet:Create testnet files'
      'version:Print version'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
