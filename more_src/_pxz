#compdef pxz
# Documentation: https://man.archlinux.org/search?q=pxz
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-z --compress)'{-z,--compress}'[compress mode]' \
  '(-d --decompress)'{-d,--decompress}'[decompress mode]' \
  '(-t --test)'{-t,--test}'[test compressed file]' \
  '(-l --list)'{-l,--list}'[list info]' \
  '(-c --stdout)'{-c,--stdout}'[write to stdout]' \
  '(-k --keep)'{-k,--keep}'[keep original]' \
  '(-f --force)'{-f,--force}'[force]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-T --threads)'{-T,--threads}'+[number of threads]:n:' \
  '(-0)-0[fastest]' \
  '(-1)-1[level 1]' \
  '(-2)-2[level 2]' \
  '(-3)-3[level 3]' \
  '(-4)-4[level 4]' \
  '(-5)-5[level 5]' \
  '(-6)-6[level 6 (default)]' \
  '(-7)-7[level 7]' \
  '(-8)-8[level 8]' \
  '(-9 --best)'{-9,--best}'[best compression]' \
  '(-e --extreme)'{-e,--extreme}'[try harder]' \
  '*:file:_files' && ret=0

return ret
