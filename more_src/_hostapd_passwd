#compdef wpa_passphrase hostapd_passwd
# _hostapd_passwd — hostapd wpa_passphrase / hostapd_passwd (helper utilities for generating WPA2/3 PSK records; wpa_passphrase prints a wpa_supplicant.conf-style "network={...}" stanza from an SSID + passphrase, hostapd_passwd hashes a SAE password for hostapd.conf; positional ssid then passphrase via arg or stdin)
# upstream: https://w1.fi/cgit/hostap (wpa_passphrase + hostapd-tools)
# Argument shape from w1.fi/hostap wpa_passphrase.c on tip.

_hostapd_passwd() {
    _arguments \
        '1:SSID:' \
        '2:passphrase:'
}

_hostapd_passwd "$@"
