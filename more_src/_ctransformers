#compdef ctransformers
# _ctransformers — Ravindra Marella ctransformers Python binding for GGML transformers running quantized LLMs locally with GPT-2/J/NeoX MPT Falcon StarCoder Llama Mistral support (marella team, Python); argparse
# upstream: https://github.com/marella/ctransformers

_ctransformers() {
    local -a sub=(
        'generate:generate text'
        'embed:compute embeddings'
        'tokenize:tokenize text'
        'detokenize:detokenize ids'
        'serve:start HTTP server'
        'list-models:list supported models'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-m+[model file or hub id]:str:' \
        '--model=+[model file or hub id]:str:' \
        '--model-type=+[type]:t:(gpt2 gptj gptneox dolly-v2 starcoder falcon llama mpt replit gpt-bigcode mistral)' \
        '--model-file=+[file]:file:_files -g "*.bin *.gguf *.ggml"' \
        '--lib=+[file]:file:_files -g "*.dll *.so *.dylib"' \
        '--config-file=+[file]:file:_files -g "*.json"' \
        '--gpu-layers=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--top-k=+[N]:n:' \
        '--top-p=+[F]:f:' \
        '--temperature=+[F]:f:' \
        '--repetition-penalty=+[F]:f:' \
        '--last-n-tokens=+[N]:n:' \
        '--seed=+[N]:n:' \
        '--batch-size=+[N]:n:' \
        '--context-length=+[N]:n:' \
        '--max-new-tokens=+[N]:n:' \
        '--stop=+[csv]:str:' \
        '--stream[stream output]' \
        '--reset[reset between gens]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ctransformers subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments '*:prompt:' ;;
                serve) _arguments \
                    '--host=+[host]:str:' \
                    '--port=+[port]:n:' ;;
            esac
            ;;
    esac
}

_ctransformers "$@"
