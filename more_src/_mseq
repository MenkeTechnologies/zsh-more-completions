#compdef mseq

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-S[set the sequence from stdin]' \
  '-A[append to the sequence from stdin]' \
  '-C[set current message]:message number:' \
  '-f[print only filenames]' \
  '-r[reverse the sequence]' \
  '-n[print message numbers]' \
  '*:message range:' && ret=0

return ret
