#compdef xplus4
# Documentation: https://vice-emu.sourceforge.io/vice_3.html
# Reference accessed: 2026-05-16

# xplus4: VICE Plus/4 and C16 emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '(- *)-?[show help]' \
  '+confirmonexit[confirm on exit]' \
  '-confirmonexit[no confirm on exit]' \
  '+saveres[save resources on exit]' \
  '-saveres[do not save resources on exit]' \
  '-config[config file]:file:_files -g "*.vrs"' \
  '-default[use default settings]' \
  '-warp[start in warp mode]' \
  '-fullscreen[start fullscreen]' \
  '-window[start windowed]' \
  '-truedrive[true drive emulation]' \
  '-virtualdev[virtual device traps]' \
  '-iecdevice8[iec device 8]:dev:' \
  '-iecdevice9[iec device 9]:dev:' \
  '-iecdevice10[iec device 10]:dev:' \
  '-iecdevice11[iec device 11]:dev:' \
  '-8[attach to drive 8]:file:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00)"' \
  '-9[attach to drive 9]:file:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00)"' \
  '-10[attach to drive 10]:file:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00)"' \
  '-11[attach to drive 11]:file:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00)"' \
  '-1[attach to tape unit 1]:file:_files -g "*.(tap|t64)"' \
  '-cart[attach cartridge]:file:_files -g "*.(crt|bin)"' \
  '-pal[PAL mode]' \
  '-ntsc[NTSC mode]' \
  '-jamaction[jam action]:action:(continue monitor reset hardreset quit)' \
  '-monitor[start in monitor]' \
  '-VICIIextpal[enable VIC-II external palette]' \
  '-VICIIpalette=[VIC-II palette]:file:_files -g "*.vpl"' \
  '-machinetype[machine type]:type:' \
  '-keymap[keymap file]:file:_files' \
  '-debug[debug mode]' \
  '*:disk/tape/cartridge:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00|crt|bin)"' && ret=0
return ret
