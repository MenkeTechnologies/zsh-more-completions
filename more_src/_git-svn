#compdef git-svn

# Zsh completion for git-svn - Git SVN bridge

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'clone:Clone an SVN repository'
  'init:Initialize a git-svn repository'
  'fetch:Fetch revisions from SVN'
  'rebase:Fetch and rebase on top of SVN'
  'dcommit:Commit changes back to SVN'
  'branch:Create a branch in SVN'
  'tag:Create a tag in SVN'
  'log:Show SVN-style log'
  'blame:Show SVN blame annotations'
  'find-rev:Find git commit for SVN revision or vice versa'
  'set-tree:Set SVN repository to a given tree'
  'create-ignore:Create .gitignore from svn:ignore'
  'show-ignore:Print svn:ignore as .gitignore rules'
  'mkdirs:Recreate empty directories from SVN'
  'commit-diff:Commit a diff between two trees to SVN'
  'info:Show info about a file similar to svn info'
  'propget:Get an SVN property'
  'proplist:List SVN properties'
  'show-externals:Show SVN externals'
  'gc:Compress git-svn metadata'
  'reset:Undo fetch back to a specific revision'
)

_arguments -C \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'git-svn subcommand' subcommands
    ;;
  args)
    case $words[1] in
      clone)
        _arguments \
          '(-s --stdlayout)'{-s,--stdlayout}'[use standard trunk/tags/branches layout]' \
          '(-T --trunk)'{-T,--trunk}'[trunk subpath]:path' \
          '(-t --tags)'{-t,--tags}'[tags subpath]:path' \
          '(-b --branches)'{-b,--branches}'[branches subpath]:path' \
          '--prefix=[SVN-tracking ref prefix]:prefix' \
          '--no-metadata[do not include git-svn-id in commit messages]' \
          '--use-svm-props[remap repository URLs using SVN::Mirror]' \
          '--use-svnsync-props[remap repository URLs using svnsync]' \
          '--rewrite-root=[rewrite root URL]:url' \
          '(-A --authors-file)'{-A,--authors-file}'[authors mapping file]:file:_files' \
          '--username=[SVN username]:username' \
          '--ignore-paths=[regex of paths to ignore]:regex' \
          '--include-paths=[regex of paths to include]:regex' \
          '(-r --revision)'{-r,--revision}'[SVN revision or range]:revision' \
          '1:SVN URL'
        ;;
      init)
        _arguments \
          '(-s --stdlayout)'{-s,--stdlayout}'[use standard trunk/tags/branches layout]' \
          '(-T --trunk)'{-T,--trunk}'[trunk subpath]:path' \
          '(-t --tags)'{-t,--tags}'[tags subpath]:path' \
          '(-b --branches)'{-b,--branches}'[branches subpath]:path' \
          '--prefix=[SVN-tracking ref prefix]:prefix' \
          '--no-metadata[do not include git-svn-id in commit messages]' \
          '--username=[SVN username]:username' \
          '1:SVN URL'
        ;;
      fetch)
        _arguments \
          '(-r --revision)'{-r,--revision}'[SVN revision or range]:revision' \
          '(-A --authors-file)'{-A,--authors-file}'[authors mapping file]:file:_files' \
          '--ignore-paths=[regex of paths to ignore]:regex' \
          '--include-paths=[regex of paths to include]:regex'
        ;;
      rebase)
        _arguments \
          '--local[do not fetch, only rebase]' \
          '--dry-run[show what would be done]'
        ;;
      dcommit)
        _arguments \
          '--no-rebase[do not rebase after committing]' \
          '--dry-run[show what would be done]' \
          '--rmdir[remove empty directories from SVN]' \
          '-e[edit commit message]' \
          '--edit[edit commit message]'
        ;;
      branch|tag)
        _arguments \
          '-m[commit message]:message' \
          '--message=[commit message]:message' \
          '--dry-run[show what would be done]' \
          '1:branch/tag name'
        ;;
      log)
        _arguments \
          '(-r --revision)'{-r,--revision}'[SVN revision or range]:revision' \
          '--limit=[limit number of log entries]:number' \
          '-v[verbose, show changed paths]' \
          '--verbose[verbose, show changed paths]' \
          '--oneline[show one line per commit]' \
          '--show-commit[show git commit hash]'
        ;;
      find-rev)
        _arguments '1:revision or commit'
        ;;
      propget)
        _arguments \
          '1:property name' \
          '2:path:_files'
        ;;
      proplist)
        _arguments '1:path:_files'
        ;;
      reset)
        _arguments \
          '(-r --revision)'{-r,--revision}'[revision to reset to]:revision' \
          '--parent[reset to parent of specified revision]'
        ;;
      *)
        _arguments '*:arguments'
        ;;
    esac
    ;;
esac

return ret
