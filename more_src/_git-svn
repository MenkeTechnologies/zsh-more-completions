#compdef git-svn
# Documentation: https://git-scm.com/docs/git-svn
# Source: git/git git-svn.perl — bidirectional operation between Subversion and Git (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '1:subcommand:(init clone fetch dcommit rebase show-ignore set-tree create-ignore show-externals mkdirs commit-diff info log blame find-rev reset gc branch tag propset propget proplist multi-fetch multi-init)' \
    '*::args:->cmdargs' \
    && ret=0

return ret
