#compdef h4cc
# Documentation: https://manpages.debian.org/testing/hdf4-tools/h4cc.1.en.html
# Helper script to compile C programs against the HDF4 library

local ret=1

_arguments -s \
  '-help[display usage information]' \
  '-echo[show all the shell commands executed]' \
  '-prefix=[prefix directory to find HDF4 lib/ and include/]:dir:_files -/' \
  '-show[show the commands without executing them]' \
  '(-noshlib)-shlib[compile with shared HDF4 libraries]' \
  '(-shlib)-noshlib[compile with static HDF4 libraries]' \
  '*:compile arg:_files' && ret=0

return ret
