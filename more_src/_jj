#compdef jj
# Documentation: https://docs.jj-vcs.dev/latest/cli-reference/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jj (Jujutsu VCS, git-compatible)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-R --repository)'{-R,--repository}'[path to repository]:directory:_directories' \
  '--ignore-working-copy[skip working copy snapshot]' \
  '--ignore-immutable[allow rewriting immutable commits]' \
  '(--at-operation --at-op)'{--at-operation,--at-op}'[operate on repo at given operation]:operation' \
  '--debug[enable debug logging]' \
  '--color[when to colorize output]:when:(always never debug auto)' \
  '--quiet[suppress non-primary command output]' \
  '--no-pager[disable pager]' \
  '*--config[config override]:name=value:' \
  '*--config-file[additional config file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'abandon:abandon a revision'
      'absorb:move changes from a revision into its mutable ancestors'
      'backout:apply reverse of a revision'
      'bookmark:manage bookmarks'
      'commit:update description and create a new change on top'
      'config:manage config options'
      'describe:update change description or other metadata'
      'diff:show changes in a revision'
      'diffedit:edit changes interactively'
      'duplicate:create copies of revisions'
      'edit:set a revision as the working-copy revision'
      'evolog:show how a change has evolved over time'
      'file:file operations'
      'fix:run code formatters on revisions'
      'git:interact with underlying git repo'
      'help:show help for a subcommand'
      'interdiff:show changes between two revisions'
      'log:show revision history'
      'new:create a new empty change'
      'next:move working copy to a child revision'
      'operation:manage operation history'
      'parallelize:parallelize revisions by making them siblings'
      'prev:move working copy to a parent revision'
      'rebase:move revisions to a new parent'
      'resolve:resolve conflicted files with an external merge tool'
      'restore:restore paths from another revision'
      'revert:apply the reverse of revisions on top of another revision'
      'root:show the workspace root directory'
      'show:show commit description and changes in a revision'
      'sign:cryptographically sign a revision'
      'simplify-parents:simplify parent edges for the specified revisions'
      'sparse:manage which paths from the working-copy commit are present'
      'split:split a revision into two'
      'squash:move changes from a revision into another revision'
      'status:show high-level repo status'
      'tag:manage tags'
      'undo:undo an operation (shortcut for jj op undo)'
      'unsign:remove a cryptographic signature from a revision'
      'util:infrequently used commands such as for generating shell completions'
      'version:display version information'
      'workspace:manage workspaces'
    )
    _describe -t commands 'jj subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      git)
        local -a git_subcmds=(
          'clone:create a new repo backed by a clone of a git repo'
          'export:update the underlying git repo with changes made in the repo'
          'fetch:fetch from a git remote'
          'import:update repo with changes made in the underlying git repo'
          'init:create a new git-backed repo'
          'push:push to a git remote'
          'remote:manage git remotes'
          'root:show the underlying git directory of a repository'
        )
        _describe -t commands 'git subcommand' git_subcmds && ret=0
        ;;
      log|diff|show|evolog)
        _arguments \
          '(-r --revisions)'{-r,--revisions}'[revisions to show]:revset' \
          '(-p --patch)'{-p,--patch}'[show patch]' \
          '(-s --summary)'{-s,--summary}'[show summary of changes]' \
          '--stat[show diffstat]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
