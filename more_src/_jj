#compdef jj

# Zsh completion for jj (Jujutsu VCS, git-compatible)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-R --repository)'{-R,--repository}'[path to repository]:directory:_directories' \
  '--ignore-working-copy[skip working copy snapshot]' \
  '--ignore-immutable[allow rewriting immutable commits]' \
  '--at-operation[operate on repo at given operation]:operation' \
  '--at-op[operate on repo at given operation]:operation' \
  '--debug[enable debug logging]' \
  '--color[when to colorize output]:when:(always never auto)' \
  '--no-pager[disable pager]' \
  '--config-toml[additional config in TOML]:toml' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'abandon:abandon a revision'
      'backout:apply reverse of a revision'
      'bookmark:manage bookmarks (branches)'
      'branch:manage branches'
      'cat:print file contents at a revision'
      'checkout:create a new working-copy revision'
      'commit:update working copy description and create new change'
      'config:manage config options'
      'describe:update change description'
      'diff:show changes in a revision'
      'diffedit:edit changes interactively'
      'duplicate:create copies of revisions'
      'edit:set a revision as the working-copy revision'
      'file:file operations'
      'fix:run code formatters on revisions'
      'git:interact with underlying git repo'
      'init:create a new repository'
      'interdiff:show changes between two revisions'
      'log:show revision log'
      'merge:merge revisions'
      'move:move changes between revisions'
      'new:create a new empty change'
      'next:move working copy to next revision'
      'obslog:show how a change has evolved'
      'operation:manage operations'
      'parallelize:parallelize revisions'
      'prev:move working copy to previous revision'
      'rebase:move revisions to a new parent'
      'resolve:resolve merge conflicts'
      'restore:restore paths from another revision'
      'show:show details of a revision'
      'simplify-parents:simplify parent edges'
      'split:split a revision into two'
      'squash:squash changes into a parent revision'
      'status:show working copy status'
      'tag:manage tags'
      'undo:undo an operation'
      'unsquash:move changes from parent into this revision'
      'util:miscellaneous utilities'
      'version:show version info'
      'workspace:manage workspaces'
      'help:show help for a subcommand'
    )
    _describe -t commands 'jj subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments \
          '--git[use git backend]' \
          '--git-repo[path to existing git repo]:directory:_directories' \
          '1:directory:_directories' && ret=0
        ;;
      git)
        local -a git_subcmds=(
          'clone:clone a git repo'
          'export:export to underlying git repo'
          'fetch:fetch from git remote'
          'import:import from underlying git repo'
          'init:initialize git backend'
          'push:push to git remote'
          'remote:manage git remotes'
        )
        _describe -t commands 'git subcommand' git_subcmds && ret=0
        ;;
      log|diff|show|obslog)
        _arguments \
          '(-r --revisions)'{-r,--revisions}'[revisions to show]:revset' \
          '(-p --patch)'{-p,--patch}'[show patch]' \
          '(-s --summary)'{-s,--summary}'[show summary of changes]' \
          '--stat[show diffstat]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
