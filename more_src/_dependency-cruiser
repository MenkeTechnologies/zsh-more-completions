#compdef depcruise dependency-cruiser
# Documentation: https://man.archlinux.org/search?q=depcruise
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.cjs *.js"' \
  '(--validate)--validate=[config file]:file:_files' \
  '(-T --output-type)'{-T+,--output-type=}'[output format]:f:(json dot ddot cdot archi err err-html err-long flat html mermaid baseline csv markdown null teamcity text)' \
  '(-f --output-to)'{-f+,--output-to=}'[output file]:file:_files' \
  '(-X --exclude)'{-X+,--exclude=}'[exclude regex]:re:' \
  '(-x --do-not-follow)'{-x+,--do-not-follow=}'[do-not-follow regex]:re:' \
  '(-S --focus)'{-S+,--focus=}'[focus regex]:re:' \
  '(-M --reaches)'{-M+,--reaches=}'[reaches regex]:re:' \
  '(-N --highlight)'{-N+,--highlight=}'[highlight regex]:re:' \
  '(--max-depth)--max-depth=[max depth]:n:' \
  '(--prefix)--prefix=[prefix]:p:' \
  '(--preserve-symlinks)--preserve-symlinks[preserve symlinks]' \
  '(--module-systems)--module-systems=[module systems csv]:list:(amd cjs es6 tsd)' \
  '(--ts-config)--ts-config=[tsconfig path]:file:_files -g "tsconfig*.json"' \
  '(--webpack-config)--webpack-config=[webpack config]:file:_files -g "*.js *.cjs"' \
  '(--ts-pre-compilation-deps)--ts-pre-compilation-deps[TS pre-compile deps]' \
  '(--init)--init=[init config]:t:(yes preset notyet)' \
  '(--info)--info[info about transpile types]' \
  '(--metrics)--metrics[print metrics]' \
  '(--cache)--cache=[cache strategy]:s:' \
  '(--no-cache)--no-cache[no cache]' \
  '(-P --progress)'{-P+,--progress=}'[progress]:p:(cli-feedback performance-log none)' \
  '(--ignore-known)--ignore-known[ignore known violations]' \
  '(--include-only)--include-only=[include regex]:re:' \
  '*: :_files' && ret=0

return ret
