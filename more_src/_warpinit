#compdef warpinit
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/warpinit.html
# create an initial warp image, representing an identity transformation

local ret=1

_arguments -s -S \
  '-info[display information messages]' \
  '-quiet[suppress information and progress messages]' \
  '-debug[display debugging messages]' \
  '-force[force overwrite of output files]' \
  '-nthreads=[number of threads]:number' \
  '-config=[temporarily set a config entry]:key:_default:value' \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version information]' \
  '1:template:_files' \
  '2:warp:_files' && ret=0

return ret
