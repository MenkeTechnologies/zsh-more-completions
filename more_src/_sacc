#compdef sacc
# Documentation: https://man.archlinux.org/search?q=sacc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-i[run interactively]' \
  '-l[print links only]' \
  '-T+[fetch timeout (s)]:n:' \
  '*:gopher_url:' && ret=0

return ret
