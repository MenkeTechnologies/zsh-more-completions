#compdef zeppelin-daemon zeppelin-daemon.sh

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'start:start the Zeppelin daemon'
  'stop:stop the Zeppelin daemon'
  'restart:restart the Zeppelin daemon'
  'reload:reload Zeppelin configuration'
  'status:show daemon status'
  'upstart:run in upstart mode'
)

_arguments -C \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->action' && ret=0

case $state in
  (action)
    _describe -t actions 'zeppelin-daemon action' actions && ret=0
    ;;
esac

return ret
