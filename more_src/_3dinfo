#compdef 3dinfo
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dinfo.html
# AFNI print header / spatial information about a dataset

local ret=1

_arguments -s -S \
  '-help[entire help output]' \
  '-h[mini help]' \
  '-HELP[extreme help]' \
  '-h_find[search help for matching lines]:word' \
  '-verb[print lots of stuff]' \
  '-VERB[even more stuff including slice time offsets]' \
  '-short[print less stuff (default)]' \
  '-no_hist[omit HISTORY text]' \
  '-label2index[output index for labeled sub-brick]:label' \
  '-niml_hdr[output NIML-formatted header]' \
  '-subbrick_info[only sub-brick information]' \
  '-exists[check if dataset is loadable]' \
  '-id[idcode string]' \
  '-is_nifti[check if NIFTI format]' \
  '-is_oblique[check obliquity]' \
  '-is_atlas[check if atlas]' \
  '-space[dataset space]' \
  '-av_space[AFNI view extension for space]' \
  '-prefix[return prefix]' \
  '-prefix_noext[return prefix without extensions]' \
  '-ni[voxels in i dimension]' \
  '-nj[voxels in j dimension]' \
  '-nk[voxels in k dimension]' \
  '-nijk[ni*nj*nk product]' \
  '-nv[points in time or sub-bricks]' \
  '-nt[same as -nv]' \
  '-n3[same as -ni -nj -nk]' \
  '-n4[same as -ni -nj -nk -nv]' \
  '-nvi[maximum sub-brick index]' \
  '-di[voxel displacement along i (dx)]' \
  '-dj[voxel displacement along j (dy)]' \
  '-dk[voxel displacement along k (dz)]' \
  '-d3[same as -di -dj -dk]' \
  '-adi[voxel size along i]' \
  '-adj[voxel size along j]' \
  '-adk[voxel size along k]' \
  '-ad3[same as -adi -adj -adk]' \
  '-voxvol[voxel volume in cubic mm]' \
  '-oi[volume origin along i]' \
  '-oj[volume origin along j]' \
  '-ok[volume origin along k]' \
  '-o3[same as -oi -oj -ok]' \
  '-tr[TR value in seconds]' \
  '-dmin[minimum value (scaled)]' \
  '-dmax[maximum value (scaled)]' \
  '-smode[storage mode string]' \
  '-orient[orientation string]' \
  '-extent[spatial extent R L A P I S]' \
  '-fac[float scaling factor per sub-brick]' \
  '-label[label of each sub-brick]' \
  '-datum[data storage type]' \
  '-labeltable[show label table]' \
  '-atlas_points[show atlas points list]' \
  '-history[history note]' \
  '-slice_timing[show slice timing]' \
  '-header_line[output attribute names as first line]' \
  '-hdr[same as -header_line]' \
  '-sb_delim[delimiter between sub-brick values]:delim' \
  '-NA_flag[string for missing fields]:str' \
  '-atr_delim[delimiter between attributes]:delim' \
  '-aform_real[display 3x4 aform_real matrix]' \
  '-aform_orth[display 3x4 aform_orth matrix]' \
  '-same_grid[compare grids between dataset pairs]' \
  '-same_dim[compare dimensions between pairs]' \
  '-same_delta[compare voxel sizes between pairs]' \
  '-same_orient[compare orientation between pairs]' \
  '-same_center[compare geometric center between pairs]' \
  '-same_obl[compare obliquity between pairs]' \
  '-same_all_grid[all same_* options]' \
  '-val_diff[sum of absolute differences between pair]' \
  '-monog_pairs[pair each couple separately]' \
  '*:dataset:_files' && ret=0

return ret
