#compdef winlogbeat-cli winlogbeat
# _winlogbeat-cli — Elastic Beats winlogbeat-cli CLI command-line frontend to the Winlogbeat lightweight shipper reading Windows event-logs Security System Application PowerShell-operational ETW-event-trace shipping events to Elasticsearch Logstash Kafka with channel-name filtering ignore-older event-id-include-exclude shaping (Elastic team, Go); cobra
# upstream: https://www.elastic.co/beats/winlogbeat

_winlogbeat-cli() {
    local -a sub=(
        'run:run beat'
        'test:test config or output'
        'export:export config templates dashboards'
        'keystore:keystore management'
        'setup:setup index templates dashboards'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[selectors]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--c=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-e[log to stderr]' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '-E+[k=v]:str:' \
        '--strict.perms=+[bool]:s:(true false)' \
        '-N[do not publish events]' \
        '--once[publish once and exit]' \
        '--memprofile=+[file]:file:_files' \
        '--httpprof=+[host:port]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'winlogbeat-cli subcommand' sub ;;
    esac
}

_winlogbeat-cli "$@"
