#compdef tarantool
# Documentation: https://www.tarantool.io/en/doc/latest/reference/configuration/command_line_options/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,-V,--version}'[show version]' \
  '-i[enter interactive mode after running script]' \
  '*-e[execute Lua expression]:expr:' \
  '*-l[require library]:name:' \
  '-j[LuaJIT control command]:cmd:' \
  '-b[bytecode save/list operation]:arg:' \
  '-d[debug script]:script:_files' \
  '*:script:_files'
