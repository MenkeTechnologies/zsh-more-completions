#compdef jx
# Documentation: https://man.archlinux.org/search?q=jx
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add resources'
  'create:create resources'
  'ctx:context (alias)'
  'dashboard:open Pipelines Dashboard'
  'get:display resources'
  'import:import project (alias)'
  'namespace:view/change namespace'
  'start:start resource'
  'stop:stop resource'
  'ui:open Jenkins X UI'
  'upgrade:upgrade resources'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'jx subcommand' subcommands && ret=0 ;;
esac

return ret
