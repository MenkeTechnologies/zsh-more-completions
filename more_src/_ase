#compdef ase
# Documentation: source-direct extraction from upstream
# yfyh2013/ase (the GitHub mirror of gitlab.com/ase/ase, the
# Atomic Simulation Environment).  ase/cli/main.py:
#   commands = [
#       ('info', 'ase.cli.info'),
#       ('test', 'ase.test'),
#       ('gui', 'ase.gui.ag'),
#       ('db', 'ase.db.cli'),
#       ('run', 'ase.cli.run'),
#       ('band-structure', 'ase.cli.band_structure'),
#       ('build', 'ase.cli.build'),
#       ('eos', 'ase.eos'),
#       ('ulm', 'ase.io.ulm'),
#       ('find', 'ase.cli.find'),
#       ('nomad-upload', 'ase.cli.nomad'),
#       ('completion', 'ase.cli.completion')]
# Per-subcommand `class CLICommand: add_arguments(parser)`
# decoded source-direct from each module.
# Reference accessed: 2026-05-30 via gh api.
# yfyh2013 ase R186 — follow-up to R185's hunt-skip on "ase
# (Atomic Simulation Environment) still deferred from R184 -
# has 25+ subcommands via click subcommand-module loading that
# needs its own state-machine round".  Correction to R185:
# upstream has 12 subcommands (not 25+) and the dispatch is
# argparse subparsers + `import_module(module_name).CLICommand`
# reflection, not click.  Sister tool to the heavily-covered
# computational chemistry family (psi4/nwchem/vasp/quantum-
# espresso/gmx/mdtraj/antechamber/amber/cpptraj/vmd/pymol/
# ovito/pyscf/gabedit + R184 pmg + R185 ccget/ccwrite/ccframe/
# cda) already in the corpus.

local -a subcmds=(
  'help:show ase command help'
  'info:print information about files or system'
  'test:run the ASE test suite'
  'gui:ASE graphical user interface (also "ase-gui" alias)'
  'db:manipulate and query ASE database'
  'run:run calculation with one of ASE calculators'
  'band-structure:plot/print electronic band structure'
  'build:build an atom, molecule, or bulk structure'
  'eos:calculate equation of state'
  'ulm:manipulate/show content of ULM file'
  'find:find files with atoms in them'
  'nomad-upload:upload files to NOMAD'
  'completion:generate Bash tab-completion (use `ase completion -0` to dry-run)'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '--version[print version and exit]' \
  '1: :->cmd' \
  '*:: :->sub'

case $state in
  cmd)
    _describe -t commands 'ase subcommand' subcmds
    ;;
  sub)
    case $words[1] in
      info)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '*:file:_files'
        ;;
      build)
        _arguments -s -S \
          '(-M --magnetic-moment)'{-M+,--magnetic-moment=}'[magnetic moment(s) (e.g. 1 or 2.3,-2.3)]:M:' \
          '--modify=[modify atoms with Python statement (e.g. "atoms.positions[-1,2]+=0.1")]:expr:' \
          '(-V --vacuum)'{-V+,--vacuum=}'[vacuum to add around isolated atoms (Å)]:angstrom:' \
          '--unit-cell=[unit cell ("10.0" or "9,10,11" in Å)]:cell:' \
          '--bond-length=[dimer bond length in Å]:length:' \
          '(-x --crystal-structure)'{-x+,--crystal-structure=}'[crystal structure]:struct:(sc fcc bcc hcp diamond zincblende rocksalt cesiumchloride fluorite wurtzite)' \
          '(-a --lattice-constant)'{-a+,--lattice-constant=}'[lattice constant(s) in Å]:const:' \
          '--orthorhombic[use orthorhombic unit cell]' \
          '--cubic[use cubic unit cell]' \
          '(-r --repeat)'{-r+,--repeat=}'[repeat unit cell (e.g. "2" or "2,3,1")]:repeat:' \
          '(-g --gui)'{-g,--gui}'[open in GUI after build]' \
          '--periodic[apply periodic boundary conditions]' \
          '1:name or input file:_files' \
          '2:output file:_files'
        ;;
      run)
        _arguments -s -S \
          '(-t --tag)'{-t+,--tag=}'[tag for results]:tag:' \
          '(-p --parameters)'{-p+,--parameters=}'[calculator parameters as key=val,...]:params:' \
          '(-d --database)'{-d+,--database=}'[ASE database to write results to]:db:_files' \
          '(-S --skip)'{-S,--skip}'[skip systems already in database]' \
          '--properties=[properties to compute (default efsdMm: e=energy, f=forces, s=stress, d=dipole, M=magmom, m=magmoms)]:flags:' \
          '(-f --maximum-force)'{-f+,--maximum-force=}'[optimize until max force below threshold (eV/Å)]:fmax:' \
          '--constrain-tags=[constrain atoms with these tags]:tags:' \
          '(-s --maximum-stress)'{-s+,--maximum-stress=}'[relax cell until max stress below threshold (eV/Å³)]:smax:' \
          '(-E --equation-of-state)'{-E+,--equation-of-state=}'[fit equation of state (e.g. 5,1.05)]:spec:' \
          '--eos-type=[EOS type (default sjeos)]:type:(sj sjeos taylor murnaghan birch birchmurnaghan pouriertarantola vinet antonschmidt p3)' \
          '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
          '(-c --collection)'{-c+,--collection=}'[collection name]:name:' \
          '--modify=[Python statement to modify atoms]:expr:' \
          '--after=[Python statement to run after calculation]:expr:' \
          '1:calculator name:(abinit aims amber asap castep cp2k crystal demon dftd3 dftb dmol elk emt espresso exciting fleur gamess_us gaussian gpaw gromacs hotbit jacapo jdftx kim lammpsrun lammpslib lj morse nwchem octopus onetep openmx orca psi4 qchem siesta tip3p tip4p turbomole vasp)' \
          '*:atomic-system names:'
        ;;
      db)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-n --count)'{-n,--count}'[count number of selected rows]' \
          '(-l --long)'{-l,--long}'[long description of selected row]' \
          '(-i --insert-into)'{-i+,--insert-into=}'[insert selected rows into another database]:db:_files' \
          '(-a --add-from-file)'{-a+,--add-from-file=}'[add results from file]:file:_files' \
          '(-k --add-key-value-pairs)'{-k+,--add-key-value-pairs=}'[add key=val,... to selected rows]:kvs:' \
          '(-L --limit)'{-L+,--limit=}'[show only first N rows (0 = all; default 20)]:n:' \
          '--offset=[skip first N rows (default 0)]:n:' \
          '--delete[delete selected rows]' \
          '--delete-keys=[delete keys for selected rows]:keys:' \
          '(-y --yes)'{-y,--yes}'[say yes to all prompts]' \
          '--explain[explain query plan]' \
          '(-c --columns)'{-c+,--columns=}'[show only these columns ("+col" add, "-col" remove, "++" all)]:cols:' \
          '(-s --sort)'{-s+,--sort=}'[sort by column ("column-" for descending; default id)]:col:' \
          '--cut=[truncate keyword/key-value columns after N chars (0 = disable; default 35)]:n:' \
          '(-p --plot)'{-p+,--plot=}'[plot x,y1,y2,... (e.g. "x,y" or "a:x,y")]:spec:' \
          '(-P --plot-data)'{-P+,--plot-data=}'[show plot from data["name"] of selected row]:name:' \
          '--csv[write CSV file]' \
          '(-w --open-web-browser)'{-w,--open-web-browser}'[open results in web browser]' \
          '--no-lock-file[do not use lock files]' \
          '1:database:_files' \
          '*:query:'
        ;;
      gui)
        _arguments -s -S \
          '(-n --image-number)'{-n+,--image-number=}'[pick image(s) from trajectory (single number or start:stop:step)]:N:' \
          '(-u --show-unit-cell)'{-u+,--show-unit-cell=}'[unit cell display mode]:mode:((0\:do-not-show 1\:show 2\:show-all))' \
          '(-r --repeat)'{-r+,--repeat=}'[repeat unit cell (e.g. "2" or "2,3,1")]:rep:' \
          '(-R --rotations)'{-R+,--rotations=}'[rotations (e.g. "-90x" or "90z,-30x")]:rot:' \
          '(-o --output)'{-o+,--output=}'[write configurations to file]:file:_files' \
          '(-g --graph)'{-g+,--graph=}'[plot x,y1,y2,... graph (symbols i s d fmax e ekin A R E F)]:expr:' \
          '(-t --terminal)'{-t,--terminal}'[run in terminal (no GUI)]' \
          '--interpolate=[interpolate N images between 2 given images]:n:' \
          '(-b --bonds)'{-b,--bonds}'[draw bonds between atoms]' \
          '(-s --scale --radii-scale)'{-s+,--scale=,--radii-scale=}'[scale covalent radii]:factor:' \
          '*:trajectory file(s):_files'
        ;;
      find)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-l --long)'{-l,--long}'[long output]' \
          '(-i --include)'{-i+,--include=}'[include only filenames matching pattern]:glob:' \
          '(-x --exclude)'{-x+,--exclude=}'[exclude filenames matching pattern]:glob:' \
          '1:folder to look in:_files -/' \
          '*:filename or pattern:'
        ;;
      nomad-upload)
        _arguments -s -S \
          '(-t --token)'{-t+,--token=}'[NOMAD upload token]:token:' \
          '(-n --do-not-save-token)'{-n,--do-not-save-token}'[do not save token to ~/.ase/nomad]' \
          '-0[dry run (no upload)]' \
          '--dry-run[dry run (no upload)]' \
          '*:folder to upload:_files -/'
        ;;
      completion)
        _arguments -s -S \
          '-0[dry run: print completion script to stdout instead of writing]' \
          '--dry-run[dry run: print to stdout instead of writing]' \
          '1:output filename:_files'
        ;;
      eos)
        _arguments -s -S \
          '(-p --plot)'{-p,--plot}'[plot EOS curve]' \
          '(-t --type)'{-t+,--type=}'[EOS type (default sj)]:type:(sj sjeos taylor murnaghan birch birchmurnaghan pouriertarantola vinet antonschmidt p3)' \
          '*:trajectory file(s):_files'
        ;;
      ulm)
        _arguments -s -S \
          '(-n --index)'{-n+,--index=}'[index of frame to inspect]:n:' \
          '(-d --delete)'{-d+,--delete=}'[delete given key]:key:' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '1:ulm file:_files'
        ;;
      help)
        _arguments -s -S \
          '1:subcommand to show help for:(info test gui db run band-structure build eos ulm find nomad-upload completion)'
        ;;
    esac
    ;;
esac
