#compdef gomo
# Documentation: https://meme-suite.org/meme/doc/gomo.html
# MEME Suite: associate motifs with Gene Ontology terms

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--o=[output directory (default gomo_out), fail if exists]:dir:_files -/' \
  '--oc=[output directory (default gomo_out), overwrite if exists]:dir:_files -/' \
  '--text[output tab-delimited text to stdout]' \
  '--motifs=[motif file for the score columns]:file:_files' \
  '--dag=[GO DAG file]:file:_files' \
  '*--motif=[use only the motif with the given id]:id:' \
  '--shuffle_scores=[number of shuffled-score replicates]:n:' \
  '--t=[q-value threshold for reporting]:q:' \
  '--gs[use the GS statistic to rank GO terms]' \
  '--score_E_thresh=[E-value threshold for gene scores]:E:' \
  '--min_gene_count=[minimum genes annotated to a GO term]:n:' \
  '--nostatus[suppress progress reports to stderr]' \
  '*:go-term database/scoring file:_files' && ret=0

return ret
