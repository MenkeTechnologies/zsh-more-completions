#compdef ITGLog
# Documentation: https://traffic.comics.unina.it/software/ITG/manual/
# D-ITG remote log server: collects log data from ITGSend and ITGRecv

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '-q+[number of packets to push to the log at once]:log buffer size' && ret=0

return ret
