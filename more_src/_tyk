#compdef tyk
# Documentation: https://man.archlinux.org/search?q=tyk
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:run the gateway (default)'
  'lint:lint Tyk gateway config'
  'version:print version'
  'import:import API definitions'
  'bundler:plugin bundler'
  'plugin:plugin tools'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tyk subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--conf=[config file]:file:_files -g "*.(json|conf)"' \
          '--port=[listen port]:port:' \
          '--memprofile[write memory profile]' \
          '--cpuprofile[write CPU profile]' \
          '--blockprofile[write block profile]' \
          '--mutexprofile[write mutex profile]' \
          '--httpprofile[serve pprof over HTTP]' \
          '--debug[enable debug mode]' \
          '--log-instrumentation[log instrumentation events]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
