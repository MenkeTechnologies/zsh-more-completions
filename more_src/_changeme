#compdef changeme
# _changeme — Rapid7 Andrew Kissinger changeme CLI default credential scanner identifying services using vendor-default factory username password combinations Cisco Linksys Netgear MikroTik OpenWrt VMware HP Dell IBM phpMyAdmin Tomcat JBoss Jenkins WordPress with rule-based credential fingerprint matching (Rapid7 team, Python); argparse
# upstream: https://github.com/ztgrace/changeme

_changeme() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t+[target]:str:' \
        '--target=+[target]:str:' \
        '-T+[target file]:file:_files' \
        '--target-file=+[file]:file:_files' \
        '-c+[contributors]:str:' \
        '--cred=+[name]:str:' \
        '--category=+[name]:str:' \
        '-n+[name match]:str:' \
        '--name=+[regex]:str:' \
        '--protocols=+[proto]:p:(http https ftp ssh telnet snmp postgres mysql mssql tftp)' \
        '--proxy=+[url]:str:' \
        '--portoverride=+[port]:n:' \
        '--portoverride-only[only use port override]' \
        '--threads=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--useragent=+[ua]:str:' \
        '--useragent-file=+[file]:file:_files' \
        '--ssl[force SSL]' \
        '--validate[validate creds]' \
        '--dryrun[dryrun]' \
        '--shodan[Shodan integration]' \
        '--shodan_query=+[query]:str:' \
        '--shodan_key=+[key]:str:' \
        '--fingerprint[fingerprint targets]' \
        '--mkcred[make creds yml stub]' \
        '--dump[dump matched creds]' \
        '--output=+[file]:file:_files -g "*.csv *.json *.html"' \
        '--log=+[file]:file:_files' \
        '*::'
}

_changeme "$@"
