#compdef dimple
# Documentation: https://ccp4.github.io/dimple/
# DIMPLE - difference map pipeline for ligand screening (CCP4)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h}'[list all available options]' \
  '(-s --slow)'{-s,--slow}'[spend more cycles on refinement (repeatable)]' \
  '-M[control when molecular replacement activates]:R-factor threshold:' \
  '--libin[pass ligand descriptions (CIF) to Refmac]:cif file:_files' \
  '--icolumn[intensity column label]:I label:' \
  '--fcolumn[amplitude column label]:F label:' \
  '--ItoF-prog[intensity-to-amplitude conversion program]:program:(truncate ctruncate)' \
  '(-R --free-r-flags)--free-r-flags[external reference free-R flags MTZ (or - for input)]:mtz file:_files' \
  '(-R --free-r-flags)-R[use existing free-R flags from input MTZ]:mtz file:_files' \
  '--freecolumn[free-set column name and excluded-data value]:column=value:' \
  '--anode[search for blobs in anomalous difference map]' \
  '-f[generate static PNG/JPEG images of the blobs]' \
  '--no-cleanup[preserve intermediate files]' \
  '--from-step[re-run pipeline from given step]:step number:' \
  '*:input (mtz pdb output-dir):_files' && ret=0

return ret
