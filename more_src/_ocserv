#compdef ocserv

_arguments -s \
  '(-f --foreground)'{-f,--foreground}'[no fork]' \
  '(-d --debug)'{-d,--debug=}'[debug level]:n:' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-t --test-config)'{-t,--test-config}'[test config and exit]' \
  '(-p --pid-file)'{-p,--pid-file=}'[PID file]:file:_files' \
  '(-e --log-stderr)'{-e,--log-stderr}'[log to stderr]' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '--no-chdir[skip chdir on daemonize]' \
  '(-x --traceable)'{-x,--traceable}'[allow ptrace/coredump]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
