#compdef omregion
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omregion/node4.html
# Calculate evselect region files for an OM source

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--set=[input OM OSW source list]:file:_files' \
  '--srcnumber=[number of the source in the OM OSW source list]:n' \
  '--srcradius=[source extraction radius (FWHM if positive, pixels if negative)]:value' \
  '--bkginner=[inner background radius in terms of source radius]:value' \
  '--bkgouter=[outer background radius in terms of source radius]:value' \
  '--nfwhm=[limiting source extent in terms of PSF FWHM]:value' \
  '--srcfile=[name of the source extraction region file]:file:_files' \
  '--bkgfile=[name of the background extraction region file]:file:_files' \
  '*:param=value:_default' && ret=0

return ret
