#compdef ohcli
# Documentation: https://man.archlinux.org/search?q=ohcli
# Reference accessed: 2026-05-16

# ohcli: lightweight OpenHPI CLI wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-D[OpenHPI domain id]:n:' \
  '-d[debug output]' \
  '-c[OpenHPI config file]:file:_files' \
  '*:ohcli args:' && ret=0
return ret
