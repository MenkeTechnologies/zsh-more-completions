#compdef mdtraj
# Documentation: https://man.archlinux.org/search?q=mdtraj
# Reference accessed: 2026-05-16

# MDTraj: trajectory file format conversion via mdconvert
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::MDTraj Python script:_files' && ret=0
return ret
