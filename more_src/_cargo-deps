#compdef cargo-deps
# Documentation: https://github.com/stiiifff/cargo-deps
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-o --dot-file)'{-o,--dot-file}'=[output file]:file:_files' \
  '*--filter=[deps]:dep:' \
  '--include-orphans[keep orphan nodes]' \
  '(-I --include-versions)'{-I,--include-versions}'[include versions]' \
  '*--subgraph=[deps]:dep:' \
  '--all-deps[include all deps]' \
  '--no-regular-deps[exclude regular deps]' \
  '--build-deps[include build deps]' \
  '--dev-deps[include dev deps]' \
  '--optional-deps[include optional]' \
  '--no-transitive-deps[no transitive]' \
  '(-d --depth)'{-d,--depth}'=[max depth]:n:' \
  '--manifest-path=[manifest]:file:_files' \
  '--subgraph-name=[name]:name:'
