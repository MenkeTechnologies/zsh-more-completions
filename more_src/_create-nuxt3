#compdef create-nuxt3
# Documentation: https://www.npmjs.com/package/create-nuxt3
# Reference accessed: 2026-05-23
# Verified: npm view create-nuxt3 bin; unpkg create-nuxt3 dist/cli.js.

# Zsh completion for create-nuxt3 - Nuxt 3 project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--uiFramework=[UI framework]:framework:(None UnoCSS TailwindCSS WindiCSS)' \
  '--linterModules=[linter]:linter:(None ESLint JSHint TSLint)' \
  '--prettier[enable Prettier formatting]' \
  ':directory:_directories' && ret=0

return ret
