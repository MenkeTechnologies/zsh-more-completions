#compdef mdbook-d2
# _mdbook-d2 — mdbook preprocessor that renders D2 diagrams (danieleades/mdbook-d2)
# upstream: https://github.com/danieleades/mdbook-d2
# Subcommands from src/main.rs (clap).

_mdbook-d2() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-d2 "$@"
