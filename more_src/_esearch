#compdef esearch
# Documentation: https://man.archlinux.org/search?q=esearch
# Reference accessed: 2026-05-16

# NCBI EDirect esearch: query Entrez database, return UID set in WebEnv
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-db=[Entrez database]:db:(pubmed protein nucleotide nuccore nucest nucgss popset gene structure pmc taxonomy snp dbvar gds homologene mesh assembly bioproject biosample biosystems books pccompound pcsubstance pcassay sra)' \
  '-query=[query string]:query:' \
  '-mindate=[lower date bound (YYYY/MM/DD)]:date:' \
  '-maxdate=[upper date bound]:date:' \
  '-datetype=[date type]:type:(PDAT EDAT MDAT)' \
  '-days=[entries within last N days]:days:' \
  '-field=[restrict query to specific field]:field:(TITL AUTH AFFL JOUR PDAT MESH ALL)' \
  '-sort=[sort order]:sort:(relevance pub+date author title journal first+author last+author)' \
  '-spell[apply spelling correction]' \
  '-pub=[publication type]:type:(abstract clinical english free+full+text humans last+month last+week last+year medline ncbi+journal+articles+free preprint review structured+abstract)' \
  '-feature=[sequence feature type]:type:(cds gene mrna mature_peptide misc_feature)' \
  '-organism=[organism filter]:org:' \
  '-source=[source filter]:src:' \
  '-status=[status filter]:stat:' \
  '-type=[type filter]:type:' \
  '-journal=[journal name]:journal:' \
  '-released=[release status filter]:status:' \
  '-published=[publication date range]:range:' \
  '-country=[country filter]:country:' \
  '-location=[location filter]:loc:' \
  '*::query:' && ret=0
return ret
