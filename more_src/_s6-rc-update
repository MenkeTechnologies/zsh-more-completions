#compdef s6-rc-update

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l[path to live state directory]:live directory:_files -/' \
  '-f[path to conversion file]:conversion file:_files' \
  '-v+[set verbosity level]:verbosity:(0 1 2 3)' \
  '-t+[timeout in milliseconds]:timeout' \
  '-n[dry run]' \
  '1:new compiled database:_files -/' && ret=0

return ret
