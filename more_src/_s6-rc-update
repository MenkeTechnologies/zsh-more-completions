#compdef s6-rc-update
# Documentation: https://skarnet.org/software/s6-rc/s6-rc-update.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --dry-run)'{-n,--dry-run}'[show what would be executed without making changes]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:verbosity:(0 1 2 3)' \
  '(-t --timeout)'{-t+,--timeout=}'[max execution time in milliseconds]:timeout' \
  '(-l --livedir)'{-l+,--livedir=}'[live state directory]:live directory:_files -/' \
  '(-f --conversion-file)'{-f+,--conversion-file=}'[conversion file]:conversion file:_files' \
  '(-b --block)'{-b,--block}'[blocking lock]' \
  '(-E --no-force-essentials)'{-E,--no-force-essentials}'[preserve essential services during transitions]' \
  '(-e --force-essentials)'{-e,--force-essentials}'[allow stopping essential services]' \
  '1:new compiled database:_files -/' && ret=0

return ret
