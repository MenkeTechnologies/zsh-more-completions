#compdef mesheryctl

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'system:manage Meshery lifecycle'
      'mesh:manage service meshes'
      'perf:manage performance testing'
      'pattern:manage patterns'
      'filter:manage filters'
      'app:manage applications'
      'model:manage models'
      'registry:manage registries'
      'exp:experimental features'
      'version:show version'
      'completion:generate shell completions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (system)
        _arguments \
          '1:action:(start stop restart status config context channel dashboard login logout check token provider update reset logs)' && ret=0
        ;;
      (mesh)
        _arguments \
          '1:action:(validate deploy remove list)' \
          '--adapter=[adapter]:adapter:' \
          '--namespace=[namespace]:namespace:' \
          '--token=[auth token]:token:' && ret=0
        ;;
      (perf)
        _arguments \
          '1:action:(apply list view delete result)' \
          '--name=[test name]:name:' \
          '--url=[target URL]:url:' \
          '--concurrent-requests=[concurrent requests]:number:' \
          '--duration=[test duration]:duration:' \
          '--load-generator=[load generator]:generator:(fortio wrk2 nighthawk)' \
          '--mesh=[service mesh]:mesh:' \
          '--qps=[queries per second]:qps:' && ret=0
        ;;
      (pattern)
        _arguments \
          '1:action:(apply list view delete import export)' \
          '(-f --file)'{-f,--file}'=[pattern file]:file:_files' && ret=0
        ;;
      (filter)
        _arguments \
          '1:action:(apply list view delete import)' \
          '(-f --file)'{-f,--file}'=[filter file]:file:_files' && ret=0
        ;;
      (app)
        _arguments \
          '1:action:(import list view onboard offboard)' \
          '(-f --file)'{-f,--file}'=[application file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
