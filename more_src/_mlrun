#compdef mlrun
# Documentation: https://man.archlinux.org/search?q=mlrun
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build a function image (Docker)'
  'run:run a task and inject parameters'
  'deploy:deploy a function'
  'get:list objects by kind/class'
  'logs:get or watch task logs'
  'clean:clean runtime resources'
  'config:display client environment settings'
  'project:load and/or run a project'
  'watch-stream:watch a v3io stream'
  'version:show MLRun version'
  'db:DB management subcommands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mlrun command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '*'{-p+,--param=}'[parameter key=value]:p:' \
          '*'{-i+,--inputs=}'[input name=path]:i:' \
          '*'{-o+,--outputs=}'[output name]:o:' \
          '(-f --func-url)'{-f+,--func-url=}'[function URL]:url:' \
          '(-w --watch)'{-w,--watch}'[watch run progress]' \
          '--project=[project name]:project:' \
          '--name=[run name]:name:' \
          '--workflow=[workflow name]:name:' \
          '--local[run locally]' \
          '--schedule=[cron schedule]:cron:' \
          '--label=[label k=v]:label:' \
          '--uid=[run uid]:uid:' \
          '--from-env=[load env vars]:env:' \
          '--auto-mount[auto-mount data store]' \
          '*::file:_files' && ret=0 ;;
      (build)
        _arguments \
          '--name=[function name]:name:' \
          '--project=[project name]:project:' \
          '(-t --tag)'{-t+,--tag=}'[image tag]:tag:' \
          '(-i --image)'{-i+,--image=}'[target image]:image:' \
          '(-s --source)'{-s+,--source=}'[source dir]:dir:_files -/' \
          '(-b --base-image)'{-b+,--base-image=}'[base image]:image:' \
          '(-c --command)*'{-c+,--command=}'[build command]:cmd:' \
          '(-a --archive)'{-a+,--archive=}'[upload archive]:archive:_files' \
          '--secret-name=[image push secret]:name:' \
          '--with-mlrun[install MLRun in the image]' \
          '--watch[watch build progress]' && ret=0 ;;
      (deploy)
        _arguments \
          '--name=[function name]:name:' \
          '--project=[project name]:project:' \
          '(-t --tag)'{-t+,--tag=}'[image tag]:tag:' \
          '--source=[source path]:path:_files' \
          '--dashboard=[Nuclio dashboard URL]:url:' \
          '--watch[watch deployment]' && ret=0 ;;
      (get)
        _arguments \
          '--kind=[resource kind]:kind:(run runtime artifact function workflow project schedule)' \
          '--name=[resource name]:name:' \
          '--project=[project name]:project:' \
          '(-s --selector)'{-s+,--selector=}'[label selector]:selector:' \
          '--uid=[uid]:uid:' && ret=0 ;;
      (logs)
        _arguments \
          '--uid=[run uid]:uid:' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-w --watch)'{-w,--watch}'[watch logs]' \
          '--offset=[offset bytes]:n:' && ret=0 ;;
      (clean)
        _arguments \
          '--kind=[runtime kind]:kind:' \
          '--id=[runtime id]:id:' \
          '(-f --force)'{-f,--force}'[force clean]' \
          '(-ls --label-selector)'{-ls+,--label-selector=}'[label selector]:selector:' && ret=0 ;;
      (config)
        _arguments \
          '--command=[show config command (set/show)]:cmd:(set show)' \
          '(-a --api)'{-a+,--api=}'[MLRun API URL]:url:' \
          '(-p --artifact-path)'{-p+,--artifact-path=}'[artifact path]:path:' && ret=0 ;;
      (project)
        _arguments \
          '(-n --name)'{-n+,--name=}'[project name]:name:' \
          '(-u --url)'{-u+,--url=}'[project source URL]:url:' \
          '(-r --run)'{-r+,--run=}'[workflow to run]:workflow:' \
          '(-a --arguments)*'{-a+,--arguments=}'[Kubeflow pipeline argument]:arg:' \
          '(-p --artifact-path)'{-p+,--artifact-path=}'[artifact path]:path:' \
          '(-w --watch)'{-w,--watch}'[watch run]' \
          '--db=[MLRun DB URL]:url:' \
          '--schedule=[cron schedule]:cron:' \
          '*::path:_files -/' && ret=0 ;;
      (watch-stream)
        _arguments \
          '(-s --shard-ids)'{-s+,--shard-ids=}'[shard ids]:ids:' \
          '--seek=[seek policy]:seek:(earliest latest)' \
          '(-i --interval)'{-i+,--interval=}'[poll interval]:seconds:' \
          '(-j --is-json)'{-j,--is-json}'[parse as JSON]' && ret=0 ;;
      (db)
        _arguments '*::sub:(init upgrade migrate prune)' && ret=0 ;;
    esac ;;
esac

return ret
