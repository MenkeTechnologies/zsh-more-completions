#compdef mlrun
# Documentation: https://docs.mlrun.org/en/stable/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build a function image (Docker)'
  'clean:clean runtime resources'
  'config:display/set client environment settings'
  'get:list objects by kind/class'
  'logs:get or watch task logs'
  'project:load and/or run a project'
  'run:run a task and inject parameters'
  'version:show MLRun version'
  'watch-stream:watch a v3io stream'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mlrun command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '*'{-p+,--param=}'[parameter key=value]:p:' \
          '*'{-i+,--inputs=}'[input name=path]:i:' \
          '*'{-o+,--outputs=}'[output name]:o:' \
          '(-f --func-url)'{-f+,--func-url=}'[function URL]:url:' \
          '(-w --watch)'{-w,--watch}'[watch run progress]' \
          '(-s --secrets)'{-s+,--secrets=}'[secrets file or env]:s:' \
          '--in-path=[base dir for input artifacts]:path:_files -/' \
          '--out-path=[base dir for output artifacts]:path:_files -/' \
          '--project=[project name]:project:' \
          '--name=[run name]:name:' \
          '--workflow=[workflow name]:name:' \
          '--local[run locally]' \
          '--schedule=[cron schedule]:cron:' \
          '--label=[run label]:label:' \
          '--uid=[run uid]:uid:' \
          '--db=[DB URL]:url:' \
          '--runtime=[function spec dict]:dict:' \
          '--kfp[Kubeflow Pipelines mode]' \
          '(-h --hyperparam)'{-h+,--hyperparam=}'[hyperparameters]:hp:' \
          '--param-file=[hyperparameter CSV file]:file:_files' \
          '--selector=[result selection criteria]:sel:' \
          '--hyper-param-strategy=[strategy]:strategy:(grid random list)' \
          '--hyper-param-options=[hyperparam options JSON]:json:' \
          '--task=[YAML task file]:file:_files' \
          '--handler=[function handler]:handler:' \
          '--mode=[special run mode]:mode:' \
          '--from-env[load spec from environment]' \
          '--dump[output results as YAML]' \
          '--image=[container image]:image:' \
          '--kind=[serverless runtime kind]:kind:' \
          '--source=[source code archive/git]:src:' \
          '--auto-mount[add volume mount]' \
          '--workdir=[working directory]:dir:_files -/' \
          '--verbose[verbose logging]' \
          '--scrape-metrics[add scrape-metrics label]' \
          '--env-file=[path to .env file]:file:_files' \
          '--auto-build[build image before run]' \
          '--ensure-project[create project if missing]' \
          '--returns=[return value logging]:r:' \
          '*::file:_files' && ret=0 ;;
      (build)
        _arguments \
          '--name=[function name]:name:' \
          '--project=[project name]:project:' \
          '--tag=[function tag]:tag:' \
          '(-i --image)'{-i+,--image=}'[target image]:image:' \
          '(-s --source)'{-s+,--source=}'[source dir/url]:src:' \
          '(-b --base-image)'{-b+,--base-image=}'[base image]:image:' \
          '(-c --command)*'{-c+,--command=}'[build command]:cmd:' \
          '(-a --archive)'{-a+,--archive=}'[archive dir]:archive:' \
          '--secret-name=[image push secret]:name:' \
          '--silent[suppress build logs]' \
          '--with-mlrun[include MLRun package]' \
          '--db=[DB URL]:url:' \
          '(-r --runtime)'{-r+,--runtime=}'[function spec dict]:spec:' \
          '--kfp[Kubeflow Pipelines mode]' \
          '--skip[skip if already deployed]' \
          '--env-file=[path to .env file]:file:_files' \
          '--ensure-project[create project if missing]' && ret=0 ;;
      (get)
        _arguments \
          '--kind=[resource kind]:kind:(run runtime workflow artifact function)' \
          '--name=[object name]:name:' \
          '(-s --selector)'{-s+,--selector=}'[label selector]:selector:' \
          '(-n --namespace)'{-n+,--namespace=}'[k8s namespace]:ns:' \
          '--uid=[object id]:uid:' \
          '--project=[project name]:project:' \
          '(-t --tag)'{-t+,--tag=}'[artifact/function tag]:tag:' \
          '--db=[DB URL]:url:' && ret=0 ;;
      (logs)
        _arguments \
          '--uid=[run uid]:uid:' \
          '(-p --project)'{-p+,--project=}'[project name]:project:' \
          '(-w --watch)'{-w,--watch}'[watch logs]' \
          '--offset=[byte offset]:n:' \
          '--db=[API service URL]:url:' && ret=0 ;;
      (clean)
        _arguments \
          '--kind=[runtime kind]:kind:' \
          '--id=[runtime id]:id:' \
          '--api=[API service URL]:url:' \
          '(-ls --label-selector)'{-ls+,--label-selector=}'[label selector]:selector:' \
          '(-f --force)'{-f,--force}'[force deletion]' \
          '(-gp --grace-period)'{-gp+,--grace-period=}'[seconds before removal]:s:' && ret=0 ;;
      (config)
        _arguments \
          '--command=[get/set/clear]:cmd:(get set clear)' \
          '--env-file=[.mlrun.env path]:file:_files' \
          '(-a --api)'{-a+,--api=}'[API service URL]:url:' \
          '(-p --artifact-path)'{-p+,--artifact-path=}'[default artifacts path]:path:' \
          '(-u --username)'{-u+,--username=}'[username]:user:' \
          '(-k --access-key)'{-k+,--access-key=}'[access key]:key:' \
          '(-e --env-vars)*'{-e+,--env-vars=}'[env vars]:env:' && ret=0 ;;
      (project)
        _arguments \
          '(-n --name)'{-n+,--name=}'[project name]:name:' \
          '(-u --url)'{-u+,--url=}'[git/archive URL]:url:' \
          '(-r --run)'{-r+,--run=}'[workflow to run]:workflow:' \
          '(-a --arguments)*'{-a+,--arguments=}'[pipeline argument]:arg:' \
          '(-p --artifact-path)'{-p+,--artifact-path=}'[artifact path]:path:' \
          '(-x --param)*'{-x+,--param=}'[project parameter]:p:' \
          '(-s --secrets)'{-s+,--secrets=}'[secrets file/env]:sec:' \
          '--namespace=[k8s namespace]:ns:' \
          '--db=[API service URL]:url:' \
          '--init-git[initialize git]' \
          '(-c --clone)'{-c,--clone}'[force clone into context]' \
          '--sync[sync functions to DB]' \
          '(-w --watch)'{-w,--watch}'[wait for completion]' \
          '(-d --dirty)'{-d,--dirty}'[allow uncommitted changes]' \
          '--git-repo=[git repo reference]:repo:' \
          '--git-issue=[git issue number]:n:' \
          '--handler=[workflow handler name]:handler:' \
          '--engine=[workflow engine]:engine:(kfp local)' \
          '--local[run locally]' \
          '--timeout=[completion timeout sec]:s:' \
          '--env-file=[.env path]:file:_files' \
          '--schedule=[crontab expression]:cron:' \
          '--save-secrets[store as k8s secrets]' \
          '(-nt --notifications)'{-nt+,--notifications=}'[notification config]:cfg:' \
          '*::path:_files -/' && ret=0 ;;
      (watch-stream)
        _arguments \
          '(-s --shard-ids)'{-s+,--shard-ids=}'[shard ids]:ids:' \
          '--seek=[seek position]:seek:(EARLIEST LATEST)' \
          '(-i --interval)'{-i+,--interval=}'[poll interval sec]:s:' \
          '(-j --is-json)'{-j,--is-json}'[parse JSON]' && ret=0 ;;
    esac ;;
esac

return ret
