#compdef githound
# Documentation: https://github.com/tillson/git-hound
# git-hound - find exposed API keys and secrets across GitHub using code search.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--dashboard[stream results to web dashboard]' \
  '--all-results[print all results even without secrets]' \
  '--api-debug[print details about GitHub API requests]' \
  '--config-file=[supply path to a config file]:file:_files' \
  '--debug[enable verbose debug logging]' \
  '--dig-commits[dig through commit history to find more secrets]' \
  '--dig-files[dig through repo files to find more secrets]' \
  '--fast[skip file grepping and only return search preview]' \
  '--json[print results in JSON format]' \
  '--many-results[search beyond 100 pages with filtering hack]' \
  '--no-api-keys[do not search for generic API keys]' \
  '--no-files[do not search for interesting files]' \
  '--no-gists[do not search Gists]' \
  '--no-keywords[do not search for built-in keywords]' \
  '--no-repos[do not search repos]' \
  '--no-scoring[do not use scoring to filter false positives]' \
  '--otp-code=[GitHub account 2FA token for sign-in]:code:' \
  '--pages=[maximum pages to search per query]:pages:' \
  '--profile[enable pprof profiling]' \
  '--profile-addr=[address to serve pprof profiles]:addr:' \
  '--query=[a query string]:query:' \
  '--query-file=[file containing a list of queries]:file:_files' \
  '--results-only[only print match strings]' \
  '--rules=[path to regexes or a GitLeaks rules folder]:path:_files' \
  '--search-type=[search interface]:type:(api ui)' \
  '--threads=[threads to dig with]:threads:' \
  '*:query:' && ret=0

return ret
