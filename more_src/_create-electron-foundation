#compdef create-electron-foundation
# Documentation: https://www.npmjs.com/package/create-electron-foundation
# Reference accessed: 2026-05-24
# Verified: npm view create-electron-foundation bin; npm readme Command-Line Arguments table.

# Zsh completion for create-electron-foundation - Electron desktop app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--project_name=[project name]:name:' \
  '--router=[client router]:router:(tanstack-router react-router)' \
  '--styles=[styling stack]:styles:(tailwind none)' \
  '--database=[embedded database]:database:(sqlite none)' \
  '--orm=[ORM choice]:orm:(drizzle none)' \
  '--ide=[preferred IDE setup]:ide:(cursor vscode none)' \
  '--pkg_manager=[package manager]:manager:(npm)' \
  '--initialize_git[initialize Git repository]' \
  '--git[alias for --initialize_git]' \
  '--install_packages[install packages after scaffolding]' \
  '--ci[run in CI non-interactive mode]' \
  '(-y --yes)'{-y,--yes}'[skip prompts and use defaults]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
