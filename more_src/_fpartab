#compdef fpartab
# Write a task parameter value to a FITS table element

local ret=1

_arguments -s \
  "value=[value to write]:" \
  "fitsfile=[target FITS table file]:file:_files" \
  "column=[column name]:" \
  "row=[row number]:" \
  "element=[vector element number]:" \
  "*:FITS file:_files" && ret=0

return ret
