#compdef zshrs
# Documentation: https://github.com/MenkeTechnologies/zshrs
# Reference accessed: 2026-05-21
# Verified: zshrs bins/zshrs.rs --help block (`zshrs --help` output)
# at HEAD on main. Flag set ported directly from the in-source help
# text; -o OPTION accepts any named zsh option (delegated to _options).

local curcontext=$curcontext state state_descr line expl not='!'
typeset -A opt_args

[[ $CURRENT = 2 ]] && not=''

_arguments -S -s : \
  ${not}'--emulate[specify emulation mode]:mode:(zsh sh ksh csh)' \
  '*-o+[set named option]:option:_options' \
  '*+o+[unset named option]:option:_options' \
  '(1 -s --shinstdin)'{-s,--shinstdin}'[read commands from standard input]' \
  '(-)-b[end of option processing, like --]' \
  '(1 -)-c[run a command]:command:_cmdstring' \
  '(-)--help[show help message and exit]' \
  '(-)--version[show version number and exit]' \
  '(-)--doctor[full diagnostic report of shell health, caches, and performance]' \
  '(-)--dump-reflection[emit JSON of builtins/keywords/options for IntelliJ plugin]' \
  '(-)--docs[render the LSP hover card for a builtin/keyword/option]:symbol name' \
  '(-)--lsp[start LSP server on stdio for editor integration]' \
  '(-)--dap[start DAP debug adapter; connects back to IDE listener]:host\:port' \
  '--dump-tokens[emit one TOKNAME<tab>TOKSTR line per lexer token]:output file:_files' \
  '--dump-ast[emit parser AST as canonical S-expression]:output file:_files' \
  '--dump-wordcode[emit wordcode emitter output]:output file:_files' \
  '--dump-zwc[inspect compiled .zwc cache (list or one fn)]:zwc file:_files -g "*.zwc"' \
  '--disasm[print fusevm opcodes for each compiled unit before VM run]' \
  '--zsh[identical-behaviour drop-in for /bin/zsh (compat-test entrypoint)]' \
  '--bash[identical-behaviour drop-in for /bin/bash]' \
  '--ksh[identical-behaviour drop-in for /bin/ksh (ksh-93)]' \
  '--posix[identical-behaviour drop-in for /bin/sh (Bourne / dash)]' \
  '--zsh-compat[alias of --zsh (legacy spelling)]' \
  '--no-rcs[do not source startup files]' \
  '-f[equivalent to --no-rcs]' \
  '-i[force interactive mode]' \
  '-l[force login shell mode]' \
  '-v[verbose (equivalent to --verbose)]' \
  '-x[xtrace (equivalent to --xtrace)]' \
  '(-)1:script file:_files' \
  '*::script arguments:->args' -- && return 0

case $state in
  (args)
    if [[ -n ${opt_args[(I)-c|-s|--shinstdin]} ]]; then
      _files
    else
      _normal
    fi
    ;;
esac
