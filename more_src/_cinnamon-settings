#compdef cinnamon-settings
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/cinnamon-settings.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
local -a panels

panels=(
  'applets:Applets'
  'background:Background'
  'calendar:Calendar'
  'default:Default Applications'
  'desklets:Desklets'
  'desktop:Desktop'
  'effects:Effects'
  'extensions:Extensions'
  'fonts:Fonts'
  'general:General'
  'gestures:Gestures'
  'hotcorner:Hot Corners'
  'info:System Info'
  'input-method:Input Method'
  'keyboard:Keyboard'
  'mouse:Mouse and Touchpad'
  'network:Network'
  'notifications:Notifications'
  'online-accounts:Online Accounts'
  'panel:Panel'
  'power:Power Management'
  'printers:Printers'
  'privacy:Privacy'
  'screensaver:Screensaver'
  'sound:Sound'
  'startup:Startup Applications'
  'themes:Themes'
  'tiling:Window Tiling'
  'universal-access:Accessibility'
  'user:Account'
  'windows:Windows'
  'workspaces:Workspaces'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-t --tab)'{-t,--tab}'+[tab to show on first panel]:tab:' \
  '1:panel:->panel' && ret=0

if [[ "$state" == "panel" ]]; then
  _describe -t panels 'cinnamon settings panel' panels && ret=0
fi

return ret
