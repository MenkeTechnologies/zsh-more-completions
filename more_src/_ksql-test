#compdef ksql-test ksqldb-test ksql-test-runner
# _ksql-test — Confluent ksql-test ksqldb-test-runner CLI command-line frontend wrapping the ksqlDB test runner enabling unit testing for SQL statements running test SQL statements expected-results test-spec test-statements-input-records-output-records aggregations joins UDFs custom-streams-aggregation kafka-test-utils embedded brokers without running the full server (Confluent team, Java); custom argparse
# upstream: https://docs.ksqldb.io/

_ksql-test() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--sql=+[file]:file:_files -g "*.sql *.ksql"' \
        '--input=+[file]:file:_files -g "*.json"' \
        '--output=+[file]:file:_files -g "*.json"' \
        '--extension-dir=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.properties"' \
        '-c+[config]:file:_files -g "*.properties"' \
        '--test-config-file=+[file]:file:_files -g "*.json *.yaml *.yml"' \
        '--test-results-file=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--use-original-fps[use original fps]' \
        '--format=+[fmt]:f:(JSON YAML CSV)' \
        '*::'
}

_ksql-test "$@"
