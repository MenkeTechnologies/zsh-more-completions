#compdef tagainijisho
# _tagainijisho — Tagaini Jisho (Qt Japanese-language dictionary + JLPT study tool with offline JMdict/Kanjidic backing store; --user-data-dir overrides profile dir, --debug enables verbose logging; positional argument prefills the search bar)
# upstream: https://github.com/Gnurou/tagainijisho
# Flags from tagainijisho src/core/Database.cc + src/main.cc on tip.

_tagainijisho() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[verbose logging]' \
        '--user-data-dir+[user data dir]:dir:_files -/' \
        '*::search query:'
}

_tagainijisho "$@"
