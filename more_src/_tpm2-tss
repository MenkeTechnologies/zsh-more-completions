#compdef tpm2-tss pkg-config-tpm2-tss tss2 esys-get-version
# _tpm2-tss — Intel tpm2-tss TCG Trusted Computing Group TPM 2.0 Software Stack Tcti Sys Esys Fapi helper CLI for build feature flags include/lib paths supported transmission interfaces (tpm2-software team, C); GOption-ish
# upstream: https://github.com/tpm2-software/tpm2-tss

_tpm2-tss() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--prefix[show install prefix]' \
        '--libdir[show lib dir]' \
        '--includedir[show include dir]' \
        '--cflags[show CFLAGS]' \
        '--libs[show LIBS]' \
        '--datarootdir[show data root dir]' \
        '--print-tcti-modules[print TCTI modules]' \
        '--print-supported-tctis[print supported TCTIs]' \
        '--print-policy-search-paths[print policy search paths]' \
        '--list-fapi-keystore[list FAPI keystore]' \
        '--list-system-keystore[list system keystore]' \
        '--list-user-keystore[list user keystore]' \
        '--list-policies[list policies]' \
        '--esys-version[print Esys version]' \
        '--sys-version[print Sys version]' \
        '--fapi-version[print Fapi version]' \
        '--mu-version[print MU version]' \
        '--rc-decode[decode rc]' \
        '--tcti=+[tcti]:t:(device mssim swtpm libtpms tabrmd)'
}

_tpm2-tss "$@"
