#compdef openhpi-clients

# openhpi-clients umbrella: OpenHPI client/utility binaries (hpiel, hpitree, hpidomain, hpisensor, hpipower, etc.)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'hpiel:display HPI System Event Log'
  'hpidomain:list HPI domains'
  'hpitree:show resource tree'
  'hpiinv:inventory data'
  'hpisensor:read sensors'
  'hpipower:power management'
  'hpireset:reset resource'
  'hpithres:show/set sensor thresholds'
  'hpiwdt:watchdog timer'
  'hpiupgrade:firmware upgrade'
  'hpidiscover:discover resources'
  'hpigensimdata:HPI simulator data generator'
  'hpisettime:set HPI event log time'
  'hpiarcalarmexample:alarm example'
  'hpifan:fan management'
  'hpilsres:list resources'
  'hpionoff:turn LED on/off'
  'hpisettag:set entity tag'
  'hpisetsystinfo:set system info'
  'hpixml:XML output of HPI tree'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openhpi-clients command' commands && ret=0 ;;
esac
return ret
