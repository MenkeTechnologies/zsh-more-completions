#compdef capsule
# _capsule — multi-tenancy Kubernetes operator (clastix/capsule)
# upstream: https://github.com/projectcapsule/capsule
# Flags from cmd/main.go on tip.

_capsule() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--configuration-name=[CapsuleConfiguration CR name]:name:' \
        '--enable-leader-election[enable leader election]' \
        '--workers=[max concurrent reconciles]:n:' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--metrics-secure[serve metrics over HTTPS]' \
        '--metrics-cert-path=[metrics TLS cert directory]:dir:_files -/' \
        '--metrics-cert-name=[metrics TLS cert file name]:name:' \
        '--metrics-cert-key=[metrics TLS key file name]:name:' \
        '--webhook-port=[webhook server port]:port:' \
        '--webhook-cert-path=[webhook TLS cert directory]:dir:_files -/' \
        '--webhook-cert-name=[webhook TLS cert file name]:name:' \
        '--webhook-cert-key=[webhook TLS key file name]:name:' \
        '--enable-http2[allow HTTP/2 on webhook/metrics]' \
        '--client-connection-qps=[Kubernetes client QPS]:f:' \
        '--client-connection-burst=[Kubernetes client burst]:n:' \
        '--enable-pprof[enable pprof endpoint]' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capsule "$@"
