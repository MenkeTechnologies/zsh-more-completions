#compdef barman-cloud-backup-delete
# Documentation: https://man.archlinux.org/search?q=barman-cloud-backup-delete
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--cloud-provider)--cloud-provider=+[cloud provider]:provider:(aws-s3 azure-blob-storage google-cloud-storage)' \
  '(--endpoint-url)--endpoint-url=+[endpoint URL]:url:' \
  '(-P --profile)'{-P,--profile}'+[AWS profile]:profile:' \
  '(--azure-credential)--azure-credential=+[Azure credential]:cred:(azure-cli managed-identity)' \
  '(-t --test)'{-t,--test}'[test connectivity]' \
  '(-b --backup-id)'{-b,--backup-id}'+[backup id]:id:' \
  '(-r --retention-policy)'{-r,--retention-policy}'+[retention policy]:policy:' \
  '(-m --minimum-redundancy)'{-m,--minimum-redundancy}'+[minimum redundancy]:n:' \
  '(--batch-size)--batch-size=+[delete batch size]:n:' \
  '(--dry-run)--dry-run[dry run]' \
  '*:server_name destination_url:' && ret=0

return ret
