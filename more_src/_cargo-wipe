#compdef cargo-wipe
# Documentation: https://man.archlinux.org/search?q=cargo-wipe
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-w[actually perform the wipe]' \
  '--wipe[actually perform the wipe]' \
  '-i[ignore hidden directories]' \
  '--ignore-hidden[ignore hidden directories]' \
  '1:folder type:(target node_modules)' \
  '2:path:_directories' && ret=0

return ret
