#compdef cargo-wipe
# Documentation: https://github.com/mihai-dinculescu/cargo-wipe
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Cargo subcommand: recursively find/wipe build artefact dirs.
# Folder types: rust (target/), node (node_modules/), terraform (.terraform/).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-w[perform the wipe (without it dry-run only)]' \
  '--wipe[perform the wipe (without it dry-run only)]' \
  '-i+[ignore path]:path:_directories' \
  '--ignore=[ignore path]:path:_directories' \
  '--hidden[include hidden directories]' \
  '1:folder type:(rust node terraform)' \
  '2:path:_directories' && ret=0

return ret
