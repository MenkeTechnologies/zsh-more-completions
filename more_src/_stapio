#compdef stapio
# Documentation: https://man.archlinux.org/search?q=stapio
# Reference accessed: 2026-05-16

# stapio: SystemTap I/O daemon (called from stap)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-c[run command]:cmd:' \
  '-x[target PID]:pid:' \
  '-D[detached mode]' \
  '-R[remote (ssh)]:host:_hosts' \
  '-r[release marker]:str:' \
  '-d[symbol info]:file:_files' \
  '*::stapio args:_files' && ret=0
return ret
