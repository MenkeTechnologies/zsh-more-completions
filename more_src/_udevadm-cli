#compdef udevadm
# _udevadm-cli — udev / systemd-udev management utility; query device DB, monitor events, control rules + triggers
# upstream: https://github.com/systemd/systemd

_udevadm-cli() {
    local -a sub=(
        'info:query the udev DB'
        'trigger:request events from the kernel'
        'settle:wait for pending events'
        'control:control udevd'
        'monitor:listen to kernel + udev events'
        'test:simulate udev event for a device'
        'test-builtin:test a built-in udev rule'
        'verify:verify udev rule files'
        'wait:wait until a device is ready'
        'lock:wait then lock a device exclusively'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'udevadm subcommand' sub ;;
        args)
            case $words[1] in
                info) _arguments \
                    '(-q --query)'{-q,--query}'+[query]:type:(name symlink path property all)' \
                    '(-n --name)'{-n,--name}'+[device node]:node:_files' \
                    '(-p --path)'{-p,--path}'+[sysfs path]:path:' \
                    '(-r --root)'{-r,--root}'[print full /dev path]' \
                    '(-a --attribute-walk)'{-a,--attribute-walk}'[walk chain of parents]' \
                    '(-x --export)'{-x,--export}'[export as env vars]' \
                    '(-P --export-prefix)'{-P,--export-prefix}'+[export prefix]:prefix:' \
                    '(-d --device-id-of-file)'{-d,--device-id-of-file}'+[get major:minor]:file:_files' \
                    '(-e --export-db)'{-e,--export-db}'[export entire db]' \
                    '(-c --cleanup-db)'{-c,--cleanup-db}'[clean udev db]' \
                    '--json+[json mode]:mode:(pretty short off)' \
                    '--value[only show requested attr]' \
                    '--no-pager[no pager]' \
                    '*:device:_files' ;;
                trigger) _arguments \
                    '(-v --verbose)'{-v,--verbose}'[verbose]' \
                    '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
                    '(-t --type)'{-t,--type}'+[device type]:type:(devices subsystems)' \
                    '(-c --action)'{-c,--action}'+[action]:action:(add change remove)' \
                    '(-s --subsystem-match)'{-s,--subsystem-match}'+[subsystem]:str:' \
                    '(-S --subsystem-nomatch)'{-S,--subsystem-nomatch}'+[exclude subsystem]:str:' \
                    '(-a --attr-match)'{-a,--attr-match}'+[attr match]:attr=val:' \
                    '(-A --attr-nomatch)'{-A,--attr-nomatch}'+[attr nomatch]:attr=val:' \
                    '(-p --property-match)'{-p,--property-match}'+[property match]:prop=val:' \
                    '(-g --tag-match)'{-g,--tag-match}'+[tag match]:tag:' \
                    '(-y --sysname-match)'{-y,--sysname-match}'+[sysname match]:name:' \
                    '(-b --parent-match)'{-b,--parent-match}'+[parent match]:path:' \
                    '(-w --settle)'{-w,--settle}'[wait until events done]' \
                    '--prioritized-subsystem+[prioritized subsystem]:str:' \
                    '--initialized-match[only initialized]' \
                    '--initialized-nomatch[only uninitialized]' \
                    '--name-match+[device node]:node:_files' ;;
                control) _arguments \
                    '(-e --exit)'{-e,--exit}'[stop udevd]' \
                    '(-l --log-priority)'{-l,--log-priority}'+[log priority]:prio:(emerg alert crit err warning notice info debug)' \
                    '(-s --stop-exec-queue)'{-s,--stop-exec-queue}'[stop processing events]' \
                    '(-S --start-exec-queue)'{-S,--start-exec-queue}'[resume processing events]' \
                    '(-R --reload)'{-R,--reload}'[reload rules]' \
                    '(-p --property)'{-p,--property}'+[set prop]:KEY=VAL:' \
                    '(-m --children-max)'{-m,--children-max}'+[max workers]:n:' \
                    '--ping[ping daemon]' \
                    '(-t --timeout)'{-t,--timeout}'+[timeout]:sec:' \
                    '--load-credentials[reload credentials]' ;;
                monitor) _arguments \
                    '(-p --property)'{-p,--property}'[show properties]' \
                    '(-k --kernel)'{-k,--kernel}'[only kernel events]' \
                    '(-u --udev)'{-u,--udev}'[only udev events]' \
                    '(-s --subsystem-match)'{-s,--subsystem-match}'+[subsystem]:str:' \
                    '(-t --tag)'{-t,--tag}'+[tag]:tag:' ;;
                test) _arguments \
                    '(-a --action)'{-a,--action}'+[action]:action:(add change remove)' \
                    '(-N --resolve-names)'{-N,--resolve-names}'+[resolve names]:when:(early late never)' \
                    '1:device:_files' ;;
                verify) _arguments \
                    '(-N --no-style)'{-N,--no-style}'[no styled output]' \
                    '--resolve-names+[resolve names]:when:(early late never)' \
                    '--root+[root]:dir:_files -/' \
                    '*:rules file:_files -g "*.rules"' ;;
            esac
            ;;
    esac
}

_udevadm-cli "$@"
