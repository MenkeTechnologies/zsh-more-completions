# ============================================================================
# _oneshot — zsh completion for forestnode-io/oneshot v2, "a first-come
#             first-served single-fire HTTP server.  Easily transfer files
#             to and from your computer via HTTP, including over P2P
#             WebRTC data channels for NAT traversal."  Go=154 leader bump
#             continuing Axis 99 WebRTC / webrtc-rs via the canonical Go
#             WebRTC stack github.com/pion/webrtc.
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/forestnode-io/oneshot
#   Maintainer : Raphael Reyna (raphaelreyna)
#   License    : MIT
#   Stars      : 339
#   Language   : Go (v2/ submodule, Go 1.18+)
#   Module     : github.com/forestnode-io/oneshot/v2
#   Binary     : oneshot  (built from v2/cmd/main.go)
#   Last push  : 2025-07-12
#
# WHAT IT IS
#   oneshot is a single-fire HTTP server: spin it up, the first
#   client to hit the endpoint completes the transfer (`send`),
#   uploads a file (`receive`), runs a command server-side
#   (`exec`), reverse-proxies a host (`reverse-proxy`), or is
#   redirected (`redirect`).  Once that one client connects, the
#   process exits.  Designed for ad-hoc file transfers, share-
#   sheet integrations, build-tool side-channels, and quick
#   NAT-pierced P2P sends between machines without exposing a
#   listening port to the public internet — that last mode uses
#   a `discovery-server` instance plus the pion/webrtc-driven
#   ICE/STUN/TURN negotiation to open a direct WebRTC data
#   channel between sender and receiver, falling back to a
#   relay only when both ends are behind symmetric NATs.
#
# CLI ARGUMENT GRAMMAR  (verbatim from v2/pkg/commands/*/cobra.go
#                       + v2/pkg/commands/*/configuration/
#                       configuration.go pflag declarations,
#                       extracted via `gh api repos/forestnode-
#                       io/oneshot/contents/v2/pkg/commands/...`)
#
#   oneshot [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Subcommands:
#     send [FILE|DIR]                Send a file or directory to
#                                    the client.  If no
#                                    FILE/DIR is given, stdin is
#                                    used (requests block until
#                                    EOF; content is buffered).
#                                    Directories are archived
#                                    before being sent.
#       -a, --archive-method <KIND>    Archive method for
#                                      directory sends
#                                      (zip | tar.gz | tar)
#       -D, --no-download              Do not allow client
#                                      download
#       -m, --mime <TYPE>              MIME type of file
#                                      presented to client
#       -n, --name <NAME>              Name of file presented to
#                                      client when downloading
#           --status-code <CODE>       HTTP status code to send
#                                      to client
#       -H, --header <KEY=VAL>         Response header (can be
#                                      repeated)
#
#     receive [FILE]                 Receive a file from the
#                                    client.  If FILE is given,
#                                    bytes are written there;
#                                    otherwise the body is
#                                    written to stdout.
#
#     exec -- <COMMAND>...           Execute a command for each
#                                    request, piping the request
#                                    body to stdin and returning
#                                    the command's stdout to
#                                    the client
#
#     reverse-proxy <HOST>           Reverse-proxy all requests
#                                    to the specified host
#                                    (alias: rproxy)
#
#     redirect <URL>                 Redirect all requests to
#                                    the specified URL
#
#     discovery-server               Run a NAT-traversal
#                                    discovery server for use
#                                    with the P2P WebRTC flow
#                                    (binds the WebSocket
#                                    signaling channel and
#                                    issues ICE candidates +
#                                    SDP offers / answers
#                                    between sender and
#                                    receiver)
#
#     version                        Print version information
#
#   Standard cobra auto-flags  (on every subcommand):
#     -h, --help                     Show help
#         --config <PATH>            Path to YAML config file
#                                    (the entire CLI surface
#                                    can also be driven by
#                                    YAML; `oneshot.yaml` /
#                                    `~/.config/oneshot/
#                                    oneshot.yaml` are picked
#                                    up automatically)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/pion/webrtc/v3 v3.2.12` and
#   `github.com/pion/datachannel v1.5.5` declared in v2/go.mod —
#   `pion/webrtc` is THE canonical Go WebRTC stack maintained by
#   the Pion team (pion/webrtc, 14,300+ stars; the reference
#   pure-Go WebRTC protocol implementation that nearly every
#   Go-language WebRTC project — Meepo, weron, JetKVM, neko,
#   live777-Go-bridges, the LiveKit Go ingress, Janus-Go
#   gateways, etc. — depends on, and the project whose API
#   surface webrtc-rs deliberately mirrors so the two
#   implementations stay symmetrical).  pion/webrtc exposes the
#   typed `webrtc.NewAPI` factory with
#   `webrtc.NewAPI(webrtc.WithMediaEngine(m),
#   webrtc.WithInterceptorRegistry(i),
#   webrtc.WithSettingEngine(s))`, the typed
#   `*webrtc.PeerConnection` constructor +
#   `pc.CreateOffer` / `pc.CreateAnswer` / `pc.SetLocalDescription`
#   / `pc.SetRemoteDescription` / `pc.AddICECandidate` /
#   `pc.AddTransceiverFromKind` / `pc.AddTrack` /
#   `pc.CreateDataChannel` / `pc.Close` request + response model,
#   the typed `*webrtc.DataChannel` with `dc.OnMessage` /
#   `dc.OnOpen` / `dc.OnClose` / `dc.Send` / `dc.SendText`, the
#   typed `webrtc.SessionDescription` / `webrtc.ICECandidate` /
#   `webrtc.ICECandidateInit` / `webrtc.ICEServer` /
#   `webrtc.Configuration` / `webrtc.RTPTransceiver` /
#   `webrtc.RTPSender` / `webrtc.RTPReceiver` /
#   `webrtc.RTPCodecParameters` / `webrtc.RTPCodecCapability`
#   / `webrtc.RTPCodecType` schemas, the `media/*` Sample/Track
#   primitives (`TrackLocal`, `TrackLocalStaticSample`,
#   `TrackLocalStaticRTP`, `TrackRemote`), the `interceptor/*`
#   registry (NACK, TWCC, REMB, ULPFEC, RTX), the
#   `ice/v2` ICE stack with trickle ICE and Half-Trickle, the
#   `sctp/*` DataChannel transport, the `dtls/v2` DTLS-SRTP
#   transport, the SRTP/SRTCP cipher modules, stats API
#   (`pc.GetStats()`), and trickle-ICE non-blocking candidate
#   negotiation.  oneshot's
#   v2/pkg/net/webrtc/{client,server,signallingserver} construct
#   per-transfer `*webrtc.PeerConnection` instances, negotiate
#   trickle-ICE candidates over a WebSocket signaling channel
#   to the `oneshot discovery-server`, and open a single
#   `*webrtc.DataChannel` over which the entire HTTP request /
#   response body is framed.  Verified via:
#     gh api repos/forestnode-io/oneshot/contents/v2/go.mod
#       → module github.com/forestnode-io/oneshot/v2
#       → github.com/pion/webrtc/v3 v3.2.12
#       → github.com/pion/datachannel v1.5.5
#       → github.com/spf13/cobra v1.7.0
#     gh api repos/forestnode-io/oneshot/contents/v2/pkg/
#         commands/{send,receive,exec,rproxy,redirect,
#         discovery-server,version}/cobra.go
#       → cobra subcommands: send | receive | exec |
#                             reverse-proxy | redirect |
#                             discovery-server | version
#     gh api repos/forestnode-io/oneshot/contents/v2/pkg/
#         commands/send/configuration/configuration.go
#       → flags.StringP "archive-method" -a,
#                       "mime" -m,
#                       "name" -n,
#         flags.BoolP   "no-download" -D,
#         flags.Int     "status-code",
#         flags.StringSliceP "header" -H
#   This entry is the Go=154 leader bump that continues Axis 99
#   (WebRTC / webrtc-rs WebRTC stack) at 2/0/0 following R985
#   _live777 (Rust=154 OPENED the axis on webrtc-rs `webrtc`
#   git crate).  TS-Node=154 closing pair to follow at R987
#   (candidates: simple-peer / @roamhq/wrtc / wrtc users).
#
#   No completion for `oneshot` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_oneshot() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[path to YAML config file]:config:_files -g "*.yaml *.yml"' \
        '1: :_oneshot_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                send)
                    _arguments \
                        '(-a --archive-method)'{-a,--archive-method}'=[archive method for directory sends]:method:(zip tar.gz tar)' \
                        '(-D --no-download)'{-D,--no-download}'[do not allow client download]' \
                        '(-m --mime)'{-m,--mime}'=[MIME type of file presented to client]:mime:' \
                        '(-n --name)'{-n,--name}'=[name of file presented to client]:name:' \
                        '--status-code=[HTTP status code to send to client]:code:' \
                        '*'{-H,--header}'=[response header (KEY=VAL, repeatable)]:header:' \
                        '*:file or directory:_files' && ret=0 ;;
                receive)
                    _arguments \
                        '::output file:_files' && ret=0 ;;
                exec)
                    _arguments \
                        '*:command:_command_names -e' && ret=0 ;;
                reverse-proxy|rproxy)
                    _arguments \
                        '1:upstream host:' && ret=0 ;;
                redirect)
                    _arguments \
                        '1:redirect URL:' && ret=0 ;;
                discovery-server|version)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_oneshot_commands] )) ||
_oneshot_commands() {
    local -a commands
    commands=(
        'send:send a file or directory to the client'
        'receive:receive a file from the client'
        'exec:execute a command for each request'
        'reverse-proxy:reverse-proxy all requests to a host'
        'redirect:redirect all requests to a URL'
        'discovery-server:NAT-traversal discovery server (P2P WebRTC flow)'
        'version:print the version information'
    )
    _describe -t commands 'oneshot command' commands
}

_oneshot "$@"
