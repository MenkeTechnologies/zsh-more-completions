#compdef pt-fifo-split
# Documentation: https://man.archlinux.org/search?q=pt-fifo-split
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--fifo=[FIFO path]:file:_files' \
  '--lines=[lines per chunk]:n:' \
  '--offset=[offset lines]:n:' \
  '--pid=[PID file]:file:_files' \
  '--statistics[print statistics]' \
  '--force[force overwrite]' \
  '*:file:_files' && ret=0

return ret
