#compdef pt-fifo-split

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--fifo=[FIFO path]:file:_files' \
  '--lines=[lines per chunk]:n:' \
  '--offset=[offset lines]:n:' \
  '--pid=[PID file]:file:_files' \
  '--statistics[print statistics]' \
  '--force[force overwrite]' \
  '*:file:_files' && ret=0

return ret
