#compdef vtpdetect
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/vtpdetect.html
# Voronoi Tessellation and Percolation (VTP) source detection

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file name (event list or image)]:file:_files' \
  'expfile=[exposure map file with WCS matching input]:file:_files' \
  'outfile=[name of the output file]:file:_files' \
  'regfile=[filename for ASCII region output]:file:_files' \
  'ellsigma=[size in sigmas for elliptical source regions]:ellsigma:' \
  'scale=[background flux cutoff scale]:scale:' \
  'limit=[false source events per background events ratio]:limit:' \
  'coarse=[minimum number of events for a real source]:coarse:' \
  'maxiter=[maximum number of iterations allowed]:maxiter:' \
  'edge=[Voronoi tessellation edge depth control]:edge:' \
  'superdo=[enable super Voronoi cell update algorithm]:superdo:(yes no)' \
  'maxbkgflux=[maximum normalized background flux for Poisson fit]:maxbkgflux:' \
  'mintotflux=[minimum normalized total flux for parabola fit]:mintotflux:' \
  'maxtotflux=[maximum normalized total flux for parabola fit]:maxtotflux:' \
  'mincutoff=[minimum absolute normalized flux for cutoff]:mincutoff:' \
  'maxcutoff=[maximum absolute normalized flux for cutoff]:maxcutoff:' \
  'fittol=[fit tolerance on Poisson fit]:fittol:' \
  'fitstart=[initial guess at Poisson fit]:fitstart:' \
  'clobber=[remove output file if it already exists]:clobber:(yes no)' \
  'verbose=[level of informative output during execution]:verbose:(0 1 2 3 4 5)' \
  'logfile=[file where all messages will be directed]:file:_files' && ret=0

return ret
