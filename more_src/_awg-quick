#compdef awg-quick
# Documentation: https://man.archlinux.org/search?q=awg-quick
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'up:set up interface'
  'down:tear down interface'
  'save:save running config'
  'strip:print config without awg-quick directives'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'awg-quick subcommand' subcommands && ret=0
    ;;
  (args)
    _files -g '*.conf' && ret=0
    ;;
esac

return ret
