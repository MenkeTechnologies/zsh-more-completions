#compdef revbayes
# Documentation: https://github.com/revbayes/revbayes/blob/development/src/revlanguage/main.cpp
# RevBayes Bayesian phylogenetic inference. Flags mirror parse_cmd_line() in main.cpp.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-j --jupyter)'{-j,--jupyter}'[run in jupyter mode]' \
  '(-q --quiet)'{-q,--quiet}'[hide startup message]' \
  '(-i --interactive)'{-i,--interactive}'[force interactive (with file or -e expr)]' \
  '(-c --continue)'{-c,--continue}'[continue after error]' \
  '(-p --print-commands)'{-p,--print-commands}'[print commands from file or -e expr]' \
  '(-s --seed)'{-s,--seed}'=[random seed (unsigned integer)]:seed:' \
  '(-o --setOption)'{-o,--setOption}'=[set an option key=value]:option:' \
  '*-e[evaluate Rev expression]:expression:' \
  '*:Rev script:_files -g "*.Rev"' && ret=0

return ret
