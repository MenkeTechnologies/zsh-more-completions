#compdef textHistogram
# UCSC kent: make a histogram in ascii

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-binSize=[size of bins]:n:' \
  '-maxBinCount=[maximum number of bins]:n:' \
  '-minVal=[minimum value to put in histogram]:n:' \
  '-log[do log transformation before plotting]' \
  '-noStar[don'\''t draw asterisks]' \
  '-col=[which column to use]:n:' \
  '-aveCol=[second column to average over]:n:' \
  '-real[data input are real values]' \
  '-autoScale=[autoscale to N bins]:n:' \
  '-probValues[show prob-values (density and cum.distr.)]' \
  '-freq[show frequencies instead of counts]' \
  '-skip=[skip N lines before starting]:n:' \
  ':in file:_files' && ret=0

return ret
