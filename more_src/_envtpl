#compdef envtpl
# Documentation: https://github.com/subfuzion/envtpl
# envtpl - render Go templates on the command line with shell environment variables

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the version]' \
  '(-o --output)'{-o+,--output=}'[write the rendered output to a file]:file:_files' \
  '(-m --missingkey)'{-m+,--missingkey=}'[strategy for missing keys]:strategy:(default zero error)' \
  '1:template:_files' && ret=0

return ret
