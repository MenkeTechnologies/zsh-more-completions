#compdef autopkgtest-virt-null
# _autopkgtest-virt-null — null virtualisation backend for autopkgtest
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-null(1) man page.

_autopkgtest-virt-null() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[enable debugging output]' \
        '*--fake-capability=[advertise CAPABILITY regardless of implementation]:cap:(isolation-machine isolation-container revert revert-full-system reboot)'
}

_autopkgtest-virt-null "$@"
