#compdef lbzip2
# _lbzip2-bin — lbzip2 SMP-parallel bzip2 (Mikolaj Izdebski); bzip2-compatible parallel compressor
# upstream: https://lbzip2.org

_lbzip2-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-z --compress)'{-z,--compress}'[compress (default)]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-t --test)'{-t,--test}'[test]' \
        '(-c --stdout)'{-c,--stdout}'[stdout]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-S --no-sparse)'{-S,--no-sparse}'[disable sparse output]' \
        '(-u --no-utf8)'{-u,--no-utf8}'[disable UTF-8 transcode]' \
        '(-n --threads)'{-n,--threads}'+[threads]:n:' \
        '(-1)-1[smaller block]' \
        '(-2)-2[lvl 2]' \
        '(-3)-3[lvl 3]' \
        '(-4)-4[lvl 4]' \
        '(-5)-5[lvl 5]' \
        '(-6)-6[lvl 6]' \
        '(-7)-7[lvl 7]' \
        '(-8)-8[lvl 8]' \
        '(-9)-9[best]' \
        '*:file:_files'
}

_lbzip2-bin "$@"
