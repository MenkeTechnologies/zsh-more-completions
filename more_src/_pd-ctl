#compdef pd-ctl

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cluster:show cluster information'
  'config:show/edit PD configuration'
  'health:show health of PD members'
  'hot:show/configure hot region statistics'
  'log:get/set log level'
  'member:manage PD members'
  'operator:show/control operators'
  'ping:check connection to PD server'
  'plugin:plugin management'
  'region:show/operate regions'
  'scheduler:show/configure schedulers'
  'service-gc-safepoint:manage service GC safepoints'
  'store:manage TiKV stores'
  'tso:show physical/logical time of a TSO'
  'unsafe:unsafe operations'
  'completion:generate shell completion'
  'exit:exit interactive mode'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --interact)'{-i,--interact}'[interactive mode]' \
  '(-u --pd)'{-u+,--pd=}'[PD server endpoint(s)]:url:' \
  '(-d --detach)'{-d,--detach}'[detach (non-interactive)]' \
  '--cacert=[CA cert path]:file:_files' \
  '--cert=[client cert path]:file:_files' \
  '--key=[client key path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pd-ctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (operator)
        _arguments \
          '*::sub:(show add remove check)' \
          '*::kind:(admin leader region replica merge-region split-region transfer-leader transfer-region)' && ret=0 ;;
      (region)
        _arguments \
          '*::sub:(check sibling key startkey topread topwrite scan keys split-region merge-region)' && ret=0 ;;
      (scheduler)
        _arguments \
          '*::sub:(show add remove config pause resume describe)' \
          '*::kind:(balance-leader-scheduler balance-region-scheduler balance-hot-region-scheduler balance-witness-scheduler evict-leader-scheduler evict-slow-store-scheduler evict-slow-trend-scheduler grant-leader-scheduler grant-hot-region-scheduler shuffle-leader-scheduler shuffle-region-scheduler shuffle-hot-region-scheduler split-bucket-scheduler transfer-witness-leader-scheduler)' && ret=0 ;;
      (store)
        _arguments \
          '*::sub:(delete cancel-delete pause resume label weight remove-tombstone limit limit-scene)' && ret=0 ;;
      (config)
        _arguments '*::sub:(show set placement-rules)' && ret=0 ;;
      (member)
        _arguments '*::sub:(delete leader transfer)' && ret=0 ;;
      (log)
        _arguments '*::level:(debug info warn error fatal)' && ret=0 ;;
      (unsafe)
        _arguments '*::sub:(remove-failed-stores)' && ret=0 ;;
    esac ;;
esac

return ret
