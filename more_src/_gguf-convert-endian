#compdef gguf-convert-endian
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/gguf-py/gguf/scripts/gguf_convert_endian.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse in gguf-py/gguf/scripts/gguf_convert_endian.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--dry-run[do not actually change anything]' \
  '--verbose[increase output verbosity]' \
  '1:GGUF model:_files -g "*.gguf"' \
  '2:byte order:(big little native)' && ret=0

return ret
