#compdef tele-aria2
# ============================================================================
# _tele-aria2 — zsh completion for li-peifeng's tele-aria2, a Telegram
#                bot that controls an Aria2 RPC server (telegraf backed)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/li-peifeng/Tele-Aria2
#   Author     : li-peifeng
#   License    : MIT
#   Language   : TypeScript
#   Package    : tele-aria2 v0.2.2
#   Binary     : tele-aria2  (package.json bin: ./dist/run.js)
#   Last push  : 2025-01-28
#
# WHAT IT IS
#   tele-aria2 is "use Telegram to control Aria2 download tasks" —
#   a long-running Telegram bot that opens a WebSocket-JSON-RPC
#   connection to an Aria2 daemon and lets one or more allowed
#   Telegram user IDs add downloads, query active / waiting /
#   stopped task lists, pause / resume / remove individual tasks,
#   and monitor live progress.  All flags can also be supplied via
#   a JSON config file or environment variables.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/run.ts commander.js
#                       `program.option(...)` builder)
#   tele-aria2 [OPTIONS]
#
#   Options (none are subcommands — every option below is a top-
#   level flag):
#     -s, --aria2-server <ENDPOINT>   Aria2 server endpoint
#                                       e.g.
#                                       `ws://192.168.1.119:6800/jsonrpc`
#                                       [REQUIRED unless via config/env]
#     -k, --aria2-key    <KEY>        Aria2 server RPC secret key
#     -b, --bot-key      <KEY>        Telegram bot key
#                                       [REQUIRED unless via config/env]
#     -u, --user-id      <IDS>        Telegram user ID(s) — comma-
#                                       separated for multiple IDs.
#                                       [REQUIRED unless via config/env]
#     -p, --proxy        <URL>        Access Telegram server through
#                                       an HTTP proxy
#     -m, --max-index    <N>          Max items in the range [1, N]
#                                       used for list-format paginated
#                                       responses          [default: 20]
#     -c, --config       <FILE>       Load options from a JSON config
#                                       file (option names in the JSON
#                                       use the long-flag spelling,
#                                       e.g. `aria2-server`)
#     -V, --version                   Output the current version
#     -v, --verbose                   Verbose log output (winston
#                                       level = "verbose")
#
#   Environment-variable overrides (read by src/run.ts):
#     ta.aria2-server                 Aria2 endpoint
#     ta.aria2-key                    Aria2 RPC key
#     ta.bot-key                      Telegram bot token
#     ta.user-id                      Comma-separated allowed user IDs
#     https_proxy                     HTTP/HTTPS proxy for Telegram
#     ta.max-index                    Max paginated index
#
#   Option-source precedence (mergeWith in src/run.ts):
#     defaults < config file < env vars < CLI flags
#
# AXIS / CORPUS POSITION
#   Direct dependency on `telegraf ^3.38.0` declared in package.json
#   — the canonical Node.js Telegram Bot API client maintained by
#   the Telegraf team (telegrafjs/telegraf).  Telegraf provides
#   typed Bot API bindings, a middleware-style update pipeline,
#   scene/wizard dialogue support, inline keyboards, callback-query
#   helpers, and webhook + long-polling transports.  tele-aria2's
#   `src/Telegram.ts` constructs a `Telegraf<Context>` instance,
#   registers Aria2 event listeners + Telegram command handlers
#   (`onStart`, `onMessage`, `onAction`), and routes user requests
#   to the Aria2 WebSocket-JSON-RPC client.  Verified via:
#     gh api repos/li-peifeng/Tele-Aria2/contents/package.json
#       → "telegraf": "^3.38.0"
#     gh api repos/li-peifeng/Tele-Aria2/contents/src/Telegram.ts
#       → import Telegraf, { Markup, Context } from 'telegraf';
#         this.bot = this.connect2Tg({ botKey: options.botKey });
#   This entry is the TS-Node=130 leader bump that CLOSES Axis 75
#   (Telegram Bot API Client Library) at 1/1/1 three-language
#   symmetry — pairing Rust=teloxide 0.3 (R889 _logram),
#   Go=go-telegram-bot-api v4.6.4 (R890 _tg-bot), and TS-Node=
#   telegraf ^3.38.0 (this entry).  Triple-130 landmark on commit.
#
#   No completion for `tele-aria2` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_tele-aria2() {
    _arguments -s \
        '(-s --aria2-server)'{-s+,--aria2-server=}'[Aria2 server endpoint (e.g. ws\://host\:6800/jsonrpc)]:endpoint:' \
        '(-k --aria2-key)'{-k+,--aria2-key=}'[Aria2 server RPC secret key]:key:' \
        '(-b --bot-key)'{-b+,--bot-key=}'[Telegram bot key]:key:' \
        '(-u --user-id)'{-u+,--user-id=}'[Telegram user ID(s), comma-separated]:user IDs:' \
        '(-p --proxy)'{-p+,--proxy=}'[HTTP proxy URL for Telegram]:proxy URL:' \
        '(-m --max-index)'{-m+,--max-index=}'[max items per paginated range (default 20)]:n:' \
        '(-c --config)'{-c+,--config=}'[load options from JSON config file]:config file:_files -g "*.json"' \
        '(-V --version)'{-V,--version}'[output the current version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log output]' \
        '(- *)'{-h,--help}'[show help]'
}

_tele-aria2 "$@"
