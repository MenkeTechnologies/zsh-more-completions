#compdef g2o_simulator2d
# Documentation: https://github.com/RainerKuemmerle/g2o/blob/master/g2o/apps/g2o_simulator/test_simulator2d.cpp
# Generate a simulated 2D SLAM graph for g2o

local ret=1

_arguments -s -S \
  '-nlandmarks[number of landmarks in the map]:n' \
  '-nSegments[number of segments]:n' \
  '-segmentGridSize[number of cells of the grid to align segments]:n' \
  '-minSegmentLength[minimal length of a segment in the world]:len' \
  '-maxSegmentLength[maximal length of a segment in the world]:len' \
  '-simSteps[number of simulation steps]:n' \
  '-worldSize[size of the world]:size' \
  '-hasOdom[the robot has an odometry]' \
  '-hasPointSensor[the robot has a point sensor]' \
  '-hasPointBearingSensor[the robot has a point bearing sensor]' \
  '-hasPoseSensor[the robot has a pose sensor]' \
  '-hasCompass[the robot has a compass]' \
  '-hasGPS[the robot has a GPS]' \
  '-hasSegmentSensor[the robot has a segment sensor]' \
  '*:output:_files -g "*.g2o"' && ret=0

return ret
