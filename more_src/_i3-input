#compdef i3-input
# Documentation: https://i3wm.org/docs/i3-input.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# i3-input — interactive text input dialog for i3 window manager

local curcontext="$curcontext" state line ret=1

# i3-input uses short flags only (no long-option counterparts per upstream docs)
_arguments -s -S \
  '-s+[i3 IPC socket path]:socket:_files' \
  '-F+[format string (%s replaced by input)]:format' \
  '-l+[maximum input length]:length' \
  '-P+[prompt prefix string]:prefix' \
  '-f+[X11 font to use]:font' \
  '-v[show version]' \
  '-h[show help]' && ret=0

return ret
