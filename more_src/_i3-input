#compdef i3-input

# Zsh completion for i3-input (i3 text input dialog)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --socket)'{-s,--socket}'=[Use the specified socket path]:socket path:_files' \
  '(-F --format)'{-F,--format}'=[Format string for the command to execute]:format string' \
  '(-l --limit)'{-l,--limit}'=[Set the maximum length of the input]:length' \
  '(-P --prefix)'{-P,--prefix}'=[Set the prompt prefix]:prefix' \
  '(-f --font)'{-f,--font}'=[Set the font to use]:font' \
  '(-v --version)'{-v,--version}'[Display version]' \
  '(-h --help)'{-h,--help}'[Display help]' && ret=0

return ret
