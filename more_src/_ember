#compdef ember
# _ember — Ember.js framework CLI (Ember.js Team, JavaScript); commander
# upstream: https://github.com/ember-cli/ember-cli

_ember() {
    local -a sub=(
        'new:scaffold project'
        'init:init in current directory'
        'build:build app'
        'b:build app (alias)'
        'serve:run dev server'
        's:run dev server (alias)'
        'test:run tests'
        't:run tests (alias)'
        'generate:generate code'
        'g:generate code (alias)'
        'destroy:undo generation'
        'd:undo generation (alias)'
        'install:install addon'
        'addon:scaffold addon'
        'help:show help'
        'version:show version'
        'asset-sizes:show asset sizes'
        'completion:generate shell completion'
        'unattended-install:unattended install'
        'lint:run linter'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--silent[silent]' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '--config-path=+[config path]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ember subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:name:' \
                    '--dry-run[dry run]' \
                    '-d[dry run]' \
                    '--verbose[verbose]' \
                    '-v[verbose]' \
                    '--blueprint=+[blueprint]:str:' \
                    '-b+[blueprint]:str:' \
                    '--skip-npm[skip npm]' \
                    '--skip-git[skip git]' \
                    '--skip-bower[skip bower]' \
                    '-sg[skip git]' \
                    '--directory=+[directory]:dir:_files -/' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn bun)' \
                    '--lang=+[language]:lang:(en-US)' \
                    '--embroider[use embroider]' \
                    '--no-welcome[no welcome page]' \
                    '--typescript[typescript]' \
                    '--ci-provider=+[ci provider]:c:(github travis)' \
                    '--strict[strict]' ;;
                init) _arguments \
                    '--blueprint=+[blueprint]:str:' \
                    '-b+[blueprint]:str:' \
                    '--lint-fix[lint fix]' \
                    '--strict[strict]' \
                    '--name=+[name]:str:' \
                    '--skip-npm[skip npm]' ;;
                build|b) _arguments \
                    '--environment=+[environment]:e:(development production test)' \
                    '-e+[environment]:e:(development production test)' \
                    '--output-path=+[output path]:dir:_files -/' \
                    '-o+[output path]:dir:_files -/' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--watcher=+[watcher]:str:' \
                    '--no-cleanup[no cleanup]' \
                    '--suppress-sizes[suppress sizes]' ;;
                serve|s) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--proxy=+[proxy]:url:_urls' \
                    '--secure-proxy=+[secure proxy]:b:(true false)' \
                    '--transparent-proxy=+[transparent proxy]:b:(true false)' \
                    '--watcher=+[watcher]:str:' \
                    '--watch=+[watch]:b:(true false)' \
                    '--live-reload=+[live reload]:b:(true false)' \
                    '--live-reload-host=+[live reload host]:host:_hosts' \
                    '--live-reload-port=+[live reload port]:port:' \
                    '--ssl=+[ssl]:b:(true false)' \
                    '--ssl-key=+[ssl key]:file:_files' \
                    '--ssl-cert=+[ssl cert]:file:_files' ;;
                test|t) _arguments \
                    '--environment=+[environment]:e:(development production test)' \
                    '-e+[environment]:e:(development production test)' \
                    '--config-file=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--server[server mode]' \
                    '--host=+[host]:host:_hosts' \
                    '--test-port=+[test port]:port:' \
                    '--filter=+[filter]:str:' \
                    '-f+[filter]:str:' \
                    '--module=+[module]:str:' \
                    '-m+[module]:str:' \
                    '--watcher=+[watcher]:str:' \
                    '--launch=+[launchers]:list:(Chrome Firefox Safari PhantomJS Electron)' \
                    '--reporter=+[reporter]:str:' \
                    '--silent[silent]' \
                    '--ssl=+[ssl]:b:(true false)' \
                    '--ssl-key=+[ssl key]:file:_files' \
                    '--ssl-cert=+[ssl cert]:file:_files' \
                    '--testem-debug=+[testem debug]:file:_files' \
                    '--test-page=+[test page url]:url:_urls' \
                    '--query=+[query]:str:' \
                    '--test-options=+[test options]:str:' \
                    '--config-options=+[config options]:str:' ;;
                generate|g|destroy|d) _arguments \
                    '1:blueprint:(component controller helper model route service template adapter serializer mixin util test test-helper acceptance-test addon-import blueprint http-mock http-proxy in-repo-addon initializer instance-initializer object utility-test transform)' \
                    '*:name:' ;;
                install) _arguments \
                    '*:addon-name:' \
                    '--save[save]' \
                    '--save-dev[save dev]' ;;
                addon) _arguments \
                    '1:name:' \
                    '--blueprint=+[blueprint]:str:' \
                    '-b+[blueprint]:str:' \
                    '--skip-npm[skip npm]' \
                    '--skip-git[skip git]' ;;
                asset-sizes) _arguments \
                    '--output-path=+[output path]:dir:_files -/' \
                    '-o+[output path]:dir:_files -/' \
                    '--json[json output]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_ember "$@"
