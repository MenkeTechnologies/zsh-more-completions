#compdef jags
# Documentation: https://manpages.debian.org/testing/jags/jags.1.en.html
# jags - Just Another Gibbs Sampler command-line interface

local ret=1

_arguments -s -S \
  '(-d --debugger)'{-d,--debugger=}'[run jags through debugger NAME]:debugger:_command_names -e' \
  '--debugger-args=[pass ARGS to the debugger]:args:' \
  '1:script file:_files' && ret=0

return ret
