#compdef httpie
# Documentation: https://httpie.io/docs/cli/manager
# Source: httpie/cli — httpie manager CLI (httpie/manager/cli.py).
# Reference accessed: 2026-06-10
# Note: separate from `http`/`https` request commands — this binary manages
# plugins and sessions for the HTTPie installation itself.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_httpie_plugins() {
    local -a sub
    sub=(
        'install:install plugin(s) from PyPI or local path'
        'upgrade:upgrade installed plugin(s) to latest version'
        'uninstall:remove installed plugin(s)'
        'list:list installed HTTPie plugins'
    )
    _describe -t plugins-subcmds 'httpie plugins subcommand' sub
}

_httpie_cli() {
    local -a sub
    sub=(
        'export-args:export available request-command options'
        'check-updates:check for HTTPie updates'
        'sessions:manage HTTPie sessions'
    )
    _describe -t cli-subcmds 'httpie cli subcommand' sub
}

_httpie_sessions() {
    local -a sub
    sub=(
        'upgrade:upgrade a single session for HOSTNAME'
        'upgrade-all:upgrade all named sessions'
    )
    _describe -t sessions-subcmds 'httpie cli sessions subcommand' sub
}

_arguments -C \
    '--debug[turn on Python tracebacks + DEBUG-level logging]' \
    '--traceback[turn on Python tracebacks (no DEBUG logging)]' \
    '(- *)--version[show program version and exit]' \
    '(- *)--help[show help and exit]' \
    '1: :->verb' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        local -a verbs
        verbs=(
            'plugins:manage HTTPie plugins'
            'cli:CLI / sessions / plugin export commands'
        )
        _describe -t httpie-verbs 'httpie subcommand' verbs && ret=0
        ;;
    args)
        case $line[1] in
            plugins)
                if (( CURRENT == 2 )); then
                    _httpie_plugins && ret=0
                else
                    case $line[2] in
                        install|upgrade|uninstall)
                            _arguments '*:target (PyPI name or local path):_files' && ret=0
                            ;;
                        list)
                            ret=0
                            ;;
                    esac
                fi
                ;;
            cli)
                if (( CURRENT == 2 )); then
                    _httpie_cli && ret=0
                else
                    case $line[2] in
                        export-args)
                            _arguments \
                                '(-f --format)'{-f,--format}'[output format]:format:(json)' \
                                && ret=0
                            ;;
                        check-updates)
                            ret=0
                            ;;
                        sessions)
                            if (( CURRENT == 3 )); then
                                _httpie_sessions && ret=0
                            else
                                case $line[3] in
                                    upgrade)
                                        _arguments \
                                            '--bind-cookies[bind cookies to the request hostname]' \
                                            '1:hostname:_hosts' \
                                            '2:session-name-or-path:_files' \
                                            && ret=0
                                        ;;
                                    upgrade-all)
                                        _arguments \
                                            '--bind-cookies[bind cookies to the request hostname]' \
                                            && ret=0
                                        ;;
                                esac
                            fi
                            ;;
                    esac
                fi
                ;;
    esac
    ;;
esac

return ret
