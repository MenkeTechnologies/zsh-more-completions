#compdef psc-package
# _psc-package — PureScript psc-package package manager CLI (purescript team, Haskell); optparse-applicative
# upstream: https://github.com/purescript/psc-package

_psc-package() {
    local -a sub=(
        'init:initialize psc-package.json'
        'uninstall:remove dependency from psc-package.json'
        'install:install or update dependencies'
        'update:update all dependencies'
        'build:build the project'
        'available:list packages in package set'
        'sources:list source globs'
        'dependencies:list all dependencies'
        'verify:verify packages build'
        'verify-set:verify the entire package set'
        'updates:show outdated dependencies'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'psc-package subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|verify) _arguments '1:package name:' ;;
                build) _arguments '*:purs args:' ;;
                init) _arguments \
                    '--name=+[project name]:str:' \
                    '--source=+[package set source]:url:_urls' \
                    '--set=+[package set version]:str:' ;;
                available) _arguments '--json[json output]' '--show=+[type]:t:(all installed missing)' ;;
                updates) _arguments '--check[check only]' ;;
            esac
            ;;
    esac
}

_psc-package "$@"
