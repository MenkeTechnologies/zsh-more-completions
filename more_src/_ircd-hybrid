#compdef ircd-hybrid ircd
# _ircd-hybrid — Hybrid IRC daemon (ircd-hybrid/ircd-hybrid)
# upstream: https://github.com/ircd-hybrid/ircd-hybrid
# Flags from src/ircd.c (io_getopt myopts[]).

_ircd-hybrid() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-c --configfile)'{-c+,--configfile=}'[ircd.conf path]:file:_files -g "*.conf"' \
        '(-k --klinefile)'{-k+,--klinefile=}'[kline database]:file:_files' \
        '(-d --dlinefile)'{-d+,--dlinefile=}'[dline database]:file:_files' \
        '(-x --xlinefile)'{-x+,--xlinefile=}'[xline database]:file:_files' \
        '(-r --resvfile)'{-r+,--resvfile=}'[resv database]:file:_files' \
        '(-l --logfile)'{-l+,--logfile=}'[ircd.log path]:file:_files -g "*.log"' \
        '(-p --pidfile)'{-p+,--pidfile=}'[PID file]:file:_files' \
        '(-f --foreground)'{-f,--foreground}'[run in foreground (no daemonize)]'
}

_ircd-hybrid "$@"
