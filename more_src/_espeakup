#compdef espeakup

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug mode (no fork)]' \
  '(-D --default-voice)'{-D,--default-voice}'+[default voice]:voice:' \
  '(-l --lang)'{-l,--lang}'+[default language]:lang:' \
  '(-m --mbrola)'{-m,--mbrola}'+[mbrola voice]:voice:' \
  '(-P --pid)'{-P,--pid}'+[PID file]:file:_files' \
  '(-s --soft)'{-s,--soft}'+[soft synth port]:device:' \
  '(-V --vol)'{-V,--vol}'+[volume]:vol:' && ret=0

return ret
