#compdef pdns_recursor

_arguments -s \
  '--allow-from=[allowed networks]:nets:' \
  '--auth-zones=[auth zones]:list:' \
  '--chroot=[chroot directory]:dir:_files -/' \
  '--client-tcp-timeout=[client TCP timeout]:secs:' \
  '--config=[config display mode]:mode:(default diff check)' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--daemon[run as daemon]' \
  '--export-etc-hosts[export /etc/hosts]' \
  '--forward-zones=[forward zones]:list:' \
  '--forward-zones-file=[forward zones file]:file:_files' \
  '(- *)--help[show help]' \
  '--hint-file=[hint file]:file:_files' \
  '--local-address=[local address]:addr:' \
  '--local-port=[local port]:port:' \
  '--log-common-errors[log common errors]' \
  '--max-cache-entries=[max cache entries]:n:' \
  '--max-negative-ttl=[max negative TTL]:n:' \
  '--max-tcp-clients=[max TCP clients]:n:' \
  '--max-tcp-per-client=[max TCP per client]:n:' \
  '--query-local-address=[query local address(es)]:addrs:' \
  '--quiet[quiet output]' \
  '--server-id=[server ID text]:text:' \
  '--serve-rfc1918[serve RFC1918 zones]' \
  '--setgid=[gid]:gid:' \
  '--setuid=[uid]:uid:' \
  '--single-socket[use single socket]' \
  '--socket-dir=[socket directory]:dir:_files -/' \
  '--spoof-nearmiss-max=[spoof nearmiss max]:n:' \
  '--trace[enable tracing]' \
  '--version-string=[version string]:text:'
