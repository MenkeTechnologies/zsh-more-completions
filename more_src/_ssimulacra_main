#compdef ssimulacra_main
# Documentation: https://man.archlinux.org/search?q=ssimulacra_main
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '-v[verbose]' \
  '-s[summary]' \
  '1:original PNG:_files -g "*.png"' \
  '2:distorted PNG:_files -g "*.png"' && ret=0

return ret
