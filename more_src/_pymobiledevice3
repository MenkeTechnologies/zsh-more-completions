#compdef pymobiledevice3
# Documentation: https://github.com/doronz88/pymobiledevice3/blob/master/README.md
# Pure python3 implementation for working with iDevices (iPhone, etc...)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(activation afc amfi apps backup2 bonjour companion crash developer diagnostics lockdown mounter notification pcap power-assertion processes profile provision restore springboard syslog usbmux install-completions)' \
  '*::args:->args' && ret=0

return ret
