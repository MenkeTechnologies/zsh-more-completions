#compdef computeMatrixOperations
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/computeMatrixOperations.html
# deepTools: subset, filter, merge, and sort computeMatrix output files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:((info\:"print group and sample information" relabel\:"change sample/group labels" subset\:"subset the matrix" filterStrand\:"filter entries by strand" filterValues\:"filter entries by min/max value" rbind\:"merge matrices head to tail" cbind\:"merge matrices left to right" sort\:"sort matrix to match input region order" dataRange\:"print per-sample value range stats"))' \
  '(-m --matrixFile)'{-m,--matrixFile}'[matrix file from computeMatrix]:file:_files' \
  '(-o --outFileName)'{-o,--outFileName}'[output file name]:file:_files' \
  '--groupLabels[group labels]:labels:' \
  '--sampleLabels[sample labels]:labels:' \
  '--groups[groups to include]:groups:' \
  '--samples[samples to include]:samples:' \
  '(-s --strand)'{-s,--strand}'[strand to keep]:strand:(+ - .)' \
  '--min[minimum value threshold]:n:' \
  '--max[maximum value threshold]:n:' \
  '(-R --regionsFileName)'{-R,--regionsFileName}'[BED/GTF region file(s)]:file:_files' \
  '--transcriptID[GTF transcript feature type]:id:' \
  '--transcript_id_designator[region ID key for GTF files]:key:' && ret=0

return ret
