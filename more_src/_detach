#compdef detach
# Documentation: https://man.archlinux.org/search?q=detach
# Reference accessed: 2026-05-16

# Zsh completion for detach
# Upstream: Execute given command in detached process
# Conservative fallback — run `detach --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
