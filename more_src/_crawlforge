#compdef crawlforge
# Documentation: https://www.npmjs.com/package/@crawlforge/cli
# Reference accessed: 2026-05-22
# Verified: CrawlForge v4.2.2 CLI announcement and command examples.

# Zsh completion for crawlforge - local AI web scraping CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'crawlforge command' \
      'scrape[scrape a URL]' \
      'search[web search]' \
      'research[deep research crawl]' \
      'extract[LLM structured extraction]' \
      'template[pre-built site template]' \
      'list-ollama-models[list local Ollama models]' && ret=0
    ;;
  args)
    case $line[1] in
      scrape|search)
        _arguments '1:url or query:' && ret=0
        ;;
      research)
        _arguments \
          '--depth[crawl depth]:depth:' \
          '1:query:' && ret=0
        ;;
      extract)
        _arguments \
          '--provider[LLM provider]:provider:(ollama)' \
          '--model[model name]:model:' \
          '1:prompt or url:' && ret=0
        ;;
      template)
        _arguments \
          '1:template:(amazon github hackernews youtube reddit stackoverflow npm producthunt twitter)' \
          '--url[target URL]:url:' \
          '--top[top N items hackernews]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
