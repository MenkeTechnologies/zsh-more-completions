#compdef walkmod-cli
# Documentation: http://www.walkmod.com
# Reference accessed: 2026-05-23
# Verified: walkmod-core README and walkmod-git-plugin usage.

# Zsh completion for walkmod-cli - Java code convention and refactoring CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'walkmod command' \
      'apply[apply conventions to project]' \
      'add[add transformation or plugin]' \
      'set-reader[set incremental git reader]' && ret=0
    ;;
  args)
    case $line[1] in
      set-reader)
        _arguments ':reader:(git:reader)' && ret=0
        ;;
      add)
        _arguments '*:plugin or transformation:' && ret=0
        ;;
    esac
    ;;
esac

return ret
