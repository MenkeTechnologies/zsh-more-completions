#compdef disnix-capture-infra
# _disnix-capture-infra — capture container configs into an infra Nix expr (svanderburg/disnix)
# upstream: https://github.com/svanderburg/disnix
# Flags from src/capture-infra/main.c (getopt_long).

_disnix-capture-infra() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--interface=[Disnix interface executable]:cmd:' \
        '--target-property=[infra-model property for connection]:prop:' \
        '--xml[treat configurations as XML]' \
        '1:infrastructure file:_files -g "*.nix"'
}

_disnix-capture-infra "$@"
