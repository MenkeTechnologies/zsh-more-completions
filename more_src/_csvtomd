#compdef csvtomd
# _csvtomd — Matt Curry csvtomd CSV-to-markdown table converter CLI alias (mattduck team, Python); argparse
# upstream: https://github.com/mattduck/csvtomd

_csvtomd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--delim=+[delimiter]:str:' \
        '-d+[delimiter]:str:' \
        '--padding=+[padding]:n:' \
        '-p+[padding]:n:' \
        '--no-padding[no padding]' \
        '-n[no padding]' \
        '--no-header[no header]' \
        '*:csv files:_files -g "*.csv"'
}

_csvtomd "$@"
