#compdef meek-client
# Documentation: https://man.archlinux.org/search?q=meek-client
# Reference accessed: 2026-05-16

# meek-client: Tor pluggable transport client using domain fronting
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-url=[upstream URL (meek server)]:url:' \
  '-front=[domain to front through]:domain:_hosts' \
  '-utls=[uTLS fingerprint]:fingerprint:(hellochrome_auto hellofirefox_auto helloios_auto helloedge_auto)' \
  '-proxy=[proxy URL (socks5://...)]:url:' \
  '-helper=[helper URL (firefox-based)]:url:' \
  '-log=[log file]:file:_files' \
  '*::meek-client args:_files' && ret=0
return ret
