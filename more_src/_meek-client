#compdef meek-client

# meek-client: Tor meek pluggable transport client side
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-helper[meek-client-torbrowser helper]:cmd:' \
  '-log[log file]:file:_files' \
  '-url[front URL]:url:' \
  '-front[front domain]:host:' \
  '-utls[use uTLS fingerprint]:tls:' \
  '-allowed-cipher-suites[ciphers list]:list:' \
  '-proxy[upstream proxy URL]:url:' \
  '*::meek-client args:_files' && ret=0
return ret
