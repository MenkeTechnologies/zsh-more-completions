#compdef fshfsinfo fshfsmount
# _libfshfs — libfshfs tools (Joachim Metz libyal family for parsing Apple's HFS / HFS+ filesystem on Linux/BSD; fshfsinfo dumps catalog + extents, fshfsmount FUSE-mounts an HFS image read-only; -h help, -V version, -v verbose, -o image offset, -p password, -B bytes-per-block override)
# upstream: https://github.com/libyal/libfshfs
# Flags from libyal/libfshfs fshfstools/fshfsinfo.c on tip.

_libfshfs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-B+[bytes per block]:bytes:' \
        '*:HFS image:_files'
}

_libfshfs "$@"
