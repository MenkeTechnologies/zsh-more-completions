#compdef microdnf
# Zsh completion for microdnf - Lightweight DNF package manager for containers
# https://github.com/rpm-software-management/microdnf

local -a commands=(
  'install:install packages'
  'reinstall:reinstall packages'
  'remove:remove packages'
  'upgrade:upgrade packages'
  'downgrade:downgrade packages'
  'distro-sync:synchronize installed packages to latest available versions'
  'autoremove:remove unneeded packages'
  'clean:clean cached data'
  'repolist:list configured repositories'
  'repoquery:search for packages'
  'makecache:generate repository metadata cache'
  'module:manage modules'
  'advisory:manage advisories'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--allowerasing[allow erasing of installed packages to resolve dependencies]' \
  '--assumeyes[answer yes for all questions]' \
  '--best[try the best available package versions]' \
  '--config=[set config file location]:config file:_files' \
  '--disablerepo=[disable repository]:repository:' \
  '--enablerepo=[enable repository]:repository:' \
  '--installroot=[set install root directory]:directory:_files -/' \
  '--nodocs[do not install documentation]' \
  '--noplugins[disable all plugins]' \
  '--nogpgcheck[skip GPG check]' \
  '--refresh[force refresh of metadata]' \
  '--releasever=[set release version]:version:' \
  '--repo=[enable only specific repository]:repository:' \
  '--repofrompath=[specify path to additional repository]:name\,path:' \
  '--setopt=[set config and repo options]:option:' \
  '-y[answer yes for all questions]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'microdnf command' commands
    ;;
  args)
    case $words[1] in
      install|reinstall|remove|upgrade|downgrade)
        _arguments '*:package name:'
        ;;
      clean)
        _arguments '1:clean type:(all packages metadata dbcache expire-cache)'
        ;;
      repolist)
        _arguments '1:filter:(--all --enabled --disabled)'
        ;;
    esac
    ;;
esac
