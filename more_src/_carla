#compdef carla
# Documentation: https://github.com/falkTX/Carla
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (see source/frontend/carla_shared.py:handleInitialCommandLineArguments).

# Carla audio plugin host (LADSPA/DSSI/LV2/VST2/VST3/CLAU/AU/SFZ/SF2/JSFX).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-gui[run headless without UI]' \
  '--nogui[run headless without UI]' \
  '-n[run headless without UI]' \
  '--with-appname=[set application name]:name:' \
  '--with-libprefix=[library prefix path]:path:_directories' \
  '--osc-gui=[OSC GUI mode]:mode:' \
  '--cnprefix=[client name prefix]:prefix:' \
  '--gdb[run inside gdb]' \
  '*:project file:_files -g "*.carxp"' && ret=0

return ret
