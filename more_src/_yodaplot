#compdef yodaplot
# Documentation: https://yoda.hepforge.org/
# yodaplot - render .dat plot-specification files to PDF/PNG etc

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --format)'{-f,--format}'[output format string, comma-separated]:format:' \
  '--mode[mode of plot combination]:mode:(CMP FILE)' \
  '(-m --match)'{-m,--match}'[only use histograms whose path matches this regex]:regex:' \
  '(-M --unmatch)'{-M,--unmatch}'[exclude histograms whose path matches this regex]:regex:' \
  '(-E --engine)'{-E,--engine}'[choose rendering engine]:engine:(PGF TEX MPL)' \
  '--debug[run in debug mode with more verbosity and no parallelism]' \
  '--quiet[run in quiet mode with no status output]' \
  '*:datfile:_files' && ret=0

return ret
