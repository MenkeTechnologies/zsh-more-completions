#compdef amass2
# _amass2 — OWASP amass2 CLI command-line frontend wrapping the OWASP Amass open-source in-depth attack surface mapping asset discovery network mapping subdomain enumeration tool by Jeff Foley providing intel enum viz track db config datasource-API-keys passive-active recursive DNS-brute-force OSINT-data-sources alterations permutations Marshalled-graph-DB DataLossDB Shodan Censys VirusTotal SecurityTrails AlienVault PassiveTotal RiskIQ Greynoise (OWASP Amass Jeff Foley team, Go); flag
# upstream: https://owasp.org/www-project-amass/

_amass2() {
    local -a sub=(
        'intel:gather intelligence'
        'enum:enumerate subdomains'
        'viz:visualize'
        'track:track changes'
        'db:database operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-active[active mode]' \
        '-passive[passive mode]' \
        '-brute[DNS brute force]' \
        '-alts[alterations]' \
        '-d+[domain]:str:' \
        '-df+[domains file]:file:_files' \
        '-ef+[exclude file]:file:_files' \
        '-r+[resolver]:str:' \
        '-rf+[resolvers file]:file:_files' \
        '-config+[config file]:file:_files -g "config.yaml *.yaml *.yml *.ini"' \
        '-min-for-recursive+[N]:n:' \
        '-max-depth+[N]:n:' \
        '-max-dns-queries+[N]:n:' \
        '-min-for-passive+[N]:n:' \
        '-w+[wordlist]:file:_files' \
        '-aw+[alterations wordlist]:file:_files' \
        '-bw+[brute wordlist]:file:_files' \
        '-blf+[blacklist file]:file:_files' \
        '-exclude+[exclude sources]:str:' \
        '-include+[include sources]:str:' \
        '-src[show source]' \
        '-list[list sources]' \
        '-log+[log file]:file:_files' \
        '-dir+[graph dir]:dir:_files -/' \
        '-json+[json output]:file:_files -g "*.json"' \
        '-o+[text output]:file:_files' \
        '-oA+[all output prefix]:str:' \
        '-html+[HTML output]:file:_files -g "*.html"' \
        '-d3+[D3 output]:file:_files' \
        '-dot+[DOT output]:file:_files -g "*.dot"' \
        '-gexf+[GEXF output]:file:_files -g "*.gexf"' \
        '-graphistry+[file]:file:_files' \
        '-maltego+[file]:file:_files' \
        '-cidr+[CIDR]:str:' \
        '-asn+[ASN]:n:' \
        '-org+[org name]:str:' \
        '-whois[reverse WHOIS]' \
        '-ip[show IPs]' \
        '-ipv4[show IPv4]' \
        '-ipv6[show IPv6]' \
        '-show[show sources]' \
        '-demo[demo mode]' \
        '-nocolor[no color]' \
        '-silent[silent mode]' \
        '-share[share results]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amass subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_amass2 "$@"
