#compdef changeset
# _changesets-cli — changesets monorepo versioning CLI (Atlassian); generates changelog + bumps versions across workspaces
# upstream: https://github.com/changesets/changesets

_changesets-cli() {
    local -a sub=(
        'init:create .changeset directory + config'
        'add:add a changeset (interactive)'
        'version:apply changesets and bump versions'
        'publish:publish bumped packages'
        'status:report unreleased changesets'
        'pre:enter/exit pre-release mode'
        'tag:create git tags for released versions'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'changeset subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--empty[create empty changeset]' \
                    '--open[open editor]' ;;
                publish) _arguments \
                    '--otp+[npm OTP]:otp:' \
                    '--no-git-tag[skip git tag]' \
                    '--gitTag[force git tag]' \
                    '--snapshot+[snapshot tag]:tag:' \
                    '--tag+[npm dist-tag]:tag:' ;;
                status) _arguments \
                    '--output+[output file]:file:_files' \
                    '--verbose[verbose]' \
                    '--since+[since git ref]:ref:' \
                    '--sinceMaster[since main]' ;;
                pre) _arguments \
                    '1:action:(enter exit)' \
                    '2:tag:' ;;
                version) _arguments \
                    '--snapshot+[snapshot tag]:tag:' \
                    '--ignore+[ignore package]:pkg:' ;;
                tag) _arguments \
                    '--git[run git tag]' \
                    '--from+[from ref]:ref:' ;;
            esac
            ;;
    esac
}

_changesets-cli "$@"
