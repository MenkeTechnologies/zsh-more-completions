#compdef stack2nix
# Documentation: https://github.com/input-output-hk/stack2nix
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-c --container)'{-c,--container}'+[container]:c:' \
  '--platform=+[platform]:platform:' \
  '--hackage-snapshot=+[hackage snapshot]:snap:' \
  '--test[include tests]' \
  '--bench[include benchmarks]' \
  '--haddock[include haddock]' \
  '--nixpkgs-revision=+[nixpkgs revision]:rev:' \
  '--verbose[verbose]' \
  '--jobs=+[parallel jobs]:n:' \
  '*:stack.yaml:_files -g "stack.yaml"' && ret=0

return ret
