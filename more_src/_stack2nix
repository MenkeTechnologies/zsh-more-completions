#compdef stack2nix
# Documentation: https://github.com/input-output-hk/stack2nix
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version number]' \
  '--revision=[revision to use when fetching from VCS]:rev:' \
  '-o+[output file for generated nix expression]:file:_files' \
  '--stack-yaml=[override project stack.yaml file]:file:_files -g "*.yaml"' \
  '-j+[number of threads for subprocesses]:int:' \
  '--test[enable tests]' \
  '--bench[enable benchmarks]' \
  '--haddock[enable documentation generation]' \
  '--hackage-snapshot=[hackage snapshot time, ISO format]:time:' \
  '--platform=[target platform (e.g. x86_64-linux)]:platform:(i686-linux x86_64-linux i686-osx x86_64-osx i686-darwin x86_64-darwin)' \
  '--no-indent[disable indentation and place one item per line]' \
  '--verbose[verbose output]' \
  '--cabal2nix-args=[extra arguments for cabal2nix]:args:' \
  '--no-ensure-executables[do not ensure required executables are installed]' \
  '*:URI:_files' && ret=0

return ret
