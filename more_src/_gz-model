#compdef gz-model
# Documentation: https://gazebosim.org/docs
# Gazebo Sim model introspection tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--force-version=[use a particular library version]:version' \
  '--versions[list available versions]' \
  '--list[retrieve available models]' \
  '(-m --model)'{-m,--model}'=[specify which model to display]:model' \
  '(-p --pose)'{-p,--pose}'[show model position and orientation]' \
  '(-l --link)'{-l,--link}'=[display link properties]:link' \
  '(-s --sensor)'{-s,--sensor}'=[display sensor properties]:sensor' \
  '(-j --joint)'{-j,--joint}'=[display joint properties]:joint' && ret=0

return ret
