#compdef coq_makefile

# Zsh completion for coq_makefile - generate Makefile for Coq projects

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f[Makefile output name]:file:_files' \
  '-o[output Makefile name]:file:_files' \
  '-R[recursively map a directory]:directory:_files -/ logical name' \
  '-Q[map a directory (non-recursive)]:directory:_files -/ logical name' \
  '-I[add directory to ML include path]:directory:_files -/' \
  '-arg[pass an argument to Coq]:argument' \
  '-install[installation mode]:mode:(user none global)' \
  '-docroot[root URL for documentation]:URL' \
  '*:Coq source files:_files -g "*.v *.ml *.mli *.ml4 *.mlg *.mlpack *.mllib"'
