#compdef nd2tool
# Documentation: https://github.com/elgw/nd2tool
# Convert Nikon ND2 files to TIFF and extract metadata

local ret=1

_arguments -s -S \
  '--help[show quick command reference]' \
  '--info[print a short summary of metadata]' \
  '--meta[extract all metadata]' \
  '--meta-file[extract file-level metadata]' \
  '--meta-coord[extract coordinate metadata]' \
  '--meta-frame[extract frame metadata]' \
  '--meta-text[extract text metadata]' \
  '--meta-exp[extract experiment metadata]' \
  '--composite[export one TIFF per field of view]' \
  '--coord[export FOV coordinates as CSV]' \
  '--deconwolf[generate deconwolf deconvolution scripts]' \
  '--deconwolfx[interactively generate deconwolf scripts]' \
  '--deconwolf_dots[generate deconwolf spot-detection scripts]' \
  '*:nd2 file:_files -g "*.nd2"' && ret=0

return ret
