#compdef demumble
# Documentation: https://man.archlinux.org/search?q=demumble
# Reference accessed: 2026-05-16

# Zsh completion for demumble
# Upstream: More powerful symbol demangler (a la c++filt)
# Conservative fallback — run `demumble --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
