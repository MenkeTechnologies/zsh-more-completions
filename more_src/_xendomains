#compdef xendomains
# Documentation: https://man.archlinux.org/search?q=xendomains
# Reference accessed: 2026-05-16

# xendomains: start/stop/save Xen guests via service init
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1:action:(start stop status restart reload force-reload save shutdown)' \
  '*::xendomains args:_files' && ret=0
return ret
