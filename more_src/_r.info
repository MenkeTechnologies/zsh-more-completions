#compdef r.info
# Documentation: https://grass.osgeo.org/grass-stable/manuals/r.info.html
# Outputs basic information about a raster map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-g[print raster array information]' \
  '-r[print range]' \
  '-s[print stats]' \
  '-e[print extended metadata information]' \
  '-h[print raster history]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  'map=[name of raster map]:map:' \
  'format=[output format]:format:(plain shell json)' \
  '*:param:' && ret=0

return ret
