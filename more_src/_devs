autoload -U is-at-least

_devs() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_devs_commands" \
"*::: :->devs" \
&& ret=0
    case $state in
    (devs)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:devs-command-$line[1]:"
        case $line[1] in
            (new)
_arguments "${_arguments_options[@]}" : \
'--path=[Project directory path (defaults to current directory)]:PATH:_default' \
'--color=[Tab color in hex format (#rrggbb or rrggbb)]:COLOR:_default' \
'--from=[Copy layout from an existing project]:FROM:_default' \
'(--from)--from-session=[Capture layout from a live tmux session]:FROM_SESSION:_default' \
'*--session=[Pre-populate a Claude session (format\: LABEL\:ID, repeatable)]:LABEL:ID:_default' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Project name (used as tmux session name):_default' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'--local[Edit the machine-local config (sessions, saved state) instead of the portable config]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'--force[Skip confirmation prompt]' \
'--kill[Kill the tmux session if alive]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(open)
_arguments "${_arguments_options[@]}" : \
'--default[Use the declarative layout even if saved state exists]' \
'--saved[Use the saved layout (error if none)]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(close)
_arguments "${_arguments_options[@]}" : \
'--save[Save the current layout before closing]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(save)
_arguments "${_arguments_options[@]}" : \
'--as-default[Write the captured layout as the declarative default in \[layout\]]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(reset)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(claude)
_arguments "${_arguments_options[@]}" : \
'--resume=[Resume a session by label]:RESUME:_default' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
'::label -- Session label (required when starting a new session):_default' \
&& ret=0
;;
(claudes)
_arguments "${_arguments_options[@]}" : \
'--all[Show all sessions including done ones]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(claude-done)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
'::label -- Session label:_default' \
&& ret=0
;;
(note)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
'::message -- Note message:_default' \
&& ret=0
;;
(notes)
_arguments "${_arguments_options[@]}" : \
'--since=[Filter notes by time (e.g., "2d", "1h", "30m")]:SINCE:_default' \
'--all[Show all notes (default\: last 20)]' \
'--clear[Delete all notes]' \
'--force[Confirm destructive clear operation]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Project name (inferred from current directory if omitted):_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(tmux-help)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(generate-man)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':output_dir -- Directory to write man page files into:_files' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_devs__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:devs-help-command-$line[1]:"
        case $line[1] in
            (new)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(open)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(close)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(save)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(reset)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(claude)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(claudes)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(claude-done)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(note)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(notes)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tmux-help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-man)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_devs_commands] )) ||
_devs_commands() {
    local commands; commands=(
'new:Register a new project' \
'init:Export project config to a shareable .devs.toml' \
'list:List all registered projects' \
'status:Show all projects with live status' \
'config:Print a project'\''s current config' \
'edit:Open a project'\''s config in \$VISUAL or \$EDITOR' \
'remove:Remove a project from tracking' \
'open:Create or attach to a tmux session for a project' \
'close:Close a project'\''s tmux session (optionally saving layout first)' \
'save:Save the current tmux layout for a project' \
'reset:Reset a project'\''s layout to its declarative default' \
'claude:Start or resume a Claude Code session' \
'claudes:List Claude Code sessions for a project' \
'claude-done:Mark a Claude Code session as done' \
'note:Add a timestamped note to a project' \
'notes:List notes for a project' \
'completions:Generate shell completions (static fallback — prefer dynamic setup below)' \
'tmux-help:Print tmux quick reference' \
'generate-man:Generate man pages for devs and all subcommands' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'devs commands' commands "$@"
}
