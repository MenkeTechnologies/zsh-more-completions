#compdef cpufetch

# Zsh completion for cpufetch (CPU architecture info tool)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-v[Show version]' \
  '--version[Show version]' \
  '-s+[Set logo style]:style:(small medium big)' \
  '--style=[Set logo style]:style:(small medium big)' \
  '-c+[Set color scheme]:color:(intel amd ibm arm rockchip)' \
  '--color=[Set color scheme]:color:(intel amd ibm arm rockchip)' \
  '-C+[Set custom color scheme]:hex colors (C1,C2,C3,C4):' \
  '--custom=[Set custom color scheme]:hex colors (C1,C2,C3,C4):' \
  '-r[Force raw output (no colors)]' \
  '--raw[Force raw output (no colors)]' \
  '-j[Output in JSON format]' \
  '--json[Output in JSON format]' \
  '-d[Enable debug mode]' \
  '--debug[Enable debug mode]' \
  '-l[Set logo to display]:logo:' \
  '--logo=[Set logo to display]:logo:' && return 0
