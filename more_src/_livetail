#compdef livetail

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '-i+[Sumo Logic access id]:id:' \
  '-k+[Sumo Logic access key]:key:' \
  '-d+[Sumo Logic deployment]:deployment:(us1 us2 eu au de jp ca in)' \
  '-c[clear stored Live Tail credentials]' \
  '*::filter:' && ret=0

return ret
