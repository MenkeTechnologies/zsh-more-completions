#compdef kawa

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--debug[enable debug]' \
  '-d+[output directory]:dir:_files -/' \
  '-C+[compile and continue]:file:_files -g "*.scm *.kawa"' \
  '-c+[compile to .class]:file:_files -g "*.scm *.kawa"' \
  '-f+[load and run file]:file:_files -g "*.scm *.kawa"' \
  '-s[interactive read-eval-print loop]' \
  '--server+[start server on port]:port:' \
  '--connect+[connect to server]:host\:port:' \
  '-e+[evaluate expression]:expr:' \
  '--script+[run script]:file:_files' \
  '--script0+[run script no shebang]:file:_files' \
  '-w[start REPL window]' \
  '--main[generate main method]' \
  '--applet[generate applet]' \
  '--servlet[generate servlet]' \
  '--module-static[static module]' \
  '--module-static-run[static module with run]' \
  '--module-nonstatic[non-static module]' \
  '--module-extends:-[parent class]:cls:' \
  '--module-implements:-[implemented interfaces csv]:list:' \
  '--full-tailcalls[full tail calls]' \
  '--no-full-tailcalls[disable full tail calls]' \
  '--no-inline[no inlining]' \
  '--inline[enable inlining]' \
  '--warn-undefined-variable[warn undef var]' \
  '--warn-unknown-member[warn unknown member]' \
  '--warn-invoke-unknown-method[warn invoke unknown]' \
  '--warn-as-error[warnings as errors]' \
  '--no-warn-as-error[reset warn as error]' \
  '-T+[target classpath]:cp:' \
  '--target+[target Java version]:v:(7 8 11 17 21)' \
  '--language+[language module]:lang:(scheme commonlisp emacs elisp xquery brl krl)' \
  '--scheme[Scheme syntax]' \
  '--r5rs[R5RS]' \
  '--r6rs[R6RS]' \
  '--r7rs[R7RS]' \
  '--commonlisp[Common Lisp]' \
  '--elisp[Emacs Lisp]' \
  '--xquery[XQuery]' \
  '--brl[BRL]' \
  '--krl[KRL]' \
  '*: :_files -g "*.scm *.kawa *.xq *.cl *.el"' && ret=0

return ret
