#compdef asn1c
# Documentation: https://man.archlinux.org/search?q=asn1c
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-E[print parsed and dump on stdout]' \
  '-EF[fix and print]' \
  '-S+[skeletons dir]:dir:_files -/' \
  '-X[dump XML schema]' \
  '-W+[warnings]:warning:' \
  '-print-class-matrix[print class matrix]' \
  '-print-constraints[print parsed constraints]' \
  '-print-lines[print line numbers]' \
  '-no-constraints[ignore constraints]' \
  '-fline-refs[generate line references]' \
  '-fcompound-names[unique compound names]' \
  '-findirect-choice[generate indirect choice]' \
  '-fno-include-deps[no include deps]' \
  '-fknown-extern-type=[treat type as external]:type:' \
  '-funnamed-unions[allow unnamed unions]' \
  '-fwide-types[wide types]' \
  '-gen-PER[generate PER support]' \
  '-gen-UPER[generate UPER support]' \
  '-gen-APER[generate APER support]' \
  '-gen-OER[generate OER support]' \
  '-gen-BER[generate BER support]' \
  '-gen-XER[generate XER support]' \
  '-gen-JER[generate JER support]' \
  '-gen-PER-only[generate PER only]' \
  '-gen-UPER-only[generate UPER only]' \
  '-gen-OER-only[generate OER only]' \
  '-gen-BER-only[generate BER only]' \
  '-gen-XER-only[generate XER only]' \
  '-gen-JER-only[generate JER only]' \
  '-pdu=[generate PDU table for type]:type:' \
  '-D+[output dir]:dir:_files -/' \
  '-no-gen-example[do not generate example]' \
  '-no-gen-PER[do not generate PER]' \
  '-no-gen-UPER[do not generate UPER]' \
  '-no-gen-APER[do not generate APER]' \
  '-no-gen-OER[do not generate OER]' \
  '-no-gen-BER[do not generate BER]' \
  '-no-gen-XER[do not generate XER]' \
  '-no-gen-JER[do not generate JER]' \
  '-no-gen-random-fill[do not generate random fill]' \
  '-no-line-refs[no line references]' \
  '*:file:_files -g "*.asn1"' && ret=0

return ret
