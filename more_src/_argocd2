#compdef argocd2
# _argocd2 — Intuit Argo Project argocd2 CLI command-line frontend wrapping the ArgoCD declarative GitOps continuous delivery tool for Kubernetes CNCF Graduated open-source written in Go automated deployment of desired application states in the specified target environments application definitions configurations and environments should be declarative and version controlled application deployment and lifecycle management should be automated auditable and easy to understand admin app cert cluster context gpg login logout proj relogin repo repocreds version completion repo-creds account user role token notification cluster-secret session (Intuit Argo CNCF team Alexander Matyushentsev Jesse Suen, Go); cobra
# upstream: https://argo-cd.readthedocs.io/

_argocd2() {
    local -a sub=(
        'account:account operations'
        'admin:admin operations'
        'app:application operations'
        'appset:ApplicationSet operations'
        'cert:certificate operations'
        'cluster:cluster operations'
        'completion:generate shell completion'
        'context:switch context'
        'gpg:GPG key operations'
        'login:login'
        'logout:logout'
        'proj:project operations'
        'relogin:re-login'
        'repo:repo operations'
        'repocreds:repo credential operations'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[host:port]:_hosts' \
        '--auth-token=+[token]:str:' \
        '--client-crt=+[file]:file:_files -g "*.pem *.crt"' \
        '--client-crt-key=+[file]:file:_files -g "*.pem *.key"' \
        '--server-crt=+[file]:file:_files -g "*.pem *.crt"' \
        '--config=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '--http-retry-max=+[N]:n:' \
        '--grpc-web[gRPC-Web]' \
        '--grpc-web-root-path=+[path]:str:' \
        '--port-forward[port-forward]' \
        '--port-forward-namespace=+[ns]:str:' \
        '--plaintext[plaintext]' \
        '--core[in-cluster Core mode]' \
        '--header=+[k=v]:str:' \
        '*-H+[k=v]:str:' \
        '--kube-context=+[name]:str:' \
        '--logformat=+[fmt]:f:(text json)' \
        '--loglevel=+[l]:l:(debug info warn error fatal panic)' \
        '--prompts-enabled[enable prompts]' \
        '--redis-compress-data[redis compress data]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argocd subcommand' sub ;;
        args)
            case $words[1] in
                app|appset|cluster|proj|repo|repocreds|account|cert|gpg|context) _arguments '1:op:(list get create update delete sync wait diff history rollback resources logs manifests patch set unset add rm)' '*:name:' ;;
                admin) _arguments '1:op:(dashboard cluster export import generatespec initial-password notifications proj redis-initial-password reset reset-app-cache)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argocd2 "$@"
