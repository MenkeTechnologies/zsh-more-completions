#compdef redpanda-connect
# Redpanda Connect stream processor for routing and transforming data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--log.level=[set logging verbosity]:level:(off error warn info debug trace)' \
  '*--set=[set a field by dot path in the config]:assignment' \
  '(-r --resources)'{-r,--resources}'+[import supplementary resources from a file]:file:_files -g "*.(yaml|yml)"' \
  '--chilled[run configs that contain linter errors]' \
  '(-w --watcher)'{-w,--watcher}'[watch config files and auto-apply changes]' \
  '(-e --env-file)'{-e,--env-file}'+[load environment variables from a dotenv file]:file:_files' \
  '(-t --templates)'{-t,--templates}'+[import Redpanda Connect templates]:file:_files' \
  '*:command:(echo lint run streams list create test template blobl studio)' && ret=0

return ret
