#compdef Scwrl4
# Documentation: https://dunbrack.fccc.edu/lab/scwrl
# Scwrl4 protein side-chain conformation prediction

local ret=1

_arguments -s -S \
  '-i+[input PDB with backbone atoms]:input:_files -g "*.pdb"' \
  '-o+[output PDB with predicted side chains]:output:_files -g "*.pdb"' \
  '-s+[sequence file for fixed residues]:sequence:_files' \
  '-f+[frame PDB for steric clash checks]:frame:_files -g "*.pdb"' \
  '-p+[parameters file override]:params:_files' \
  '-h[disable hydrogen atom output]' \
  '-t[disable N-terminal capping and C-terminal OXT addition]' \
  '-#[calculate conformations within crystal structure]' \
  '*:file:_files' && ret=0

return ret
