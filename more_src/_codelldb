#compdef codelldb
# Documentation: https://github.com/vadimcn/codelldb
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# LLDB-based debug adapter binary. Flags below match adapter/main.rs in upstream.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--port=[listen for DAP connections on port]:port:' \
  '--multi-session[accept multiple debug sessions]' \
  '--preload-lldb[preload LLDB at startup]' \
  '--liblldb=[path to liblldb]:path:_files' \
  '--params=[launch parameters as JSON]:json:' \
  '--settings=[initial debugger settings as JSON]:json:' && ret=0

return ret
