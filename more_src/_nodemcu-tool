#compdef nodemcu-tool
# nodemcu-tool — NodeMCU/ESP8266 file management CLI

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'upload:upload files to device'
  'download:download files from device'
  'remove:remove files from device'
  'mkfs:format device filesystem'
  'fsinfo:show filesystem info'
  'run:execute a file on device'
  'terminal:open serial terminal'
  'listdevices:list available serial devices'
  'devices:list available serial devices'
  'reset:reset the device'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-p,--port}'=[serial port]:port:_files -g "/dev/tty*(-.)"' \
  {-b,--baud}'=[baud rate]:baud rate:(9600 19200 38400 57600 115200)' \
  '--connection-delay=[delay after connecting in ms]:milliseconds:' \
  '--minify[minify Lua files before upload]' \
  '--compile[compile Lua files after upload]' \
  '--keeppath[keep file path on upload]' \
  '--raw[use raw output in terminal]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'nodemcu-tool subcommand' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      upload)
        _files && ret=0
        ;;
      download)
        _arguments '-o+[output file]:output file:_files' '*:remote file:' && ret=0
        ;;
      run|remove)
        _arguments '*:remote file:' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
