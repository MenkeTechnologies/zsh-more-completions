#compdef incrond
# Documentation: https://github.com/ar-/incron
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --config)'{-f,--config}'+[config file]:file:_files' \
  '(-n --foreground)'{-n,--foreground}'[do not daemonize]' \
  '(-k --kickoff)'{-k,--kickoff}'[force initial run]' && ret=0

return ret
