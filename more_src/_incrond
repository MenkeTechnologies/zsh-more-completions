#compdef incrond
# Documentation: https://man.archlinux.org/search?q=incrond
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --config)'{-f,--config}'+[config file]:file:_files' \
  '(-n --foreground)'{-n,--foreground}'[do not daemonize]' \
  '(-k --kickoff)'{-k,--kickoff}'[force initial run]' && ret=0

return ret
