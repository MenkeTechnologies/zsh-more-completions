#compdef sview
# Documentation: https://slurm.schedmd.com/sview.html
# Reference accessed: 2026-05-21
# Verified: upstream Slurm sview(1) man page at the URL above.
# STUB: sview is the Slurm GTK GUI; the man page documents no command-line
# flags (configuration is via the SLURM_CONF environment variable).

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
