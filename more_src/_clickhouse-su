#compdef clickhouse-su
# _clickhouse-su — set user/group and exec args (ClickHouse/ClickHouse)
# upstream: https://github.com/ClickHouse/ClickHouse
# Usage from programs/su/su.cpp: clickhouse su user[:group] args...

_clickhouse-su() {
    _arguments \
        '1:user[:group]:_users' \
        '*::command:_command_names -e'
}

_clickhouse-su "$@"
