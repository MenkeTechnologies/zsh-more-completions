#compdef approver-policy cert-manager-approver-policy
# _approver-policy — cert-manager CertificateRequest approver-policy controller
# upstream: https://github.com/cert-manager/approver-policy
# Flags from pkg/internal/cmd/options on tip; uses controller-runtime defaults.

_approver-policy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-host=[webhook server bind host]:host:' \
        '--webhook-certificate-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--approve-signer-names=[csv of signer names to approve]:csv:' \
        '--log-level=[log verbosity level]:n:' \
        '--log-format=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_approver-policy "$@"
