#compdef prow-hook
# _prow-hook — Prow GitHub webhook handler that dispatches to plugins (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/hook/main.go (flag).

_prow-hook() {
    _arguments \
        '-webhook-path=[webhook events path]:path:' \
        '-port=[listen port]:port:' \
        '-dry-run=[dry run for testing]:val:(true false)' \
        '-grace-period=[shutdown grace period]:duration:' \
        '-hmac-secret-file=[GitHub HMAC secret file]:file:_files' \
        '-slack-token-file=[Slack token file]:file:_files' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-plugin-config=[plugin config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_prow-hook "$@"
