#compdef crm_failcount

# Pacemaker crm_failcount: view/manipulate per-resource fail counts
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-r --resource)'{-r,--resource=}'[resource id]:resource:' \
  '(-N --node)'{-N,--node=}'[node name]:node:' \
  '(-D --delete)'{-D,--delete}'[delete fail count]' \
  '(-G --query)'{-G,--query}'[query fail count]' \
  '(-v --value)'{-v,--value=}'[set fail count value]:val:' \
  '(-n --operation)'{-n,--operation=}'[operation type]:op:(start stop monitor)' \
  '(-i --interval)'{-i,--interval=}'[operation interval]:interval:' \
  '*::crm_failcount args:_files' && ret=0
return ret
