#compdef crm_failcount
# Documentation: https://www.mankier.com/8/crm_failcount
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_failcount: query or reset a Pacemaker resource failcount on a node
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[display help, then exit]' \
  '(- *)--version[display version information, then exit]' \
  '*-V[increase debug output]' \
  '*--verbose[increase debug output]' \
  '(-q --quiet)'{-q,--quiet}'[print only the value when querying]' \
  '(-G --query)'{-G,--query}'[query the failcount]' \
  '(-D --delete)'{-D,--delete}'[clear the failcount]' \
  '(-r --resource)'{-r+,--resource=}'[target resource name]:resource:' \
  '(-N --node)'{-N+,--node=}'[target node name]:node:' \
  '(-n --operation)'{-n+,--operation=}'[restrict to specific operation]:op:(monitor start stop promote demote migrate_to migrate_from notify)' \
  '(-I --interval)'{-I+,--interval=}'[interval for the operation]:interval:' && ret=0
return ret
