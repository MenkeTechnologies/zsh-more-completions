#compdef crm_failcount

# crm_failcount: query/reset failcount for a Pacemaker resource on a node
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-G[query failcount]' \
  '--query[query failcount]' \
  '-D[delete (reset) failcount]' \
  '--delete[delete (reset) failcount]' \
  '-r[resource name]:resource:' \
  '--resource=[resource name]:resource:' \
  '-N[node name]:node:' \
  '--node=[node name]:node:' \
  '-n[operation name]:op:(monitor start stop promote demote migrate_to migrate_from notify)' \
  '--operation=[operation name]:op:(monitor start stop promote demote migrate_to migrate_from notify)' \
  '-I[operation interval]:interval:' \
  '--interval=[operation interval]:interval:' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_failcount args:_files' && ret=0
return ret
