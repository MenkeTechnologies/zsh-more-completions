#compdef sncast

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'account:account management'
  'declare:declare contract class'
  'declare-from:declare from source'
  'deploy:deploy contract instance'
  'invoke:execute contract function'
  'call:read from contract'
  'multicall:multicall operations'
  'script:script operations'
  'get:read chain state'
  'ledger:ledger device operations'
  'utils:utility functions'
  'verify:verify contracts'
  'show-config:display configuration'
  'completions:generate shell completions'
)

_arguments -C \
  '--profile=[profile]:profile:' \
  '--accounts-file=[accounts file]:file:_files' \
  '--account=[account name]:name:' \
  '--keystore=[keystore]:file:_files' \
  '--url=[RPC URL]:url:' \
  '--network=[network]:net:(mainnet sepolia)' \
  '--wait[wait for tx]' \
  '--json[JSON output]' \
  '--hex-format[hex output format]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sncast subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (account)
        _values 'account action' 'import' 'create' 'deploy' 'delete' && ret=0
        ;;
      (multicall)
        _values 'multicall action' 'new' 'run' 'execute' && ret=0
        ;;
      (script)
        _values 'script action' 'init' 'run' && ret=0
        ;;
      (get)
        _values 'get target' 'balance' 'class-hash-at' 'nonce' 'tx' 'tx-status' && ret=0
        ;;
      (ledger)
        _values 'ledger action' 'app-version' 'get-public-key' 'sign-hash' && ret=0
        ;;
      (utils)
        _values 'utils action' 'serialize' 'class-hash' 'selector' && ret=0
        ;;
      (completions)
        _values 'shell' 'bash' 'zsh' 'fish' 'elvish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
