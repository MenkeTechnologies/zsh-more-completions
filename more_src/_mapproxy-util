#compdef mapproxy-util
# Documentation: https://manpages.debian.org/testing/mapproxy/mapproxy-util.1.en.html
# mapproxy-util - command-line tool for MapProxy administration and tile export

local ret=1
local curcontext="$curcontext" state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mapproxy-util command' \
      'create[create example mapproxy.yaml/seed.yaml configuration]' \
      'serve-develop[start a standalone MapProxy development server]' \
      'serve-multiapp-develop[start a MultiMapProxy development server]' \
      'scales[convert between scales and resolutions]' \
      'wms-capabilities[parse and display WMS capabilities documents]' \
      'grids[display information about configured grids]' \
      'export[export tiles from one cache to another]' \
      'autoconfig[generate a MapProxy configuration from a WMS/WMTS source]' \
      'defrag-compact-cache[defragment a compact cache]' \
      'gridconf-from-ogcapitilematrixset[generate grid config from an OGC API tile matrix set]' && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -s \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '(-t --template)'{-t,--template}'=[template to create]:template' \
          '*:dir:_files -/' && ret=0
        ;;
      serve-develop|serve-multiapp-develop)
        _arguments -s \
          '(-b --bind)'{-b,--bind}'=[bind address]:address' \
          '*:file:_files' && ret=0
        ;;
      *)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
