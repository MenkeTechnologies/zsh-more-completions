#compdef daytona

# Zsh completion for daytona (development environment manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:Create a new workspace'
  'code:Open a workspace in an IDE'
  'delete:Delete a workspace'
  'info:Show workspace info'
  'list:List workspaces'
  'start:Start a workspace'
  'stop:Stop a workspace'
  'ssh:SSH into a workspace'
  'target:Manage workspace targets'
  'provider:Manage providers'
  'server:Manage the Daytona server'
  'profile:Manage connection profiles'
  'git-providers:Manage git providers'
  'ide:Manage IDE settings'
  'env:Manage workspace environment variables'
  'purge:Purge all workspaces and configuration'
  'autocomplete:Generate shell completion scripts'
  'version:Print version information'
  'whoami:Show current user'
  'telemetry:Manage telemetry preferences'
)

_arguments -s -S -C \
  '--help[Print help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'daytona command' commands && ret=0
    ;;
  args)
    case $words[1] in
      create)
        _arguments -s -S \
          '--code[Open in IDE after creation]' \
          '--target=[Specify target]:target' \
          '--custom-image=[Use a custom image]:image' \
          '--custom-image-user=[Set the user for the custom image]:user' \
          '--devcontainer-path=[Specify a devcontainer.json path]:path:_files' \
          '--env=[Set environment variable]:key=value' \
          '--manual[Skip automatic IDE launch]' \
          '--multi-project[Enable multi-project workspace]' \
          '--name=[Set workspace name]:name' \
          '(-y --yes)'{-y,--yes}'[Skip confirmation prompts]' \
          '*:repository URL' && ret=0
        ;;
      code)
        _arguments -s -S \
          '--ide=[Specify IDE to use]:ide:(vscode browser ssh-proxy)' \
          '(-y --yes)'{-y,--yes}'[Skip confirmation prompts]' \
          ':workspace' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '--all[Delete all workspaces]' \
          '(-f --force)'{-f,--force}'[Force delete]' \
          '(-y --yes)'{-y,--yes}'[Skip confirmation]' \
          ':workspace' && ret=0
        ;;
      target)
        local -a target_cmds=(
          'list:List targets'
          'set:Set the default target'
          'remove:Remove a target'
        )
        _describe -t target_cmds 'target subcommand' target_cmds && ret=0
        ;;
      provider)
        local -a provider_cmds=(
          'install:Install a provider'
          'list:List providers'
          'uninstall:Uninstall a provider'
          'update:Update a provider'
        )
        _describe -t provider_cmds 'provider subcommand' provider_cmds && ret=0
        ;;
      server)
        local -a server_cmds=(
          'start:Start the Daytona server'
          'stop:Stop the Daytona server'
          'restart:Restart the Daytona server'
          'logs:Show server logs'
          'configure:Configure the Daytona server'
        )
        _describe -t server_cmds 'server subcommand' server_cmds && ret=0
        ;;
      profile)
        local -a profile_cmds=(
          'list:List profiles'
          'add:Add a profile'
          'edit:Edit a profile'
          'delete:Delete a profile'
          'info:Show profile info'
        )
        _describe -t profile_cmds 'profile subcommand' profile_cmds && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[Show more details]' \
          '--format=[Output format]:format:(table json)' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '(-y --yes)'{-y,--yes}'[Skip confirmation]' \
          ':workspace' && ret=0
        ;;
      autocomplete)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
