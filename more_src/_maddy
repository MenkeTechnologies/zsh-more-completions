#compdef maddy

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run the maddy server'
  'version:print version'
  'verify-config:check config and exit'
  'hash:hash a password'
  'creds:manage credentials'
  'imap-acct:manage IMAP accounts'
  'imap-mboxes:manage IMAP mailboxes'
  'imap-msgs:manage IMAP messages'
)

_arguments -C \
  '--config=[config file]:file:_files -g "*.conf"' \
  '--debug[debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'maddy subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--libexec=[libexec dir]:dir:_files -/' \
          '*--log=[log target]:target:' \
          '-v[verbose]' && ret=0
        ;;
      (hash)
        _arguments \
          '--password=[password]:password:' \
          '--hash=[hash algorithm]:algo:(bcrypt argon2 sha3-512 sha256 sha512)' \
          '--bcrypt-cost=[bcrypt cost]:n:' \
          '--argon2-time=[argon2 time]:n:' \
          '--argon2-memory=[argon2 memory]:n:' \
          '--argon2-threads=[argon2 threads]:n:' && ret=0
        ;;
      (creds)
        _values 'creds action' list create remove password && ret=0
        ;;
      (imap-acct)
        _values 'imap-acct action' list create remove appendlimit && ret=0
        ;;
      (imap-mboxes)
        _values 'imap-mboxes action' list create remove rename && ret=0
        ;;
      (imap-msgs)
        _values 'imap-msgs action' add add-flags rem-flags set-flags remove copy move list && ret=0
        ;;
    esac
    ;;
esac

return ret
