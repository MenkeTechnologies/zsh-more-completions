#compdef maddy
# Documentation: https://github.com/foxcpp/maddy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for maddy - composable all-in-one mail server

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run the maddy server'
  'version:print version and build metadata'
  'creds:manage user credentials (list/create/remove/password)'
  'imap-acct:manage IMAP accounts (list/create/remove/appendlimit)'
  'imap-mboxes:manage IMAP mailboxes (list/create/remove/rename)'
  'imap-msgs:manage IMAP messages (add/add-flags/rem-flags/set-flags/remove/copy/move/list/dump)'
  'hash:hash a password'
)

_arguments -C \
  '--config=[config file]:file:_files' \
  '--debug[enable debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'maddy subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--libexec=[libexec directory]:dir:_directories' \
          '*--log=[log target]:target' \
          '-v[print version and exit]' && ret=0
        ;;
      (hash)
        _arguments \
          '(-p --password)'{-p,--password=}'[provide password directly]:password' \
          '--hash=[hash algorithm]:algo:(bcrypt argon2 sha3-512 sha256 sha512)' \
          '--bcrypt-cost=[bcrypt cost]:n' \
          '--argon2-time=[argon2 time]:n' \
          '--argon2-memory=[argon2 memory]:n' \
          '--argon2-threads=[argon2 threads]:n' && ret=0
        ;;
      (creds)
        _values 'creds action' list create remove password && ret=0
        ;;
      (imap-acct)
        _values 'imap-acct action' list create remove appendlimit && ret=0
        ;;
      (imap-mboxes)
        _values 'imap-mboxes action' list create remove rename && ret=0
        ;;
      (imap-msgs)
        _values 'imap-msgs action' add add-flags rem-flags set-flags remove copy move list dump && ret=0
        ;;
    esac
    ;;
esac

return ret
