#compdef momorph
# Documentation: https://github.com/momorph/cli
# Reference accessed: 2026-05-22
# Verified: cmd/root.go and cmd/init.go cobra definitions.

# Zsh completion for momorph - MoMorph AI-driven development CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug logging]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'momorph command' \
      'login[authenticate with GitHub OAuth]' \
      'logout[log out]' \
      'whoami[show current user]' \
      'init[initialize a new MoMorph project]' \
      'upload[upload files to MoMorph server]' \
      'update[update MoMorph CLI]' \
      'version[show CLI version]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--ai[AI tool to use]:tool:(copilot cursor claude windsurf gemini)' \
          '--tag[template version tag]:tag:' \
          '--variant[template variant]:variant:' \
          '--with-beads[install uv and beads-mcp]' \
          '1:project name:_files -/' && ret=0
        ;;
      upload)
        if (( CURRENT == 3 )); then
          _values 'upload command' testcases specs && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
