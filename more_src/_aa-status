#compdef aa-status apparmor_status
# _aa-status — AppArmor aa-status (print AppArmor policy state on the running system: number of loaded profiles, processes confined / unconfined, complain / enforce / mixed mode; --verbose verbose, --enabled exit 0 if AppArmor enabled, --pretty-json JSON output, --version, --help)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from apparmor/apparmor utils/aa-status on tip.

_aa-status() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--enabled[exit 0 if enabled]' \
        '--profiled[exit 0 if any profile loaded]' \
        '--complaining[exit 0 if any profile in complain]' \
        '--enforced[exit 0 if any profile in enforce]' \
        '--json[JSON output]' \
        '--pretty-json[pretty JSON]'
}

_aa-status "$@"
