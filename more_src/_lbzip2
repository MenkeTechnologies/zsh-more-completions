#compdef lbzip2

# Zsh completion for lbzip2 (parallel bzip2 compression)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[Set block size to 100k]' \
  '-2[Set block size to 200k]' \
  '-3[Set block size to 300k]' \
  '-4[Set block size to 400k]' \
  '-5[Set block size to 500k]' \
  '-6[Set block size to 600k]' \
  '-7[Set block size to 700k]' \
  '-8[Set block size to 800k]' \
  '-9[Set block size to 900k (default)]' \
  '(-d --decompress)'{-d,--decompress}'[Force decompression]' \
  '(-z --compress)'{-z,--compress}'[Force compression]' \
  '(-t --test)'{-t,--test}'[Test compressed file integrity]' \
  '(-k --keep)'{-k,--keep}'[Keep (do not delete) input files]' \
  '(-c --stdout)'{-c,--stdout}'[Write to standard output]' \
  '(-f --force)'{-f,--force}'[Force overwrite of output file]' \
  '(-n --threads)'{-n,--threads}'=[Set number of worker threads]:threads' \
  '(-v --verbose)'{-v,--verbose}'[Be verbose]' \
  '(-s --small)'{-s,--small}'[Reduce memory usage for decompression]' \
  '(-S --space)'{-S,--space}'=[Control disk space usage]:mode:(0 1 2)' \
  '(-q --quiet)'{-q,--quiet}'[Suppress non-essential warnings]' \
  '(-h --help)'{-h,--help}'[Display help]' \
  '(-L --license)'{-L,--license}'[Display license]' \
  '(-V --version)'{-V,--version}'[Display version]' \
  '*:file:_files' && ret=0

return ret
