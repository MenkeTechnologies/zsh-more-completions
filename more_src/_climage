#compdef climage
# Documentation: https://github.com/pnappa/CLImage
# convert images to ANSI escape codes for display in the terminal

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-u --unicode)'{-u,--unicode}'[use unicode characters for a more detailed image]' \
  '(-a --ascii)'{-a,--ascii}'[restrict output to ascii characters (default)]' \
  '(-t --truecolor)'{-t,--truecolor}'[use 16 million colors to encode output]' \
  '(-m --256color)'{-m,--256color}'[use 256 colors to encode output (default)]' \
  '(-s --16color)'{-s,--16color}'[use 16 colors to encode output]' \
  '(-b --8color)'{-b,--8color}'[use 8 colors to encode output]' \
  '(-p --palette)'{-p,--palette=}'[choose a system color palette]:palette' \
  '(-q --quiet)'{-q,--quiet}'[disable warnings]' \
  '(-w --cols)'{-w,--cols=}'[number of columns output should contain]:columns' \
  '(-o --output)'{-o,--output=}'[file to output to]:file:_files' \
  '*:image file:_files' && ret=0

return ret
