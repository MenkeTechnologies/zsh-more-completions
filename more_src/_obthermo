#compdef obthermo
# Documentation: https://openbabel.org/docs/Command-line_tools.html
# Open Babel: extract and calculate thermochemistry properties

local ret=1

_arguments -s -S \
  '--symm=[override symmetry number used in input file]:N' \
  '--nrot=[number of rotatable bonds for conformational entropy]:N' \
  '--dbdt=[temperature derivative of second virial coefficient for cp calculation]:x' \
  '--kj[output kJ/mol related units (default kcal/mol)]' \
  '*:input file:_files' && ret=0

return ret
