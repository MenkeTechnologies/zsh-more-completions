#compdef mvn mvnw ./mvnw

# Zsh completion for Apache Maven

_mvn() {
  local curcontext="$curcontext" state line ret=1

  local -a lifecycle_phases=(
    'validate:validate the project is correct'
    'initialize:initialize build state'
    'generate-sources:generate source code'
    'process-sources:process source code'
    'generate-resources:generate resources'
    'process-resources:process resources'
    'compile:compile the source code'
    'process-classes:post-process generated files'
    'generate-test-sources:generate test source code'
    'process-test-sources:process test source code'
    'generate-test-resources:generate test resources'
    'process-test-resources:process test resources'
    'test-compile:compile test source code'
    'process-test-classes:post-process test files'
    'test:run tests'
    'prepare-package:prepare for packaging'
    'package:package compiled code'
    'pre-integration-test:pre-integration test actions'
    'integration-test:run integration tests'
    'post-integration-test:post-integration test actions'
    'verify:verify package is valid'
    'install:install package into local repository'
    'deploy:deploy package to remote repository'
    'clean:clean the build'
    'site:generate site documentation'
    'site-deploy:deploy site documentation'
  )

  _arguments -s -S \
    '-am[also make dependant modules]' \
    '--also-make[also make dependant modules]' \
    '-amd[also make dependees]' \
    '--also-make-dependents[also make dependees]' \
    '-B[run in non-interactive batch mode]' \
    '--batch-mode[run in non-interactive batch mode]' \
    '-b+[alternate path for the user toolchains]:toolchains file:_files -g "*.xml"' \
    '--builder=[builder ID]:builder:' \
    '-C[fail build if checksums do not match]' \
    '--strict-checksums[fail build if checksums do not match]' \
    '-c[warn if checksums do not match]' \
    '--lax-checksums[warn if checksums do not match]' \
    '-cpu[ineffective - only kept for backward compatibility]' \
    '-D+[define a system property]:property=value:' \
    '-e[produce execution error messages]' \
    '--errors[produce execution error messages]' \
    '-f+[POM file]:POM file:_files -g "pom.xml"' \
    '--file=[POM file]:POM file:_files -g "pom.xml"' \
    '-fae[only fail the build afterwards]' \
    '--fail-at-end[only fail the build afterwards]' \
    '-ff[stop at first failure]' \
    '--fail-fast[stop at first failure]' \
    '-fn[never fail the build regardless of result]' \
    '--fail-never[never fail the build regardless of result]' \
    '-gs+[global settings file]:settings file:_files -g "*.xml"' \
    '--global-settings=[global settings file]:settings file:_files -g "*.xml"' \
    '-gt+[global toolchains file]:toolchains file:_files -g "*.xml"' \
    '--global-toolchains=[global toolchains file]:toolchains file:_files -g "*.xml"' \
    '(-h --help)'{-h,--help}'[display help information]' \
    '-l+[log file]:log file:_files' \
    '--log-file=[log file]:log file:_files' \
    '-llr[use Maven 2 local repository behaviour]' \
    '-N[do not recurse into sub-projects]' \
    '--non-recursive[do not recurse into sub-projects]' \
    '-nsu[suppress SNAPSHOT updates]' \
    '--no-snapshot-updates[suppress SNAPSHOT updates]' \
    '-ntp[do not display transfer progress]' \
    '--no-transfer-progress[do not display transfer progress]' \
    '-o[work offline]' \
    '--offline[work offline]' \
    '-P+[activate profiles]:profiles:' \
    '--activate-profiles=[activate profiles]:profiles:' \
    '-pl+[build specified reactor modules]:modules:' \
    '--projects=[build specified reactor modules]:modules:' \
    '-q[quiet output - only show errors]' \
    '--quiet[quiet output - only show errors]' \
    '-rf+[resume reactor from specified project]:project:' \
    '--resume-from=[resume reactor from specified project]:project:' \
    '-s+[user settings file]:settings file:_files -g "*.xml"' \
    '--settings=[user settings file]:settings file:_files -g "*.xml"' \
    '-T+[thread count]:threads:' \
    '--threads=[thread count]:threads:' \
    '-t+[alternate path for the user toolchains]:toolchains file:_files -g "*.xml"' \
    '--toolchains=[alternate path for the user toolchains]:toolchains file:_files -g "*.xml"' \
    '-U[force update of snapshots]' \
    '--update-snapshots[force update of snapshots]' \
    '-up[ineffective - only kept for backward compatibility]' \
    '-V[display version without stopping build]' \
    '--show-version[display version without stopping build]' \
    '-v[display version information]' \
    '--version[display version information]' \
    '-X[produce execution debug output]' \
    '--debug[produce execution debug output]' \
    '*:phase or goal:->phase_or_goal' \
    && ret=0

  case $state in
    (phase_or_goal)
      _describe -t phases 'lifecycle phase' lifecycle_phases && ret=0
      ;;
  esac

  return ret
}

_mvn "$@"
