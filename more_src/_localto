#compdef localto
# _localto — localto CLI for exposing localhost services via secure HTTPS tunnels with custom subdomain region routing rate-limit basic auth bearer token webhook signing and TCP/UDP port forwarding (localto team, Go); flag
# upstream: https://localto.dev/

_localto() {
    local -a sub=(
        'http:expose HTTP service'
        'tcp:expose TCP service'
        'udp:expose UDP service'
        'tunnels:list active tunnels'
        'auth:auth operations'
        'login:login'
        'logout:logout'
        'config:show config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--api-token=+[token]:str:' \
        '--region=+[r]:r:(us eu ap apac sa au us-east us-west eu-west eu-central ap-south)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'localto subcommand' sub ;;
        args)
            case $words[1] in
                http|tcp|udp) _arguments \
                    '--subdomain=+[name]:str:' \
                    '--auth=+[user:password]:str:' \
                    '--bearer=+[token]:str:' \
                    '--host-header=+[name]:str:' \
                    '--inspect[enable inspect]' \
                    '--no-inspect[disable inspect]' \
                    '--webhook-secret=+[secret]:str:' \
                    '--scheme=+[s]:s:(http https)' \
                    '*:port or host:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_localto "$@"
