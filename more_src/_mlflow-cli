#compdef mlflow-cli mlflow2
# _mlflow-cli — Databricks MLflow mlflow-cli CLI command-line frontend wrapping the MLflow open-source machine learning lifecycle platform managing experiments runs models projects deployments artifacts servers gc gc-runs export import garbage-collection registry transitions stages versions deployment server (MLflow team, Python); click
# upstream: https://mlflow.org/

_mlflow-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'experiments:experiment management'
        'runs:run management'
        'models:model registry management'
        'projects:project operations'
        'deployments:deployment operations'
        'artifacts:artifact operations'
        'server:run tracking server'
        'ui:start UI'
        'gc:run garbage collection'
        'export:export experiment'
        'import:import experiment'
        'register:register a model'
        'serve:serve a model'
        'sagemaker:SageMaker deployment'
        'azureml:Azure ML deployment'
        'recipes:recipe operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--tracking-uri=+[uri]:str:' \
        '--registry-uri=+[uri]:str:' \
        '--experiment-id=+[id]:str:' \
        '--experiment-name=+[name]:str:' \
        '--run-id=+[id]:str:' \
        '--artifact-uri=+[uri]:str:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '-h+[host]:_hosts' \
        '--workers=+[N]:n:' \
        '-w+[workers]:n:' \
        '--backend-store-uri=+[uri]:str:' \
        '--default-artifact-root=+[uri]:str:' \
        '--gunicorn-opts=+[opts]:str:' \
        '--app-name=+[name]:str:' \
        '--app-runtime=+[r]:r:(python conda docker)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mlflow-cli subcommand' sub ;;
        args)
            case $words[1] in
                experiments|runs|models|projects|deployments) _arguments '1:op:(list create update delete search restore promote transition)' '*:id:' ;;
                artifacts) _arguments '1:op:(list log download)' '*:path:_files' ;;
                run) _arguments '*:uri:' ;;
            esac
            ;;
    esac
}

_mlflow-cli "$@"
