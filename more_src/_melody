#compdef melody
# Documentation: https://man.archlinux.org/search?q=melody
# Reference accessed: 2026-05-16

_arguments -s \
  '(-r --pcap)'{-r,--pcap}'=[replay pcap]:file:_files' \
  '(-F --filter)'{-F,--filter}'=[BPF filter]:filter:' \
  '(-H --home-dir)'{-H,--home-dir}'=[home dir]:dir:_files -/' \
  '(-C --config-dir)'{-C,--config-dir}'=[config dir]:dir:_files -/' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-f --bpf)'{-f,--bpf}'=[BPF file]:file:_files' \
  '(-i --interface)'{-i,--interface}'=[interface]:iface:_net_interfaces' \
  '(-s --stdout)'{-s,--stdout}'[stdout output]' \
  '(-d --dump)'{-d,--dump}'[raw packet output]' \
  '*'{-o,--option}'=[override config key]:setting:'
