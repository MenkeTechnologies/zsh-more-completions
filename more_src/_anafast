#compdef anafast
# Documentation: https://healpix.sourceforge.io/html/fac_anafast.htm
# HEALPix: harmonic analysis of a map (power spectrum and a_lm)

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
