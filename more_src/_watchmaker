#compdef watchmaker
# _watchmaker — manipulate target process clock skew (chaos-mesh/chaos-mesh)
# upstream: https://github.com/chaos-mesh/chaos-mesh
# Flags from cmd/watchmaker/main_linux.go (flag).

_watchmaker() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[print version and exit]' \
        '-pid=[target process PID]:pid:_pids' \
        '-sec_delta=[seconds delta to inject]:n:' \
        '-nsec_delta=[nanoseconds delta to inject]:n:' \
        '-clk_ids=[CSV of CLOCK_* ids to affect]:clocks:'
}

_watchmaker "$@"
