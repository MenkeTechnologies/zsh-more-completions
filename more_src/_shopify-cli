#compdef shopify-cli
# _shopify-cli — Shopify app/theme/hydrogen CLI alias (Shopify team, TypeScript); oclif
# upstream: https://github.com/Shopify/cli

_shopify-cli() {
    local -a sub=(
        'app:init:initialize a new app'
        'app:build:build app'
        'app:config:link:link app config'
        'app:config:push:push app config'
        'app:config:use:select app config'
        'app:deploy:deploy app to shopify'
        'app:dev:start app dev'
        'app:env:pull:pull app env'
        'app:env:push:push app env'
        'app:env:show:show app env'
        'app:function:run:run function locally'
        'app:function:build:build function'
        'app:function:typegen:generate function types'
        'app:function:replay:replay function'
        'app:function:schema:generate function schema'
        'app:generate:extension:generate extension'
        'app:import-extensions:import extensions'
        'app:info:show app info'
        'app:logs:show app logs'
        'app:release:release app version'
        'app:scaffold:extension:scaffold extension'
        'app:update-url:update app urls'
        'app:versions:list:list app versions'
        'app:webhook:trigger:trigger webhook'
        'theme:dev:start theme dev'
        'theme:check:check theme'
        'theme:console:open theme console'
        'theme:delete:delete theme'
        'theme:info:theme info'
        'theme:init:init new theme'
        'theme:language-server:start language server'
        'theme:list:list themes'
        'theme:open:open theme in browser'
        'theme:package:package theme'
        'theme:profile:profile theme'
        'theme:publish:publish theme'
        'theme:pull:pull theme'
        'theme:push:push theme'
        'theme:rename:rename theme'
        'theme:share:share theme'
        'hydrogen:init:init hydrogen project'
        'hydrogen:dev:start hydrogen dev'
        'hydrogen:build:build hydrogen'
        'hydrogen:deploy:deploy hydrogen'
        'hydrogen:env:list:list env'
        'hydrogen:env:pull:pull env'
        'hydrogen:env:push:push env'
        'hydrogen:link:link storefront'
        'hydrogen:unlink:unlink storefront'
        'hydrogen:list:list storefronts'
        'hydrogen:preview:preview hydrogen'
        'hydrogen:setup:setup hydrogen'
        'hydrogen:upgrade:upgrade hydrogen'
        'auth:login:login'
        'auth:logout:logout'
        'plugins:list:list plugins'
        'plugins:install:install plugin'
        'plugins:uninstall:uninstall plugin'
        'plugins:update:update plugin'
        'commands:list commands'
        'config:autocorrect:set autocorrect'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shopify subcommand' sub ;;
        args)
            case $words[1] in
                app:init) _arguments \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--template=+[template]:t:(remix none ruby php node)' \
                    '-t+[template]:t:(remix none ruby php node)' \
                    '--directory=+[dir]:dir:_files -/' \
                    '-d+[dir]:dir:_files -/' \
                    '--package-manager=+[pm]:pm:(yarn npm pnpm bun)' \
                    '-p+[pm]:pm:(yarn npm pnpm bun)' \
                    '--flavor=+[flavor]:f:(vanilla typescript)' ;;
                app:dev|app:deploy|app:build) _arguments \
                    '--reset[reset config]' \
                    '--config=+[config name]:str:' \
                    '-c+[config name]:str:' \
                    '--api-key=+[api key]:str:' \
                    '--store=+[store]:str:' \
                    '-s+[store]:str:' \
                    '--tunnel=+[tunnel]:t:(cloudflare ngrok)' \
                    '--no-tunnel[no tunnel]' \
                    '--tunnel-url=+[tunnel url]:url:_urls' \
                    '--theme=+[theme]:str:' \
                    '--update-url[update urls]' ;;
                theme:dev|theme:push|theme:pull|theme:publish|theme:delete|theme:rename|theme:share) _arguments \
                    '--store=+[store]:str:' \
                    '-s+[store]:str:' \
                    '--password=+[password]:str:' \
                    '--theme=+[theme]:str:' \
                    '-t+[theme]:str:' \
                    '--development[development theme]' \
                    '--live[live theme]' \
                    '--unpublished[unpublished]' \
                    '-u[unpublished]' \
                    '--path=+[path]:dir:_files -/' \
                    '--port=+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--ignore=+[ignore]:str:' \
                    '-x+[ignore]:str:' \
                    '--only=+[only]:str:' \
                    '-o+[only]:str:' ;;
                hydrogen:init|hydrogen:dev|hydrogen:build|hydrogen:deploy) _arguments \
                    '--path=+[path]:dir:_files -/' \
                    '--port=+[port]:port:' \
                    '--template=+[template]:t:(hello-world demo-store)' \
                    '--styling=+[styling]:s:(tailwind css-modules vanilla-extract postcss none)' \
                    '--language=+[lang]:l:(js ts)' \
                    '--mock-shop[mock shop]' \
                    '--shortcut[install shortcut]' \
                    '--no-shortcut[no shortcut]' ;;
            esac
            ;;
    esac
}

_shopify-cli "$@"
