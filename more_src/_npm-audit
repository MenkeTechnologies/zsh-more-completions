#compdef npm-audit
# _npm-audit — npm Inc npm-audit CLI security audit subcommand of npm reporting vulnerabilities in dependency graph from the GitHub Advisory Database with severity-low-moderate-high-critical detail per-package automatic-fix npm-7-style suggestions report json text optional-production-only audit-level threshold (npm team, JS); custom argparse
# upstream: https://docs.npmjs.com/cli/v10/commands/npm-audit

_npm-audit() {
    local -a sub=(
        'fix:apply fixes'
        'signatures:verify registry signatures'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--json[json output]' \
        '--audit-level=+[l]:l:(info low moderate high critical)' \
        '--production[only production deps]' \
        '--package-lock-only[use package-lock.json]' \
        '--no-package-lock[ignore package-lock.json]' \
        '--force[force fix]' \
        '--registry=+[url]:str:' \
        '--include-dev[include dev deps]' \
        '--workspace=+[name]:str:' \
        '-w+[workspace]:str:' \
        '--workspaces[all workspaces]' \
        '--include-workspace-root[include root]' \
        '--omit=+[type]:t:(dev optional peer)' \
        '--dry-run[show what would be done]' \
        '--ignore-scripts[ignore lifecycle scripts]' \
        '--legacy-peer-deps[legacy peer deps]' \
        '--strict-peer-deps[strict peer deps]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'npm-audit subcommand' sub ;;
    esac
}

_npm-audit "$@"
