#compdef prek

# Zsh completion for prek Git hook runner (pre-commit compatible)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      install prepare-hooks install-hooks run list uninstall validate-config validate-manifest
      sample-config autoupdate cache gc clean init-templatedir try-repo util self
    )
    _describe -t commands 'prek command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
