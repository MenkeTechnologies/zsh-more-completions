#compdef antechamber
# Documentation: https://ambermd.org/antechamber/ac.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Amber antechamber: assign atom types, partial charges and force-field parameters
local curcontext="$curcontext" ret=1
_arguments -C \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '-fi[input file format]:format:(mol2 mol mdl ac pdb ent prep prepi prepc gzmat gcrt mopint mopcrt gout mopout alc hin rst zmat)' \
  '-fo[output file format]:format:(mol2 mol mdl ac pdb ent prep prepi prepc gzmat gcrt mopint mopcrt gout mopout alc hin rst zmat)' \
  '-c[charge method]:method:(gas bcc mul cm1 cm2 esp resp wc rc)' \
  '-cf[charge file]:file:_files' \
  '-nc[net molecular charge]:val:' \
  '-a[additional file name]:file:_files' \
  '-fa[additional file format]:format:' \
  '-ao[additional file operation]:op:(crd crg radius name type bond)' \
  '-m[multiplicity]:n:' \
  '-rn[residue name]:name:' \
  '-rf[force-field residue topology output]:file:_files' \
  '-ch[check input file name]:file:_files' \
  '-eq[atomic equivalence in charge fitting]:opt:(0 1 2)' \
  '-gv[Gaussian/GAMESS keyword]:val:' \
  '-ge[Gaussian/GAMESS extra]:val:' \
  '-df[use ddi or g09 (0=g03 1=g09 2=hf 3=mp2)]:opt:(0 1 2 3)' \
  '-at[atom type set]:type:(gaff gaff2 amber bcc sybyl)' \
  '-du[duplicated atom names]:opt:(yes no)' \
  '-bk[BK keyword]:val:' \
  '-an[adjust atom names]:opt:(yes no)' \
  '-j[atom type and bond type prediction index]:n:' \
  '-s[status info: 0 brief, 1 normal, 2 verbose]:level:(0 1 2)' \
  '-pf[remove intermediate files]:opt:(yes no)' \
  '-pl[parameter file]:file:_files' \
  '*::antechamber args:_files' && ret=0
return ret
