#compdef isic esic tcpsic udpsic icmpsic multisic isic6 tcpsic6 udpsic6 icmpsic6
# Documentation: https://github.com/IPv4v6/isic/blob/master/isic.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-s+[source MAC/IP address (use rand for random)]:ip:' \
  '-d+[destination MAC/IP address (use rand for random)]:ip:' \
  '-r+[random seed value]:seed:' \
  '-p+[packet count (protocol number for esic)]:n:' \
  '-k+[number of skipped packets]:n:' \
  '-x+[send each packet num times]:n:' \
  '-m+[traffic speed limit in kB/s (printout frequency for esic)]:n:' \
  '-i+[required outgoing interface]:interface:_net_interfaces' \
  '-F+[percentage of fragmented packets]:percent:' \
  '-V+[percentage with invalid IP version values]:percent:' \
  '-I+[percentage with IP options/headers]:percent:' \
  '-v[print version information]' \
  '-D[enable debugging output]' && ret=0

return ret
