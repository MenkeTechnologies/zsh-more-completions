#compdef axtToMaf
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# convert from axt to maf format

local ret=1

_arguments -s -S \
  '-qPrefix=[add XX. to start of query sequence name in maf]:prefix' \
  '-tPrefix=[add YY. to start of target sequence name in maf]:prefix' \
  '-tSplit[create a separate maf file for each target sequence]' \
  '-score[recalculate score]' \
  '-scoreZero[recalculate score if zero]' \
  '1:in axt:_files -g "*.axt"' \
  '2:target sizes:_files' \
  '3:query sizes:_files' \
  '4:out maf:_files' && ret=0

return ret
