#compdef retire
# Documentation: https://github.com/RetireJS/retire.js
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--node[scan node modules]' \
  '--js[scan JavaScript files]' \
  '--path[path to scan]:path:_files' \
  '--package[package.json path]:file:_files' \
  '--outputformat[output format]:format:(json text jsonsimple cyclonedx)' \
  '--outputpath[output file path]:file:_files' \
  '*--ignore[paths to ignore]:path' \
  '--ignorefile[file with paths to ignore]:file:_files' \
  '--severity[minimum severity level]:severity:(low medium high critical)' \
  '--exitwith[exit code on vulnerability found]:code' \
  '--verbose[verbose output]' \
  '--nocache[disable caching]' \
  '--proxy[proxy URL]:url' \
  '--cacert[CA certificate file]:file:_files' \
  '--insecure[disable SSL verification]' \
  '*:path:_files' && ret=0

return ret
