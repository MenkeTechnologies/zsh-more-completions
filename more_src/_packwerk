#compdef packwerk
# Documentation: https://github.com/Shopify/packwerk/blob/main/USAGE.md
# Packwerk Ruby package modularization checker

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(init check update-todo validate version)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      check)
        _arguments -s \
          '--packages=[comma-separated list of packages to check]:packages' \
          '--offenses-formatter=[custom offenses formatter to use]:formatter' \
          '(--parallel --no-parallel)--parallel[run checks in parallel]' \
          '(--parallel --no-parallel)--no-parallel[disable parallel checking]' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
