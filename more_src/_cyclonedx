#compdef cyclonedx

# Zsh completion for cyclonedx - CycloneDX SBOM CLI tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add items to a BOM'
  'analyze:analyze a BOM for issues'
  'convert:convert between BOM formats'
  'diff:diff two BOMs'
  'enrich:enrich a BOM with additional data'
  'merge:merge multiple BOMs'
  'validate:validate a BOM against the CycloneDX schema'
  'keygen:generate signing keys'
  'sign:sign a BOM'
  'verify:verify a signed BOM'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cyclonedx command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (convert)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-file=[input BOM file]:file:_files -g "*.json *.xml"' \
          '--output-file=[output BOM file]:file:_files' \
          '--input-format=[input format]:format:(json xml protobuf)' \
          '--output-format=[output format]:format:(json xml protobuf)' \
          '--output-version=[output specification version]:version:(1.0 1.1 1.2 1.3 1.4 1.5 1.6)' && ret=0
        ;;
      (validate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-file=[input BOM file]:file:_files -g "*.json *.xml"' \
          '--input-format=[input format]:format:(json xml)' \
          '--input-version=[specification version]:version:(1.0 1.1 1.2 1.3 1.4 1.5 1.6)' \
          '--fail-on-errors[exit with error on validation failures]' && ret=0
        ;;
      (merge)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-files=[input BOM files]:files:_files -g "*.json *.xml"' \
          '--output-file=[output BOM file]:file:_files' \
          '--output-format=[output format]:format:(json xml)' \
          '--output-version=[output specification version]:version:(1.0 1.1 1.2 1.3 1.4 1.5 1.6)' \
          '--name=[component name]:name' \
          '--version=[component version]:version' \
          '--hierarchical[perform hierarchical merge]' \
          '--group=[component group]:group' && ret=0
        ;;
      (diff)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--from-file=[first BOM file]:file:_files -g "*.json *.xml"' \
          '--to-file=[second BOM file]:file:_files -g "*.json *.xml"' \
          '--output-format=[output format]:format:(json)' \
          '--component-comparison-third-party[compare components]' && ret=0
        ;;
      (sign)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-file=[BOM file to sign]:file:_files -g "*.json *.xml"' \
          '--output-file=[output file]:file:_files' \
          '--key-file=[private key file]:file:_files' \
          '--algorithm=[signing algorithm]:algorithm:(RS256 RS384 RS512 ES256 ES384 ES512 PS256 PS384 PS512 Ed25519 Ed448)' && ret=0
        ;;
      (verify)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-file=[signed BOM file]:file:_files -g "*.json *.xml"' \
          '--key-file=[public key file]:file:_files' && ret=0
        ;;
      (keygen)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--algorithm=[key algorithm]:algorithm:(RS256 RS384 RS512 ES256 ES384 ES512 PS256 PS384 PS512 Ed25519 Ed448)' \
          '--private-key=[private key output file]:file:_files' \
          '--public-key=[public key output file]:file:_files' && ret=0
        ;;
      (add)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-file=[input BOM file]:file:_files -g "*.json *.xml"' \
          '--output-file=[output file]:file:_files' && ret=0
        ;;
      (analyze|enrich)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--input-file=[input BOM file]:file:_files -g "*.json *.xml"' \
          '--output-file=[output file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
