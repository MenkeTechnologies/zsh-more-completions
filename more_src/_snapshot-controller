#compdef snapshot-controller
# _snapshot-controller — Kubernetes CSI cluster-level VolumeSnapshot controller (kubernetes-csi/external-snapshotter)
# upstream: https://github.com/kubernetes-csi/external-snapshotter
# Flags from cmd/snapshot-controller/main.go on tip.

_snapshot-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster only)]:file:_files' \
        '--resync-period=[informer resync interval]:dur:' \
        '--worker-threads=[concurrent worker threads]:n:' \
        '--leader-election[enable leader election]' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--leader-election-lease-duration=[leader lease duration]:dur:' \
        '--leader-election-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-election-retry-period=[leader retry period]:dur:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--http-endpoint=[diagnostics HTTP host\:port]:host\:port:' \
        '--metrics-path=[Prometheus metrics HTTP path]:path:' \
        '--retry-interval-start=[initial retry interval]:dur:' \
        '--retry-interval-max=[max retry interval]:dur:' \
        '--enable-distributed-snapshotting[per-node snapshotting for node-local volumes]' \
        '--prevent-volume-mode-conversion=[block volume-mode conversion via PVC]:bool:(true false)' \
        '--retry-crd-interval-max=[max wait for CRDs at startup]:dur:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:'
}

_snapshot-controller "$@"
