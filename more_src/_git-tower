#compdef git-tower
# _git-tower — fournova Tower macOS Git GUI command-line helper CLI alias (fournova / fournova Software, Objective-C); custom argparse
# upstream: https://www.git-tower.com

_git-tower() {
    local -a sub=(
        'pulse:show pulse'
        'show:show repository in Tower'
        'browse:open repository in Tower'
        'open:open repository in Tower (alias)'
        'init:initialize repository in Tower'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--no-launch[no launch app]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--repo=+[repo path]:dir:_files -/' \
        '1:subcommand-or-path:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'git-tower subcommand' sub
            _files -/ ;;
        args)
            case $words[1] in
                show|browse|open|init) _arguments '*:path:_files -/' ;;
            esac
            ;;
    esac
}

_git-tower "$@"
