#compdef dmcopy
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmcopy.html
# Copy a Data Model virtual file with filtering/binning to a new file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input virtual file]:infile:_files' \
  'outfile=[output filename to create]:outfile:_files' \
  'kernel=[output file format type]:kernel:(default fits iraf)' \
  'option=[low-level copy option]:option:(all image bare)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
