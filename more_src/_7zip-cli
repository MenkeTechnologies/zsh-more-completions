#compdef 7zip-cli 7za-cli 7zz-cli
# _7zip-cli — Igor Pavlov 7-Zip file archiver CLI alias (ip7z team, C++); custom argparse
# upstream: https://github.com/ip7z/7zip

_7zip-cli() {
    local -a sub=(
        'a:add files to archive'
        'b:benchmark'
        'd:delete files from archive'
        'e:extract files (no path)'
        'h:calculate hash'
        'i:show info about supported formats'
        'l:list archive contents'
        'rn:rename files in archive'
        't:test integrity'
        'u:update files in archive'
        'x:extract files with full paths'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands '7z command' sub ;;
        args)
            _arguments \
                '-bb+[output level]:n:(0 1 2 3)' \
                '-bd[disable progress indicator]' \
                '-bs+[stream]:str:' \
                '-bt[show benchmark info]' \
                '-i+[include filenames]:str:' \
                '-m+[method]:str:' \
                '-mx0[copy mode (no compression)]' \
                '-mx1[fastest]' \
                '-mx3[fast]' \
                '-mx5[normal (default)]' \
                '-mx7[maximum]' \
                '-mx9[ultra]' \
                '-mmt[multithread]' \
                '-mmt=+[threads]:n:' \
                '-o+[output dir]:dir:_files -/' \
                '-p+[password]:str:' \
                '-r[recursive]' \
                '-r-[disable recursion]' \
                '-r0[recursion only with wildcards]' \
                '-sa+[archive name mode]:m:(e s)' \
                '-scc+[charset]:c:(UTF-8 WIN DOS)' \
                '-scs+[charset for list files]:c:(UTF-8 UTF-16LE UTF-16BE WIN DOS)' \
                '-sdel[delete files after creation]' \
                '-sfx+[stub]:file:_files' \
                '-si[read from stdin]' \
                '-slp[set large pages mode]' \
                '-slt[list technical info]' \
                '-snh[store hard links as links]' \
                '-snl[store symbolic links as links]' \
                '-sno[store NT security info]' \
                '-sns[store NTFS alternate streams]' \
                '-so[write to stdout]' \
                '-spd[disable wildcard matching]' \
                '-spe[eliminate duplicate paths]' \
                '-spf[use full paths]' \
                '-ssc[case sensitive matching]' \
                '-sse[stop archive creation if archive cannot store all files]' \
                '-ssp[do not modify last access time]' \
                '-ssw[compress shared files]' \
                '-stl[set archive timestamp from latest file]' \
                '-stm+[set CPU thread affinity mask]:str:' \
                '-stx+[exclude formats]:str:' \
                '-t+[archive type]:t:(7z bzip2 cab gzip iso lzma tar wim xz zip zstd)' \
                '-u+[update options]:str:' \
                '-v+[volume size]:str:' \
                '-w+[working dir]:dir:_files -/' \
                '-x+[exclude filenames]:str:' \
                '-y[assume yes on all queries]' \
                '*:archive files:_files' ;;
    esac
}

_7zip-cli "$@"
