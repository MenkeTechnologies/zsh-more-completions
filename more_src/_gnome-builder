#compdef gnome-builder
# Documentation: https://man.archlinux.org/search?q=gnome-builder
# Reference accessed: 2026-05-16

# GNOME Builder: GNOME IDE (gIDE)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '--standalone[run as standalone instance]' \
  '--no-extensions[disable extensions]' \
  '--type=[file type to open]:type:' \
  '--list-projects[list known projects]' \
  '--clone=[clone repo URL]:url:' \
  '--service=[start in service mode]' \
  '--editor[start in editor mode]' \
  '--gapplication-app-id=[GApplication id]:id:' \
  '--gapplication-service[run as a GApplication service]' \
  '*:project or file:_files' && ret=0
return ret
