#compdef nepim
# Documentation: https://github.com/udhos/nepim/blob/master/README.md
# nepim - network pipemeter, measures available bandwidth between hosts

local ret=1

_arguments -s -S \
  '(-h)-h[display brief help about command line options]' \
  '-c[connect to server address (client mode)]:host:_hosts' \
  '-d[bidirectional traffic: both client and server send]' \
  '-u[use UDP sockets instead of TCP]' \
  '-s[reverse: only the client sends traffic]' \
  '-r[upper bit rate limit (bps, suffixes ok)]:rate' \
  '-R[upper packet rate limit (pps, suffixes ok)]:rate' \
  '-D[default period in microseconds for sending packets]:usec' \
  '-e[constant data rate with segments at regular intervals]:value' \
  '-n[run multiple parallel traffic streams]:count' \
  '-b[server listen on specific local addresses]:addr:_hosts' \
  '-6[disable IPv6 support]' \
  '-4[disable IPv4 support]' \
  '-j[join a multicast group or SSM pair]:group' \
  '-M[enable multicast-compatible options]' \
  '-k[password for client authentication]:password' \
  '-F[force sending UDP packets regardless of remote server]' \
  '-U[server listen on UNIX-domain stream sockets]:path:_files' \
  '-W[UDP payload write size]:size' \
  '-o[account for per-packet encapsulation overhead]' \
  '-a[test duration (suffixes m,h,d ok)]:duration' \
  '-sweep[cycle write size low to high with increment]:spec' \
  '*::arg:_default' && ret=0

return ret
