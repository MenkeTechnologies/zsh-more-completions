#compdef me_cleaner me_cleaner.py
# Documentation: https://github.com/corna/me_cleaner
# Tool to disable and remove Intel ME/TXE firmware

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-O --output)'{-O,--output}'[save modified image to separate file]:output:_files' \
  '(-S --soft-disable)'{-S,--soft-disable}'[set MeAltDisable/HAP bit for ME self-disable]' \
  '(-s --soft-disable-only)'{-s,--soft-disable-only}'[only set HAP bit, skip firmware operations]' \
  '(-r --relocate)'{-r,--relocate}'[move FTPR partition to top of ME region]' \
  '(-t --truncate)'{-t,--truncate}'[remove empty firmware portion]' \
  '(-k --keep-modules)'{-k,--keep-modules}'[preserve FTPR modules even when removable]' \
  '(-w --whitelist)'{-w,--whitelist}'[comma-separated partitions to keep]:partitions:' \
  '(-b --blacklist)'{-b,--blacklist}'[comma-separated partitions to remove]:partitions:' \
  '(-d --descriptor)'{-d,--descriptor}'[remove ME R/W permissions to other flash regions]' \
  '(-D --extract-descriptor)'{-D,--extract-descriptor}'[extract flash descriptor]:file:_files' \
  '(-M --extract-me)'{-M,--extract-me}'[extract ME firmware from full dump]:file:_files' \
  '(-c --check)'{-c,--check}'[verify firmware integrity and exit]' \
  '*:image:_files' && ret=0

return ret
