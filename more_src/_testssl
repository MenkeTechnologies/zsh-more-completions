#compdef testssl testssl.sh

# Zsh completion for testssl.sh - TLS/SSL testing tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--openssl=[use this openssl binary]:file:_files' \
  '--connect-timeout=[connect timeout in seconds]:seconds' \
  '--parallel[run tests in parallel]' \
  '-U[test all vulnerabilities]' \
  '--vulnerabilities[test all vulnerabilities]' \
  '-S[display server defaults]' \
  '--server-defaults[display server defaults]' \
  '-P[display server preference]' \
  '--server-preference[display server preference]' \
  '-s[check TLS/SSL protocols]' \
  '-p[check TLS/SSL protocols]' \
  '-e[check each cipher suite per protocol]' \
  '-f[check ciphers per protocol]' \
  '-E[check cipher suites]' \
  '--headers[check HTTP headers]' \
  '--heartbleed[test for Heartbleed]' \
  '--ccs[test for CCS injection]' \
  '--ticketbleed[test for Ticketbleed]' \
  '--robot[test for ROBOT]' \
  '--poodle[test for POODLE]' \
  '--tls-fallback[test for TLS fallback SCSV]' \
  '--sweet32[test for SWEET32]' \
  '--freak[test for FREAK]' \
  '--drown[test for DROWN]' \
  '--logjam[test for LOGJAM]' \
  '--beast[test for BEAST]' \
  '--lucky13[test for Lucky Thirteen]' \
  '--breach[test for BREACH]' \
  '--crime[test for CRIME]' \
  '--starttls=[STARTTLS protocol]:protocol:(ftp smtp pop3 imap xmpp telnet ldap nntp postgres mysql)' \
  '--json[output results as JSON]' \
  '--jsonfile=[write JSON to file]:file:_files' \
  '--csv[output results as CSV]' \
  '--csvfile=[write CSV to file]:file:_files' \
  '--html[output results as HTML]' \
  '--htmlfile=[write HTML to file]:file:_files' \
  '--log[log output]' \
  '--logfile=[write log to file]:file:_files' \
  '-q[quiet mode]' \
  '--wide[wide output]' \
  '--color=[color mode]:level:(0 1 2 3)' \
  '--debug=[debug level]:level:(0 1 2 3 4 5 6)' \
  '--ip=[connect to this IP]:ip' \
  '--nodns[do not use DNS]' \
  '--sneaky[use a harmless user agent]' \
  '--mapping=[cipher name mapping]:mapping:(no-openssl openssl rfc)' \
  '--add-ca=[additional CA file]:file:_files' \
  '--severity=[minimum severity]:severity:(LOW MEDIUM HIGH CRITICAL)' \
  '--assuming-http[assume HTTP even without detection]' \
  '--ssl-native[use openssl native instead of sockets]' \
  '1:host\:port or URI' \
  && ret=0

return ret
