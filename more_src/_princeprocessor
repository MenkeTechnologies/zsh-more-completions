#compdef princeprocessor pp64
# _princeprocessor — Jens Atom Steube hashcat princeprocessor PRINCE PRobability INfinite Chained Elements password candidate generator (hashcat team, C); custom argparse
# upstream: https://github.com/hashcat/princeprocessor

_princeprocessor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-c+[case permutation]:n:' \
        '--case-permute=+[case permutation]:n:' \
        '-k+[keyspace]:n:' \
        '--keyspace=+[keyspace]:n:' \
        '-s+[skip n elements]:n:' \
        '--skip=+[skip n elements]:n:' \
        '-l+[limit n elements]:n:' \
        '--limit=+[limit n elements]:n:' \
        '--pw-min=+[min length]:n:' \
        '--pw-max=+[max length]:n:' \
        '--elem-cnt-min=+[min elements per chain]:n:' \
        '--elem-cnt-max=+[max elements per chain]:n:' \
        '--wl-dist-len[wordlist distribution]' \
        '--wl-max=+[wordlist max length]:n:' \
        '-1+[charset 1]:str:' \
        '--custom-charset1=+[charset 1]:str:' \
        '-2+[charset 2]:str:' \
        '--custom-charset2=+[charset 2]:str:' \
        '-3+[charset 3]:str:' \
        '--custom-charset3=+[charset 3]:str:' \
        '-4+[charset 4]:str:' \
        '--custom-charset4=+[charset 4]:str:' \
        '*:wordlist file:_files'
}

_princeprocessor "$@"
