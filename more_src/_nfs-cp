#compdef nfs-cp
# Documentation: https://github.com/sahlberg/libnfs/blob/master/utils/nfs-cp.c
# Reference accessed: 2026-05-19
# Verified: libnfs utils/nfs-cp.c — usage is "nfs-cp <src> <dst>" with two
# positional args (local path or nfs:// URL); no flags.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '1:source (local file or NFS URL):_files' \
  '2:destination (local file or NFS URL):_files' && ret=0

return ret
