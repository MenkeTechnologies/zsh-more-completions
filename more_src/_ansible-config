#compdef ansible-config
# _ansible-config — Ansible config (inspect/dump effective ansible.cfg layering: list shows every known key, dump prints resolved values, view prints raw cfg, init creates a default cfg; -c selects an explicit config file; --only-changed limits dump to non-default)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/config.py)
# Subcommands from ansible cli/config.py on tip.

_ansible-config() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--version[show version]' \
        '-h[show help]' \
        '*-v[verbose]' \
        '-c+[config file]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ansible-config command' '(list dump view init)' ;;
        args)
            _arguments \
                '--only-changed[(dump) only non-default values]' \
                '-t+[config type]:type:(base all become cache callback cliconf connection httpapi inventory keyword lookup module netconf shell strategy terminal test vars)' \
                '*--format+[output format]:format:(yaml json ini env)' \
                '*:name:'
            ;;
    esac
}

_ansible-config "$@"
