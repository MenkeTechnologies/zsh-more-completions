#compdef c2patool

# Zsh completion for c2patool (C2PA content provenance tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --manifest)'{-m,--manifest}'[manifest definition file]:file:_files -g "*.json"' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-f --force)'{-f,--force}'[force overwrite output]' \
  '(-p --parent)'{-p,--parent}'[parent file]:parent:_files' \
  '(-d --detailed)'{-d,--detailed}'[show detailed manifest report]' \
  '(-c --config)'{-c,--config}'[configuration file]:config:_files -g "*.json"' \
  '--ingredient[add ingredient file]:file:_files' \
  '--no-signing-verify[skip verification after signing]' \
  '--tree[display manifest tree]' \
  '--info[display brief information]' \
  '--certs[display signing certificates]' \
  '--trust[use trust settings]:file:_files' \
  '--signer-path[path to signer]:path:_files' \
  '--remote-manifest[use remote manifest URL]:url' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:input file:_files' && ret=0

return ret
