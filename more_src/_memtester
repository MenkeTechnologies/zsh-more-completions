#compdef memtester
# Documentation: https://manpages.debian.org/bookworm/memtester/memtester.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for memtester (userspace memory testing utility)

_arguments -s -S \
  '-p[test memory at physical address]:physaddr (hex):' \
  '-d[device to mmap (with -p)]:device:_files' \
  '1:memory size (B/K/M/G suffix):' \
  '2:number of iterations:'
