#compdef memtester
# Documentation: https://man.archlinux.org/search?q=memtester
# Reference accessed: 2026-05-16

# Zsh completion for memtester (userspace memory testing utility)

_arguments -s -S \
  '-p[test memory at physical address]:physical address:' \
  '1:memory size (e.g. 100M, 1G):' \
  '2:number of iterations:'
