#compdef clearLmod
# Documentation: https://lmod.readthedocs.io/en/latest/010_user.html
# Lmod tool: module purge plus removal of all LMOD aliases and environment variables

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--quiet[suppress output while clearing Lmod state]' && ret=0

return ret
