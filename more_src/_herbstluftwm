#compdef herbstclient

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--idle[wait for hooks instead of executing commands]' \
  '--wait[block until next hook and print it]' \
  '--count=[number of hooks to wait for]:count' \
  '--no-newline[do not print a trailing newline]' \
  '--last-arg[print only the last argument of a hook]' \
  '--quiet[do not print error messages]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'reload:reload autostart file'
      'close:close focused window'
      'quit:quit herbstluftwm'
      'detect_monitors:detect connected monitors'
      'list_monitors:list all monitors'
      'focus_monitor:focus a monitor'
      'add_monitor:add a monitor'
      'remove_monitor:remove a monitor'
      'move_monitor:move and resize a monitor'
      'raise_monitor:raise a monitor'
      'lock:lock screen updates'
      'unlock:unlock screen updates'
      'set_layout:set frame layout'
      'cycle_layout:cycle through layouts'
      'split:split a frame'
      'remove:remove current frame'
      'focus:focus in a direction'
      'shift:shift window in a direction'
      'resize:resize a frame'
      'cycle:cycle through windows in frame'
      'cycle_all:cycle through all windows'
      'cycle_monitor:cycle through monitors'
      'focus_edge:focus edge in a direction'
      'bring:bring a window to current frame'
      'use:switch to a tag'
      'use_index:switch to a tag by index'
      'use_previous:switch to previous tag'
      'jumpto:jump to a window'
      'floating:toggle floating mode'
      'fullscreen:toggle fullscreen'
      'pseudotile:toggle pseudotile'
      'add:add a tag'
      'use_tag:switch to a tag'
      'merge_tag:merge a tag into another'
      'rename:rename a tag'
      'move:move window to a tag'
      'move_index:move window to a tag by index'
      'lock_tag:lock a tag'
      'unlock_tag:unlock a tag'
      'tag_status:print tag status'
      'get_attr:get an attribute'
      'set_attr:set an attribute'
      'new_attr:create a new attribute'
      'remove_attr:remove an attribute'
      'attr:get or set an attribute'
      'substitute:substitute attribute value in command'
      'foreach:run command for each object'
      'sprintf:format string with attribute values'
      'chain:chain multiple commands'
      'and:logical and of commands'
      'or:logical or of commands'
      'emit_hook:emit a custom hook'
      'list_keybinds:list all keybindings'
      'list_rules:list all rules'
      'list_padding:list padding of a monitor'
      'mousebind:bind a mouse button'
      'keyunbind:unbind a key'
      'keybind:bind a key'
      'mouseunbind:unbind a mouse button'
      'unrule:remove a rule'
      'rule:add a rule'
      'pad:set monitor padding'
      'watch:watch an attribute for changes'
      'set:set a setting'
      'get:get a setting'
      'toggle:toggle a boolean setting'
      'layout:print layout tree'
      'dump:dump frame layout'
      'load:load frame layout'
      'complete:print completions for a partial command'
      'complete_shell:print shell-friendly completions'
      'try:try a command, ignore errors'
      'silent:run a command silently'
      'version:print version'
    )
    _describe -t commands 'herbstclient command' commands && ret=0
    ;;
esac

return ret
