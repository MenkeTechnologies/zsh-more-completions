#compdef dirmngr
# Documentation: dirmngr --help on dirmngr (GnuPG) 2.5.20
# Source: GnuPG dirmngr — keyserver, CRL, and OCSP access for GnuPG.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--server --daemon)--server[run in server mode (foreground)]' \
    '(--server --daemon)--daemon[run in daemon mode (background)]' \
    '--list-crls[list contents of CRL cache]' \
    '--load-crl[load CRL from FILE into cache]:file:_files' \
    '--fetch-crl[fetch a CRL from URL]:url:' \
    '--shutdown[shutdown the dirmngr]' \
    '--flush[flush the cache]' \
    '--no-detach[do not detach from the console]' \
    '(-s --sh -c --csh)'{-s,--sh}'[sh-style command output]' \
    '(-s --sh -c --csh)'{-c,--csh}'[csh-style command output]' \
    '--options=[read options from FILE]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[somewhat more quiet]' \
    '--debug-level=[set debug level]:level:(none basic advanced expert guru)' \
    '--log-file=[write server-mode logs to FILE]:file:_files' \
    '--allow-version-check[allow online software version check]' \
    '--max-replies=[max items in one query]:N:' \
    '--use-tor[route all network traffic via Tor]' \
    '--disable-http[inhibit use of HTTP]' \
    '--ignore-http-dp[ignore HTTP CRL distribution points]' \
    '--http-proxy=[redirect all HTTP requests to URL]:url:' \
    '--honor-http-proxy[use systems HTTP proxy setting]' \
    '--keyserver=[use keyserver at URL]:url:' \
    '--hkp-cacert=[CA cert file for HKP over TLS]:file:_files' \
    '--disable-ldap[inhibit use of LDAP]' \
    '--ignore-ldap-dp[ignore LDAP CRL distribution points]' \
    '--ldap-proxy=[host for LDAP queries]:host:_hosts' \
    '--only-ldap-proxy[no fallback hosts with --ldap-proxy]' \
    '*--ldapserver=[keyserver SPEC for key lookups]:spec:' \
    '--ldapserverlist-file=[LDAP server list FILE]:file:_files' \
    '--add-servers[add servers discovered in CRL DPs]' \
    '--ldaptimeout=[LDAP timeout (s)]:N:' \
    '--allow-ocsp[allow sending OCSP requests]' \
    '--ignore-ocsp-service-url[ignore cert-contained OCSP URLs]' \
    '--ocsp-responder=[OCSP responder URL]:url:' \
    '--ocsp-signer=[OCSP response signed by FPR]:fpr:' \
    '--force[force loading of outdated CRLs]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    && ret=0

return ret
