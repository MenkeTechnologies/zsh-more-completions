#compdef virt-pki-validate
# _virt-pki-validate — libvirt virt-pki-validate (shell script that checks the libvirt TLS PKI installation on the host: CA cert/key, server cert/key, client cert/key locations + permissions; verbose mode prints what it expected to find for each role)
# upstream: https://gitlab.com/libvirt/libvirt (tools/virt-pki-validate.sh)
# Flags from libvirt tools/virt-pki-validate.sh on tip.

_virt-pki-validate() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]'
}

_virt-pki-validate "$@"
