#compdef HighResPrecursorMassCorrector
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: correct precursor m/z values in high-resolution MS data

local ret=1

_arguments -s -S \
  '-in[input centroided mzML file]:input file:_files' \
  '-out[output mzML file]:output file:_files' \
  '-out_csv[CSV results file]:file:_files' \
  '-feature:in[features file for correction]:file:_files' \
  '-feature:mz_tolerance[mass tolerance threshold]:value:' \
  '-feature:mz_tolerance_unit[tolerance unit]:unit:(Da ppm)' \
  '-feature:rt_tolerance[retention time tolerance]:value:' \
  '-feature:max_trace[isotopic peak offset consideration]:n:' \
  '-feature:believe_charge[assume charge accuracy]' \
  '-feature:keep_original[retain original precursor data]' \
  '-feature:assign_all_matching[use all matching features]' \
  '-nearest_peak:mz_tolerance[mass tolerance for closest peak]:value:' \
  '-nearest_peak:mz_tolerance_unit[tolerance unit]:unit:(Da ppm)' \
  '-highest_intensity_peak:mz_tolerance[mass range for peak search]:value:' \
  '-highest_intensity_peak:mz_tolerance_unit[tolerance unit]:unit:(Da ppm)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
