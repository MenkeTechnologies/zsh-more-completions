#compdef honeycomb-cli
# Documentation: https://github.com/node-honeycomb/honeycomb-cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# node-honeycomb/honeycomb-cli: developer tool for honeycomb micro-app framework

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'init:initialize an app'
  'start:start an app'
  'package:pack an app'
  'config:manage global settings (e.g. npm registry)'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'honeycomb-cli command' commands && ret=0 ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--template=[scaffold template]:template:' \
          '--scope=[npm scope]:scope:' \
          '--registry=[npm registry URL]:url:' \
          '--directory=[target directory]:dir:_files -/' && ret=0 ;;
      start)
        _arguments \
          '--port=[listen port]:port:' \
          '--domain=[serving domain]:domain:' \
          '--inspect[enable node --inspect]' && ret=0 ;;
      package)
        _arguments \
          '--env=[build environment]:env:' && ret=0 ;;
      config)
        _arguments '*::sub:(set get list delete)' && ret=0 ;;
    esac ;;
esac
return ret
