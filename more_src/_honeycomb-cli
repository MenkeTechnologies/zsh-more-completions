#compdef honeycomb-cli
# Documentation: https://man.archlinux.org/search?q=honeycomb-cli
# Reference accessed: 2026-05-16

# honeycomb-cli: Honeycomb.io management CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'dataset:dataset operations'
  'event:event ops'
  'query:run a query'
  'trigger:manage triggers'
  'board:manage boards'
  'derived_column:manage derived columns'
  'team:team info'
  'whoami:current user info'
  'environment:environment ops'
  'apikey:manage api keys'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--api-key=[API key]:key:' \
  '--api-url=[API URL]:url:' \
  '--dataset=[dataset name]:name:' \
  '--debug[debug mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'honeycomb-cli command' commands && ret=0 ;;
esac
return ret
