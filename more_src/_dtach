#compdef dtach

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-A[attach to or create session]:socket:_files' \
  '-a[attach to existing session]:socket:_files' \
  '-c[create new session]:socket:_files' \
  '-n[create new session without attaching]:socket:_files' \
  '-N[create new session without attaching, exit on EOF]:socket:_files' \
  '-e[set detach character]:character' \
  '-E[disable detach character]' \
  '-r[set redraw method]:method:(none ctrl_l winch)' \
  '-z[disable suspend]' \
  '-R[retry on failure]' \
  '*:command:_command_names -e' && ret=0

return ret
