#compdef drizzle-kit

# Zsh completion for drizzle-kit (Drizzle ORM CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:Generate SQL migrations based on schema changes'
      'migrate:Apply pending migrations to the database'
      'push:Push schema changes directly to the database'
      'pull:Introspect database and generate schema'
      'check:Check generated migrations consistency'
      'up:Upgrade snapshots of previously generated migrations'
      'drop:Delete previously generated migration'
      'studio:Launch Drizzle Studio for browsing data'
    )
    _describe -t commands 'drizzle-kit command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '--config=[Path to drizzle config file]:file:_files'
      '--dialect=[Database dialect]:dialect:(postgresql mysql sqlite turso)'
      '--schema=[Path to schema file(s)]:file:_files'
      '--out=[Migrations output directory]:dir:_directories'
      '--driver=[Database driver]:driver:(pg mysql2 better-sqlite3 libsql turso d1-http expo pg-proxy mysql-proxy)'
      '--url=[Database connection URL]:url'
      '--host=[Database host]:host'
      '--port=[Database port]:port'
      '--user=[Database user]:user'
      '--password=[Database password]:password'
      '--database=[Database name]:name'
      '--ssl=[SSL mode]:ssl'
      '--auth-token=[Auth token for database]:token'
      '-h[Print help]'
      '--help[Print help]'
    )

    case ${words[1]} in
      generate)
        _arguments -s -S \
          $common_flags \
          '--name=[Migration name]:name' \
          '--custom[Generate empty migration file for custom SQL]' \
          '--breakpoints[Use SQL breakpoints in generated migrations]' && ret=0
        ;;
      migrate)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      push)
        _arguments -s -S \
          $common_flags \
          '--strict[Always ask for approval before pushing schema changes]' \
          '--force-delete[Force delete data if required by schema changes]' \
          '--verbose[Print all SQL statements]' && ret=0
        ;;
      pull)
        _arguments -s -S \
          $common_flags \
          '--breakpoints[Use SQL breakpoints in generated migrations]' \
          '--introspect-casing=[Casing for column and table names]:casing:(camel preserve)' && ret=0
        ;;
      check)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      up)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      drop)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      studio)
        _arguments -s -S \
          $common_flags \
          '--port=[Port for Drizzle Studio]:port' \
          '--host=[Host for Drizzle Studio]:host' \
          '--verbose[Print all SQL statements]' && ret=0
        ;;
    esac
    ;;
esac

return ret
