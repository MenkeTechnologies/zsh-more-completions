#compdef maxen
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/maxen.html
# MIRIAD maxen - maximum entropy deconvolution

local ret=1

_arguments -s -S \
  'map=[input dirty map (Jy/beam)]:map:_files' \
  'beam=[input dirty beam]:beam:_files' \
  'model=[initial deconvolved image estimate (Jy/pixel)]:model:_files' \
  'default=[reference image solution tends toward]:default:_files' \
  'out=[output map (Jy/pixel)]:out:_files' \
  'niters=[maximum iteration count]:niters' \
  'region=[deconvolution area]:region' \
  'measure=[entropy measure gull/cornwell]:measure:(gull cornwell)' \
  'tol=[solution tolerance]:tol' \
  'q=[estimate of points per beam]:q' \
  'rms=[noise level in Jy/beam]:rms' \
  'flux=[source flux constraint]:flux' \
  'options=[quiet,verbose,asym,pad]:options' \
  '*:dataset:_files' && ret=0

return ret
