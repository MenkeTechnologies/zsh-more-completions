#compdef composer

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'about:short information about Composer'
  'archive:create an archive of a package'
  'audit:audit dependencies for security advisories'
  'browse:open package browse URL'
  'bump:bump constraint versions'
  'check-platform-reqs:check platform requirements'
  'clear-cache:clear Composer caches'
  'clearcache:clear Composer caches'
  'cc:clear Composer caches'
  'completion:generate shell completion script'
  'config:set/edit Composer config'
  'create-project:create new project from a package'
  'depends:list dependencies of a package'
  'why:list dependencies of a package'
  'diagnose:diagnose Composer setup'
  'dump-autoload:dump the autoloader'
  'dumpautoload:dump the autoloader'
  'exec:run a vendor binary'
  'fund:show funding info'
  'global:run a command in the global directory'
  'help:show help'
  'home:open package home URL'
  'init:create a basic composer.json'
  'install:install dependencies'
  'i:install dependencies'
  'licenses:show licenses of dependencies'
  'list:list available commands'
  'outdated:show outdated packages'
  'prohibits:show packages preventing an installation'
  'why-not:show packages preventing an installation'
  'reinstall:reinstall a package'
  'remove:remove a package'
  'rm:remove a package'
  'uninstall:remove a package'
  'require:add a package'
  'r:add a package'
  'run:run a script'
  'run-script:run a script'
  'search:search for packages'
  'self-update:update Composer itself'
  'selfupdate:update Composer itself'
  'show:show package information'
  'info:show package information'
  'status:show changes in vendor sources'
  'suggests:show suggestions from installed packages'
  'support:get support links'
  'update:update dependencies'
  'u:update dependencies'
  'upgrade:update dependencies'
  'validate:validate composer.json'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v -vv -vvv --verbose)'{-v,-vv,-vvv,--verbose}'[verbose output]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '(-n --no-interaction)'{-n,--no-interaction}'[no interaction]' \
  '--profile[show timing/memory profile]' \
  '--no-plugins[disable plugins]' \
  '--no-scripts[disable scripts]' \
  '(-d --working-dir)'{-d,--working-dir=}'[working directory]:dir:_files -/' \
  '--no-cache[disable cache]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'composer subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|i|update|u|upgrade|require|r|remove|rm|uninstall)
        _arguments \
          '--prefer-source[install from source]' \
          '--prefer-dist[install from dist]' \
          '--prefer-install=[prefer install mode]:mode:(dist source auto)' \
          '--dry-run[dry run]' \
          '--dev[install dev deps]' \
          '--no-dev[no dev deps]' \
          '--no-autoloader[skip autoloader]' \
          '--no-progress[no progress]' \
          '--no-install[only update lock file]' \
          '--audit[run audit]' \
          '(-o --optimize-autoloader)'{-o,--optimize-autoloader}'[optimize autoloader]' \
          '(-a --classmap-authoritative)'{-a,--classmap-authoritative}'[authoritative classmap]' \
          '--apcu-autoloader[use APCu]' \
          '--ignore-platform-reqs[ignore platform reqs]' \
          '*--ignore-platform-req=[ignore specific platform req]:req:' \
          '--prefer-stable[prefer stable]' \
          '--prefer-lowest[prefer lowest version]' \
          '*:package:' && ret=0
        ;;
      (show|info)
        _arguments \
          '--all[all packages]' \
          '--locked[show from lock file]' \
          '(-i --installed)'{-i,--installed}'[show installed]' \
          '(-p --platform)'{-p,--platform}'[show platform packages]' \
          '(-a --available)'{-a,--available}'[show available packages]' \
          '(-s --self)'{-s,--self}'[show package info]' \
          '(-N --name-only)'{-N,--name-only}'[name only]' \
          '(-P --path)'{-P,--path}'[show paths]' \
          '(-t --tree)'{-t,--tree}'[tree output]' \
          '(-l --latest)'{-l,--latest}'[latest version]' \
          '(-o --outdated)'{-o,--outdated}'[outdated]' \
          '(-D --direct)'{-D,--direct}'[direct deps only]' \
          '--strict[exit non-zero on outdated]' \
          '(-f --format)'{-f,--format=}'[output format]:fmt:(text json)' && ret=0
        ;;
      (search)
        _arguments \
          '(-N --only-name)'{-N,--only-name}'[match only name]' \
          '(-O --only-vendor)'{-O,--only-vendor}'[match only vendor]' \
          '(-t --type)'{-t,--type=}'[package type]:type:' \
          '(-f --format)'{-f,--format=}'[output format]:fmt:(text json)' && ret=0
        ;;
      (audit)
        _arguments \
          '--no-dev[no dev deps]' \
          '(-f --format)'{-f,--format=}'[output format]:fmt:(table plain json summary)' \
          '--locked[from lock file]' \
          '--abandoned=[abandoned policy]:policy:(ignore report fail)' && ret=0
        ;;
      (config)
        _arguments \
          '(-g --global)'{-g,--global}'[global config]' \
          '(-e --editor)'{-e,--editor}'[open editor]' \
          '(-a --auth)'{-a,--auth}'[auth config]' \
          '--unset[unset value]' \
          '(-l --list)'{-l,--list}'[list config]' \
          '(-f --file)'{-f,--file=}'[config file]:file:_files' \
          '--absolute[show absolute paths]' \
          '--json[treat value as JSON]' \
          '--merge[merge value]' \
          '--append[append to list]' \
          '--source[show source]' && ret=0
        ;;
      (run|run-script)
        _arguments \
          '--timeout=[timeout seconds]:secs:' \
          '--dev[include dev scripts]' \
          '--no-dev[exclude dev scripts]' \
          '(-l --list)'{-l,--list}'[list scripts]' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' && ret=0
        ;;
    esac
    ;;
esac

return ret
