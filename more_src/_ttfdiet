#compdef ttfdiet
# Documentation: https://github.com/twardoch/ttfdiet
# TTF DIacritics Encoding Tool: modernize precomposed glyph storage

local ret=1

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[print additional information during processing]' \
  '(-f --fea)'{-f,--fea}"[save 'ccmp' feature in AFDKO-syntax .fea file]" \
  '(-S --sanitise)'{-S,--sanitise}"[test outputfont with ot-sanitise (1, or 2 to remove on fail)]:level:(1 2)" \
  '(-g --glyf)'{-g,--glyf}'[remove components and contours from precomposed glyphs]' \
  '(-k --kern)'{-k,--kern}"[remove precomposed glyphs from GPOS kern PairPosFormat1 subtables]" \
  '(-C --ccmp)'{-C,--ccmp}"[add 'ccmp' subtable that decomposes precomposed glyphs]" \
  '(-s --skipmarks)'{-s,--skipmarks}'[do not process precomposed glyphs involving these marks]:marks:' \
  '(-a --repmarks)'{-a,--repmarks}'[report marks missing in font that would allow a better diet]' \
  '(-c --cmap)'{-c,--cmap}"[remove all 'cmap' subtables except Windows-platform]" \
  '(-n --name)'{-n,--name}"[remove all 'name' records except Windows-platform]" \
  '(-p --post)'{-p,--post}"[remove 'post' glyph names]" \
  '(-r --rename)'{-r,--rename}"[add 'Diet' prefix to 'name' records (enables --name)]" \
  '(-d --dsig)'{-d,--dsig}"[add empty 'DSIG' table]" \
  '1:input font:_files -g "*.ttf"' \
  '2:output font:_files -g "*.ttf"' && ret=0

return ret
