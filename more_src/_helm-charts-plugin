#compdef helm-charts-plugin
# Documentation: https://github.com/sapcc/helm-charts-plugin
# helm charts: manage Helm charts in a directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*--exclude-dirs=[sub-directories to exclude]:dir:_files -/' \
  '--only-path[output only the chart path]' \
  '--output-dir=[write results to file in specified directory]:dir:_files -/' \
  '--remote=[git remote name for identifying changes]:remote:' \
  '--branch=[branch name for identifying changes]:branch:' \
  '--commit=[commit reference for identifying changes]:commit:' \
  '1:command:(list list-changed)' \
  '*::arg:_files' && ret=0

return ret
