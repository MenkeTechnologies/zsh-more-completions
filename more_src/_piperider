#compdef piperider
# Documentation: https://docs.piperider.io/reference/piperider-cli
# PipeRider - code review for data in dbt (init, run, compare, compare-reports)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '--dbt-project-dir=[dbt project directory]:dir:_files -/' \
  '--dbt-target=[dbt target]:target' \
  '--dbt-profiles-dir=[dbt profiles directory]:dir:_files -/' \
  '--dbt-profile=[dbt profile]:profile' \
  '--no-auto-search[disable dbt project auto-search]' \
  '--datasource=[datasource name]:datasource' \
  '--table=[table name]:table' \
  '(-o --output)'{-o,--output=}'[output directory]:dir:_files -/' \
  '--report-dir=[report directory]:dir:_files -/' \
  '--skip-report[skip report generation]' \
  '--dbt-target-path=[dbt target path]:dir:_files -/' \
  '--dbt-list[use dbt list]' \
  '--dbt-run-results[use dbt run results]' \
  '--upload[upload report to cloud]' \
  '--project=[cloud project name]:project' \
  '--share[create shareable report]' \
  '--open[open report after run]' \
  '--skip-datasource[skip datasource connection]' \
  '(-s --select)'{-s,--select=}'[select models]:models' \
  '--state=[dbt state path]:dir:_files -/' \
  '--enable-quick-look-share[enable quick look share]' \
  '--input=[input report file]:file:_files' \
  '--base=[base report]:report' \
  '--target=[target report]:report' \
  '--last[compare against last report]' \
  '--summary-file=[summary markdown file]:file:_files' \
  '--tables-from=[tables to compare]:source' \
  '--recipe=[comparison recipe]:recipe' \
  '--dry-run[dry run]' \
  '--interactive[interactive mode]' \
  '--modified[only modified tables]' \
  '--base-branch=[base git branch]:branch' \
  '--no-interaction[disable interactive prompts]' \
  '--token=[cloud API token]:token' \
  '1:command:(version feedback init diagnose run generate-report compare-reports compare config cloud)' \
  '*::arg:->args' && ret=0

return ret
