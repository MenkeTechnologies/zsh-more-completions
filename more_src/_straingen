#compdef straingen
# Documentation: https://github.com/dftbplus/dftbplus/blob/main/tools/dptools/src/dptools/scripts/straingen.py
# DFTB+ dptools: apply a strain to a gen geometry file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'+[override the name of the output file]:file:_files' \
  '(-c --component)'{-c,--component}'+[strain type to apply]:component:(xx yy zz xz yz I)' \
  '1:gen input file:_files -g "*.gen"' \
  '2:strain (percentage):' && ret=0

return ret
