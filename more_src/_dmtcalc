#compdef dmtcalc
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmtcalc.html
# Perform arithmetic on table columns via an expression

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file to operate upon]:infile:_files' \
  'outfile=[name of output file to create]:outfile:_files' \
  'expression=[expressions evaluated per row]:expression:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
