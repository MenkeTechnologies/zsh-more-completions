#compdef galah
# Documentation: https://wwood.github.io/galah/
# galah - genome dereplication clustering

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'cluster:dereplicate and cluster genomes'
      'dist:calculate pairwise distances'
    )
    _describe -t commands 'galah command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      cluster)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --genome-fasta-files)'{-f,--genome-fasta-files}'+[individual genome fasta files]:files:_files' \
          '(-d --genome-fasta-directory)'{-d,--genome-fasta-directory}'=[directory of genome fastas]:dir:_files -/' \
          '(-x --genome-fasta-extension)'{-x,--genome-fasta-extension}'=[fasta extension in directory]:ext' \
          '--genome-fasta-list=[file with fasta paths]:file:_files' \
          '--output-cluster-definition=[output cluster definition file]:file:_files' \
          '--output-representative-fasta-directory=[symlink representatives dir]:dir:_files -/' \
          '--cluster-contigs[cluster contigs instead of genomes]' \
          '--small-genomes[optimize for small genome inputs]' \
          '--ani=[ANI level for dereplication]:ani' \
          '--min-aligned-fraction=[minimum aligned fraction]:frac' \
          '--quality-formula=[genome quality scoring function]:formula' \
          '--checkm2-quality-report=[CheckM2 quality report]:file:_files' \
          '--precluster-method=[preclustering method]:method:(dashing finch skani)' \
          '--cluster-method=[ANI calculation method]:method:(fastani skani)' \
          '(-t --threads)'{-t,--threads}'=[number of threads]:threads' && ret=0
        ;;
      *)
        _arguments '(-h --help)'{-h,--help}'[show help]' '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
