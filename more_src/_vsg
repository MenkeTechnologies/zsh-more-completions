#compdef vsg
# Documentation: https://vhdl-style-guide.readthedocs.io/en/latest/usage.html
# VHDL Style Guide (vsg): VHDL linter and auto-formatter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '*'{-f,--filename}'=[file(s) to analyze]:file:_files -g "*.(vhd|vhdl)"' \
  '--stdin[read VHDL input from stdin]' \
  '--fix[fix issues found]' \
  '(-fp --fix_phase)'{-fp,--fix_phase}'=[fix issues up to and including this phase]:phase:' \
  '--fix_only=[restrict fixing via JSON file]:file:_files' \
  '(-ap --all_phases)'{-ap,--all_phases}'[do not stop when a violation is detected]' \
  '*'{-c,--configuration}'=[JSON/YAML configuration file]:file:_files' \
  '(-lr --local_rules)'{-lr,--local_rules}'=[path to local rules]:dir:_files -/' \
  '--style=[use predefined style]:style:(indent_only jcl)' \
  '(-of --output_format)'{-of,--output_format}'=[output format]:format:(vsg syntastic summary)' \
  '(-j --junit)'{-j,--junit}'=[extract Junit file]:file:_files' \
  '(-js --json)'{-js,--json}'=[extract JSON file]:file:_files' \
  '(-oc --output_configuration)'{-oc,--output_configuration}'=[write configuration to file]:file:_files' \
  '--quality_report=[create GitLab-compatible quality report]:file:_files' \
  '(-rc --rule_configuration)'{-rc,--rule_configuration}'=[display configuration of a rule]:rule:' \
  '(-b --backup)'{-b,--backup}'[create a copy of input file for comparison]' \
  '(-p --jobs)'{-p,--jobs}'=[number of parallel cores]:cores:' \
  '--debug[display verbose debug information]' && ret=0

return ret
