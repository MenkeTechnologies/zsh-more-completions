#compdef onionpipe
# Documentation: https://github.com/cmars/onionpipe
# onionpipe - forward ports through Tor onion services

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--anonymous=[export to a non-anonymous remote onion service]:bool:(true false)' \
  '--require-auth=[restrict access to a public key]:pubkey:' \
  '--auth=[authenticate with a private key]:key:' \
  '--config=[read forwards from a yaml file]:file:_files' \
  '*:forward:' && ret=0

return ret
