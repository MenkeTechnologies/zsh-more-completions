#compdef armada-binoculars binoculars
# _armada-binoculars — Armada per-cluster log-streaming + exec proxy service (gRPC + REST gateway, paired with the Lookout UI)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/binoculars/main.go on tip; runtime config is YAML-driven (./config/binoculars/config.yaml + --config overrides) with viper ARMADA_* env binding.

_armada-binoculars() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[YAML config file (repeat or comma-separate for multiple)]:file:_files'
}

_armada-binoculars "$@"
