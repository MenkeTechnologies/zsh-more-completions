#compdef ntLink
# Documentation: https://github.com/bcgsc/ntLink
# ntLink: scaffolding genome assemblies using long reads and minimizers

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'ntLink command' \
      'scaffold[main scaffolding operation]' \
      'pair[run only the pairing/mapping stage]' \
      'gap_fill[include gap-filling after scaffolding]' && ret=0
    ;;
esac

return ret
