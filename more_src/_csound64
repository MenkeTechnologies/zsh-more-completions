#compdef csound64
# Documentation: https://csound.com/docs/manual/CommandFlags.html
# Reference accessed: 2026-06-21
# Verified: upstream docs at the URL above (csound64 is the double-precision csound binary, same flags).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-U+[run utility]:utility:(atsa cvanal dnoise envext extractor het_export het_import hetro lpanal pvanal pvlook scale sndinfo srconv)' \
  '-d[suppress all displays]' \
  '-g[suppress graphics displays]' \
  '-G[postscript graphics displays]' \
  '-m+[message level]:n:(0 1 2 3 4 5 6 7)' \
  '-W[write WAV format output]' \
  '-A[write AIFF format output]' \
  '-J[write IRCAM format output]' \
  '-h[no header on output sound file]' \
  '-n[no sound onto disk]' \
  '-s[short integer output samples]' \
  '-f[32-bit floating point output samples]' \
  '-3[24-bit integer output samples]' \
  '-o+[output filename]:file:_files' \
  '-i+[input audio file]:file:_files' \
  '-F+[MIDI input file]:file:_files -g "*.mid"' \
  '-M+[MIDI input device]:device:' \
  '-Q+[MIDI output device]:device:' \
  '-r+[sample rate override]:rate:' \
  '-k+[control rate override]:rate:' \
  '-b+[software buffer samples]:n:' \
  '-B+[hardware buffer samples]:n:' \
  '-+rtaudio=[realtime audio module]:module:' \
  '-+rtmidi=[realtime MIDI module]:module:' \
  '-O+[message log file]:file:_files' \
  '--realtime[realtime mode]' \
  '*:csound file:_files -g "*.(csd|orc|sco)"' && ret=0

return ret
