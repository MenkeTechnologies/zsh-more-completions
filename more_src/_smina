#compdef smina
# Documentation: https://github.com/mwojcikowski/smina
# smina: fork of AutoDock Vina for scoring and minimization (custom scoring functions)

local ret=1

_arguments -s -S \
  '(- *)--help[display usage summary]' \
  '(- *)--help_hidden[display usage summary with hidden options]' \
  '(- *)--version[display program version]' \
  '(-r --receptor)'{-r+,--receptor=}'[rigid part of the receptor (PDBQT)]:receptor file:_files -g "*.pdbqt"' \
  '--flex=[flexible side chains (PDBQT)]:flex file:_files -g "*.pdbqt"' \
  '(-l --ligand)'{-l+,--ligand=}'[ligand(s)]:ligand file:_files' \
  '--flexres=[flexible side chains as comma-separated list]:flexres list:' \
  '--flexdist_ligand=[ligand to use for flexdist]:ligand file:_files' \
  '--flexdist=[set all side chains within distance to flexible]:distance:' \
  '--center_x=[X coordinate of the center]:X coordinate:' \
  '--center_y=[Y coordinate of the center]:Y coordinate:' \
  '--center_z=[Z coordinate of the center]:Z coordinate:' \
  '--size_x=[size in the X dimension (Angstroms)]:X size:' \
  '--size_y=[size in the Y dimension (Angstroms)]:Y size:' \
  '--size_z=[size in the Z dimension (Angstroms)]:Z size:' \
  '--autobox_ligand=[ligand to use for autobox]:ligand file:_files' \
  '--autobox_add=[buffer space to add to auto-generated box]:buffer:' \
  '--no_lig[no ligand; for sampling/minimizing flexible residues]' \
  '--scoring=[alternative builtin scoring function]:scoring:(vina vinardo ad4_scoring dkoes_scoring dkoes_fast)' \
  '--custom_scoring=[custom scoring function file]:file:_files' \
  '--custom_atoms=[custom atom type parameters file]:file:_files' \
  '--score_only[score provided ligand pose]' \
  '--local_only[local search only using autobox]' \
  '--minimize[energy minimization]' \
  '--randomize_only[generate random poses, avoiding clashes]' \
  '--minimize_iters=[number iterations of steepest descent]:iterations:' \
  '--accurate_line[use accurate line search]' \
  '--minimize_early_term[stop minimization before convergence conditions]' \
  '--approximation=[approximation to use]:approximation:(linear spline exact)' \
  '--factor=[approximation factor]:factor:' \
  '--force_cap=[max allowed force]:force:' \
  '--user_grid=[Autodock map file for user grid data]:map file:_files' \
  '--user_grid_lambda=[scales user_grid and functional scoring]:lambda:' \
  '--print_terms[print all available terms]' \
  '--print_atom_types[print all available atom types]' \
  '(-o --out)'{-o+,--out=}'[output file name]:output file:_files' \
  '--out_flex=[output file for flexible receptor residues]:output file:_files' \
  '--log=[write log file]:log file:_files' \
  '--atom_terms=[write per-atom interaction term values]:file:_files' \
  '--atom_term_data[embed per-atom interaction terms in output sd data]' \
  '--cpu=[number of CPUs to use]:cpus:' \
  '--seed=[explicit random seed]:seed:' \
  '--exhaustiveness=[exhaustiveness of the global search (default 8)]:exhaustiveness:' \
  '--num_modes=[maximum number of binding modes to generate (default 9)]:num modes:' \
  '--energy_range=[max energy difference between best and worst mode (default 3)]:energy range:' \
  '--min_rmsd_filter=[rmsd value used to filter final poses]:rmsd:' \
  '(-q --quiet)'{-q,--quiet}'[suppress output messages]' \
  '--addH=[automatically add hydrogens in ligands]:add hydrogens:(true false)' \
  '--config=[options can be put here]:config file:_files' && ret=0

return ret
