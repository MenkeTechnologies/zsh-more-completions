#compdef mri_vol2surf
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_vol2surf
# mri_vol2surf - sample a volume onto a surface

local ret=1

_arguments -s -S \
  '--src[input volume path]:file:_files' \
  '--out[output path]:file:_files' \
  '--srcreg[source registration file]:file:_files' \
  '--hemi[hemisphere (lh or rh)]:hemi:(lh rh)' \
  '--src_type[input volume file format]:type:' \
  '--out_type[output file format]:type:' \
  '--float2int[float-to-int conversion (round/tkregister)]:method:(round tkregister)' \
  '--fixtkreg[make registration matrix round-compatible]' \
  '--fwhm[smooth input volume by FWHM mm]:fwhm:' \
  '--trgsubject[target subject if different than registration]:subject:' \
  '--surf[target surface (default white)]:surf:' \
  '--surfreg[intersubject registration surface]:surf:' \
  '--icoorder[order of icosahedron when trgsubject=ico]:order:' \
  '--projfrac[fractional projection along surface normal (0 to 1)]:frac:' \
  '--projdist[distance projection along normal (mm)]:dist:' \
  '--frame[save only nth frame (paint format)]:n:' \
  '--noreshape[do not save output as multiple slices]' \
  '--rf[integer reshaping factor]:n:' \
  '--srchit[volume storing number of hits at each voxel]:file:_files' \
  '--srchit_type[source hit volume format]:type:' \
  '--nvox[write number of voxels intersecting surface]:file:_files' \
  '--srcsynth[synthesize source volume]:seed:' \
  '--seedfile[save synth seed to file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version and exit]' && ret=0

return ret
