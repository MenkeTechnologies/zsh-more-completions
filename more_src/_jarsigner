#compdef jarsigner

_arguments -s \
  '(- *)-version[show version]' \
  '-keystore=[keystore URL]:url:' \
  '-storepass=[keystore password]:password:' \
  '-storepass:env=[env var holding store password]:env:' \
  '-storepass:file=[file holding store password]:file:_files' \
  '-storetype=[keystore type]:type:(JKS PKCS12 JCEKS)' \
  '-keypass=[private key password]:password:' \
  '-keypass:env=[env var holding key password]:env:' \
  '-keypass:file=[file holding key password]:file:_files' \
  '-certchain=[certificate chain file]:file:_files' \
  '-sigfile=[signature file name]:name:' \
  '-signedjar=[output signed jar]:file:_files' \
  '-digestalg=[digest algorithm]:algo:(SHA-256 SHA-384 SHA-512 SHA-1)' \
  '-sigalg=[signature algorithm]:algo:(SHA256withRSA SHA384withRSA SHA512withRSA SHA256withDSA SHA256withECDSA)' \
  '-internalsf[include .SF file in signature block]' \
  '-sectionsonly[do not compute signature for entire manifest]' \
  '-tsa=[timestamping authority URL]:url:' \
  '-tsacert=[TSA cert alias]:alias:' \
  '-tsapolicyid=[TSA policy ID]:oid:' \
  '-tsadigestalg=[TSA digest algorithm]:algo:' \
  '-verify[verify a signed JAR]' \
  '-certs[show certificates with -verify]' \
  '-revCheck[revocation check during verify]' \
  '-protected=[keystore protection auth]:flag:(true false)' \
  '-strict[treat warnings as errors]' \
  '-verbose[verbose output]' \
  '-providerName=[provider name]:name:' \
  '-addprovider=[add a security provider]:name:' \
  '-providerClass=[provider class]:class:' \
  '-providerArg=[provider argument]:arg:' \
  '-providerPath=[provider classpath]:path:' \
  '*-J-[pass option to JVM]:option:' \
  '-conf=[options config file]:url:' \
  '*:jar:_files -g "*.jar"'
