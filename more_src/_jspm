#compdef jspm

# Zsh completion for jspm - Module CDN / import map generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_jspm_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '(-m --map)'{-m,--map}'[path to import map]:file:_files'
  '*'{-e,--env}'[environment condition]:env:(browser node development production module deno worker react-native)'
  '(-r --resolution)'{-r,--resolution}'[custom resolution]:resolution:'
  '(-p --provider)'{-p,--provider}'[module provider]:provider:(jspm nodemodules deno unpkg jsdelivr skypack esm.sh)'
  '(-o --output)'{-o,--output}'[output file path]:file:_files'
  '--stdout[write output to stdout]'
  '(-P --preload)'{-P,--preload}'[include preload tags]'
  '(-I --integrity)'{-I,--integrity}'[include integrity attributes]'
  '(-C --compact)'{-C,--compact}'[output compact JSON]'
)

_arguments -s -S -C \
  "${_jspm_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'install:Install packages into the import map (alias: i)'
      'uninstall:Remove packages from the import map (alias: u)'
      'update:Update packages in the import map'
      'link:Link a local package'
      'build:Build modules'
    )
    _describe -t commands 'jspm commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      install|i)
        _arguments -s -S \
          "${_jspm_global_flags[@]}" \
          '*:package:' && ret=0
        ;;
      uninstall|u)
        _arguments -s -S \
          "${_jspm_global_flags[@]}" \
          '*:package:' && ret=0
        ;;
      update)
        _arguments -s -S \
          "${_jspm_global_flags[@]}" \
          '*:package:' && ret=0
        ;;
      link)
        _arguments -s -S \
          "${_jspm_global_flags[@]}" \
          '1:package path:_files' && ret=0
        ;;
      build)
        _arguments -s -S \
          "${_jspm_global_flags[@]}" \
          '*:modules:' && ret=0
        ;;
    esac
    ;;
esac

return ret
