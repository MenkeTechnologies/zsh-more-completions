#compdef bacalhau
# Documentation: https://bacalhau.org/docs/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--api-host=[API host]:host:' \
  '--api-port=[API port]:port:' \
  '(-c --config)'{-c,--config}'=[Config path or dotted values]:path:' \
  '--data-dir=[Bacalhau data dir]:dir:_directories' \
  '--output=[Format]:format:(json yaml table)' \
  '--pretty[Pretty-print JSON or YAML]' \
  '1:command:(agent config docker job node)' \
  '*::args: _default'
