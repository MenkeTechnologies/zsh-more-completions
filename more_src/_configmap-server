#compdef configmap-server
# _configmap-server — operator-registry server that materialises a ConfigMap of OLM manifests into a sqlite db + serves it over gRPC
# upstream: https://github.com/operator-framework/operator-registry
# Flags from cmd/configmap-server/main.go on tip (cobra).

_configmap-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-k --kubeconfig)'{-k,--kubeconfig}'=[absolute path to kubeconfig file]:file:_files' \
        '(-d --database)'{-d,--database}'=[name of db to output]:file:_files' \
        '(-c --configMapName)'{-c,--configMapName}'=[name of the configmap]:name:' \
        '(-n --configMapNamespace)'{-n,--configMapNamespace}'=[namespace of the configmap]:ns:' \
        '(-p --port)'{-p,--port}'=[port number to serve on]:port:' \
        '(-t --termination-log)'{-t,--termination-log}'=[container termination log path]:file:_files' \
        '--permissive[allow registry load errors]' \
        '--debug[enable debug logging (hidden)]'
}

_configmap-server "$@"
