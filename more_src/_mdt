#compdef mdt

# https://github.com/basilioss/mdt — shell UI (mdt v1.4.0)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(-d --dir)'{-d,--dir}'=-[tasks directory]:dir:_directories' \
  '(-i --inbox)'{-i,--inbox}'=-[inbox file path]:file:_files' \
  '(-m --add-multiple)'{-m,--add-multiple}'[add several tasks in one prompt]' \
  '(-u --unite-tasks)'{-u,--unite-tasks}'[list tasks from united sources]' \
  '--color=-[gum highlight color]:color:' \
  '--prompt=-[input prompt character]:char:' \
  '--cursor=-[selection cursor character]:char:' \
  '--item-width=-[list column width]:n:' \
  '--input-width=-[input field width]:n:' \
  '--editor=-[external markdown editor]:command:_command_names'
