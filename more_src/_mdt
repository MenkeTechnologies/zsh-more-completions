#compdef mdt
# Documentation: https://github.com/basilioss/mdt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mdt: task manager with gum UI
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --dir)'{-d,--dir}'=-[tasks directory]:dir:_directories' \
  '(-i --inbox)'{-i,--inbox}'=-[inbox file path]:file:_files' \
  '(-l --list-inbox)'{-l,--list-inbox}"[auto-select 'List inbox']" \
  '(-a --add-inbox)'{-a,--add-inbox}"[auto-select 'Add inbox']" \
  '(-e --edit-inbox)'{-e,--edit-inbox}'[open inbox in editor]' \
  '(-m --add-multiple)'{-m,--add-multiple}'[add multiple tasks in one prompt]' \
  '(-u --unite-tasks)'{-u,--unite-tasks}'[list all tasks regardless of heading]' \
  '--display-titles[show first heading instead of filename]' \
  '--todo-filename=-[filename for newly created files]:name:' \
  '--color=-[main color]:color:' \
  '--prompt=-[input prompt character]:char:' \
  '--cursor=-[selection character]:char:' \
  '--item-width=-[item display width]:n:' \
  '--input-width=-[input field width]:n:' \
  '--editor=-[markdown file editor]:command:_command_names'
