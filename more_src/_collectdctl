#compdef collectdctl
# Documentation: https://www.collectd.org/documentation/manpages/collectdctl.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'getval:get value identifier'
  'flush:flush plugin caches'
  'listval:list value identifiers'
  'putval:submit value'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-s+[unix socket]:sock:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'collectdctl command' commands && ret=0 ;;
esac

return ret
