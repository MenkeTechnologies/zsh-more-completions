#compdef last-split
# Documentation: https://gitlab.com/mcfrith/last/-/raw/main/doc/last-split.rst
# Read alignments of query sequences and find a unique best alignment for each part

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show a help message, with default option values, and exit]' \
  '(-f --format)'{-f,--format=}'[choose the output format: MAF or MAF+]:format:(MAF MAF+)' \
  '(-r --reverse)'{-r,--reverse}'[reverse the roles of the 2 sequences in each alignment]' \
  '(-g --genome)'{-g,--genome=}'[do spliced alignment, reading splice signals from the named genome]:name:' \
  '(-d --direction)'{-d,--direction=}'[do spliced alignment, set the strandedness of the queries]:direction:' \
  '(-c --cis)'{-c,--cis=}'[do spliced alignment, set the average probability of cis-splicing]:prob:' \
  '(-t --trans)'{-t,--trans=}'[do spliced alignment, set the average probability of trans-splicing]:prob:' \
  '(-M --mean)'{-M,--mean=}'[do spliced alignment, set the mean of ln(intron length)]:mean:' \
  '(-S --sdev)'{-S,--sdev=}'[do spliced alignment, set the standard deviation of ln(intron length)]:sdev:' \
  '(-m --mismap)'{-m,--mismap=}'[do not write alignments with mismap probability greater than PROB]:prob:' \
  '(-s --score)'{-s,--score=}'[do not write alignments with score less than INT]:int:' \
  '(-n --no-split)'{-n,--no-split}'[do probability calculations as usual, but write the original alignments]' \
  '(-b --bytes)'{-b,--bytes=}'[skip any query sequence requiring more than B bytes of memory]:bytes:' \
  '(-v --verbose)'{-v,--verbose}'[show progress information on the screen]' \
  '(-V --version)'{-V,--version}'[show version information and exit]' \
  '*:maf alignment file:_files' && ret=0

return ret
