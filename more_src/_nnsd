#compdef nnsd
# Documentation: https://www.systutorials.com/docs/linux/man/n-nnsd/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Tcllib nameserv daemon. `nnsd -h` confirms: ?-localonly BOOL? ?-port PORT?

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-localonly+[localhost only]:bool:(true false 1 0)' \
  '-port+[port]:port:' && ret=0

return ret
