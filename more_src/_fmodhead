#compdef fmodhead
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fmodhead.txt
# Add, modify, or delete keywords in a FITS header

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "tmpfil=[template file of header changes]:file:_files" \
  "*:FITS file:_files" && ret=0

return ret
