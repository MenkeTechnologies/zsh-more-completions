#compdef urlhunter
# Documentation: https://github.com/utkusen/urlhunter
# recon tool that allows searching on URLs that are exposed via shortener services

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--keywords=[text file containing keywords to search within URLs]:file:_files' \
  '--date=[archive file(s) to download (latest, single date, year, or range)]:date' \
  '-o+[output file for results]:file:_files' \
  '-rm[remove downloaded archive folders after processing]' && ret=0

return ret
