#compdef dhcp_lease_time
# Documentation: https://man.archlinux.org/search?q=dhcp_lease_time
# Reference accessed: 2026-05-16

# dhcp_lease_time: report DHCP lease time for an IP (dnsmasq helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:IPv4 address:' && ret=0
return ret
