#compdef heif-enc
# Documentation: heif-enc --help (libheif 1.23.0)
# Source: HEIF/AVIF encoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
    '(-q --quality)'{-q+,--quality=}'[output quality 0..100]:q:' \
    '(-L --lossless)'{-L,--lossless}'[generate lossless output]' \
    '(-t --thumb)'{-t+,--thumb=}'[generate thumbnail of max size]:size:' \
    '--no-alpha[do not save alpha channel]' \
    '--no-thumb-alpha[do not save alpha in thumbnail]' \
    '--verbose[enable logging]' \
    '(-b --bit-depth)'{-b+,--bit-depth=}'[bits to use from 16-bit PNG input (9-16)]:bits:' \
    '--premultiplied-alpha[input has premultiplied alpha]' \
    '(-C --chroma-downsampling)'{-C+,--chroma-downsampling=}'[chroma downsampling algorithm]:algo:(nn average sharp-yuv)' \
    '--benchmark[measure encoding time + PSNR]' \
    '--pitm-description=[user description for primary image]:text:' \
    '--add-compatible-brand=[add compatible brand (4 chars)]:brand:' \
    '--unif[use unified ID namespace]' \
    '--mini[use compact mini box format]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)'{-A,--avif}'[encode as AVIF]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)--hevc[encode as HEVC (default)]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)--vvc[encode as VVC (experimental)]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)--avc[encode as AVC (experimental)]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)--jpeg[encode as JPEG]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)--jpeg2000[encode as JPEG 2000 (experimental)]' \
    '(-A --avif --hevc --vvc --avc --jpeg --jpeg2000 --htj2k)--htj2k[encode as High Throughput JPEG 2000 (experimental)]' \
    '--list-encoders[list available encoders]' \
    '*-p+[encoder parameter NAME=VALUE]:param:' \
    '*:input image:_files -g "*.(png|jpg|jpeg|y4m|ppm)"' \
    && ret=0

return ret
