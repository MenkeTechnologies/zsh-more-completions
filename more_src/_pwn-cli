#compdef pwn
# Documentation: https://man.archlinux.org/search?q=pwn
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'asm:assemble shellcode'
  'checksec:check ELF security'
  'constgrep:grep pwntools constants'
  'cyclic:de Bruijn cyclic patterns'
  'debug:debug a process'
  'disablenx:disable NX bit'
  'disasm:disassemble bytes'
  'elfdiff:diff ELF files'
  'elfpatch:patch ELF binary'
  'errno:lookup errno'
  'hex:hex encode'
  'libcdb:libc db lookup'
  'phd:colourful hex dump'
  'pwnstrip:strip pwntools binary'
  'scramble:scramble shellcode'
  'shellcraft:show shellcode template'
  'template:exploit template generator'
  'unhex:hex decode'
  'unupdate:disable update'
  'update:update pwntools'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pwn command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (asm)
        _arguments \
          '-h[help]' \
          '-f+[output format]:f:(raw hex string elf default)' \
          '-o+[output]:file:_files' \
          '-c+[context]:c:' \
          '-v+[avoid bytes]:bytes:' \
          '-i+[infile]:file:_files' \
          '*: :' && ret=0 ;;
      (checksec)
        _arguments \
          '-h[help]' \
          '*: :_files' && ret=0 ;;
      (cyclic)
        _arguments \
          '-h[help]' \
          '-a+[alphabet]:s:' \
          '-n+[length]:n:' \
          '-l+[lookup]:s:' \
          '-c+[context]:c:' \
          '*:length:' && ret=0 ;;
      (disasm)
        _arguments \
          '-h[help]' \
          '-c+[color]:b:' \
          '-a+[address]:hex:' \
          '-c+[context]:c:' \
          '*:bytes:' && ret=0 ;;
      (shellcraft)
        _arguments \
          '-h[help]' \
          '-l[list templates]' \
          '-f+[output format]:f:(raw hex string elf default)' \
          '-o+[output]:file:_files' \
          '-d+[debug after]:b:' \
          '-r[run]' \
          '*: :' && ret=0 ;;
      (libcdb)
        _arguments \
          '1:subcommand:(file fetch find hash lookup search)' \
          '*: :_files' && ret=0 ;;
      (template)
        _arguments \
          '-h[help]' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
