#compdef tcpkali

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose=}'[verbosity]:level:(0 1 2 3)' \
  '(-w --workers)'{-w,--workers=}'[parallel threads]:n:' \
  '--nagle=[Nagle algorithm]:state:(on off)' \
  '--rcvbuf=[TCP recv buffer]:size:' \
  '--sndbuf=[TCP send buffer]:size:' \
  '*--source-ip=[source IP]:ip:' \
  '(--ws --websocket)'{--ws,--websocket}'[use WebSocket framing]' \
  '(-c --connections)'{-c,--connections=}'[concurrent connections]:n:' \
  '--connect-rate=[new connections per sec]:rate:' \
  '--connect-timeout=[connection timeout]:duration:' \
  '--channel-lifetime=[close after duration]:duration:' \
  '--channel-bandwidth-upstream=[upstream BW]:bw:' \
  '--channel-bandwidth-downstream=[downstream BW]:bw:' \
  '(-l --listen-port)'{-l,--listen-port=}'[accept inbound on port]:port:' \
  '--listen-mode=[inbound behavior]:mode:(silent active)' \
  '(-T --duration)'{-T,--duration=}'[total run time]:duration:' \
  '(-e --unescape-message-args)'{-e,--unescape-message-args}'[unescape message args]' \
  '--first-message=[send once at open]:msg:' \
  '--first-message-file=[first message file]:file:_files' \
  '*'{-m,--message=}'[repeated message]:msg:' \
  '*'{-f,--message-file=}'[message file]:file:_files' \
  '(-r --message-rate)'{-r,--message-rate=}'[messages per sec]:rate:' \
  '--latency-marker=[latency marker]:str:' \
  '--latency-marker-skip=[ignore N markers]:n:' \
  '--statsd[enable StatsD]' \
  '--statsd-host=[StatsD host]:host:_hosts' \
  '--statsd-port=[StatsD port]:port:' \
  '--statsd-namespace=[metric namespace]:ns:' \
  '*:host\:port:'
