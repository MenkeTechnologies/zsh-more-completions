#compdef dosbox-x

# Zsh completion for dosbox-x - DOS emulator with enhancements

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-conf[use specified config file]:config file:_files -g "*.conf"' \
  '-startmapper[start the keymapper on startup]' \
  '-noautoexec[skip the \[autoexec\] section of the config file]' \
  '-securemode[enable secure mode (restricted system access)]' \
  '-fullscreen[start in fullscreen mode]' \
  '-savedir=[specify save file directory]:directory:_files -/' \
  '-defaultdir=[specify default directory]:directory:_files -/' \
  '-defaultconf[use the default config file]' \
  '-defaultmapper[use the default mapper file]' \
  '-data-host-forced[force data host mode]' \
  '-prerun[run command before starting the shell]' \
  '-hostrun[run command on the host]' \
  '-silent[suppress output]' \
  '-socket=[specify socket for NE2000]:socket' \
  '-o=[set command line option]:option' \
  '-set=[set config option]:section property=value' \
  '-editconf=[edit config file with editor]:editor:_command_names -e' \
  '-opencaptures=[open captures directory]:program:_command_names -e' \
  '-eraseconf[erase the default config file]' \
  '-resetconf[reset the config file to defaults]' \
  '-erasemapper[erase the mapper file]' \
  '-resetmapper[reset the mapper file to defaults]' \
  '-nogui[do not show the GUI menu bar]' \
  '-nomenu[do not show the menu bar]' \
  '-userconf[load config from user directory]' \
  '-lang=[use specified language file]:file:_files' \
  '-machine=[set machine type]:type:(hercules cga tandy pcjr ega vgaonly svga_s3 svga_et3000 svga_et4000 svga_paradise vesa_nolfb vesa_oldvbe pc98 pc9801 pc9821 fm_towns)' \
  '-debug[enable debug mode]' \
  '-nolog[do not write a log file]' \
  '-version[show version]' \
  '-h[show help]' \
  '-help[show help]' \
  '*:file:_files' && ret=0

return ret
