#compdef supermute
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/operations/supermute.c
# permute or transpose a 3d datacube

local ret=1

_arguments -s -S \
  'n1=[number of samples in the fast direction]:n1' \
  'n2=[number of samples in the med direction]:n2' \
  'n3=[number of samples in the slow direction]:n3' \
  'o1=[new fast direction]:o1' \
  'o2=[new med direction]:o2' \
  'o3=[new slow direction]:o3' \
  'd1=[output interval in new fast direction]:d1' \
  'd2=[output interval in new med direction]:d2' \
  'd3=[output interval in new slow direction]:d3' \
  '*:file:_files' && ret=0


return ret
