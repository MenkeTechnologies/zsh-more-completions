#compdef ecalc
# ecalc — calculate normalised structure factors (E values) (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input reflection MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output MTZ or ASCII]:file:_files' \
  'LABIN[input column assignments]:labels:' \
  'LABOUT[output column labels]:labels:' \
  'EXCLUDE[data exclusion criteria]:opt:' \
  'MODDIFF[noise correction on differences]:m:(YES NO)' \
  'RESOLUTION[resolution cutoff]:lim:' \
  'SHELL[reflections averaged per shell]:n:' \
  'SPACEGROUP[space group]:sg:' \
  'TITLE[output title]:title:' \
  'SCALE[scaling factor for output]:scale:' \
  'MULTAN[output E values for MULTAN]' \
  'SNB[output E values for SnB]' \
  'REFLECTIONS[max reflections to write]:n:' \
  '*:argument:_files' && ret=0

return ret
