#compdef clusterssh cssh ctel crsh ckrb cscp
# Documentation: https://manpages.debian.org/testing/clusterssh/cssh.1p.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-H,--man}'[show full manual]' \
  '(- *)'{-v,--version}'[show version]' \
  '--usage[show usage]' \
  '(-a --action)'{-a+,--action=}'[command to run in each session]:command:_command_names' \
  '(-l --username)'{-l+,--username=}'[ssh username]:user:_users' \
  '(-p --port)'{-p+,--port=}'[ssh port]:port:_ports' \
  '(-c --cluster-file)'{-c+,--cluster-file=}'[additional cluster definitions file]:file:_files' \
  '(-C --config-file)'{-C+,--config-file=}'[ClusterSSH config file]:file:_files' \
  '(-r --tag-file)'{-r+,--tag-file=}'[additional tag file]:file:_files' \
  '(-T --title)'{-T+,--title=}'[controlling window title]:title:' \
  '(-o --options)'{-o+,--options=}'[options passed to ssh]:opts:' \
  '(-x --cols)'{-x+,--cols=}'[number of columns in window grid]:n:' \
  '(-y --rows)'{-y+,--rows=}'[number of rows in window grid]:n:' \
  '(-f --font)'{-f+,--font=}'[terminal font]:font:' \
  '(-K --autoclose)'{-K+,--autoclose=}'[seconds before closing finished windows]:seconds:' \
  '(-q --autoquit)'{-q,--autoquit}'[auto-quit when last window closes]' \
  '(-d --dump-config)'{-d,--dump-config}'[dump current configuration]' \
  '(-s --show-history)'{-s,--show-history}'[show cssh history]' \
  '(-L --list)'{-L,--list}'[list configured cluster tags]' \
  '(-g --tile)'{-g,--tile}'[tile windows]' \
  '(-G --no-tile)'{-G,--no-tile}'[do not tile windows]' \
  '(-u --unique-servers)'{-u,--unique-servers}'[de-duplicate the server list]' \
  '(-e --evaluate)'{-e+,--evaluate=}'[evaluate connection settings]:host:_hosts' \
  '(-t --term-args)'{-t+,--term-args=}'[xterm arguments]:args:' \
  '--use-all-a-records[use all DNS A records for a host]' \
  '--fillscreen[resize windows to fill the screen]' \
  '--debug=[set debug level]:level:' \
  '*:host:_hosts' && ret=0

return ret
