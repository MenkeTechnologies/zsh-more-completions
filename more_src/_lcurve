#compdef lcurve
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/lcurve.txt
# Produce binned lightcurves and plot up to 4 simultaneous energy time series

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'nser=[number of input time series (1-4)]:count:(1 2 3 4)' \
  'cfile1=[input filename for first time series]:file:_files' \
  'cfile2=[input filename for second time series]:file:_files' \
  'cfile3=[input filename for third time series]:file:_files' \
  'cfile4=[input filename for fourth time series]:file:_files' \
  'window=[xronos window file for data screening]:window file:_files' \
  'dtnb=[duration in seconds of the NEWBIN time]:seconds:' \
  'nbint=[number of newbins per interval]:count:' \
  'outfile=[output filename]:output file:_files' \
  'plot=[plot results via PLT]:flag:(yes no)' \
  'plotdev=[plot device]:device:(/xw /ps /tek /vt)' \
  'itre=[polynomial trend removal flag 0-4]:order:(0 1 2 3 4)' \
  'itremo=[trend removal mode]:mode:(1 2 3)' \
  'tunits=[time axis units]:units:' \
  'tchat=[terminal chattiness level]:level:' \
  'lchat=[log file chattiness level]:level:' \
  'logname=[log filename]:log file:_files' \
  'clobber=[overwrite pre-existing output files]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
