#compdef sfind
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/sfind.html
# MIRIAD: find sources in images (FDR or sigma-clipping)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'type=[display type]:type:(contour pixel)' \
  'region=[region of interest]:region:' \
  'xybin=[spatial increment and binning]:xybin:' \
  'chan=[channel increment and averaging]:chan:' \
  'slev=[contour level scale factor]:slev:' \
  'levs=[contour levels]:levs:' \
  'range=[pixel map range and transfer function]:range:' \
  'cutoff=[minimum flux density threshold]:cutoff:' \
  'rmsbox=[background estimation box size]:rmsbox:' \
  'alpha=[FDR false pixel percentage]:alpha:' \
  'xrms=[sigma cutoff threshold multiplier]:xrms:' \
  'device=[PGPLOT device]:device:' \
  'nxy=[subplots in x and y]:nxy:' \
  'labtyp=[spatial label types]:labtyp:' \
  'logfile=[output log file]:logfile:_files' \
  'options=[output and behavior options]:options:' \
  'csize=[character sizes]:csize:' \
  '*:image:_files' && ret=0

return ret
