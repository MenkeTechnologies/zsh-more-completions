#compdef tofi-drun
# _tofi-drun — tofi tofi-drun CLI desktop application launcher around the tofi dmenu-style fuzzy menu for Wayland scanning $XDG_DATA_DIRS/applications .desktop files presenting them with icons fuzzy matching prefix configurable terminal launching for GUI apps (Philip Jones team, C); getopt
# upstream: https://github.com/philj56/tofi

_tofi-drun() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.ini *.conf"' \
        '--config=+[config file]:file:_files -g "*.ini *.conf"' \
        '--output=+[output name]:str:' \
        '--prompt-text=+[prompt]:str:' \
        '--terminal=+[terminal cmd]:file:_files' \
        '--include-generic-name=+[s]:s:(true false)' \
        '--include-actions=+[s]:s:(true false)' \
        '--drun-launch=+[s]:s:(true false)' \
        '--drun-print-exec=+[s]:s:(true false)' \
        '--anchor=+[a]:a:(top-left top top-right left center right bottom-left bottom bottom-right)' \
        '--margin-top=+[N]:n:' \
        '--margin-bottom=+[N]:n:' \
        '--margin-left=+[N]:n:' \
        '--margin-right=+[N]:n:' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--font=+[font]:str:' \
        '--font-size=+[N]:n:' \
        '--num-results=+[N]:n:' \
        '--background-color=+[color]:str:' \
        '--foreground-color=+[color]:str:' \
        '--selection-color=+[color]:str:' \
        '--matching-algorithm=+[a]:a:(normal fuzzy prefix contains)' \
        '--horizontal[horizontal layout]' \
        '--history=+[s]:s:(true false)' \
        '--history-file=+[file]:file:_files' \
        '*::'
}

_tofi-drun "$@"
