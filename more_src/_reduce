#compdef reduce

# REDUCE: general-purpose computer algebra system
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '--gui[start GUI version]' \
  '--csl[use CSL backend]' \
  '--psl[use PSL backend]' \
  '-w[batch mode]' \
  '-l[load this file as input]:file:_files -g "*.red"' \
  '*:REDUCE source:_files -g "*.red"' && ret=0
return ret
