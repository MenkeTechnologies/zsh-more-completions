#compdef fileroot
# _fileroot — strip 1+ extensions from filenames (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from fileroot.c (single-letter getopt-style).

_fileroot() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-r+[replace next char with one after]:chars:' \
        '-2[remove 2 extensions]' \
        '-3[remove 3 extensions]' \
        '-4[remove 4 extensions]' \
        '-5[remove 5 extensions]' \
        '-6[remove 6 extensions]' \
        '-a[remove all extensions]' \
        '*:file path:_files'
}

_fileroot "$@"
