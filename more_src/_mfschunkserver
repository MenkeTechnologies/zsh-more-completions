#compdef mfschunkserver
# Documentation: https://moosefs.com/manpages/mfschunkserver
# Reference accessed: 2026-05-19
# Verified: upstream MooseFS man page at the URL above.
# mfschunkserver: MooseFS chunkserver daemon.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show usage and exit]' \
  '(- *)-v[show version and exit]' \
  '-c+[alternative config file (default mfschunkserver.cfg)]:file:_files -g "*.cfg"' \
  '-f[run in foreground, do not daemonize]' \
  '-d[run with dangerous (DANGEROUS_*) options]' \
  '-u[log undefined configuration values]' \
  '-n[do not increase core dump size limit]' \
  '-t+[lockfile wait seconds (default 60)]:secs:' \
  '*:action:(start stop restart reload info test kill restore)' && ret=0
return ret
