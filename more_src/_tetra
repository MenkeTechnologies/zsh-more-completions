#compdef tetra
# Documentation: https://github.com/cilium/tetragon/tree/main/cmd/tetra
# Reference accessed: 2026-05-21
# Verified: upstream tetra source at the URL above.

# Zsh completion for tetra - Tetragon eBPF CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--server-address=[gRPC server address]:address' \
  '--timeout=[connection timeout]:timeout' \
  '--retries=[number of retries]:retries' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bugtool:Diagnostic tool for bug reporting'
      'getevents:Retrieve recorded events'
      'loglevel:Log level management'
      'sensors:Manage sensors'
      'status:Show system status'
      'tracingpolicy:Tracing policy configuration'
      'policyfilter:Policy filtering'
      'policytest:Test policies'
      'debug:Debugging utilities'
      'eventlog:Event logging functionality'
      'explain:Event explanation'
      'info:System information'
      'probe:Probe management'
      'rthooks:Runtime hooks'
      'cgtracker:Control group tracking'
      'cri:CRI integration'
      'version:Show version information'
    )
    _describe -t commands 'tetra command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      getevents)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output format]:format:(json compact)' \
          '--color=[colorize compact output]:when:(auto always never)' \
          '(-t --tty-encode)'{-t,--tty-encode}'[encode terminal data by file path]:file:_files' \
          '--timestamps[include timestamps in compact output]' \
          '--host[get host events]' \
          '(-n --namespace)'{-n,--namespace}'[filter by Kubernetes namespace]:namespace' \
          '--pod=[filter by pod name regex]:pod' \
          '--process=[filter by process name regex]:process' \
          '(-e --event-types)'{-e,--event-types}'[include only events of given types]:types' \
          '--policy-names=[filter by tracing policy names]:names' \
          '--namespace-regex=[filter by namespace name regex]:regex' \
          '--cel-expression=[filter by CEL expression]:expr' \
          '(-f --include-fields)'{-f,--include-fields}'[include only these fields]:fields' \
          '(-F --exclude-fields)'{-F,--exclude-fields}'[exclude these fields]:fields' \
          '--stack-traces[include stack traces in compact output]' \
          '--ima-hash[include IMA hashes in compact output]' \
          '--reconnect[keep trying to connect after errors]' \
          '--reconnect-wait=[wait time before reconnecting]:duration' && ret=0
        ;;
      loglevel)
        local -a subcmds=(
          'get:Get current log level'
          'set:Set log level'
        )
        _describe -t subcmds 'loglevel subcommand' subcmds && ret=0
        ;;
      sensors)
        local -a subcmds=(
          'list:List sensors'
          'enable:Enable a sensor'
          'disable:Disable a sensor'
          'rm:Remove a sensor'
        )
        _describe -t subcmds 'sensors subcommand' subcmds && ret=0
        ;;
      tracingpolicy)
        local -a subcmds=(
          'add:Add a tracing policy'
          'delete:Delete a tracing policy'
          'list:List tracing policies'
          'generate:Generate a tracing policy'
        )
        _describe -t subcmds 'tracingpolicy subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
