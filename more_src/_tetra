#compdef tetra

# Zsh completion for tetra - Tetragon eBPF CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--server-address=[gRPC server address]:address' \
  '--timeout=[connection timeout]:timeout' \
  '--retries=[number of retries]:retries' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bugtool:Collect debug information'
      'completion:Generate shell completions'
      'getevents:Get events from Tetragon'
      'loglevel:Manage log level'
      'sensors:Manage sensors'
      'status:Show status'
      'tracingpolicy:Manage tracing policies'
    )
    _describe -t commands 'tetra command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      completion)
        local -a subcmds=(
          'bash:Generate bash completions'
          'zsh:Generate zsh completions'
          'fish:Generate fish completions'
          'powershell:Generate PowerShell completions'
        )
        _describe -t subcmds 'completion subcommand' subcmds && ret=0
        ;;
      getevents)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output format]:format:(compact json tabular)' \
          '--color=[colorize output]:when:(auto always never)' \
          '--compact[compact output]' \
          '--tty-encode[encode for TTY]' \
          '--timestamps[show timestamps]' \
          '--host=[filter by host]:host' \
          '(-n --namespace)'{-n,--namespace}'[filter by namespace]:namespace' \
          '--pod=[filter by pod name]:pod' \
          '--container=[filter by container name]:container' \
          '--process=[filter by process name]:process' \
          '--pid=[filter by PID]:pid' && ret=0
        ;;
      loglevel)
        local -a subcmds=(
          'get:Get current log level'
          'set:Set log level'
        )
        _describe -t subcmds 'loglevel subcommand' subcmds && ret=0
        ;;
      sensors)
        local -a subcmds=(
          'list:List sensors'
          'enable:Enable a sensor'
          'disable:Disable a sensor'
          'rm:Remove a sensor'
        )
        _describe -t subcmds 'sensors subcommand' subcmds && ret=0
        ;;
      tracingpolicy)
        local -a subcmds=(
          'add:Add a tracing policy'
          'delete:Delete a tracing policy'
          'list:List tracing policies'
          'generate:Generate a tracing policy'
        )
        _describe -t subcmds 'tracingpolicy subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
