#compdef memacct

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'get:fetch memory usage statistics'
  'set:set memory usage limits'
  'monitor:monitor memory usage for a given subsystem in real time'
  'help:show subcommand help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-v,--verbose}'[enable verbose mode]' \
  '--list[list names for all active memory accounting subsystems]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'memacct subcommand' subcommands && ret=0
    ;;
esac

return ret
