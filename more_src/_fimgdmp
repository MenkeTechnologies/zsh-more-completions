#compdef fimgdmp
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/fimgdmp.html
# Dump the contents of a FITS image to an ASCII file

local ret=1

_arguments -s -S \
  'infile=[input FITS image and extension]:infile:_files' \
  'outfil=[output ASCII file, STDOUT for screen]:outfil:_files' \
  'xlow=[lower column bound NAXIS1]:xlow:' \
  'xhigh=[upper column bound NAXIS1]:xhigh:' \
  'ylow=[lower row bound NAXIS2]:ylow:' \
  'yhigh=[upper row bound NAXIS2]:yhigh:' \
  'zlow=[lower layer bound NAXIS3]:zlow:' \
  'zhigh=[upper layer bound NAXIS3]:zhigh:' \
  'prflag=[include header keywords]:prflag:(yes no)' \
  'showscale=[apply scaling or show raw values]:showscale:(yes no)' \
  '*:file:_files' && ret=0

return ret
