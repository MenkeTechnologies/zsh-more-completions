#compdef dipc
# Documentation: https://man.archlinux.org/search?q=dipc
# Reference accessed: 2026-05-16

# Zsh completion for dipc (doprz/dipc, clap 4): src/cli.rs, built-in theme names from
# ColorPalette::from_str, DeltaE labels from CLIDEMethod in src/delta.rs.

_dipc_themes() {
  local -a themes
  themes=(
    catppuccin dracula edge everforest gruvbox gruvbox-material kanagawa nord onedark
    rose-pine solarized tokyo-night
  )
  _alternative \
    "themes:built-in palette:($themes)" \
    'files:JSON theme on disk:_files'
}

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tui[interactive palette and file picker]' \
  '(-s --styles)'{-s,--styles=}'[palette variations: all, none, or comma-separated names]:variations:(all none)' \
  '(-o --output)'{-o,--output=}'[comma-separated output paths (- for stdout)]:paths:' \
  '(-d --dir-output)'{-d,--dir-output=}'[output directory for batches]:directory:_files -/' \
  '(-m --method)'{-m,--method=}'[CIELAB DeltaE metric]:method:(de2000 de1994g de1994t de1976)' \
  '*-v[verbosity (repeatable, gated by log crate)]' \
  '::palette (builtin name, theme.json, or JSON\: {} inline):_dipc_themes' \
  '*:image path (comma list allowed, - for stdin):_files' && ret=0

return ret
