#compdef solidity-select

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a Solidity compiler version'
  'use:switch to a Solidity compiler version'
  'versions:list available versions'
  'current:show current version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'solidity-select command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install|use)
        _arguments -s -S \
          '1:version:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
