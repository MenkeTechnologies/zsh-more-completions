#compdef show-coords
# Documentation: https://manpages.debian.org/testing/mummer/show-coords.1.en.html
# MUMmer utility to parse delta alignment output into coordinate table

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-b[merge overlapping alignments without identity information]' \
  '-B[switch output to btab format]' \
  '-c[include percent coverage information]' \
  '-d[display alignment direction in FRM columns]' \
  '-g[deprecated; use delta-filter instead]' \
  '-H[do not print the output header]' \
  '-I+[set minimum percent identity to display]:identity' \
  '-k[filter cross-frame overlapping alignments (promer only)]' \
  '-l[include sequence length information]' \
  '-L+[set minimum alignment length to display]:length' \
  '-o[annotate maximal alignments between two sequences]' \
  '-q[sort output lines by query IDs and coordinates]' \
  '-r[sort output lines by reference IDs and coordinates]' \
  '-T[switch output to tab-delimited format]' \
  ':delta file:_files -g "*.delta"' && ret=0

return ret
