#compdef mermaid

# Zsh completion for mermaid - alias for mmdc (Mermaid CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-i+[input file]:input:_files -g "*.{mmd,md,mermaid}"' \
  '--input=[input file]:input:_files -g "*.{mmd,md,mermaid}"' \
  '-o+[output file]:output:_files -g "*.{svg,png,pdf}"' \
  '--output=[output file]:output:_files -g "*.{svg,png,pdf}"' \
  '-e+[output format]:format:(svg png pdf)' \
  '--outputFormat=[output format]:format:(svg png pdf)' \
  '-t+[theme]:theme:(default forest dark neutral)' \
  '--theme=[theme]:theme:(default forest dark neutral)' \
  '-b+[background color]:color' \
  '--backgroundColor=[background color]:color' \
  '-c+[config file]:config:_files -g "*.json"' \
  '--configFile=[config file]:config:_files -g "*.json"' \
  '-w+[width]:width' \
  '--width=[width]:width' \
  '-H+[height]:height' \
  '--height=[height]:height' \
  '-s+[scale factor]:scale' \
  '--scale=[scale factor]:scale' \
  '-q[suppress log output]' \
  '--quiet[suppress log output]' \
  '-p+[puppeteer config file]:config:_files -g "*.json"' \
  '--puppeteerConfigFile=[puppeteer config file]:config:_files -g "*.json"' \
  '*:input file:_files -g "*.{mmd,md,mermaid}"' && ret=0

return ret
