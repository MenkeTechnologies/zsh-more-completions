#compdef ashuffle
# Documentation: https://github.com/joshkunz/ashuffle/blob/master/readme.md
# automatic library-wide shuffle for mpd

local ret=1

_arguments -s -S \
  '(-h --help -?)'{-h,--help}'[display help message]' \
  '--by-album[equivalent to --group-by album date]' \
  '*'{-e,--exclude}'[exclude items from shuffle]:pattern' \
  '--exclude-from[read exclude rules from YAML file]:file:_files' \
  '(-f --file)'{-f,--file}'[use MPD URIs from file instead of library]:file:_files' \
  '*'{-g,--group-by}'[shuffle songs grouped by tags]:tag' \
  '--host[connect to specified host]:host:_hosts' \
  '--log-file[write log output to file]:file:_files' \
  '(-n --no-check)'{-n,--no-check}'[skip URI filtering when reading from file]' \
  '(-o --only)'{-o,--only}'[add NUMBER songs and exit]:number' \
  '(-p --port)'{-p,--port}'[connect to specified port]:port:_ports' \
  '(-q --queue-buffer)'{-q,--queue-buffer}'[maintain buffer of n songs after current]:number' \
  '*'{-t,--tweak}'[configure specialized options]:key=value' \
  '(-v --version)'{-v,--version}'[print version and exit]' && ret=0

return ret
