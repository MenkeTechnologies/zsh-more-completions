#compdef mlton mlton-lpw mlnlffigen
# Documentation: https://man.archlinux.org/search?q=mlton
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (mlton|mlton-lpw)
    _arguments -C \
      '(- *)-help[show help]' \
      '-version[show version]' \
      '-output+[output file]:file:_files' \
      '-format+[output format]:fmt:(executable archive library libarchive)' \
      '-stop+[stop after]:phase:(f tc cc ds o oc o2)' \
      '-codegen+[code generator]:cg:(amd64 c llvm x86)' \
      '-cc-opt+[CC option]:opt:' \
      '*-cc-opt-quote+[CC quoted option]:opt:' \
      '-link-opt+[linker option]:opt:' \
      '*-link-opt-quote+[linker quoted option]:opt:' \
      '-as-opt+[assembler option]:opt:' \
      '*-as-opt-quote+[as quoted option]:opt:' \
      '-target+[cross-compile target]:t:(self amd64-linux x86-linux amd64-darwin x86-darwin amd64-freebsd amd64-mingw)' \
      '-default-ann+[default annotation]:ann:' \
      '-default-type+[default type]:t:' \
      '-disable-ann+[disable annotation]:ann:' \
      '-mlb-path-var+[mlb path var]:var:' \
      '-mlb-path-map+[mlb path map file]:file:_files' \
      '*-keep+[keep intermediate]:k:(ast core-ml ssa ssa2 rssa machine c o asm dot dotpost)' \
      '-debug+[debug]:b:(true false)' \
      '-detect-overflow+[overflow detect]:b:(true false)' \
      '-default-language+[default lang]:l:' \
      '-export-header+[export header]:file:_files' \
      '-globalize-arrays+[globalize arrays]:b:(true false)' \
      '-globalize-refs+[globalize refs]:b:(true false)' \
      '-inline+[inline]:n:' \
      '-link-opt+[linker opt]:opt:' \
      '-loop-passes+[loop passes]:n:' \
      '-mlb-runtime-args+[mlb runtime args]:args:' \
      '-native-commented+[commented assembly]:n:' \
      '-native-copy-prop+[copy prop]:b:(true false)' \
      '-native-cutoff+[native cutoff]:n:' \
      '-optimization-passes+[opt passes]:passes:' \
      '-output-arch+[output arch]:a:' \
      '-polyvariance+[polyvariance]:n:' \
      '-prefer-abs-paths+[abs paths]:b:(true false)' \
      '-profile+[profile]:p:(no alloc count time)' \
      '-profile-branch+[profile branch]:b:(true false)' \
      '-profile-stack+[profile stack]:b:(true false)' \
      '-profile-val+[profile val]:b:(true false)' \
      '-runtime+[runtime args]:args:' \
      '-show-anns[show annotations]' \
      '-show-basis+[show basis]:file:_files' \
      '-show-def-use+[show def-use]:file:_files' \
      '-stop-syntax[stop after syntax]' \
      '-verbose+[verbosity]:n:(0 1 2 3)' \
      '-warn-ann+[warn annotation]:b:(true false)' \
      '-warn-deprecated+[warn deprecated]:b:(true false)' \
      '-warn-match+[warn match]:b:(true false)' \
      '-warn-unused+[warn unused]:b:(true false)' \
      '*: :_files -g "*.sml *.fun *.sig *.mlb *.cm"' && ret=0 ;;
  (mlnlffigen)
    _arguments -C \
      '-help[help]' \
      '-version[version]' \
      '-dir+[output dir]:dir:_files -/' \
      '-allSU[all structs/unions]' \
      '-cppopt+[cpp option]:opt:' \
      '-cppfilt+[cpp filter]:filt:' \
      '*: :_files -g "*.h"' && ret=0 ;;
esac

return ret
