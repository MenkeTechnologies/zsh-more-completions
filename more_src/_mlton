#compdef mlton mlton-lpw mlnlffigen
# Documentation: http://mlton.org/RunningMLton
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (mlton|mlton-lpw)
    _arguments -C \
      '-align+[alignment]:n:' \
      '-as-opt+[assembler option]:opt:' \
      '-cc+[C compiler]:cc:' \
      '-cc-opt+[CC option]:opt:' \
      '-codegen+[code generator]:cg:(native x86 amd64 c llvm)' \
      '-const+[set constant]:name value:' \
      '-default-ann+[default annotation]:ann:' \
      '-default-type+[default type]:t:' \
      '-disable-ann+[disable annotation]:ann:' \
      '-export-header+[export C header]:file:_files' \
      '-ieee-fp+[IEEE floating point]:b:(false true)' \
      '-inline+[inline limit]:n:' \
      '*-keep+[keep intermediate]:k:(g o)' \
      '-link-opt+[linker option]:opt:' \
      '-llvm-as+[llvm-as command]:cmd:' \
      '-llvm-as-opt+[llvm-as option]:opt:' \
      '-llvm-llc+[llvm llc command]:cmd:' \
      '-llvm-llc-opt+[llvm llc option]:opt:' \
      '-llvm-opt+[llvm opt command]:cmd:' \
      '-llvm-opt-opt+[llvm opt option]:opt:' \
      '-mlb-path-map+[mlb path map file]:file:_files' \
      '-mlb-path-var+[mlb path var]:name value:' \
      '-output+[output file]:file:_files' \
      '-profile+[profile]:p:(no alloc count time)' \
      '-profile-branch+[profile branch]:b:(false true)' \
      '-profile-stack+[profile stack]:b:(false true)' \
      '-profile-val+[profile val]:b:(false true)' \
      '-runtime+[runtime arg]:arg:' \
      '-show-basis+[show basis]:file:_files' \
      '-show-def-use+[show def-use]:file:_files' \
      '-stop+[stop after]:s:(f g o tc)' \
      '-target+[cross-compile target]:t:' \
      '-target-as-opt+[target as option]:target option:' \
      '-target-cc-opt+[target cc option]:target option:' \
      '-target-link-opt+[target link option]:target option:' \
      '-verbose+[verbosity]:n:(0 1 2 3)' \
      '*: :_files -g "*.sml *.fun *.sig *.mlb *.cm"' && ret=0 ;;
  (mlnlffigen)
    _arguments -C \
      '*: :_files -g "*.h"' && ret=0 ;;
esac

return ret
