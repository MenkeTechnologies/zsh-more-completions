#compdef suresstat
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/suresstat.c
# surface consistent source and receiver statics calculation

local ret=1

_arguments -s -S \
  'ssol=[output file source statics]:file:_files' \
  'rsol=[output file receiver statics]:file:_files' \
  'ntraces=[number of traces in input data set]:ntraces' \
  'ntpick=[maximum static shift (samples)]:ntpick' \
  'niter=[number of iterations]:niter' \
  'nshot=[largest shot number]:nshot' \
  'nr=[largest receiver number]:nr' \
  'nc=[maximum number of cmps]:nc' \
  'sfold=[maximum shot gather fold]:sfold' \
  'rfold=[maximum receiver gather fold]:rfold' \
  'cfold=[maximum cmp gather fold]:cfold' \
  'sub=[subtract super trace 1 from super trace 2]:sub' \
  'mode=[cross-correlation window mode]:mode' \
  'perc=[percent of global max (mode=1)]:perc' \
  'verbose=[print diagnostic output]:verbose' \
  '*:file:_files' && ret=0


return ret
