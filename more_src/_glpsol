#compdef glpsol
# Documentation: https://en.wikibooks.org/wiki/GLPK/Using_GLPSOL
# GLPK standalone LP/MIP solver

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '--mps[read problem in fixed MPS format]' \
  '--freemps[read problem in free MPS format]' \
  '--lp[read problem in CPLEX LP format]' \
  '--glp[read problem in GLPK format]' \
  '--math[read model in GNU MathProg language]' \
  '(-m --model)'{-m,--model}'[read model section from file]:file:_files' \
  '(-d --data)'{-d,--data}'[read data section from file]:file:_files' \
  '--simplex[use simplex method (default)]' \
  '--interior[use interior point method (LP only)]' \
  '--primal[use primal simplex (default)]' \
  '--dual[use dual simplex]' \
  '--min[minimization]' \
  '--max[maximization]' \
  '(-o --output)'{-o,--output}'[write solution in printable format]:file:_files' \
  '(-w --write)'{-w,--write}'[write solution in plain text format]:file:_files' \
  '--ranges[write sensitivity analysis report]:file:_files' \
  '(-y --display)'{-y,--display}'[send display output to file]:file:_files' \
  '--scale[scale problem (default)]' \
  '--noscale[do not scale problem]' \
  '--nomip[treat integers as continuous]' \
  '--tmlim[limit solution time in seconds]:seconds' \
  '--memlim[limit available memory in megabytes]:megabytes' \
  '--wmps[write problem in fixed MPS format]:file:_files' \
  '--wfreemps[write problem in free MPS format]:file:_files' \
  '--wlp[write problem in CPLEX LP format]:file:_files' \
  '--wglp[write problem in GLPK format]:file:_files' \
  '--check[validate input without solving]' \
  '--first[branch on first integer variable]' \
  '--last[branch on last integer variable]' \
  '--mostf[branch on most fractional variable]' \
  '--drtom[Driebeck-Tomlin heuristic (default)]' \
  '--pcost[hybrid pseudocost heuristic]' \
  '--cuts[generate all cuts]' \
  '--gomory[generate Gomory cuts]' \
  '--mir[generate mixed integer rounding cuts]' \
  '--cover[generate mixed cover cuts]' \
  '--clique[generate clique cuts]' \
  '--intopt[use MIP presolver (default)]' \
  '--nointopt[disable MIP presolver]' \
  '--mipgap[set relative MIP gap tolerance]:gap' \
  '--fpump[apply feasibility pump heuristic]' \
  '--seed[initialize random number generator]:seed' \
  '*:file:_files' && ret=0

return ret
