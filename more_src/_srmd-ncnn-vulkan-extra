#compdef srmd-ncnn-vulkan-extra
# Documentation: https://github.com/nihui/srmd-ncnn-vulkan
# SRMD ncnn Vulkan image upscaler/denoiser (extra-models fork)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-i+[input image path or directory]:input:_files' \
  '-o+[output image path or directory]:output:_files' \
  '-n+[denoise level (-1..10, default=3)]:noise' \
  '-s+[upscale ratio (2/3/4, default=2)]:scale:(2 3 4)' \
  '-t+[tile size (>=32/0=auto)]:tile size' \
  '-m+[srmd model path]:model dir:_files -/' \
  '-g+[gpu device to use (default=0)]:gpu id' \
  '-j+[thread count for load:proc:save]:threads' \
  '-x[enable tta mode]' \
  '-f+[output image format]:format:(jpg png webp)' && ret=0

return ret
