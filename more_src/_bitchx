#compdef BitchX bitchx
# _bitchx — BitchX IRC client (ircii fork); terminal-based IRC client with extensive scripting (BitchX-script, Tcl)
# upstream: https://github.com/JakeXKS/BitchX

_bitchx() {
    _arguments \
        '-a[disable autoconnect]' \
        '-A[disable colors]' \
        '-b[load .bitchxrc only]' \
        '-B[don'\''t load any rc]' \
        '-c+[autojoin channel]:channel:' \
        '-d[dumb mode]' \
        '-D[debug]' \
        '-f[no flow control]' \
        '-F[use flow control]' \
        '-H+[hostname for VHOST]:host:_hosts' \
        '-i+[ircname]:realname:' \
        '-l+[load script]:file:_files' \
        '-n+[nickname]:nick:' \
        '-N[no auto-rejoin]' \
        '-o[no auto-op]' \
        '-O+[server options]:opts:' \
        '-p+[port]:port:' \
        '-P[print version and exit]' \
        '-q[no .ircrc]' \
        '-r+[reject ircservers]:list:' \
        '-R[no remote sessions]' \
        '-S[autoconnect with SSL]' \
        '-t+[set TERM type]:term:' \
        '-v[show version]' \
        '-x[XECHO debug]' \
        '*:nickname:'
}

_bitchx "$@"
