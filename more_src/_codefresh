#compdef codefresh cf
# Documentation: https://man.archlinux.org/search?q=codefresh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:manage authentication contexts'
  'config:configure CLI defaults'
  'create:create a resource from file/stdin'
  'replace:replace a resource by filename'
  'patch:patch a resource by filename or stdin'
  'delete:delete a resource'
  'get:get one or many resources'
  'annotate:annotate a resource with labels'
  'run:run a pipeline by id or name'
  'logs:show logs for a build'
  'restart:restart a build'
  'terminate:terminate a build'
  'wait:wait until a build reaches a condition'
  'install:install a Codefresh runner / agent'
  'runner:manage Codefresh runners'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cfconfig=[Codefresh config path]:file:_files' \
  '--api-key=[Codefresh API key]:key:' \
  '--auth-context=[auth context name]:context:' \
  '--debug[enable debug logging]' \
  '--insecure[skip TLS verification]' \
  '--output=[output format]:format:(json yaml table)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'codefresh command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-b --branch)'{-b+,--branch=}'[branch to run]:branch:' \
          '(-t --trigger)'{-t+,--trigger=}'[trigger name]:trigger:' \
          '(-r --revision)'{-r+,--revision=}'[git revision]:rev:' \
          '*-v[set variable key=value]:var:' \
          '*--variable=[set variable key=value]:var:' \
          '--variables-file=[YAML/JSON variables file]:file:_files' \
          '--detach[do not attach logs]' \
          '--enable-notifications[enable notifications]' \
          '--no-cache[disable cache]' \
          '--no-cf-cache[disable Codefresh cache]' \
          '--reset-volume[reset workflow volume]' \
          '--context=[git context]:context:' \
          '--annotation=[annotation key=value]:annotation:' \
          '*::pipeline_name:' && ret=0 ;;
      (logs|restart|terminate|wait)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow logs]' \
          '*::build_id:' && ret=0 ;;
      (auth)
        _arguments '*::sub:(create-context get-context use-context current-context list-contexts delete-context)' && ret=0 ;;
      (get|delete|create|replace|patch|annotate)
        local -a resources=(
          'pipeline:Codefresh pipeline'
          'project:Codefresh project'
          'context:integration context'
          'image:image'
          'build:build'
          'team:team'
          'permission:permission'
          'user:user'
          'account:account'
          'agent:Codefresh agent'
          'runtime-environment:runtime environment'
          'cluster:Kubernetes cluster'
          'helm-repos:Helm repository'
          'workflow:workflow'
          'environment:environment'
          'workflow-template:workflow template'
        )
        _describe -t res 'resource' resources && ret=0 ;;
      (runner)
        _arguments '*::sub:(install upgrade list status uninstall)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
