#compdef cstranslate
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# cstranslate: translate an alignment/sequence into an abstract state sequence or profile

local ret=1

_arguments -s -S \
  '(-i --infile)'{-i,--infile}'+[input file with alignment or sequence]:file:_files' \
  '(-o --outfile)'{-o,--outfile}'+[output file for abstract state sequence]:file:_files' \
  '(-a --append)'{-a,--append}'+[append abstract state sequence to this file]:file:_files' \
  '(-I --informat)'{-I,--informat}'+[input format]:format:(prf seq fas a2m a3m ca3m)' \
  '(-O --outformat)'{-O,--outformat}'+[output format]:format:(seq prf)' \
  '(-M --match-assign)'{-M,--match-assign}'+[make FASTA columns with fewer than X%% gaps match columns]:int' \
  '(-A --alphabet)'{-A,--alphabet}'+[abstract state alphabet file with 219 states]:file:_files' \
  '(-D --context-data)'{-D,--context-data}'+[add context-specific pseudocounts using context-data]:file:_files' \
  '(-x --pc-admix)'{-x,--pc-admix}'+[pseudocount admix for context-specific pseudocounts]:num' \
  '(-c --pc-ali)'{-c,--pc-ali}'+[constant in pseudocount calculation for alignments]:num' \
  '(-w --weight)'{-w,--weight}'+[weight of abstract state column in emission calculation]:num' \
  '(-f --ffindex)'{-f,--ffindex}'[read/write ffindex; enables openmp if possible]' \
  '(-v --verbose)'{-v,--verbose}'+[verbose mode]:level' && ret=0

return ret
