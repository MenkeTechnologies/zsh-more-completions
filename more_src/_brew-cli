#compdef brew-cli
# _brew-cli — Homebrew macOS/Linux package manager CLI alias (Mike McQuaid / Homebrew team, Ruby); custom argparse
# upstream: https://github.com/Homebrew/brew

_brew-cli() {
    local -a sub=(
        'analytics:control analytics'
        'autoremove:remove packages no longer needed'
        'caveats:show caveats'
        'cleanup:remove old downloads'
        'commands:list installed commands'
        'completions:configure completions'
        'config:show config'
        'deps:show dependencies'
        'desc:show short descriptions'
        'developer:show developer mode'
        'doctor:diagnose installation'
        'fetch:download a formula'
        'formulae:list installable formulae'
        'gist-logs:upload logs as gist'
        'home:open homepage'
        'info:show info'
        'install:install packages'
        'leaves:list installed formulae not deps of anything else'
        'link:symlink installed formula files'
        'list:list installed formulae'
        'log:show formula commit history'
        'migrate:migrate formulae'
        'options:list options'
        'outdated:list outdated formulae'
        'pin:pin a formula'
        'postinstall:rerun postinstall'
        'reinstall:reinstall a formula'
        'search:search formulae'
        'shellenv:print env var setup'
        'tap:tap a repository'
        'tap-info:show tap info'
        'taps:list tapped repositories'
        'uninstall:uninstall formulae'
        'unlink:unlink installed formula files'
        'unpin:unpin a formula'
        'untap:untap a repository'
        'update:update Homebrew'
        'update-reset:reset homebrew state'
        'upgrade:upgrade installed formulae'
        'uses:show formulae that depend on package'
        'vendor-install:install ruby vendor'
        'cask:Homebrew cask subcommand'
        'services:Homebrew services subcommand'
        'bundle:Homebrew bundle subcommand'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brew subcommand' sub ;;
        args)
            case $words[1] in
                install|reinstall|upgrade|uninstall|info|outdated|search|deps|uses|fetch|home|log|options|pin|unpin|link|unlink|leaves|caveats|desc) _arguments \
                    '--cask[cask]' \
                    '--formula[formula]' \
                    '--HEAD[HEAD]' \
                    '--build-from-source[build from source]' \
                    '-s[build from source]' \
                    '--force-bottle[force bottle]' \
                    '--keep-tmp[keep tmp]' \
                    '--debug-symbols[debug symbols]' \
                    '--ignore-dependencies[ignore deps]' \
                    '--only-dependencies[only deps]' \
                    '--cc=+[CC]:c:(clang gcc)' \
                    '*:formula:' ;;
                services) _arguments \
                    '1:cmd:(list run start stop restart cleanup info)' \
                    '*:formula:' ;;
                cask) _arguments \
                    '1:cmd:(install reinstall uninstall info list outdated upgrade fetch deps doctor home audit edit)' \
                    '*:cask:' ;;
                bundle) _arguments \
                    '1:cmd:(install dump cleanup check list)' \
                    '*:arg:' ;;
                tap|untap) _arguments '*:tap:' ;;
                completions) _arguments '*:cmd:(state link unlink)' ;;
            esac
            ;;
    esac
}

_brew-cli "$@"
