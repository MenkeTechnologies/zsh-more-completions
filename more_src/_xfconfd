#compdef xfconfd
# Documentation: https://gitlab.xfce.org/xfce/xfconf/-/blob/master/xfconfd/main.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: fabricated --no-daemon, --replace, -h, --help (none in upstream
# source GOptionEntry array). GLib provides --help automatically.
# Added: -V/--version, -b/--backends, --daemon (from upstream source).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-V,--version}'[print xfconfd version]' \
  '*'{-b+,--backends=}'[configuration backends to use]:backend:' \
  '--daemon[fork into background after starting (test use)]' \
  '--help[show help]' && ret=0

return ret
