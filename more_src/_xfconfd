#compdef xfconfd
# Documentation: https://man.archlinux.org/search?q=xfconfd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-daemon[do not fork]' \
  '--replace[replace running instance]' && ret=0

return ret
