#compdef vcsh

# Zsh completion for vcsh (version control system for $HOME)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'clone:clone a repository'
  'commit:commit changes in a repository'
  'delete:delete a repository'
  'enter:enter a repository shell'
  'foreach:run a command for every repository'
  'help:show help'
  'init:initialize a new repository'
  'list:list all repositories'
  'list-tracked:list tracked files'
  'list-untracked:list untracked files'
  'pull:pull from all repositories'
  'push:push to all repositories'
  'rename:rename a repository'
  'run:run a command in repository context'
  'status:show status of all repositories'
  'upgrade:upgrade a repository'
  'version:show version'
  'which:show which repository tracks a file'
  'write-gitignore:write .gitignore files'
)

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '1:subcommand:->subcommand' \
  '*::args:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vcsh subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (clone)
        _arguments \
          '-b[branch to clone]:branch:' \
          '1:URL:' \
          '2:repository name:' && ret=0
        ;;
      (commit)
        _arguments \
          '1:repository name:->repos' && ret=0
        ;;
      (delete|enter|upgrade|write-gitignore)
        _arguments \
          '1:repository name:->repos' && ret=0
        ;;
      (init)
        _arguments \
          '1:repository name:' && ret=0
        ;;
      (list-tracked|status)
        _arguments \
          '1::repository name:->repos' && ret=0
        ;;
      (list-untracked)
        _arguments \
          '-a[show all untracked files]' \
          '-r[recursive]' \
          '1::repository name:->repos' && ret=0
        ;;
      (rename)
        _arguments \
          '1:old repository name:->repos' \
          '2:new repository name:' && ret=0
        ;;
      (run)
        _arguments \
          '1:repository name:->repos' \
          '*:command:_command_names' && ret=0
        ;;
      (which)
        _arguments \
          '1:file:_files' && ret=0
        ;;
      (foreach)
        _arguments \
          '*:git command:' && ret=0
        ;;
      (help)
        _arguments '1:subcommand:->subcommand_help' && ret=0
        case $state in
          (subcommand_help)
            _describe -t subcommands 'vcsh subcommand' subcommands && ret=0
            ;;
        esac
        ;;
    esac

    case $state in
      (repos)
        local -a repos
        repos=( ${(f)"$(vcsh list 2>/dev/null)"} )
        _describe -t repositories 'repository' repos && ret=0
        ;;
    esac
    ;;
esac

return ret
