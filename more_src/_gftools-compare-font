#compdef gftools-compare-font
# Documentation: https://github.com/googlefonts/gftools
# Compare two font files (table sizes and coverage)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--nodiff_tables[do not print table size diffs]' \
  '--nodiff_coverage[do not print coverage diffs]' \
  '1:first font:_files -g "*.(ttf|otf|TTF|OTF)"' \
  '2:second font:_files -g "*.(ttf|otf|TTF|OTF)"' && ret=0

return ret
