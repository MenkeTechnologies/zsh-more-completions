#compdef presto
# Documentation: https://prestodb.io/docs/current/clients/presto-cli.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--server=[Presto server location]:url:' \
  '--catalog=[default catalog]:catalog:' \
  '--schema=[default schema]:schema:' \
  '--user=[username for authentication]:user:' \
  '--source=[name of source making query]:source:' \
  '--client-info=[extra client information]:info:' \
  '--client-request-timeout=[client request timeout]:timeout:' \
  '--client-tags=[client tags]:tags:' \
  '--debug[enable debug information]' \
  '--runtime-stats[enable runtime statistics (requires --debug)]' \
  '--execute=[execute statements and exit]:query:' \
  '(-f --file)'{-f+,--file=}'[execute statements from file]:file:_files' \
  '--output-format=[output format]:format:(ALIGNED VERTICAL TSV TSV_HEADER CSV CSV_HEADER CSV_UNQUOTED CSV_HEADER_UNQUOTED JSON NULL)' \
  '*--resource-estimate=[resource estimate]:estimate:' \
  '*--session=[session property]:property=value:' \
  '*--extra-credential=[extra credential]:credential:' \
  '--keystore-path=[path to keystore]:path:_files' \
  '--keystore-password=[keystore password]:password:' \
  '--keystore-type=[keystore type]:type:' \
  '--truststore-path=[path to truststore]:path:_files' \
  '--truststore-password=[truststore password]:password:' \
  '--truststore-type=[truststore type]:type:' \
  '--access-token=[access token for authentication]:token:' \
  '--log-levels-file=[log levels configuration file]:file:_files' \
  '--password[prompt for password]' \
  '--insecure[skip HTTP server certificate validation]' \
  '--socks-proxy=[SOCKS proxy]:host\:port:' \
  '--http-proxy=[HTTP proxy]:host\:port:' \
  '--krb5-config-path=[Kerberos config path]:path:_files' \
  '--krb5-keytab-path=[Kerberos keytab path]:path:_files' \
  '--krb5-principal=[Kerberos principal]:principal:' \
  '--krb5-credential-cache-path=[Kerberos credential cache path]:path:_files' \
  '--krb5-remote-service-name=[Kerberos remote service name]:name:' \
  '--krb5-disable-remote-service-hostname-canonicalization[disable Kerberos DNS reverse lookup]' \
  '--disable-compression[disable compression of query results]' \
  '--disable-redirects[disable following server redirects]' \
  '--ignore-errors[continue on errors in batch mode]' \
  '--validate-nexturi-source[validate server host/port consistency]' \
  '*:file:_files' && ret=0

return ret
