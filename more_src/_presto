#compdef presto

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--server[Presto server location]:url' \
  '--catalog[default catalog]:catalog' \
  '--schema[default schema]:schema' \
  '--user[username for authentication]:user' \
  '--source[name of source making query]:source' \
  '--client-request-timeout[client request timeout]:timeout' \
  '--client-tags[client tags]:tags' \
  '--debug[enable debug logging]' \
  '(-f --execute)'{-f,--execute}'[execute a query and exit]:query' \
  '--output-format[output format]:format:(ALIGNED VERTICAL TSV TSV_HEADER CSV CSV_HEADER CSV_UNQUOTED CSV_HEADER_UNQUOTED JSON NULL)' \
  '--resource-estimate[resource estimate]:estimate' \
  '*--session[session property]:property=value' \
  '*--extra-credential[extra credential]:credential' \
  '--keystore-path[path to keystore]:path:_files' \
  '--keystore-password[keystore password]:password' \
  '--truststore-path[path to truststore]:path:_files' \
  '--truststore-password[truststore password]:password' \
  '--access-token[access token for authentication]:token' \
  '--log-levels-file[log levels configuration file]:file:_files' \
  '--password[prompt for password]' \
  '--socksProxy[SOCKS proxy]:host\:port' \
  '--httpProxy[HTTP proxy]:host\:port' \
  '--timezone[session timezone]:timezone' \
  '--disable-compression[disable compression of query results]' \
  '*:file:_files' && ret=0

return ret
