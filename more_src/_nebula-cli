#compdef nebula-cli nebula nebula-cert
# _nebula-cli — Slack Nebula scalable overlay networking CLI alias (slackhq team, Go); custom argparse
# upstream: https://github.com/slackhq/nebula

_nebula-cli() {
    local -a sub=(
        'ca:create CA cert and key'
        'keygen:generate keypair'
        'sign:sign a cert'
        'print:print a cert'
        'verify:verify a cert'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '-version[show version]' \
        '-config=+[config file]:file:_files -g "config.{yaml,yml}"' \
        '-test[test config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nebula subcommand' sub ;;
        args)
            case $words[1] in
                ca) _arguments \
                    '-name=+[name]:str:' \
                    '-out-crt=+[output cert]:file:_files' \
                    '-out-key=+[output key]:file:_files' \
                    '-duration=+[duration]:str:' \
                    '-groups=+[groups csv]:str:' \
                    '-ips=+[ips csv]:str:' \
                    '-subnets=+[subnets csv]:str:' \
                    '-out-qr=+[qr png]:file:_files' ;;
                sign) _arguments \
                    '-ca-crt=+[ca cert]:file:_files' \
                    '-ca-key=+[ca key]:file:_files' \
                    '-name=+[name]:str:' \
                    '-ip=+[ip]:str:' \
                    '-subnets=+[subnets csv]:str:' \
                    '-groups=+[groups csv]:str:' \
                    '-in-pub=+[input pubkey]:file:_files' \
                    '-out-crt=+[output cert]:file:_files' \
                    '-out-key=+[output key]:file:_files' \
                    '-duration=+[duration]:str:' \
                    '-out-qr=+[qr png]:file:_files' ;;
                print|verify) _arguments \
                    '-path=+[cert path]:file:_files' \
                    '-out-qr=+[qr png]:file:_files' \
                    '-json[json output]' ;;
                keygen) _arguments \
                    '-out-pub=+[output pubkey]:file:_files' \
                    '-out-key=+[output key]:file:_files' \
                    '-curve=+[curve]:c:(25519 P256)' ;;
            esac
            ;;
    esac
}

_nebula-cli "$@"
