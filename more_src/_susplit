#compdef susplit
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/susplit.c
# split traces into different output files by keyword value

local ret=1

_arguments -s -S \
  'key=[key header word to split on]:key' \
  'stem=[stem name for output files]:stem' \
  'middle=[middle of name of output files]:middle' \
  'suffix=[suffix for output files]:suffix' \
  'numlength=[length of numeric part of filename]:numlength' \
  'verbose=[=1 to echo filenames]:verbose' \
  'close=[=1 to close files before opening new ones]:close' \
  '*:file:_files' && ret=0


return ret
