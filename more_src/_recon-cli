#compdef recon-cli
# Documentation: https://man.archlinux.org/search?q=recon-cli
# Reference accessed: 2026-05-23
# Verified: recon-ng recon-cli flags (man.archlinux.org recon-cli).

# Zsh completion for recon-cli - recon-ng workspace CLI

local curcontext="$curcontext" state line ret=1
local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-v,--version}'[show programs version number and exit]'
  '-w[load/create a workspace]'
  '-C[runs a command at the global context]'
  '-c[runs a command at the module context (pre-run)]'
  '-G[show available global options]'
  '-g[value set a global option (can be used more than once)]'
  '-M[show modules]'
  '-m[specify the module]'
  '-O[show available module options]'
  '-o[value set a module option (can be used more than once)]'
  '-x[run the module]'
  '--no-check[disable version check]'
  '*:filename:_files'
)

_arguments -s -S $arguments
