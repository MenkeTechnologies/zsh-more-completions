_tst() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tst_commands" \
"*::: :->tst" \
&& ret=0
    case $state in
    (tst)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tst-command-$line[1]:"
        case $line[1] in
            (next)
_arguments "${_arguments_options[@]}" : \
'-c+[Number of results to return]:COUNT:_default' \
'--count=[Number of results to return]:COUNT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':from -- Starting station:_default' \
':to -- Destination station:_default' \
&& ret=0
;;
(arrivals)
_arguments "${_arguments_options[@]}" : \
'-c+[Number of results to return]:COUNT:_default' \
'--count=[Number of results to return]:COUNT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':station -- Station name:_default' \
&& ret=0
;;
(train)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':number -- Train number:_default' \
&& ret=0
;;
(stations)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(extra)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_tst__extra_commands" \
"*::: :->extra" \
&& ret=0

    case $state in
    (extra)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tst-extra-command-$line[1]:"
        case $line[1] in
            (schedule)
_arguments "${_arguments_options[@]}" : \
'--inbound[Trains going inbound]' \
'--outbound[Trains going outbound]' \
'--weekday[Weekday trains]' \
'--weekend[Weekend trains]' \
'-h[Print help]' \
'--help[Print help]' \
':line -- The Regional Rail Line Code (e.g, TRE):_default' \
':orig -- Starting Station (e.g, Trenton):_default' \
':dest -- Ending Station (e.g, Gray 30th Street):_default' \
&& ret=0
;;
(lines)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(stations)
_arguments "${_arguments_options[@]}" : \
'--inbound[Trains going inbound]' \
'--outbound[Trains going outbound]' \
'-h[Print help]' \
'--help[Print help]' \
':line -- The Regional Rail Line Code (e.g, TRE):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tst__extra__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tst-extra-help-command-$line[1]:"
        case $line[1] in
            (schedule)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(lines)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stations)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tst__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tst-help-command-$line[1]:"
        case $line[1] in
            (next)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(arrivals)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(train)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stations)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(extra)
_arguments "${_arguments_options[@]}" : \
":: :_tst__help__extra_commands" \
"*::: :->extra" \
&& ret=0

    case $state in
    (extra)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tst-help-extra-command-$line[1]:"
        case $line[1] in
            (schedule)
_arguments "${_arguments_options[@]}" : \
