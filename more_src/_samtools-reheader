#compdef samtools-reheader
# Documentation: http://www.htslib.org/doc/samtools-reheader.html
# samtools reheader: Replace the header in a coordinate-sorted BAM file

local ret=1

_arguments -s -S \
  '(-P --no-PG)'{-P,--no-PG}'[Do not add a @PG line to the header of the output file.]' \
  '(-i --in-place)'{-i,--in-place}'[Perform the header edit in-place, if possible. This only works on CRAM]' \
  '(-c --command)'{-c,--command}'[Allow the header from in.bam to be processed by external CMD and read]:CMD: ' \
  '*:file:_files' && ret=0

return ret
