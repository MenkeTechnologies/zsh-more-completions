#compdef twelf-server twelf-sml twelf
# Documentation: https://man.archlinux.org/search?q=twelf-server
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-version[show version]' \
  '*: :_files -g "*.elf *.thy *.cfg"' && ret=0

return ret
