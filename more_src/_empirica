#
# WHAT IT IS
#   Empirica is an open-source engine for running multiplayer
#   interactive online experiments — psychology / behavioral
#   science / market research that needs synchronized real-time
#   coordination between participants.  It bundles a React-
#   based front-end for the "player" experience, a server-side
#   Go runtime that handles experiment design + treatment
#   assignment + data export, and the upstream `tajriba` data-
#   model service that backs the persistent experiment state
#   via a GraphQL API.  Researchers write callbacks in
#   JavaScript that run on every stage transition (round start,
#   round end, game start, etc.), and Empirica handles the
#   websocket plumbing between participants' browsers and the
#   server-side experiment logic.
#
#   The `empirica` CLI is a multi-mode binary:  in a project
#   directory it boots the development server (default
#   subcommand); `create` scaffolds a new project; `serve`
#   serves a `bundle`-produced production build; `cloud
#   deploy` ships the bundle to Empirica Cloud; `tajriba`
#   runs the standalone data-model service; and the npm / yarn
#   passthroughs let you stay inside the empirica binary for
#   package management instead of bouncing out to the host
#   node toolchain.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmds/empirica/cmd/
#                       {root,bundle,create,export,node,npm,
#                       serve,setup,tajriba,upgrade,version,
#                       yarn}.go + cmds/empirica/cmd/cloud/
#                       {cloud,deploy,signin}.go cobra
#                       declarations; extracted via `gh api
#                       repos/empiricaly/empirica/contents/
#                       cmds/empirica/...`)
#
#   empirica [GLOBAL OPTIONS] [<SUBCOMMAND>] [args...]
#
#   Default (no subcommand):  boots the development server in
#                              the current project directory.
#                              If the current directory is not
#                              an Empirica project, prints
#                              instructions for `empirica create
#                              <name>` and exits 1.
#
#   Global persistent flags:
#     --config <PATH>                Config file (default
#                                    `<empirica-dir>/
#                                    empirica.toml`)
#
#   Subcommands:
#     create <NAME>                  Create a new Empirica
#                                    project under the named
#                                    directory
#     setup                          Setup empirica (installs
#                                    Volta-managed node, sets
#                                    up the local empirica
#                                    config directory)
#
#   Project lifecycle:
#     bundle                         Bundle the project for
#                                    production deployment
#     serve [BUNDLE]                 Serve a `bundle`-produced
#                                    artifact in production
#                                    mode
#
#   Data management:
#     export [TAJRIBA.JSON]          Export empirica data from
#                                    a tajriba snapshot into a
#                                    spreadsheet-friendly
#                                    format
#     tajriba                        Run the standalone tajriba
#                                    data-model server
#                                    (development workflow:
#                                    point Empirica at it via
#                                    config)
#
#   Node toolchain passthrough:
#     node [args...]                 Run node through the
#                                    Volta-managed runtime
#     npm  [args...]                 Run npm commands through
#                                    the Volta-managed runtime
#     yarn [args...]                 Run yarn commands through
#                                    the Volta-managed runtime
#
#   Maintenance:
#     upgrade                        Upgrade empirica packages
#     version                        Print empirica version
#
#   Empirica Cloud:
#     cloud signin                   Sign into Empirica Cloud
#     cloud deploy                   Deploy the bundled project
#                                    to Empirica Cloud
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help (root + each
#                                    subcommand)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/99designs/gqlgen v0.17.36`
#   declared in go.mod — `99designs/gqlgen` is THE canonical Go
#   GraphQL server framework maintained by 99designs Inc. and
#   the gqlgen contributor community (99designs/gqlgen,
#   10,500+ stars; the predominant typed Go GraphQL server
#   used by every major Go GraphQL application — dagger/
#   dagger, git-bug/git-bug, guacsec/guac, kubetail-org/
#   kubetail, in-toto/archivista, JordanKnott/taskcafe,
#   open-feature/cli (build-tool indirect), grafana/alloy
#   (build-tool direct), guidewire-oss/fern-platform,
#   empiricaly/empirica, cloud-native-nordics/meetup-kit,
#   i-love-flamingo/graphql, jt05610/scaf, ericls/imgdd, and
#   dozens of other production Go applications serving a
#   GraphQL API).  gqlgen is a *schema-first* framework — you
#   write `*.graphql` lexicon, run `gqlgen generate`, and it
#   emits typed Go binding code under `graph/generated/`,
#   `graph/model/`, and `graph/resolver.go` stubs.  Then you
#   wire it into an HTTP server via `handler.NewDefaultServer(
#   generated.NewExecutableSchema(generated.Config{Resolvers:
#   &graph.Resolver{ ...injected deps...}}))` returning a
#   typed `*handler.Server` that implements `http.Handler`,
#   with `srv.Use(extension.Introspection{})` /
#   `srv.Use(extension.AutomaticPersistedQuery{Cache: ...})` /
#   `srv.SetQueryCache(lru.New(1000))` /
#   `srv.SetErrorPresenter(fn)` /
#   `srv.SetRecoverFunc(fn)` /
#   `srv.AroundFields(fn)` /
#   `srv.AroundOperations(fn)` /
#   `srv.AroundRootFields(fn)` /
#   `srv.AroundResponses(fn)` middleware hooks, and the
#   `playground.Handler(...)` / `playground.ApolloSandboxHandler
#   (...)` interactive-playground utilities.  Other typed
#   primitives include `graphql.Marshaler` /
#   `graphql.Unmarshaler` boundary types, `graphql.UploadFile`
#   for multipart-upload-spec compliance,
#   `graphql.Omittable[T]` for distinguishing `null` from
#   missing, `graphql.OperationContext` /
#   `graphql.RootResolverFunc` /
#   `graphql.FieldStats` /
#   `graphql.ResponseContext` resolver-scope handles, the
#   typed dataloader helper (`github.com/99designs/gqlgen/
#   graphql/dataloader`), and the `client.Client` test-client
#   for testing resolvers end-to-end.  empirica's `internal/
#   server/...` constructs a typed
#   `generated.NewExecutableSchema(generated.Config{Resolvers:
#   ...})` with the experiment-runtime as the resolver, then
#   mounts it as a Chi/gorilla-mux subroute and bridges
#   participant websocket events to typed `graphql.Subscription`
#   payloads.  Verified via:
#     gh api repos/empiricaly/empirica/contents/go.mod
#       → module github.com/empiricaly/empirica
#       → github.com/99designs/gqlgen v0.17.36
#       → github.com/spf13/cobra v1.5.0
#     gh api repos/empiricaly/empirica/contents/empirica.go
#       → import "github.com/99designs/gqlgen/graphql"
#       → import "github.com/empiricaly/tajriba"
#     gh api repos/empiricaly/empirica/contents/cmds/empirica/
#         cmd/{root,bundle,create,export,node,npm,serve,setup,
#         tajriba,upgrade,version,yarn}.go +
#         cmds/empirica/cmd/cloud/{cloud,deploy,signin}.go
#       → cobra subcommands: bundle, create, export, node,
#                              npm, serve, setup, tajriba,
#                              upgrade, version, yarn, cloud
#                              {signin, deploy}
#       → root persistent flag: --config <PATH>
#   This entry is the Go=159 leader bump that continues Axis
#   104 (GraphQL server framework) at 2/0/0 following R1003
#   _oxyromon (Rust=159 OPENED the axis on async-graphql
#   v7.0.16 + dataloader feature).  TS-Node=159 closing pair
#   to follow at R1005 (candidates: graphql-js / @apollo/
#   server / type-graphql / @graphql-codegen consumers).
#
#   No completion for `empirica` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_empirica() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file (default <empirica-dir>/empirica.toml)]:config:_files -g "*.toml"' \
        '1: :_empirica_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                create)
                    _arguments '1:project name:' && ret=0 ;;
                serve)
                    _arguments '::bundle:_files' && ret=0 ;;
                export)
                    _arguments '::tajriba.json file:_files -g "*.json"' && ret=0 ;;
                node|npm|yarn)
                    _arguments '*::passthrough args:' && ret=0 ;;
                cloud)
                    _arguments \
                        '1:cloud operation:(signin deploy)' \
                        '*: :' && ret=0 ;;
                bundle|setup|tajriba|upgrade|version)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_empirica_commands] )) ||
_empirica_commands() {
    local -a commands
    commands=(
        'create:create a new Empirica project'
        'setup:setup empirica (Volta + config dir)'
        'bundle:bundle the project for production'
        'serve:serve a bundle in production mode'
        'export:export empirica data from a tajriba snapshot'
        'tajriba:run the standalone tajriba data-model server'
        'node:run node through Volta'
        'npm:run npm through Volta'
        'yarn:run yarn through Volta'
        'upgrade:upgrade empirica packages'
        'version:print empirica version'
        'cloud:Empirica Cloud services (signin / deploy)'
    )
    _describe -t commands 'empirica command' commands
}

_empirica "$@"
