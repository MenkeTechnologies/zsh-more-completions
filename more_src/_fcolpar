#compdef fcolpar
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fcolpar.txt
# Write the column number for an input filename and column name

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "colname=[name of column]:" \
  "exact=[exact column name match]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
