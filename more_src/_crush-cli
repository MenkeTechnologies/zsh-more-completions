#compdef crush-cli
# Documentation: https://github.com/charmbracelet/crush
# Reference accessed: 2026-05-23
# Verified: npx @charmland/crush --help (same as crush; see _crush).

# Zsh completion for crush-cli - Charm Crush AI agent (alternate binary name)

local curcontext="$curcontext" state line ret=1

_crush_cli_commands() {
  local -a commands=(
    'run:run a single non-interactive prompt'
    'logs:view application logs'
    'login:authenticate with a provider'
    'logout:remove provider credentials'
    'models:list available models'
    'projects:manage projects'
    'server:run crush in client/server mode'
    'completion:generate shell completion'
    'dirs:show config and data directories'
    'help:show help'
  )
  _describe -t commands 'crush-cli command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --cwd)'{-c+,--cwd=}'[working directory]:directory:_directories' \
  '(-D --data-dir)'{-D+,--data-dir=}'[custom data directory]:directory:_directories' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-y --yolo)'{-y,--yolo}'[auto-accept all permissions]' \
  '(-s --session)'{-s+,--session=}'[continue session by ID]:id:' \
  '(-C --continue)'{-C,--continue}'[continue most recent session]' \
  '1: :_crush_cli_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[hide spinner]' \
          '(-v --verbose)'{-v,--verbose}'[show logs]' \
          '(-m --model)'{-m+,--model=}'[model]:model:' \
          '(-s --session)'{-s+,--session=}'[session ID]:id:' \
          '(-C --continue)'{-C,--continue}'[continue most recent session]' \
          '*:prompt:' && ret=0
        ;;
      login|logout)
        _arguments '*:platform:platform:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
