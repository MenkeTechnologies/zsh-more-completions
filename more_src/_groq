#compdef groq
# Documentation: https://man.archlinux.org/search?q=groq
# Reference accessed: 2026-05-16

_groq() {
    _arguments \
        '(-t --temperature)'{-t,--temperature}'[Set generation temperature]:number:' \
        '(-s --system)'{-s,--system}'[Custom system instruction]:instruction:' \
        '(-o --output)'{-o,--output}'[Format output]:format:(json ndjson pretty)' \
        '*:query:'
}

_groq "$@"
