#compdef waydroid

# Zsh completion for waydroid - Android container on Linux

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:set up waydroid-specific configs and install images'
  'status:show quick status of waydroid'
  'session:session controller'
  'container:container controller'
  'app:applications controller'
  'prop:android system properties controller'
  'show-full-ui:show Android full UI'
  'shell:run a remote shell in the container'
  'logcat:follow Android logcat'
  'log:follow waydroid log'
  'upgrade:upgrade Android images'
  'first-launch:run first-launch setup'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'waydroid command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '(-s --images-path)'{-s,--images-path}'[custom path for images]:directory:_files -/' \
          '(-f --force)'{-f,--force}'[re-initialize even if already done]' \
          '(-c --system-channel)'{-c,--system-channel}'[system OTA channel]:channel' \
          '(-v --vendor-channel)'{-v,--vendor-channel}'[vendor OTA channel]:channel' \
          '(-r --rom-type)'{-r,--rom-type}'[ROM type]:type:(lineage gapps)' \
          '(-i --system-type)'{-i,--system-type}'[system type]:type:(VANILLA GAPPS)' && ret=0
        ;;
      (session)
        local -a session_commands=(
          'start:start the waydroid session'
          'stop:stop the waydroid session'
        )
        _arguments -s -S \
          '1:session command:->session_cmd' && ret=0
        if [[ $state == session_cmd ]]; then
          _describe -t commands 'session command' session_commands && ret=0
        fi
        ;;
      (container)
        local -a container_commands=(
          'start:start the waydroid container'
          'stop:stop the waydroid container'
          'restart:restart the waydroid container'
          'freeze:freeze the waydroid container'
          'unfreeze:unfreeze the waydroid container'
        )
        _arguments -s -S \
          '1:container command:->container_cmd' && ret=0
        if [[ $state == container_cmd ]]; then
          _describe -t commands 'container command' container_commands && ret=0
        fi
        ;;
      (app)
        local -a app_commands=(
          'install:install an APK'
          'remove:remove an app'
          'launch:launch an app'
          'list:list installed apps'
          'intent:send an intent'
        )
        _arguments -s -S \
          '1:app command:->app_cmd' \
          '*:: :->app_args' && ret=0
        case $state in
          (app_cmd)
            _describe -t commands 'app command' app_commands && ret=0
            ;;
          (app_args)
            case $words[1] in
              (install) _arguments '1:APK file:_files -g "*.apk"' && ret=0 ;;
              (remove|launch) _arguments '1:package name' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      (prop)
        local -a prop_commands=(
          'get:get a property'
          'set:set a property'
        )
        _arguments -s -S \
          '1:prop command:->prop_cmd' \
          '*:: :->prop_args' && ret=0
        case $state in
          (prop_cmd) _describe -t commands 'prop command' prop_commands && ret=0 ;;
          (prop_args)
            case $words[1] in
              (get) _arguments '1:property name' && ret=0 ;;
              (set) _arguments '1:property name' '2:value' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      (shell)
        _arguments '*:command' && ret=0
        ;;
      (upgrade)
        _arguments -s -S \
          '(-s --images-path)'{-s,--images-path}'[custom path for images]:directory:_files -/' \
          '(-o --offline)'{-o,--offline}'[use local images]' && ret=0
        ;;
    esac
    ;;
esac

return ret
