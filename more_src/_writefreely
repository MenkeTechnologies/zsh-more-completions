#compdef writefreely

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:edit configuration'
  'keys:generate or load encryption keys'
  'db:database operations'
  'user:user management'
  'fetch-remote-posts:fetch remote ActivityPub posts'
  'remote-user:manage remote users'
  'oauth:OAuth provider operations'
  'instance:instance commands'
  'health:show health'
  'reset-password:reset user password'
  'create-admin:create admin user'
  'create-user:create regular user'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.ini"' \
  '--init-db[initialise database]' \
  '--migrate[migrate db schema]' \
  '--gen-keys[generate encryption keys]' \
  '--create-admin=[create admin user:password]:user:pw:' \
  '--create-user=[create user:password]:user:pw:' \
  '--reset-password=[reset password for user]:user:' \
  '--delete-user=[delete user]:user:' \
  '--suspend-user=[suspend user]:user:' \
  '--unsuspend-user=[unsuspend user]:user:' \
  '--user-admin=[grant admin to user]:user:' \
  '--user-not-admin=[remove admin from user]:user:' \
  '--user-passphrase=[set user passphrase]:user:' \
  '--debug[enable debug logs]' \
  '--config-args=[config sections csv]:list:(app db server)' \
  '*--sections=[sections csv]:list:(app db server)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'writefreely command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config) _values 'subcommand' 'start' 'show' && ret=0 ;;
      (keys) _values 'subcommand' 'generate' && ret=0 ;;
      (db) _values 'subcommand' 'init' 'migrate' && ret=0 ;;
      (user) _values 'subcommand' 'create' 'reset-pass' 'delete' 'suspend' 'unsuspend' 'admin' 'not-admin' && ret=0 ;;
      (oauth) _values 'subcommand' 'sync' 'remove' && ret=0 ;;
    esac ;;
esac

return ret
