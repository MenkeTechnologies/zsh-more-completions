#compdef unwindctl
# _unwindctl — OpenBSD unwindctl (control + introspect the running unwind(8) validating recursive DNS resolver; status snapshot, autoconf, memory, reload, log level brief/verbose/debug)
# upstream: https://github.com/openbsd/src (usr.sbin/unwindctl)
# Flags + commands from usr.sbin/unwindctl/unwindctl.8 on tip.

_unwindctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-s+[control socket (default /dev/unwind.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'unwindctl command' \
                '(status:show daemon status reload:reload config log:log level (brief|verbose|debug))'
            ;;
        args)
            case $line[1] in
                status) _describe -t commands 'status target' '(autoconf memory)' ;;
                log) _describe -t commands 'log level' '(brief verbose debug)' ;;
            esac
            ;;
    esac
}

_unwindctl "$@"
