#compdef 3dSetupGroupInCorr
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dSetupGroupInCorr.html
# Set up datasets for use with 3dGroupInCorr

local ret=1

_arguments -s \
  '-mask[mask dataset to restrict voxels]:dataset:_files' \
  '-prefix[output file prefix]:prefix' \
  '-short[store data as 16-bit shorts]' \
  '-byte[store data as 8-bit bytes]' \
  '-labels[file with unique dataset labels]:file:_files' \
  '-DELETE[remove input datasets after processing]' \
  '-prep[preprocessing before normalization]:method:(SPEARMAN DEMEAN)' \
  '-LRpairs[left/right hemisphere surface pairs]:surfaces' \
  '*:dataset:_files' && ret=0

return ret
