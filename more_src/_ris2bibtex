#compdef ris2bibtex
# _ris2bibtex — Petr Janata ris2bibtex CLI Perl converter translating RIS Reference Information System Endnote-style ProQuest Wiley Web of Science citation files directly into BibTeX entries without going through MODS XML intermediate skipping unsupported tags preserving authors title journal year DOI (Petr Janata team, Perl); getopt
# upstream: https://github.com/petrjanata/ris2bibtex

_ris2bibtex() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-i+[input file]:file:_files -g "*.ris *.txt"' \
        '--input=+[file]:file:_files -g "*.ris *.txt"' \
        '-o+[output file]:file:_files -g "*.bib"' \
        '--output=+[file]:file:_files -g "*.bib"' \
        '-e+[encoding]:e:(utf8 latin1 iso-8859-1)' \
        '--encoding=+[enc]:e:(utf8 latin1 iso-8859-1)' \
        '--keep-unknown[keep unknown fields]' \
        '--no-emit-empty[skip empty fields]' \
        '--use-id-key[use ID tag for citation key]' \
        '*:ris file:_files -g "*.ris *.txt"'
}

_ris2bibtex "$@"
