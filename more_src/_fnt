#compdef fnt

# alexmyczko/fnt — font manager script

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '-u[update font index]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'fnt command' compadd -- search install remove list update
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
