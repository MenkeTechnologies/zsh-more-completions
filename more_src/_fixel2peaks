#compdef fixel2peaks
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixel2peaks.html
# Source: MRtrix3/mrtrix3 cmd/fixel2peaks.cpp — convert fixel data to peak amplitude/direction image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-number+[max fixels per voxel]:n:_default' \
    '-nan[fill excess peaks with NaN instead of 0]' \
    '1:in (fixel info):_files' \
    '2:out (peaks image):_files' \
    && ret=0

return ret
