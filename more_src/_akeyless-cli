#compdef akeyless-cli akeyless
# _akeyless-cli — Akeyless akeyless-cli CLI command-line frontend wrapping the Akeyless SaaS Vault Secrets Management Zero-Trust Access SaaS solution providing alternative to HashiCorp Vault open-source written in Go DFC distributed-fragments-cryptography manage secrets static dynamic rotated machine identity SSH Cert Kubernetes Containers credentials keys encryption signing K8s PAM secure remote access JIT zero-trust auth-method UID-Tokens-Universal-Identity OAUTH2-OIDC SAML LDAP API-Key-AWS-IAM-Azure-AD GCP-IAM Cert-Auth UID-EmpInfo Tenants gateway connect customer-fragment-CF DFC oauth (Akeyless team Oded Hareven Refael Angel, Go); cobra
# upstream: https://www.akeyless.io/

_akeyless-cli() {
    local -a sub=(
        'configure:configure CLI'
        'auth:authenticate'
        'list-items:list items'
        'get-secret-value:get secret value'
        'create-secret:create a static secret'
        'create-dynamic-secret:create a dynamic secret'
        'create-rotated-secret:create a rotated secret'
        'update-secret-val:update static secret'
        'delete-item:delete item'
        'rotate-secret:rotate a secret'
        'get-rsa-public:get RSA public key'
        'encrypt:encrypt'
        'decrypt:decrypt'
        'sign:sign'
        'verify:verify'
        'export-classic-key:export classic key'
        'import-classic-key:import classic key'
        'create-classic-key:create classic key'
        'connect:connect to target'
        'kube-config:Kube exec credentials'
        'list-targets:list targets'
        'create-target:create target'
        'update-target:update target'
        'delete-target:delete target'
        'list-auth-methods:list auth methods'
        'create-auth-method:create auth method'
        'create-role:create role'
        'create-customer-fragment:create CF'
        'gateway-status:gateway status'
        'gateway-list-allowed-management-access:list allowed mgmt'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--profile=+[name]:str:' \
        '-p+[profile]:str:' \
        '--access-id=+[id]:str:' \
        '--access-key=+[key]:str:' \
        '--access-type=+[t]:t:(access_key password api_key azure_ad aws_iam gcp k8s cert universal_identity saml ldap oauth2 oidc jwt)' \
        '--api-gateway-url=+[url]:str:' \
        '--gateway-url=+[url]:str:' \
        '--api-url=+[url]:str:' \
        '--cf-url=+[url]:str:' \
        '--uid-token=+[token]:str:' \
        '--token=+[token]:str:' \
        '-t+[token]:str:' \
        '--password=+[password]:str:' \
        '--admin-email=+[email]:str:' \
        '--ldap-username=+[user]:_users' \
        '--ldap-password=+[password]:str:' \
        '--azure-ad-object-id=+[id]:str:' \
        '--gcp-audience=+[aud]:str:' \
        '--cert-data=+[data]:str:' \
        '--key-data=+[data]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--path=+[path]:str:' \
        '--type=+[t]:str:' \
        '--value=+[value]:str:' \
        '--file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '--description=+[text]:str:' \
        '--metadata=+[json]:str:' \
        '--tags=+[tags]:str:' \
        '--protection-key=+[key]:str:' \
        '--key=+[key]:str:' \
        '--encryption-key-name=+[name]:str:' \
        '-o+[output format]:f:(json yaml table text)' \
        '--output=+[fmt]:f:(json yaml table text)' \
        '--json[JSON output]' \
        '--yaml[YAML output]' \
        '--quiet[quiet]' \
        '--no-banner[no banner]' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'akeyless subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                get-secret-value|delete-item|update-secret-val|rotate-secret) _arguments '*:name:' ;;
            esac
            ;;
    esac
}

_akeyless-cli "$@"
