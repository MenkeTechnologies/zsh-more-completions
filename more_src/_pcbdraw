#compdef pcbdraw
# Documentation: https://github.com/yaqwsx/PcbDraw/blob/master/README.md
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help message and exit]' \
  '--style[style JSON file for board rendering]:style file:_files -g "*.json"' \
  '--libs[directory containing component libraries]:library dir:_files -/' \
  '--filter[file listing components to filter]:filter file:_files' \
  '--remap[file for remapping component footprints]:remap file:_files' \
  '--dpi[DPI for PNG output]:dpi:' \
  '--no-drillholes[do not render drill holes]' \
  '--back[render the back side of the board]' \
  '--mirror[mirror the board image]' \
  '*--highlight[highlight specified components]:component:' \
  '--vcuts[render V-cuts on the board]' \
  '--side[board side to render]:side:(front back)' \
  '--format[output format]:format:(svg png)' \
  '1:input PCB file:_files -g "*.kicad_pcb"' \
  '2:output file:_files' && ret=0

return ret
