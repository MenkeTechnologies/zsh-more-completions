#compdef kuzu

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --default_bp_size)'{-d,--default_bp_size=}'[buffer pool size MB]:mb:' \
  '(-r --read_only)'{-r,--read_only}'[open database read-only]' \
  '(-p --path_history)'{-p,--path_history=}'[shell history file]:file:_files' \
  '(-m --mode)'{-m,--mode=}'[output mode]:mode:(box column csv tsv html json line list markdown trash)' \
  '(-s --no_stats)'{-s,--no_stats}'[hide query statistics]' \
  '--no_compression[disable compression]' \
  ':database:_files -/'
