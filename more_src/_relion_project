#compdef relion_project
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: calculate 2D projections of a 3D map

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input map to be projected]:file:_files' \
  '--o=[rootname for output projections]:file:_files' \
  '--angpix=[pixel size (A)]:value' \
  '--mask=[mask applied to the input map prior to projections]:file:_files' \
  '--ang=[particle STAR file with orientations and CTF]:file:_files' \
  '--nr_uniform=[get this many random samples from uniform distribution]:value' \
  '--sigma_offset=[apply Gaussian errors (A) with this stddev to XY-offsets]:value' \
  '--rot=[first Euler angle (single projection)]:value' \
  '--tilt=[second Euler angle (single projection)]:value' \
  '--psi=[third Euler angle (single projection)]:value' \
  '--xoff=[origin X-offset (pixels, single projection)]:value' \
  '--yoff=[origin Y-offset (pixels, single projection)]:value' \
  '--zoff=[origin Z-offset (pixels, single 3D rotation)]:value' \
  '--white_noise=[stddev of added white Gaussian noise]:value' \
  '--model_noise=[model STAR file with power spectra for coloured noise]:file:_files' \
  '--maxres=[maximum resolution (A) to consider in Fourier space]:value' \
  '--pad=[padding factor]:value' \
  '*:file:_files' && ret=0

return ret
