#compdef SurfExtrema
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfExtrema.html
# Find local extrema on a surface (SUMA)

local ret=1

_arguments -s -S \
  '(-h -help -HELP)'{-h,-help,-HELP}'[show help]' \
  '-input[dataset for extrema identification]:dataset:_files' \
  '-hood[neighborhood radius in mm]:R:' \
  '-nbhd_rad[neighborhood radius in mm]:R:' \
  '-thresh[minimum value threshold for node]:TH:' \
  '-gthresh[minimum gradient threshold]:GTH:' \
  '-gscale[gradient scaling method]:scl:(NONE LMEAN GMEAN)' \
  '-extype[extrema type]:typ:(MAX MIN ABS)' \
  '-prefix[output dataset prefix]:prefix:' \
  '-table[output file for extrema records]:file:_files' \
  '-i[input surface file(s)]:surface:_files' \
  '-spec[specification file for multiple surfaces]:spec:_files' \
  '-sv[surface volume for coordinate alignment]:dataset:_files' \
  '-onestate[synchronize multiple surfaces to single state]' \
  '-anatomical[label surfaces as anatomically correct]' \
  '-n_mask[apply to specific node indices]:mask:_files' \
  '-b_mask[binary mask for node filtering]:mask:_files' \
  '-c_mask[expression-based masking]:expr:' \
  '-talk_suma[send progress updates to SUMA]' \
  '-refresh_rate[update frequency limit]:rps:' \
  '-send_kth[send every kth element]:kth:' \
  '-sh[SUMA host computer]:host:' \
  '-ni_text[text data transmission mode]' \
  '-ni_binary[binary data transmission mode]' \
  '-feed_afni[send updates to AFNI]' \
  '-novolreg[ignore volume transformations]' \
  '-noxform[ignore volume transformations]' \
  '-setenv[set environment variable]:env:' \
  '-trace[enable debug tracing]' \
  '-TRACE[enable extreme tracing]' \
  '-h_view[view help in editor]' \
  '-h_web[view help in browser]' \
  '-h_find[search help for word]:word:' \
  '-all_opts[identify all program options]' \
  '*:surface:_files' && ret=0

return ret
