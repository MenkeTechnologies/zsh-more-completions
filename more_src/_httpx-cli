#compdef httpx-cli
# Documentation: https://man.archlinux.org/search?q=httpx-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-X --request)'{-X+,--request=}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '(-d --data)'{-d+,--data=}'[request body]:body:' \
  '(-j --json)'{-j+,--json=}'[JSON body]:json:' \
  '*'{-c+,--cookie=}'[cookie name=value]:cookie:' \
  '*'{-H+,--header=}'[header Name:Value]:header:' \
  '(-p --params)'{-p+,--params=}'[query params]:params:' \
  '(--auth)--auth=[basic auth user:pass]:auth:' \
  '(--bearer)--bearer=[bearer token]:token:' \
  '(--proxy)--proxy=[proxy URL]:url:' \
  '(-t --timeout)'{-t+,--timeout=}'[timeout seconds]:s:' \
  '(--no-verify)--no-verify[skip TLS verify]' \
  '(--http1)--http1[force HTTP/1.1]' \
  '(--http2)--http2[force HTTP/2]' \
  '(--follow-redirects)--follow-redirects[follow redirects]' \
  '(--max-redirects)--max-redirects=[max redirects]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-D --download)'{-D+,--download=}'[download to file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(--print-headers)--print-headers[print headers only]' \
  '(--print-body)--print-body[print body only]' \
  '*::URL:_urls' && ret=0

return ret
