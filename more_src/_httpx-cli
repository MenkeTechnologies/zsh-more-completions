#compdef httpx-cli
# Documentation: https://github.com/encode/httpx
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httpx CLI - command-line client for the encode/httpx Python package.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(-m --method)'{-m+,--method=}'[HTTP method]:method:(GET POST PUT PATCH DELETE OPTIONS HEAD)' \
  '*'{-p+,--params=}'[query parameter key value]:params:' \
  '(-c --content)'{-c+,--content=}'[byte content for request body]:content:' \
  '*'{-d+,--data=}'[form data key value]:data:' \
  '*'{-f+,--files=}'[form file key value]:files:_files' \
  '(-j --json)'{-j+,--json=}'[JSON body]:json:' \
  '*'{-h+,--headers=}'[header name value]:header:' \
  '*--cookies=[cookie name value]:cookie:' \
  '--auth=[username password]:auth:' \
  '--proxy=[proxy URL]:url:_urls' \
  '--timeout=[timeout seconds (default 5.0)]:s:' \
  '--follow-redirects[follow redirects]' \
  '--no-verify[disable SSL verification]' \
  '--http2[use HTTP/2]' \
  '--download=[save response to file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[show request and response details]' \
  '*::URL:_urls' && ret=0

return ret
