#compdef msfdb
# Documentation: https://github.com/rapid7/metasploit-framework/blob/master/msfdb
# Manage the Metasploit Framework database

local ret=1

_arguments -s -S \
  '--component=[component used with provided command (database, webservice, or all)]:component:(database webservice all)' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--use-defaults[accept all defaults without prompting during initialization]' \
  '--msf-db-name=[database name (default msf)]:name' \
  '--msf-db-user-name=[database username (default msf)]:user' \
  '--msf-test-db-name=[test database name (default msftest)]:name' \
  '--msf-test-db-user-name=[test database username (default msftest)]:user' \
  '--db-port=[database port (default 5433)]:port' \
  '--db-pool=[database connection pool size (default 200)]:max' \
  '--connection-string=[use pre-existing database cluster for initialization]:uri' \
  '(-a --address)'{-a,--address}'=[bind to host address (default localhost)]:address:_hosts' \
  '(-p --port)'{-p,--port}'=[web service port (default 5443)]:port' \
  '--daemon[enable daemon mode]' \
  '--no-daemon[disable daemon mode]' \
  '--ssl[enable SSL]' \
  '--no-ssl[disable SSL]' \
  '--ssl-key-file=[path to private key]:key file:_files' \
  '--ssl-cert-file=[path to certificate]:cert file:_files' \
  '--ssl-disable-verify[disable optional client cert requests]' \
  '--environment=[web service framework environment]:env:(production development)' \
  '--retry-max=[maximum web service connection attempts (default 10)]:max' \
  '--retry-delay=[delay between connection attempts in seconds (default 5.0)]:delay' \
  '--user=[initial web service admin username]:user' \
  '--pass=[initial web service admin password]:password' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:command:(init reinit delete status start stop restart run)' && ret=0

return ret
