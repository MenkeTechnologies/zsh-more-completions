#compdef dpdk-pdump
# Documentation: https://doc.dpdk.org/guides/tools/pdump.html
# DPDK packet capture framework application

local ret=1

_arguments -s -S \
  '--multi[run capture on unique cores for all --pdump options]' \
  '*--pdump=[packet capture parameters (port=,queue=,rx-dev=,tx-dev=)]:pdump spec' && ret=0

return ret
