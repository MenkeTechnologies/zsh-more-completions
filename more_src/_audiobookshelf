#compdef audiobookshelf
# _audiobookshelf — advplyr audiobookshelf self-hosted audiobook/podcast server with multi-user library and progress sync (advplyr team, Node.js); standard argv
# upstream: https://github.com/advplyr/audiobookshelf

_audiobookshelf() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config dir]:dir:_files -/' \
        '-c+[config dir]:dir:_files -/' \
        '--metadata=+[metadata dir]:dir:_files -/' \
        '-m+[metadata dir]:dir:_files -/' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--host=+[bind host]:host:_hosts' \
        '-H+[bind host]:host:_hosts' \
        '--source=+[install source]:s:(docker debian rpm)' \
        '--reverse-proxy[behind reverse proxy]' \
        '--reverse-proxy-host=+[trusted proxy]:str:' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--access-log[enable access log]' \
        '--audio-codec=+[codec]:c:(aac mp3 opus flac)' \
        '--allow-iframe[allow iframe embedding]' \
        '--backup-path=+[backup dir]:dir:_files -/'
}

_audiobookshelf "$@"
