#compdef rsgisapplycmd
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# Applies a command (e.g., gdal_translate) using subprocess

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--indir[Input directory.]:value:_files' \
  '--outdir[Ouput directory.]:value:_files' \
  '--inext[Input file extension of the files to be processed (e.g., kea).]:value:_files' \
  '--outext[Output file extension for the output files (e.g., tif).]:value:_files' \
  '--nameapp[Provide a string to be appended on the file name]:value:_files' \
  '--cmd[The command to be excuted with {{ input }} and {{ output }}]:value:_files' \
  '--ncores[Number of cores to used for processing (default = 1).]:value:_files' \
  '--printcmds[Prints the commands to be executed to the]' \
  '*:file:_files' && ret=0

return ret
