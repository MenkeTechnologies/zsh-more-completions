#compdef prism

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'mock:start a mock server from an API description'
  'proxy:start a proxy server validating requests/responses'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'prism command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (mock)
        _arguments \
          '-p+[port to listen on]:port' \
          '--port=[port to listen on]:port' \
          '-h+[host to listen on]:host' \
          '--host=[host to listen on]:host' \
          '-d[dynamic response generation]' \
          '--dynamic[dynamic response generation]' \
          '--cors[enable CORS]' \
          '--errors[throw errors for invalid requests]' \
          '--json-schema-faker-fillProperties=[fill optional properties]:fill:(true false)' \
          '1:spec file:_files -g "*.{json,yaml,yml}"' && ret=0
        ;;
      (proxy)
        _arguments \
          '-p+[port to listen on]:port' \
          '--port=[port to listen on]:port' \
          '-h+[host to listen on]:host' \
          '--host=[host to listen on]:host' \
          '-u+[upstream URL]:url' \
          '--upstream=[upstream URL]:url' \
          '--errors[return errors for violations]' \
          '--validate-request[validate request against spec]' \
          '1:spec file:_files -g "*.{json,yaml,yml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
