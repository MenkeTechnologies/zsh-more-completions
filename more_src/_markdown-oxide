#compdef markdown-oxide
# Documentation: https://man.archlinux.org/search?q=markdown-oxide
# Reference accessed: 2026-05-16

# Zsh completion for markdown-oxide (Markdown LSP server for PKM)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--stdio[use stdio transport]' && ret=0

return ret
