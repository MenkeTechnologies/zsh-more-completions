#                 authored both projects, making @iarna/toml the
#                 default TOML implementation across the entire npm
#                 client tooling surface.
#
# Round-number 231 landmark fires simultaneously across all three lanes:
# Rust completion #231 (_fallow) + Go completion #231 (_tailon) + TS-Node
# completion #231 (_cannon) = triple-231.  Axis #169 closed in the
# lifetime of the corpus — every major TOML library in the three big
# systems languages now has both a representative consumer completion
# AND a documented axis closure landmark; the lanes are tied together by
# a common design discipline (spec-complete TOML 1.0 parser + serializer
# in pure host-language code with optional format-preservation for
# config-mutation tools).
# ============================================================================

_cannon() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'run:run a local Cannon package (Chain ID 13370) on a local node for development and testing (default action when no subcommand)'
                'build:build a package from a Cannonfile (default cannonfile.toml)'
                'verify:verify a deployed package on a block explorer (Etherscan/Sourcify)'
                'diff:diff two Cannon packages or two versions of a package'
                'alter:alter a deployed package in-place (advanced — modifies on-chain state references)'
                'fetch:fetch a published Cannon package from the registry to local cache'
                'pin:pin a Cannon package on IPFS (prevents garbage collection)'
                'publish:publish a locally-built package to the Cannon registry'
                'unpublish:unpublish a package from the Cannon registry'
                'register:register a new package name on the registry (one-time per name)'
                'publishers:list / add / remove publishers authorized to publish under a package name'
                'inspect:inspect a Cannon package (deployment artifact contents, ABIs, addresses)'
                'prune:prune local Cannon cache of stale packages'
                'trace:trace a transaction through a deployed Cannon package'
                'decode:decode transaction data against a Cannon package ABI'
                'test:run Cannon-orchestrated Foundry tests against a built package'
                'interact:interactive prompt for calling functions on a deployed package'
                'setup:first-run setup wizard (registry config, default RPC URL, IPFS gateway)'
                'clean:clean local Cannon cache and build outputs'
                'plugin:manage Cannon plugins (subcommand: list / install / remove)'
            )
            _describe -t commands 'cannon command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(-n --rpc-url)'{-n,--rpc-url=}'[RPC endpoint to fork off of]:url:' \
                        '(-c --chain-id)'{-c,--chain-id=}'[chain ID of the deployment]:chain ID:' \
                        '--port=[port for JSON-RPC server (default 0 = random)]:port:' \
                        '--build[rebuild generated artifacts even if no changed settings]' \
                        '--upgrade-from=[package to use as new base for the deployment]:package\:version:' \
                        '--registry-priority=[default registry to read from first]:registry:(onchain offchain local)' \
                        '--logs[show RPC logs instead of interactive prompt]' \
                        '*--fund-addresses=[addresses to receive 10,000 ETH each]:address:' \
                        '--impersonate=[impersonate all calls from given signer (default ANVIL_FIRST_ADDRESS)]:address:' \
                        '--mnemonic=[mnemonic to initialize a chain of signers]:BIP39 phrase:' \
                        '--private-key=[comma-separated list of private keys for signing]:keys:' \
                        '--non-interactive[do not prompt for any user input (useful for CI)]' \
                        '-v[debug verbosity (repeatable: -v / -vv / -vvv)]' \
                        '*:package refs (name[:semver] [key=value ...]):' && ret=0
                    ;;
                build)
                    _arguments \
                        '(-n --rpc-url)'{-n,--rpc-url=}'[RPC endpoint to execute deployment on]:url:' \
                        '(-c --chain-id)'{-c,--chain-id=}'[chain ID of deployment]:chain ID:' \
                        '--port=[port for JSON-RPC server (default 0 = random)]:port:' \
                        '--dry-run[do not actually execute on-chain transactions (requires --impersonate or --impersonate-all)]' \
                        '--impersonate=[impersonate calls from given signer]:address:' \
                        '--impersonate-all[impersonate calls from any signer]' \
                        '--upgrade-from=[package to use as new base for deployment]:package\:version:' \
                        '--wipe[wipe existing deployment state and rebuild from scratch]' \
                        '--keep-alive[keep the local Anvil node alive after build]' \
                        '--port-priority=[use this port if available, else fallback]:port:' \
                        '--mnemonic=[mnemonic for signers]:BIP39 phrase:' \
                        '--private-key=[comma-separated private keys]:keys:' \
                        '--non-interactive[no prompts]' \
                        '1:cannonfile path (default cannonfile.toml):_files -g "*.(toml|TOML)"' \
                        '*:settings (key=value):' && ret=0
                    ;;
                verify|inspect|interact|trace|decode|publish|unpublish|register|publishers|fetch|pin|alter)
                    _arguments \
                        '*:package reference (name[:semver][@preset]):' && ret=0
                    ;;
                test)
                    _arguments \
                        '1:cannonfile (default cannonfile.toml):_files -g "*.(toml|TOML)"' \
                        '*:forge test options (passed through to forge test):' && ret=0
                    ;;
                plugin)
                    _arguments \
                        '1: :(list install remove)' \
                        '2:plugin name (npm package):' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_cannon "$@"
