#compdef cdda2mp3
# Documentation: https://manpages.debian.org/bookworm/cdda2wav/cdda2mp3.1.en.html
# Reference accessed: 2026-05-17
# Verified: cdda2wav-distributed cdda2mp3(1) wrapper script. The
# wrapper accepts a single optional argument (track range) and
# delegates to cdda2wav/lame; it has no -h/--help/-V flags of its
# own (those belong to cdda2wav).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h flag.

local ret=1
_arguments -s \
  '1:track range (e.g. 1+2-5):' \
  '*:device:_files -g "/dev/(cdrom|sr*|cd*|dvd*)(-.)"' && ret=0
return ret
