#compdef devspace

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[show debug output]' \
  '--silent[suppress all output]' \
  '-n+[target namespace]:namespace' \
  '--namespace=[target namespace]:namespace' \
  '--no-warn[suppress warnings]' \
  '-p+[profile to use]:profile' \
  '--profile=[profile to use]:profile' \
  '--kube-context=[kube context to use]:context' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a new devspace project'
      'dev:start development mode'
      'build:build images'
      'deploy:deploy the project'
      'purge:delete deployed resources'
      'use:use a specific context/namespace/profile'
      'ui:open the DevSpace UI'
      'list:list configurations'
      'add:add a configuration'
      'remove:remove a configuration'
      'run:run a command pipeline'
      'logs:print container logs'
      'enter:open a shell in a container'
      'sync:start file synchronization'
      'open:open the app in the browser'
      'analyze:analyze issues in the namespace'
      'reset:reset configurations'
      'upgrade:upgrade DevSpace CLI'
      'cleanup:clean up resources'
      'print:print generated config'
      'attach:attach to a container'
      'restart:restart containers'
      'set:set configuration values'
      'completion:generate shell completion'
    )
    _describe -t commands 'devspace command' commands && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-b[force rebuild images]' \
          '--force-build[force rebuild images]' \
          '--force-deploy[force redeploy]' \
          '--skip-build[skip image building]' \
          '--skip-push[skip image pushing]' \
          '--open[open browser on start]' \
          '--skip-pipeline[skip pipeline steps]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--skip-push[skip pushing images]' \
          '-b[force rebuild images]' \
          '--force-build[force rebuild images]' \
          '-t+[override image tag]:tag' \
          '--tag=[override image tag]:tag' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--force-build[force rebuild images]' \
          '--skip-build[skip image building]' \
          '--force-deploy[force redeploy]' \
          '--skip-push[skip image pushing]' && ret=0
        ;;
      use)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:resource:(context namespace profile)' && ret=0
        ;;
      enter)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-l+[label selector]:selector' \
          '--label-selector=[label selector]:selector' \
          '-c+[container name]:container' \
          '--container=[container name]:container' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f[follow logs]' \
          '--follow[follow logs]' \
          '-c+[container name]:container' \
          '--container=[container name]:container' \
          '--last-log[show last log]' && ret=0
        ;;
    esac
    ;;
esac

return ret
