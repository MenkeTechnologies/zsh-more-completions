#compdef create-start
# Documentation: https://www.npmjs.com/package/@tanstack/create-start
# Reference accessed: 2026-05-24
# Verified: npm view @tanstack/create-start bin; npx @tanstack/create-start --help output.

# Zsh completion for create-start - TanStack Start application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-v --version)'{-v,--version}'[output current version]'   '--framework=[project framework]:framework:(React Solid)'   '--template-id=[built-in template id]:id:'   '--template=[template URL or id]:template:'   '--no-install[skip installing dependencies]'   '--package-manager=[package manager]:manager:(npm yarn pnpm bun deno)'   '--dev-watch=[watch framework directory for changes]:path:_directories'   '--run-dev[run dev server alongside dev-watch]'   '--router-only[router-only compatibility mode without TanStack Start]'   '--examples[include demo/example pages]'   '--no-examples[exclude demo/example pages]'   '--deployment=[deployment adapter]:adapter:(cloudflare netlify nitro railway)'   '--toolchain=[toolchain]:toolchain:(biome eslint)'   '--no-toolchain[skip toolchain selection]'   '--interactive[interactive mode]'   '--non-interactive[skip prompts and use defaults]'   '(-y --yes)'{-y,--yes}'[accept defaults and skip prompts]'   '--add-ons=[comma-separated add-ons]:addons:'   '--list-add-ons[list all available add-ons]'   '--json[output JSON for automation]'   '--git[create a git repository]'   '--no-git[do not create a git repository]'   '--intent[set up TanStack Intent skill mappings]'   '--no-intent[skip TanStack Intent setup]'   '--target-dir=[application root directory]:directory:_directories'   '(-f --force)'{-f,--force}'[force creation in non-empty directory]'   '(-h --help)'{-h,--help}'[display help for command]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command'       create dev libraries doc search-docs ecosystem pin-versions clean-demos add && ret=0
    ;;
  args)
    _arguments -C       ':project name:'       '*:arguments:' && ret=0
    ;;
esac

return ret
