#compdef ml
# Documentation: https://lmod.readthedocs.io/en/latest/010_user.html
# Lmod 'ml' shortcut: ml=module list, ml foo=load foo, ml -bar=unload bar

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--show_hidden[include hidden modules in avail/spider output]' \
  '--raw[show raw modulefile contents (with show)]' \
  '--redirect[send module output to stdout (with show)]' \
  '--location[show modulefile location (with show)]' \
  '--force[force purge of sticky modules]' \
  '*:module or subcommand:(list avail load unload swap purge reset restore overview try-load help is-loaded is-avail whatis keyword spider category show save describe savelist disable)' && ret=0

return ret
