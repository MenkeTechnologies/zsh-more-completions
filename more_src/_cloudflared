#compdef cloudflared

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print version]' \
  '--config[path to config file]:file:_files -g "*.{yml,yaml}"' \
  '--origincert[path to cert.pem]:file:_files -g "*.pem"' \
  '--no-autoupdate[disable auto-update]' \
  '--metrics[listen address for metrics]:host\:port' \
  '--pidfile[write PID to file]:file:_files' \
  '--logfile[log to file]:file:_files' \
  '--loglevel[log level]:level:(debug info warn error fatal)' \
  '--log-directory[directory for log files]:dir:_directories' \
  '--protocol[protocol for connection]:protocol:(auto quic http2)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'tunnel:manage Cloudflare Tunnels'
      'service:manage cloudflared system service'
      'access:access related commands'
      'update:update cloudflared'
      'version:print version'
      'proxy-dns:run a DNS over HTTPS proxy server'
      'tail:tail logs from a tunnel'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      tunnel)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--config[config file]:file:_files -g "*.{yml,yaml}"' \
          '--origincert[path to cert.pem]:file:_files -g "*.pem"' \
          '--credentials-file[credentials file]:file:_files -g "*.json"' \
          '--name[tunnel name]:name' \
          '--url[local server URL]:url' \
          '--protocol[protocol]:protocol:(auto quic http2)' \
          '--grace-period[grace period]:duration' \
          '1:subcommand:->tunnel_cmds' \
          '*::arg:->tunnel_args' && ret=0
        case "$state" in
          tunnel_cmds)
            local -a tunnel_commands=(
              'create:create a tunnel'
              'delete:delete a tunnel'
              'list:list tunnels'
              'info:show tunnel info'
              'run:run a tunnel'
              'route:configure tunnel routes'
              'login:login to Cloudflare'
              'cleanup:cleanup stale connections'
              'token:get tunnel token'
            )
            _describe -t commands 'tunnel command' tunnel_commands && ret=0
            ;;
        esac
        ;;
      service)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(install uninstall log)' && ret=0
        ;;
      access)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->access_cmds' \
          '*::arg:->access_args' && ret=0
        case "$state" in
          access_cmds)
            local -a access_commands=(
              'login:login to Access'
              'curl:curl with Access headers'
              'token:get Access token'
              'tcp:start a TCP proxy'
              'ssh:start an SSH proxy'
            )
            _describe -t commands 'access command' access_commands && ret=0
            ;;
        esac
        ;;
      proxy-dns)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port[DNS proxy port]:port' \
          '--address[listen address]:address' \
          '*--upstream[upstream DNS]:url' \
          '--max-upstream-conns[max upstream connections]:count' && ret=0
        ;;
    esac
    ;;
esac

return ret
