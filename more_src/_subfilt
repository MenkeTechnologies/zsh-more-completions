#compdef subfilt
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/subfilt.c
# SUBFILT - apply Butterworth bandpass filter

local ret=1

_arguments -s -S \
  'zerophase=[=0 for minimum phase filter]:z:(0 1)' \
  'locut=[=0 for no low cut filter]:l:(0 1)' \
  'hicut=[=0 for no high cut filter]:h:(0 1)' \
  'fstoplo=[freq (Hz) in low cut stop band]:f:' \
  'astoplo=[upper bound on amp at fstoplo]:a:' \
  'fpasslo=[freq (Hz) in low cut pass band]:f:' \
  'apasslo=[lower bound on amp at fpasslo]:a:' \
  'fpasshi=[freq (Hz) in high cut pass band]:f:' \
  'apasshi=[lower bound on amp at fpasshi]:a:' \
  'fstophi=[freq (Hz) in high cut stop band]:f:' \
  'astophi=[upper bound on amp at fstophi]:a:' \
  'npoleselo=[number of poles of lo pass band]:n:' \
  'npolesehi=[number of poles of hi pass band]:n:' \
  'f3dblo=[frequency of 3db lo cutoff]:f:' \
  'f3dbhi=[frequency of 3db hi cutoff]:f:' \
  'verbose=[=1 for filter design info]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
