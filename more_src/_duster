#compdef duster
# Documentation: https://github.com/tighten/duster
# Duster code style lint and fix runner for Laravel

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(lint fix commands)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      lint|fix)
        _arguments -s \
          '--dirty[only dust files with uncommitted git changes]' \
          '--using=[comma-separated list of tools to run]:tools' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
