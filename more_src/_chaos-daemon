#compdef chaos-daemon
# _chaos-daemon — node-side Chaos Mesh daemon (chaos-mesh/chaos-mesh)
# upstream: https://github.com/chaos-mesh/chaos-mesh
# Flags from cmd/chaos-daemon/main.go (flag).

_chaos-daemon() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[print version and exit]' \
        '-grpc-port=[gRPC server port]:port:' \
        '-http-port=[HTTP server port]:port:' \
        '-runtime=[container runtime]:runtime:(docker containerd crio)' \
        '-runtime-socket-path=[container runtime socket path]:file:_files' \
        '-containerd-ns=[containerd namespace]:ns:' \
        '-ca=[gRPC CA cert]:file:_files -g "*.(pem|crt)"' \
        '-cert=[gRPC server cert]:file:_files -g "*.(pem|crt)"' \
        '-key=[gRPC server key]:file:_files -g "*.(pem|key)"' \
        '-pprof[enable pprof endpoints]'
}

_chaos-daemon "$@"
