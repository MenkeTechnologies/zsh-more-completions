#compdef vamp-simple-host
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/vamp-simple-host.1.html
# a simple Vamp plugin host

local ret=1

_arguments -s -S \
  '(- *)-v[display version information only]' \
  '(- *)'{-l,--list}'[list plugin libraries and Vamp plugins in a verbose human-readable format]' \
  '(- *)--list-full[list all data reported by all Vamp plugins in a very verbose human-readable format]' \
  '(- *)--list-ids[list plugins in a terse machine-readable format (vamp:soname:identifier)]' \
  '(- *)--list-outputs[list plugin outputs in a machine-readable format (vamp:soname:identifier:output)]' \
  '(- *)--list-by-category[list the plugins as a plugin index by category]' \
  '(- *)-p[print out the Vamp library search path]' \
  '-s[label results with the audio sample frame at which they occur]' \
  '-o[dump plugin output into file]:output file:_files' \
  '*:audio file:_files' && ret=0

return ret
