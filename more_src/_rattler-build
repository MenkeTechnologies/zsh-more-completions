#compdef rattler-build

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a conda package'
  'test:test a conda package'
  'rebuild:rebuild a conda package'
  'upload:upload a conda package'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rattler-build command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-r --recipe)'{-r,--recipe}'=[path to recipe file]:file:_files' \
          '--recipe-dir=[path to recipe directory]:dir:_files -/' \
          '--output-dir=[output directory for packages]:dir:_files -/' \
          '--target-platform=[target platform]:platform:(linux-64 linux-aarch64 osx-64 osx-arm64 win-64 noarch)' \
          '*'{-c,--channel}'=[channel to search for dependencies]:channel' \
          '--variant-config=[path to variant config file]:file:_files' \
          '--no-build-id[do not use build id in output directory]' \
          '--no-test[do not run tests after build]' \
          '--color-build-log[colorize build log output]' \
          '--keep-build[keep build directory after build]' \
          '--compression-threads=[number of compression threads]:threads' \
          '--skip-existing=[skip if package already exists]:mode:(local all)' \
          '--render-only[only render the recipe, do not build]' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-r --recipe)'{-r,--recipe}'=[path to recipe file]:file:_files' \
          '*'{-c,--channel}'=[channel to search for dependencies]:channel' \
          '1:package file:_files -g "*.conda|*.tar.bz2"' && ret=0
        ;;
      (rebuild)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package file:_files -g "*.conda|*.tar.bz2"' && ret=0
        ;;
      (upload)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:package file:_files -g "*.conda|*.tar.bz2"' && ret=0
        ;;
    esac
    ;;
esac

return ret
