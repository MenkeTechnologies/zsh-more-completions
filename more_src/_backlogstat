#compdef backlogstat
# Documentation: man backlogstat(8)
# Source: InterNetNews/inn contrib/backlogstat.in — print innfeed backlog info (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-H[output a header line]' \
    '-k[scale numbers in 1024-unit k]' \
    '-n[count articles, not bytes]' \
    '-d+[innfeed directory]:dir:_files -/' \
    '-S+[site name prefix filter]:prefix:_default' \
    && ret=0

return ret
