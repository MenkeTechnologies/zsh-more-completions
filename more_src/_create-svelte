#compdef create-svelte

# Completion for create-svelte - Create a new SvelteKit project

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--name=[project name]:name' \
  '--template=[project template]:template:(default skeleton skeletonlib)' \
  '--types=[type checking]:type:(checkjs typescript null)' \
  '--prettier[add Prettier]' \
  '--no-prettier[skip Prettier]' \
  '--eslint[add ESLint]' \
  '--no-eslint[skip ESLint]' \
  '--playwright[add Playwright]' \
  '--no-playwright[skip Playwright]' \
  '--vitest[add Vitest]' \
  '--no-vitest[skip Vitest]' \
  '1:project directory:_directories' && ret=0

return ret
