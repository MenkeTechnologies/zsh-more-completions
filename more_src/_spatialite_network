#compdef spatialite_network
# Documentation: https://manpages.debian.org/testing/spatialite-bin/spatialite_network.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian testing spatialite_network(1) manpage.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# spatialite_network: build routable network table from spatialite DB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --db-path)'{-d+,--db-path=}'[spatialite database file]:file:_files' \
  '(-T --table)'{-T+,--table=}'[table to validate]:table:' \
  '(-f --from-column)'{-f+,--from-column=}'[from node column]:col:' \
  '(-t --to-column)'{-t+,--to-column=}'[to node column]:col:' \
  '(-g --geometry-column)'{-g+,--geometry-column=}'[geometry column]:col:' \
  '(-c --cost-column)'{-c+,--cost-column=}'[cost column]:col:' \
  '(-n --name-column)'{-n+,--name-column=}'[name column]:col:' \
  '--a-star-supported[A* algorithm supported]' \
  '--a-star-excluded[exclude A*]' \
  '(--unidirectional)--bidirectional[bidirectional edges]' \
  '(--bidirectional)--unidirectional[unidirectional edges]' \
  '--oneway-tofrom=[oneway to->from column]:col:' \
  '--oneway-fromto=[oneway from->to column]:col:' \
  '(-o --output-table)'{-o+,--output-table=}'[output table name]:table:' \
  '--overwrite-output[overwrite existing output table]' && ret=0
return ret
