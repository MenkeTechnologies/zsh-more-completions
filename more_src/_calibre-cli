#compdef calibredb

# Zsh completion for calibredb - calibre command-line database interface

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'list:list books in the library'
  'add:add books to the library'
  'remove:remove books from the library'
  'add_format:add a format to an existing book'
  'remove_format:remove a format from a book'
  'show_metadata:show metadata for a book'
  'set_metadata:set metadata for a book'
  'export:export books from the library'
  'catalog:generate a catalog of the library'
  'saved_searches:manage saved searches'
  'add_custom_column:add a custom column'
  'custom_columns:list custom columns'
  'remove_custom_column:remove a custom column'
  'is_empty:check if the library is empty'
  'backup_metadata:backup metadata of all books'
  'check_library:check the library for errors'
  'restore_database:restore the database from metadata'
  'search:search the library'
  'fts_index:manage full-text search index'
  'fts_search:full-text search'
  'embed_metadata:embed metadata into book files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --library-path)'{-l,--library-path}'[path to the calibre library]:library path:_files -/' \
  '--with-library[use the specified library]:library path:_files -/' \
  '--username[username for connecting to a calibre content server]:username' \
  '--password[password for connecting to a calibre content server]:password' \
  '1:subcommand:->subcmd' \
  '*::arguments:->args' \
  && ret=0

case "$state" in
  subcmd)
    _describe -t subcommands 'calibredb subcommand' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      list)
        _arguments -s -S \
          '(-f --fields)'{-f,--fields}'[comma-separated list of fields to display]:fields' \
          '--sort-by[field to sort by]:field' \
          '--ascending[sort in ascending order]' \
          '(-s --search)'{-s,--search}'[search query to filter results]:search query' \
          '(-w --line-width)'{-w,--line-width}'[maximum width of a single line]:width' \
          '--separator[field separator]:separator' \
          '--prefix[prefix for each line of output]:prefix' \
          '--limit[maximum number of results]:limit' \
          '--for-machine[output in JSON format for machine parsing]' \
          && ret=0
        ;;
      add)
        _arguments -s -S \
          '(-t --title)'{-t,--title}'[set title]:title' \
          '(-a --authors)'{-a,--authors}'[set authors]:authors' \
          '(-i --isbn)'{-i,--isbn}'[set ISBN]:isbn' \
          '--tags[set tags]:tags' \
          '--series[set series]:series' \
          '--series-index[set series index]:index' \
          '(-c --cover)'{-c,--cover}'[set cover image]:cover image:_files -g "*(#i).(jpg|jpeg|png|gif)"' \
          '--identifier[set identifier (type:value)]:identifier' \
          '--languages[set languages]:languages' \
          '(-r --recurse)'{-r,--recurse}'[add books from directories recursively]' \
          '(-d --duplicates)'{-d,--duplicates}'[add even if duplicates exist]' \
          '--empty[add an empty book (no formats)]' \
          '--automerge[auto-merge added books if they already exist]:merge mode' \
          '*:book file:_files' \
          && ret=0
        ;;
      export)
        _arguments -s -S \
          '--all[export all books]' \
          '--to-dir[export to specified directory]:directory:_files -/' \
          '--single-dir[export all books into a single directory]' \
          '--progress[show export progress]' \
          '--replace-whitespace[replace whitespace in filenames with underscores]' \
          '--to-lowercase[convert filenames to lowercase]' \
          '--formats[comma-separated list of formats to export]:formats' \
          '--template[template for filenames]:template' \
          '*:book id' \
          && ret=0
        ;;
      search)
        _arguments -s -S \
          '(-l --limit)'{-l,--limit}'[maximum number of results]:count' \
          '*:search expression' \
          && ret=0
        ;;
      remove)
        _arguments -s -S \
          '*:book id' \
          && ret=0
        ;;
      add_format)
        _arguments -s -S \
          '1:book id' \
          '2:book file:_files' \
          && ret=0
        ;;
      remove_format)
        _arguments -s -S \
          '1:book id' \
          '2:format' \
          && ret=0
        ;;
      show_metadata)
        _arguments -s -S \
          '1:book id' \
          && ret=0
        ;;
      set_metadata)
        _arguments -s -S \
          '1:book id' \
          '2:metadata file (OPF):_files -g "*.opf"' \
          && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
