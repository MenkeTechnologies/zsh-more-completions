#compdef avbanalyse
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'pcap:analyze pcap data'
  'trace:analyze trace data'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'avbanalyse subcommand' subcommands && ret=0
    ;;
  (args)
    _arguments \
      '--data=[input data path]:path:_files' \
      '--output=[output path]:path:_files' && ret=0
    ;;
esac

return ret
