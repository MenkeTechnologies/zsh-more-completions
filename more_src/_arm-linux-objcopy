#compdef arm-linux-objcopy arm-linux-gnueabi-objcopy arm-linux-gnueabihf-objcopy
# _arm-linux-objcopy — GNU binutils arm-linux-objcopy CLI cross-arch ELF/COFF/binary object file manipulator copying converting filtering between formats with section selection address translation symbol renaming/stripping/keeping global hidden weak modification of ARM Linux relocatable shared libraries (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_arm-linux-objcopy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-I+[input format]:f:(binary ihex srec symbolsrec verilog tekhex elf32-little elf32-big elf32-littlearm elf32-bigarm elf64-littleaarch64)' \
        '--input-target=+[fmt]:f:(binary ihex srec symbolsrec verilog tekhex elf32-littlearm elf32-bigarm)' \
        '-O+[output format]:f:(binary ihex srec symbolsrec verilog tekhex elf32-little elf32-big elf32-littlearm elf32-bigarm elf64-littleaarch64)' \
        '--output-target=+[fmt]:f:(binary ihex srec symbolsrec verilog tekhex elf32-littlearm elf32-bigarm)' \
        '-F+[bfd target]:str:' \
        '--target=+[bfd target]:str:' \
        '-B+[bfd arch]:a:(arm thumb)' \
        '--binary-architecture=+[arch]:str:' \
        '-S[strip all symbols]' \
        '--strip-all[strip all symbols]' \
        '-g[strip debug]' \
        '--strip-debug[strip debug]' \
        '--strip-unneeded[strip unneeded]' \
        '-K+[keep symbol]:str:' \
        '--keep-symbol=+[symbol]:str:' \
        '-N+[strip symbol]:str:' \
        '--strip-symbol=+[symbol]:str:' \
        '-L+[localize symbol]:str:' \
        '--localize-symbol=+[symbol]:str:' \
        '-G+[keep global symbol]:str:' \
        '--keep-global-symbol=+[symbol]:str:' \
        '-W+[weaken symbol]:str:' \
        '--weaken-symbol=+[symbol]:str:' \
        '-w[wildcards]' \
        '--wildcard[wildcards]' \
        '-x[discard all]' \
        '--discard-all[discard all]' \
        '-X[discard locals]' \
        '--discard-locals[discard locals]' \
        '-j+[section]:str:' \
        '--only-section=+[section]:str:' \
        '-R+[section]:str:' \
        '--remove-section=+[section]:str:' \
        '--rename-section=+[old=new]:str:' \
        '--change-section-address=+[s=val]:str:' \
        '--change-addresses=+[val]:str:' \
        '--set-section-flags=+[s=flag]:str:' \
        '--add-section=+[name=file]:str:' \
        '--update-section=+[name=file]:str:' \
        '--dump-section=+[name=file]:str:' \
        '-p[preserve dates]' \
        '--preserve-dates[preserve dates]' \
        '*:file:_files'
}

_arm-linux-objcopy "$@"
