#compdef windapsearch
# Documentation: https://man.archlinux.org/search?q=windapsearch
# Reference accessed: 2026-05-16

_arguments -s \
  '(-d --domain)'{-d,--domain}'=[domain FQDN]:domain:' \
  '--dc-ip=[DC IP]:ip:' \
  '(-u --user)'{-u,--user}'=[username]:user:' \
  '(-p --password)'{-p,--password}'=[password]:pw:' \
  '--functionality[domain functionality level]' \
  '(-G --groups)'{-G,--groups}'[enumerate groups]' \
  '(-U --users)'{-U,--users}'[enumerate users]' \
  '(-PU --privileged-users)'{-PU,--privileged-users}'[privileged users]' \
  '(-C --computers)'{-C,--computers}'[enumerate computers]' \
  '(-m --members)'{-m,--members}'=[group name]:group:' \
  '--da[Domain Admins]' \
  '--admin-objects[protected ACL objects]' \
  '--user-spns[users with SPNs]' \
  '--unconstrained-users[unconstrained users]' \
  '--unconstrained-computers[unconstrained computers]' \
  '--gpos[GPOs]' \
  '(-s --search)'{-s,--search}'=[search term]:term:' \
  '(-l --lookup)'{-l,--lookup}'=[lookup DN]:dn:' \
  '--custom=[LDAP filter]:filter:' \
  '(-r --resolve)'{-r,--resolve}'[resolve via DNS]' \
  '--attrs=[custom attributes]:attrs:' \
  '--full[dump all attributes]' \
  '(-o --output)'{-o,--output}'=[output dir]:dir:_files -/'
