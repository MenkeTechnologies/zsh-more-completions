#compdef rnr

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --dry-run)'{-d,--dry-run}'[show what would be renamed]' \
  '(-f --force)'{-f,--force}'[force overwrite existing files]' \
  '(-r --recursive)'{-r,--recursive}'[rename files recursively]' \
  '(-x --regex)'{-x,--regex}'[use regex instead of literal]' \
  '--max-depth[maximum directory depth]:depth' \
  '(-s --silent)'{-s,--silent}'[suppress output]' \
  '--dump[dump operations to file]:file:_files' \
  '--no-dump[do not create dump file]' \
  '--color[colorize output]:when:(always never auto)' \
  '--include[include files matching pattern]:pattern' \
  '--exclude[exclude files matching pattern]:pattern' \
  '--include-dirs[include directories in renaming]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:search pattern' \
  '2:replacement' \
  '*:file:_files' && ret=0
return ret
