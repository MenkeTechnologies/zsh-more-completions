#compdef deghosting_mask
# Documentation: https://man.archlinux.org/man/deghosting_mask.1.en
# deghosting_mask: generate deghosting masks for HDR/exposure stacks

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-o --output)'{-o+,--output=}'[prefix for output masks]:prefix:' \
  '(-s --sigma)'{-s+,--sigma=}'[std dev of Gaussian weighting (default 30)]:sigma:' \
  '(-i --iterations)'{-i+,--iterations=}'[number of iterations (default 4)]:iter:' \
  '(-t --threshold)'{-t+,--threshold=}'[threshold (default 150)]:threshold:' \
  '(-c --contrast)'{-c+,--contrast=}'[change contrast before threshold (default 1.3)]:contrast:' \
  '(-a --advanced)'{-a+,--advanced=}'[advanced computation settings f|g|m|t|w]:advanced:' \
  '(-w --save)'{-w+,--save=}'[advanced save settings for weights i|w]:save:' \
  '-b+[image cache blocksize in KB (default 2048)]:kb:' \
  '-m+[image cachesize in MB (default 1024)]:mb:' \
  '(-v --verbose)'{-v+,--verbose=}'[verbose 0|1]:level:(0 1)' \
  '*:image:_files' && ret=0

return ret
