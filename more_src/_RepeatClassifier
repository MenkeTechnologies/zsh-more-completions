#compdef RepeatClassifier
# Documentation: https://github.com/Dfam-consortium/RepeatModeler/blob/master/RepeatClassifier
# RepeatModeler: classify consensus repeat models against known libraries

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[detailed help]' \
  '-consensi[repeat model (consensus) fasta file]:file:_files' \
  '-stockholm[stockholm seed alignment file]:file:_files' \
  '-threads[number of parallel threads]:threads:' \
  '-preserve_class[keep existing classifications]' \
  '-debug[enable debug output]' && ret=0

return ret
