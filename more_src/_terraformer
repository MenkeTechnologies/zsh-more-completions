#compdef terraformer

# Zsh completion for terraformer - generate Terraform files from existing infrastructure

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'import:import current state to Terraform configuration'
  'plan:plan to import current state to Terraform configuration'
  'version:show version'
  'help:show help'
  'completion:generate shell completion'
)

local -a providers=(
  'aws:Amazon Web Services'
  'google:Google Cloud Platform'
  'azure:Microsoft Azure'
  'alicloud:Alibaba Cloud'
  'azuread:Azure Active Directory'
  'datadog:Datadog'
  'digitalocean:DigitalOcean'
  'github:GitHub'
  'gitlab:GitLab'
  'hetzner:Hetzner Cloud'
  'kubernetes:Kubernetes'
  'linode:Linode'
  'openstack:OpenStack'
  'rancher:Rancher'
  'vault:HashiCorp Vault'
  'vsphere:VMware vSphere'
  'fastly:Fastly'
  'ibm:IBM Cloud'
  'oci:Oracle Cloud Infrastructure'
  'cloudflare:Cloudflare'
  'heroku:Heroku'
  'ns1:NS1'
  'newrelic:New Relic'
  'pagerduty:PagerDuty'
  'relic:New Relic'
  'okta:Okta'
  'keycloak:Keycloak'
  'logzio:Logz.io'
  'launchdarkly:LaunchDarkly'
  'mikrotik:Mikrotik'
  'mygithub:MyGithub'
  'opsgenie:Opsgenie'
  'panos:PAN-OS'
  'yandex:Yandex'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'terraformer command' commands && ret=0
    ;;
  args)
    case $words[1] in
      import|plan)
        _arguments \
          '(-p --provider)'{-p,--provider}'[provider to use]:provider:(($providers))' \
          '(-r --resources)'{-r,--resources}'[resources to import]:resources:' \
          '(-R --regions)'{-R,--regions}'[list of regions]:regions:' \
          '--projects[list of projects]:projects:' \
          '(-f --filter)'{-f,--filter}'[filter resources]:filter:' \
          '(-o --output)'{-o,--output}'[output format]:format:(hcl json)' \
          '(-s --state)'{-s,--state}'[state backend]:state:(local bucket remote)' \
          '(-b --bucket)'{-b,--bucket}'[S3 bucket name for state]:bucket:' \
          '--path-pattern[output path pattern]:pattern:' \
          '--path-output[base output path]:path:_directories' \
          '--compact[generate a single state file]' \
          '(-x --excludes)'{-x,--excludes}'[exclude resources]:excludes:' \
          '--retry-number[number of retries]:num:' \
          '--retry-sleep-ms[retry sleep in milliseconds]:ms:' \
          '--profile[AWS profile]:profile:' \
          '--connect[connect resources with each other]' \
          '--resource-group[resource group (Azure)]:group:' && ret=0
        ;;
    esac
    ;;
esac

return ret
