#compdef sweagent

_sweagent() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Display help for any command]'
        '--version[Show the version number]'
    )

    subcmds=(
        'run:Run the agent on a single problem or issue'
        'run-batch:Run the agent on a list of problem statements'
        'run-replay:Replay a trajectory file or demo'
        'inspect:Open the command-line trajectory inspector'
        'inspector:Open the web-based trajectory inspector'
        'quick-stats:Display a summary of metrics for trajectories'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'sweagent commands' subcmds
            ;;
        args)
            case $line[1] in
                run)
                    _arguments \
                        '--agent.model.name=[The model to use]:model:' \
                        '--agent.model.per_instance_cost_limit=[Maximum dollar amount per task]:limit:' \
                        '--agent.config_file=[Path to custom agent config]:file:_files' \
                        '--problem_statement.github_url=[URL to a GitHub issue]:url:' \
                        '--problem_statement.text=[Raw string describing the task]:text:' \
                        '--problem_statement.path=[Path to local problem file]:file:_files' \
                        '--env.repo.github_url=[URL of the GitHub repo to work on]:url:' \
                        '--env.repo.path=[Path to local repository]:directory:_files -/' \
                        '--env.deployment.image=[Docker image for execution environment]:image:' \
                        '--env.deployment.type=[Environment type]:type:(docker modal)' \
                        '--actions.apply_patch_locally[Apply generated fix to local files]' \
                        '--actions.open_pr[Automatically open a Pull Request]' \
                        '--output_dir=[Directory for trajectories and logs]:directory:_files -/'
                    ;;
                run-batch)
                    _arguments \
                        '--subset=[SWE-bench subset to use]:subset:(lite verified)' \
                        '--split=[Dataset split]:split:(dev test)' \
                        '--workers=[Number of parallel worker threads]:number:' \
                        '--slice=[Process a specific range of instances]:range:'
                    ;;
            esac
            ;;
    esac
}

_sweagent "$@"
