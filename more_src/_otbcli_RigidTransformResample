#compdef otbcli_RigidTransformResample
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_RigidTransformResample.html
# Orfeo ToolBox: resample an image using a rigid transform (scale, translation, rotation)

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to translate]:image:_files' \
  '-out[transformed output image]:output:_files' \
  '-transform.type[type of transformation]:type:(id translation rotation)' \
  '-transform.type.id.scalex[output/input X spacing scaling factor]:value:' \
  '-transform.type.id.scaley[output/input Y spacing scaling factor]:value:' \
  '-transform.type.translation.tx[translation along X axis]:value:' \
  '-transform.type.translation.ty[translation along Y axis]:value:' \
  '-transform.type.translation.scalex[X spacing scaling factor]:value:' \
  '-transform.type.translation.scaley[Y spacing scaling factor]:value:' \
  '-transform.type.rotation.angle[rotation angle in degrees]:value:' \
  '-transform.type.rotation.scalex[X spacing scale factor]:value:' \
  '-transform.type.rotation.scaley[Y spacing scale factor]:value:' \
  '-interpolator[interpolation method]:interp:(bco nn linear)' \
  '-interpolator.bco.radius[bicubic interpolation filter size]:radius:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
