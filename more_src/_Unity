#compdef Unity
# Documentation: https://docs.unity3d.com/6000.0/Documentation/Manual/EditorCommandLineArguments.html
# Unity Editor command line arguments

local ret=1

_arguments -s -S \
  '-batchmode[run Unity in batch mode without GUI]' \
  '-quit[quit Unity after executing other commands]' \
  '-nographics[do not initialize the graphics device]' \
  '-accept-apiupdate[accept API updater changes in batch mode]' \
  '-ignorecompilererrors[continue despite script compiler errors]' \
  '-silent-crashes[do not display crash dialog]' \
  '-executeMethod[execute static method on open]:method (Class.Method):' \
  '-projectPath[open the project at the given path]:path:_files -/' \
  '-createProject[create a new project at the given path]:path:_files -/' \
  '-cloneFromTemplate[create project from template]:template:_files' \
  '-buildTarget[set the active build target]:target:(Win64 Win Android iOS WebGL Linux64 OSXUniversal PS4 PS5 XboxOne Switch tvOS)' \
  '-standaloneBuildSubtarget[set standalone build subtarget]:subtarget:(Player Server)' \
  '-activeBuildProfile[set the active build profile]:profile:_files' \
  '-build[build a player]:path:_files' \
  '-buildLinux64Player[build a 64-bit Linux player]:path:_files' \
  '-buildOSXUniversalPlayer[build a macOS universal player]:path:_files' \
  '-buildWindowsPlayer[build a 32-bit Windows player]:path:_files' \
  '-buildWindows64Player[build a 64-bit Windows player]:path:_files' \
  '-logFile[redirect Editor log output to the given file]:path:_files' \
  '-exportPackage[export a package]:asset path:_files' \
  '-importPackage[import a package]:path:_files' \
  '-openfile[open the given file]:path:_files' \
  '-username[Unity account username for activation]:username:' \
  '-password[Unity account password for activation]:password:' \
  '-serial[Unity serial key for activation]:serial:' \
  '-returnlicense[return the active license]' \
  '-createManualActivationFile[create a manual activation file]' \
  '-manualLicenseFile[the .ulf license file to activate]:file:_files' \
  '-vcsMode[set the version control mode]:mode:' \
  '-disable-assembly-updater[disable the assembly updater]:assemblies:' \
  '-stackTraceLogType[set stack trace log type]:type:(None ScriptOnly Full)' \
  '-cacheServerEndpoint[connect to the accelerator/cache server]:host\:port:' \
  '-EnableCacheServer[enable the cache server]' \
  '-force-d3d11[use Direct3D 11 for rendering]' \
  '-force-d3d12[use Direct3D 12 for rendering]' \
  '-force-glcore[use OpenGL core for rendering]' \
  '-force-vulkan[use Vulkan for rendering]' \
  '-force-metal[use Metal for rendering (macOS)]' \
  '-force-opengl[use legacy OpenGL for rendering]' \
  '-force-clamped[disable OpenGL extensions]' \
  '-version[print the Unity version and quit]' \
  '-timestamps[prefix log messages with a timestamp]' \
  '-disableManagedDebugger[disable the managed debugger listen socket]' \
  '-deepprofiling[enable deep profiling]' \
  '-profiler-enable[enable the profiler]' \
  '-profiler-log-file[write profiler stream to file]:path:_files' \
  '-rebuildLibrary[rebuild the project Library folder]' \
  '*::arg:_files' && ret=0

return ret
