#compdef vorpaview
# Documentation: https://github.com/BrunoLevy/geogram/wiki/Vorpaline
# Geogram vorpaview (GeoView): interactive mesh viewer

local ret=1

_arguments -s -S \
  '*gfx\:GL_profile=[OpenGL profile]:profile:(core compatibility ES)' \
  '*gfx\:GL_debug=[enable OpenGL debugging]:val:(true false)' \
  '*gfx\:full_screen=[start in full screen]:val:(true false)' \
  '*gui\:font_size=[font size]:size:' \
  '*sys\:multithread=[enable multi-threaded computations]:val:(true false)' \
  '*debug=[toggle debug mode]:debug:(true false)' \
  '*:mesh:_files' && ret=0

return ret
