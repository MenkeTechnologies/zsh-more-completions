  '--general-bd-mpeg4-hpst[General Purpose BD Interchange with MPEG-4 Stereo HiP@Level4.2]' \
  '--usb-and-flash-jpeg[General Purpose USB/Flash Memory Interchange with JPEG]' \
  '-Pfl[General Purpose USB/Flash Memory Interchange with JPEG]' \
  '--usb-and-flash-j2k[General Purpose USB/Flash Memory Interchange with JPEG 2000]' \
  '-Pf2[General Purpose USB/Flash Memory Interchange with JPEG 2000]' \
  '--general-mime[General Purpose MIME Interchange]' \
  '-Pmi[General Purpose MIME Interchange]' \
  '--mpeg2-mpml-dvd[DVD Interchange with MPEG2 Main Profile @ Main Level]' \
  '-Pmp[DVD Interchange with MPEG2 Main Profile @ Main Level]' \
  '--basic-cardiac[Basic Cardiac X-Ray Angiographic Studies on CD-R]' \
  '-Pbc[Basic Cardiac X-Ray Angiographic Studies on CD-R]' \
  '--xray-angiographic[1024 X-Ray Angiographic Studies on CD-R Media]' \
