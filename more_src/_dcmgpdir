  '(-A --replace)'{-A,--replace}'[replace existing DICOMDIR (default)]' \
  '(+A --append)'{+A,--append}'[append to existing DICOMDIR]' \
  '(+U --update)'{+U,--update}'[update existing DICOMDIR]' \
  '(-w --discard)'{-w,--discard}'[do not write out DICOMDIR]' \
  '--create-backup[create a backup of existing DICOMDIR (default)]' \
  '(-nb --no-backup)'{-nb,--no-backup}'[do not create a backup of existing DICOMDIR]' \
  '(+u --enable-new-vr)'{+u,--enable-new-vr}'[enable support for new VRs (UN/UT) (default)]' \
  '(-u --disable-new-vr)'{-u,--disable-new-vr}'[disable support for new VRs, convert to OB]' \
  '(-g --group-length-remove)'{-g,--group-length-remove}'[write without group length elements (default)]' \
  '(+g --group-length-create)'{+g,--group-length-create}'[write with group length elements]' \
  '(+e --length-explicit)'{+e,--length-explicit}'[write with explicit lengths (default)]' \
  '(-e --length-undefined)'{-e,--length-undefined}'[write with undefined lengths]' \
  '*:dcmfile-in:_files'
