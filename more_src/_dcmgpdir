  '--general-bd-j2k[General Purpose BD Interchange with JPEG 2000]' \
  '-Pb2[General Purpose BD Interchange with JPEG 2000]' \
  '--general-bd-mpeg2-mpml[General Purpose BD Interchange with MPEG2 MP@ML]' \
  '-Pbm[General Purpose BD Interchange with MPEG2 MP@ML]' \
  '--general-bd-mpeg2-mphl[General Purpose BD Interchange with MPEG2 MP@HL]' \
  '-Pbh[General Purpose BD Interchange with MPEG2 MP@HL]' \
  '--general-bd-mpeg4-hp[General Purpose BD Interchange with MPEG-4 HiP@Level4.1]' \
  '-Pba[General Purpose BD Interchange with MPEG-4 HiP@Level4.1]' \
  '--general-bd-mpeg4-hpbd[General Purpose BD Interchange with MPEG-4 BD-Compatible HiP@Level4.1]' \
  '-Pbb[General Purpose BD Interchange with MPEG-4 BD-Compatible HiP@Level4.1]' \
  '--general-bd-mpeg4-hp2d[General Purpose BD Interchange with MPEG-4 HiP@Level4.2 for 2D video]' \
