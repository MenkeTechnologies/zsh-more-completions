  '--xray-angiographic-dvd[1024 X-Ray Angiographic Studies on DVD Media]' \
  '-Pxd[1024 X-Ray Angiographic Studies on DVD Media]' \
  '--dental-radiograph[Dental Radiograph Interchange]' \
  '-Pde[Dental Radiograph Interchange]' \
  '--ct-and-mr[CT/MR Studies]' \
  '-Pcm[CT/MR Studies]' \
  '--ultrasound-id-sf[Ultrasound Single Frame for Image Display]' \
  '-Pus[Ultrasound Single Frame for Image Display]' \
  '--ultrasound-sc-sf[Ultrasound Single Frame with Spatial Calibration]' \
  '--ultrasound-cc-sf[Ultrasound Single Frame with Combined Calibration]' \
  '--ultrasound-id-mf[Ultrasound Single & Multi-Frame for Image Display]' \
  '-Pum[Ultrasound Single & Multi-Frame for Image Display]' \
  '--ultrasound-sc-mf[Ultrasound Single & Multi-Frame with Spatial Calibration]' \
