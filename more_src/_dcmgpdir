#compdef dcmgpdir
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmgpdir.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmdata/apps/dcmgpdir.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmdata/apps/dcmgpdir.cc OFCommandLine setup + docs/man/dcmgpdir.man.
# Note: dcmgpdir is a proxy stub that forwards to dcmmkdir; option set comes from
# dcmjpeg/apps/dcmmkdir.cc. The older dcmgpdir-only interface no longer exists upstream.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+F --fileset-id)'{+F+,--fileset-id=}'[use specific file-set ID]:id:' \
  '(+R --descriptor)'{+R+,--descriptor=}'[add a file-set descriptor file ID]:filename:_files' \
  '(+C --char-set)'{+C+,--char-set=}'[add a specific character set for descriptor]:charset:' \
  '(+id --input-directory)'{+id+,--input-directory=}'[read referenced DICOM files from directory]:directory:_files -/' \
  '(-m --keep-filenames)'{-m,--keep-filenames}'[expect filenames to be in DICOM format (default)]' \
  '(+m --map-filenames)'{+m,--map-filenames}'[map to DICOM filenames (lowercase->uppercase, strip trailing period)]' \
  '(-r --no-recurse)'{-r,--no-recurse}'[do not recurse within directories (default)]' \
  '(+r --recurse)'{+r,--recurse}'[recurse within filesystem directories]' \
  '(+p --pattern)'{+p+,--pattern=}'[pattern for filename matching (only with --recurse)]:pattern:' \
  '(-W --no-consistency-check)'{-W,--no-consistency-check}'[do not check files for consistency]' \
  '(+W --warn-inconsist-files)'{+W,--warn-inconsist-files}'[warn about inconsistent files (default)]' \
  '(-a --abort-inconsist-file)'{-a,--abort-inconsist-file}'[abort on first inconsistent file]' \
  '(-I --strict)'{-I,--strict}'[exit with error if DICOMDIR type 1 attributes missing (default)]' \
  '(+I --invent)'{+I,--invent}'[invent DICOMDIR type 1 attributes if missing]' \
  '(+Ipi --invent-patient-id)'{+Ipi,--invent-patient-id}'[invent new PatientID for inconsistent PatientName]' \
  '(+Nrs --allow-retired-sop)'{+Nrs,--allow-retired-sop}'[allow retired SOP classes from previous editions]' \
  '(-Nxc --no-xfer-check)'{-Nxc,--no-xfer-check}'[do not reject images with non-standard transfer syntax]' \
  '(-Nec --no-encoding-check)'{-Nec,--no-encoding-check}'[do not reject images with non-standard pixel encoding]' \
  '(-Nrc --no-resolution-check)'{-Nrc,--no-resolution-check}'[do not reject images with non-standard spatial resolution]' \
  '(+X --add-icon-image)'{+X,--add-icon-image}'[add monochrome icon image on IMAGE level]' \
  '(-Xs --icon-image-size)'{-Xs+,--icon-image-size=}'[width and height of icon image in pixels (1..128)]:size:' \
  '(-Xi --icon-file-prefix)'{-Xi+,--icon-file-prefix=}'[use PGM image as icon]:prefix:' \
  '(-Xd --default-icon)'{-Xd+,--default-icon=}'[use PGM image if auto-creation fails]:filename:_files' \
  '(+D --output-file)'{+D+,--output-file=}'[generate specific DICOMDIR file]:filename:_files' \
  '--general-purpose[General Purpose Interchange on CD/DVD-RAM/BD (default)]' \
  '-Pgp[General Purpose Interchange on CD/DVD-RAM/BD (default)]' \
  '--general-dvd-jpeg[General Purpose DVD Interchange with JPEG]' \
  '-Pdv[General Purpose DVD Interchange with JPEG]' \
  '--general-dvd-j2k[General Purpose DVD Interchange with JPEG 2000]' \
  '-Pd2[General Purpose DVD Interchange with JPEG 2000]' \
  '--general-bd-jpeg[General Purpose BD Interchange with JPEG]' \
