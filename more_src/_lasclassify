#compdef lasclassify
# LAStools: classify buildings and high vegetation in LAS/LAZ files

local ret=1

_arguments -s -S \
  '-help[print help output]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '-demo[run in demo mode]' \
  '-verbose[print extra information]' \
  '-planar+[stddev up to n are potential roofs (default 0.1)]:stddev' \
  '-rugged+[stddev above n are potential vegetation (default 0.4)]:stddev' \
  '-ground_offset+[threshold above ground to consider (default 2)]:meters' \
  '-step+[grid cell size for analysis (default 2)]:meters' \
  '-small_buildings[do not discard overly small buildings]' \
  '-small_trees[do not discard overly small trees]' \
  '-height_in_attribute+[use height from extra attribute]:n' \
  '-height_in_z[interpret z value as normalized height]' \
  '-keep_overhang[keep vegetation overhanging buildings]' \
  '-no_gutters[skip completing roof edges]' \
  '-wide_gutters[enhanced roof edge completion]' \
  '-sub+[use n substeps for analysis]:n' \
  '-feet[use feet for measurements]' \
  '-elevation_feet[use feet for elevation]' \
  '*-i+[input file or mask]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-olay[write classification changes to LASlayers file]' \
  '-olaydir+[output LASlayers directory]:dir:_files -/' \
  '-cores+[process on N parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
