#compdef stressapptest
# Documentation: https://github.com/stressapptest/stressapptest
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-W[use weighted random distribution]' \
  '-m+[memory threads]:n:' \
  '-M+[memory in MB]:mb:' \
  '-C+[cpu stress threads]:n:' \
  '-s+[seconds to run]:sec:' \
  '-i+[invert thread count]:n:' \
  '-f+[temp file]:file:_files' \
  '-l+[log file]:file:_files' \
  '-p+[page size]:bytes:' \
  '-n+[network thread count]:n:' \
  '-H+[network host]:host:_hosts' \
  '--no_errors[stop on first error]' \
  '--max_errors=+[max errors]:n:' \
  '--printsec=+[print every sec]:sec:' \
  '--pause_delay=+[pause delay sec]:sec:' \
  '--pause_duration=+[pause duration sec]:sec:' \
  '--listsize=+[list size]:n:' && ret=0

return ret
