#compdef venc_data_dump
# Documentation: https://github.com/FFmpeg/FFmpeg/blob/master/tools/venc_data_dump.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# FFmpeg developer tool: dump video encoder side-data per frame
# Usage: venc_data_dump <input file> <stream index> <max frame count> [<thread count> <thread type>]
local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:stream index:' \
  '3:max frame count:' \
  '4:thread count:' \
  '5:thread type:' && ret=0

return ret
