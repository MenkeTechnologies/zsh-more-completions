#compdef docx2txt docx2txt.pl
# Documentation: https://docx2txt.sourceforge.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# docx2txt is a Perl utility to convert DOCX to plain text. Accepts an input
# file (or stdin) and optional output file (or stdout). No flag options are
# documented; behavior is controlled via docx2txt.config.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input file:_files -g "*.{docx,DOCX}"' \
  '2:output file:_files -g "*.txt"' && ret=0

return ret
