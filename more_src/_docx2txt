#compdef docx2txt
# Documentation: https://man.archlinux.org/search?q=docx2txt
# Reference accessed: 2026-05-16

# Completion for docx2txt - Convert DOCX to plain text

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:input file:_files -g "*.{docx,DOCX}"' \
  '2:output file:_files -g "*.txt"' && ret=0

return ret
