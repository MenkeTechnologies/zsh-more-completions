#compdef dumbpipe
# Documentation: https://github.com/n0-computer/dumbpipe
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/n0-computer/dumbpipe — src/main.rs (nested Connect/Listen args omitted; use --help)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _dp_cmds
    _dp_cmds=(
      'generate-ticket:print connection ticket'
      listen:'stdio pipe ← QUIC'
      'listen-tcp':forward QUIC streams to TCP
      connect:'stdio ↔ remote pipe via ticket'
      'connect-tcp':pipe QUIC to local TCP listener
      'listen-unix':forward to unix socket
      'connect-unix':bridge local unix socket
    )
    _describe -t commands 'dumbpipe mode' _dp_cmds && ret=0
    ;;
esac

return ret
