#compdef rsgain
# Documentation: https://manpages.debian.org/testing/rsgain/rsgain.1.en.html
# ReplayGain 2.0 loudness normalizer

local ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version number]' \
  '1:command:((easy\:"recursively scan a directory with recommended settings" custom\:"scan individual files with custom settings"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      easy)
        _arguments -s -S \
          '(-m --multithreaded)'{-m+,--multithreaded=}'[enable multithreaded scanning]:threads' \
          '(-S --skip-existing)'{-S,--skip-existing}'[skip files with existing ReplayGain information]' \
          '(-O --output)'{-O,--output}'[save scan logs as tab-delimited CSV files]' \
          '-p+[specify a preset configuration file or preset name]:preset' \
          '-q[disable progress bar output]' \
          '*:directory:_files -/' && ret=0
        ;;
      custom)
        _arguments -s -S \
          '(-a --album)'{-a,--album}'[calculate album gain and peak]' \
          '(-s --tagmode)'{-s+,--tagmode=}'[tag mode]:mode:(s d i)' \
          '(-l --target-loudness)'{-l+,--target-loudness=}'[target loudness in LUFS]:lufs' \
          '(-c --clip-mode)'{-c+,--clip-mode=}'[clipping protection mode]:mode:(n p a)' \
          '(-t --true-peak)'{-t,--true-peak}'[use true peak for peak calculations]' \
          '(-L --lowercase)'{-L,--lowercase}'[write lowercase tags]' \
          '(-I --id3v2-version)'{-I+,--id3v2-version=}'[ID3v2 version]:version' \
          '(-m --max-peak)'{-m+,--max-peak=}'[maximum peak level]:level' \
          '(-o --opus-mode)'{-o+,--opus-mode=}'[Opus file tagging mode]:mode:(d r s t a)' \
          '(-p --preserve-mtimes)'{-p,--preserve-mtimes}'[preserve file modification times]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '*:audio file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
