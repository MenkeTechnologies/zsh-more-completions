#compdef ipa-server-upgrade
# Documentation: https://man.archlinux.org/search?q=ipa-server-upgrade
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--skip-version-check)--skip-version-check[skip version check]' && ret=0

return ret
