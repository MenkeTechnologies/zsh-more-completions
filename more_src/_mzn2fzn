#compdef mzn2fzn
# Documentation: https://docs.minizinc.dev/en/stable/command_line.html
# MiniZinc to FlatZinc compiler (flattener)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--version[display version information]' \
  '(-v -l --verbose)'{-v,-l,--verbose}'[print progress/log statements]' \
  '(-s --statistics)'{-s,--statistics}'[print compilation statistics]' \
  '--no-optimize[skip FlatZinc optimization]' \
  '(-m --model)'{-m,--model}'[specify model file]:file:_files' \
  '(-d --data)'{-d,--data}'[specify data file]:file:_files' \
  '(-D --cmdline-data)'{-D,--cmdline-data}'[include data assignment]:data' \
  '--cmdline-json-data[include JSON data]:data' \
  '--stdlib-dir[path to standard library]:dir:_files -/' \
  '(-G --globals-dir --mzn-globals-dir)'{-G,--globals-dir,--mzn-globals-dir}'[globals search directory]:dir:_files -/' \
  '*'{-I,--search-dir}'[additional search directory]:dir:_files -/' \
  '--allow-multiple-assignments[allow variable reassignment]' \
  '--two-pass[flatten twice for better decisions]' \
  '--use-gecode[root-node propagation with Gecode]' \
  '--shave[probe variable bounds at root]' \
  '--sac[probe variable values at root]' \
  '--pre-passes[number of preprocessing passes]:n' \
  '--output-base[base name for outputs]:name' \
  '(--fzn --output-fzn-to-file)'{--fzn,--output-fzn-to-file}'[FlatZinc output file]:file:_files' \
  '(-O --ozn --output-ozn-to-file)'{-O,--ozn,--output-ozn-to-file}'[output specification file]:file:_files' \
  '--output-mode[output format]:mode:(item dzn json)' \
  '--output-objective[include objective value]' \
  '-Werror[treat warnings as errors]' \
  '*:file:_files' && ret=0

return ret
