#compdef polysh
# Documentation: https://github.com/innogames/polysh
# polysh - control thousands of remote shells simultaneously

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show program version number]' \
  '--hosts-file=[read hostnames from given file, one per line]:file:_files' \
  '--command=[command to execute on the remote shells]:command' \
  '--ssh=[command to use for ssh]:ssh command' \
  '--user=[remote user to log in as]:user:_users' \
  '--password-file=[read a password from the specified file]:file:_files' \
  '--log-file=[file to log each machine conversation]:file:_files' \
  '--abort-errors[abort if some shell fails to initialize]' \
  '--no-color[disable colored hostnames]' \
  '--debug[print debugging information]' \
  '*:host:_hosts' && ret=0

return ret
