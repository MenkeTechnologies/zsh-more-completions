#compdef rsem-calculate-expression
# Documentation: https://deweylab.github.io/RSEM/rsem-calculate-expression.html
# RSEM: estimate gene and isoform expression levels from RNA-seq data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--paired-end[paired-end input reads]' \
  '--no-qualities[input lacks quality scores]' \
  '--strandedness=[RNA-seq protocol strandedness]:strandedness:(none forward reverse)' \
  '(-p --num-threads)'{-p,--num-threads}'=[thread count]:int' \
  '--alignments[input contains SAM/BAM/CRAM alignments]' \
  '--fai=[FAI reference file]:fai file:_files' \
  '--bowtie2[use Bowtie 2 aligner]' \
  '--star[use STAR aligner]' \
  '--hisat2-hca[use HISAT2 with HCA parameters]' \
  '--append-names[append gene/transcript names to output IDs]' \
  '--seed=[RNG seed]:uint32' \
  '--single-cell-prior[apply Dirichlet(0.1) prior]' \
  '--calc-pme[calculate posterior mean estimates]' \
  '--calc-ci[calculate 95% credibility intervals]' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging output]' \
  '--sort-bam-by-read-name[sort transcript BAM by read names]' \
  '--no-bam-output[omit BAM generation]' \
  '--sampling-for-bam[sample single alignment per read in BAM]' \
  '--output-genome-bam[create genomic coordinate BAM]' \
  '--sort-bam-by-coordinate[sort BAM by genomic coordinates]' \
  '--sort-bam-memory-per-thread=[memory limit per thread]:mem' \
  '--seed-length=[seed length for alignment]:int' \
  '--phred33-quals[Phred+33 quality scores]' \
  '--phred64-quals[Phred+64 quality scores]' \
  '--solexa-quals[Solexa-encoded quality scores]' \
  '--bowtie-path=[directory of Bowtie executables]:path:_files -/' \
  '--bowtie-n=[Bowtie seed mismatches]:int' \
  '--bowtie-e=[Bowtie quality score threshold]:int' \
  '--bowtie-m=[Bowtie alignment suppression limit]:int' \
  '--bowtie-chunkmbs=[Bowtie memory in MB]:int' \
  '--bowtie2-path=[directory of Bowtie 2 executables]:path:_files -/' \
  '--bowtie2-mismatch-rate=[max mismatch rate]:double' \
  '--bowtie2-k=[alignments per read to report]:int' \
  '--bowtie2-sensitivity-level=[sensitivity preset]:level:(very_fast fast sensitive very_sensitive)' \
  '--star-path=[directory of STAR executable]:path:_files -/' \
  '--star-gzipped-read-file[STAR: gzip-compressed input]' \
  '--star-bzipped-read-file[STAR: bzip2-compressed input]' \
  '--star-output-genome-bam[STAR: save genomic coordinate BAM]' \
  '--hisat2-path=[directory of HISAT2 executable]:path:_files -/' \
  '--tag=[SAM optional field for over-aligned reads]:string' \
  '--fragment-length-min=[minimum insert length]:int' \
  '--fragment-length-max=[maximum insert length]:int' \
  '--fragment-length-mean=[mean fragment length]:double' \
  '--fragment-length-sd=[fragment length std dev]:double' \
  '--estimate-rspd[learn read start position distribution]' \
  '--num-rspd-bins=[RSPD histogram bin count]:int' \
  '--gibbs-burnin=[Gibbs burn-in iterations]:int' \
  '--gibbs-number-of-samples=[Gibbs output samples]:int' \
  '--gibbs-sampling-gap=[iterations between samples]:int' \
  '--ci-credibility-level=[credibility interval level]:double' \
  '--ci-memory=[memory for CI buffer (MB)]:int' \
  '--ci-number-of-samples-per-count-vector=[theta samples per count vector]:int' \
  '--keep-intermediate-files[preserve temporary directory]' \
  '--temporary-folder=[custom temporary directory]:dir:_files -/' \
  '--time[output timing statistics]' \
  '--run-pRSEM[enable prior-enhanced RSEM mode]' \
  '--chipseq-peak-file=[ChIP-seq narrowPeak file]:file:_files' \
  '--chipseq-target-read-files=[ChIP-seq target FASTQ files]:files' \
  '--chipseq-control-read-files=[ChIP-seq control FASTQ files]:files' \
  '--chipseq-read-files-multi-targets=[multiple ChIP-seq target FASTQ files]:files' \
  '--chipseq-bed-files-multi-targets=[multiple ChIP-seq target BED files]:files' \
  '--cap-stacked-chipseq-reads[limit ChIP-seq reads at same interval]' \
  '--n-max-stacked-chipseq-reads=[max stacked ChIP-seq reads]:int' \
  '--partition-model=[partition model type]:model' \
  '*:read file, reference name or sample name:_files' && ret=0

return ret
