#compdef lwp-download.p6-j lwp-download.p6-js lwp-download.p6-m lwp-get.p6-j lwp-get.p6-js lwp-get.p6-m
# Documentation: https://man.archlinux.org/search?q=lwp-download.p6-j
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:URL:' \
  '2::output file:_files' && ret=0

return ret
