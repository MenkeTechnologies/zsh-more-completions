#compdef ppest
# Documentation: https://www.prinmath.com/pest/RunBeoPEST.pdf
# BeoPEST/Parallel PEST master; runs a PEST control file. Master: ppest case /H :port, slave: ppest case /H host:port

local ret=1

_arguments -s \
  '1:PEST control file:_files -g "*.pst"' \
  '*:/H arg - :port for master, host:port for slave:_default' && ret=0

return ret
