#compdef xfce4-mixer
# Documentation: https://github.com/xfce-mirror/xfce4-mixer/blob/master/xfce4-mixer/main.c
# Reference accessed: 2026-05-21
# Verified: xfce4-mixer main.c uses g_application_run with no custom
# GOptionEntry table. Only standard GTK options are accepted.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display]:display:' && ret=0
return ret
