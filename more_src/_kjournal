#compdef kjournal kjournaldbrowser
# Documentation: https://invent.kde.org/system/kjournald/-/raw/master/browser/main.cpp
# Reference accessed: 2026-05-16
# Verified: upstream KDE kjournald browser main.cpp. Real binary name
# is `kjournaldbrowser`; this completion accepts the shorter alias.
# Removed from prior file: bogus man.archlinux.org search URL.

# kjournal/kjournaldbrowser: KDE journald viewer
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-D[path to journald database folder]:dir:_files -/' && ret=0
return ret
