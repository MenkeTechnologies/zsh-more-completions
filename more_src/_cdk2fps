#compdef cdk2fps
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp fingerprint generator using the CDK toolkit

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--MACCS[create MACCS fingerprints]' \
  '--rdmaccs[generate RDMACCS fingerprints]' \
  '--id-tag=[identifier SD field]:tag:' \
  '-o+[output filename]:file:_files' \
  '--using=[reference fingerprint type from file]:file:_files' \
  '--errors=[error handling mode]:handler:(ignore report strict)' \
  '--no-progress[disable progress bar]' \
  '*:structure file:_files' && ret=0

return ret
