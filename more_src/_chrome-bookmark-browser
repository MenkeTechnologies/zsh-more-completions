#compdef chrome-bookmark-browser
# Documentation: https://man.archlinux.org/search?q=chrome-bookmark-browser
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help]'
    '--help[Show help]'
    '-v[Show version]'
    '--version[Show version]'
    '*:bookmark file:_files'
)

_arguments -s -S $arguments
