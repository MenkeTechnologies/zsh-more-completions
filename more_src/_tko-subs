#compdef tko-subs

_tko-subs() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '--domains=[file containing list of subdomains]:domains file:_files' \
        '--data=[path to providers JSON data file]:data file:_files' \
        '--output=[output file for results]:output file:_files' \
        '--threads=[number of concurrent threads]:threads:' \
        '--timeout=[connection timeout in seconds]:seconds:' \
        '--takeover[attempt subdomain takeover]' && ret=0

    return ret
}

_tko-subs "$@"
