#compdef yo

# Zsh completion for yo - Yeoman scaffolding tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[show help]' \
  '--generators[list available generators]' \
  '--version[show version]' \
  '--no-color[disable color output]' \
  '--insight[enable anonymous usage tracking]' \
  '--no-insight[disable anonymous usage tracking]' \
  '--force[overwrite files that already exist]' \
  '--skip-install[skip automatic installation of dependencies]' \
  '1:generator:->generators' \
  '*:: :->args' && ret=0

case $state in
  generators)
    local -a generators
    generators=(${(f)"$(yo --generators 2>/dev/null | grep -oE '^\s+\S+' | sed 's/^[[:space:]]*//')"})
    if (( ${#generators} )); then
      _describe -t generators 'generator' generators && ret=0
    fi
    ;;
esac

return ret
