#compdef inlyne
# Documentation: https://man.archlinux.org/search?q=inlyne
# Reference accessed: 2026-05-16

# https://github.com/Inlyne-Project/inlyne — src/opts/cli.rs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->tok' \
  '*::arg:->args' && ret=0

case $state in
  (tok)
    _alternative 'subcommands:config help:(config)' 'files:markdown file:_files -g "*.md"' && ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _arguments '2: :(open)' && ret=0 ;;
      (*)
        _arguments \
          '(-t --theme)'{-t,--theme}'=[theme]:theme:(auto dark light)' \
          '(-d --decorations)'{-d,--decorations}'[enable decorations]' \
          '(-s --scale)'{-s,--scale}'[ui scale]:factor:' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-w --page-width)'{-w+,--page-width=}'[max width]:width:' \
          '(-p --win-pos)'{-p+,--win-pos=}'[window x,y]:position:' \
          '--win-size=[window WxH]:size:' \
          '*::markdown:_files -g "*.md"' && ret=0
        ;;
    esac ;;
esac

return ret
