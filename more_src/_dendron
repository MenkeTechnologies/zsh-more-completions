#compdef dendron dendron-cli
# _dendron — Dendron dendron-cli hierarchical note-taking PKM CLI for Markdown vaults with schema-driven hierarchies bidirectional links pod export/import (dendronhq team, TypeScript); yargs
# upstream: https://github.com/dendronhq/dendron

_dendron() {
    local -a sub=(
        'init:initialize vault'
        'launch-engine-server:launch engine'
        'workspace:workspace operations'
        'launch:launch dendron'
        'vault:vault operations'
        'export:export notes'
        'import:import notes'
        'note:note operations'
        'publish:publish site'
        'doctor:doctor checks'
        'seed:seed operations'
        'dev:dev operations'
        'lookup:lookup notes'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--wsRoot=+[dir]:dir:_files -/' \
        '--vault=+[name]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dendron subcommand' sub ;;
        args)
            case $words[1] in
                init|workspace) _arguments \
                    '1:action:(init add remove list info publish-config)' \
                    '--type=+[t]:t:(blank scratch full)' ;;
                publish) _arguments \
                    '1:action:(init export dev preview build)' \
                    '--target=+[t]:t:(github netlify vercel aws)' \
                    '--asset-dir=+[dir]:dir:_files -/' \
                    '--output=+[dir]:dir:_files -/' ;;
                export|import) _arguments \
                    '--podId=+[id]:str:' \
                    '--config=+[file]:file:_files' \
                    '--vault=+[vault]:str:' \
                    '--noteHash=+[hash]:str:' ;;
                doctor) _arguments \
                    '--action=+[a]:a:(h1ToTitle backfill backlinks find-broken-links find-inline-code regenerateNoteId removeStubs createMissingLinkedNotes addMissingDefaultConfigs fixFrontmatter)' \
                    '--limit=+[N]:n:' \
                    '--dryRun[dry run]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_dendron "$@"
