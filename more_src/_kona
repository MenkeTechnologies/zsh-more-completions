# Zsh completion for the Kona K interpreter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[suppress boilerplate banner on startup]' \
  '-h+[bind HTTP server to port]:http-port:' \
  '-i+[bind IPC server to port]:ipc-port:' \
  '-e+[evaluate K expression and exit]:expr:' \
  '-x+[evaluate and print K expression at depth then exit]:expr:' \
  '*:script:_files' && ret=0

return ret
