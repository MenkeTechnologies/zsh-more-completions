#compdef ellfou
# Documentation: https://starlink.eao.hawaii.edu/docs/sun180.htx/sun180ss2.html
# ESP: ellipse fitting galaxy profiles using contour analysis.

local ret=1

_arguments -s -S \
  'IN=[source NDF data structure]:ndf:_files' \
  'OUT=[output text file for profile data]:file:_files' \
  'OUTCAT=[output catalogue file]:cat:_files' \
  'INFILE=[text file with galaxy coordinates]:file:_files' \
  'ARDFIL=[ARD file for masking regions]:file:_files' \
  'MODE=[interactive or file input mode]:flag:(TRUE FALSE)' \
  'DEVICE=[graphics device for results]:device:' \
  'IMGDEV=[graphics device displaying image]:device:' \
  'BACK=[background count value]:val:' \
  'SIGMA=[std deviation of background]:val:' \
  'PSIZE=[pixel size in arc seconds]:val:' \
  'ZEROP=[surface brightness zero point]:val:' \
  'ORIGIN=[galaxy origin coordinates]:coords:' \
  'RLIM=[profiling radius limit in pixels]:n:' \
  'FINE=[isophotal separation factor]:val:' \
  'LIM1=[max ratio for successive radii]:val:' \
  'LIM2=[lower mean profile count threshold]:val:' \
  'FRACT=[pixel presence fraction]:frac:' \
  'AUTOL=[improved galaxy centre estimation]:flag:(TRUE FALSE)' \
  'AUTOLT=[centroiding method selection]:flag:(TRUE FALSE)' \
  'FRZORI=[freeze origin coordinates]:flag:(TRUE FALSE)' \
  'CURSOR=[use graphics cursor or keyboard]:flag:(TRUE FALSE)' \
  'SAME=[display on current image device]:flag:(TRUE FALSE)' \
  'AGAIN=[repeat profiling operation]:flag:(TRUE FALSE)' \
  'COLOUR=[pen colour for centre marking]:n:' \
  'ANGCON=[position angle convention]:flag:(TRUE FALSE)' \
  'ANGOFF=[positive angle offset in degrees]:deg:' \
  '*:ndf:_files' && ret=0

return ret
