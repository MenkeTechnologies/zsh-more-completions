#compdef nextcloudcmd

# Zsh completion for nextcloudcmd - Nextcloud command line sync client

_arguments -s -S \
  '(-s --silent)'{-s,--silent}'[do not print log output]' \
  '--httpproxy=[HTTP proxy]:proxy url:' \
  '(-n --non-interactive)'{-n,--non-interactive}'[do not prompt for questions]' \
  '--max-sync-retries=[max sync retries]:retries:' \
  '--uplimit=[upload limit in KB/s]:KB/s:' \
  '--downlimit=[download limit in KB/s]:KB/s:' \
  '--exclude=[exclude file]:file:_files' \
  '--unsyncedfolders=[path to list of unsynced folders]:file:_files' \
  '-u+[username]:username:' \
  '-p+[password]:password:' \
  '--trust[trust SSL certificates]' \
  '--path=[path on server]:path:' \
  '--logdebug[more verbose logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:local directory:_files -/' \
  '2:server URL:'
