#compdef curlylint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--parse-only[only parse the templates, do not lint]' \
  '*--rule[specify a lint rule]:rule:' \
  '--config[configuration file]:config file:_files' \
  '--quiet[suppress non-error output]' \
  '--verbose[verbose output]' \
  '--format[output format]:format:(compact json stylish)' \
  '*--include[file patterns to include]:pattern:' \
  '*--exclude[file patterns to exclude]:pattern:' \
  '--version[show version]' \
  '--help[show help message]' \
  '*:file:_files' && ret=0

return ret
