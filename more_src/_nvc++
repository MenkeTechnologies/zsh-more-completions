#compdef nvc++
# Documentation: https://man.archlinux.org/search?q=nvc++
# Reference accessed: 2026-05-16

# nvc++: NVIDIA HPC C++ compiler (PGI replacement)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-V[show version]' \
  '-c[compile only]' \
  '-S[stop at assembly]' \
  '-o[output file]:file:_files' \
  '-I[include dir]:dir:_files -/' \
  '-L[library dir]:dir:_files -/' \
  '-l[library]:lib:' \
  '-O[opt level]:level:(0 1 2 3 4)' \
  '-g[debug info]' \
  '-fpic[generate PIC]' \
  '-mp[OpenMP]' \
  '-acc[OpenACC]' \
  '-stdpar[Standard parallelism (C++17/20)]' \
  '-gpu=[GPU target]:arch:' \
  '-fast[favor speed]' \
  '*:files:_files' && ret=0
return ret
