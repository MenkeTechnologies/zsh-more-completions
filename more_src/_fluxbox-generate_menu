#compdef fluxbox-generate_menu
# Documentation: https://github.com/fluxbox/fluxbox/blob/master/util/fluxbox-generate_menu.in
# Reference accessed: 2026-05-16
# Verified: upstream fluxbox-generate_menu shell script. Single-dash flags.
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# fluxbox-generate_menu: build Fluxbox menu from installed applications
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-a[show authors]' \
  '-k[insert KDE menu]' \
  '-g[add Gnome menu]' \
  '-B[add backgrounds menu]' \
  '-su[enable sudo commands]' \
  '-r[do not remove empty entries]' \
  '-d[extra .desktop search paths]:dirs:' \
  '-ds[broader desktop search]' \
  '-i[extra icon search paths]:dirs:' \
  '-is[broader icon search]' \
  '-in[skip icon search]' \
  '-t[terminal program]:terminal:_command_names' \
  '-w[default URL (default fluxbox.org)]:url:' \
  '-b[browser program]:browser:_command_names' \
  '-m[menu title (default Fluxbox)]:title:' \
  '-o[output path (default ~/.fluxbox/menu)]:file:_files' \
  '-u[user menu path (default ~/.fluxbox/usermenu)]:file:_files' \
  '-p[install prefix]:prefix:' \
  '-n[gnome prefix]:prefix:' \
  '-q[kde prefix]:prefix:' && ret=0
return ret
