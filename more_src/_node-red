#compdef node-red

# Zsh completion for node-red (low-code programming for event-driven applications)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-p+[Set the TCP port to listen on]:port' \
  '--port=[Set the TCP port to listen on]:port' \
  '-s+[Set the settings file]:settings file:_files -g "*.js"' \
  '--settings=[Set the settings file]:settings file:_files -g "*.js"' \
  '--title=[Set a custom page title]:title' \
  '-u+[Set the user directory]:directory:_files -/' \
  '--userDir=[Set the user directory]:directory:_files -/' \
  '-v[Enable verbose output]' \
  '--verbose[Enable verbose output]' \
  '--safe[Start in safe mode (no flows running)]' \
  '--define=[Override individual settings]:key=value' \
  '-D=[Override individual settings]:key=value' \
  '-?[Print help]' \
  '--help[Print help]' \
  ':flow file:_files -g "*.json"' && ret=0

return ret
