#compdef fastapi-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'dev:run in development mode'
  'run:run in production'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'fastapi-cli command' commands && ret=0 ;;
  (args)
    _arguments \
      '--host=+[host]:host:_hosts' \
      '--port=+[port]:port:' \
      '--reload[enable reload]' \
      '--no-reload[disable reload]' \
      '--workers=+[workers]:n:' \
      '--root-path=+[root path]:path:' \
      '--app=+[app name]:name:' \
      '--proxy-headers[use proxy headers]' \
      '*:path:_files -g "*.py"' && ret=0
    ;;
esac

return ret
