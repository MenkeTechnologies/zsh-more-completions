autoload -U is-at-least

_schemaui() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'--schema=[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'-c+[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--config=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--data=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--title=[title shown at the top of the UI]:TITLE:_default' \
'--description=[description shown under the title in the active UI]:DESCRIPTION:_default' \
'*-o+[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'*--output=[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'--temp-file=[write to PATH when no destinations are set (stdout remains the default)]:PATH:_files' \
'--no-temp-file[compatibility no-op\: stdout is already the default when no destinations are set]' \
'--no-pretty[emit compact JSON/TOML rather than pretty formatting]' \
'-f[overwrite output files even if they already exist]' \
'-y[overwrite output files even if they already exist]' \
'--force[overwrite output files even if they already exist]' \
'--yes[overwrite output files even if they already exist]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_schemaui_commands" \
"*::: :->schemaui" \
&& ret=0
    case $state in
    (schemaui)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:schemaui-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- target shell\: bash, zsh, fish, or powershell:(bash zsh fish powershell)' \
&& ret=0
;;
(tui)
_arguments "${_arguments_options[@]}" : \
'-s+[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'--schema=[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'-c+[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--config=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--data=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--title=[title shown at the top of the UI]:TITLE:_default' \
'--description=[description shown under the title in the active UI]:DESCRIPTION:_default' \
'*-o+[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'*--output=[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'--temp-file=[write to PATH when no destinations are set (stdout remains the default)]:PATH:_files' \
'--no-temp-file[compatibility no-op\: stdout is already the default when no destinations are set]' \
'--no-pretty[emit compact JSON/TOML rather than pretty formatting]' \
'-f[overwrite output files even if they already exist]' \
'-y[overwrite output files even if they already exist]' \
'--force[overwrite output files even if they already exist]' \
'--yes[overwrite output files even if they already exist]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(web)
_arguments "${_arguments_options[@]}" : \
'-s+[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'--schema=[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'-c+[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--config=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--data=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--title=[title shown at the top of the UI]:TITLE:_default' \
'--description=[description shown under the title in the active UI]:DESCRIPTION:_default' \
'*-o+[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'*--output=[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'--temp-file=[write to PATH when no destinations are set (stdout remains the default)]:PATH:_files' \
'-l+[bind address for the temporary HTTP server]:IP:_default' \
'--host=[bind address for the temporary HTTP server]:IP:_default' \
'--bind=[bind address for the temporary HTTP server]:IP:_default' \
'--listen=[bind address for the temporary HTTP server]:IP:_default' \
'-p+[bind port for the temporary HTTP server (0 picks a random free port)]:PORT:_default' \
'--port=[bind port for the temporary HTTP server (0 picks a random free port)]:PORT:_default' \
'--no-temp-file[compatibility no-op\: stdout is already the default when no destinations are set]' \
'--no-pretty[emit compact JSON/TOML rather than pretty formatting]' \
'-f[overwrite output files even if they already exist]' \
'-y[overwrite output files even if they already exist]' \
'--force[overwrite output files even if they already exist]' \
'--yes[overwrite output files even if they already exist]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(web-snapshot)
_arguments "${_arguments_options[@]}" : \
'-s+[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'--schema=[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'-c+[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--config=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--data=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--title=[title shown at the top of the UI]:TITLE:_default' \
'--description=[description shown under the title in the active UI]:DESCRIPTION:_default' \
'*-o+[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'*--output=[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'--temp-file=[write to PATH when no destinations are set (stdout remains the default)]:PATH:_files' \
'--out-dir=[output directory for generated Web snapshots (JSON + TS)]:DIR:_files' \
'--ts-export=[name of the exported constant in the generated TS module]:NAME:_default' \
'--no-temp-file[compatibility no-op\: stdout is already the default when no destinations are set]' \
'--no-pretty[emit compact JSON/TOML rather than pretty formatting]' \
'-f[overwrite output files even if they already exist]' \
'-y[overwrite output files even if they already exist]' \
'--force[overwrite output files even if they already exist]' \
'--yes[overwrite output files even if they already exist]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(tui-snapshot)
_arguments "${_arguments_options[@]}" : \
'-s+[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'--schema=[schema spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:SCHEMA:_default' \
'-c+[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--config=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--data=[config spec\: local path, file/HTTP URL, inline payload, or "-" for stdin]:CONFIG:_default' \
'--title=[title shown at the top of the UI]:TITLE:_default' \
'--description=[description shown under the title in the active UI]:DESCRIPTION:_default' \
'*-o+[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'*--output=[output destinations ("-" writes to stdout). Repeat the flag to add more]:DEST:_default' \
'--temp-file=[write to PATH when no destinations are set (stdout remains the default)]:PATH:_files' \
'--out-dir=[output directory for generated TUI artifact modules (Rust source)]:DIR:_files' \
'--tui-fn=[name of the generated TuiArtifacts constructor function]:NAME:_default' \
'--form-fn=[name of the generated FormSchema constructor function]:NAME:_default' \
'--layout-fn=[name of the generated LayoutNavModel constructor function]:NAME:_default' \
'--no-temp-file[compatibility no-op\: stdout is already the default when no destinations are set]' \
'--no-pretty[emit compact JSON/TOML rather than pretty formatting]' \
'-f[overwrite output files even if they already exist]' \
'-y[overwrite output files even if they already exist]' \
'--force[overwrite output files even if they already exist]' \
'--yes[overwrite output files even if they already exist]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_schemaui_commands] )) ||
_schemaui_commands() {
    local commands; commands=(
'completion:Generate shell completion scripts for the schemaui CLI' \
'tui:Launch the interactive terminal UI' \
'web:Launch the interactive web UI instead of the terminal UI' \
'web-snapshot:Precompute Web session snapshots instead of launching the UI' \
'tui-snapshot:Precompute TUI FormSchema/LayoutNavModel modules instead of launching the UI' \
    )
    _describe -t commands 'schemaui commands' commands "$@"
}
(( $+functions[_schemaui__subcmd__completion_commands] )) ||
_schemaui__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'schemaui completion commands' commands "$@"
}
(( $+functions[_schemaui__subcmd__tui_commands] )) ||
_schemaui__subcmd__tui_commands() {
    local commands; commands=()
    _describe -t commands 'schemaui tui commands' commands "$@"
}
(( $+functions[_schemaui__subcmd__tui-snapshot_commands] )) ||
_schemaui__subcmd__tui-snapshot_commands() {
    local commands; commands=()
    _describe -t commands 'schemaui tui-snapshot commands' commands "$@"
}
(( $+functions[_schemaui__subcmd__web_commands] )) ||
_schemaui__subcmd__web_commands() {
    local commands; commands=()
    _describe -t commands 'schemaui web commands' commands "$@"
}
(( $+functions[_schemaui__subcmd__web-snapshot_commands] )) ||
_schemaui__subcmd__web-snapshot_commands() {
    local commands; commands=()
    _describe -t commands 'schemaui web-snapshot commands' commands "$@"
}

if [ "$funcstack[1]" = "_schemaui" ]; then
    _schemaui "$@"
else
    compdef _schemaui schemaui
fi
