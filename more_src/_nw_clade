#compdef nw_clade
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: extract clades (subtrees) defined by labels.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-c+[context: start subtree N nodes higher]:levels:' \
  '-m[only monophyletic clades]' \
  '-r[regexp mode: labels match a regular expression]' \
  '-s[output siblings of the defined clade]' \
  '*:newick file:_files' && ret=0

return ret
