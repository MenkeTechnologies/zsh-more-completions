#compdef dh_movetousr
# _dh_movetousr — canonicalize package paths to merged /usr (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_movetousr script.

_dh_movetousr() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '(--fail-noop --warn-noop)--fail-noop[fail if no aliased files found]' \
        '(--fail-noop --warn-noop)--warn-noop[warn if no aliased files found]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-a[arch-dep packages only]' \
        '-i[arch-indep packages only]' \
        '-O+[option passed to the helper]:opt:'
}

_dh_movetousr "$@"
