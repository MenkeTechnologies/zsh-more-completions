#compdef zookeeper-server
# Documentation: https://man.archlinux.org/search?q=zookeeper-server
# Reference accessed: 2026-05-16

# zookeeper-server: ZooKeeper server control script
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart status upgrade print-cmd help)' \
  '*::zookeeper-server args:_files' && ret=0
return ret
