#compdef sftime2depth
# Documentation: http://www.ahay.org/RSF/sftime2depth.html
# Madagascar: time-to-depth conversion in V(z) media

local ret=1

_arguments -s \
  'velocity=[auxiliary velocity input file]:file:_files' \
  'intime=[y if velocity is in time domain]:flag:(y n)' \
  'nz=[number of depth samples (default n1)]:nz' \
  'dz=[depth sampling (default d1)]:dz' \
  'z0=[depth origin]:z0' \
  'slow=[y for slowness, n for velocity]:flag:(y n)' \
  'twoway=[y for two-way traveltime]:flag:(y n)' \
  'extend=[trace extension]:extend' \
  'eps=[stretch regularization parameter]:eps' \
  '*:rsf file:_files' && ret=0

return ret
