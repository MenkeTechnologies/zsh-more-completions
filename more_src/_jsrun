#compdef jsrun
# Documentation: https://docs.olcf.ornl.gov/systems/summit_user_guide.html
# IBM Spectrum LSF/CSM parallel job launcher (resource sets)

local ret=1

_arguments -s -S \
  '(-n --nrs)'{-n,--nrs}'[number of resource sets to launch]:count:' \
  '(-a --tasks_per_rs)'{-a,--tasks_per_rs}'[number of task instances per resource set]:count:' \
  '(-c --cpu_per_rs)'{-c,--cpu_per_rs}'[CPU cores allocated to each resource set]:cpus:' \
  '(-g --gpu_per_rs)'{-g,--gpu_per_rs}'[GPU devices allocated to each resource set]:gpus:' \
  '(-b --bind)'{-b,--bind}'[binding strategy for tasks to CPU cores]:bind:' \
  '(-r --rs_per_host)'{-r,--rs_per_host}'[resource sets to place on each compute host]:count:' \
  '(-d --launch_distribution)'{-d,--launch_distribution}'[distribution pattern for resource set placement]:dist:' \
  '(-l --latency_priority)'{-l,--latency_priority}'[latency optimization for task communication]:priority:' \
  '(-m --memory_per_rs)'{-m,--memory_per_rs}'[memory allocation per resource set]:mem:' \
  '(-p --np)'{-p,--np}'[total number of processes to launch]:count:' \
  '(-e --stdio_stderr)'{-e,--stdio_stderr}'[redirect standard error output destination]:mode:' \
  '(-o --stdio_stdout)'{-o,--stdio_stdout}'[redirect standard output destination]:mode:' \
  '(-k --stdio_input)'{-k,--stdio_input}'[redirect standard input source]:mode:' \
  '(-E --env)'{-E,--env}'[export environment variable to remote tasks]:var:' \
  '(-D --denv)'{-D,--denv}'[do not export environment variable to remote tasks]:var:' \
  '--smpiargs[Spectrum MPI-specific arguments]:args:' \
  '(-i --erf_input)'{-i,--erf_input}'[explicit resource file input]:file:_files' \
  '(-I --immediate)'{-I,--immediate}'[immediate job launch mode]' \
  '(-f --appfile)'{-f,--appfile}'[application configuration file]:file:_files' \
  '--progress[progress monitoring output]:opts:' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '(-h --help)'{-h,--help}'[display help information]' \
  '*::command:_command_names -e' && ret=0

return ret
