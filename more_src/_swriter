#compdef swriter scalc simpress sdraw smath sbase sweb
# _swriter — LibreOffice component wrappers (soffice --writer/--calc/etc.)
# upstream: https://github.com/LibreOffice/core
# Flags from desktop/source/app/cmdlineargs.cxx (CommandLineArgs::ParseCommandLine).

_swriter() {
    _arguments \
        '(- *)'{-h,--help,-\?}'[show help]' \
        '(- *)--version[show version]' \
        '--minimized[start with minimized main window]' \
        '--invisible[start without UI (no splash)]' \
        '--norestore[skip restoring after crash]' \
        '--nodefault[do not open a default document]' \
        '--headless[run without GUI (batch)]' \
        '--safe-mode[start in safe mode]' \
        '--cat=[print document text to stdout]:file:_files' \
        '--script-cat[print script of macro to stdout]' \
        '--quickstart[enable quickstart]' \
        '--quickstart=no[disable quickstart]' \
        '--terminate_after_init[exit after init]' \
        '--nofirststartwizard[skip first-start wizard]' \
        '--nologo[skip startup logo]' \
        '--nolockcheck[skip lockfile checks]' \
        '--writer[open Writer]' \
        '--calc[open Calc]' \
        '--draw[open Draw]' \
        '--impress[open Impress]' \
        '--base[open Base]' \
        '--global[open global document]' \
        '--math[open Math]' \
        '--web[open Web (HTML)]' \
        '-n[create new document from template]' \
        '-o[open document for editing]' \
        '--pt=[print to printer (with name)]:printer:_printers' \
        '-p[print to default printer]' \
        '--view[open in read-only view]' \
        '--show[start presentation immediately]' \
        '--display=[X display]:display:' \
        '--convert-to=[convert documents to format]:fmt:' \
        '--print-to-file[print to file]' \
        '--printer-name=[printer name]:printer:_printers' \
        '--outdir=[output directory for conversion]:dir:_files -/' \
        '--convert-images-to=[convert images to format]:fmt:(png jpg pdf gif tiff)' \
        '--helpwriter[open Writer help]' \
        '--helpcalc[open Calc help]' \
        '--helpdraw[open Draw help]' \
        '--helpimpress[open Impress help]' \
        '--helpbase[open Base help]' \
        '--helpbasic[open Basic IDE help]' \
        '--helpmath[open Math help]' \
        '*:document:_files'
}

_swriter "$@"
