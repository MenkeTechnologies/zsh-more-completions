#compdef donut
# Documentation: https://github.com/TheWover/donut (donut.c usage)
# Reference accessed: 2026-05-30
# donut — generate position-independent shellcode from .NET assemblies, EXEs, DLLs, scripts.
# Authorized security-testing tool; ships in many penetration-testing distributions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --modname)'{-n,--modname=}'[module name for HTTP staging (random if entropy enabled)]:name:' \
  '(-s --server)'{-s,--server=}'[server hosting the donut module (host[user\:pass])]:url:' \
  '(-e --entropy)'{-e,--entropy=}'[entropy level]:level:((1\:none 2\:random-names 3\:random-names+encryption))' \
  '(-a --arch --cpu)'{-a,--arch=,--cpu=}'[target architecture]:arch:((1\:x86 2\:amd64 3\:x86+amd64))' \
  '(-o --output)'{-o,--output=}'[output file path (default loader.bin)]:file:_files' \
  '(-f --format)'{-f,--format=}'[output format]:fmt:((1\:binary 2\:base64 3\:c 4\:ruby 5\:python 6\:powershell 7\:csharp 8\:hex))' \
  '(-y --fork --oep)'{-y,--fork=,--oep=}'[create new thread at specified offset]:offset:' \
  '(-x --exit)'{-x,--exit=}'[exit behavior]:behavior:((1\:thread 2\:process 3\:block))' \
  '(-c --class)'{-c,--class=}'[class name (REQUIRED for .NET DLL)]:name:' \
  '(-d --domain)'{-d,--domain=}'[AppDomain name (random if entropy enabled)]:name:' \
  '(-i --input --file)'{-i,--input=,--file=}'[input file]:file:_files' \
  '(-m --method --function)'{-m,--method=,--function=}'[method/function for DLL (REQUIRED for .NET DLL)]:name:' \
  '(-p --params --args)'{-p,--params=,--args=}'[parameters / command-line arguments]:args:' \
  '(-w --unicode)'{-w,--unicode}'[pass command line as Unicode to unmanaged DLL]' \
  '(-r --runtime)'{-r,--runtime=}'[CLR runtime version]:version:' \
  '(-t --thread)'{-t,--thread}'[execute EXE entrypoint as a thread]' \
  '(-z --compress)'{-z,--compress=}'[compression]:codec:((1\:none 2\:aPLib 3\:LZNT1 4\:Xpress))' \
  '(-b --bypass)'{-b,--bypass=}'[AMSI/WLDP/ETW bypass]:mode:((1\:none 2\:abort 3\:continue))' \
  '(-k --headers)'{-k,--headers=}'[PE headers]:mode:((1\:overwrite 2\:keep))' \
  '(-j --decoy)'{-j,--decoy=}'[optional decoy module path]:file:_files' \
  && ret=0

return ret
