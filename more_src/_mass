#compdef mass
# Documentation: https://man.archlinux.org/search?q=mass
# Reference accessed: 2026-05-16

# Zsh completion for Massdriver Cloud CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      bundle component deployment docs environment instance project repository resource type schema version whoami
    )
    _describe -t commands 'mass command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
