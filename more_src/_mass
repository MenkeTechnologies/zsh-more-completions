#compdef mass
# Documentation: https://docs.massdriver.cloud/reference/cli/overview
# Reference accessed: 2026-05-17
# Verified: massdriver-cloud/mass upstream — Massdriver Cloud CLI.
# NOTE: there is no prominent `evilsocket/mass` or `mass-go`; the
# authoritative `mass` is massdriver-cloud/mass.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'bundle:bundle ops (build/create/get/import/lint/list/new/publish/pull/template)'
  'component:component ops (add/link/remove/unlink/update)'
  'deployment:deployment ops'
  'instance:instance ops (deploy/destroy/export/get/list/version)'
  'project:project management'
  'environment:environment config'
  'repository:repository management'
  'resource:resource ops'
  'resource-type:resource type management'
  'completion:shell completion'
  'docs:generate docs'
  'schema:schema validate/dereference'
  'version:print version'
  'whoami:auth check'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--api-key=[API key]:key:' \
  '--org-id=[organization ID]:id:' \
  '--endpoint=[API endpoint URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mass command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (bundle)
        _arguments '1:operation:(build create get import lint list new publish pull template)' && ret=0 ;;
      (component)
        _arguments '1:operation:(add link remove unlink update)' && ret=0 ;;
      (instance)
        _arguments '1:operation:(deploy destroy export get list version)' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
