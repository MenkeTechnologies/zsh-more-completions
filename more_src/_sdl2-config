#compdef sdl2-config
# Documentation: https://man.archlinux.org/search?q=sdl2-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--cflags[print C compiler flags]' \
  '--libs[print linker flags]' \
  '--static-libs[print linker flags for static linking]' && ret=0

return ret
