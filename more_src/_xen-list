#compdef xen-list
# Documentation: https://man.archlinux.org/search?q=xen-list
# Reference accessed: 2026-05-16

# xen-list: list Xen domains and resource use
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-l[long format]' \
  '--long[long format]' \
  '*::xen-list args:_files' && ret=0
return ret
