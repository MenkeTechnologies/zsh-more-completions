#compdef mailcatcher
# Documentation: https://man.archlinux.org/search?q=mailcatcher
# Reference accessed: 2026-05-16

# MailCatcher: SMTP test trap with web UI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f[run in foreground]' \
  '--foreground[run in foreground]' \
  '--ip=[bind IP]:ip:' \
  '-i[smtp ip]:ip:' \
  '--smtp-ip=[smtp ip]:ip:' \
  '-s[smtp port]:port:' \
  '--smtp-port=[smtp port]:port:' \
  '-h[http ip]:ip:' \
  '--http-ip=[http ip]:ip:' \
  '-p[http port]:port:' \
  '--http-port=[http port]:port:' \
  '--http-path=[http path prefix]:path:' \
  '--no-quit[disable quit button]' \
  '--browse[open browser on start]' \
  '--message-limit=[max stored messages]:n:' \
  '*::mailcatcher args:_files' && ret=0
return ret
