#compdef luaver luaver-cli
# _luaver — DhavalKapil Lua version manager CLI (Dhaval Kapil / DhavalKapil, Bash); custom argparse
# upstream: https://github.com/DhavalKapil/luaver

_luaver() {
    local -a sub=(
        'install:install Lua version'
        'install-luarocks:install LuaRocks'
        'install-luajit:install LuaJIT'
        'use:switch Lua version'
        'use-luarocks:switch LuaRocks version'
        'use-luajit:switch LuaJIT version'
        'uninstall:uninstall Lua'
        'uninstall-luarocks:uninstall LuaRocks'
        'uninstall-luajit:uninstall LuaJIT'
        'set-default:set default Lua'
        'set-default-luarocks:set default LuaRocks'
        'set-default-luajit:set default LuaJIT'
        'unset-default:unset default Lua'
        'unset-default-luarocks:unset default LuaRocks'
        'unset-default-luajit:unset default LuaJIT'
        'current:show current Lua'
        'current-luarocks:show current LuaRocks'
        'current-luajit:show current LuaJIT'
        'list:list installed Lua versions'
        'list-luarocks:list installed LuaRocks versions'
        'list-luajit:list installed LuaJIT versions'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'luaver subcommand' sub ;;
        args)
            case $words[1] in
                install|use|uninstall|set-default|install-luarocks|use-luarocks|uninstall-luarocks|set-default-luarocks|install-luajit|use-luajit|uninstall-luajit|set-default-luajit) _arguments '*:version:' ;;
            esac
            ;;
    esac
}

_luaver "$@"
