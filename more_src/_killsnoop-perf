#compdef killsnoop-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/killsnoop.8
# trace kill() syscalls with signal and process details (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-n+[process name to match]:name' \
  '-p+[PID to match on kill issue]:pid:_pids' \
  '-t[include time in seconds]' \
  '-s[human readable signal names]' && ret=0

return ret
