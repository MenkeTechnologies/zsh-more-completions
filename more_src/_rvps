#compdef rvps
# _rvps — Confidential Containers Reference Value Provider Service (Trustee RVPS gRPC server)
# upstream: https://github.com/confidential-containers/trustee
# Flags from rvps/src/bin/rvps.rs Cli on tip (clap).

_rvps() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-c --config)'{-c,--config}'=[path to RVPS config file]:file:_files' \
        '(-a --address)'{-a,--address}'=[address to listen on (default 127.0.0.1:50003)]:addr:'
}

_rvps "$@"
