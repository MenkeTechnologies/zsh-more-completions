#compdef vasp
# Documentation: https://man.archlinux.org/search?q=vasp
# Reference accessed: 2026-05-16

# VASP: Vienna Ab-initio Simulation Package - DFT plane-wave code.
# VASP reads INCAR/POSCAR/KPOINTS/POTCAR from cwd; no CLI flags.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::VASP runs from INCAR/POSCAR/KPOINTS/POTCAR in current directory:_files' && ret=0
return ret
