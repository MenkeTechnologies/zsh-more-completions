#compdef stringer
# _stringer — Go x/tools stringer (Rob Pike, Go team); generates String() methods for integer constants
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/stringer

_stringer() {
    _arguments \
        '-type+[comma-separated type names]:types:' \
        '-output+[output file]:file:_files' \
        '-tags+[build tags]:tags:' \
        '-linecomment[use line comment text as the printed name]' \
        '-trimprefix+[strip prefix from each value]:prefix:' \
        '*:dir:_files -/'
}

_stringer "$@"
