#compdef afl-fuzz-cli afl-fuzz
# _afl-fuzz-cli — Michał Zalewski AFL American Fuzzy Lop fuzzer CLI alias (AFLplusplus team, C); custom argparse
# upstream: https://github.com/AFLplusplus/AFLplusplus

_afl-fuzz-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i+[input dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '-p+[power schedule]:p:(fast explore exploit coe lin quad mmopt rare seek)' \
        '-f+[mock file]:file:_files' \
        '-t+[timeout ms]:n:' \
        '-m+[memory limit mb]:str:' \
        '-T+[banner text]:str:' \
        '-M+[main fuzzer id]:str:' \
        '-S+[secondary fuzzer id]:str:' \
        '-c+[cmplog binary]:file:_files' \
        '-l+[cmplog level]:l:(1 2 3 4)' \
        '-b+[cpu binding]:n:' \
        '-d[quick deterministic]' \
        '-n[non-instrumented mode]' \
        '-x+[dictionary file]:file:_files' \
        '-z[no instrumentation]' \
        '-Z[old afl scheduling]' \
        '-r[restart with new seeds]' \
        '-s+[static seed]:n:' \
        '-e+[file extension]:str:' \
        '-B+[bitmap file]:file:_files' \
        '-D[disable trim]' \
        '-C[crash exploration]' \
        '-F[foreign sync dir]' \
        '-I+[external syscall log]:file:_files' \
        '-L+[mopt seconds]:n:' \
        '-N[do not unlink]' \
        '-P[skip if power schedule fail]' \
        '-Q[QEMU emulation]' \
        '-U[unicorn emulation]' \
        '-W[wine emulation]' \
        '-X[afl-frida]' \
        '-Y[force exit on fuzz]' \
        '*:target binary args:_files'
}

_afl-fuzz-cli "$@"
