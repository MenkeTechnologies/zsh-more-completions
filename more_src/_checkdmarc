#compdef checkdmarc
# Documentation: https://man.archlinux.org/search?q=checkdmarc
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --parked)'{-p,--parked}'[domains are parked (SPF/DMARC semantics)]' \
  '(-d --descriptions)'{-d,--descriptions}'[include tag descriptions in JSON]' \
  '(-f --format)'{-f,--format}'=[screen output format]:format:(json csv)' \
  '(-o --output)*'{-o,--output}'=[write results to .json or .csv path]:output file:_files' \
  '(-n --nameserver)*'{-n,--nameserver}'=[DNS server to query]:nameserver:_hosts' \
  '(-t --timeout)'{-t,--timeout}'=[DNS timeout seconds]:timeout:' \
  '--retries=[DNS retries on transient errors]:retries:' \
  '*--ns=[approved nameserver hostname substrings]:substring:' \
  '*--mx=[approved MX hostname substrings]:substring:' \
  '(-b --bimi-selector)'{-b,--bimi-selector}'=[BIMI selector]:selector:' \
  '(-w --wait)'{-w,--wait}'=[seconds between domain checks]:seconds:' \
  '--skip-tls[skip TLS/SSL testing against MTA-STS endpoints]' \
  '--debug[enable debug logging]' \
  '*:domain or domain list file:_files'
