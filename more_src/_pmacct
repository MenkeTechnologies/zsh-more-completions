#compdef pmacct pmacctd nfacctd sfacctd uacctd
# Documentation: https://github.com/pmacct/pmacct/blob/master/src/pmacctd.c
# Reference accessed: 2026-05-16
# Verified: usage_daemon() in upstream pmacct/pmacct repo. The same flag set
# is shared across pmacctd/sfacctd/nfacctd/uacctd with minor differences
# (interface vs file capture sources).
# Removed from prior file: fabricated -h/--help/-V/--version long-flag
# variants and bogus man.archlinux.org search URL.

# pmacct: network accounting daemon family
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[display help]' \
  '-V[show version and compile-time options]' \
  '-f[configuration file]:file:_files' \
  '-a[list supported aggregation primitives]' \
  '-c[aggregation method]:method:' \
  '-D[run as daemon]' \
  '-N[disable promiscuous mode (pmacctd only)]' \
  '-z[allow non-root execution]' \
  '-n[networks/ASNs definitions file]:file:_files' \
  '-t[ports definitions file]:file:_files' \
  '-P[activate plugin]:plugin:(memory print mysql pgsql sqlite3 amqp kafka nfprobe sfprobe)' \
  '-d[enable debug mode]' \
  '-i[listen interface (pmacctd)]:interface:' \
  '-I[read packets from savefile (pmacctd)]:savefile:_files' \
  '-S[syslog facility]:facility:(daemon local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-F[PID file]:file:_files' \
  '-w[wait for listening interface availability]' \
  '-Z[sleep seconds when replaying savefiles]:seconds:' \
  '-W[do not exit after savefile playback]' \
  '-Y[replay savefile N times]:n:' \
  '-R[renormalize sampled data]' \
  '-L[snapshot length (pmacctd)]:bytes:' \
  '-u[keep IP protocols numerical]' \
  '-T[perform dry run]' \
  '-p[plugin pipe size]:size:' \
  '-b[plugin buffer size]:size:' \
  '-m[plugin memory table mask]:mask:' \
  '-s[plugin map size]:size:' \
  '-r[refresh time]:seconds:' \
  '-O[plugin output format]:format:(formatted csv json avro)' \
  '-o[plugin output file]:file:_files' \
  '-M[message size]:size:' \
  '-A[plugin amqp args]:args:' \
  '-E[plugin extra args]:args:' && ret=0
return ret
