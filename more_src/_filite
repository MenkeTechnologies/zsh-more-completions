#compdef filite

# filite — minimal pastebin/file server (see project README / `filite --help`). Typical flags bind address and sqlite path.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-b,--bind}"=[listen socket host:port]:bind" \
  {-d,--database}"=[SQLite database path]:file:_files" \
  '--config=[TOML config file]:file:_files' && ret=0

return ret
