#compdef filite
# Documentation: https://github.com/raftario/filite
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Minimal pastebin/file server (unmaintained per upstream README).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-b,--bind}"=[listen socket host:port]:bind" \
  {-d,--database}"=[SQLite database path]:file:_files" \
  '--config=[TOML config file]:file:_files' && ret=0

return ret
