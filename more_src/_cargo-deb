#compdef cargo-deb

_cargo-deb() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    {-v,--verbose}'[Print progress]' \
    {-q,--quiet}'[Suppress output]' \
    '--no-build[Skip building the project]' \
    '--no-strip[Do not strip debug symbols]' \
    '--strip[Strip debug symbols]' \
    '--fast[Use release-with-debug profile]' \
    {-p,--package}'[Package to build]:package:' \
    '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '--target[Target triple]:target:' \
    '--variant[Package variant]:variant:' \
    '--deb-version[Override Debian version]:version:' \
    '--deb-revision[Debian revision number]:revision:' \
    '--install[Install the generated package]' \
    '-o[Output directory]:dir:_directories' \
    '--output[Output directory]:dir:_directories' \
    '--selected[Only include selected assets]' \
    '--compress-type[Compression type]:type:(gzip xz none)' \
    '--compress-system[Use system compressor]' \
    '--rsyncable[Make gzip output rsyncable]' \
    '--profile[Cargo build profile]:profile:' \
    '--cargo-build[Custom cargo build command]:command:' \
    '--separate-debug-symbols[Create separate debug symbols package]' \
    '--system-xz[Use system xz instead of built-in]' \
    '*:args:'
}

_cargo-deb "$@"
