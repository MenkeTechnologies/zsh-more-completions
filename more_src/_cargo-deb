#compdef cargo-deb
# Documentation: https://github.com/kornelski/cargo-deb
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_cargo-deb() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '*'{-v,--verbose}'[Print progress (-vv for max logging)]' \
    {-q,--quiet}'[Suppress output]' \
    '--no-build[Skip building the project]' \
    '--no-strip[Do not strip binaries]' \
    '--strip[Strip debug symbols]' \
    '--fast[Use lighter/quicker compression]' \
    '(-p --package)'{-p+,--package=}'[Package to build]:package:' \
    '--manifest-path=[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '*--target=[Cross-compilation target triple]:target:' \
    '--variant=[Metadata variant from [package.metadata.deb.variants.NAME]]:variant:' \
    '--deb-version=[Override Debian version string]:version:' \
    '--deb-revision=[Override Debian revision suffix]:revision:' \
    '--maintainer=[Set package maintainer]:maintainer:' \
    '--install[Build and immediately install package locally]' \
    '(-o --output)'{-o+,--output=}'[Output directory or file path]:dir:_directories' \
    '--compress-type=[Compression type]:type:(gzip xz zstd none)' \
    '--compress-system[Use system compressor instead of built-in]' \
    '--rsyncable[Enable rsync-friendly compression]' \
    '--profile=[Cargo build profile]:profile:' \
    '--cargo-build=[Custom cargo build command]:command:' \
    '--separate-debug-symbols[Extract debug info into separate files]' \
    '--no-separate-debug-symbols[Suppress debug symbol extraction]' \
    '--compress-debug-symbols[Compress debug symbols internally]' \
    '--dbgsym[Create separate -dbgsym.ddeb package]' \
    '--system-xz[DEPRECATED alias for --compress-system]' \
    '--multiarch=[Multiarch layout]:mode:(none same foreign)' \
    '*:args:'
}

_cargo-deb "$@"
