#compdef clangd
# _clangd-bin — LLVM clangd C/C++ language server (LLVM project, C++); LSP backend for clang
# upstream: https://github.com/llvm/llvm-project

_clangd-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--all-scopes-completion[all-scopes completion]' \
        '--background-index+[background index]:bool:(true false)' \
        '--check+[check file]:file:_files' \
        '--compile-commands-dir=+[compile commands dir]:dir:_files -/' \
        '--completion-parse=+[completion parse]:val:(always always_with_async never)' \
        '--completion-style=+[completion style]:style:(bundled detailed)' \
        '--cross-file-rename+[cross-file rename]:bool:(true false)' \
        '--enable-config[enable config files]' \
        '--enable-link-headers+[enable link headers]:bool:(true false)' \
        '--enable-token-modifiers+[enable token modifiers]:bool:(true false)' \
        '--experimental-modules-support[experimental modules]' \
        '--fallback-style=+[fallback style]:style:(LLVM Google Chromium Mozilla WebKit Microsoft)' \
        '--folding-ranges[folding ranges]' \
        '--function-arg-placeholders+[function arg placeholders]:bool:(true false)' \
        '--header-insertion=+[header insertion]:mode:(iwyu never)' \
        '--header-insertion-decorators+[header insertion decorators]:bool:(true false)' \
        '--hidden-features[hidden features]' \
        '--input-style=+[input style]:style:(standard delimited)' \
        '--input-mirror-file=+[input mirror file]:file:_files' \
        '-j+[parallel workers]:n:' \
        '--limit-results=+[max results]:n:' \
        '--lit-test[lit test mode]' \
        '--log=+[log level]:level:(error info verbose)' \
        '--malloc-trim+[malloc trim]:bool:(true false)' \
        '--offset-encoding=+[offset encoding]:enc:(utf-8 utf-16 utf-32)' \
        '--path-mappings+[path mappings]:str:' \
        '--pch-storage=+[pch storage]:val:(memory disk)' \
        '--pretty[pretty print]' \
        '--print-options[print options]' \
        '--query-driver=+[driver path]:str:' \
        '--ranking-model=+[ranking model]:model:(heuristics decision_forest)' \
        '--resource-dir=+[resource dir]:dir:_files -/' \
        '--rename-file-limit=+[rename file limit]:n:' \
        '--remote-index-address=+[remote index addr]:addr:' \
        '--sync[sync mode]' \
        '--use-dirty-headers[use dirty headers]' \
        '*:file:_files'
}

_clangd-bin "$@"
