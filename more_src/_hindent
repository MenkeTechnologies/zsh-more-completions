#compdef hindent
# Documentation: https://man.archlinux.org/search?q=hindent
# Reference accessed: 2026-05-16

_arguments -s \
  '--version[show version]' \
  '--help[show help]' \
  '--style=[style]:style:(johan-tibell)' \
  '--line-length=[max line length]:n:' \
  '--indent-size=[indent size]:n:' \
  '--indentation=[indent size]:n:' \
  '--no-force-newline[no trailing newline]' \
  '*-X[Haskell extension]:ext:' \
  '*:file:_files -g "*.(hs|lhs)"'
