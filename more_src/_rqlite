#compdef rqlite

# Zsh completion for rqlite - CLI for rqlite distributed SQLite

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-H+[rqlite host]:host' \
  '-p+[rqlite port]:port' \
  '-P+[rqlite protocol]:protocol:(http https)' \
  '-i[read from stdin]' \
  '-u+[username]:user' \
  '-w+[password]:password' \
  '-ca-cert=[CA certificate]:cert:_files' \
  '-consistency=[consistency level]:level:(none weak strong)' \
  '-http-timeout=[HTTP timeout]:timeout' \
  '*:SQL statement or file:_files -g "*.sql"' && ret=0

return ret
