#compdef sncli
# Documentation: https://github.com/insanum/sncli
# sncli - Simplenote command line client

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[usage help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --nosync)'{-n,--nosync}'[do not perform a server sync]' \
  '(-r --regex)'{-r,--regex}'[search string is a regular expression]' \
  '(-k --key)'{-k,--key}'=[note key]:key:' \
  '(-t --title)'{-t,--title}'=[title of note for create]:title:' \
  '(-c --config)'{-c,--config}'=[config file to read from]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'sync:perform a full sync with the server'
      'list:list notes refined with search string'
      'export:export notes in JSON'
      'dump:dump notes'
      'create:create a note'
      'import:import a note in JSON format'
      'edit:edit a note'
      'trash:trash a note'
      'untrash:untrash a note'
      'pin:pin a note'
      'unpin:unpin a note'
      'markdown:flag note as markdown'
      'unmarkdown:unflag note as markdown'
      'tag:get/set/add/rm note tags'
    )
    _describe -t commands 'sncli command' cmds && ret=0
    ;;
  args)
    if [[ $line[1] == tag ]]; then
      local -a sub
      sub=(
        'get:retrieve the tags from a note'
        'set:set the tags for a note'
        'add:add tags to a note'
        'rm:remove tags from a note'
      )
      _describe -t subcommands 'tag subcommand' sub && ret=0
    fi
    ;;
esac

return ret
