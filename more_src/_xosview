#compdef xosview xosview2
# Documentation: https://man.archlinux.org/search?q=xosview
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-display+[X display]:display:' \
  '-geometry+[geometry WxH+X+Y]:geom:' \
  '-name+[X resource name]:name:' \
  '-title+[window title]:title:' \
  '-iconic[start iconified]' \
  '-bg+[background color]:color:' \
  '-fg+[foreground color]:color:' \
  '-fn+[font]:font:' \
  '-font+[font]:font:' \
  '-rv[reverse video]' \
  '-c+[load alternate config theme]:file:_files' \
  '-config+[config file]:file:_files' \
  '-resources+[resources file]:file:_files' \
  '-cpu+[show CPU meter]:bool:(True False)' \
  '-cpuFormat+[CPU layout]:fmt:(single all both auto)' \
  '-cpuFields+[CPU fields]:fields:' \
  '-load+[show load meter]:bool:(True False)' \
  '-mem+[show memory meter]:bool:(True False)' \
  '-swap+[show swap meter]:bool:(True False)' \
  '-page+[show page IO meter]:bool:(True False)' \
  '-net+[show net meter]:bool:(True False)' \
  '-disk+[show disk meter]:bool:(True False)' \
  '-int+[show interrupt meter]:bool:(True False)' \
  '-battery+[show battery meter]:bool:(True False)' \
  '-coretemp+[show core temp meter]:bool:(True False)' \
  '-RAID+[show RAID meter]:bool:(True False)' \
  '-NFSStats+[show NFS meter]:bool:(True False)' \
  '-update+[update interval seconds]:secs:' \
  '-graph+[graph mode]:bool:(True False)' \
  '-grid+[show grid]:bool:(True False)' \
  '-labels+[show labels]:bool:(True False)' \
  '-usedlabels+[show used labels]:bool:(True False)' \
  '-meterLabelColor+[meter label color]:color:' \
  '-usedLabelColor+[used label color]:color:' \
  '-borderwidth+[border width]:n:' \
  '-help-meters[list available meters]' && ret=0

return ret
