#compdef retina

# Zsh completion for Retina - Kubernetes network observability

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'capture:manage packet captures'
      'config:manage Retina configuration'
      'install:install Retina'
      'uninstall:uninstall Retina'
      'version:show version'
    )
    _describe -t commands 'retina command' commands && ret=0
    ;;
  args)
    case $line[1] in
      capture)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create delete list output)' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--version=[version to install]:version' \
          '--set=[override values]:KEY=VALUE' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
