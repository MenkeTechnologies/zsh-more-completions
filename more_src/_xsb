#compdef xsb
# Documentation: https://xsb.sourceforge.net/shadow_site/manual1/node22.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nobanner[suppress startup banner]' \
  '--quietload[hide module loading messages]' \
  '--noprompt[omit interactive prompt]' \
  '-i[launch interpreter (default)]' \
  '-l[display unbound variables as letters]' \
  '-n[non-interactive mode for C integration]' \
  '-e+[goal to execute at startup]:goal:' \
  '-B+[boot module]:module:' \
  '-D+[command loop driver]:driver:' \
  '-t[trace at SLG-WAM instruction level]' \
  '-d[disassemble bytecode and exit]' \
  '-c+[trail/choice-point stack KB (default 768)]:kb:' \
  '-m+[local/global stack KB (default 768)]:kb:' \
  '-o+[completion stack KB (default 64)]:kb:' \
  '-u+[unification stack KB (default 64)]:kb:' \
  '-r[disable automatic stack expansion]' \
  '-g+[garbage collection type]:gc:(none indirection sliding copying)' \
  '-s[maintain stack size statistics]' \
  '-S[use subsumption-based tabling by default]' \
  '-T[trace predicate entry points]' \
  '*:file:_files -g "*.P"' && ret=0

return ret
