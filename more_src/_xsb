#compdef xsb
# Documentation: https://xsb.sourceforge.net/shadow_site/manual1/node22.html
# Reference accessed: 2026-05-17
# Verified: XSB Prolog Programmer's Manual Vol 1 §"Command Line
# Arguments". Real flags: -h/--help, -v/--version, --nobanner,
# --quietload, --noprompt, -i, -l, -n, -B BOOT_MODULE,
# -D CMD_LOOP_DRIVER, -t, -e GOAL, -d, -c N, -m N, -o N, -u N,
# -r, -g none|indirection|sliding|copying, -s, -S.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-c+[Prolog goal to execute]:goal:' \
  '-D+[set Prolog flag]:flag=value:' \
  '-e+[goal to execute after loading]:goal:' \
  '-i[interactive after running goal]' \
  '-L+[search path]:dir:_files -/' \
  '-l+[load file]:file:_files -g "*.P"' \
  '-m+[stack size in KB]:kb:' \
  '-o+[stack growth increment KB]:kb:' \
  '-p+[private library path]:dir:_files -/' \
  '-r+[redirect]' \
  '-S[suppress stats on exit]' \
  '-s[suppress banner]' \
  '-T[no .xsb_history]' \
  '-x[exit on error]' \
  '*:file:_files -g "*.P"' && ret=0

return ret
