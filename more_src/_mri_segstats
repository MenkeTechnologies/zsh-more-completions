#compdef mri_segstats
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_segstats
# mri_segstats - compute statistics within segmentations or labels

local ret=1

_arguments -s -S \
  '--seg[input segmentation volume]:file:_files' \
  '--annot[create segmentation from hemi.parc.annot]:spec:' \
  '--slabel[create segmentation from surface label]:spec:' \
  '--sum[ASCII file for summary statistics]:file:_files' \
  '--pv[partial volume compensation volume]:file:_files' \
  '--i[input volume for additional statistics]:file:_files' \
  '--frame[report statistics at specific frame number]:n:' \
  '--seg-erode[erode segmentation boundaries Nvoxels]:n:' \
  '--robust[exclude percentage from high/low values]:pct:' \
  '--sqr[square the input values]' \
  '--sqrt[square root of input values]' \
  '--mul[multiply input by value]:val:' \
  '--div[divide input by value]:val:' \
  '--abs[absolute value before averaging]' \
  '--snr[save mean/std as extra column]' \
  '--id[specify numeric segmentation IDs]:id:' \
  '--excludeid[exclude segmentation ID]:id:' \
  '--excl-ctxgmwm[exclude cortical gray/white matter]' \
  '--empty[report unlabeled segmentations]' \
  '--ctab[FreeSurfer color table file]:file:_files' \
  '--ctab-default[use default color table]' \
  '--ctab-gca[get color table from GCA file]:file:_files' \
  '--ctab-out[output color table]:file:_files' \
  '--replace[replace one ID with another]:spec:' \
  '--replace-file[replace via file of pairs]:file:_files' \
  '--brain-vol-from-seg[brain volume from segmentations]' \
  '--brainmask[load brain mask]:file:_files' \
  '--subcortgray[subcortical gray matter volume]' \
  '--totalgray[total gray matter volume]' \
  '--etiv[intracranial volume from talairach transform]' \
  '--etiv-only[compute eTIV and exit]' \
  '--talxfm[talairach transform path]:file:_files' \
  '--euler[defect holes from euler number]' \
  '--mask[mask volume for exclusion]:file:_files' \
  '--maskthresh[masking threshold value]:thresh:' \
  '--masksign[masking sign (abs/pos/neg)]:sign:(abs pos neg)' \
  '--maskframe[mask frame number]:n:' \
  '--maskinvert[invert mask]' \
  '--maskerode[erode mask Nvoxels]:n:' \
  '--avgwf[average waveform text file]:file:_files' \
  '--sumwf[sum waveform text file]:file:_files' \
  '--avgwfvol[average waveform in MRI volume format]:file:_files' \
  '--sfavg[mean across space and frame]:file:_files' \
  '--vox[replace with zeros except at CRS coordinate]:crs:' \
  '--qa-stats[quality control statistics]' \
  '--sd[set SUBJECTS_DIR]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
