#compdef gcode2png
# Documentation: https://github.com/shodushi/gcode2png
# gcode2png: render a 3D preview PNG from a G-code file

local ret=1

_arguments -s -S \
  '--moves[show movements in red (default false)]' \
  '--support[show support layers in grey (default true)]' \
  '--bed[show printbed (default true)]' \
  '--show[display the rendered image instead of saving PNG]' \
  '*:gcode file:_files -g "*.(gcode|gco|g|GCODE)"' && ret=0

return ret
