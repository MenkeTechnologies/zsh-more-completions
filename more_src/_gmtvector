#compdef gmtvector
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtvector.html
# Source: GenericMappingTools/gmt src/gmtvector.c — vector operations on 2D/3D Cartesian or geographic vectors (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[primary vector or mean]:vector:_default' \
    '-C+[input/output Cartesian]:io:(i o)' \
    '-E[geodetic↔geocentric conversion]' \
    '-N[normalise transformed vectors]' \
    '-S+[secondary vector]:vector:_default' \
    '-T+[transformation type]:type:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[segment gaps]:gap:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[record selection]:cols:_default' \
    '-s+[skip records with NaN]:cols:_default' \
    '*:input table:_files' \
    && ret=0

return ret
