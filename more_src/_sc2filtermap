#compdef sc2filtermap
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss55.html
# SMURF: filter a 2-d map.

local ret=1

_arguments -s -S \
  'IN=[input files to transform]:ndf:_files' \
  'OUT=[output transformed files]:ndf:_files' \
  'OUTFILTER=[optional NDF for the filter]:ndf:_files' \
  'FILT_EDGEHIGH=[high-pass filter frequency]:freq:' \
  'FILT_EDGELOW=[low-pass filter frequency]:freq:' \
  'WHITEN=[apply whitening filter]:flag:(TRUE FALSE)' \
  'WHITEREFMAP=[reference map for whitening]:ndf:_files' \
  'ZEROBAD=[zero bad values before FFT]:flag:(TRUE FALSE)' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
