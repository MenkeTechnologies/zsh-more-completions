#compdef awless
# Documentation: https://man.archlinux.org/search?q=awless
# Reference accessed: 2026-05-16

# awless — wallix/awless commands/root.go (cobra). Subcommands registered under commands/*.go.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'list:list cloud resources'
  'show:show resource details'
  'search:search resources'
  'inspect:inspect graph/relations'
  'run:run templated actions'
  'sync:sync local model with cloud'
  'revert:revert changes'
  'ssh:ssh to instance'
  'switch:switch profile/context'
  'config:configure awless'
  'history:command history'
  'log:cloudtrail-style logs'
  'tail:tail log streams'
  'whoami:show identity'
  'hooks:manage hooks'
  'scheduler:scheduler helpers'
  'web:start web UI'
  'autocompletion:shell completion helpers'
)

_arguments -s -S -C \
  '(- *)--version[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-e --extra-verbose)'{-e,--extra-verbose}'[extra verbose]' \
  '--silent[silent mode]' \
  '(-l --local)'{-l,--local}'[offline local cache only]' \
  '(-f --force)'{-f,--force}'[force; skip prompts]' \
  '--no-sync[disable sync on command]' \
  '(-r --aws-region)'{-r,--aws-region}"=[AWS region]:region" \
  '(-p --aws-profile)'{-p,--aws-profile}"=[AWS profile]:profile" \
  '--color=[color policy]:mode:(auto never always)' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'awless command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
