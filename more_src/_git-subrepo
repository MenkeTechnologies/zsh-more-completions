#compdef git-subrepo

# Zsh completion for git-subrepo (git subrepo management)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'clone:clone a remote repo into a subdirectory'
      'init:turn a subdirectory into a subrepo'
      'pull:pull upstream changes into subrepo'
      'push:push subrepo changes upstream'
      'fetch:fetch upstream changes'
      'branch:create a branch with subrepo commits'
      'commit:commit staged subrepo changes'
      'config:get or set subrepo config'
      'clean:remove branches created by subrepo'
      'status:show status of subrepos'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'git-subrepo command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (clone)
        _arguments \
          '(-b --branch)'{-b,--branch}'[branch to clone]:branch' \
          '(-f --force)'{-f,--force}'[force clone]' \
          '(-e --edit)'{-e,--edit}'[edit commit message]' \
          '(-M --method)'{-M,--method}'[merge method]:method:(merge rebase)' \
          '1:repository URL' \
          '2:subdirectory:_files -/' && ret=0
        ;;
      (init)
        _arguments \
          '(-r --remote)'{-r,--remote}'[remote URL]:url' \
          '(-b --branch)'{-b,--branch}'[remote branch]:branch' \
          '(-e --edit)'{-e,--edit}'[edit commit message]' \
          '(-M --method)'{-M,--method}'[merge method]:method:(merge rebase)' \
          '1:subdirectory:_files -/' && ret=0
        ;;
      (pull)
        _arguments \
          '(-b --branch)'{-b,--branch}'[branch to pull]:branch' \
          '(-f --force)'{-f,--force}'[force pull]' \
          '(-r --remote)'{-r,--remote}'[remote URL]:url' \
          '(-e --edit)'{-e,--edit}'[edit commit message]' \
          '(-M --method)'{-M,--method}'[merge method]:method:(merge rebase)' \
          '-u[update .gitrepo]' \
          '--all[pull all subrepos]' \
          '1:subdirectory:_files -/' && ret=0
        ;;
      (push)
        _arguments \
          '(-b --branch)'{-b,--branch}'[branch to push]:branch' \
          '(-f --force)'{-f,--force}'[force push]' \
          '(-r --remote)'{-r,--remote}'[remote URL]:url' \
          '-u[update .gitrepo]' \
          '--all[push all subrepos]' \
          '1:subdirectory:_files -/' && ret=0
        ;;
      (fetch|branch|commit|clean|status)
        _arguments \
          '--all[apply to all subrepos]' \
          '1:subdirectory:_files -/' && ret=0
        ;;
      (config)
        _arguments \
          '1:subdirectory:_files -/' \
          '2:option' \
          '3:value' && ret=0
        ;;
    esac
    ;;
esac

return ret
