#compdef coqui-tts coqui-cli tts-cli
# _coqui-tts — Coqui TTS deep learning toolkit for text-to-speech CLI alias (Coqui.ai / coqui-ai, Python); custom argparse
# upstream: https://github.com/coqui-ai/TTS

_coqui-tts() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--text=+[text to synthesize]:str:' \
        '--out_path=+[output wav]:file:_files -g "*.wav"' \
        '--model_name=+[model name]:str:' \
        '--vocoder_name=+[vocoder name]:str:' \
        '--config_path=+[config path]:file:_files -g "*.json *.yaml"' \
        '--model_path=+[model path]:file:_files' \
        '--vocoder_config_path=+[vocoder config path]:file:_files -g "*.json *.yaml"' \
        '--vocoder_path=+[vocoder path]:file:_files' \
        '--encoder_config_path=+[encoder config path]:file:_files' \
        '--encoder_path=+[encoder path]:file:_files' \
        '--cuda[use cuda]' \
        '--use_cuda=+[use cuda]:b:(true false)' \
        '--speakers_file_path=+[speakers file]:file:_files' \
        '--speaker_idx=+[speaker idx]:str:' \
        '--language_idx=+[language idx]:str:' \
        '--speaker_wav=+[reference speaker wav]:list:_files -g "*.wav"' \
        '--language=+[language]:str:' \
        '--reference_wav=+[reference wav]:file:_files -g "*.wav"' \
        '--reference_speaker_idx=+[reference speaker idx]:str:' \
        '--gst_style=+[GST style ref]:file:_files' \
        '--capacitron_style_wav=+[capacitron style wav]:file:_files' \
        '--capacitron_style_text=+[capacitron style text]:str:' \
        '--list_models[list models]' \
        '--list_speaker_idxs[list speaker ids]' \
        '--list_language_idxs[list language ids]' \
        '--source_wav=+[source wav]:file:_files' \
        '--target_wav=+[target wav]:file:_files' \
        '--model_info_by_idx=+[model info by idx]:str:' \
        '--model_info_by_name=+[model info by name]:str:' \
        '--save_spectogram[save spectrogram]' \
        '--progress_bar=+[progress bar]:b:(true false)' \
        '--reference_speaker_idx=+[reference speaker idx]:str:' \
        '--encoder_path=+[encoder path]:file:_files' \
        '--encoder_config_path=+[encoder config path]:file:_files' \
        '--server[run server]' \
        '*:arg:'
}

_coqui-tts "$@"
