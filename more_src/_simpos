#compdef simpos
# _simpos — query SIMBAD/NED/Vizier for object positions (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from simpos.c (single-letter getopt-style).

_simpos() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a[print all ID information]' \
        '-b[print coordinates in B1950]' \
        '-c[use CDS server in France]' \
        '-d[print coordinates in degrees]' \
        '-e[print ecliptic coordinates]' \
        '-g[print galactic coordinates]' \
        '-i[print all IDs found by SIMBAD]' \
        '-n[search NED database]' \
        '-o[print object name]' \
        '-s+[database search order]:order:(simbad ned vizier all)' \
        '-t[output as tab-separated table]' \
        '-v[verbose output]' \
        '-z[search Vizier catalogs]' \
        '*:object name:'
}

_simpos "$@"
