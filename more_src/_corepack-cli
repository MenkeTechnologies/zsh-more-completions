#compdef corepack
# Documentation: https://github.com/nodejs/corepack#readme
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'enable:enable corepack shims'
  'disable:disable corepack shims'
  'install:install package manager'
  'use:set version for project'
  'pack:pack a package manager'
  'prepare:prepare/cache a package manager'
  'hydrate:hydrate package manager from tar'
  'cache:cache management'
  'completion:show completion script'
  'help:show help'
  'up:upgrade package manager'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*--cwd=[cwd]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'corepack command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (enable|disable)
        _arguments \
          '(--install-directory)--install-directory=[install dir]:dir:_files -/' \
          '*:pm:(npm pnpm yarn)' && ret=0 ;;
      (prepare)
        _arguments \
          '(--all)--all[all known package managers]' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(--activate)--activate[activate]' \
          '(--json)--json[JSON output]' \
          '*: :' && ret=0 ;;
      (install)
        _arguments \
          '(-g --global)'{-g,--global}'[global]' \
          '(--cache-only)--cache-only[cache only]' \
          '*: :' && ret=0 ;;
      (use)
        _arguments \
          '*: :' && ret=0 ;;
      (hydrate)
        _arguments \
          '(--activate)--activate[activate]' \
          '*: :_files -g "*.tgz *.tar.gz"' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(clean clear)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
