#compdef bhosts
# Documentation: https://man.archlinux.org/search?q=bhosts
# Reference accessed: 2026-05-16

# bhosts: show LSF batch hosts
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-l[long format]' \
  '-w[wide format]' \
  '-x[execute hosts only]' \
  '-R[res. requirements]:expr:' \
  '-o[output fields]:fields:' \
  '*:host:_hosts' && ret=0
return ret
