#compdef bhosts
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-bhosts
# Reference accessed: 2026-05-17
# Verified: IBM Spectrum LSF 10.1 bhosts(1) reference (-w, -l, -x,
# -X, -e, -gpu, -aff, -alloc, -cname, -R, -s, -o, -json, -o
# unitgroup, -noheader, -h, -V).
# Removed from prior file: bogus man.archlinux.org search URL.

# bhosts: show LSF batch hosts
local ret=1
_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-w[wide format]' \
  '-l[long format]' \
  '-x[execute hosts only]' \
  '-X[expand host group to members]' \
  '-e[show exception status]' \
  '-gpu[show GPU host info]' \
  '-aff[show affinity info]' \
  '-alloc[show allocation info]' \
  '-cname[show host canonical name]' \
  '-R+[resource requirement]:expr:' \
  '-s+[shared resource]:resource:' \
  '-o+[output fields]:fields:' \
  '-json[JSON output]' \
  '-noheader[omit header]' \
  '*:host:_hosts' && ret=0
return ret
