#compdef create-dynamic-app
# Documentation: https://www.npmjs.com/package/create-dynamic-app
# Reference accessed: 2026-05-24
# Verified: npm view create-dynamic-app bin; npm readme Command-Line Options table.

# Zsh completion for create-dynamic-app - Dynamic.xyz web3 auth app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-f --framework)'{-f,--framework=}'[target framework]:framework:(nextjs react react-native)' \
  '--pm=[package manager]:manager:(npm yarn pnpm bun)' \
  '--package-manager=[package manager alias]:manager:(npm yarn pnpm bun)' \
  '(-l --library)'{-l,--library=}'[Ethereum library]:library:(viem ethers)' \
  '--wagmi=[use Wagmi with Viem]:bool:(true false)' \
  '(-c --chains)'{-c,--chains=}'[comma-separated chain list]:chains:(ethereum solana flow starknet algorand cosmos bitcoin sui)' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
