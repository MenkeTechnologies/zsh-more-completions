#compdef syz-base-commit
# _syz-base-commit — find the kernel commit a fix should be backported to (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-base-commit/main.go (flag).

_syz-base-commit() {
    _arguments \
        '-sourcedir=[path to Linux kernel repository]:dir:_files -/' \
        '*:fix commit:'
}

_syz-base-commit "$@"
