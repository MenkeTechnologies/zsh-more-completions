#compdef autopkgtest-build-lxc
# _autopkgtest-build-lxc — build LXC container template for autopkgtest (Debian/autopkgtest)
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-build-lxc(1) man page.

_autopkgtest-build-lxc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--arch=[dpkg architecture]:arch:(amd64 i386 armhf arm64 ppc64el riscv64 s390x)' \
        '--keyring=[keyring for apt repo verification]:file:_files' \
        '--script=[customization script run inside container]:file:_files' \
        '1:debootstrap variant:(debian ubuntu)' \
        '2:release:(stable testing unstable bookworm trixie jammy noble)' \
        '3:arch:(amd64 i386 armhf arm64 ppc64el riscv64 s390x)' \
        '4:script:_files'
}

_autopkgtest-build-lxc "$@"
