#compdef GenotypeConcordance
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#GenotypeConcordance
# Picard: compute genotype concordance between a truth and a call VCF sample

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-TV=,--TRUTH_VCF=}'[VCF containing the truth sample]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-CV=,--CALL_VCF=}'[VCF containing the call sample]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  {-O=,--OUTPUT=}'[basename for the two metrics files written]:basename:' \
  {-TS=,--TRUTH_SAMPLE=}'[name of the truth sample within the truth VCF]:sample:' \
  {-CS=,--CALL_SAMPLE=}'[name of the call sample within the call VCF]:sample:' \
  '*--INTERVALS=[interval list files limiting the concordance]:interval_list:_files -g "*.interval_list"' \
  '--MIN_GQ=[genotypes below this GQ are classified as LowGq]:int:' \
  '--MIN_DP=[genotypes below this depth are classified as LowDp]:int:' \
  '--OUTPUT_ALL_ROWS=[output all rows even when count is zero]:bool:(true false)' \
  {-MISSING_HOM=,--MISSING_SITES_HOM_REF=}'[treat missing truth sites as homozygous reference]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
