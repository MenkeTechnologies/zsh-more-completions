#compdef llvm-dwp
# _llvm-dwp — LLVM DWARF package merger (LLVM project, C++); combine .dwo files into .dwp packages for split DWARF
# upstream: https://github.com/llvm/llvm-project

_llvm-dwp() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-e+[input executable]:file:_files' \
        '-o+[output dwp]:file:_files' \
        '--continue-on-cu-index-overflow=+[behavior]:behavior:(soft-stop continue)' \
        '*:file:_files -g "*.dwo"'
}

_llvm-dwp "$@"
