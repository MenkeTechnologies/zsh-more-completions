#compdef xset
# _xset — X11 xset (set user preferences on the X server: keyboard rate/click, mouse accel, screensaver, bell, font path, DPMS power saving, LEDs; b/c/q reset toggles)
# upstream: https://gitlab.freedesktop.org/xorg/app/xset
# Subcommands from xset.man on tip.

_xset() {
    _arguments \
        '-display+[X display]:display:' \
        'q[query current settings]' \
        '*:setting:(b c bc fp m p r s dpms led mouse repeat r)'
}

_xset "$@"
