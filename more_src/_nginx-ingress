#compdef nginx-ingress
# Documentation: https://man.archlinux.org/search?q=nginx-ingress
# Reference accessed: 2026-05-16

# nginx-ingress: NGINX Ingress Controller for Kubernetes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--default-server-tls-secret=[default server TLS secret]:secret:' \
  '--enable-cert-manager[enable cert-manager integration]' \
  '--enable-external-dns[enable external-dns integration]' \
  '--enable-leader-election[enable leader election]' \
  '--enable-tls-passthrough[enable TLS passthrough]' \
  '--enable-snippets[enable snippets]' \
  '--enable-custom-resources[enable custom resources]' \
  '--enable-preview-policies[enable preview policies]' \
  '--health-status[enable /healthz]' \
  '--health-status-uri=[health status URI]:uri:' \
  '--ingress-class=[ingress class]:class:' \
  '--ingress-template-path=[ingress template path]:file:_files' \
  '--leader-election-lock-name=[lock name]:name:' \
  '--main-template-path=[main template path]:file:_files' \
  '--metrics-listen-port=[metrics listen port]:port:' \
  '--nginx-configmaps=[NGINX configmap]:ns/name:' \
  '--nginx-debug[enable nginx debug]' \
  '--nginx-reload-timeout=[nginx reload timeout]:duration:' \
  '--nginx-plus[enable NGINX Plus features]' \
  '--proxy-protocol[enable PROXY protocol]' \
  '--ready-status[enable /nginx-ready endpoint]' \
  '--ready-status-port=[ready status port]:port:' \
  '--report-ingress-status[update ingress status]' \
  '--service-insight-listen-port=[service insight port]:port:' \
  '--ssl-services=[TLS services configmap]:cm:' \
  '--use-cluster-ip[use cluster IP]' \
  '--watch-namespace=[watch namespace]:ns:' \
  '--wildcard-tls-secret=[wildcard TLS secret]:secret:' \
  '*::nginx-ingress args:_files' && ret=0
return ret
