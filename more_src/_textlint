#compdef textlint
# Documentation: https://man.archlinux.org/search?q=textlint
# Reference accessed: 2026-05-16

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '--ignore-path=[ignore file]:file:_files' \
  '--init[create config]' \
  '--no-textlintrc[disable .textlintrc]' \
  '*--plugin=[plugin]:plugin:' \
  '*--rule=[rule]:rule:' \
  '*--preset=[preset]:preset:' \
  '--rulesdir=[rules dir]:dir:_files -/' \
  '--fix[auto-fix]' \
  '--dry-run[dry run]' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-f --format)'{-f,--format}'=[format]:fmt:(checkstyle compact github jslint-xml json junit pretty-error stylish table tap unix compats diff fixed-result)' \
  '--no-color[no color]' \
  '--quiet[errors only]' \
  '--stdin[read stdin]' \
  '--stdin-filename=[stdin filename]:name:' \
  '--cache[cache]' \
  '--cache-location=[cache file]:file:_files' \
  '--debug[debug]' \
  '--print-config[print config]' \
  '--experimental[experimental]' \
  '--rules-base-directory=[base dir]:dir:_files -/' \
  '--mcp[MCP server]' \
  '*:file:_files -g "*.(md|markdown|txt|rst)"'
