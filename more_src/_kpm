#compdef kpm
# Documentation: https://www.kcl-lang.io/docs/0.5/reference/package-management/command-reference/
# KCL package manager to install, package and distribute KCL packages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show the kpm version number]' \
  '*:command:((
    init\:"init a kcl package"
    add\:"add a dependency to a kcl package"
    pkg\:"package a kcl package into a tarball"
    metadata\:"print the metadata of a kcl package"
    run\:"compile a kcl package into yaml"
    login\:"login to a kcl registry"
    logout\:"logout from a kcl registry"
    push\:"push a kcl package to a registry"
    pull\:"pull a kcl package from a registry"
    help\:"print help for kpm command"
  ))' && ret=0

return ret
