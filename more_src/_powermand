#compdef powermand
# _powermand — Lawrence Livermore powermand (centralised power-control daemon for cluster nodes; reads /etc/power/powerman.conf to know which scripted backend (apc, ibmrsa, dell-drac, ipmipower) talks to which strip + port; -c config file, -f stay foreground, -d debug bitmask, -L listen address)
# upstream: https://github.com/chaos/powerman
# Flags from chaos/powerman src/powermand.c on tip.

_powermand() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-f[foreground]' \
        '-d+[debug bitmask]:bitmask:' \
        '-L+[listen address]:addr:' \
        '-p+[pidfile]:file:_files' \
        '-l+[log file]:file:_files'
}

_powermand "$@"
