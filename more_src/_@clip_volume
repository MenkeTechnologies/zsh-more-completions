#compdef @clip_volume
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@clip_volume.html
# Clip regions of a volume

local ret=1

_arguments -s -S \
  '-input[volume to clip (mandatory)]:vol:_files' \
  '-below[set to 0 slices below Zmm coordinate]:zmm' \
  '-above[set to 0 slices above Zmm coordinate]:zmm' \
  '-left[set to 0 slices left of Xmm coordinate]:xmm' \
  '-right[set to 0 slices right of Xmm coordinate]:xmm' \
  '-anterior[set to 0 slices anterior to Ymm coordinate]:ymm' \
  '-posterior[set to 0 slices posterior to Ymm coordinate]:ymm' \
  '-box[clip volume to box centered at coords with dims]:cx' \
  '-mask_box[same as -box, set all values inside box to 1]:cx' \
  '(-or)-and[combine clipping planes using logical AND (default)]' \
  '(-and)-or[combine clipping planes using logical OR]' \
  '-verb[display commands (verbose mode)]' \
  '-crop_allzero[crop output with 3dAutobox -noclust]' \
  '-crop_greedy[crop output with 3dAutobox]' \
  '-crop[same as -crop_greedy]' \
  '-crop_npad[set 3dAutobox -npad option value]:npad' \
  '-prefix[output filename prefix]:prefix' \
  '*-followers[apply same treatment to follower datasets]:dset:_files' && ret=0

return ret
