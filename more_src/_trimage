#compdef trimage
# Documentation: https://github.com/Kilian/Trimage/blob/master/README.md
# Trimage - cross-platform lossless PNG and JPG compressor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '(-v --verbose -q --quiet)'{-v,--verbose}'[verbose mode (default)]' \
  '(-q --quiet -v --verbose)'{-q,--quiet}'[quiet mode]' \
  '(-f --file)'{-f,--file}'=[compress image and exit]:file:_files' \
  '(-d --directory)'{-d,--directory}'=[compress images in directory and exit]:dir:_files -/' \
  '*:image:_files' && ret=0

return ret
