#compdef mri_surf2vol
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_surf2vol
# FreeSurfer: resample surface overlay values into a volume

local ret=1

_arguments -s -S \
  '(- *)--help[print help information]' \
  '(- *)--version[print version and exit]' \
  '--so[path to surface and matching overlay]:surface overlay' \
  '--lta[registration file with output space info]:lta file:_files' \
  '--o[output volume]:outfile:_files' \
  '--subject[subject name when LTA not specified]:subject' \
  '--ribbon[ribbon file]:ribbon:_files' \
  '--merge[merge output with this volume]:volume:_files' \
  '--surfval[source of surface values]:surfval' \
  '--mkmask[make binary mask of surface/voxel intersections]' \
  '--hemi[hemisphere]:hemi:(lh rh)' \
  '--surf[surface name (default white)]:surf' \
  '--projfrac[project along normal by thickness fraction]:fraction' \
  '--fillribbon[fill entire ribbon]' \
  '--fill-projfrac[fill ribbon over range]:start stop delta' \
  '--reg[registration matrix]:reg file:_files' \
  '--identity[use identity matrix]:subjid' \
  '--template[template volume for output geometry]:template:_files' \
  '--fstal[use MNI305 template]:resolution:(1 2)' \
  '--vtxvol[vertex-indexed output volume]:vtxvol:_files' \
  '--add[add constant to non-zero output voxels]:constant' \
  '--sd[subjects directory]:dir:_files -/' \
  '--gdiagno[diagnostic level]:number' \
  '*:argument:_files' && ret=0

return ret
