#compdef jack_server_control
# Documentation: https://man.archlinux.org/search?q=jack_server_control
# Reference accessed: 2026-05-16

# jack_server_control: control a running JACK server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[JACK server name]:name:' \
  '--server=[JACK server name]:name:' \
  '*::jack_server_control args:_files' && ret=0
return ret
