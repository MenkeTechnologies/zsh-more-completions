#compdef jack_server_control
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/example-clients/server_control.c
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above (getopt_long: "d:c:").
# Note: prior file invented -n/-s/--name/--server; the real options
# are --driver/-d and --client/-c.

# jack_server_control: control a running JACK server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-d --driver)'{-d,--driver}'+[driver name]:driver:(dummy alsa coreaudio portaudio net netone firewire)' \
  '(-c --client)'{-c,--client}'+[client name]:client name:' && ret=0
return ret
