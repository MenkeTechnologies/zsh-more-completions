#compdef udisksctl
# _udisksctl-cli — udisks2 D-Bus storage daemon CLI; mount/unmount/lock/unlock partitions through polkit policy
# upstream: https://github.com/storaged-project/udisks

_udisksctl-cli() {
    local -a sub=(
        'help:show help'
        'info:show device info'
        'dump:show all info'
        'status:show high-level info'
        'mount:filesystem mount'
        'unmount:filesystem unmount'
        'mkfs:create a new filesystem'
        'unlock:unlock encrypted device'
        'lock:lock encrypted device'
        'loop-setup:setup loop device'
        'loop-delete:delete loop device'
        'power-off:safely power off drive'
        'smart-simulate:simulate SMART data'
        'monitor:monitor events'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--no-user-interaction[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'udisksctl subcommand' sub ;;
        args)
            case $words[1] in
                info|mount|unmount|unlock|lock|power-off) _arguments \
                    '(-b --block-device)'{-b,--block-device}'+[block device]:device:_files' \
                    '(-p --object-path)'{-p,--object-path}'+[object path]:path:' \
                    '(-d --drive)'{-d,--drive}'+[drive]:drive:' \
                    '(-o --options)'{-o,--options}'+[mount options]:opts:' \
                    '(-t --filesystem-type)'{-t,--filesystem-type}'+[fs type]:type:' ;;
                loop-setup) _arguments \
                    '(-f --file)'{-f,--file}'+[backing file]:file:_files' \
                    '(-r --read-only)'{-r,--read-only}'[read only]' \
                    '(-o --offset)'{-o,--offset}'+[offset]:n:' \
                    '(-s --size)'{-s,--size}'+[size]:n:' ;;
                loop-delete) _arguments \
                    '(-b --block-device)'{-b,--block-device}'+[loop device]:device:_files' \
                    '(-p --object-path)'{-p,--object-path}'+[object path]:path:' ;;
                mkfs) _arguments \
                    '(-b --block-device)'{-b,--block-device}'+[block device]:device:_files' \
                    '(-p --object-path)'{-p,--object-path}'+[object path]:path:' \
                    '(-t --type)'{-t,--type}'+[fs type]:type:(ext2 ext3 ext4 btrfs xfs vfat exfat ntfs swap)' \
                    '(-l --label)'{-l,--label}'+[label]:str:' \
                    '--take-ownership[chown to current user]' \
                    '--encrypt[encrypt with LUKS]' ;;
            esac
            ;;
    esac
}

_udisksctl-cli "$@"
