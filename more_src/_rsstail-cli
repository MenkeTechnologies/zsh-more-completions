#compdef rsstail rsstail2

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '*-u+[URL]:url:_urls' \
  '-i+[interval seconds]:s:' \
  '-1[run once]' \
  '-l[show link]' \
  '-p[show pubdate]' \
  '-a[show author]' \
  '-d[show description]' \
  '-t[show title]' \
  '-c[show comments]' \
  '-z[show category]' \
  '-r[reverse order]' \
  '-N[no time printed]' \
  '-T[show time stamp]' \
  '-y+[max items]:n:' \
  '-n+[show last n]:n:' \
  '-o[no output until first update]' \
  '-b+[heartbeat]:s:' \
  '-Z+[strip lines]:n:' \
  '-s[stop after n updates]' \
  '-w[wait for content change]' \
  '-A+[user agent]:ua:' \
  '-x+[proxy URL]:url:' \
  '-D+[debug level]:n:' \
  '-S+[only show items matching regex]:re:' \
  '-X+[exclude items matching regex]:re:' \
  '-P+[output format]:f:' \
  '*: :' && ret=0

return ret
