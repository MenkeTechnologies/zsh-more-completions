#compdef postgis
# Documentation: https://postgis.net/docs/
# Reference accessed: 2026-05-16
# Verified: PostGIS does not provide a standalone CLI binary. All
# functionality is exposed as PostgreSQL extension functions invoked
# via `psql` (e.g. SELECT ST_Distance(...)). Companion CLI tools like
# raster2pgsql, shp2pgsql, pgsql2shp ship as separate binaries with
# their own completion files.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# postgis: PostgreSQL extension (no standalone CLI binary)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
