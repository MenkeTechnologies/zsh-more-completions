#compdef GatherPileupSummaries
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/contamination/GatherPileupSummaries.java
# Combine output files from GetPileupSummaries in the order defined by a sequence dictionary

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{--input,-I}'=[an output of GetPileupSummaries]:value:_files' \
  '(--output -O)'{--output,-O}'=[output file]:value:_files' \
  '(--sequence-dictionary)--sequence-dictionary=[sequence dictionary file]:value:_files' \
  '*:argument:_files' && ret=0

return ret
