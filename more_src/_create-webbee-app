#compdef create-webbee-app
# Documentation: https://www.npmjs.com/package/create-webbee-app
# Reference accessed: 2026-05-24
# Verified: npm view create-webbee-app bin; npx create-webbee-app --help output.

# Zsh completion for create-webbee-app - Webbee React/Next/Vite template scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--template=[app template]:template:(react-webpack-starter react-vite-starter next-starter)' \
  '--tailwind=[initialize Tailwind CSS config]:bool:(true false)' \
  '--eslint=[initialize ESLint config]:bool:(true false)' \
  '--turbo[initialize Turborepo config]' \
  '--use-npm[bootstrap using npm]' \
  '--use-pnpm[bootstrap using pnpm]' \
  '--use-yarn[bootstrap using yarn]' \
  '--css=[CSS setup type]:css:' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  ':project directory:_directories' && ret=0

return ret
