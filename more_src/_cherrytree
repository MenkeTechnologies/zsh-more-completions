#compdef cherrytree
# Documentation: https://www.giuspen.com/cherrytreemanual/
# Source: giuspen/cherrytree — hierarchical note-taking app (GTKmm rewrite of the Python original).
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-n --node)'{-n+,--node=}'[open document at the named node]:node:_default' \
    '(-x --export_to_html_dir)'{-x+,--export_to_html_dir=}'[export the document to HTML in DIR]:dir:_files -/' \
    '(-t --export_to_txt_dir)'{-t+,--export_to_txt_dir=}'[export the document to plain text in DIR]:dir:_files -/' \
    '(-w --export_overwrite)'{-w,--export_overwrite}'[overwrite any existing export]' \
    '(- *)'{-h,--help}'[show help]' \
    '1:document:_files -g "*.(ctb|ctd|ctx|ctz)"' \
    && ret=0

return ret
