#compdef jiracli
# Documentation: https://man.archlinux.org/search?q=jiracli
# Reference accessed: 2026-05-16

# jiracli: command-line interface to Atlassian JIRA
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create an issue'
  'comment:comment on an issue'
  'fetch:fetch an issue'
  'search:search issues'
  'transition:run a transition'
  'fields:list available fields'
  'priorities:list priorities'
  'transitions:list possible transitions'
  'projects:list projects'
  'login:login (cache credentials)'
  'logout:logout (clear cache)'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-u[username]:user:_users' \
  '--user=[username]:user:_users' \
  '-p[password]:pass:' \
  '--password=[password]:pass:' \
  '-j[Jira URL]:url:' \
  '--jira-url=[Jira URL]:url:' \
  '--ssl-verify=[verify SSL]:bool:(true false)' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'jiracli command' commands && ret=0 ;;
esac
return ret
