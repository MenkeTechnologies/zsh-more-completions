#compdef systemd-resolvectl resolvectl-legacy
# _systemd-resolvectl — systemd resolvectl shim (alias of resolvectl(1) keeping the legacy systemd-resolve interface; same subcommand surface (query, service, openpgp, tlsa, statistics, reset-statistics, flush-caches, reset-server-features, dns, domain, llmnr, mdns, nta, dnssec, revert, log-level); -i interface, -t type, -p protocol, -j JSON)
# upstream: https://github.com/systemd/systemd (src/resolve)
# Behaviour from systemd src/resolve/resolvectl.c on tip.

_systemd-resolvectl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-i+[interface]:interface:_net_interfaces' \
        '-p+[protocol]:proto:(dns llmnr mdns)' \
        '-t+[qtype]:type:(A AAAA MX NS PTR TXT SRV CNAME SOA DS DNSKEY CAA TLSA OPENPGPKEY SVCB HTTPS)' \
        '-j[json]' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '1::command:(query service openpgp tlsa statistics reset-statistics flush-caches reset-server-features dns domain default-route llmnr mdns nta dnssec dnsovertls revert log-level monitor show-cache show-server-state status)' \
        '*::arg:'
}

_systemd-resolvectl "$@"
