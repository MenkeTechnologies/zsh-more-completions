#compdef openstack-populator
# _openstack-populator — CDI populator that streams an OpenStack Cinder/Glance image into a PVC
# upstream: https://github.com/kubevirt/containerized-data-importer
# Flags from cmd/openstack-populator/openstack-populator.go on tip.

_openstack-populator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoint=[Keystone endpoint URL]:url:_urls' \
        '--secret-name=[secret containing OpenStack credentials]:name:' \
        '--image-id=[OpenStack image ID]:id:' \
        '--volume-path=[path to populate]:path:_files' \
        '--owner-uid=[owner UID (usually PVC UID)]:uid:' \
        '--pvc-size=[size of pvc (bytes)]:n:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_openstack-populator "$@"
