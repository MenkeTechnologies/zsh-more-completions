#compdef kubevpn

local curcontext="$curcontext" state line ret=1

_kubevpn_global_flags=(
  '--kubeconfig[path to the kubeconfig file]:file:_files'
  '--kubeconfig-json[kubeconfig in JSON format]:json'
  '--context[the name of the kubeconfig context to use]:context'
  '--cluster[the name of the kubeconfig cluster to use]:cluster'
  '--user[the name of the kubeconfig user to use]:user'
  {-n,--namespace}'[namespace scope for this request]:namespace'
  {-s,--server}'[the address and port of the Kubernetes API server]:server'
)

_kubevpn_commands() {
  local -a commands=(
    'connect:connect to the Kubernetes cluster network'
    'disconnect:disconnect from a cluster network'
    'proxy:proxy inbound workload traffic to the local machine'
    'proxy-out:expose cluster workloads through a local outbound proxy'
    'leave:leave proxied workloads'
    'sync:sync local files to a workload'
    'unsync:stop an active sync'
    'run:run a command with cluster access'
    'status:show connection and proxy status'
    'alias:manage kubevpn aliases'
    'connection:manage saved connections'
    'route:inspect managed routes'
    'ssh:manage SSH helpers'
    'logs:show kubevpn logs'
    'reset:reset kubevpn state'
    'uninstall:remove kubevpn components'
    'quit:stop managed background services'
    'upgrade:upgrade kubevpn'
    'version:show version information'
    'options:show global options'
  )
  _describe -t commands 'kubevpn command' commands
}

_arguments -C \
  "${_kubevpn_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _kubevpn_commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (connect)
        _arguments -s -S \
          "${_kubevpn_global_flags[@]}" \
          '--foreground[hang up in the foreground]' \
          '--socks[start a managed local SOCKS5 proxy after connect]' \
          '--socks-listen[SOCKS5 listen address]:address' \
          '--manager-namespace[traffic manager namespace]:namespace' \
          '--ssh-addr[SSH jump host address]:host:port' \
          '--ssh-username[SSH username]:user' \
          '--ssh-keyfile[SSH private key file]:file:_files' \
          '--ssh-alias[SSH alias from local config]:alias' \
          '--ssh-jump[inline SSH jump configuration]:jump config' \
          '--gssapi-keytab[GSSAPI keytab file]:file:_files' \
          '--gssapi-cache[GSSAPI cache file]:file:_files' \
          '--gssapi-password[GSSAPI password]:password' && ret=0
        ;;
      (disconnect)
        _arguments \
          "${_kubevpn_global_flags[@]}" \
          '1:connection id:' && ret=0
        ;;
      (proxy)
        _arguments -s -S \
          "${_kubevpn_global_flags[@]}" \
          '(-H --headers)'{-H,--headers}'[header that triggers local routing]:key=value' \
          '--portmap[map container port to local port]:mapping' \
          '--foreground[hang up in the foreground]' \
          '--manager-namespace[traffic manager namespace]:namespace' \
          '--ssh-addr[SSH jump host address]:host:port' \
          '--ssh-username[SSH username]:user' \
          '--ssh-keyfile[SSH private key file]:file:_files' \
          '--ssh-alias[SSH alias from local config]:alias' \
          '--gssapi-keytab[GSSAPI keytab file]:file:_files' \
          '--gssapi-cache[GSSAPI cache file]:file:_files' \
          '--gssapi-password[GSSAPI password]:password' \
          '*:workload:' && ret=0
        ;;
      (proxy-out)
        _arguments -s -S \
          "${_kubevpn_global_flags[@]}" \
          '--listen-socks[local SOCKS5 listen address]:address' \
          '--listen-http-connect[local HTTP CONNECT listen address]:address' && ret=0
        ;;
      (leave)
        _arguments \
          "${_kubevpn_global_flags[@]}" \
          '*:workload:' && ret=0
        ;;
      (sync)
        _arguments -s -S \
          "${_kubevpn_global_flags[@]}" \
          '1:workload:' \
          '2:local path:_files' \
          '3:remote path:' && ret=0
        ;;
      (unsync)
        _arguments \
          "${_kubevpn_global_flags[@]}" \
          '1:workload:' && ret=0
        ;;
      (run)
        _arguments \
          "${_kubevpn_global_flags[@]}" \
          '*:command:_command_names -e' && ret=0
        ;;
      (status)
        _arguments -s -S \
          "${_kubevpn_global_flags[@]}" \
          '(-o --output)'{-o,--output}'[output format]:format:(table json yaml)' && ret=0
        ;;
      (logs|route|alias|connection|ssh|reset|uninstall|quit|upgrade|version|options)
        _arguments "${_kubevpn_global_flags[@]}" '*:arg' && ret=0
        ;;
    esac
    ;;
esac

return ret
