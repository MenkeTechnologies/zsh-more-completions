#compdef bufr_set
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_set
# Source: ecmwf/eccodes tools/bufr_set.cc — set key/value pairs in BUFR messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s+[key=value pairs to set]:kvs:_default' \
    '-p+[keys to print]:keys:_default' \
    '-P+[append keys to default print list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-7[do not fail on wrong message length]' \
    '-S[strict — only matching messages are written]' \
    '(- *)-V[show version]' \
    '-g[copy GTS header]' \
    '-T+[message type]:type:(T B M A)' \
    '-f[force, do not fail on error]' \
    '-v[verbose]' \
    '*:bufr file:_files' \
    && ret=0

return ret
