#compdef pslReps
# UCSC kent: analyze repeats and generate genome-wide best alignments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-nohead[don'\''t add PSL header]' \
  '-ignoreSize[larger alignments not weighed as much in favor]' \
  '-noIntrons[don'\''t penalize for not having introns]' \
  '-singleHit[take single best hit, not splitting into parts]' \
  '-minCover=[minimum coverage to output]:frac:' \
  '-ignoreNs[ignore Ns when calculating minCover]' \
  '-minAli=[minimum alignment ratio (default 0.93)]:frac:' \
  '-nearTop=[how much can deviate from top and be taken]:frac:' \
  '-minNearTopSize=[minimum size of near-top alignment]:n:' \
  '-coverQSizes=[file with effective query sizes]:file:_files' \
  ':in psl:_files' \
  ':out psl:_files' \
  ':out psr:_files' && ret=0

return ret
