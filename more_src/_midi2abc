#compdef midi2abc
# _midi2abc — convert MIDI files to ABC music notation (sshlien/abcmidi)
# upstream: https://github.com/sshlien/abcmidi
# Flags from midi2abc(1) man page.

_midi2abc() {
    _arguments \
        '-a+[anacrusis in half unit lengths]:beats:' \
        '-xa[extract anacrusis from first strong note]' \
        '-ga[guess anacrusis by minimizing ties across bars]' \
        '-m+[time signature]:sig:' \
        '-b+[bars wanted in output]:n:' \
        '-Q+[tempo (quarter-notes per minute)]:bpm:' \
        '-u+[midi pulses per ABC time unit]:n:' \
        '-ppu+[parts per ABC unit length]:n:' \
        '-aul+[denominator of ABC unit length]:n:' \
        '-gu[guess pulses per ABC time unit]' \
        '-gk[guess key signature]' \
        '-k+[key signature (-6..6 sharps)]:n:' \
        '-c+[select MIDI channel]:channel:' \
        '-f+[input MIDI file]:file:_files -g "*.{mid,midi}"' \
        '-o+[output ABC file]:file:_files -g "*.abc"' \
        '-s[do not discard very short notes]' \
        '-sr+[do not notate rest smaller than quantum units]:n:' \
        '-sum[print short summary of input MIDI]' \
        '-nb[do not look for broken rhythms]' \
        '-nt[do not look for triplets]' \
        '-obpl[one bar per line]' \
        '-nogr[no note grouping]' \
        '-bpl+[bars per line]:n:' \
        '-bps+[bars per split line]:n:' \
        '-splitvoices[split polyphonic chords into voices]' \
        '-midigram[output midigram list]' \
        '-mftext[output MIDI text events]' \
        '-mftextpulses[output MIDI text events with pulses]' \
        '-title+[set T: title field]:title:' \
        '-origin+[set O: origin field]:origin:' \
        '-midinotes[output MIDI pitch/cents info]' \
        '*:MIDI file:_files -g "*.{mid,midi}"'
}

_midi2abc "$@"
