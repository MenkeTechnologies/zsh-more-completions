#compdef kbuildsycoca6 kbuildsycoca5
# _kbuildsycoca6 — KService kbuildsycoca5/6 (rebuild KDE's system configuration cache (.kde/...ksycoca); --noincremental forces full rebuild, --menutest reports menu-config errors, --testmode runs against test env)
# upstream: https://invent.kde.org/frameworks/kservice (src/kbuildsycoca/kbuildsycoca.cpp)
# Flags from kservice src/kbuildsycoca/kbuildsycoca.cpp on tip.

_kbuildsycoca6() {
    _arguments \
        '--help[show help]' \
        '--noincremental[force full rebuild]' \
        '--menutest[test the menu structure]' \
        '--testmode[use test environment]' \
        '--track+[track resource]:resource:' \
        '--global[update global cache]'
}

_kbuildsycoca6 "$@"
