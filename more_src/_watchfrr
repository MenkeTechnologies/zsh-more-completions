#compdef watchfrr

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[daemonize]' \
  '(-l --loglevel)'{-l,--loglevel}'+[log level]:level:(LOG_EMERG LOG_ALERT LOG_CRIT LOG_ERR LOG_WARNING LOG_NOTICE LOG_INFO LOG_DEBUG)' \
  '(-S --statedir)'{-S,--statedir}'+[state directory]:dir:_files -/' \
  '(-e --no-echo)'{-e,--no-echo}'[do not ping daemons]' \
  '(-r --restart)'{-r,--restart}'+[restart command]:cmd:' \
  '(-s --start-command)'{-s,--start-command}'+[start command]:cmd:' \
  '(-k --stop-command)'{-k,--stop-command}'+[stop command]:cmd:' \
  '(-t --timeout)'{-t,--timeout}'+[timeout sec]:sec:' \
  '(-T --restart-timeout)'{-T,--restart-timeout}'+[restart timeout sec]:sec:' \
  '(-p --pid-file)'{-p,--pid-file}'+[pid file]:file:_files' \
  '(-b --blank-string)'{-b,--blank-string}'+[blank string]:str:' \
  '(-i --interval)'{-i,--interval}'+[heartbeat interval sec]:sec:' \
  '(-z --unresponsive-restart)'{-z,--unresponsive-restart}'[restart unresponsive daemons]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:daemons:' && ret=0

return ret
