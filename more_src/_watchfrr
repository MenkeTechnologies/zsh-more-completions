#compdef watchfrr
# Documentation: https://docs.frrouting.org/en/latest/watchfrr.html
# Reference accessed: 2026-05-21
# Verified: upstream source github.com/FRRouting/frr/watchfrr/watchfrr.c

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode]' \
  '(-l --loglevel)'{-l,--loglevel}'+[set logging level]:level:' \
  '(-S --statedir)'{-S,--statedir}'+[vty socket directory]:dir:_files -/' \
  '(-N --pathspace)'{-N,--pathspace}'+[prefix for config/socket paths]:prefix:' \
  '--netns=[create/use Linux network namespace]:name:' \
  '(-r --restart)'{-r,--restart}'+[restart command for a single daemon]:cmd:' \
  '(-s --start-command)'{-s,--start-command}'+[start command for a single daemon]:cmd:' \
  '(-k --kill-command)'{-k,--kill-command}'+[kill command for a single daemon]:cmd:' \
  '(-t --timeout)'{-t,--timeout}'+[unresponsiveness timeout sec]:sec:' \
  '(-T --restart-timeout)'{-T,--restart-timeout}'+[restart kill timeout sec]:sec:' \
  '(-i --interval)'{-i,--interval}'+[status polling interval sec]:sec:' \
  '(-c --collect-core)'{-c,--collect-core}'[send SIGABRT to collect core on missed heartbeat]' \
  '(-p --pid-file)'{-p,--pid-file}'+[pid file]:file:_files' \
  '(-b --blank-string)'{-b,--blank-string}'+[blank string for argument substitution]:str:' \
  '--dry[do not start or restart anything, just log]' \
  '--min-restart-interval=[min seconds between restart invocations]:sec:' \
  '--max-restart-interval=[max seconds between restart invocations]:sec:' \
  '--operational-timeout=[seconds before systemd is told operational]:sec:' \
  '*:daemons:' && ret=0

return ret
