#compdef metalcloud-cli
# Documentation: https://github.com/metalsoft-io/metalcloud-cli/blob/master/README.md
# MetalSoft Metalcloud CLI for managing bare-metal cloud infrastructure

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version information]' \
  '--format=[output format]:format:(json yaml csv text)' \
  '*:command:((infrastructure\:"manage infrastructures" instance-array\:"manage instance arrays" drive-array\:"manage drive arrays" datacenter\:"manage datacenters" secret\:"manage secrets" workflow\:"manage workflows" apply\:"create or update a resource from a YAML file" get\:"get a resource" list\:"list resources" delete\:"delete a resource"))' && ret=0

return ret
