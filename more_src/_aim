#compdef aim
# Documentation: https://aimstack.readthedocs.io/en/stable/refs/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize an Aim repo'
  'version:show Aim version'
  'up:launch the Aim web UI'
  'server:run a remote tracking server'
  'telemetry:configure telemetry'
  'reset:reset the local Aim repo'
  'runs:manage experiment runs'
  'convert:convert third-party experiment data'
  'storage:repository maintenance'
  'upgrade:upgrade Aim repository runs data'
  'remote:run a tracking server (alias)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'aim command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--repo=[repo path]:dir:_files -/' \
          '--yes[skip confirmation]' && ret=0 ;;
      (up)
        _arguments \
          '(-h --host)'{-h+,--host=}'[host address]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[port (default 43800)]:port:' \
          '--repo=[repo path]:dir:_files -/' \
          '--workers=[worker count]:n:' \
          '--uds=[unix domain socket path]:file:_files' \
          '--ssl-keyfile=[SSL key file]:file:_files' \
          '--ssl-certfile=[SSL certificate file]:file:_files' \
          '--base-path=[URL base path]:path:' \
          '--profiler[enable API profiler]' \
          '--dev[development mode]' \
          '-y[auto-confirm prompts]' \
          '--log-level=[Python log level]:level:(debug info warning error critical)' && ret=0 ;;
      (server)
        _arguments \
          '--repo=[repo path]:dir:_files -/' \
          '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[port (default 53800)]:port:' \
          '-w[worker count]:n:' \
          '--workers=[worker count]:n:' \
          '--ssl-keyfile=[SSL key]:file:_files' \
          '--ssl-certfile=[SSL cert]:file:_files' \
          '--base-path=[URL base path]:path:' \
          '--dev[development mode]' \
          '--log-level=[log level]:level:(debug info warning error critical)' && ret=0 ;;
      (runs)
        local -a runs_cmds=(
          'ls:list runs'
          'rm:remove runs'
          'cp:copy runs'
          'mv:move runs to another repo'
          'upload:upload runs to cloud bucket'
          'close:close failed runs'
        )
        _describe -t rcmds 'runs command' runs_cmds && ret=0
        _arguments \
          '--repo=[repo path]:dir:_files -/' \
          '--destination=[destination repo path]:dir:_files -/' \
          '--bucket=[cloud bucket name]:bucket:' && ret=0 ;;
      (convert)
        local -a conv_cmds=(
          'tensorboard:convert TensorBoard logs'
          'mlflow:convert MLflow logs'
          'wandb:convert W&B logs'
        )
        _describe -t ccmds 'convert command' conv_cmds && ret=0
        _arguments \
          '--repo=[target repo]:dir:_files -/' \
          '--flat[flat output structure]' \
          '--no-cache[do not cache previous runs]' && ret=0 ;;
      (storage)
        local -a stor_cmds=(
          'upgrade:upgrade storage format'
          'restore:restore corrupted storage'
          'reindex:rebuild index'
          'prune:prune deleted runs'
        )
        _describe -t scmds 'storage command' stor_cmds && ret=0
        _arguments \
          '--repo=[repo path]:dir:_files -/' \
          '--finalize-only[reindex finalize only]' && ret=0 ;;
      (telemetry)
        _arguments '*::on_off:(on off)' && ret=0 ;;
      (reset)
        _arguments \
          '--repo=[repo path]:dir:_files -/' \
          '-y[auto-confirm]' && ret=0 ;;
    esac ;;
esac

return ret
