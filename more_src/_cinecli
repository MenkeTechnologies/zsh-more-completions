#compdef cinecli
# Documentation: https://github.com/NerdBaba/cinecli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# eyeblech/cinecli (typer); Homebrew: Formula/c/cinecli.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'cinecli command' compadd -- search open download config
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
