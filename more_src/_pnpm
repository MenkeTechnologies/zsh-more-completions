#compdef pnpm

# Zsh completion for pnpm (package manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-r[Run command in every package found in subdirectories]' \
  '--recursive[Run command in every package found in subdirectories]' \
  '--filter=[Restrict to packages matching pattern]:pattern' \
  '--filter-prod=[Restrict to packages matching pattern (prod only)]:pattern' \
  '-w[Run as if inside the workspace root]' \
  '--workspace-root[Run as if inside the workspace root]' \
  '-C+[Change to directory]:dir:_directories' \
  '--dir=[Change to directory]:dir:_directories' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:Install a package'
      'audit:Check for known security issues'
      'bin:Print the directory where pnpm installs executables'
      'config:Manage the pnpm configuration files'
      'c:Manage the pnpm configuration files'
      'create:Create a project from a create-* or @scope/create-* starter kit'
      'dedupe:Perform an install removing older dependencies in the lockfile'
      'deploy:Deploy a package from a workspace'
      'dlx:Fetch a package, install it, and run its default command binary'
      'doctor:Check for known common issues'
      'env:Manage Node.js environments'
      'exec:Execute a shell command in scope of a project'
      'fetch:Fetch packages from a lockfile into virtual store'
      'import:Generate a pnpm-lock.yaml from npm or yarn lockfile'
      'init:Create a package.json file'
      'install:Install all dependencies for a project'
      'i:Install all dependencies for a project'
      'install-test:Runs pnpm install followed by pnpm test'
      'it:Runs pnpm install followed by pnpm test'
      'licenses:Check licenses of installed packages'
      'link:Connect the local project to another one'
      'ln:Connect the local project to another one'
      'list:Print all the versions of packages installed'
      'ls:Print all the versions of packages installed'
      'outdated:Check for outdated packages'
      'pack:Create a tarball from a package'
      'patch:Prepare a package for patching'
      'patch-commit:Generate a patch from a directory'
      'patch-remove:Remove a patch'
      'prune:Remove extraneous packages'
      'publish:Publish a package to a registry'
      'rebuild:Rebuild a package'
      'rb:Rebuild a package'
      'remove:Remove packages from node_modules and package.json'
      'rm:Remove packages from node_modules and package.json'
      'un:Remove packages from node_modules and package.json'
      'uninstall:Remove packages from node_modules and package.json'
      'root:Print the effective modules directory'
      'run:Run a defined package script'
      'server:Manage a store server'
      'setup:Setup pnpm'
      'start:Run the start script'
      'store:Manage the package store'
      'test:Run the test script'
      't:Run the test script'
      'tst:Run the test script'
      'unlink:Unlinks a package'
      'update:Update packages to their latest version'
      'up:Update packages to their latest version'
      'upgrade:Update packages to their latest version'
      'why:Shows all packages that depend on the specified package'
    )
    _describe -t commands 'pnpm command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      add)
        _arguments -s -S \
          '-D[Save package to devDependencies]' \
          '--save-dev[Save package to devDependencies]' \
          '-O[Save package to optionalDependencies]' \
          '--save-optional[Save package to optionalDependencies]' \
          '-P[Save package to dependencies]' \
          '--save-prod[Save package to dependencies]' \
          '-E[Install exact version]' \
          '--save-exact[Install exact version]' \
          '-g[Install as a global package]' \
          '--global[Install as a global package]' \
          '--save-peer[Save package to peerDependencies]' \
          '--workspace[Only add dependencies found in the workspace]' \
          '--global-dir=[Specify a custom directory to store global packages]:dir:_directories' \
          '--virtual-store-dir=[Virtual store directory]:dir:_directories' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      install|i)
        _arguments -s -S \
          '--frozen-lockfile[Do not generate a lockfile]' \
          '--lockfile-only[Only update pnpm-lock.yaml]' \
          '--no-frozen-lockfile[Do not fail if lockfile is outdated]' \
          '--prefer-frozen-lockfile[Prefer frozen lockfile]' \
          '--prefer-offline[Use cached packages if available]' \
          '--prod[Only install production dependencies]' \
          '-P[Only install production dependencies]' \
          '--dev[Only install development dependencies]' \
          '-D[Only install development dependencies]' \
          '--no-optional[Do not install optional dependencies]' \
          '--ignore-scripts[Do not run any scripts]' \
          '--fix-lockfile[Fix broken lockfile entries]' \
          '--shamefully-hoist[Create a flat node_modules]' \
          '--no-hoist[Do not hoist packages]' \
          '--strict-peer-dependencies[Fail on missing peer dependencies]' \
          '--reporter=[Specify the reporter]:reporter:(default append-only ndjson silent)' \
          '--store-dir=[The directory to store packages]:dir:_directories' \
          '--virtual-store-dir=[Virtual store directory]:dir:_directories' \
          '--verify-store-integrity[Verify the integrity of the store]' \
          '--child-concurrency=[Number of child processes]:number' \
          '--network-concurrency=[Number of network requests]:number' \
          '--side-effects-cache[Use side effects cache]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      remove|rm|un|uninstall)
        _arguments -s -S \
          '-D[Remove from devDependencies]' \
          '--save-dev[Remove from devDependencies]' \
          '-O[Remove from optionalDependencies]' \
          '--save-optional[Remove from optionalDependencies]' \
          '-P[Remove from dependencies]' \
          '--save-prod[Remove from dependencies]' \
          '-g[Remove global package]' \
          '--global[Remove global package]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--recursive[Run in every package found in subdirectories]' \
          '-r[Run in every package found in subdirectories]' \
          '--if-present[Do not exit with error code if script is missing]' \
          '--parallel[Ignore concurrency and run scripts in parallel]' \
          '--stream[Stream output from child processes immediately]' \
          '--aggregate-output[Aggregate output from child processes]' \
          '--reporter=[Specify the reporter]:reporter:(default append-only ndjson silent)' \
          '--resume-from=[Resume from a particular project]:project' \
          '--sequential[Run scripts one after another]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:script:->scripts' \
          '*:args' && ret=0
        ;;
      update|up|upgrade)
        _arguments -s -S \
          '-g[Update global packages]' \
          '--global[Update global packages]' \
          '-D[Only update devDependencies]' \
          '--dev[Only update devDependencies]' \
          '-P[Only update production dependencies]' \
          '--prod[Only update production dependencies]' \
          '--no-optional[Do not update optional dependencies]' \
          '-i[Show outdated deps and select which ones to update]' \
          '--interactive[Show outdated deps and select which ones to update]' \
          '-L[Update to the latest version]' \
          '--latest[Update to the latest version]' \
          '-r[Run in every package found in subdirectories]' \
          '--recursive[Run in every package found in subdirectories]' \
          '--workspace[Only update packages found in the workspace]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          '-g[List global packages]' \
          '--global[List global packages]' \
          '--json[Output in JSON format]' \
          '--long[Show extended information]' \
          '--parseable[Output parseable results]' \
          '--depth=[Max display depth]:depth' \
          '-D[Only list devDependencies]' \
          '--dev[Only list devDependencies]' \
          '-P[Only list production dependencies]' \
          '--prod[Only list production dependencies]' \
          '--no-optional[Do not list optional dependencies]' \
          '-r[Run in every package found in subdirectories]' \
          '--recursive[Run in every package found in subdirectories]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '-r[Run in every package found in subdirectories]' \
          '--recursive[Run in every package found in subdirectories]' \
          '--parallel[Ignore concurrency and run in parallel]' \
          '-c+[Run specified command]:command' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*::command:_command_names -e' && ret=0
        ;;
      dlx)
        _arguments -s -S \
          '-p+[Package to install]:package' \
          '--package=[Package to install]:package' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:command' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '--access=[Access level]:access:(public restricted)' \
          '--tag=[Publish with tag]:tag' \
          '--dry-run[Do not actually publish]' \
          '--no-git-checks[Do not check if current branch is your publish branch]' \
          '--otp=[One-time password from authenticator]:otp' \
          '--registry=[The registry to publish to]:url' \
          '--report-summary[Save the list of published packages to pnpm-publish-summary.json]' \
          '--force[Publish even if version is already published]' \
          '-r[Publish all packages in workspace]' \
          '--recursive[Publish all packages in workspace]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:tarball or folder:_files' && ret=0
        ;;
      outdated)
        _arguments -s -S \
          '-g[Check global packages]' \
          '--global[Check global packages]' \
          '--long[Show extended information]' \
          '--format=[Output format]:format:(default json list table)' \
          '--compatible[Print only versions compatible with current semver range]' \
          '-D[Only check devDependencies]' \
          '--dev[Only check devDependencies]' \
          '-P[Only check production dependencies]' \
          '--prod[Only check production dependencies]' \
          '--no-optional[Do not check optional dependencies]' \
          '-r[Run in every package found in subdirectories]' \
          '--recursive[Run in every package found in subdirectories]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      store)
        local -a subcmds=(
          'add:Add new packages to the store'
          'path:Print the path to the active store directory'
          'prune:Remove unreferenced packages from the store'
          'status:Check the integrity of the store'
        )
        _describe -t subcmds 'store subcommand' subcmds && ret=0
        ;;
      env)
        local -a subcmds=(
          'use:Install and use the specified Node.js version'
          'remove:Remove the specified Node.js version'
          'list:List Node.js versions available locally or remotely'
          'ls:List Node.js versions available locally or remotely'
        )
        _describe -t subcmds 'env subcommand' subcmds && ret=0
        ;;
      why)
        _arguments -s -S \
          '--json[Output in JSON format]' \
          '--long[Show extended information]' \
          '--parseable[Output parseable results]' \
          '-g[Search in global packages]' \
          '--global[Search in global packages]' \
          '-D[Only search in devDependencies]' \
          '--dev[Only search in devDependencies]' \
          '-P[Only search in production dependencies]' \
          '--prod[Only search in production dependencies]' \
          '-r[Run in every package found in subdirectories]' \
          '--recursive[Run in every package found in subdirectories]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:package' && ret=0
        ;;
      patch)
        _arguments -s -S \
          '--edit-dir=[The package that needs to be modified will be extracted to this directory]:dir:_directories' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:package' && ret=0
        ;;
      patch-commit)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:patch dir:_directories' && ret=0
        ;;
    esac

    if [[ $state == scripts ]]; then
      local -a scripts
      if [[ -f package.json ]]; then
        scripts=( ${(f)"$(node -e "try{const p=require('./package.json');Object.keys(p.scripts||{}).forEach(k=>console.log(k))}catch(e){}" 2>/dev/null)"} )
      fi
      _describe -t scripts 'script' scripts && ret=0
    fi
    ;;
esac

return ret
