#compdef samtools-ampliconstats
# Documentation: http://www.htslib.org/doc/samtools-ampliconstats.html
# samtools ampliconstats: Get statistics from amplicon sequencing alignment file

local ret=1

_arguments -s -S \
  '(-f --required-flag)'{-f,--required-flag}'[Only output alignments with all bits set in INT present in the FLAG fi]:INT: ' \
  '(-F --filter-flag)'{-F,--filter-flag}'[Do not output alignments with any bits set in INT present in the FLAG]:INT: ' \
  '(-a --max-amplicons)'{-a,--max-amplicons}'[Specify the maximum number of amplicons permitted.]:INT: ' \
  '(-b --tcoord-bin)'{-b,--tcoord-bin}'[Bin the template start,end positions into multiples of NT prior to cou]:INT: ' \
  '(-c --tcoord-min-count)'{-c,--tcoord-min-count}'[In the FTCOORD and CTCOORD lines, only record template start,end coord]:INT: ' \
  '(-d --min-depth)'{-d,--min-depth}'[Specifies the minimum base depth to consider a reference position to b]:INT: ' \
  '(-D --depth-bin)'{-D,--depth-bin}'[Controls the merging of neighbouring similar depths for the FDP_ALL an]:FRACTION: ' \
  '(-l --max-amplicon-length)'{-l,--max-amplicon-length}'[Specifies the maximum length of any individual amplicon.]:INT: ' \
  '(-m --pos-margin)'{-m,--pos-margin}'[Reads are compared against the primer start and end locations specifie]:INT: ' \
  '(-o)'-o'[Output stats to FILE. The default is to write to stdout.]:FILE:_files' \
  '(-s --use-sample-name)'{-s,--use-sample-name}'[Instead of using the basename component of the input path names, use t]' \
  '(-S --single-ref)'{-S,--single-ref}'[Force the output format to match the older single-reference style used]' \
  '(-t --tlen-adjust)'{-t,--tlen-adjust}'[Adjust the TLEN field by +/- INT to compensate for primer clipping. Th]:INT: ' \
  '*:file:_files' && ret=0

return ret
