#compdef httpcat
# Documentation: https://github.com/httpie/httpcat
# Source: httpie/httpcat httpcat.py — construct raw HTTP requests on the command line (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-v --verbose)'{-v,--verbose}'[show the constructed request on stderr]' \
    '(-n --no-stdin)'{-n,--no-stdin}'[do not read body from stdin]' \
    '(- *)'{-V,--version}'[print version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:line:_default' \
    && ret=0

return ret
