#compdef cartographer_pbstream_map_publisher
# Documentation: https://github.com/cartographer-project/cartographer_ros/blob/master/cartographer_ros/cartographer_ros/pbstream_map_publisher_main.cc
# Publish a Cartographer pbstream map as a ROS topic

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '-pbstream_filename=[filename of a pbstream to draw a map from]:file:_files -g "*.pbstream"' \
  '-map_topic=[name of the published map topic]:topic' \
  '-map_frame_id=[frame ID of the published map]:frame' \
  '-resolution=[resolution of a grid cell in the drawn map]:m' && ret=0

return ret
