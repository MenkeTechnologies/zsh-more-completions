#compdef pingdom-cli pingdom
# _pingdom-cli — SolarWinds Pingdom pingdom-cli CLI command-line frontend wrapping the Pingdom uptime monitoring real-user monitoring synthetic transaction monitoring platform REST API providing checks summary performance results outages probes contacts maintenance teams users reports public-report-share traceroute transaction-checks tms TMS-test-management Real-User-Monitoring (SolarWinds Pingdom team Mikael Hansson, Go); cobra
# upstream: https://www.pingdom.com/

_pingdom-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'check:check operations'
        'tms:transaction monitoring operations'
        'summary:summary operations'
        'results:check results'
        'outage:outage operations'
        'performance:performance operations'
        'probe:probe operations'
        'contact:contact operations'
        'team:team operations'
        'user:user operations'
        'maintenance:maintenance window operations'
        'report:report operations'
        'traceroute:traceroute operation'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--account-email=+[email]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pingdom subcommand' sub ;;
        args)
            case $words[1] in
                check|tms|summary|results|outage|performance|probe|contact|team|user|maintenance|report|webhook) _arguments '1:op:(list get create update delete pause resume run)' '*:id:' ;;
            esac
            ;;
    esac
}

_pingdom-cli "$@"
