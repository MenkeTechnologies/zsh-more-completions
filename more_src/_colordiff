#compdef colordiff
# Documentation: colordiff --help
# Source: colordiff — colorize output of diff(1).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--color=[force / suppress color output]:mode:(yes no)' \
    '--color\=patches=[force / suppress colour codes in patch output]:mode:(yes no)' \
    '--color-term-output-only=[colour only on terminal output]:mode:(yes no)' \
    '--difftype=[force difftype]:type:(diff diffc diffu diffy debdiff wdiff)' \
    '(--banner --nobanner)--banner[show colordiff banner]' \
    '(--banner --nobanner)--nobanner[suppress colordiff banner]' \
    '*:diff input file:_files' \
    && ret=0

return ret
