#compdef bokeh
# Documentation: https://docs.bokeh.org/en/latest/docs/reference/command.html
# Reference accessed: 2026-06-04

# Zsh completion for Bokeh visualization library CLI

_bokeh() {
    local line state ret=1

    local -a subcmds=(
        'serve:run a Bokeh server with one or more applications'
        'html:create a standalone HTML file for one or more applications'
        'json:create a JSON file for one or more applications'
        'png:create a PNG file for one or more applications'
        'svg:create an SVG file for one or more applications'
        'static:print the locations of BokehJS static resources'
        'secret:generate a Bokeh secret key for use with the server'
        'info:print information about Bokeh and BokehJS'
        'sampledata:download the Bokeh sample data sets'
    )

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '(- *)--version[show version and exit]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'bokeh commands' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                serve)
                    _arguments \
                        '--port[port to listen on]:port number' \
                        '--address[address to listen on]:address' \
                        '--log-level[set the log level]:level:(trace debug info warning error critical)' \
                        '--num-procs[number of worker processes]:number' \
                        '--prefix[URL prefix for Bokeh server]:prefix' \
                        '--keep-alive[how often to send a keep-alive ping]:milliseconds' \
                        '--check-unused-sessions[how often to check for unused sessions]:milliseconds' \
                        '--unused-session-lifetime[how long unused sessions last]:milliseconds' \
                        '--stats-log-frequency[how often to log stats]:milliseconds' \
                        '--mem-log-frequency[how often to log memory usage]:milliseconds' \
                        '--use-xheaders[prefer X-headers for redirects]' \
                        '--index[path to a template to use for the site index]:file:_files' \
                        '--disable-index[do not use the default index on the root path]' \
                        '--disable-index-redirect[do not redirect to running app from root path]' \
                        '--show[open a browser after starting server]' \
                        '*--allow-websocket-origin[public hostnames allowed for WebSocket connections]:hostname' \
                        '--glob[process all filename arguments as globs]' \
                        '*--dev[enable development-time features]:target' \
                        '--args[command line arguments for scripts]:args' \
                        '(- *)--help[show help message and exit]' \
                        '*:script:_files -g "*.py"' && ret=0
                    ;;
                html)
                    _arguments \
                        '(-o --output)'{-o,--output}'[output file name]:file:_files -g "*.html"' \
                        '(- *)--help[show help message and exit]' \
                        '*:script:_files -g "*.py"' && ret=0
                    ;;
                json)
                    _arguments \
                        '(-o --output)'{-o,--output}'[output file name]:file:_files -g "*.json"' \
                        '--indent[number of spaces for indentation]:indent' \
                        '(- *)--help[show help message and exit]' \
                        '*:script:_files -g "*.py"' && ret=0
                    ;;
                png)
                    _arguments \
                        '(-o --output)'{-o,--output}'[output file name]:file:_files -g "*.png"' \
                        '--height[height of the output image in pixels]:pixels' \
                        '--width[width of the output image in pixels]:pixels' \
                        '(- *)--help[show help message and exit]' \
                        '*:script:_files -g "*.py"' && ret=0
                    ;;
                svg)
                    _arguments \
                        '(-o --output)'{-o,--output}'[output file name]:file:_files -g "*.svg"' \
                        '--height[height of the output image in pixels]:pixels' \
                        '--width[width of the output image in pixels]:pixels' \
                        '(- *)--help[show help message and exit]' \
                        '*:script:_files -g "*.py"' && ret=0
                    ;;
                info)
                    _arguments \
                        '--static[print the locations of BokehJS static resources]' \
                        '(- *)--help[show help message and exit]' && ret=0
                    ;;
                secret)
                    _arguments \
                        '(- *)--help[show help message and exit]' && ret=0
                    ;;
                sampledata)
                    _arguments \
                        '(- *)--help[show help message and exit]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_bokeh "$@"
