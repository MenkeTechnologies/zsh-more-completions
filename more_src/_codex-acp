#compdef codex-acp
# Documentation: https://github.com/openai/codex
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Use Codex from ACP-compatible clients such as Zed.
# Conservative fallback — run `codex-acp --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
