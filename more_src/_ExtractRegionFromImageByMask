#compdef ExtractRegionFromImageByMask
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ExtractRegionFromImageByMask.cxx — extract bounding region of a label mask (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImage:_files' \
    '4:labelMaskImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '5::label (default 1):_default' \
    '6::padRadius (default 0):_default' \
    && ret=0

return ret
