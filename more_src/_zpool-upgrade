#compdef zpool-upgrade
# _zpool-upgrade — OpenZFS zpool upgrade (upgrade the pool on-disk format to enable newer feature flags; -v lists supported features, -a upgrades all pools, -V picks a specific pool version (legacy), -f forces enable of unsupported feature flags; positional pool to upgrade)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_upgrade) on tip.

_zpool-upgrade() {
    _arguments \
        '-v[list supported features]' \
        '-a[upgrade all]' \
        '-V+[legacy pool version]:version:' \
        '-f[force]' \
        '*:pool:'
}

_zpool-upgrade "$@"
