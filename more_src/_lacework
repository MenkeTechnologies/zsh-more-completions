#compdef lacework
# Documentation: https://docs.fortinet.com/product/lacework-forticnapp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lacework (Lacework FortiCNAPP) CLI - cobra-based.
# Source: https://github.com/lacework/go-sdk
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '--json[output as JSON]' \
  '--profile=[switch between configured profiles]:profile:' \
  '--subaccount=[sub-account name inside your organization]:subaccount:' \
  '--debug[enable debug logging]' \
  '--nocolor[disable colored output]' \
  '1:command:(access-token account agent alert api cloud-account compliance component configure container-registry policy query vulnerability completion version help)' \
  '*::arguments:_default'
