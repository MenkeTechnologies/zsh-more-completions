#compdef warp-cli

# Zsh completion for Cloudflare WARP CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--accept-tos[accept Terms of Service]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'connect:connect to WARP'
      'disconnect:disconnect from WARP'
      'disable-wifi:disable WARP on Wi-Fi'
      'dns:manage DNS settings'
      'enable-wifi:enable WARP on Wi-Fi'
      'mode:set WARP mode'
      'registration:manage registration'
      'rotate-keys:rotate cryptographic keys'
      'set-custom-endpoint:set custom endpoint'
      'set-families-mode:set families mode'
      'set-gateway-id:set gateway ID'
      'set-license:set license key'
      'set-mode:set WARP mode'
      'set-proxy-port:set local proxy port'
      'settings:view settings'
      'status:show connection status'
      'teams-enroll:enroll in Cloudflare Zero Trust'
      'tunnel:manage tunnel'
      'vnet:manage virtual networks'
      'warp-stats:show WARP stats'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      mode|set-mode)
        _arguments '1:mode:(warp doh warp+doh dot warp+dot proxy)' && ret=0
        ;;
      set-families-mode)
        _arguments '1:mode:(off malware full)' && ret=0
        ;;
      dns)
        _arguments -s -S \
          '1:action:(families gateway log stats)' && ret=0
        ;;
    esac
    ;;
esac

return ret
