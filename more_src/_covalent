#compdef covalent
# Documentation: https://covalent.readthedocs.io/en/stable/api/cli.html
# covalent - manage the Covalent workflow orchestration server

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'start:start the Covalent server'
      'stop:stop the Covalent server'
      'restart:restart the Covalent server'
      'status:check the server status'
      'purge:remove Covalent files and reset configuration'
      'logs:display the server log output'
      'db:database management utilities'
      'cluster:manage the Dask cluster configuration'
    )
    _describe -t commands 'covalent command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'=[server port, default 48008]:port' \
          '(-n --workers)'{-n,--workers}'=[number of workers to initialize]:workers' \
          '(-m --mem-per-worker)'{-m,--mem-per-worker}'=[memory limit per worker in GB]:mem' \
          '(-t --threads-per-worker)'{-t,--threads-per-worker}'=[CPU threads per worker]:threads' \
          '(-d --develop)'{-d,--develop}'[run in developer mode]' \
          '--no-cluster[launch without a Dask cluster]' \
          '--no-triggers[run without the Triggers server]' \
          '--triggers-only[run the Triggers server exclusively]' \
          '--ignore-migrations[skip database migrations]' && ret=0
        ;;
      restart)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'=[server port]:port' \
          '(-d --develop)'{-d,--develop}'[run in developer mode]' && ret=0
        ;;
      purge)
        _arguments -s -S \
          '(-H --hard)'{-H,--hard}'[also delete the database]' \
          '(-y --yes)'{-y,--yes}'[skip the warning prompt]' && ret=0
        ;;
      cluster)
        _arguments -s -S \
          '--status[show cluster status]' \
          '--info[show cluster info]' \
          '--address[show scheduler address]' \
          '--size[show cluster size]' \
          '--restart[restart the cluster]' \
          '--scale=[scale the cluster to N workers]:n' \
          '--logs[show cluster logs]' && ret=0
        ;;
    esac
    ;;
esac

return ret
