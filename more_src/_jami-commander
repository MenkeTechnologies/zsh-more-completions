#compdef jami-commander
# Documentation: https://github.com/8go/jami-commander
# jami-commander - CLI-based Jami client for accounts, swarms and messaging

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '--manual[show detailed manual]' \
  '--usage[print usage guide]' \
  '(-v --version)'{-v,--version}'[show version details]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--log-level=[set logging verbosity]:level' \
  '(-o --output)'{-o,--output}'[choose output format]:format:(TEXT JSON)' \
  '--get-enabled-accounts[display all active accounts by ID]' \
  '--add-account[create a new Jami account]:alias' \
  '--remove-account[delete one or more accounts]:accountid' \
  '(-a --account)'{-a,--account}'[select a specific account to use]:accountid' \
  '--get-conversations[list all swarm conversations]' \
  '--add-conversation[create a new conversation]' \
  '--remove-conversation[delete conversations]' \
  '(-c --conversations)'{-c,--conversations}'[specify target conversations]:conversationid' \
  '--get-conversation-members[show conversation participants]' \
  '--add-conversation-member[invite members]:userid' \
  '--remove-conversation-member[remove participants]:userid' \
  '(-m --message)'{-m,--message}'[send text messages]:text' \
  '(-f --file)'{-f,--file}'[send files]:file:_files' \
  '(-w --html)'{-w,--html}'[format message as HTML]' \
  '(-z --markdown)'{-z,--markdown}'[format message as Markdown]' \
  '(-k --code)'{-k,--code}'[format message as code]' \
  '(-j --emojize)'{-j,--emojize}'[process emojis in messages]' \
  '--split=[split messages by delimiter]:separator' && ret=0

return ret
