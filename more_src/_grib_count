#compdef grib_count
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_count
# Source: ecmwf/eccodes tools/grib_count.desc — count GRIB messages in given files (C, via codes_count).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '-v[verbose: print per-file counts]' \
    '-f[force, do not fail on error]' \
    '*:grib file:_files' \
    && ret=0

return ret
