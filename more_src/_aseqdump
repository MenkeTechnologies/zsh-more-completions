#compdef aseqdump
# Documentation: https://manpages.debian.org/aseqdump.1
# Source: alsa-utils — print events received from ALSA sequencer ports (UMP-aware).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print options]' \
    '(- *)'{-V,--version}'[print version]' \
    '(- *)'{-l,--list}'[list possible input ports]' \
    '(-u --ump)'{-u+,--ump=}'[client MIDI version (0=legacy / 1=UMP MIDI 1.0 / 2=UMP MIDI 2.0)]:ver:(0 1 2)' \
    '(-r --raw)'{-r,--raw}'[suppress UMP/legacy auto-conversion]' \
    '(-R --raw-view -N --normalized-view -P --percent-view)'{-R,--raw-view}'[show raw 0-based channel/group values]' \
    '(-R --raw-view -N --normalized-view -P --percent-view)'{-N,--normalized-view}'[show MIDI 1.0-normalized 1-based values]' \
    '(-R --raw-view -N --normalized-view -P --percent-view)'{-P,--percent-view}'[show values as percentages, 1-based]' \
    '(-p --port)'{-p+,--port=}'[sequencer port(s) "client:port,..."]:port:' \
    && ret=0

return ret
