#compdef sniprun
# Documentation: https://github.com/michaelb/sniprun
# Reference accessed: 2026-05-21
# Verified: upstream src/lib.rs and src/main.rs. sniprun has no CLI flag
# parser - it is a Neovim plugin binary invoked via RPC; arguments arrive
# as a space-separated string from the editor (`cli_args` field of
# DataHolder) and are passed straight to interpreters.
# Removed from prior file: fabricated --clean, --config, --display-type,
# --inline-limit, --interpreter, --no-color, --repl-enable, --repl-disable,
# --repl-reset, --sniprun-root, -V/--version, -h/--help flags (none of
# these exist in upstream source).
# STUB: no CLI surface; only positional fallback.

local curcontext="$curcontext" ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
