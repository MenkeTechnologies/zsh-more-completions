#compdef sniprun

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--clean[clean sniprun data]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--display-type[display type]:type:(Classic VirtualTextOk VirtualTextErr Terminal TerminalWithCode LongTempFloatingWindow TempFloatingWindow NvimNotify Api)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--inline-limit[max inline result length]:length' \
  '--interpreter[interpreter to use]:interpreter' \
  '--no-color[disable color output]' \
  '--repl-enable[enable REPL mode for interpreter]:interpreter' \
  '--repl-disable[disable REPL mode for interpreter]:interpreter' \
  '--repl-reset[reset REPL for interpreter]:interpreter' \
  '--sniprun-root[sniprun root directory]:directory:_directories' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:code file:_files' && ret=0
return ret
