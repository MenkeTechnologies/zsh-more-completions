#compdef barycen
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/barycen/node5.html
# Convert time tags from the local satellite frame to Barycentric Dynamical Time

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--withtable=[convert table in a dataset]:bool:(true false)' \
  '--table=[name of existing table to process]:table' \
  '--timecolumn=[column containing time values to correct]:column' \
  '--withsrccoordinates=[source coordinates provided by user]:bool:(true false)' \
  '--srcra=[Right Ascension of source, decimal degrees J2000]:ra' \
  '--srcdec=[Declination of source, decimal degrees J2000]:dec' \
  '--processgtis=[correct GTI tables if present]:bool:(true false)' \
  '--processexposutables=[correct EXPOSU tables if present]:bool:(true false)' \
  '--time=[single time value to correct]:time' \
  '--ephemeris=[Earth ephemeris file for TDB conversion]:ephem:(DE200 DE405)' \
  '*:param=value:_default' && ret=0

return ret
