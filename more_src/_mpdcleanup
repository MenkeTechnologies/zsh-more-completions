#compdef mpdcleanup
# Documentation: https://man.archlinux.org/search?q=mpdcleanup
# Reference accessed: 2026-05-16

# mpdcleanup: kill MPD ring on a set of hosts (cleanup)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[hosts file]:file:_files' \
  '*::mpdcleanup args:_files' && ret=0
return ret
