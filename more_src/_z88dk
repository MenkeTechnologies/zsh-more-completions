#compdef z88dk z88dk-z80asm zcc

# z88dk: Z80 development kit (front-end zcc)
# Documentation: https://github.com/z88dk/z88dk/wiki
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-c[compile only]' \
  '-S[generate asm]' \
  '-o[output file]:file:_files' \
  '-O[optimize]:n:(0 1 2 3)' \
  '-create-app[create binary app]' \
  '-compiler=[backend compiler]:compiler:(sccz80 sdcc zsdcc)' \
  '+[target machine]:target:' \
  '-subtype=[machine subtype]:subtype:' \
  '-pragma-define=[pragma define]:str:' \
  '-pragma-include=[pragma include]:str:' \
  '-startup=[startup file id]:n:' \
  '-clib=[clib variant]:clib:' \
  '-Cl[options to z80asm]:opts:' \
  '-Cz[options to appmake]:opts:' \
  '-vn[verbose only]' \
  '-bn[generate binary]' \
  '-I[include path]:dir:_files -/' \
  '-L[library path]:dir:_files -/' \
  '-l[library]:lib:' \
  '-D[define macro]:macro:' \
  '*:source file:_files' && ret=0
return ret
