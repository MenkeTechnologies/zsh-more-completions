#compdef z88dk-zcc zcc z88dk-z80asm z88dk-appmake z88dk-z80nm z88dk-z80svg z88dk-zsdcpp z88dk-z80lib z88dk-zproject z88dk-z80sdcc

local curcontext="$curcontext" state line ret=1

case $service in
  (z88dk-zcc|zcc)
    _arguments -C \
      '-h[show help]' \
      '-V+[verbosity]:n:(0 1 2)' \
      '-v[show version]' \
      '-c[compile only]' \
      '-S[asm only]' \
      '-E[preprocess only]' \
      '-o+[output]:file:_files' \
      '*-I+[include path]:dir:_files -/' \
      '*-L+[lib path]:dir:_files -/' \
      '*-l+[link lib]:lib:' \
      '*-D+[define]:macro:' \
      '*-U+[undef]:macro:' \
      '-O+[opt level]:n:(0 1 2 3 s)' \
      '-pragma-define\:-[pragma define]:def:' \
      '-pragma-need\:-[pragma need]:n:' \
      '-pragma-output\:-[pragma output]:o:' \
      '-pragma-export\:-[pragma export]:e:' \
      '-pragma-string\:-[pragma string]:s:' \
      '-pragma-redirect\:-[pragma redirect]:r:' \
      '-pragma-include\:-[pragma include]:i:' \
      '-pragma-bytes\:-[pragma bytes]:b:' \
      '-pragma-bind\:-[pragma bind]:b:' \
      '-clib=[clib variant]:c:(default new sdcc_iy sdcc_ix classic)' \
      '+zx[ZX Spectrum]' \
      '+zx81[ZX81]' \
      '+cpm[CP/M]' \
      '+cpc[Amstrad CPC]' \
      '+msx[MSX]' \
      '+msx2[MSX2]' \
      '+enterprise[Enterprise]' \
      '+ti83[TI-83]' \
      '+ti84[TI-84]' \
      '+ti85[TI-85]' \
      '+ti86[TI-86]' \
      '+gb[Game Boy]' \
      '+sms[Sega Master System]' \
      '+nes[NES]' \
      '+coleco[ColecoVision]' \
      '+sg[Sega SG-1000]' \
      '+spectra[Spectra]' \
      '+test[test target]' \
      '+rom[generic ROM]' \
      '*: :_files -g "*.c *.s *.asm *.h *.lib *.o"' && ret=0 ;;
  (z88dk-z80asm)
    _arguments -C \
      '-h[help]' \
      '-V+[verbosity]:n:' \
      '-v[verbose]' \
      '-w[no warnings]' \
      '-o+[output]:file:_files' \
      '-l[list file]' \
      '-x[xref]' \
      '-s[symbol file]' \
      '*-I+[include]:dir:_files -/' \
      '*-L+[libpath]:dir:_files -/' \
      '*-l+[lib]:lib:' \
      '*-D+[define]:macro:' \
      '*: :_files -g "*.asm *.s"' && ret=0 ;;
  (z88dk-appmake)
    _arguments -C \
      '-h[help]' \
      '-+[target]:t:(zx zx81 cpc cpm msx ti83 +zx +zx81 sms nes coleco)' \
      '--help[help]' \
      '*: :_files' && ret=0 ;;
  (*)
    _arguments '*: :_files' && ret=0 ;;
esac

return ret
