#compdef grdvector
# Documentation: https://docs.generic-mapping-tools.org/latest/grdvector.html
# Source: GenericMappingTools/gmt classic-mode grdvector — plot vector field from two grids (x,y or r,θ).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A[treat inputs as polar (r,θ), not Cartesian]' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT (color palette table)]:cpt:_files -g "*.cpt(-.)"' \
    '-G+[vector fill color]:fill:_default' \
    '-I+[plot at every Nth node]:opts:_default' \
    '-N[do not clip vectors at map boundary]' \
    '-Q+[vector head properties]:opts:_default' \
    '-S+[length scaling (data units per plot dist)]:scale:_default' \
    '-T[adjust azimuths for negative x/y scales]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[vector outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z[grid contains azimuth (not direction)]' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-t+[transparency percent]:pct:_default' \
    '*:grid files (2 expected):_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
