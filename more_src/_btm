#compdef btm
# _btm — ClementTsang bottom (cross-platform top(1) alternative; -t/--tree process tree, -g/--group group identical processes, -m/--memory_default, -n/--network_default, --battery, -b/--basic basic mode, -r/--rate refresh ms, -d/--default_widget_type, --color picks theme, --process_command full cmdline)
# upstream: https://github.com/ClementTsang/bottom
# Flags from bottom src/options.rs on tip.

_btm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-b[basic mode]' \
        '--basic[basic mode]' \
        '-l[show legend in basic mode]' \
        '-S+[default widget type]:type:(cpu mem net proc temp disk battery)' \
        '--default_widget_type+[default widget type]:type:(cpu mem net proc temp disk battery)' \
        '-c[use celsius]' \
        '--celsius[use celsius]' \
        '-f[use fahrenheit]' \
        '--fahrenheit[use fahrenheit]' \
        '-k[use kelvin]' \
        '--kelvin[use kelvin]' \
        '-t[process tree]' \
        '--tree[process tree]' \
        '-g[group identical processes]' \
        '--group[group identical processes]' \
        '-m[memory default widget]' \
        '--memory_default[memory default widget]' \
        '-n[network default widget]' \
        '--network_default[network default widget]' \
        '--battery[show battery widget]' \
        '--disable_advanced_kill[disable advanced kill]' \
        '--enable_cache_memory[enable cache memory]' \
        '--enable_gpu[enable gpu]' \
        '-u[use binary prefix]' \
        '--use_old_network_legend[old network legend]' \
        '-W[wide proc table]' \
        '--whole_word[search whole word]' \
        '-r+[refresh rate ms]:ms:' \
        '--rate+[refresh rate ms]:ms:' \
        '--default_time_value+[default time value]:value:' \
        '--time_delta+[time delta]:value:' \
        '-C+[config path]:file:_files' \
        '--config+[config path]:file:_files' \
        '--color+[theme]:theme:(default default-light gruvbox gruvbox-light nord nord-light)' \
        '--process_command[full cmdline]'
}

_btm "$@"
