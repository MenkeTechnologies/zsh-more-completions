#compdef kubectl-nodepools
# Documentation: https://github.com/grafana/kubectl-nodepools
# Reference accessed: 2026-05-17
# Verified: grafana/kubectl-nodepools upstream README.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing list/nodes subcommands and -l/--label.

# kubectl-nodepools: list Kubernetes node pools
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'list:list node pools'
  'nodes:list nodes in a pool'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --label)'{-l+,--label=}'[node-pool label key]:label:' \
  '--context=[kubectl context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kubectl-nodepools command' commands && ret=0 ;;
esac
return ret
