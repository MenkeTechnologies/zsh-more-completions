#compdef ifetch
# Documentation: https://github.com/deivshon/ifetch
# ifetch - tiny network interface information tool

local ret=1

_arguments -s -S \
  '-if[select which network interface to fetch data from]:interface:' \
  '-lo[select the logo to display]:logo:' \
  '-loc[set the logo color]:color:' \
  '-fc[set the fields color]:color:' \
  '-sc[set the separator color]:color:' \
  '-vc[set the values color]:color:' \
  '-s[select the separator string]:separator:' \
  '-ns[use a single space as the separator]' \
  '-mld[set minimum logo-field distance]:distance:' \
  '-mp[set minimum padding]:padding:' && ret=0

return ret
