#compdef create-docker
# Documentation: https://www.npmjs.com/package/create-docker
# Reference accessed: 2026-05-24
# Verified: npm view create-docker bin; npx create-docker --help; npx create-docker node --help output.

# Zsh completion for create-docker - Node.js/Swift Dockerfile generator

local curcontext="$curcontext" state line ret=1

_arguments -C   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' node swift && ret=0
    ;;
  args)
    _arguments -C       '(-o --out)'{-o,--out}'[Dockerfile output path]:file:_files'       '--node=[Node.js version]:version:'       '--swift=[Swift version]:version:'       '--env=[NODE_ENV value]:env:(development staging production)'       '--port=[port to expose]:port:'       '--name=[label name]:name:'       '--help[show help]' && ret=0
    ;;
esac

return ret
