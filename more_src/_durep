#compdef durep
# Documentation: https://manpages.debian.org/unstable/durep/durep.1.en.html
# durep - disk usage report generator

local ret=1

_arguments -s -S \
  '(-f --files)'{-f,--files}'[do not descend into sub-directories, only report files]' \
  '(-x --one-file-system)'{-x,--one-file-system}'[do not traverse file systems]' \
  '(-cp --collapse-path)'{-cp,--collapse-path}'=[hide entries below paths matching pattern]:pattern' \
  '(-ep --exclude-path)'{-ep,--exclude-path}'=[ignore paths matching pattern]:pattern' \
  '(-cf --coalesce-files)'{-cf,--coalesce-files}'=[coalesce entries for files below size]:size' \
  '(-td --text-depth)'{-td,--text-depth}'=[limit text report on directories to depth N]:depth' \
  '(-hs --hide-size)'{-hs,--hide-size}'=[do not display entries using N or less]:size' \
  '(-sd --show-date)'{-sd,--show-date}'[display modification date of file or directory]' \
  '(-ns --nosort)'{-ns,--nosort}'[do not sort results by size]' \
  '(-q --quiet)'{-q,--quiet}'[do not produce text output]' \
  '(-sf --save-file)'{-sf,--save-file}'=[save the results of the scan into this file]:file:_files' \
  '(-lf --load-file)'{-lf,--load-file}'=[load the results of a scan from this file]:file:_files' \
  '(-d --desc)'{-d,--desc}'=[give a description stored in the save-file]:description' \
  '(-c --collate)'{-c,--collate}'=[collate the save-files in the given directory]:dir:_files -/' \
  '*:directory:_files -/' && ret=0

return ret
