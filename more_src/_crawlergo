#compdef crawlergo
# Documentation: https://github.com/0Kee-Team/crawlergo
# powerful browser crawler for web vulnerability scanners

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --chromium-path)'{-c,--chromium-path}'+[path to the chrome executable]:path:_files' \
  '--custom-headers=[customize HTTP headers via JSON serialization]:headers' \
  '(-d --post-data)'{-d,--post-data}'+[POST data for requests]:data' \
  '(-m --max-crawled-count)'{-m,--max-crawled-count}'+[maximum crawler tasks]:n' \
  '(-f --filter-mode)'{-f,--filter-mode}'+[filtering mode]:mode:(simple smart strict)' \
  '(-o --output-mode)'{-o,--output-mode}'+[output format]:mode:(console json none)' \
  '--output-json=[write JSON results to specified file]:file:_files' \
  '--request-proxy=[socks5 proxy address for all requests]:proxy' \
  '--fuzz-path[use built-in dictionary for path fuzzing]' \
  '--fuzz-path-dict=[custom fuzz path dictionary file]:file:_files' \
  '--robots-path[resolve paths from /robots.txt]' \
  '(-iuk --ignore-url-keywords)'{-iuk,--ignore-url-keywords}'+[URL keywords to exclude from visiting]:keywords' \
  '(-fv --form-values)'{-fv,--form-values}'+[customize form fill values by text type]:values' \
  '(-fkv --form-keyword-values)'{-fkv,--form-keyword-values}'+[customize form fill values by keyword]:values' \
  '(-t --max-tab-count)'{-t,--max-tab-count}'+[maximum concurrent browser tabs]:n' \
  '--tab-run-timeout=[maximum runtime per tab page]:timeout' \
  '--wait-dom-content-loaded-timeout=[page load completion timeout]:timeout' \
  '--event-trigger-interval=[interval for automatic event triggering]:interval' \
  '--event-trigger-mode=[event trigger mode]:mode:(async sync)' \
  '--before-exit-delay=[delay before closing tab to capture DOM updates]:delay' \
  '--push-to-proxy=[listener address for passive scanner integration]:addr' \
  '--push-pool-max=[maximum concurrent connections for sending results]:n' \
  '--log-level=[logging level]:level:(debug info warn error fatal)' \
  '--no-headless[disable headless mode to visualize crawling]' \
  '*:url:_urls' && ret=0

return ret
