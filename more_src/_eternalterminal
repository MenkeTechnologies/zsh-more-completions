#compdef et eternalterminal

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-c+[run command on connect]:command' \
  '--command=[run command on connect]:command' \
  '-p+[remote port]:port' \
  '--port=[remote port]:port' \
  '-t+[tunnel specification (lport:dhost:dport)]:tunnel spec' \
  '--tunnel=[tunnel specification]:tunnel spec' \
  '-r+[reverse tunnel specification]:tunnel spec' \
  '--reverse-tunnel=[reverse tunnel specification]:tunnel spec' \
  '--no-terminal[do not allocate terminal]' \
  '-x[forward ssh agent]' \
  '--ssh-agent[forward ssh agent]' \
  '--jump-host=[SSH jump/proxy host]:host:_hosts' \
  '--jport=[SSH jump/proxy port]:port' \
  '-v[verbose logging]' \
  '--verbose[verbose logging]' \
  '-l+[SSH socket path]:path:_files' \
  '--logtostdout[log to stdout]' \
  '--silent[no output]' \
  '--ssh-option=[additional SSH option]:option' \
  '-N[no default shell]' \
  '--no-default-shell[no default shell]' \
  '1:destination (user@host):_hosts' && return 0
