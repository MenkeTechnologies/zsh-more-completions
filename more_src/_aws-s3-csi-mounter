#compdef aws-s3-csi-mounter
# _aws-s3-csi-mounter — Mountpoint for S3 CSI side-car that receives mount args over a Unix socket and execs mount-s3
# upstream: https://github.com/awslabs/mountpoint-s3-csi-driver
# Flags from cmd/aws-s3-csi-mounter/main.go on tip.

_aws-s3-csi-mounter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--mount-sock-recv-timeout=[timeout for receiving mount options on Unix socket]:duration:' \
        '--mountpoint-bin-dir=[directory containing the mount-s3 binary]:dir:_files -/' \
        '-v[klog verbosity level]:n:'
}

_aws-s3-csi-mounter "$@"
