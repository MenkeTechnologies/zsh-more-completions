#compdef lfs

# lfs: Lustre filesystem CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'check:check Lustre filesystem state'
  'df:Lustre disk usage'
  'find:find files matching criteria'
  'getstripe:get striping info'
  'setstripe:set striping info'
  'getstripe -d:dir defaults'
  'getsom:get SOM data'
  'mdts:list MDTs'
  'osts:list OSTs'
  'pools_list:list OST pools'
  'pool_list:list OST pools'
  'pool_add:add OSTs to pool'
  'pool_remove:remove OSTs from pool'
  'pool_destroy:destroy OST pool'
  'pool_new:create OST pool'
  'quota:show quota info'
  'setquota:set quota'
  'quotacheck:run quotacheck'
  'project:project quota mgmt'
  'mv:move file across MDTs'
  'mirror:lustre HSM/mirror commands'
  'getsom:get SOM metadata'
  'changelog_clear:clear changelog records'
  'fid2path:get path from FID'
  'path2fid:get FID from path'
  'hsm_state:HSM state'
  'hsm_set:set HSM flags'
  'hsm_clear:clear HSM flags'
  'hsm_archive:archive a file'
  'hsm_restore:restore a file'
  'hsm_release:release a file'
  'hsm_remove:remove HSM copy'
  'hsm_cancel:cancel HSM request'
  'data_version:get data version'
  'help:show help'
  'flushctx:flush GSSAPI cred cache'
  'cp:lfs-aware cp'
  'rm_entry:remove a single object/entry'
  'rmfid:remove file by FID'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'lfs command' commands && ret=0 ;;
esac
return ret
