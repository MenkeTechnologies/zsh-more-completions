#compdef wimdelete
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-delete.1.html
# wimdelete — delete an image from a WIM file

local ret=1

_arguments -s -S \
  '--check[verify integrity and include integrity info in modified WIM]' \
  '--include-integrity[add integrity info without prior verification]' \
  '--soft[perform minimal changes only, leaving file resources untouched]' \
  '--unsafe-compact[compact WIM archive in-place by eliminating gaps]' \
  '*:WIM file:_files' && ret=0

return ret
