#compdef childsplay
# Documentation: https://manpages.debian.org/bookworm/childsplay/childsplay.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm childsplay(6) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# childsplay: Python educational games suite for children
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--no-login[disable login screen]' \
  '--kioskmode[run in kiosk mode]' \
  '--remote-mysqlserver[use remote MySQL server]' \
  '(-t --theme)'{-t+,--theme=}'[theme]:theme:' \
  '(-l --loglevel)'{-l+,--loglevel=}'[log level]:level:(debug info warning error critical)' \
  '--adminmode[run in admin mode]' \
  '--no-sound[disable sound]' \
  '--no-text[disable text]' \
  '--language=[language]:lang:' \
  '--default_language=[default language]:lang:' \
  '--fullscreen[fullscreen mode]' \
  '--bigcursor[use large cursor]' \
  '--nocursor[hide cursor]' \
  '--no-exit-question[skip exit confirmation]' \
  '--no-countdown[disable countdown]' \
  '--user=[username]:user:' \
  '--no-level-pause[disable pause between levels]' \
  '--checklog[check log only]' \
  '--crapware[run as crapware]' \
  '--plainversion[print version only]' \
  '--kill-btp=[kill backtoplay PID]:pid:_pids' \
  '--restart-btp=[restart backtoplay PID]:pid:_pids' && ret=0
return ret
