#compdef rpiece
# Documentation: https://floyd.lbl.gov/radiance/man_html/rpiece.1.html
# Radiance parallel piecewise renderer

local ret=1

_arguments -s \
  '-v[verbose mode: report as each piece begins and finishes]' \
  '-x[overall picture width in pixels]:xres' \
  '-y[overall picture height in pixels]:yres' \
  '-X[number of horizontal divisions]:xdiv' \
  '-Y[number of vertical divisions]:ydiv' \
  '-F[synchronization file for coordinating processes]:syncfile:_files' \
  '-R[recovery mode from interrupted run]:syncfile:_files' \
  '-T[send ALRM signal after given hours]:timelim' \
  '-o[output picture and input octree]:picture:_files' \
  '*:octree:_files' && ret=0

return ret
