#compdef alpine alpinef
# Documentation: man alpine(1)
# Source: Alpine — Alternatively Licensed Program for Internet News and Email.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-attach+[attach file to outgoing mail]:file:_files' \
    '-attachlist+[attach file-list to outgoing mail]:file-list:_files' \
    '*-attach_and_delete+[attach file then delete after send]:file:_files' \
    '-aux+[local dir for aux files (PC-Alpine)]:dir:_files -/' \
    '-bail[exit if pinerc does not exist]' \
    '-c+[folder-collection number for -f]:context-number:' \
    '(- *)-conf[output sample system-wide pine.conf]' \
    '-convert_sigs+[convert sig files to literal signatures]:pinerc:_files' \
    '-copy_abook[copy local→remote address book]:local + remote:_files' \
    '-copy_pinerc[copy local→remote pinerc]:local + remote:_files' \
    '*-d+[debug level (0-9) or key[=val]]:debug-spec:' \
    '-f+[open folder instead of INBOX]:folder:' \
    '-F+[view text file with Alpines browser]:file:_files' \
    '(- *)-h[list valid command-line options]' \
    '-i[start in FOLDER INDEX screen]' \
    '-I+[initial keystrokes to execute at startup]:keystrokes:' \
    '-install[prompt for setup and exit (PC-Alpine)]' \
    '-k[use function keys for commands (= alpinef)]' \
    '-n+[start with current message number set to N]:number:' \
    '-nowrite_password_cache[read but never write password cache]' \
    '-o[open first folder read-only]' \
    '-p+[personal config file instead of .pinerc]:config:_files' \
    '-P+[system-wide config file instead of pine.conf]:config:_files' \
    '-passfile+[password file path]:file:_files' \
    '-pinerc+[output fresh pinerc to FILE (- for stdout)]:file:_files' \
    '-pwdcertdir+[SMIME password-file key+cert dir]:dir:_files -/' \
    '-r[restricted / demo mode]' \
    '-registry[PC-Alpine registry action]:cmd:(set clear clearsilent dump)' \
    '-smimedir+[SMIME directory]:dir:_files -/' \
    '-sort+[FOLDER INDEX sort order]:order:(arrival date subject orderedsubj thread from size score to cc reverse arrival/reverse date/reverse subject/reverse from/reverse size/reverse to/reverse cc/reverse)' \
    '(- *)-supported[show compiled-in supported options]' \
    '-uninstall[remove Alpine refs from Windows settings]' \
    '-url+[open the given URL]:url:' \
    '(- *)-v[print version information]' \
    '(- *)-version[print version information]' \
    '-x+[configuration-exceptions file]:config:_files' \
    '-xoauth2-server+[XOAUTH2 service name]:server:(Gmail)' \
    '-xoauth2-client-id+[XOAUTH2 client id]:client-id:' \
    '-xoauth2-client-secret+[XOAUTH2 client secret]:client-secret:' \
    '*:address:_email_addresses' \
    && ret=0

return ret
