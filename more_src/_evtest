#compdef evtest
# Documentation: https://man.archlinux.org/search?q=evtest
# Reference accessed: 2026-05-16

# Zsh completion for evtest - input event tester

_evtest_devices() {
  local -a devices
  devices=(/dev/input/event*(N))
  if (( ${#devices} )); then
    _values 'event device' ${devices}
  fi
}

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--query[query a specific event code]' \
  '--grab[grab the device exclusively]' \
  '1:device:_evtest_devices'
