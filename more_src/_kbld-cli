#compdef kbld

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'inspect:inspect images in resources'
  'pkg:package commands'
  'unpkg:unpackage commands'
  'completion:generate completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-f+[file or URL]:file:_files' \
  '*--file=[file or URL]:file:_files' \
  '*--no-color[no color]' \
  '*--debug[debug]' \
  '*--lock-output=[lock output file]:file:_files' \
  '*--build-concurrency=[build concurrency]:n:' \
  '*--imgpkg-lock-output=[imgpkg lock output]:file:_files' \
  '*--images-annotation=[images annotation]:b:(true false)' \
  '*--registry-ca-cert-path=[registry CA cert]:file:_files' \
  '*--registry-username=[registry user]:u:_users' \
  '*--registry-password=[registry pass]:p:' \
  '*--registry-token=[registry token]:t:' \
  '*--registry-anon[anon registry auth]' \
  '*--registry-azure-cr-config=[azure CR config]:file:_files' \
  '*--registry-response-header-timeout=[response timeout]:t:' \
  '*--registry-retry-count=[retry count]:n:' \
  '*--registry-verify-certs=[verify certs]:b:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kbld command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pkg|unpkg)
        _arguments \
          '*-f+[input file]:file:_files' \
          '--repository=[repository]:r:' \
          '--lock-output=[lock output]:file:_files' \
          '--input=[input tar]:file:_files' \
          '--output=[output tar]:file:_files' \
          '*: :' && ret=0 ;;
      (inspect)
        _arguments \
          '*-f+[file]:file:_files' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
