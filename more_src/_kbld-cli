#compdef kbld-cli
# Documentation: https://github.com/carvel-dev/kbld
# Reference accessed: 2026-05-19
# Verified: upstream carvel-dev/kbld. STUB: there is no `kbld-cli`
# binary upstream — the Carvel image tool is `kbld`. This file
# previously declared `#compdef kbld`, colliding with _kbld. The
# collision is resolved by delegating to the canonical _kbld
# completion if present; otherwise this is a no-op stub.

if (( ! $+functions[_kbld] )); then
  autoload -Uz +X _kbld 2>/dev/null
fi

if (( $+functions[_kbld] )); then
  _kbld "$@"
else
  _message 'no kbld-cli command (use kbld; see _kbld)'
fi
