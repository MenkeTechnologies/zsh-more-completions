#compdef flaca
# Documentation: https://github.com/Blobfolio/flaca
# brute-force lossless GIF/JPEG/PNG optimizer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information and exit]' \
  '(-V --version)'{-V,--version}'[display version details and exit]' \
  '-j+[restrict parallelization to specified thread count]:num:' \
  '(-l --list)'{-l,--list}'+[load image/directory paths from text file or STDIN (-)]:file:_files' \
  '--max-resolution=[discard images exceeding pixel count threshold]:num:' \
  '--no-gif[exclude GIF files from processing]' \
  '--no-jpeg[exclude JPEG files from processing]' \
  '--no-png[exclude PNG files from processing]' \
  '--no-symlinks[skip symbolic links during processing]' \
  '--preserve-times[retain original file access/modification timestamps]' \
  '(-p --progress)'{-p,--progress}'[display formatted progress indicator]' \
  '(-z --zopfli-iterations)'{-z,--zopfli-iterations}'+[adjust zopfli iteration count for PNG compression]:num:' \
  '*:path:_files' && ret=0

return ret
