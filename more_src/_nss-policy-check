#compdef nss-policy-check
# Documentation: https://github.com/nss-dev/nss/blob/master/cmd/nss-policy-check/nss-policy-check.c
# Reference accessed: 2026-05-16
# Verified: upstream cmd/nss-policy-check/nss-policy-check.c.

# nss-policy-check: validate NSS crypto policy file
local curcontext="$curcontext" ret=1
_arguments -C \
  '*-f[policy check flag]:flag:(identifier value)' \
  '*:policy file:_files' && ret=0
return ret
