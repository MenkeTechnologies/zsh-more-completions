#compdef ruby -m minitest

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-s+[seed for random order]:seed' \
  '--seed=[seed for random order]:seed' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-n+[run only tests matching pattern]:pattern' \
  '--name=[run only tests matching pattern]:pattern' \
  '-e+[exclude tests matching pattern]:pattern' \
  '--exclude=[exclude tests matching pattern]:pattern' \
  '--pride[show pride output]' \
  '--no-plugins[bypass minitest plugin auto-loading]' \
  '--parallel[run tests in parallel]' \
  '--server=[DRb server]:URI' \
  '*:test file:_files -g "*_test.rb"' && ret=0

return ret
