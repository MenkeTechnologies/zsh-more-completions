#compdef minitest
# Documentation: https://github.com/minitest/minitest
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: minitest is a Ruby test framework with no dedicated binary; tests are
# typically run via `ruby -Ilib:test path/to/test.rb` and accept these runtime
# options from the in-process option parser. Completion fires only when users
# explicitly alias `minitest` to a wrapper script.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-s --seed)'{-s+,--seed=}'[seed for random order]:seed' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-n --name)'{-n+,--name=}'[run only tests matching pattern]:pattern' \
  '(-e --exclude)'{-e+,--exclude=}'[exclude tests matching pattern]:pattern' \
  '(-p --pride)'{-p,--pride}'[show pride output]' \
  '(-a --autotest)'{-a,--autotest}'[connect to autotest server]' \
  '*:test file:_files -g "*_test.rb"' && ret=0

return ret
