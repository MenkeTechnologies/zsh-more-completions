#compdef esl-alimanip

# Easel esl-alimanip: manipulate multiple alignments (subset/edit columns)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-o[output file]:file:_files' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--outformat[output format]:fmt:(stockholm pfam a2m afa clustal phylip phylips)' \
  '--seq-k[keep only listed sequences]:file:_files' \
  '--seq-r[remove listed sequences]:file:_files' \
  '--lnfract[remove sequences below this fraction of MSA length]:frac:' \
  '--lxfract[remove sequences above this fraction of MSA length]:frac:' \
  '--lmin[remove sequences shorter than N]:n:' \
  '--lmax[remove sequences longer than N]:n:' \
  '--detrim[trim leading/trailing gaps from each sequence]' \
  '--xambig[remove sequences with >N ambiguous residues]:n:' \
  '--rfreq[remove columns below fraction of RF-marked columns]:frac:' \
  '--rinserts[remove inserts (lower-case) from MSA]' \
  '--rev[reverse-complement entire MSA]' \
  '--seq-ins[insert column at position]:pos:' \
  '--num-rf[number RF-marked columns]' \
  '--ad-name[append new sequence names]' \
  '--rename[rename sequences from file]:file:_files' \
  '--minpp[remove sequences below post prob]:val:' \
  '--seed[random seed]:n:' \
  '*:alignment file:_files' && ret=0
return ret
