#compdef pandoc-tablenos
# Documentation: https://github.com/tomduck/pandoc-tablenos
# pandoc-tablenos: a Pandoc filter for numbering tables and table references

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version and exit]' \
  '--pandocversion=[the pandoc version]:version:' \
  '1:format:' && ret=0

return ret
