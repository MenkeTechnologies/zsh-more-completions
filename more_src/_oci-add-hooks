#compdef oci-add-hooks
# Documentation: https://github.com/awslabs/oci-add-hooks/blob/master/README.md
# oci-add-hooks - OCI runtime wrapper that injects hooks into config.json

local ret=1

_arguments -s -S \
  '--hook-config-path=[path to JSON file defining container hooks]:file:_files' \
  '--runtime-path=[path to an OCI-compatible runtime binary]:file:_files' \
  '--bundle=[directory containing the container bundle]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::runtime args:_normal' && ret=0

return ret
