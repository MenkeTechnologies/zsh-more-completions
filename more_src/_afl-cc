#compdef afl-cc afl-c++ afl-cxx
# _afl-cc — AFL++ compiler wrapper that auto-selects an instrumentation mode (AFLplusplus/AFLplusplus)
# upstream: https://github.com/AFLplusplus/AFLplusplus
# Flags from src/afl-cc.c (compiler_mode_by_cmdline).

_afl-cc() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)--help[show help]' \
        '--afl-llvm[select LLVM compiler mode]' \
        '--afl-lto[select LLVM LTO compiler mode]' \
        '--afl-gcc[select GCC compiler mode]' \
        '--afl-gcc-plugin[select GCC plugin compiler mode]' \
        '--afl-clang[select afl-as clang compiler mode]' \
        '--afl-noopt[do not instrument, pass-through like AFL_NOOPT]' \
        '--afl_noopt[do not instrument, pass-through like AFL_NOOPT]' \
        '*::compiler args:_normal'
}

_afl-cc "$@"
