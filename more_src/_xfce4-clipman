#compdef xfce4-clipman xfce4-clipman-history xfce4-clipman-settings

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--show[show history menu]' \
  '--list[list history to stdout]' \
  '--add=+[add text to clipboard]:text:' \
  '--clear[clear history]' \
  '--enable-actions[enable action regex]' \
  '--disable-actions[disable action regex]' && ret=0

return ret
