#compdef perlimports
# Documentation: https://github.com/perl-ide/App-perlimports
# Reference accessed: 2026-05-27
# Verified: upstream script/perlimports GetOptions in perl-ide/App-perlimports

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--create-config-file=[write a starter config to FILE]:file:_files' \
  '--config-file=[read configuration from FILE]:file:_files' \
  '--no-config-file[do not load any config file]' \
  '(-f --filename)'{-f+,--filename=}'[file to process]:file:_files' \
  '--ignore-modules=[comma-separated modules to skip]:modules:' \
  '--ignore-modules-filename=[file listing modules to skip]:file:_files' \
  '--ignore-modules-pattern=[regex matching modules to skip]:pattern:' \
  '--ignore-modules-pattern-filename=[file with module skip patterns]:file:_files' \
  '--never-export-modules=[modules whose exports are never imported]:modules:' \
  '--never-export-modules-filename=[file listing never-export modules]:file:_files' \
  '(-i --inplace-edit)'{-i,--inplace-edit}'[edit file in place]' \
  '--json[emit machine-readable JSON]' \
  '--lint[report rather than rewrite]' \
  '--indent=[spaces per indent level]:n:' \
  '--pad-brackets[pad inside import brackets]' \
  '--padding[pad imports]' \
  '--tidy-whitespace[normalize whitespace around imports]' \
  '--libs=[colon-separated paths added to @INC]:paths:' \
  '--preserve-duplicates[keep duplicate imports]' \
  '--preserve-unused[keep unused imports]' \
  '--range-begin=[first line of range to process]:line:' \
  '--range-end=[last line of range to process]:line:' \
  '--read-stdin[read source from stdin]' \
  '--cache[enable on-disk cache]' \
  '--no-cache[disable on-disk cache]' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info notice warning error)' \
  '--log-filename=[write log to file]:file:_files' \
  '--help[brief usage]' \
  '--verbose-help[full pod help]' \
  '--version[print version]' \
  '*:file:_files' && ret=0

return ret
