#compdef xvic
# Documentation: https://github.com/VICE-Team/svn-mirror/blob/main/vice/src/initcmdline.c
# Reference accessed: 2026-05-16
# Verified: vice/src/initcmdline.c common_cmdline_options + cmdline_options
# tables, vice/src/log.c (-verbose/-silent/-debug), vice/src/vsync.c (-warp),
# vice/src/machine.c (-jamaction), vice/src/keymap.c (-keymap),
# vice/src/c64/c64-cmdline-options.c (model/pal/ntsc/kernal/basic/chargen/etc.),
# vice/src/arch/gtk3/ui.c (+/-confirmonexit, +/-saveres, -fullscreen-decorations),
# vice/src/arch/sdl/ui.c (saveres/confirmonexit).
# Removed from prior file: -h's --help long form (real is also "--help" via main.c
# but other emulator flags use single-dash only), -fullscreen (not in source;
# only -fullscreen-decorations on gtk3), -window (not in source),
# -truedrive (not in source), -virtualdev (not in source), -iecdevice8..11
# (not in source), -monitor (not in source as bare; -monitorfont/-monitorbg/...
# are real), -machinetype (real is -model; -machinetype only on x128),
# -VICIIextpal (not in source; real VICII flags are -VICIIborders,
# -VICIIchecksb, -VICIIcheckss, -VICIIvspbug, -VICIInewluminance, -VICIImodel).

# VICE C64/CBM/PET emulators (shared completion across x64, x64sc, xpet, etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '(- *)-\?[show help]' \
  '(- *)-version[show version]' \
  '(- *)--version[show version]' \
  '(- *)-features[show features]' \
  '-default[restore default settings]' \
  '-config[load config file]:file:_files -g "*.vrs"' \
  '-addconfig[append config file]:file:_files -g "*.vrs"' \
  '-dumpconfig[dump config to file]:file:_files' \
  '-chdir[change working directory]:dir:_files -/' \
  '-limitcycles[limit cycles]:n:' \
  '-console[run on console (no GUI)]' \
  '-no-redirect-streams[do not redirect stdout/stderr]' \
  '-seed[set RNG seed]:n:' \
  '-core[enable core dump]' \
  '+core[disable core dump]' \
  '-verbose[verbose log]' \
  '--verbose[verbose log]' \
  '-silent[silent log]' \
  '--silent[silent log]' \
  '-debug[debug mode]' \
  '--debug[debug mode]' \
  '-warp[start in warp mode]' \
  '-jamaction[CPU jam handling]:action:(continue monitor reset hardreset quit)' \
  '-keymap[keymap file]:file:_files' \
  '-confirmonexit[confirm on exit]' \
  '+confirmonexit[do not confirm on exit]' \
  '-saveres[save resources on exit]' \
  '+saveres[do not save resources on exit]' \
  '-fullscreen-decorations[gtk3: show decorations in fullscreen]' \
  '-autostart[autostart image]:file:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00|crt|bin)"' \
  '-autoload[autoload image]:file:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00|crt|bin)"' \
  '-1[attach tape unit 1 image]:file:_files -g "*.(tap|t64)"' \
  '-8[attach drive 8 image]:file:_files -g "*.(d64|d71|d81|d80|d82|g64|x64|p64)"' \
  '-8d1[attach drive 8 disk1]:file:_files -g "*.(d64|d71|d81)"' \
  '-9[attach drive 9 image]:file:_files -g "*.(d64|d71|d81|d80|d82|g64|x64|p64)"' \
  '-9d1[attach drive 9 disk1]:file:_files -g "*.(d64|d71|d81)"' \
  '-10[attach drive 10 image]:file:_files -g "*.(d64|d71|d81|d80|d82|g64|x64|p64)"' \
  '-11[attach drive 11 image]:file:_files -g "*.(d64|d71|d81|d80|d82|g64|x64|p64)"' \
  '-cart[attach cartridge (cbm2/plus4)]:file:_files -g "*.(crt|bin)"' \
  '-pal[set PAL]' \
  '-ntsc[set NTSC]' \
  '-ntscold[set old NTSC]' \
  '-paln[set PAL-N]' \
  '-power50[mains frequency 50Hz]' \
  '-power60[mains frequency 60Hz]' \
  '-kernal[KERNAL ROM file]:file:_files' \
  '-basic[BASIC ROM file]:file:_files' \
  '-chargen[character generator ROM]:file:_files' \
  '-kernalrev[KERNAL revision]:rev:' \
  '-model[machine model]:model:' \
  '-ciamodel[CIA model]:n:' \
  '-cia1model[CIA1 model]:n:' \
  '-cia2model[CIA2 model]:n:' \
  '-burstmod[burst mode]:n:' \
  '-iecreset[IEC reset]:n:' \
  '-VICIIborders[VIC-II border mode]:mode:' \
  '-VICIIchecksb[enable sprite-background collisions]' \
  '-VICIIcheckss[enable sprite-sprite collisions]' \
  '-VICIIvspbug[emulate VSP bug]' \
  '-VICIInewluminance[use new luminance values]' \
  '-VICIImodel[VIC-II model]:model:' \
  '*:image:_files -g "*.(d64|d71|d81|d80|d82|t64|tap|prg|p00|crt|bin|g64|x64|p64)"' && ret=0
return ret
