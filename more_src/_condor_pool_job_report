#compdef condor_pool_job_report
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_pool_job_report.html
# generate a report about all jobs that have run in the past 24 hours for a pool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
