# Madagascar: frequency spectra in 2-D

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'all=[compute average spectrum for all (y/n)]:all:(y n)' \
  '*: :_files' && ret=0

return ret
