#compdef lxqt-pcmanfm pcmanfm-qt
# Documentation: https://github.com/lxqt/pcmanfm-qt/blob/master/pcmanfm/application.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# lxqt-pcmanfm is the LXQt branding of pcmanfm-qt; flag set is identical.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --profile)'{-p,--profile}'+[configuration profile name]:profile:' \
  '(-d --daemon-mode)'{-d,--daemon-mode}'[run as daemon]' \
  '(-q --quit)'{-q,--quit}'[quit pcmanfm-qt]' \
  '--desktop[launch desktop manager]' \
  '--desktop-off[turn off desktop manager if running]' \
  '--desktop-pref=[open desktop preferences on page NAME]:name:' \
  '(-n --new-window)'{-n,--new-window}'[open new window]' \
  '(-f --find-files)'{-f,--find-files}'[open Find Files utility]' \
  '(-w --set-wallpaper)'{-w,--set-wallpaper}'+[set desktop wallpaper from image file]:file:_files' \
  '--wallpaper-mode=[set wallpaper mode]:mode:(color stretch fit center tile zoom screen)' \
  '--show-pref=[open Preferences on page NAME]:name:' \
  '*:file or directory:_files' && ret=0

return ret
