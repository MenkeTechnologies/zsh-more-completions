#compdef trtllm-serve
# Documentation: https://nvidia.github.io/TensorRT-LLM/commands/trtllm-serve/trtllm-serve.html
# NVIDIA TensorRT-LLM: serve a model with an OpenAI-compatible API

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--host=[server hostname]:host:' \
  '--port=[server port]:port:' \
  '--backend=[inference backend]:backend:(pytorch tensorrt _autodeploy)' \
  '--tp_size=[tensor parallelism size]:size:' \
  '--pp_size=[pipeline parallelism size]:size:' \
  '--ep_size=[expert parallelism size]:size:' \
  '--max_batch_size=[maximum schedulable requests]:size:' \
  '--max_num_tokens=[maximum batched input tokens]:count:' \
  '--max_seq_len=[maximum total sequence length]:len:' \
  '--tokenizer=[tokenizer path or name]:tokenizer:' \
  '--log_level=[logging verbosity level]:level:' \
  '--kv_cache_free_gpu_memory_fraction=[GPU memory fraction for KV cache]:fraction:' \
  '--trust_remote_code[allow remote code from HuggingFace]' \
  '--extra_llm_api_options=[path to YAML config file]:file:_files' \
  '1:command:((
    serve\:"run an OpenAI-compatible server"
    disaggregated\:"run server in disaggregated mode"
    disaggregated_mpi_worker\:"launch a disaggregated MPI worker"
    mm_embedding_serve\:"run an OpenAI-compatible embedding server"
  ))' \
  '*::arg:_files' && ret=0

return ret
