#compdef pcp-meminfo
# _pcp-meminfo — PCP-based /proc/meminfo report (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/meminfo/pcp-meminfo.1 SYNOPSIS.

_pcp-meminfo() {
    _arguments \
        '-s+[samples to collect]:n:' \
        '-a+[PCP archive folio]:archive:_files' \
        '-S+[start time]:time:' \
        '-T+[end time]:time:'
}

_pcp-meminfo "$@"
