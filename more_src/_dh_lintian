#compdef dh_lintian
# _dh_lintian — install lintian override files (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_lintian script (debhelper standard options).

_dh_lintian() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-a[arch-dep packages only]' \
        '-i[arch-indep packages only]' \
        '-O+[option passed to the helper]:opt:'
}

_dh_lintian "$@"
