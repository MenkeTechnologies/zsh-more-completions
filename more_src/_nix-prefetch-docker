#compdef nix-prefetch-docker
# Documentation: https://github.com/NixOS/nixpkgs/blob/master/pkgs/build-support/docker/nix-prefetch-docker
# obtain the source hash of a Docker image for dockerTools.pullImage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--os=[OS to fetch image for]:os:(linux windows)' \
  '--arch=[architecture to fetch image for]:arch:(amd64 arm64 x86_64 aarch64)' \
  '--image-name=[name of the image to fetch]:name:' \
  '--image-tag=[image tag]:tag:' \
  '--image-digest=[image digest]:digest:' \
  '--final-image-name=[desired name of the resulting image]:name:' \
  '--final-image-tag=[desired tag of the resulting image]:tag:' \
  '--json[output result as JSON instead of Nix]' \
  '--quiet[only print the final result]' \
  '*:image:' && ret=0

return ret
