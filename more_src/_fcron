#compdef fcron

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-b --background)'{-b,--background}'[run in background]' \
  '(-s --savetime)'{-s,--savetime}'=[save time interval]:seconds' \
  '(-l --firstsleep)'{-l,--firstsleep}'=[initial sleep time]:seconds' \
  '(-m --maxserial)'{-m,--maxserial}'=[max serial jobs]:count' \
  '(-c --configfile)'{-c,--configfile}'=[config file]:config file:_files' \
  '(-n --newspooldir)'{-n,--newspooldir}'=[spool directory]:directory:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '--once[run all pending jobs then exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
