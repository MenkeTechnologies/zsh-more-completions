#compdef kicad-pcb pcbnew
# _kicad-pcb — KiCad pcbnew CLI for the KiCad PCB layout editor opening kicad_pcb projects exporting Gerber drill ODB++ STEP IPC-2581 SVG DXF generating BOM running DRC importing from Eagle Altium Pcad (kicad team, C++); custom argparse
# upstream: https://gitlab.com/kicad/code/kicad

_kicad-pcb() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-x+[export format]:f:(gerber drill svg pdf step pos dxf hpgl plot)' \
        '--export=+[export format]:f:(gerber drill svg pdf step pos dxf hpgl plot)' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-L+[layer csv]:str:' \
        '--layers=+[layer csv]:str:' \
        '--exclude-refdes[exclude refdes]' \
        '--exclude-value[exclude value]' \
        '--use-drill-file-origin[use drill file origin]' \
        '--no-x2[no extended X2]' \
        '--no-netlist[no netlist]' \
        '--subtract-soldermask[subtract soldermask]' \
        '--include-zone-fills[include zone fills]' \
        '--drill-format=+[fmt]:f:(excellon gerber)' \
        '--drill-origin=+[o]:o:(absolute plot)' \
        '--map-format=+[fmt]:f:(pdf gerber svg dxf ps)' \
        '--min-header[min header]' \
        '--alt-drill-units[alternate drill units]' \
        '--drill-merge-pth-npth[merge PTH NPTH]' \
        '--drill-separate-files[separate drill files]' \
        '--units=+[u]:u:(mm in inch)' \
        '--theme=+[name]:str:' \
        '--no-board-outline[no board outline]' \
        '--page-size-A0[page size A0]' \
        '--page-size-A1[page size A1]' \
        '--page-size-A2[page size A2]' \
        '--page-size-A3[page size A3]' \
        '--page-size-A4[page size A4]' \
        '--page-size-A5[page size A5]' \
        '--page-size-USLEDGER[page size USLEDGER]' \
        '--page-size-USLEGAL[page size USLEGAL]' \
        '--page-size-USLETTER[page size USLETTER]' \
        '--import-from-altium[import from Altium]' \
        '--import-from-eagle[import from Eagle]' \
        '--import-from-pcad[import from PCAD]' \
        '*:project file:_files -g "*.kicad_pcb *.kicad_pro *.pro"'
}

_kicad-pcb "$@"
