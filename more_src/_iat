#compdef iat
# Documentation: https://man.archlinux.org/search?q=iat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --iso)'{-i,--iso}'[convert to ISO]' \
  '(-c --cue)'{-c,--cue}'[generate CUE]' \
  '(-t --toc)'{-t,--toc}'[generate TOC]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files -g "*.iso"' \
  '(-d --debug)'{-d,--debug}'+[debug level]:level:(0 1 2 3)' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-w --without-subchan)'{-w,--without-subchan}'[no subchannel]' \
  '(--audio)--audio[treat as audio]' \
  '(--mode1)--mode1[force Mode 1]' \
  '(--mode2)--mode2[force Mode 2]' \
  '*:input:_files -g "*.{bin,nrg,mdf,img}"' && ret=0

return ret
