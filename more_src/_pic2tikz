#compdef pic2tikz
# Documentation: https://man.archlinux.org/search?q=pic2tikz
# Reference accessed: 2026-05-16

# pic2tikz: convert pic(1) diagrams to TikZ
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-o[output file]:file:_files -g "*.(tex|tikz)"' \
  '*:input pic file:_files -g "*.pic"' && ret=0
return ret
