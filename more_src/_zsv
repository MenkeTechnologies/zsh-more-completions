#compdef zsv

# https://github.com/liquidaty/zsv — built-ins from app/cli.c + common opts from app/builtin/help.c
local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a zsv_cmds
zsv_cmds=(
  'version:print version/extension info'
  'help:usage for command'
  'thirdparty:third-party licenses'
  'register:register an extension'
  'unregister:remove an extension'
  'license:show extension license'
  'select:filter rows/columns'
  'count:count rows'
  'paste:merge tabular streams'
  'check:validate encoding/shape'
  '2json:convert to JSON'
  '2tsv:convert to TSV'
  'serialize:id/name/value tuples'
  'flatten:flatten grouped rows'
  'pretty:pretty-print for terminal'
  'stack:stack rows'
  'desc:describe columns'
  'sql:ad-hoc SQL'
  '2db:SQLite database'
  'compare:diff tables'
  'sheet:interactive sheet UI'
  'echo:rewrite stream with edits'
  'overwrite:cell overwrite tooling'
  'prop:file metadata'
  'rm:remove rows'
  'mv:move rows'
  'jq:jq filtering (if built with USE_JQ)'
)

local -a zsv_csv_opts
zsv_csv_opts=(
  '(-h --help)'{-h,--help}'[help]'
  '(-L --limit-rows)'{-L,--limit-rows}'=-[max rows including header]:n:'
  '(-c --max-column-count)'{-c,--max-column-count}'=-[max columns parsed per row]:n:'
  '(-r --max-row-size)'{-r,--max-row-size}'=-[minimum supported max row size]:bytes:'
  '(-B --buff-size)'{-B,--buff-size}'=-[parser buffer size]:bytes:'
  '(-t --tab-delim)'{-t,--tab-delim}'[tab field delimiter]'
  '(-O --other-delim)'{-O,--other-delim}'=-[custom one-byte delimiter]:char:'
  '(-q --no-quote)'{-q,--no-quote}'[disable CSV quoting]'
  '(-R --skip-head)'{-R,--skip-head}'=-[skip leading rows]:n:'
  '(-d --header-row-span)'{-d,--header-row-span}'=-[header row depth]:n:'
  '(-u --malformed-utf8-replacement)'{-u,--malformed-utf8-replacement}'=-[UTF-8 replacement string]:str:'
  '(-S --keep-blank-headers)'{-S,--keep-blank-headers}'[keep leading blank header rows]'
  '(-0 --header-row)'{-0,--header-row}'=-[prepend synthetic header CSV row]:csv:'
  '--only-crlf[treat only CRLF as row terminator]'
  '(-1 --apply-overwrites)'{-1,--apply-overwrites}'[apply saved overwrites]'
  '--parser=-[CSV backend]:engine:(default fast compat)'
  '(-v --verbose)'{-v,--verbose}'[verbose]'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'zsv command' zsv_cmds && ret=0
    ;;
  rest)
    case $line[1] in
      help|'?')
        _wanted topics expl 'help topic' && compadd "${zsv_cmds[@]%%:*}" help
        ret=0
        ;;
      prop|rm|mv|jq)
        _files && ret=0
        ;;
      *)
        _arguments -s -S "$zsv_csv_opts[@]" '*:input:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
