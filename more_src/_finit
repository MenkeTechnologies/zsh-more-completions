#compdef finit
# Documentation: source-direct extraction from upstream
# troglobit/finit src/finit.c getopt() optstring `abe:h?st:vVz:`
# + case-arm decoding showing -a/-b/-e/-s/-z are no-op flags kept
# only for sysvinit backwards compatibility (per upstream source
# comment `case 'a': case 'b': case 'e': case 's': case 'z':
# break; /* ign, compat */`).
# Reference accessed: 2026-05-30 via gh api.
# troglobit finit R131c — lightweight Linux init that reads its
# config from /etc/finit.conf + /etc/finit.d. Smaller scope than
# s6/dinit but ships a simpler systemd-like UX out of the box.
# Sister tools to the wider init-system landscape covered in
# R124/R130 (s6-linux-init, 66).

_arguments -s -S \
  '-a[(no-op; kept for sysvinit backwards compatibility)]' \
  '-b[(no-op; kept for sysvinit backwards compatibility)]' \
  '-e+[(no-op accepting arg; kept for sysvinit backwards compatibility)]:arg:' \
  '-s[(no-op; kept for sysvinit backwards compatibility)]' \
  '-z+[(no-op accepting arg; kept for sysvinit backwards compatibility)]:arg:' \
  '-t+[grace period in seconds between SIGTERM and SIGKILL of stragglers]:sec:' \
  '(-V)-v[print version and exit]' \
  '(-v)-V[print version and exit (synonym for -v)]' \
  '(-? -h)-h[show usage]' \
  '(-h -?)-?[show usage (synonym for -h)]'
