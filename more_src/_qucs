#compdef qucs

# Qucs: Quite Universal Circuit Simulator GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-r[redirect stdout/stderr to file]:file:_files' \
  '-V[show version]' \
  '--version[show version]' \
  '-n[do not load splash screen]' \
  '*:Qucs schematic file:_files -g "*.(sch|dpl)"' && ret=0
return ret
