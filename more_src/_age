#compdef age

# Zsh completion for age - simple, modern, secure file encryption

_arguments -s -S \
  '(-e --encrypt)'{-e,--encrypt}'[encrypt input (default)]:' \
  '(-d --decrypt)'{-d,--decrypt}'[decrypt input]' \
  '(-o --output)'{-o,--output}'[write result to file]:file:_files' \
  '-a[use ASCII armored output (encrypt only)]' \
  '--armor[use ASCII armored output (encrypt only)]' \
  '-r[encrypt to recipient]:recipient:' \
  '--recipient[encrypt to recipient]:recipient:' \
  '-R[encrypt to recipients in file]:file:_files' \
  '--recipients-file[encrypt to recipients in file]:file:_files' \
  '-i[use identity file]:file:_files' \
  '--identity[use identity file]:file:_files' \
  '-p[use passphrase encryption]' \
  '--passphrase[use passphrase encryption]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '*:file:_files'
