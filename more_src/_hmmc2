#compdef hmmc2
# Documentation: http://hmmer.org/documentation.html
# HMMER: example client for the HMMER daemon

local ret=1

_arguments -s -S \
  '-i+[IP address of the daemon to connect to (default 127.0.0.1)]:ip' \
  '-p+[port number the daemon is listening on (default 51371)]:port' \
  '-S[print the scores of any hits found]' \
  '-A[print the alignment of any hits found]' && ret=0

return ret
