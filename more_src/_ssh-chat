#compdef ssh-chat
# _ssh-chat — shazow ssh-chat (single-binary SSH server that hosts a chat room instead of a shell; --bind listen address, --identity host-key path, --motd motd file, --whitelist allowed-pubkey list, --admin admin pubkey, --max-history N, --pprof debug listener; clients connect with plain ssh)
# upstream: https://github.com/shazow/ssh-chat
# Flags from shazow/ssh-chat cmd/ssh-chat on tip.

_ssh-chat() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--version[show version]' \
        '--bind+[listen address]:addr:' \
        '--identity+[host key file]:file:_files' \
        '--motd+[motd file]:file:_files' \
        '--whitelist+[pubkey file]:file:_files' \
        '--admin+[admin pubkey]:file:_files' \
        '--max-history+[max history]:n:' \
        '--max-tries+[max auth tries]:n:' \
        '--passphrase+[passphrase env]:env:' \
        '--pprof+[pprof addr]:addr:' \
        '--config+[config file]:file:_files'
}

_ssh-chat "$@"
