#compdef calfjackhost calf-jack-host
# _calfjackhost — Krzysztof Foltman Calf Studio Gear JACK rack host loading Calf LV2/LADSPA audio plugins reverb compressor EQ for live mixing (calf team, C++); GOption
# upstream: https://github.com/calf-studio-gear/calf

_calfjackhost() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--help-all[show all help]' \
        '--help-gtk[GTK help]' \
        '--help-gapplication[GApplication help]' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '-c+[client name]:str:' \
        '--client=+[client name]:str:' \
        '-i+[input port]:str:' \
        '--input=+[input port]:str:' \
        '-o+[output port]:str:' \
        '--output=+[output port]:str:' \
        '-M+[midi port]:str:' \
        '--midi=+[midi port]:str:' \
        '-p+[preset]:str:' \
        '--preset=+[preset]:str:' \
        '-l+[load file]:file:_files -g "*.calfproj *.calfpresets"' \
        '--load=+[load file]:file:_files -g "*.calfproj *.calfpresets"' \
        '--state=+[state file]:file:_files' \
        '--no-gui[no GUI]' \
        '--no-cair[no Cairo]' \
        '--no-rack[no rack]' \
        '--reload-presets[reload presets]' \
        '--export-osc[export OSC]' \
        '-O+[osc client]:str:' \
        '--osc=+[osc client]:str:' \
        '-s+[server]:str:' \
        '--server=+[server]:str:' \
        '--connect-midi=+[port]:str:' \
        '--connect-audio[connect audio]' \
        '--connect-system[connect system]' \
        '*:plugin:(monosynth organ wavetable multichorus phaser reverb gverb compressor sidechaincompressor multibandcompressor deesser flanger filter filterclavier vintagedelay compensation_delay_line limiter sidechaingate gate multibandgate equalizer5band equalizer8band equalizer12band equalizer30band exciter bassenhancer mono crossover2band crossover3band crossover4band haasenhancer stereo analyzer transientdesigner vinyl pulsator ringmodulator emphasis envelopefilter saturator pitchshifter)'
}

_calfjackhost "$@"
