#compdef eolas-util
# Documentation: https://man.archlinux.org/search?q=eolas-util
# Reference accessed: 2026-05-16
# Source: https://github.com/dmytro/zsh-compdef/blob/5b2c600c509cda1fb0a05a6055fdcb035c886616/_eolas-util
# Repository: dmytro/zsh-compdef (_eolas-util)
#
# TODO add functions for the various handlers.

_eolas-util() {
  _arguments -s \
    '(- *)-h[print help information]' \
    '-l[list available handlers]' \
    '*::eolas-util command:_eolas_util_command'
}

(( $+functions[_eolas_util_command] )) ||
_eolas_util_command() {
  local ret=1

  _eolas_util_cmds=(
    $(_call_program commands eolas-util -l 2>&1)
  )

  if (( CURRENT == 1 )); then
    _describe -t commands 'eolas-util command' _eolas_util_cmds
  else
    _message "unimplemented"
  fi

  return ret
}
