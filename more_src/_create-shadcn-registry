#compdef create-shadcn-registry
# Documentation: https://www.npmjs.com/package/create-shadcn-registry
# Reference accessed: 2026-05-24
# Verified: npm view create-shadcn-registry bin; npm readme flags and subcommands.

# Zsh completion for create-shadcn-registry - custom shadcn/ui registry scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--registry-name=[registry identifier]:name:' \
  '--project-location=[folder to create registry in]:directory:_directories' \
  '--style=[registry style]:style:(new-york default)' \
  '--homepage=[hosted registry URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' add-component add-hook add-block remove-component remove-hook remove-block && ret=0
    ;;
  args)
    case $line[1] in
      add-component)
        _arguments -C \
          '--component-name=[kebab-case component name]:name:' \
          '--registry-folder=[registry path]:directory:_directories' \
          '--style=[registry style]:style:(new-york default)' \
          '--dependencies=[comma-separated npm packages]:packages:' && ret=0
        ;;
      add-hook)
        _arguments -C \
          '--hook-name=[hook name in use-<name> format]:name:' \
          '--registry-folder=[registry path]:directory:_directories' \
          '--style=[registry style]:style:(new-york default)' \
          '--dependencies=[comma-separated npm packages]:packages:' && ret=0
        ;;
      add-block)
        _arguments -C \
          '--block-name=[kebab-case block name]:name:' \
          '--registry-folder=[registry path]:directory:_directories' \
          '--style=[registry style]:style:(new-york default)' \
          '--dependencies=[comma-separated npm packages]:packages:' && ret=0
        ;;
      remove-component)
        _arguments -C \
          '--component=[component name to remove]:name:' \
          '--registry-folder=[registry path]:directory:_directories' && ret=0
        ;;
      remove-hook)
        _arguments -C \
          '--hook=[hook name to remove]:name:' \
          '--registry-folder=[registry path]:directory:_directories' && ret=0
        ;;
      remove-block)
        _arguments -C \
          '--block=[block name to remove]:name:' \
          '--registry-folder=[registry path]:directory:_directories' && ret=0
        ;;
      *)
        _arguments -C \
          '--registry-name=[registry identifier]:name:' \
          '--project-location=[output directory]:directory:_directories' \
          '--style=[registry style]:style:(new-york default)' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
