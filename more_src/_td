#compdef td

# Swatto/td — urfave/cli/v2 (`cli.go`)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-d)'{-d,--done}'[list finished todos]' \
  '(-a)'{-a,--all}'[list every todo]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'td command' compadd -- init add modify toggle clean reorder search i a
  ;;
rest)
  case $line[1] in
    add|a|modify)
      _arguments '1:todo text:' && ret=0
      ;;
    toggle)
      _arguments '1:todo id:id:' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
