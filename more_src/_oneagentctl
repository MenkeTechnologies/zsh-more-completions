#compdef oneagentctl
# Documentation: https://docs.dynatrace.com/docs/ingest-from/dynatrace-oneagent/oneagent-configuration-via-command-line-interface
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# oneagentctl: control OneAgent (host config, network zone, modules)
local curcontext="$curcontext" ret=1
local -a bools=(true false)

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--restart-service[restart the OneAgent service]' \
  '--create-support-archive=-[create support archive]:value:' \
  '--set-server=[set communication endpoints]:endpoints:' \
  '--get-server[print communication endpoints]' \
  '--set-tenant=[set tenant ID]:tenant:' \
  '--get-tenant[print tenant ID]' \
  '--set-tenant-token=[set tenant token]:token:' \
  '--get-tenant-token[print tenant token]' \
  '--set-proxy=[set proxy]:proxy:' \
  '--get-proxy[print proxy]' \
  '--set-no-proxy=[set no-proxy list]:hosts:' \
  '--get-no-proxy[print no-proxy list]' \
  '--set-host-id=[set host ID]:id:' \
  '--get-host-id[print host ID]' \
  '--set-host-id-source=[set host ID source]:source:' \
  '--get-host-id-source[print host ID source]' \
  '--set-host-group=[set host group]:group:' \
  '--get-host-group[print host group]' \
  '--set-host-name=[set host name override]:name:' \
  '--get-host-name[print host name override]' \
  '--set-host-property=[set host property]:value:' \
  '--remove-host-property=[remove host property]:value:' \
  '--get-host-properties[print host properties]' \
  '--set-host-tag=[set host tag]:tag:' \
  '--remove-host-tag=[remove host tag]:tag:' \
  '--get-host-tags[print host tags]' \
  '--set-network-zone=[set network zone]:zone:' \
  '--get-network-zone[print network zone]' \
  '--set-monitoring-mode=[set monitoring mode]:mode:(fullstack infra-only discovery)' \
  '--get-monitoring-mode[print monitoring mode]' \
  '--set-auto-injection-enabled=[enable/disable auto injection]:value:(true false)' \
  '--get-auto-injection-enabled[print auto injection state]' \
  '--set-app-log-content-access=[enable/disable app log access]:value:(true false)' \
  '--get-app-log-content-access[print app log access state]' \
  '--set-system-logs-access-enabled=[enable/disable system logs access]:value:(true false)' \
  '--get-system-logs-access-enabled[print system logs access state]' \
  '--set-auto-update-enabled=[enable/disable auto-update]:value:(true false)' \
  '--get-auto-update-enabled[print auto-update state]' \
  '--set-watchdog-portrange=[set watchdog port range]:range:' \
  '--get-watchdog-portrange[print watchdog port range]' \
  '--set-watchdog-redirection-trust-policy-enabled=[watchdog redirection trust]:value:(true false)' \
  '--get-watchdog-redirection-trust-policy-enabled[print watchdog redirection trust]' \
  '--set-extensions-ingest-port=[extensions ingest port]:port:' \
  '--get-extensions-ingest-port[print extensions ingest port]' \
  '--set-extensions-statsd-port=[extensions statsd port]:port:' \
  '--get-extensions-statsd-port[print extensions statsd port]' \
  '--set-fips-enabled=[enable/disable FIPS]:value:(true false)' \
  '--get-fips-enabled[print FIPS state]' \
  '--set-osagent-cap-setuid-enabled=[enable/disable osagent cap_setuid]:value:(true false)' \
  '--get-osagent-cap-setuid-enabled[print osagent cap_setuid state]' && ret=0
return ret
