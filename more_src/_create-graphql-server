#compdef create-graphql-server
# Documentation: https://www.npmjs.com/package/create-graphql-server
# Reference accessed: 2026-05-24
# Verified: npm view create-graphql-server bin; npx create-graphql-server --help output.

# Zsh completion for create-graphql-server - GraphQL server environment generator

local curcontext="$curcontext" state line ret=1

_arguments -C   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' init add-type remove-type && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -C ':project directory:_directories' && ret=0
        ;;
      add-type|remove-type)
        _arguments -C           ':GraphQL type path or typename:_files'           '*:additional paths:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
