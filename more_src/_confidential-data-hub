#compdef confidential-data-hub ttrpc-cdh grpc-cdh
# _confidential-data-hub — Confidential Containers guest CDH service (KMS-backed secret release + image-decryption helper; ttRPC and gRPC bins share the same Cli)
# upstream: https://github.com/confidential-containers/guest-components
# Flags from confidential-data-hub/hub/src/bin/{ttrpc-cdh,grpc-cdh}.rs Cli on tip (clap).

_confidential-data-hub() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '-c=[path to the CDH config file]:file:_files'
}

_confidential-data-hub "$@"
