#compdef mcstatus
# _mcstatus — query Minecraft server status (py-mine/mcstatus)
# upstream: https://github.com/py-mine/mcstatus
# Subcommands + flags from mcstatus/__main__.py (argparse).

_mcstatus() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--bedrock[treat ADDRESS as a Bedrock server (default Java)]' \
        '--legacy[treat ADDRESS as a pre-1.7 Java server]' \
        '(- *)'{-h,--help}'[show help]' \
        '1:server address (host or host:port):' \
        '2: :_mcstatus_commands' \
        '*::arg:' && ret=0

    return ret
}

(( $+functions[_mcstatus_commands] )) ||
_mcstatus_commands() {
    local -a commands
    commands=(
        'ping:ping the server for latency'
        'status:print server status (version / MOTD / players / ping) — default'
        'query:print detailed server info (requires enable-query in server.properties)'
        'json:print combined status + query as JSON'
    )
    _describe -t commands 'mcstatus command' commands
}

_mcstatus "$@"
