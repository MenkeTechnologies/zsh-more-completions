#compdef slapper
# Documentation: https://github.com/ikruglov/slapper
# Simple HTTP load tester with a real-time histogram of request timings

local ret=1

_arguments -s -S \
  '-workers[number of workers]:count:' \
  '-rate[requests per second]:rps:' \
  '-minY[min on Y axis]:duration:' \
  '-maxY[max on Y axis]:duration:' \
  '-targets[targets file]:file:_files' \
  '-timeout[requests timeout]:duration:' \
  '*-H[HTTP header "key: value" set on all requests]:header:' \
  '-base64body[bodies in targets file are base64-encoded]' && ret=0

return ret
