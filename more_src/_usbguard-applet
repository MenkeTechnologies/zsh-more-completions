#compdef usbguard-applet usbguard-applet-qt
# Documentation: https://man.archlinux.org/search?q=usbguard-applet
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-tray[run without tray icon]' \
  '--debug[debug logging]' \
  '*::passthrough:' && ret=0

return ret
