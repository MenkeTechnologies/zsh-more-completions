#compdef flow-aggregator
# _flow-aggregator — Antrea IPFIX flow aggregator (antrea-io/antrea)
# upstream: https://github.com/antrea-io/antrea
# Flags from cmd/flow-aggregator/main.go + pkg/log/log.go on tip.

_flow-aggregator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--config=[flow-aggregator configuration file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[also log to stderr]' \
        '--log_dir=[klog log directory]:dir:_files -/' \
        '--log_file=[klog log file]:file:_files' \
        '--log_file_max_size=[per-file max size (MB)]:n:' \
        '--log_file_max_num=[max log files per severity (0=unlimited)]:n:' \
        '--log-flush-frequency=[log flush interval]:dur:' \
        '--stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[per-module verbosity (pattern=N,...)]:spec:'
}

_flow-aggregator "$@"
