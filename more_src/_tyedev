    _describe -t commands 'tyedev help list commands' commands "$@"
}
(( $+functions[_tyedev__help__search_commands] )) ||
_tyedev__help__search_commands() {
    local commands; commands=()
    _describe -t commands 'tyedev help search commands' commands "$@"
}
(( $+functions[_tyedev__init_commands] )) ||
_tyedev__init_commands() {
    local commands; commands=()
    _describe -t commands 'tyedev init commands' commands "$@"
}
(( $+functions[_tyedev__inspect_commands] )) ||
_tyedev__inspect_commands() {
    local commands; commands=()
    _describe -t commands 'tyedev inspect commands' commands "$@"
