#compdef tyedev
# Documentation: https://man.archlinux.org/search?q=tyedev
# Reference accessed: 2026-05-16
# Source: cargo binstall tyedev@0.4.1
# Probed via: completions zsh
# Repository: https://github.com/CodeMan99/tyedev

autoload -U is-at-least

_tyedev() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-p[Pull the index of features & templates]' \
'--pull-index[Pull the index of features & templates]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tyedev_commands" \
"*::: :->tyedev" \
&& ret=0
    case $state in
    (tyedev)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tyedev-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-t+[Reference to a Template in a supported OCI registry]:OCI_REF:_default' \
'--template-id=[Reference to a Template in a supported OCI registry]:OCI_REF:_default' \
'*-f+[Add the given features, may specify more than once]:OCI_REF:_default' \
'*--include-features=[Add the given features, may specify more than once]:OCI_REF:_default' \
'-w+[Target workspace for the devcontainer configuration]:DIRECTORY:_files' \
'--workspace-folder=[Target workspace for the devcontainer configuration]:DIRECTORY:_files' \
'-z[Avoid interactive prompts]' \
'--non-interactive[Avoid interactive prompts]' \
'-s[Write to ".devcontainer.json" when using an \`image\` type template]' \
'--attempt-single-file[Write to ".devcontainer.json" when using an \`image\` type template]' \
'-r[Strip comments from the generated devcontainer.json]' \
'--remove-comments[Strip comments from the generated devcontainer.json]' \
'--include-deprecated[Include deprecated results when searching]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
'-d+[Format for displaying the configuration]:FORMAT:(table json none)' \
'--display-as=[Format for displaying the configuration]:FORMAT:(table json none)' \
'--install-sh[Read the \`install.sh\` script of a given feature]' \
'--show-files[List the filenames of a given feature or template]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
':oci_ref -- The `id` to inspect:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-C+[Display a given collection, including features and templates]:OCI_REF:_default' \
'--collection-id=[Display a given collection, including features and templates]:OCI_REF:_default' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-c+[Match which section of the index]:COLLECTION:(templates features)' \
'--collection=[Match which section of the index]:COLLECTION:(templates features)' \
'-d+[Format for displaying the results]:FORMAT:(table json)' \
'--display-as=[Format for displaying the results]:FORMAT:(table json)' \
'*-f+[Match only within the given fields]:FIELD:(id name description keywords)' \
'*--fields=[Match only within the given fields]:FIELD:(id name description keywords)' \
'--include-deprecated[Display deprecated results]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
':value -- The keyword(s) to match:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tyedev__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tyedev-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tyedev_commands] )) ||
_tyedev_commands() {
    local commands; commands=(
'completions:Generate shell auto-complete configuration' \
'init:Create new devcontainer' \
'inspect:Display details of a specific feature, template, or collection' \
'list:Overview of collections' \
'search:Text search the \`id\`, \`keywords\`, and \`description\` fields of templates or features' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tyedev commands' commands "$@"
}
(( $+functions[_tyedev__completions_commands] )) ||
_tyedev__completions_commands() {
    local commands; commands=()
    _describe -t commands 'tyedev completions commands' commands "$@"
}
