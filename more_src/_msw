#compdef msw

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize Mock Service Worker in a project'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'msw command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--save[save public directory to package.json]' \
          '--no-save[do not save to package.json]' \
          '1:public directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
