#compdef zf
# Documentation: https://man.archlinux.org/search?q=zf
# Reference accessed: 2026-05-16

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d=[delimiter character]:delimiter' \
  '-e[use exact matching]' \
  '-p[use plain matching]' \
  '-f=[select a field by number]:field number' \
  '-0[read NUL delimited input]' \
  '--height=[height of the finder]:lines' \
  '--keep-order[keep input order]' \
  '*:file:_files'
