#compdef crm_simulate
# Documentation: https://man.archlinux.org/search?q=crm_simulate
# Reference accessed: 2026-05-16

# crm_simulate: simulate a CIB to predict cluster behavior
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-Q[quiet]' \
  '--quiet[quiet]' \
  '-S[simulate now (default)]' \
  '--simulate[simulate now (default)]' \
  '-X[input CIB XML on cmdline]:xml:' \
  '--xml-text=[input CIB XML on cmdline]:xml:' \
  '-x[input CIB from file]:file:_files' \
  '--xml-file=[input CIB from file]:file:_files' \
  '-L[input live CIB]' \
  '--live-check[input live CIB]' \
  '-r[run scheduler then check state]' \
  '--run[run scheduler then check state]' \
  '-s[show scoring]' \
  '--show-scores[show scoring]' \
  '-U[show resource utilization]' \
  '--show-utilization[show resource utilization]' \
  '-X[output transition graph]' \
  '-D[transitions destination file]:file:_files' \
  '--dot-file=[transitions destination file]:file:_files' \
  '-G[graph file]:file:_files' \
  '--graph-file=[graph file]:file:_files' \
  '-i[set CIB node attribute]:value:' \
  '-N[fail this node]:node:' \
  '-n[set node as offline]:node:' \
  '-q[fence (down) this node]:node:' \
  '-w[wait for action to complete]' \
  '-O[show operations to be done]' \
  '--operations[show operations to be done]' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_simulate args:_files' && ret=0
return ret
