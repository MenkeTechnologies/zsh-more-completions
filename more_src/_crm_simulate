#compdef crm_simulate
# Documentation: https://www.mankier.com/8/crm_simulate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_simulate: simulate a Pacemaker CIB to predict cluster behavior
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-operations[show operations options]' \
  '(- *)--help-synthetic[show synthetic cluster event options]' \
  '(- *)--help-artifact[show artifact options]' \
  '(- *)--help-source[show data source options]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-Q --quiet)'{-Q,--quiet}'[display only essential output]' \
  '--output-as=[output format]:fmt:(text xml)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '(-R --run)'{-R,--run}'[process input and show planned actions]' \
  '(-S --simulate)'{-S,--simulate}'[run then simulate actions and show new status]' \
  '(-X --in-place)'{-X,--in-place}'[like --simulate but store results back to input]' \
  '(-A --show-attrs)'{-A,--show-attrs}'[show node attributes]' \
  '(-c --show-failcounts)'{-c,--show-failcounts}'[show resource fail counts]' \
  '(-s --show-scores)'{-s,--show-scores}'[show allocation scores]' \
  '(-U --show-utilization)'{-U,--show-utilization}'[show utilization information]' \
  '(-P --profile)'{-P+,--profile=}'[profile XML files in directory]:dir:_files -/' \
  '(-N --repeat)'{-N+,--repeat=}'[repeat profiling N times]:n:' \
  '(-u --node-up)'{-u+,--node-up=}'[simulate bringing node online]:node:' \
  '(-d --node-down)'{-d+,--node-down=}'[simulate taking node offline]:node:' \
  '(-f --node-fail)'{-f+,--node-fail=}'[simulate node failing]:node:' \
  '(-i --op-inject)'{-i+,--op-inject=}'[simulate cluster reaction to failures]:opspec:' \
  '(-F --op-fail)'{-F+,--op-fail=}'[force tasks to fail during simulation]:opspec:' \
  '(-t --set-datetime)'{-t+,--set-datetime=}'[set date/time (ISO 8601)]:datetime:' \
  '(-q --quorum)'{-q+,--quorum=}'[indicate cluster quorum status]:quorum:' \
  '(-w --watchdog)'{-w+,--watchdog=}'[indicate active watchdog device]:device:' \
  '(-g --ticket-grant)'{-g+,--ticket-grant=}'[simulate granting ticket]:ticket:' \
  '(-r --ticket-revoke)'{-r+,--ticket-revoke=}'[simulate revoking ticket]:ticket:' \
  '(-b --ticket-standby)'{-b+,--ticket-standby=}'[simulate ticket standby]:ticket:' \
  '(-e --ticket-activate)'{-e+,--ticket-activate=}'[simulate ticket activate]:ticket:' \
  '(-I --save-input)'{-I+,--save-input=}'[save input config to file]:file:_files' \
  '(-O --save-output)'{-O+,--save-output=}'[save output config to file]:file:_files' \
  '(-G --save-graph)'{-G+,--save-graph=}'[save transition graph (XML)]:file:_files' \
  '(-D --save-dotfile)'{-D+,--save-dotfile=}'[save transition graph (DOT)]:file:_files' \
  '(-a --all-actions)'{-a,--all-actions}'[display all possible actions in graph]' \
  '(-L --live-check)'{-L,--live-check}'[use current live CIB as input]' \
  '(-x --xml-file)'{-x+,--xml-file=}'[retrieve XML from file]:file:_files' \
  '(-p --xml-pipe)'{-p,--xml-pipe}'[retrieve XML from stdin]' && ret=0
return ret
