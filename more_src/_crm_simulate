#compdef crm_simulate

# Pacemaker crm_simulate: simulate cluster transitions for what-if analysis
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet]' \
  '(-x --xml-file)'{-x,--xml-file=}'[read CIB from file]:file:_files' \
  '(-X --xml-stream)'{-X,--xml-stream}'[read CIB from stdin]' \
  '(-O --xml-pipe)'{-O,--xml-pipe}'[treat XML as pipe input]' \
  '(-L --live-check)'{-L,--live-check}'[connect to live CIB]' \
  '(-S --simulate)'{-S,--simulate}'[simulate cluster decisions]' \
  '(-R --run)'{-R,--run}'[simulate cluster behaviour]' \
  '(-X --in-place)'{-X,--in-place}'[modify CIB in place]' \
  '(-s --show-scores)'{-s,--show-scores}'[show resource scores]' \
  '(-U --show-utilization)'{-U,--show-utilization}'[show utilization]' \
  '(-D --save-dot)'{-D,--save-dot=}'[save dot graph]:file:_files' \
  '(-G --save-graph)'{-G,--save-graph=}'[save transition graph]:file:_files' \
  '(-I --save-input)'{-I,--save-input=}'[save input XML]:file:_files' \
  '(-O --save-output)'{-O,--save-output=}'[save output XML]:file:_files' \
  '(-u --node-up)'{-u,--node-up=}'[bring node up]:node:' \
  '(-d --node-down)'{-d,--node-down=}'[take node down]:node:' \
  '(-f --node-fail)'{-f,--node-fail=}'[fail node]:node:' \
  '(-i --op-inject)'{-i,--op-inject=}'[inject operation result]:op:' \
  '(-F --op-fail)'{-F,--op-fail=}'[fail operation]:op:' \
  '(-q --quorum)'{-q,--quorum=}'[set quorum]:val:(yes no)' \
  '(-w --watchdog)'{-w,--watchdog=}'[watchdog state]:val:(yes no)' \
  '(-t --ticket-grant)'{-t,--ticket-grant=}'[grant ticket]:ticket:' \
  '(-r --ticket-revoke)'{-r,--ticket-revoke=}'[revoke ticket]:ticket:' \
  '(-n --node-attr)'{-n,--node-attr=}'[set transient node attribute]:attr=val:' \
  '*::crm_simulate args:_files' && ret=0
return ret
