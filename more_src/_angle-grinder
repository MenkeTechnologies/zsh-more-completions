#compdef angle-grinder
# Documentation: https://man.archlinux.org/search?q=angle-grinder
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--self-update[update to the latest version]' \
  '*:query or file:_files' && ret=0

return ret
