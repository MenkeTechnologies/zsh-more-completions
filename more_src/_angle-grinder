#compdef angle-grinder
# Documentation: https://github.com/rcoh/angle-grinder
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--self-update[update to the latest version]' \
  '*:query or file:_files' && ret=0

return ret
