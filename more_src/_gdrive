#compdef gdrive

# Zsh completion for gdrive (Google Drive CLI)

_gdrive() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'list:list files'
    'download:download file or directory'
    'upload:upload file or directory'
    'update:update file'
    'info:show file info'
    'mkdir:create directory'
    'share:share file or directory'
    'delete:delete file or directory'
    'sync:sync directory'
    'changes:list file changes'
    'revision:manage file revisions'
    'import:upload and convert file to Google document'
    'export:export Google document'
    'about:show account info'
    'version:print version info'
    'help:show help'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'gdrive command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        list)
          _arguments -s -S \
            '-m+[max files to list]:count:' \
            '--max=[max files to list]:count:' \
            '-q+[query string]:query:' \
            '--query=[query string]:query:' \
            '--order=[sort order]:order:(createdTime folder modifiedTime name quotaBytesUsed recency sharedWithMeTime starred viewedByMeTime)' \
            '--name-width=[name column width]:width:' \
            '--absolute[show absolute path]' \
            '--no-header[hide header]' \
            '--bytes[show size in bytes]' \
            && ret=0
          ;;
        download)
          _arguments -s -S \
            '-f[force overwrite]' \
            '--force[force overwrite]' \
            '-r[download directory recursively]' \
            '--recursive[download directory recursively]' \
            '--path=[download path]:download path:_files -/' \
            '--delete[delete remote file after download]' \
            '--no-progress[hide progress]' \
            '--stdout[write to stdout]' \
            '--timeout=[timeout in seconds]:seconds:' \
            '1:file ID:' \
            && ret=0
          ;;
        upload)
          _arguments -s -S \
            '-r[upload directory recursively]' \
            '--recursive[upload directory recursively]' \
            '-p+[parent directory ID]:parent ID:' \
            '--parent=[parent directory ID]:parent ID:' \
            '--name=[filename]:name:' \
            '--description=[file description]:description:' \
            '--no-progress[hide progress]' \
            '--mime=[MIME type]:MIME type:' \
            '--share[share file after upload]' \
            '--delete[delete local file after upload]' \
            '--timeout=[timeout in seconds]:seconds:' \
            '--chunksize=[upload chunk size]:size:' \
            '*:files:_files' \
            && ret=0
          ;;
        info)
          _arguments -s -S \
            '--bytes[show size in bytes]' \
            '1:file ID:' \
            && ret=0
          ;;
        mkdir)
          _arguments -s -S \
            '-p+[parent directory ID]:parent ID:' \
            '--parent=[parent directory ID]:parent ID:' \
            '--description=[directory description]:description:' \
            '--share[share after creation]' \
            '1:directory name:' \
            && ret=0
          ;;
        share)
          _arguments -s -S \
            '--role=[share role]:role:(owner writer commenter reader)' \
            '--type=[share type]:type:(user group domain anyone)' \
            '--email=[email address]:email:' \
            '--domain=[domain]:domain:' \
            '--discoverable[make discoverable]' \
            '--revoke[revoke share]' \
            '1:file ID:' \
            && ret=0
          ;;
        delete)
          _arguments -s -S \
            '-r[delete directory recursively]' \
            '--recursive[delete directory recursively]' \
            '1:file ID:' \
            && ret=0
          ;;
        sync)
          _arguments -s -S \
            '1:subcommand:(upload download list content)' \
            && ret=0
          ;;
        export)
          _arguments -s -S \
            '-f[force overwrite]' \
            '--force[force overwrite]' \
            '--mime=[MIME type]:MIME type:' \
            '1:file ID:' \
            '2:output file:_files' \
            && ret=0
          ;;
        *)
          _arguments '*:file ID:' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_gdrive "$@"
