#compdef gdrive
# Documentation: https://github.com/glotlabs/gdrive
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for glotlabs/gdrive v3 (Google Drive CLI)

_gdrive() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'about:print information about gdrive'
    'account:manage accounts'
    'drives:manage drives'
    'files:manage files'
    'permissions:manage file permissions'
    'version:print version information'
    'help:show help'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' && ret=0

  case $state in
    (command)
      _describe -t commands 'gdrive command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        account)
          local -a account_cmds=(
            'add:add an account'
            'list:list all accounts'
            'current:print current account'
            'switch:switch to a different account'
            'remove:remove an account'
            'export:export account as zip'
            'import:import account from archive'
          )
          _describe -t account-cmds 'account subcommand' account_cmds && ret=0
          ;;
        drives)
          local -a drives_cmds=('list:list drives')
          _describe -t drives-cmds 'drives subcommand' drives_cmds && ret=0
          ;;
        files)
          if (( CURRENT == 2 )); then
            local -a files_cmds=(
              'info:print file info'
              'list:list files'
              'download:download file'
              'upload:upload file'
              'update:update file (new version)'
              'delete:delete file'
              'mkdir:create directory'
              'rename:rename file or directory'
              'move:move file or directory'
              'copy:copy file'
              'import:import file as google document'
              'export:export google document to file'
            )
            _describe -t files-cmds 'files subcommand' files_cmds && ret=0
          else
            case ${words[2]} in
              list)
                _arguments -s -S \
                  '--max=[max files to list]:count:' \
                  '--query=[query string]:query:' \
                  '--order-by=[sort order]:order:' \
                  '--parent=[parent directory id]:id:' \
                  '--drive=[shared drive id]:id:' \
                  '--skip-header[do not print header]' \
                  '--full-name[show full name without truncation]' \
                  '--field-separator=[field separator]:sep:' && ret=0
                ;;
              download)
                _arguments -s -S \
                  '--overwrite[overwrite existing files]' \
                  '--follow-shortcuts[follow shortcut and download target]' \
                  '--recursive[download directories]' \
                  '--destination=[download path]:path:_files -/' \
                  '--stdout[write to stdout]' \
                  '1:file id:' && ret=0
                ;;
              upload)
                _arguments -s -S \
                  '--mime=[force MIME type]:mime:' \
                  '*--parent=[parent directory id]:id:' \
                  '--recursive[upload directories]' \
                  '--chunk-size=[upload chunk size MB]:mb:(1 2 4 8 16 32 64 128 256 512 1024 4096 8192)' \
                  '--print-chunk-errors[print chunk upload errors]' \
                  '--print-chunk-info[print chunk details]' \
                  '--print-only-id[print only id]' \
                  '*:file:_files' && ret=0
                ;;
              update)
                _arguments -s -S \
                  '--mime=[force MIME type]:mime:' \
                  '--chunk-size=[upload chunk size MB]:mb:(1 2 4 8 16 32 64 128 256 512 1024 4096 8192)' \
                  '--print-chunk-errors[print chunk upload errors]' \
                  '--print-chunk-info[print chunk details]' \
                  '1:file id:' \
                  '2:file path:_files' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  '--recursive[delete directory recursively]' \
                  '1:file id:' && ret=0
                ;;
              mkdir)
                _arguments -s -S \
                  '*--parent=[parent directory id]:id:' \
                  '--print-only-id[print only id]' \
                  '1:directory name:' && ret=0
                ;;
              info)
                _arguments -s -S \
                  '--size-in-bytes[show size in bytes]' \
                  '1:file id:' && ret=0
                ;;
              import)
                _arguments -s -S \
                  '*--parent=[parent directory id]:id:' \
                  '--print-only-id[print only id]' \
                  '1:file path:_files' && ret=0
                ;;
              export)
                _arguments -s -S \
                  '--overwrite[overwrite existing files]' \
                  '1:file id:' \
                  '2:output file path:_files' && ret=0
                ;;
            esac
          fi
          ;;
        permissions)
          local -a perm_cmds=(
            'share:grant permission to file'
            'list:list permissions for a file'
            'revoke:revoke permission'
          )
          _describe -t perm-cmds 'permissions subcommand' perm_cmds && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_gdrive "$@"
