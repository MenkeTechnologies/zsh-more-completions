#compdef vspreview
# Documentation: https://github.com/Irrational-Encoding-Wizardry/vs-preview
# Standalone previewer for VapourSynth scripts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-c --preserve-cwd)'{-c,--preserve-cwd}'[do not chdir to script parent directory]' \
  '(-f --frame)'{-f,--frame}'[frame to load initially]:frame:' \
  '--vscode-setup[install launch settings in cwd .vscode]:mode:(override append ignore)' \
  '--verbose[set the logging to verbose]' \
  '--force[force install of a plugin even if it exists]' \
  '--no-deps[ignore downloading dependencies]' \
  '--force-storage[force override of local/global storage]' \
  '1:script or command:_files -g "*.vpy"' \
  '*:plugins:' && ret=0

return ret
