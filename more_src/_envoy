#compdef envoy

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config-path)'{-c,--config-path}'[path to configuration file]:config file:_files' \
  '--config-yaml=[inline YAML configuration]:yaml' \
  '--mode=[server mode]:mode:(serve validate init_only)' \
  '--admin-address-path=[admin address output path]:path:_files' \
  '--local-address-ip-version=[local IP address version]:version:(v4 v6)' \
  '(-l --log-level)'{-l,--log-level}'[default log level]:level:(trace debug info warning error critical off)' \
  '--component-log-level=[component log levels]:levels' \
  '--log-path=[log file path]:log file:_files' \
  '--log-format=[log message format]:format' \
  '--log-format-escaped[escape log format string]' \
  '--service-cluster=[cluster name]:cluster' \
  '--service-node=[node name]:node' \
  '--service-zone=[zone name]:zone' \
  '--file-flush-interval-msec=[file flush interval in ms]:ms' \
  '--drain-time-s=[drain time in seconds]:seconds' \
  '--drain-strategy=[drain strategy]:strategy:(gradual immediate)' \
  '--parent-shutdown-time-s=[parent shutdown time in seconds]:seconds' \
  '--concurrency=[number of worker threads]:threads' \
  '--max-stats=[max number of stats]:count' \
  '--max-obj-name-len=[max object name length]:length' \
  '--hot-restart-version[print hot restart compatibility version]' \
  '--restart-epoch=[hot restart epoch]:epoch' \
  '--enable-fine-grain-logging[enable fine-grain logging]' \
  '--socket-path=[socket path for hot restart]:path:_files' \
  '--socket-mode=[socket mode for hot restart]:mode' \
  '--disable-extensions=[comma-separated extensions to disable]:extensions' \
  '--use-dynamic-base-id[use dynamic base ID]' \
  '--base-id=[base ID for hot restart]:id' \
  '--base-id-path=[path to write base ID]:path:_files' \
  '--allow-unknown-static-fields[allow unknown fields in static config]' \
  '--reject-unknown-dynamic-fields[reject unknown fields in dynamic config]' \
  '--enable-mutex-tracing[enable mutex contention tracing]' \
  '--disable-hot-restart[disable hot restart]' \
  '--cpuset-threads[bind worker threads to CPU set]' \
  '--skip-hot-restart-on-no-parent[skip hot restart if no parent]' \
  '--skip-hot-restart-parent-stats[skip hot restart parent stats]'
