#compdef fio-cli
# _fio-cli — Jens Axboe fio Flexible I/O tester CLI alias (axboe team, C); custom argparse
# upstream: https://github.com/axboe/fio

_fio-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug=+[options]:str:' \
        '--parse-only[parse job only]' \
        '--output=+[file]:file:_files' \
        '--bandwidth-log[generate bandwidth log]' \
        '--minimal[minimal output]' \
        '--output-format=+[format]:f:(terse json json+ normal)' \
        '--terse-version=+[version]:n:' \
        '--readonly[force read-only]' \
        '--readonly[force read-only]' \
        '--server=+[host[,port]]:str:' \
        '--daemonize=+[pid file]:file:_files' \
        '--client=+[host file or host]:str:' \
        '--remote-config=+[file]:file:_files' \
        '--enghelp=+[engine[,cmd]]:str:' \
        '--showcmd[show as command line]' \
        '--eta=+[when]:w:(always never auto)' \
        '--eta-newline=+[interval]:str:' \
        '--eta-interval=+[interval]:str:' \
        '--status-interval=+[interval]:str:' \
        '--section=+[name]:str:' \
        '--alloc-size=+[kb]:n:' \
        '--warnings-fatal[warnings fatal]' \
        '--max-jobs=+[n]:n:' \
        '--server[run as server]' \
        '--cpuclock-test[CPU clock test]' \
        '--crctest=+[crc]:str:' \
        '--cmdhelp=+[cmd]:str:' \
        '--enghelp=+[engine]:str:' \
        '--idle-prof=+[option]:o:(system percpu calibrate)' \
        '--inflate-log=+[log]:file:_files' \
        '--trigger-file=+[file]:file:_files' \
        '--trigger-timeout=+[s]:n:' \
        '--trigger=+[command]:str:' \
        '--trigger-remote=+[command]:str:' \
        '--latency-log[generate latency log]' \
        '--iops-log[generate iops log]' \
        '--no-warnings-fatal[no warnings fatal]' \
        '--lat-log[generate latency log]' \
        '--clat-log[generate clat log]' \
        '--slat-log[generate slat log]' \
        '--bw-log[generate bw log]' \
        '--name=+[job name]:str:' \
        '--ioengine=+[engine]:e:(sync psync vsync pvsync pvsync2 libaio posixaio mmap splice syslet-rw sg null net netsplice cpuio rdma falloc e4defrag rados rbd gfapi mtd pmemblk dev-dax io_uring io_uring_cmd xnvme ime_psync ime_psyncv ime_aio libcufile dfs nfs exfat libzbc nbd libhdfs filecreate filestat filedelete sg-zone librpma_apm_client librpma_apm_server librpma_gpspm_client librpma_gpspm_server)' \
        '--rw=+[type]:t:(read write randread randwrite rw readwrite randrw trimwrite trim randtrim randrw)' \
        '--bs=+[block size]:str:' \
        '--size=+[size]:str:' \
        '--directory=+[dir]:dir:_files -/' \
        '--filename=+[file]:file:_files' \
        '--filesize=+[size]:str:' \
        '--numjobs=+[count]:n:' \
        '--runtime=+[seconds]:n:' \
        '--time_based[run time-based]' \
        '--ramp_time=+[seconds]:n:' \
        '--group_reporting[group reporting]' \
        '--direct=+[bool]:b:(0 1)' \
        '--sync=+[bool]:b:(0 1)' \
        '--buffered=+[bool]:b:(0 1)' \
        '--randrepeat=+[bool]:b:(0 1)' \
        '--norandommap[no random map]' \
        '--write_bw_log=+[name]:str:' \
        '--write_iops_log=+[name]:str:' \
        '--write_lat_log=+[name]:str:' \
        '--allow_file_create=+[bool]:b:(0 1)' \
        '--unlink=+[bool]:b:(0 1)' \
        '--prio=+[priority]:n:' \
        '--iodepth=+[depth]:n:' \
        '--queue_depth=+[depth]:n:' \
        '*:job file:_files'
}

_fio-cli "$@"
