#compdef ironbar

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[specify config file]:config file:_files' \
  '--style=[specify style file]:style file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'var:set or get variables'
      'set:set an option'
      'load-css:reload CSS stylesheet'
    )
    _describe -t commands 'ironbar command' commands && ret=0
    ;;
esac

return ret
