#compdef ollama-show
# Documentation: https://man.archlinux.org/search?q=ollama-show
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--license[show license]' \
  '--modelfile[show Modelfile]' \
  '--parameters[show parameters]' \
  '--system[show system message]' \
  '--template[show template]' \
  '1:model:' && return 0
