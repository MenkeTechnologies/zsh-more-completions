#compdef kata-ctl
# _kata-ctl — Kata Containers control tool (Rust; clap)
# upstream: https://github.com/kata-containers/kata-containers
# Top-level flags + subcommands from src/tools/kata-ctl/src/args.rs on tip.

_kata-ctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print version and exit]' \
        '(-l --log-level)'{-l,--log-level}'=[minimum log level]:level:(trace debug info warning error critical)' \
        '(-j --json-logging)'{-j,--json-logging}'[emit JSON-formatted logs]' \
        '--show-default-config-paths[list configuration file locations]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                check:'test if the system can run Kata Containers (all/no-network-checks/check-version-only/only-list-releases/include-all-releases/list)'
                'direct-volume':'manage direct-assigned block volumes (add/remove/stats/resize)'
                env:'display Kata environment / settings'
                exec:'enter a guest VM via debug console'
                factory:'manage VM factory (init/destroy/status)'
                iptables:'manage guest VM iptables'
                metrics:'gather metrics for a sandbox'
                monitor:'start a monitor exposing Kata metrics over HTTP'
                version:'show version details'
                'log-parser':'parse Kata logs into text/csv/json/toml/xml/yaml'
            )
            _describe -t commands 'kata-ctl subcommand' subs
            ;;
        args)
            case $line[1] in
                check)
                    _arguments \
                        '1:check:(all no-network-checks check-version-only only-list-releases include-all-releases list)'
                    ;;
                env)
                    _arguments \
                        '--json[format output as JSON]' \
                        '(-f --file)'{-f,--file}'=[file to write env output to]:file:_files'
                    ;;
                factory)
                    _arguments \
                        '1:factory:(init destroy status)'
                    ;;
                'direct-volume')
                    _arguments \
                        '1:directvol:(add remove stats resize)'
                    ;;
                monitor)
                    _arguments \
                        '1::address (default 127.0.0.1:8090):'
                    ;;
            esac
            ;;
    esac
}

_kata-ctl "$@"
