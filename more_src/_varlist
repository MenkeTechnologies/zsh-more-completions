#compdef varlist
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/varlist.html
# MIRIAD varlist - list variables in a uv dataset

local ret=1

_arguments -s -S \
  'vis=[input uv dataset]:vis:_files' \
  'log=[output file for results]:log:_files' \
  'option=[names or all output format]:option:(names all)' \
  '*:visibility data:_files' && ret=0

return ret
