#compdef envoy-cli2 envoy2
# _envoy-cli2 — Lyft envoyproxy envoy-cli2 CLI command-line frontend wrapping the Envoy CNCF Graduated open-source edge and service proxy designed for cloud-native applications written in C++ originally Lyft now CNCF Graduated 2018 high-performance C++ distributed proxy designed for single services and applications HTTP/1.1 HTTP/2 HTTP/3 gRPC TCP UDP WebSocket xDS API hot restart wasm-extensions service-mesh-Istio-Consul-Connect data-plane API-Gateway tracing Jaeger Zipkin OpenTracing-OpenTelemetry config-yaml admin-interface (Lyft envoyproxy CNCF team Matt Klein, C++); abseil-cli
# upstream: https://www.envoyproxy.io/

_envoy-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config path]:file:_files -g "envoy.yaml envoy.json *.yaml *.yml *.json"' \
        '--config-path=+[file]:file:_files -g "envoy.yaml envoy.json *.yaml *.yml *.json"' \
        '--config-yaml=+[yaml]:str:' \
        '--allow-unknown-static-fields[allow unknown static]' \
        '--allow-unknown-fields[allow unknown fields]' \
        '--reject-unknown-dynamic-fields[reject unknown dynamic]' \
        '--admin-address-path=+[file]:file:_files' \
        '--local-address-ip-version=+[v]:v:(v4 v6)' \
        '--log-level=+[l]:l:(trace debug info warning warn error critical off)' \
        '-l+[log level]:l:(trace debug info warning warn error critical off)' \
        '--component-log-level=+[scope:level]:str:' \
        '--log-format=+[fmt]:str:' \
        '--log-format-escaped[escape log format]' \
        '--log-path=+[file]:file:_files' \
        '--use-fake-symbol-table=+[v]:v:(true false)' \
        '--cpuset-threads[use CPU set]' \
        '--enable-fine-grain-logging[fine-grain logging]' \
        '--restart-epoch=+[N]:n:' \
        '--base-id=+[N]:n:' \
        '--use-dynamic-base-id[dynamic base id]' \
        '--base-id-path=+[file]:file:_files' \
        '--mode=+[m]:m:(serve validate)' \
        '--concurrency=+[N]:n:' \
        '--service-cluster=+[name]:str:' \
        '--service-node=+[name]:str:' \
        '--service-zone=+[name]:str:' \
        '--file-flush-interval-msec=+[N]:n:' \
        '--drain-time-s=+[N]:n:' \
        '--drain-strategy=+[s]:s:(gradual immediate)' \
        '--parent-shutdown-time-s=+[N]:n:' \
        '--hot-restart-version[show hot restart version]' \
        '--disable-hot-restart[disable hot restart]' \
        '--enable-mutex-tracing[enable mutex tracing]' \
        '--bootstrap-version=+[v]:str:' \
        '--socket-mode=+[mode]:n:' \
        '--socket-path=+[path]:_files' \
        '--enable-core-dump[enable core dump]' \
        '--quiet-logs-for-debug-level=+[v]:str:' \
        '--stats-flush-interval=+[d]:str:' \
        '*:args:'
}

_envoy-cli2 "$@"
