#compdef kubecfg

# Zsh completion for kubecfg (Kubernetes Jsonnet config tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'show:render manifests and print to stdout'
  'diff:diff against objects running on the server'
  'update:update server objects to match local manifests'
  'validate:validate manifests against server schemas'
  'delete:delete server objects matching local manifests'
  'version:print version information'
  'help:help about any command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--as[username to impersonate]:username' \
  '*--as-group[group to impersonate]:group' \
  '--cluster[cluster name]:cluster' \
  '--context[kubeconfig context]:context' \
  '*--ext-code[external code variables (key=val)]:key=code' \
  '*--ext-str[external string variables (key=val)]:key=value' \
  '*--jpath[additional library search path]:directory:_files -/' \
  '--kubeconfig[path to kubeconfig file]:kubeconfig:_files' \
  '(-n --namespace)'{-n,--namespace}'[kubernetes namespace]:namespace' \
  '--server[kubernetes API server URL]:URL' \
  '*--tla-code[top-level argument code (key=val)]:key=code' \
  '*--tla-str[top-level argument string (key=val)]:key=value' \
  '--tls-ca-cert-file[TLS CA certificate file]:file:_files' \
  '--tls-cert-file[TLS client certificate file]:file:_files' \
  '--tls-private-key-file[TLS client private key]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS certificate verification]' \
  '-v[log verbosity level]:level' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kubecfg command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (show|diff|update|validate|delete)
        _arguments \
          '*--ext-code[external code variables]:key=code' \
          '*--ext-str[external string variables]:key=value' \
          '*--tla-code[top-level argument code]:key=code' \
          '*--tla-str[top-level argument string]:key=value' \
          '*:jsonnet file:_files -g "*.(jsonnet|libsonnet|json|yaml|yml)(N)"' && ret=0
        ;;
      (help)
        _describe -t commands 'kubecfg command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
