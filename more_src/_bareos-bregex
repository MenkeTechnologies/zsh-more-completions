# bareos-bregex: Bareos regex pattern tester
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
  '(--dt --debug-timestamps)'{--dt,--debug-timestamps}'[print timestamps in debug output]' \
  '(-f --filename)'{-f+,--filename=}'[file or data to match (required)]:file:_files' \
  '(-l --suppress-linenumbers)'{-l,--suppress-linenumbers}'[suppress line numbers]' \
  '(-n --not-match)'{-n,--not-match}'[print non-matching lines]' \
  '*:pattern:' && ret=0
return ret
