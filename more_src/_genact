#compdef genact

# Zsh completion for genact (pretend activity generator)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-V[Show version]' \
  '--version[Show version]' \
  '-l[List available modules]' \
  '--list-modules[List available modules]' \
  '*-m+[Set module(s) to use]:module:(bootlog botnet cargo cc composer cryptomining docker_build docker_image_rm download julia kernel_compile memdump mkinitcpio simcity terraform weblog ansible)' \
  '*--module=[Set module(s) to use]:module:(bootlog botnet cargo cc composer cryptomining docker_build docker_image_rm download julia kernel_compile memdump mkinitcpio simcity terraform weblog ansible)' \
  '-s+[Set speed multiplier]:speed:' \
  '--speed-factor=[Set speed multiplier]:speed:' \
  '--exit-after-modules[Exit after all modules have run once]' \
  '--exit-after-time=[Exit after specified time (e.g. 5m)]:duration:' \
  '--print-completions=[Print shell completions]:shell:(bash fish zsh powershell elvish)' && return 0
