#compdef redash-cli redash redash-cli2
# _redash-cli — Redash redash-cli CLI command-line frontend wrapping the Redash open-source business intelligence visualization tool managing queries dashboards alerts data-sources users groups permissions snapshots refresh-tokens visualizations destinations notifications scheduled refresh API-key (Redash team, Python); click
# upstream: https://redash.io/

_redash-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'query:query management'
        'dashboard:dashboard management'
        'data-source:data source management'
        'alert:alert management'
        'user:user management'
        'group:group management'
        'permission:permission operations'
        'destination:destination management'
        'visualization:visualization management'
        'refresh:refresh operations'
        'execute:execute a query'
        'snapshot:snapshot management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--redash-url=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json *.ini"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json *.ini"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redash-cli subcommand' sub ;;
        args)
            case $words[1] in
                query|dashboard|data-source|alert|user|group|destination|visualization|snapshot|permission) _arguments '1:op:(list get create update delete refresh archive duplicate)' '*:id:' ;;
                execute|refresh) _arguments '*:query id:' ;;
            esac
            ;;
    esac
}

_redash-cli "$@"
