#compdef opensca-cli
# Documentation: https://github.com/XmirrorSecurity/OpenSCA-cli
# Reference accessed: 2026-05-16
# Verified: XmirrorSecurity/OpenSCA-cli README CLI flag table.
# Removed from prior file: bogus man.archlinux.org search URL;
# generic _default arg handler; missing -config/-out/-log/-token/-proj.

# opensca-cli: open-source SCA scanner (Software Composition Analysis)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-config[config file]:file:_files -g "*.(json|yaml|yml)(-.)"' \
  '-path[target file/directory to scan]:path:_files' \
  '-out[output report (format from suffix: json/xml/html/sqlite/csv/sarif/spdx/cyclonedx/swid/dsdx)]:file:_files' \
  '-log[log file]:file:_files' \
  '-token[cloud service auth token]:token:' \
  '-proj[SaaS project token]:token:' && ret=0
return ret
