#compdef kextfind
# Documentation: man kextfind(8) (macOS, deprecated; use kmutil find)
# Source: macOS kextfind — find kernel extensions and print info, supports rich query DSL.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h -help)'{-h,-help}'[show help]' \
    '-set-arch+[architecture for property-matching]:arch:(i386 x86_64 x86_64h arm64 arm64e ppc ppc64)' \
    '(-i -case-insensitive)'{-i,-case-insensitive}'[case-insensitive string compares]' \
    '(-s -substring)'{-s,-substring}'[substring searches for string properties]' \
    '-no-paths[print just bundle names]' \
    '-relative-paths[print paths relative to repositories]' \
    '(-0 -nul)'{-0,-nul}'[NUL-separate print outputs]' \
    '*'{-f,-search-item=}'[kext or directory to search]:kext_or_dir:_files' \
    '(-e -system-extensions)'{-e,-system-extensions}'[add /System/Library/Extensions and /Library/Extensions]' \
    '*:kext or query predicate (-b/-bundle-id/-property/-dup/-and/-or/-not/...):_files' \
    && ret=0

return ret
