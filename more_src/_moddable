#compdef mcconfig mcrez mcrun mcsim mclocal mcpack
# _moddable — Moddable SDK XS JavaScript engine + tools for embedded targets (Marvell, Espruino, M5Stack, Gecko, ESP32, RP2040)
# upstream: https://github.com/Moddable-OpenSource/moddable

_moddable() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d[debug build]' \
        '-i[instrument]' \
        '-m+[manifest file]:file:_files -g "manifest.json"' \
        '-o+[output dir]:dir:_files -/' \
        '-O+[host id]:id:' \
        '-p+[platform]:platform:(esp esp32 esp8266 pico pico_w nrf52 mac mac/lin lin gecko/giant gecko/mighty gecko/thunder qca4020 wasm sim/mac sim/win sim/lin)' \
        '-s+[subplatform]:platform:' \
        '-t+[target]:target:(all clean run)' \
        '-r+[rotation degrees]:n:(0 90 180 270)' \
        '-v[verbose]' \
        '-x[xs lib instead of build]' \
        '*:cmd:'
}

_moddable "$@"
