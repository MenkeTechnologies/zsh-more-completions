#compdef allure

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'serve:generate report and serve over HTTP'
  'generate:generate report from results'
  'open:open a generated report'
  'plugin:plugin operations'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'allure subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '(-o --report-dir)'{-o,--report-dir=}'[output report directory]:dir:_files -/' \
          '(-c --clean)'{-c,--clean}'[clean output before generating]' \
          '--config=[allure config file]:file:_files' \
          '--profile=[active profile]:profile:' \
          '--name=[report name]:name:' \
          '--report-language=[report language]:lang:' \
          '--single-file[generate single-file report]' \
          '*:results:_files -/' && ret=0
        ;;
      (serve)
        _arguments \
          '--host=[host]:host:_hosts' \
          '--port=[port]:port:' \
          '--config=[allure config file]:file:_files' \
          '--profile=[active profile]:profile:' \
          '--name=[report name]:name:' \
          '--report-language=[report language]:lang:' \
          '*:results:_files -/' && ret=0
        ;;
      (open)
        _arguments \
          '--host=[host]:host:_hosts' \
          '--port=[port]:port:' \
          ':report:_files -/' && ret=0
        ;;
      (plugin)
        _arguments \
          '--config=[allure config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
