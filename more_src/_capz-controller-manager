#compdef capz-controller-manager
# _capz-controller-manager — Cluster API Azure provider controller manager (CAPZ)
# upstream: https://github.com/kubernetes-sigs/cluster-api-provider-azure
# Flags from main.go (pflag) on tip.

_capz-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--profiler-address=[pprof bind address]:host\:port:' \
        '--azurecluster-concurrency=[AzureCluster concurrent reconciles]:n:' \
        '--azuremachine-concurrency=[AzureMachine concurrent reconciles]:n:' \
        '--azuremachinepool-concurrency=[AzureMachinePool concurrent reconciles]:n:' \
        '--azuremachinepoolmachine-concurrency=[AzureMachinePoolMachine concurrent reconciles]:n:' \
        '--debouncing-timer=[event debouncing window]:dur:' \
        '--sync-period=[informer resync period]:dur:' \
        '--health-addr=[health probe bind address]:host\:port:' \
        '--webhook-port=[webhook server port]:port:' \
        '--webhook-cert-dir=[webhook serving cert dir]:dir:_files -/' \
        '--reconcile-timeout=[per-reconcile timeout]:dur:' \
        '--service-reconcile-timeout=[per-Azure-service timeout]:dur:' \
        '--api-call-timeout=[Azure API call timeout]:dur:' \
        '--reconciler-requeue=[default requeue duration]:dur:' \
        '--enable-tracing=[emit Azure SDK traces]:bool:(true false)' \
        '--bootstrap-config-gvk=[bootstrap config GroupVersionKind override]:gvk:' \
        '*--disable-controllers-or-webhooks=[disabled controllers/webhooks]:list:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capz-controller-manager "$@"
