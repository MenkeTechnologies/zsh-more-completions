#compdef pyenv-cli
# _pyenv-cli — pyenv Python version manager CLI alias (pyenv-team, Bash); custom argparse
# upstream: https://github.com/pyenv/pyenv

_pyenv-cli() {
    local -a sub=(
        'activate:activate venv'
        'commands:list available commands'
        'completions:list completions'
        'deactivate:deactivate venv'
        'doctor:diagnose pyenv install'
        'exec:exec command using selected python'
        'global:set global python version'
        'help:show help'
        'hooks:show hooks'
        'init:init shell integration'
        'install:install python version'
        'latest:show latest version'
        'local:set local python version'
        'prefix:show install prefix'
        'rehash:rehash shims'
        'root:show pyenv root'
        'shell:set shell python version'
        'shims:list shims'
        'uninstall:uninstall python'
        'update:update pyenv'
        'version:show current version'
        'version-file:show version file'
        'version-name:show version name'
        'version-origin:show version origin'
        'versions:list installed versions'
        'virtualenv:create virtualenv'
        'virtualenv-delete:delete virtualenv'
        'virtualenv-init:init virtualenv'
        'virtualenv-prefix:show virtualenv prefix'
        'virtualenvs:list virtualenvs'
        'which:show python interpreter path'
        'whence:show command source version'
        'install-list:show installable versions'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pyenv subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--list[list available versions]' \
                    '-l[list available versions]' \
                    '--force[force reinstall]' \
                    '-f[force reinstall]' \
                    '--skip-existing[skip existing]' \
                    '-s[skip existing]' \
                    '--keep[keep source]' \
                    '-k[keep source]' \
                    '--verbose[verbose]' \
                    '-v[verbose]' \
                    '--patch[patch]' \
                    '-p[patch]' \
                    '*:version:' ;;
                uninstall) _arguments \
                    '--force[force]' \
                    '-f[force]' \
                    '*:version:' ;;
                global|local|shell) _arguments \
                    '--unset[unset]' \
                    '*:version:' ;;
                virtualenv) _arguments \
                    '--force[force]' \
                    '-f[force]' \
                    '*:arg:' ;;
                init) _arguments \
                    '1:shell:(- bash zsh fish ksh)' \
                    '--no-rehash[no rehash]' ;;
                exec) _arguments '*:cmd:_command_names -e' ;;
                which|prefix|version-name|whence) _arguments '*:command:_command_names -e' ;;
            esac
            ;;
    esac
}

_pyenv-cli "$@"
