#compdef convertfilestops
# Documentation: http://www.leptonica.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above; positional args from
# `convertfilestops` usage output (leptonica 1.87.0).
# Syntax: convertfilestops dirin substr res fileout

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input directory:_files -/' \
  '2:substring (allfiles for all):' \
  '3:input resolution (DPI):' \
  '4:output PS file:_files -g "*.ps"' && ret=0

return ret
