#compdef convertfilestops
# Documentation: https://man.archlinux.org/search?q=convertfilestops
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input directory:_files -/' \
  '2:substring (allfiles for all):' \
  '3:input resolution (DPI):' \
  '4:output PS file:_files -g "*.ps"' && ret=0

return ret
