#compdef evremap

_evremap_commands() {
  local -a commands=(
    'remap:run the key remapper with a config file'
    'list-devices:list available input devices'
  )
  _describe 'command' commands
}

_evremap() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '1:command:_evremap_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        remap)
          _arguments \
            '1:config file:_files -g "*.toml"' \
            '--delay[delay in ms before grabbing device]:ms'
          ;;
      esac
      ;;
  esac
}

_evremap "$@"
