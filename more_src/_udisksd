#compdef udisksd
# Documentation: https://man.archlinux.org/search?q=udisksd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--replace[replace running instance]' \
  '--no-debug[disable debug]' \
  '--no-sigint[do not handle SIGINT]' \
  '--force-load-modules[force load all modules]' \
  '--disable-modules=+[disable modules]:list:' \
  '--enable-modules=+[enable modules]:list:' \
  '--uninstalled[for running uninstalled]' && ret=0

return ret
