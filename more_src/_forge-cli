#compdef forge-cli
# _forge-cli — Laravel Forge server-management CLI alias (laravel team, PHP); symfony console
# upstream: https://github.com/laravel/forge-cli

_forge-cli() {
    local -a sub=(
        'login:login to forge'
        'logout:logout'
        'server:use:set active server'
        'server:current:show current server'
        'server:list:list servers'
        'server:reboot:reboot server'
        'server:upgrade:upgrade php on server'
        'server:nginx:nginx restart'
        'server:mysql:mysql restart'
        'server:postgres:postgres restart'
        'site:show:show site info'
        'site:list:list sites'
        'site:create:create site'
        'site:delete:delete site'
        'site:env:edit env'
        'site:env:pull:pull env'
        'site:env:push:push env'
        'site:nginx:edit nginx'
        'site:logs:show logs'
        'site:command:run command'
        'site:deploy:deploy site'
        'site:script:show deploy script'
        'site:script:edit:edit deploy script'
        'site:ssh:ssh to site'
        'site:branch:switch branch'
        'site:install:install repo'
        'site:uninstall:uninstall repo'
        'cert:list:list certs'
        'cert:install:install cert'
        'cert:obtain:obtain letsencrypt'
        'cert:activate:activate cert'
        'cert:delete:delete cert'
        'completion:dump completion'
        'help:show help'
        'list:list commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'forge subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_forge-cli "$@"
