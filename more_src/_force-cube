#compdef force-cube
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/cube.html
# FORCE: ingest auxiliary data into datacube format

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v)-v[show version]' \
  '(-i)-i[show program purpose]' \
  '(-r)-r[resampling method (GDAL method; default cubic)]:method:' \
  '(-s)-s[pixel resolution of cubed data (default 10)]:resolution:' \
  '(-a)-a[attribute name for vector data]:attribute:' \
  '(-l)-l[layer name for vector data]:layer:' \
  '(-n)-n[output nodata value (default 255)]:nodata:' \
  '(-t)-t[output data type (default Byte)]:datatype:' \
  '(-o)-o[output directory]:dir:_files -/' \
  '(-b)-b[basename of output file]:basename:' \
  '(-j)-j[number of jobs]:jobs:' \
  '*:input file:_files' && ret=0

return ret
