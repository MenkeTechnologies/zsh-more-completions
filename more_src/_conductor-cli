#compdef conductor-cli-cli
# Documentation: https://www.npmjs.com/package/@useconductor-cli/conductor
# Reference accessed: 2026-05-23
# Verified: npx @useconductor-cli/conductor --help.

# Zsh completion for conductor-cli - Conductor AI tool hub MCP server CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'conductor-cli command' \
      'init[first-run setup wizard]' \
      'onboard[interactive plugin TUI]' \
      'status[show Conductor status]' \
      'doctor[diagnose system health]' \
      'health[show health status]' \
      'dashboard[open web dashboard]' \
      'logs[show activity logs]' \
      'reset[reset configuration]' \
      'version[show version]' \
      'ai[configure AI providers]' \
      'mcp[MCP server management]' \
      'plugins[plugin management]' \
      'plugin[plugin management]' \
      'proactive[autonomous agent management]' \
      'google[alias for auth google]' \
      'slack[Slack bot management]' \
      'telegram[Telegram bot]' \
      'auth[authentication management]' \
      'install[install marketplace plugin]' \
      'uninstall[uninstall marketplace plugin]' \
      'marketplace[browse plugin marketplace]' \
      'config[read/write configuration]' \
      'audit[query tamper-evident audit log]' \
      'circuit[manage circuit breaker state]' \
      'release[bump version and publish]' \
      'help[show command help]' && ret=0
    ;;
  args)
    case $line[1] in
      install|uninstall)
        _arguments ':plugin:' && ret=0
        ;;
    esac
    ;;
esac

return ret
