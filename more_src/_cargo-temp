#compdef cargo-temp
# Documentation: https://github.com/yozhgoor/cargo-temp
# Source: yozhgoor/cargo-temp src/cli.rs — create temporary Rust projects with specified dependencies.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-l --lib)'{-l,--lib}'[create a library project instead of a binary]' \
    '(-e --edition)'{-e+,--edition=}'[select the Rust edition for the temporary project]:edition:(2015 2018 2021 2024)' \
    '(-n --name)'{-n+,--name=}'[name of the temporary crate]:name:_default' \
    '(-b --bench)'{-b+,--bench=}'[add benchmarking support using criterion.rs]::bench-file:_default' \
    '(-w --worktree)'{-w+,--worktree=}'[create a temporary git worktree from this repository]::branch:_default' \
    '(-g --git)'{-g+,--git=}'[create a temporary clone of a git repository]:url:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*:dependency:_default' \
    && ret=0

return ret
