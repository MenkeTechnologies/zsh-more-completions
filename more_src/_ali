#compdef ali
# _ali — terminal-UI HTTP load tester (nakabonne/ali)
# upstream: https://github.com/nakabonne/ali
# Flags from main.go (pflag).

_ali() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-r --rate)'{-r+,--rate=}'[requests per second (0 = unlimited)]:rps:' \
        '(-d --duration)'{-d+,--duration=}'[attack duration (0s = infinite)]:duration:' \
        '(-t --timeout)'{-t+,--timeout=}'[per-request timeout (0s disables)]:duration:' \
        '(-m --method)'{-m+,--method=}'[HTTP method]:method:(GET POST PUT DELETE HEAD PATCH OPTIONS)' \
        '*'{-H+,--header=}'[request header]:header:' \
        '(-b --body)'{-b+,--body=}'[request body]:body:' \
        '(-B --body-file)'{-B+,--body-file=}'[file containing request body]:file:_files' \
        '(-M --max-body)'{-M+,--max-body=}'[max response body bytes (-1 = no limit)]:bytes:' \
        '--debug[run in debug mode]' \
        '(-K --no-keepalive)'{-K,--no-keepalive}'[disable HTTP persistent connections]' \
        '(-w --workers)'{-w+,--workers=}'[initial workers]:n:' \
        '(-W --max-workers)'{-W+,--max-workers=}'[maximum workers]:n:' \
        '(-c --connections)'{-c+,--connections=}'[max idle connections per host]:n:' \
        '--no-http2[do not issue HTTP/2 requests]' \
        '--local-addr=[local IP address]:ip:' \
        '--insecure[skip TLS verification]' \
        '--cacert=[PEM CA certificate file]:file:_files' \
        '--cert=[PEM TLS certificate file]:file:_files' \
        '--key=[PEM TLS private key file]:file:_files' \
        '--resolvers=[custom DNS resolver list (comma)]:resolvers:' \
        '--query-range=[time range drawn on charts]:duration:' \
        '--redraw-interval=[chart redraw interval]:duration:' \
        '--export-to=[export results to directory]:dir:_files -/' \
        '1:target URL:'
}

_ali "$@"
