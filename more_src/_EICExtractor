#compdef EICExtractor
# Documentation: https://www.openms.org/documentation/html/TOPP_EICExtractor.html
# OpenMS: extracts and quantifies signal from EICs at given positions

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '*-in[input raw data file (mzML)]:file:_files -g "*.mzML"' \
  '-pos[config file with signal positions (edta)]:file:_files' \
  '-out[output quantitation file (csv)]:file:_files' \
  '-in_header[additional info from _HEADER.TXT (Waters)]:file:_files' \
  '-rt_tol[RT tolerance in seconds]:double:' \
  '-mz_tol[m/z tolerance in ppm]:double:' \
  '-rt_collect[scans up/down in RT for ppm estimation]:int:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
