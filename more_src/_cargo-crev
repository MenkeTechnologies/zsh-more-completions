#compdef cargo-crev

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:configure crev'
  'crate:manage crate reviews and advisories'
  'id:manage crev identity'
  'proof:manage proofs'
  'repo:manage proof repositories'
  'review:create a review for a crate'
  'trust:create a trust proof'
  'verify:verify dependencies'
  'wot:web of trust operations'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'cargo-crev command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      verify)
        _arguments -s -S \
          '--show-all[show all dependencies]' \
          '--show-reviews[show reviews]' \
          '--show-advisories[show advisories]' \
          '--show-issues[show issues]' \
          '--show-flags[show flags]' \
          '--for-id=[verify for specific ID]:ID' \
          '--trust=[minimum trust level]:level:(none low medium high)' \
          '--thoroughness=[minimum thoroughness]:level:(none low medium high)' \
          '--understanding=[minimum understanding]:level:(none low medium high)' \
          '--redundancy=[minimum redundancy]:count' \
          '--recursive[verify recursively]' && ret=0
        ;;
      review)
        _arguments -s -S \
          '--advisory[create an advisory]' \
          '--issue[create an issue]' \
          '--skip-activity-check[skip activity check]' \
          '--diff[review diff to previous version]' \
          '--severity=[advisory severity]:severity:(none low medium high)' \
          '*:crate name:' && ret=0
        ;;
      trust)
        _arguments -s -S \
          '--level=[trust level]:level:(none low medium high)' \
          '--override-trust[override existing trust]' \
          '*:ID:' && ret=0
        ;;
      id)
        local -a id_cmds=(
          'new:create new identity'
          'current:show current identity'
          'export:export identity'
          'import:import identity'
          'switch:switch identity'
          'trust:manage trust'
          'query:query identities'
        )
        _arguments -s -S \
          '1:id command:->id_cmd' && ret=0
        case "$state" in
          id_cmd)
            _describe -t commands 'id subcommand' id_cmds && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
