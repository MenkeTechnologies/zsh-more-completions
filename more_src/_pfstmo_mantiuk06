#compdef pfstmo_mantiuk06
# Documentation: http://pfstools.sourceforge.net/man1/pfstmo_mantiuk06.1.html
# pfstools: Mantiuk 2006 contrast mapping tone mapping operator

local ret=1

_arguments -s -S \
  '(-e --equalize-contrast -f --factor)'{-e,--equalize-contrast}'=[contrast equalization, 0.1 sharp to 1 less sharp]:val' \
  '(-f --factor -e --equalize-contrast)'{-f,--factor}'=[contrast scaling factor 0-1 (default 0.3)]:val' \
  '(-s --saturation)'{-s,--saturation}'=[saturation correction 0-2 (default 0.8)]:val' \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '(-q --quiet)'{-q,--quiet}'[do not display progress report]' \
  '(-h --help)'{-h,--help}'[print list of command line options]' && ret=0

return ret
