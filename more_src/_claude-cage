#compdef claude-cage
# Documentation: https://github.com/zbateson/claude-cage
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dry-run[preview changes without executing]' \
  '(-v --verbose)'{-v,--verbose}'[enable detailed output]' \
  '--debug[enable debug output (implies --verbose)]' \
  '--attach-session=[connect to existing session]:name' \
  '--direct-mount[skip git sync, mount source directly]' \
  '--scoped[export only the current subdirectory]' \
  '--with-dirty[include uncommitted changes in sandbox]' \
  '--test[drop into a shell instead of launching Claude]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'git-merge:Manually sync sandbox changes back to source'
      'clean:Remove cached sessions and work directories'
    )
    _describe -t commands 'claude-cage command' commands && ret=0
    ;;
esac

return ret
