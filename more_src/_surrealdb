#compdef surrealdb
# Documentation: https://surrealdb.com/docs/surrealdb/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: the canonical CLI binary is named `surreal`; `surrealdb` is a common
# alias users invoke. This completion delegates to `_surreal` if available.

if (( $+functions[_surreal] )); then
  _surreal "$@"
else
  _arguments -s -S '*:args:_files'
fi
