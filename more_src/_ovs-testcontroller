#compdef ovs-testcontroller
# _ovs-testcontroller — Open vSwitch ovs-testcontroller CLI simple test SDN OpenFlow controller listening on TCP/SSL acting as a hub or learning-switch L2 forwarding controller talking to bridges via OF1.0 OF1.3 protocol for development testing of Open vSwitch agents (Open vSwitch team, C); getopt
# upstream: https://www.openvswitch.org/

_ovs-testcontroller() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity]:m:(emer err warn info dbg)' \
        '--verbose=+[level]:m:(emer err warn info dbg)' \
        '-H+[hub mode]' \
        '--hub[hub mode]' \
        '-N[normal action]' \
        '--noflow[no flows installed]' \
        '--max-idle=+[seconds]:n:' \
        '--mute[mute echo replies]' \
        '-p+[private key]:file:_files -g "*.pem *.key"' \
        '--private-key=+[file]:file:_files -g "*.pem *.key"' \
        '-c+[certificate]:file:_files -g "*.pem *.crt"' \
        '--certificate=+[file]:file:_files -g "*.pem *.crt"' \
        '-C+[ca-cert]:file:_files -g "*.pem *.crt"' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '-l+[listen punix:/path or ptcp:port]:str:' \
        '--listen=+[target]:str:' \
        '--log-file=+[file]:file:_files' \
        '--pidfile=+[file]:file:_files' \
        '--detach[detach as daemon]' \
        '--no-chdir[do not chdir]' \
        '--monitor[monitor for restarts]' \
        '--unixctl=+[socket]:file:_files' \
        '*:target:'
}

_ovs-testcontroller "$@"
