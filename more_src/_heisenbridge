#compdef heisenbridge
# _heisenbridge — Matrix-IRC bouncer-style bridge (hifi/heisenbridge)
# upstream: https://github.com/hifi/heisenbridge
# Flags from heisenbridge/__main__.py (argparse).

_heisenbridge() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*'{-v,--verbose}'[increase logging verbosity]' \
        '(-c --config)'{-c+,--config=}'[registration YAML file]:file:_files -g "*.(yml|yaml)"' \
        '(-l --listen-address)'{-l+,--listen-address=}'[bridge listen address]:addr:' \
        '(-p --listen-port)'{-p+,--listen-port=}'[bridge listen port]:port:' \
        '(-u --uid)'{-u+,--uid=}'[user id to run as]:uid:' \
        '(-g --gid)'{-g+,--gid=}'[group id to run as]:gid:' \
        '(-i --identd)'{-i,--identd}'[enable identd service]' \
        '--identd-port=[identd listen port]:port:' \
        '--generate[generate Synapse registration YAML]' \
        '--generate-compat[generate Dendrite/Conduit registration YAML]' \
        '--reset[reset ALL bridge configuration and exit]' \
        '--media-proxy[run in media-proxy mode]' \
        '--safe-mode[do not leave invalid rooms on startup]' \
        '(-o --owner)'{-o+,--owner=}'[owner MXID (@user:homeserver)]:mxid:' \
        '1:homeserver URL:'
}

_heisenbridge "$@"
