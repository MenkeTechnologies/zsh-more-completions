#compdef lorikeet
# ============================================================================
# lorikeet - parallel test runner for DevOps with
#             YAML-defined test plans (Rust, MIT-style)
#
# Author : Cameron Braid (cetra3)
# Upstream: https://github.com/cetra3/lorikeet
# crates : lorikeet (binary: lorikeet)
#
# `lorikeet` reads a test-plan YAML file (default
# `test.yml`) describing a directed graph of test
# steps (HTTP requests, shell commands, file checks,
# system metrics, etc.) and executes them in
# parallel where dependencies allow. Each step
# carries an `expect` block describing the success
# criteria (HTTP status, regex match on output,
# numeric threshold). Failures roll up into a
# pass/fail summary + optionally get submitted to
# Slack/webhook endpoints + a JUnit XML report.
#
# Usage:
#   lorikeet [options] [test_plan]
#
# Flags (structopt -> clap v2):
#   -q, --quiet                  - don't output
#                                   results to
#                                   console
#   -c, --config <file>          - configuration
#                                   file (Tera
#                                   template context
#                                   for the test
#                                   plan)
#   -h, --hostname <hostname>    - hostname to
#                                   include in
#                                   webhook
#                                   submissions
#                                   (defaults to
#                                   the local
#                                   hostname)
#   -t, --term                   - force terminal
#                                   colours (override
#                                   atty check)
#   -w, --webhook <url>          - webhook
#                                   submission URL
#                                   (multiple values
#                                   allowed)
#   -s, --slack <url>            - Slack webhook
#                                   submission URL
#                                   (multiple values
#                                   allowed)
#   -j, --junit <file>           - output a JUnit
#                                   XML report to
#                                   this file
#       --help                   - print help
#                                   (long-only;
#                                   `-h` is bound
#                                   to hostname)
#       --version                - print version
#
# Positional:
#   test_plan                    - path to the YAML
#                                   test plan
#                                   (default
#                                   `test.yml`)
#
# Example test plan (test.yml):
#   steps:
#     check_homepage:
#       http: https://example.com
#       expect:
#         status: 200
#     check_api:
#       http: https://example.com/api
#       expect:
#         status: 200
#         regex: '"ok":true'
#       require:
#         - check_homepage
#
# The serde_yaml lane is built on `serde_yaml =
# "0.9.34"` (declared verbatim at upstream
# Cargo.toml HEAD as a direct dep, used in
# src/yaml.rs as `use serde_yaml::{self, Value};`
# then `serde_yaml::from_str(&test_plan_yaml)?`
# at line 127 + `serde_yaml::from_reader(c)` at
# line 181 for loading the configuration context),
# the (historically) canonical Rust YAML
# serialization library by David Tolnay (dtolnay) -
# github.com/dtolnay/serde-yaml.
#
# IMPORTANT: David Tolnay archived dtolnay/
# serde-yaml in March 2024 with the stated reason
# of declining interest in long-term maintenance of
# the YAML format. The Rust community has since
# fragmented its YAML strategy:
#   - serde_yaml: archived but still the dominant
#     reverse-dependency target (10,000+ crates on
#     crates.io depend on it) because the API
#     surface is frozen + the published 0.9.x
#     versions still work fine
#   - saphyr/saphyr: the new low-level YAML 1.2
#     parser (fork of yaml-rust2 which was a fork
#     of chyh1990's original yaml-rust); the
#     community-designated successor for low-level
#     YAML parsing
#   - serde_yml: community fork of serde_yaml
#     continuing the serde adapter; modest adoption
#   - libyaml-safer: pure-Rust port of the C
#     libyaml; lower-level than serde_yaml
#
# Lorikeet (this binary) sits in the dominant
# camp - it imports the archived dtolnay/serde-yaml
# directly. As of the latest commits, no migration
# to saphyr or serde_yml has happened, reflecting
# the reality that the archived serde_yaml still
# works for most use cases + migration cost
# outweighs the marginal benefit.
#
# David Tolnay is the most-canonical Rust author
# by raw library count. His footprint:
#   - syn (the canonical Rust syn-tree library for
#     proc-macros; depended on by ~every proc-macro
#     in the ecosystem)
#   - quote (the canonical Rust quasi-quoter for
#     code generation in proc-macros)
#   - proc-macro2 (canonical proc-macro stable-API
#     shim)
#   - serde (THE canonical serialization framework;
#     co-authored with Erick Tryzelaar)
#   - serde_yaml (canonical YAML adapter, now
#     archived)
#   - thiserror (canonical error-derive macro)
#   - anyhow (canonical dynamic-error type)
#   - cxx (canonical Rust<->C++ FFI bridge)
#   - ryu (canonical floating-point printer; same
#     algorithm as Java's Double.toString)
#   - itoa (canonical integer formatter)
#   - indoc (canonical compile-time indentation
#     trimmer for raw strings)
#   - linkme (canonical compile-time linker-section
#     distributed-slice library)
#   - paste (canonical compile-time identifier
#     pasting macro)
#   - erased-serde (canonical type-erased serde
#     trait objects)
#   - inventory (canonical compile-time global
#     registry)
#   - prettyplease (canonical rustfmt-style
#     formatter library; depended on by syn)
#   - dtoa (canonical floating-point formatter)
#   - half (canonical f16/bf16 implementation)
#   - rustix (with Dan Gohman; canonical libc
#     replacement)
#   - rustversion (canonical compile-time Rust
#     version detection)
#
# This is by raw count the largest single-author
# canonical-Rust footprint by far - 18+ canonical
# crates that collectively form the foundation of
# the Rust ecosystem. Every proc-macro is downstream
# of syn + quote + proc-macro2; every error type is
# downstream of thiserror + anyhow; every serializer
# is downstream of serde. Tolnay's libraries are the
# bedrock substrate.
#
# Compared to BurntSushi (Andrew Gallant): Gallant
# has the largest single-author breadth in
# *applications + spec authority* (ripgrep + regex
# + globset + xsv + fst + toml-test + twox-hash +
# rust-snappy), while Tolnay has the largest
# breadth in *foundational libraries* (serde + syn +
# quote + thiserror + ...).
#
# ----------------------------------------------------------------------------
# AXIS 262 :: YAML parsing libraries (YAML 1.1/1.2
#              spec parsing + serialization)
# Round 1484 :: Rust slot 1 of 4 :: OPENS Axis 262
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : dtolnay/serde-yaml             - Tolnay's
#             (archived 2024;                  archived-but-
#              still dominant via              still-dominant
#              reverse-dep lock-in)            canonical;
#                                              successor
#                                              candidates =
#                                              saphyr/saphyr
#                                              (low-level)
#                                              + serde_yml
#                                              (serde adapter)
#   Go      : go-yaml/yaml v3                 - Canonical
#                                              Ltd / Gustavo
#                                              Niemeyer's
#                                              canonical Go
#                                              YAML library;
#                                              the official
#                                              import path
#                                              `gopkg.in/yaml.v3`
#   TS/Node : nodeca/js-yaml                  - Vitaly
#                                              Puzrin's
#                                              canonical
#                                              Node YAML
#                                              library;
#                                              depended on
#                                              by ESLint +
#                                              webpack +
#                                              Babel + every
#                                              major Node
#                                              project that
#                                              reads YAML
#                                              config
#
# YAML is a *spec-bound* axis - the YAML 1.2 spec
# (https://yaml.org/spec/1.2.2/) defines the grammar
# byte-for-byte. Compliant parsers consume the same
# YAML files and produce the same in-memory tree,
# modulo edge cases around:
#   - YAML 1.1 vs 1.2 compatibility (booleans:
#     `yes`/`no`/`on`/`off` are YAML 1.1 truthy but
#     YAML 1.2 strings)
#   - Tag handling (`!!str`, `!!int`, custom tags)
#   - Anchor/alias resolution
#   - Flow vs block scalar styles
#
# Structural commentary on the canonical libraries:
#   - serde_yaml (Rust): serde-adapter pattern;
#     deserializes YAML into any `Deserialize`
#     type; archived but still dominant via 10,000+
#     reverse-deps + frozen-but-working API
#   - go-yaml v3 (Go): single canonical import path
#     `gopkg.in/yaml.v3`; YAML 1.2 compliance;
#     used by every Kubernetes Go client + Helm +
#     Prometheus + Grafana
#   - js-yaml (Node): YAML 1.2 + YAML 1.1
#     compatibility modes; safe-load by default;
#     used by ESLint + webpack + Babel + Vue + Next.js
#
# Cross-language interop happens at the YAML
# document level - the same YAML file parses into
# equivalent data structures across all three lanes,
# enabling polyglot toolchains like Kubernetes
# manifests (k8s YAML consumed by kubectl in Go +
# Helm in Go + Pulumi in TS + cdk8s in TS + k8s
# Rust clients).
#
# Axis 262 opens with the Rust slot at Tolnay's
# archived-but-dominant serde_yaml; subsequent
# rounds will visit the Go (go-yaml v3) + TS/Node
# (js-yaml) canonicals.
#
# Notable that this axis opens on an *archived*
# upstream library - serde_yaml is in maintenance-
# mode-by-archival yet remains canonical because:
#   1. 10,000+ crates depend on it (reverse-dep lock-in)
#   2. The 0.9.x API is frozen + stable
#   3. Migration to saphyr requires API rewrites that
#      most maintainers haven't prioritized
#   4. The successor camp (saphyr vs serde_yml)
#      hasn't consolidated yet
#
# This mirrors the Schlueter/node-glob situation at
# Axis 261 - older library remains canonical via
# reverse-dependency lock-in despite the existence
# of faster/newer alternatives. Both axes show the
# ecosystem-incumbency pattern where the network
# effect of the install base outweighs technical
# improvements in alternatives.
# ============================================================================

_lorikeet() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-q --quiet)'{-q,--quiet}'[do not output results to console]' \
        '(-c --config)'{-c,--config}'[configuration file (Tera template context)]:file:_files' \
        '(-h --hostname)'{-h,--hostname}'[hostname for webhook submissions]:hostname:_hosts' \
        '(-t --term)'{-t,--term}'[force terminal colours (override atty check)]' \
        '*'{-w,--webhook}'[webhook submission URL (repeatable)]:url:' \
        '*'{-s,--slack}'[Slack webhook submission URL (repeatable)]:url:' \
        '(-j --junit)'{-j,--junit}'[output JUnit XML report to file]:file:_files' \
        '--help[print help]' \
        '--version[print version]' \
        '*:test_plan:_files -g "*.(yml|yaml)"'
}

_lorikeet "$@"
