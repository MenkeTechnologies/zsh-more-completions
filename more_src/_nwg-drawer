#compdef nwg-drawer

# Zsh completion for nwg-drawer - application launcher for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --command)'{-c,--command}'[command to execute on entry]:command' \
  '(-fm --fm)'{-fm,--fm}'[file manager command]:command' \
  '(-term --term)'{-term,--term}'[terminal emulator command]:command' \
  '(-is --icon-size)'{-is,--icon-size}'[icon size]:pixels' \
  '(-lang --lang)'{-lang,--lang}'[force language]:language' \
  '(-nofs --nofs)'{-nofs,--nofs}'[do not show file search]' \
  '(-nocats --nocats)'{-nocats,--nocats}'[do not show categories]' \
  '(-o --output)'{-o,--output}'[show on output]:output' \
  '(-ovl --overlay)'{-ovl,--overlay}'[use GTK Layer Shell overlay]' \
  '(-pbexit --pbexit)'{-pbexit,--pbexit}'[use power bar for exit]' \
  '(-pbpoweroff --pbpoweroff)'{-pbpoweroff,--pbpoweroff}'[power bar poweroff command]:command' \
  '(-pbreboot --pbreboot)'{-pbreboot,--pbreboot}'[power bar reboot command]:command' \
  '(-r --resident)'{-r,--resident}'[remain resident in memory]' \
  '(-s --style)'{-s,--style}'[CSS style file]:file:_files -g "*.css"' \
  '(-spacing --spacing)'{-spacing,--spacing}'[grid spacing]:pixels'
