#compdef cuttlebelle
# _cuttlebelle — React-based static site generator (cuttlebelle/cuttlebelle)
# upstream: https://github.com/cuttlebelle/cuttlebelle
# Flags from src/cli.js.

_cuttlebelle() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-i --init)'{-i,--init}'[create a clean-slate website]' \
        '(-d --docs)'{-d,--docs}'[build documentation from layout components]' \
        '(-w --watch)'{-w,--watch}'[watch content and source folders for changes]' \
        '(-n --no-generate)'{-n,--no-generate}'[disable initial generation (use with watch)]' \
        '(-s --silent)'{-s,--silent}'[disable watch notifications]' \
        '--verbose[enable silly verbose mode]' \
        '1: :->cmd'

    case $state in
        cmd)
            _values 'command' \
                'init[create clean-slate website]' \
                'docs[build docs from layouts]' \
                'watch[watch and rebuild on changes]'
            ;;
    esac
}

_cuttlebelle "$@"
