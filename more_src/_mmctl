#compdef mmctl

# Zsh completion for mmctl - Mattermost CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--config-path=[config file path]:config file:_files' \
  '--disable-pager[disable pager output]' \
  '--format=[output format]:format:(json plain)' \
  '--insecure-sha1-intermediate[allow SHA-1 intermediate certificates]' \
  '--insecure-tls-version[allow older TLS versions]' \
  '--local[use local socket connection]' \
  '--strict[enable strict mode]' \
  '--suppress-warnings[suppress warnings]' \
  '--access-token=[access token]:token' \
  '--mfa-token=[MFA token]:token' \
  '--password=[password]:password' \
  '--username=[username]:username' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:Manage authentication'
      'channel:Manage channels'
      'command:Manage slash commands'
      'completion:Generate shell completions'
      'config:Manage configuration'
      'export:Manage exports'
      'group:Manage groups'
      'import:Manage imports'
      'ldap:LDAP operations'
      'license:Manage license'
      'logs:View server logs'
      'permissions:Manage permissions'
      'plugin:Manage plugins'
      'post:Manage posts'
      'roles:Manage roles'
      'saml:SAML operations'
      'system:System operations'
      'team:Manage teams'
      'token:Manage tokens'
      'user:Manage users'
      'webhook:Manage webhooks'
      'workspace:Manage workspace'
    )
    _describe -t commands 'mmctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      auth)
        local -a subcmds=(
          'login:Login to a server'
          'current:Show current authentication'
          'list:List saved authentications'
          'delete:Delete an authentication'
          'renew:Renew authentication token'
          'clean:Clean all saved credentials'
          'set:Set current authentication'
        )
        _describe -t subcmds 'auth subcommand' subcmds && ret=0
        ;;
      channel)
        local -a subcmds=(
          'archive:Archive a channel'
          'create:Create a channel'
          'delete:Delete a channel'
          'list:List channels'
          'make-private:Convert channel to private'
          'modify:Modify a channel'
          'move:Move a channel'
          'rename:Rename a channel'
          'restore:Restore a channel'
          'search:Search channels'
          'unarchive:Unarchive a channel'
          'users:Manage channel users'
        )
        _describe -t subcmds 'channel subcommand' subcmds && ret=0
        ;;
      command)
        local -a subcmds=(
          'archive:Archive a command'
          'create:Create a command'
          'delete:Delete a command'
          'list:List commands'
          'modify:Modify a command'
          'move:Move a command'
          'show:Show a command'
        )
        _describe -t subcmds 'command subcommand' subcmds && ret=0
        ;;
      completion)
        local -a subcmds=(
          'bash:Generate bash completions'
          'zsh:Generate zsh completions'
          'fish:Generate fish completions'
          'powershell:Generate PowerShell completions'
        )
        _describe -t subcmds 'completion subcommand' subcmds && ret=0
        ;;
      config)
        local -a subcmds=(
          'edit:Edit configuration'
          'get:Get a configuration value'
          'migrate:Migrate configuration'
          'patch:Patch configuration'
          'reload:Reload configuration'
          'reset:Reset configuration'
          'set:Set a configuration value'
          'show:Show configuration'
          'subpath:Update subpath'
        )
        _describe -t subcmds 'config subcommand' subcmds && ret=0
        ;;
      export)
        local -a subcmds=(
          'create:Create an export'
          'delete:Delete an export'
          'download:Download an export'
          'job:Manage export jobs'
          'list:List exports'
          'show:Show export details'
        )
        _describe -t subcmds 'export subcommand' subcmds && ret=0
        ;;
      import)
        local -a subcmds=(
          'job:Manage import jobs'
          'list:List imports'
          'process:Process an import'
          'upload:Upload an import file'
          'validate:Validate an import file'
        )
        _describe -t subcmds 'import subcommand' subcmds && ret=0
        ;;
      ldap)
        local -a subcmds=(
          'idmigrate:Migrate LDAP user IDs'
          'sync:Sync LDAP'
        )
        _describe -t subcmds 'ldap subcommand' subcmds && ret=0
        ;;
      license)
        local -a subcmds=(
          'remove:Remove the license'
          'upload:Upload a license file'
          'upload-string:Upload license from string'
        )
        _describe -t subcmds 'license subcommand' subcmds && ret=0
        ;;
      permissions)
        local -a subcmds=(
          'add:Add permissions'
          'remove:Remove permissions'
          'reset:Reset permissions'
          'role:Manage roles'
          'show:Show permissions'
        )
        _describe -t subcmds 'permissions subcommand' subcmds && ret=0
        ;;
      plugin)
        local -a subcmds=(
          'add:Add a plugin'
          'delete:Delete a plugin'
          'disable:Disable a plugin'
          'enable:Enable a plugin'
          'install-url:Install plugin from URL'
          'list:List plugins'
          'marketplace:Manage marketplace plugins'
        )
        _describe -t subcmds 'plugin subcommand' subcmds && ret=0
        ;;
      post)
        local -a subcmds=(
          'create:Create a post'
          'list:List posts'
        )
        _describe -t subcmds 'post subcommand' subcmds && ret=0
        ;;
      roles)
        local -a subcmds=(
          'member:Set user as member'
          'system-admin:Set user as system admin'
        )
        _describe -t subcmds 'roles subcommand' subcmds && ret=0
        ;;
      saml)
        local -a subcmds=(
          'auth-data-reset:Reset SAML auth data'
        )
        _describe -t subcmds 'saml subcommand' subcmds && ret=0
        ;;
      system)
        local -a subcmds=(
          'clearbusy:Clear server busy flag'
          'getbusy:Get server busy status'
          'setbusy:Set server busy flag'
          'status:Show system status'
          'version:Show server version'
        )
        _describe -t subcmds 'system subcommand' subcmds && ret=0
        ;;
      team)
        local -a subcmds=(
          'archive:Archive a team'
          'create:Create a team'
          'delete:Delete a team'
          'list:List teams'
          'list-users:List team users'
          'modify:Modify a team'
          'rename:Rename a team'
          'restore:Restore a team'
          'search:Search teams'
          'users:Manage team users'
        )
        _describe -t subcmds 'team subcommand' subcmds && ret=0
        ;;
      token)
        local -a subcmds=(
          'generate:Generate a token'
          'list:List tokens'
          'revoke:Revoke a token'
        )
        _describe -t subcmds 'token subcommand' subcmds && ret=0
        ;;
      user)
        local -a subcmds=(
          'activate:Activate a user'
          'convert:Convert a user'
          'create:Create a user'
          'deactivate:Deactivate a user'
          'delete:Delete a user'
          'demote:Demote a user'
          'email:Manage user email'
          'invite:Invite a user'
          'list:List users'
          'migrate-auth:Migrate user authentication'
          'promote:Promote a user'
          'reset-password:Reset user password'
          'resetmfa:Reset user MFA'
          'search:Search users'
          'verify:Verify a user email'
        )
        _describe -t subcmds 'user subcommand' subcmds && ret=0
        ;;
      webhook)
        local -a subcmds=(
          'create-incoming:Create incoming webhook'
          'create-outgoing:Create outgoing webhook'
          'delete:Delete a webhook'
          'list:List webhooks'
          'modify-incoming:Modify incoming webhook'
          'modify-outgoing:Modify outgoing webhook'
          'show:Show webhook details'
        )
        _describe -t subcmds 'webhook subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
