#compdef obs

local -a arguments

arguments=(
    '--help[Show help]'
    '--version[Show version]'
    '--startstreaming[Start streaming on launch]'
    '--startrecording[Start recording on launch]'
    '--startvirtualcam[Start virtual camera on launch]'
    '--startreplaybuffer[Start replay buffer on launch]'
    '--collection[Set scene collection]:collection'
    '--profile[Set profile]:profile'
    '--scene[Set starting scene]:scene'
    '--studio-mode[Enable studio mode]'
    '--minimize-to-tray[Minimize to system tray]'
    '--portable[Use portable mode]'
    '--multi[Allow multiple instances]'
    '--always-on-top[Always on top]'
    '--verbose[Verbose logging]'
    '--unfiltered_log[Unfiltered log output]'
    '--disable-updater[Disable built-in updater]'
    '--allow-opengl[Allow OpenGL renderer on Windows]'
    '--disable-shutdown-check[Disable unclean shutdown check]'
    '--safe-mode[Start in safe mode]'
    '--only-bundled-plugins[Only load bundled plugins]'
    '--disable-missing-files-check[Disable missing files check]'
)

_arguments -s -S $arguments
