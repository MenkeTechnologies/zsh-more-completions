#compdef agda-mode
# Documentation: https://agda.readthedocs.io/en/latest/tools/emacs-mode.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'setup:setup agda-mode'
  'compile:compile agda-mode'
  'locate:print location'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'agda-mode command' commands && ret=0 ;;
esac

return ret
