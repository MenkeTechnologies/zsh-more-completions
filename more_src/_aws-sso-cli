#compdef aws-sso-cli
# Documentation: https://github.com/synfinatic/aws-sso-cli
# Documentation: https://github.com/synfinatic/aws-sso-cli/blob/main/cmd/aws-sso/main.go
# Reference accessed: 2026-05-27
# Verified: upstream cmd/aws-sso/main.go CLI struct (Kong-tagged commands)
# aws-sso-cli is the package name; the binary is "aws-sso" — completion mirrors it

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cache:force reload of cached AWS SSO role info and config.yaml'
  'console:open AWS Console using specified AWS role/profile'
  'credentials:generate static AWS credentials for use with AWS CLI'
  'ecs:ECS server/client commands'
  'eval:print AWS environment vars for use with eval'
  'exec:execute command using specified IAM role in a new shell'
  'list:list all accounts / roles (default command)'
  'login:login to an AWS Identity Center instance'
  'logout:logout and invalidate all credentials'
  'process:generate JSON for AWS SDK credential_process command'
  'setup:setup wizard, completions, profiles, etc'
  'tags:list tags'
  'time:print how much time before current STS token expires'
  'version:print version and exit'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --browser)'{-b+,--browser=}'[path to browser to open URLs with]:browser:' \
  '--config=[config file]:file:_files -g "*.yaml"' \
  '(-L --level)'{-L+,--level=}'[logging level]:level:(error warn info debug trace)' \
  '--lines[print line number in logs]' \
  '(-S --sso)'{-S+,--sso=}'[override default AWS SSO instance]:sso:' \
  '1: :->subcommand' \
  '*::: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'aws-sso subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (ecs)
        local -a _ecs_sub
        _ecs_sub=(
          'server:run the ECS server locally'
          'docker:start the ECS server in a Docker container'
          'list:list profiles loaded in the ECS server'
          'unload:unload current IAM role credentials from the ECS server'
          'profile:get current role profile name in default slot'
          'load:load new IAM role credentials into the ECS server'
        )
        _arguments -s -S \
          '1: :->ecssub' \
          '*::: :->ecsargs' && ret=0
        case $state in
          (ecssub) _describe -t ecssub 'ecs subcommand' _ecs_sub && ret=0 ;;
        esac
        ;;
      (setup)
        local -a _setup_sub
        _setup_sub=(
          'completions:manage shell completions'
          'wizard:run the configuration wizard'
          'profiles:update ~/.aws/config with AWS SSO profiles'
          'ecs:manage ECS server secrets'
        )
        _arguments -s -S \
          '1: :->setupsub' \
          '*::: :->setupargs' && ret=0
        case $state in
          (setupsub) _describe -t setupsub 'setup subcommand' _setup_sub && ret=0 ;;
          (setupargs)
            case ${line[1]} in
              (ecs)
                local -a _setup_ecs_sub
                _setup_ecs_sub=(
                  'auth:configure HTTP authentication for the ECS server'
                  'ssl:load SSL cert/key for the ECS server'
                )
                _arguments -s -S \
                  '1: :->seecssub' \
                  '*::: :->seecsargs' && ret=0
                case $state in
                  (seecssub) _describe -t seecssub 'setup ecs subcommand' _setup_ecs_sub && ret=0 ;;
                  (seecsargs)
                    _arguments -s -S \
                      '(-t --bearer-token)'{-t+,--bearer-token=}'[bearer token value]:token:' \
                      '(-d --delete)'{-d,--delete}'[delete current value]' \
                      '(-p --print)'{-p,--print}'[print current SSL certificate]' \
                      '(-c --certificate)'{-c+,--certificate=}'[path to certificate chain PEM file]:file:_files' \
                      '(-k --private-key)'{-k+,--private-key=}'[path to private key PEM file]:file:_files' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      (login|logout|list|tags|time|version|cache|console|credentials|eval|exec|process)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
