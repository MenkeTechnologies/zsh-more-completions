#compdef ng

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:create a new Angular workspace'
      'serve:build and serve the application'
      'build:build the application'
      'test:run unit tests'
      'lint:run linting tools'
      'e2e:run end-to-end tests'
      'generate:generate Angular components and more'
      'add:add a library to the project'
      'update:update the application and dependencies'
      'deploy:deploy the application'
      'analytics:configure Angular CLI analytics'
      'config:get or set configuration values'
      'doc:open Angular documentation'
      'extract-i18n:extract i18n messages'
      'completion:set up Angular CLI autocompletion'
      'cache:configure persistent disk cache'
      'run:run an Architect target'
      'version:output Angular CLI version'
    )
    _describe -t commands 'ng command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--collection=[schematics collection]:collection' \
          '--commit[initial git repository commit]' \
          '--create-application[create an application in the new workspace]' \
          '--directory=[directory name]:directory' \
          '--dry-run[run through without making changes]' \
          '--force[force overwriting of existing files]' \
          '--inline-style[use inline styles]' \
          '--inline-template[use inline templates]' \
          '--interactive[enable interactive prompts]' \
          '--minimal[create a minimal workspace]' \
          '--new-project-root=[root of new projects]:root' \
          '--package-manager=[package manager to use]:pm:(npm yarn pnpm cnpm)' \
          '--prefix=[prefix for generated selectors]:prefix' \
          '--routing[generate a routing module]' \
          '--skip-git[do not initialize a git repository]' \
          '--skip-install[do not install dependency packages]' \
          '--skip-tests[do not generate test files]' \
          '--standalone[generate a standalone application]' \
          '--strict[create a stricter workspace]' \
          '--style=[style file extension]:style:(css scss sass less)' \
          '--ssr[create a server-side rendered application]' \
          '1:project name' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '--host=[host to listen on]:host' \
          '--hmr[enable hot module replacement]' \
          '--live-reload[enable live reload]' \
          '(-o --open)'{-o,--open}'[open the URL in the default browser]' \
          '--poll=[enable file watching poll time period]:period' \
          '--port=[port to listen on]:port' \
          '--proxy-config=[proxy configuration file]:file:_files' \
          '--ssl[serve using HTTPS]' \
          '--ssl-cert=[SSL certificate file]:file:_files' \
          '--ssl-key=[SSL key file]:file:_files' \
          '--verbose[add more details to output logging]' \
          '--watch[rebuild on change]' \
          '1:project' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--aot[build using Ahead of Time compilation]' \
          '--base-href=[base URL for the application]:url' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '--delete-output-path[delete the output path before building]' \
          '--extract-licenses[extract all licenses in a separate file]' \
          '--named-chunks[use file name for lazy loaded chunks]' \
          '--optimization[enable build optimization]' \
          '--output-hashing=[define output filename hashing]:mode:(none all media bundles)' \
          '--output-path=[path to output directory]:directory:_directories' \
          '--poll=[enable file watching poll time period]:period' \
          '--progress[log progress to the console]' \
          '--source-map[output source maps]' \
          '--stats-json[generate a stats.json file]' \
          '--verbose[add more details to output logging]' \
          '--watch[run build when files change]' \
          '1:project' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--browsers=[override which browsers tests run against]:browsers' \
          '--code-coverage[output code coverage]' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '--include=[glob pattern of test files]:pattern' \
          '--karma-config=[path to Karma configuration]:file:_files' \
          '--main=[path to main entry point]:file:_files' \
          '--poll=[enable file watching poll time period]:period' \
          '--progress[log progress to the console]' \
          '--source-map[output source maps]' \
          '--watch[run build when files change]' \
          '1:project' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--defaults[disable interactive prompts with defaults]' \
          '--dry-run[run through without making changes]' \
          '--force[force overwriting of existing files]' \
          '--interactive[enable interactive prompts]' \
          '1:schematic:(component directive pipe service guard interceptor module class interface enum resolver)' \
          '2:name' && ret=0
        ;;
      add)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--defaults[disable interactive prompts with defaults]' \
          '--dry-run[run through without making changes]' \
          '--force[force overwriting of existing files]' \
          '--interactive[enable interactive prompts]' \
          '--registry=[npm registry to use]:registry' \
          '--skip-confirmation[skip asking a confirmation prompt]' \
          '--verbose[display additional details during operation]' \
          '1:package' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[update all packages]' \
          '--allow-dirty[allow updating when repo contains modified or untracked files]' \
          '--create-commits[create source control commits]' \
          '--force[ignore version compatibility and peer dependencies]' \
          '--from=[version from which to migrate]:version' \
          '--migrate-only[only perform migration]' \
          '--next[use the prerelease version]' \
          '--packages=[comma-separated list of package names]:packages' \
          '--to=[version up to which to apply migrations]:version' \
          '--verbose[display additional details during operation]' \
          '*:package' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '--fix[fix linting errors]' \
          '--force[succeed even if lint errors found]' \
          '--format=[output format]:format:(prose json stylish verbose)' \
          '1:project' && ret=0
        ;;
      e2e)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '1:project' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-g --global)'{-g,--global}'[access the global configuration]' \
          '1:json path' \
          '2:value' && ret=0
        ;;
      doc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-s --search)'{-s,--search}'[search all angular.io]' \
          '--version=[Angular version]:version' \
          '1:keyword' && ret=0
        ;;
      analytics)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(enable disable info prompt)' && ret=0
        ;;
      extract-i18n)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '--format=[output format]:format:(xlf xlf2 xmb json arb)' \
          '--out-file=[name of output file]:file' \
          '--output-path=[path to output directory]:directory:_directories' \
          '--progress[log progress to the console]' \
          '1:project' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-c --configuration)'{-c,--configuration}'=[build configuration]:configuration' \
          '1:project' && ret=0
        ;;
      cache)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(enable disable clean info)' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:target' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
