#compdef nvidia-mig-parted
# _nvidia-mig-parted — NVIDIA MIG-partition CLI (apply / assert / export / generate-config / checkpoint / restore)
# upstream: https://github.com/NVIDIA/mig-parted
# Subcommands + top-level flags from cmd/nvidia-mig-parted/main.go on tip (urfave/cli/v3).

_nvidia-mig-parted() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-d --debug)'{-d,--debug}'[enable debug-level logging]' \
        '1: :->cmd'
    case $state in
        cmd)
            local -a subs=(
                apply:'apply a MIG configuration to selected GPUs'
                assert:'assert the current MIG configuration matches the desired one'
                export:'export the current MIG configuration of selected GPUs'
                generate-config:'generate a sample mig-parted config'
                checkpoint:'snapshot the current MIG configuration to a file'
                restore:'restore a MIG configuration from a checkpoint file'
            )
            _describe -t commands 'nvidia-mig-parted subcommand' subs
            ;;
    esac
}

_nvidia-mig-parted "$@"
