#compdef evalresp
# IRIS/SAGE: evaluate instrument response from RESP files

local ret=1

_arguments -s -S \
  '-f+[directory or filename containing RESP files]:file:_files' \
  '-u+[output units]:units:(dis vel acc def)' \
  '-t+[time of day HH:MM:SS for selecting responses]:time' \
  '-s+[frequency spacing]:spacing:(log lin)' \
  '-r+[response output type]:type:(ap cs fap)' \
  '-n+[filter by network ID (wildcards allowed)]:netid' \
  '-l+[filter by location ID (wildcards allowed)]:locid' \
  '-stage+[evaluate specific stage(s) by number or range]:stage' \
  '-stdio[read from stdin and write to stdout]' \
  '-use-estimated-delay[use estimated delay for ASYM FIR responses]' \
  '-il[interpolate List blockette output to requested frequencies]' \
  '-ii[interpolate List blockette input to requested frequencies]' \
  '-it+[tension value for cubic-spline interpolation]:tension' \
  '-unwrap[unwrap phase output in amplitude-phase mode]' \
  '-ts[use stage 0 total sensitivity instead of computed stage gains]' \
  '-v[verbose diagnostic output]' \
  '*:arg:' && ret=0

return ret
