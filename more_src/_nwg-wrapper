#compdef nwg-wrapper
# Documentation: https://man.archlinux.org/search?q=nwg-wrapper
# Reference accessed: 2026-05-16

# Zsh completion for nwg-wrapper (GTK3-based wrapper for scripts on Wayland)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-s --script)'{-s,--script=}'[script to execute]:script:_files' \
  '(-t --text)'{-t,--text=}'[path to text file]:text file:_files' \
  '(-c --css)'{-c,--css=}'[CSS style file]:css file:_files' \
  '(-r --refresh)'{-r,--refresh=}'[refresh interval in milliseconds]:interval:' \
  '(-p --position)'{-p,--position=}'[position on screen]:position:(left right center)' \
  '(-a --alignment)'{-a,--alignment=}'[text alignment]:alignment:(left right center)' \
  '(-j --justify)'{-j,--justify=}'[text justification]:justify:(left right center fill)' \
  '--layer=[layer to display on]:layer:(background bottom top overlay)' \
  '--margin=[margins (top right bottom left)]:margins:' \
  '--padding=[padding]:padding:' \
  '--exclusive-zone=[exclusive zone size]:size:' \
  '--sq=[square size for anchor calculation]:size:' \
  '(-o --output)'{-o,--output=}'[output/monitor name]:output:' && ret=0

return ret
