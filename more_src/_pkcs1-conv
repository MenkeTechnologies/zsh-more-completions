#compdef pkcs1-conv
# Documentation: https://www.lysator.liu.se/~nisse/nettle/nettle.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pkcs1-conv ships with GNU Nettle; minimal CLI. STUB.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--help[show help]' \
  {-V,--version}'[show version]' \
  '--public-key[the input is a public key]' \
  '--private-key[the input is a private key]' \
  '*:input file:_files -g "*.(pem|key|crt)"' && ret=0

return ret
