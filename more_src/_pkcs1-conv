#compdef pkcs1-conv
# Documentation: https://man.archlinux.org/search?q=pkcs1-conv
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--help[show help]' \
  {-V,--version}'[show version]' \
  '--public-key[the input is a public key]' \
  '--private-key[the input is a private key]' \
  '*:input file:_files -g "*.(pem|key|crt)"' && ret=0

return ret
