#compdef pkcs1-conv

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--help[show help]' \
  {-V,--version}'[show version]' \
  '--public-key[the input is a public key]' \
  '--private-key[the input is a private key]' \
  '*:input file:_files -g "*.(pem|key|crt)"' && ret=0

return ret
