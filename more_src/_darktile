#compdef darktile
# Documentation: https://man.archlinux.org/search?q=darktile
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--help-keys[show key bindings]' \
  '--config=[config file]:file:_files -g "*.yml *.yaml *.toml"' \
  '--theme=[theme name]:theme:' \
  '*: :_command_names' && ret=0

return ret
