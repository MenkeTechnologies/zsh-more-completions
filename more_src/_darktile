#compdef darktile
# Documentation: https://github.com/liamg/darktile
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--help-keys[show key bindings]' \
  '--config=[config file]:file:_files -g "*.yml *.yaml *.toml"' \
  '--theme=[theme name]:theme:' \
  '--rewrite-config[generate example configuration]' \
  '1: :(list-fonts)' \
  '*: :_command_names' && ret=0

return ret
