#compdef wyc
# =============================================================================
# wyc — the Whiley Compiler.  Whiley is a programming language specifically
#        designed to support EXTENDED STATIC CHECKING — programs can specify
#        invariants, pre/post-conditions, and loop invariants that the
#        compiler statically verifies against the source code using an
#        embedded SMT solver.  Whiley occupies a middle ground between
#        imperative languages (Java, C) and proof assistants (Coq, Agda,
#        Idris2): programs look like ordinary imperative code but carry
#        verified specifications.
#
# Author:  David J. Pearce (Victoria University of Wellington, NZ)
# Source:  https://github.com/Whiley/WhileyCompiler
# CLI:     src/main/java/wyc/Compiler.java + src/main/java/wycc/util/OptArg.java
# Library: wycc.util.OptArg
#          (in-house Java CLI parser bundled with the Whiley framework)
# License: Apache-2.0
# Status:  Active research project — 228+ stars, used in academic teaching
#          at Victoria University of Wellington and several other CompSci
#          departments worldwide; cited in 100+ research papers on
#          static verification methodology.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — WHILEY IS NOW LANGUAGE 50
# -----------------------------------------------------------------------------
# *** ROUND-NUMBER MILESTONE: 50 LANGUAGES IN THE TAXONOMY ***
#
# With this completion the cross-language CLI library taxonomy crosses from
# 49 to 50 documented languages.  Whiley joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, Beluga, REBOL, Io, Pure, Yeti, and now Whiley.  wyc is documented
# as the FIRST Whiley CLI library variant in the taxonomy (in-house Java
# wycc.util.OptArg parser with typed Kind constants, parseOptions static
# helper, and Map<String,Object> result) — bringing the total to 208
# cross-language CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS WHILEY AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# Whiley is a strongly-typed imperative programming language with FIRST-CLASS
# SUPPORT FOR EXTENDED STATIC CHECKING.  Programs in Whiley look like Java
# or C# at first glance, but every function carries `requires` (pre-condition)
# and `ensures` (post-condition) clauses, and the compiler PROVES at
# compile-time that the function body satisfies the post-condition assuming
# the pre-condition, using an embedded SMT solver (Z3 or CVC4).
#
# Example Whiley function:
#
#     function abs(int x) -> (int r)
#     ensures r >= 0
#     ensures r == x || r == -x:
#         if x >= 0:
#             return x
#         else:
#             return -x
#
# The compiler verifies that BOTH `r >= 0` AND `r == x || r == -x` hold for
# every execution path through `abs`.  If a path can be constructed where
# either fails, the compiler reports it as a static error.
#
# Whiley is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented language whose CORE FEATURE is EXTENDED
#     STATIC CHECKING (ESC) of imperative code.  Coq/Agda/Idris2 (R452)
#     are dependent-type-theory PROOF ASSISTANTS — programs are proofs,
#     and proofs require explicit term construction.  Whiley is an
#     IMPERATIVE LANGUAGE with annotations: write ordinary Java-like code
#     plus `requires`/`ensures` clauses, and the compiler discharges the
#     proof obligations automatically via SMT.  This is closer to Dafny,
#     Spec#, ESC/Java than to Coq/Agda.
#   * It uses INTERVAL/STRUCTURAL TYPES — `int` is a true unbounded
#     integer; constraints like `int x where x >= 0` are FIRST-CLASS TYPES,
#     not annotations.  The type system models intervals (`int:8`,
#     `int:16`, `nat`), arrays with statically-known size (`int[5]`), and
#     RECURSIVE STRUCTURAL TYPES (`type LinkedList is null | { LinkedList
#     next, int data }`).
#   * It targets the JVM via WyIL — Whiley Intermediate Language — a
#     verified-bytecode IR that retains type and constraint information
#     for backend re-verification (different JVM-targeting languages can
#     interoperate via WyIL).
#   * It supports COUNTEREXAMPLE GENERATION — when verification fails,
#     the SMT solver produces a CONCRETE INPUT that violates the
#     specification, which the Whiley compiler emits as a test case.
#     This is unique among compilers documented in the corpus.
#   * It uses INDENTATION-BASED SYNTAX (Python-style) for code blocks,
#     which is unusual for a JVM-targeting language with verification
#     semantics.
#
# -----------------------------------------------------------------------------
# WHILEY'S CLI LIBRARY — wycc.util.OptArg
# -----------------------------------------------------------------------------
#
# Whiley's CLI parser is `wycc.util.OptArg`, an in-house Java class shipped
# with the Whiley compiler framework.  It is the FIRST documented "in-house
# Java CLI parser with typed Kind constants and parseOptions static helper"
# pattern in the corpus's cross-language taxonomy.
#
# The OptArg API (verbatim from wycc.util.OptArg):
#
#     public final class OptArg {
#         public final String option;          // long form (e.g., "verbose")
#         public final String shortForm;       // short form (e.g., "v"), nullable
#         public final Kind argument;          // STRING, FILEDIR, FILELIST, INT
#         public final String description;     // usage text
#         public final Object defaultValue;    // null when no default
#
#         // No-argument boolean flag with no short form
#         public OptArg(String option, String description)
#
#         // No-argument boolean flag with short form (most common)
#         public OptArg(String option, String shortForm, String description)
#
#         // Value-taking flag without short form
#         public OptArg(String option, Kind argument, String description,
#                       Object defaultValue)
#
#         // Value-taking flag with short form
#         public OptArg(String option, String shortForm, Kind argument,
#                       String description, Object defaultValue)
#
#         // Top-level parsing API
#         public static Map<String,Object> parseOptions(List<String> args,
#                                                       OptArg[] options)
#     }
#
# OptArg.Kind enumeration:
#   * STRING    — plain string value
#   * INT       — integer (parsed via Integer.parseInt)
#   * FILEDIR   — single File representing a directory
#   * FILELIST  — colon-separated list of File objects
#   * (extensible by subclassing Kind)
#
# The Whiley compiler's option table (verbatim from wyc/Compiler.java):
#
#     private static final OptArg[] OPTIONS = {
#         new OptArg("verbose", "v",
#                    "set verbose output"),
#         new OptArg("strict", "s",
#                    "set strict mode"),
#         new OptArg("linking", "l",
#                    "set linking mode"),
#         new OptArg("output", "o", OptArg.STRING,
#                    "set output file", "main"),
#         new OptArg("whileydir", OptArg.FILEDIR,
#                    "Specify where to find Whiley source files",
#                    new File(".")),
#         new OptArg("wyildir", OptArg.FILEDIR,
#                    "Specify where to place binary (WyIL) files",
#                    new File(".")),
#         new OptArg("whileypath", OptArg.FILELIST,
#                    "Specify additional dependencies",
#                    new ArrayList<>())
#     };
#
# Distinctive properties of OptArg:
#
#   1. CONSTRUCTOR OVERLOADING REPLACES BUILDER PATTERN — different
#      constructor signatures for different option kinds (no-arg with
#      short, no-arg without short, value with short, value without
#      short).  Adding a kind means adding a constructor.  This is
#      pre-fluent-builder Java idiomatic — used by older Java APIs
#      before fluent builders became standard around 2009.
#   2. PUBLIC FINAL FIELDS — option metadata is exposed as public final
#      fields rather than via getters.  This was idiomatic in Java code
#      until the early 2000s; modern Java uses records or Lombok @Data
#      classes.
#   3. STATIC parseOptions ENTRY POINT — `OptArg.parseOptions(args, OPTIONS)`
#      is a static utility method returning `Map<String,Object>`.  No
#      parser object, no fluent chain, no separate Result type.
#   4. Map<String,Object> RESULT — flag values are stored in a heterogeneous
#      map keyed by long-form option name.  Type recovery requires
#      `(String) options.get("output")` casts at every use site.  Modern
#      type-safe Java CLI libraries (Picocli, JCommander) avoid this.
#   5. SHORT FORMS ARE OPTIONAL STRINGS, NOT CHARS — `shortForm = "v"`
#      (String) not `'v'` (char), which is unusual.  This allows multi-
#      character short forms but Whiley doesn't actually use any.
#   6. Kind IS AN ENUM-LIKE ABSTRACT CLASS — `OptArg.STRING`, `OptArg.INT`,
#      `OptArg.FILEDIR`, `OptArg.FILELIST` are static instances of a Kind
#      abstract class that knows how to parse a string into its target
#      type.  Adding a new value type requires subclassing Kind.
#   7. NO HELP-FLAG AUTO-GENERATION — Whiley's Compiler.java doesn't
#      explicitly register --help; usage is shown only when invalid
#      arguments are passed.
#   8. SINGLE-DASH LONG FLAGS — invocations use `-verbose`, `-output`,
#      `-whileydir`, etc., matching the JAVA/JDK convention (R468 Yeti
#      and other JVM-targeting compilers).  Whiley shares this convention
#      with Yeti, Scala 2 (scalac), Kotlin (kotlinc), and javac.
#
# CONTRAST WITH OTHER JAVA CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * Apache Commons CLI            — option-builder DSL (verbose Java 6)
#   * JOptSimple                     — fluent DSL with type tokens
#   * JCommander                     — annotation-driven (Java reflection)
#   * Picocli                        — annotation-driven (more popular)
#   * args4j                         — annotation-driven
#   * jewelcli                       — interface-based annotation
#   * naturalcli                     — natural-language parser
#   * cli-parser                     — older, less used
#   * Whiley's wycc.util.OptArg      — in-house, constructor-overloaded
#                                      Java-6-era utility
#
# OptArg is closest in spirit to early Apache Commons CLI (pre-fluent-API
# Options class) and to the OPTIONS arrays found in JDK internal classes
# like sun.tools.javac.Main.  It is distinctive in that it ships as part
# of a LANGUAGE COMPILER FRAMEWORK rather than as a standalone library —
# Whiley uses it for wyc, wycli, wyrun, and other Whiley-related binaries.
# The same OptArg class is duplicated in Whiley's sister projects Jasm
# and WhileyWeb (separate copies, not a shared dependency).
#
# -----------------------------------------------------------------------------
# WHILEY'S CLI SURFACE (verbatim from src/main/java/wyc/Compiler.java OPTIONS)
# -----------------------------------------------------------------------------
#
# USAGE:
#   wyc [options] <file.whiley> [<file.whiley> ...]
#
# Boolean flags (each has long and short form):
#   --verbose,   -v          Set verbose output
#   --strict,    -s          Set strict mode (stricter type checks)
#   --linking,   -l          Set linking mode (link in WyIL deps)
#
# Value-taking flags with defaults:
#   --output,    -o <name>   Output file name (default: "main")
#   --whileydir       <dir>  Where to find Whiley source files (default: .)
#   --wyildir         <dir>  Where to place binary WyIL files (default: .)
#   --whileypath      <list> Additional dependencies (colon-separated .zip
#                            files containing .wyil class files)
#
# Positional:
#   <file.whiley>...         Whiley source files to compile (the .whiley
#                            extension is stripped before being passed to
#                            the Trie path constructor)
#
# Exit codes:
#   0 — compilation succeeded and produced a valid binary
#   1 — compilation failed (syntax errors, type errors, or verification
#       counter-examples found)
#
# =============================================================================

_wyc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '(--verbose -v)'{--verbose,-v}'[set verbose output]' \
        '(--strict -s)'{--strict,-s}'[set strict mode (stricter type checks)]' \
        '(--linking -l)'{--linking,-l}'[set linking mode (link in WyIL deps)]' \
        '(--output -o)'{--output,-o}'[output file name]:name:' \
        '--whileydir[where to find Whiley source files]:dir:_directories' \
        '--wyildir[where to place binary WyIL files]:dir:_directories' \
        '--whileypath[additional dependencies (: separated)]:path:_files -g "*.zip"' \
        '*:Whiley source:_files -g "*.whiley"' \
        && ret=0

    return ret
}

_wyc "$@"
