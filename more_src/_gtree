#compdef gtree

# Zsh completion for gtree (generate directory trees from Markdown)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'output:output a tree from Markdown'
      'mkdir:create directories from Markdown tree'
      'verify:verify directory tree matches Markdown'
      'template:generate template Markdown'
      'web:start web server'
      'version:show version'
    )
    _describe -t commands 'gtree command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (output)
        _arguments \
          '(-f --file)'{-f,--file}'[input Markdown file]:file:_files -g "*.md"' \
          '--massive[enable massive output]' \
          '--json[output as JSON]' \
          '--yaml[output as YAML]' \
          '--toml[output as TOML]' && ret=0
        ;;
      (mkdir)
        _arguments \
          '(-f --file)'{-f,--file}'[input Markdown file]:file:_files -g "*.md"' \
          '(-e --extension)'{-e,--extension}'[add file extension handling]' \
          '--dry-run[preview without creating]' && ret=0
        ;;
      (verify)
        _arguments \
          '(-f --file)'{-f,--file}'[input Markdown file]:file:_files -g "*.md"' \
          '--strict[strict verification]' && ret=0
        ;;
      (template)
        _arguments \
          '(-d --dir)'{-d,--dir}'[target directory]:directory:_files -/' && ret=0
        ;;
      (web)
        _arguments \
          '(-p --port)'{-p,--port}'[port number]:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
