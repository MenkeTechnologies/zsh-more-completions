#compdef vlt

_vlt_cmds() {
    local -a commands=(
        'login:authenticate to HCP Vault Secrets'
        'config:manage CLI configuration'
        'secrets:manage secrets'
        'apps:manage Vault Secrets apps'
        'run:inject secrets into a process'
        'status:show authentication status'
        'version:print version'
        'help:print help information'
    )
    _describe -t commands 'vlt command' commands
}

_vlt() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '--project-id=[HCP project ID]:project-id' \
        '--organization-id=[HCP organization ID]:org-id' \
        '--app-name=[Vault Secrets app name]:app-name' \
        '(-p --profile)'{-p,--profile}'=[CLI profile]:profile' \
        '--format=[output format]:format:(table json pretty-json)' \
        '1:command:_vlt_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                login)
                    _arguments \
                        '--client-id=[service principal client ID]:id' \
                        '--client-secret=[service principal client secret]:secret'
                    ;;
                secrets)
                    _arguments \
                        '1:action:(create read update delete list rotate)' \
                        '--secret-name=[secret name]:name' \
                        '--secret-value=[secret value]:value' \
                        '--secret-value-file=[file containing secret value]:file:_files' \
                        '*:name'
                    ;;
                apps)
                    _arguments \
                        '1:action:(create read update delete list)' \
                        '--description=[app description]:description' \
                        '*:name'
                    ;;
                run)
                    _arguments \
                        '--no-newline[do not append newline]' \
                        '--plaintext[disable secret masking]' \
                        '--command=[command to run]:command' \
                        '*:command'
                    ;;
                config)
                    _arguments \
                        '1:action:(init get set)' \
                        '2:key' \
                        '3:value'
                    ;;
            esac
            ;;
    esac
}

_vlt "$@"
