#compdef vlt
# Documentation: https://github.com/vltpkg/vltpkg
# Reference accessed: 2026-05-21
# Verified: upstream source src/cli-sdk/src/commands/ directory.

_vlt_cmds() {
    local -a commands=(
        'install:install packages (updates package.json and vlt-lock.json)'
        'uninstall:remove packages'
        'update:update installed packages'
        'init:initialize a new package'
        'run:run a package.json script'
        'exec:execute a binary from a package'
        'exec-local:execute a local binary'
        'exec-cache:manage exec cache'
        'run-exec:run a binary via the runner'
        'install:install dependencies'
        'list:list installed packages'
        'query:run a graph query'
        'pkg:read/modify package.json'
        'config:view/edit configuration'
        'cache:manage cache'
        'publish:publish a package'
        'pack:create a tarball'
        'view:view a package manifest'
        'access:manage package access'
        'profile:manage user profile'
        'login:authenticate to a registry'
        'logout:log out of a registry'
        'whoami:show authenticated user'
        'token:manage auth tokens'
        'ping:ping the registry'
        'bugs:open package bug tracker'
        'repo:open package repository'
        'docs:open package documentation'
        'dist-tag:manage dist-tags'
        'deprecate:deprecate a package version'
        'unpublish:unpublish a package'
        'ci:install for CI environments'
        'version:bump package version'
        'create:scaffold a new package'
        'build:run build scripts'
        'help:show help'
    )
    _describe -t commands 'vlt command' commands
}

_vlt() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '1:command:_vlt_cmds' \
        '*::arg:_files'
}

_vlt "$@"
