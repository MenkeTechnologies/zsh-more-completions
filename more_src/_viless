#compdef viless
# Documentation: https://man.archlinux.org/search?q=viless
# Reference accessed: 2026-05-16

# viless: vi-keystroke wrapper around less
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-c[start at line]:line:' \
  '-p[search for pattern]:pattern:' \
  '*:files:_files' && ret=0
return ret
