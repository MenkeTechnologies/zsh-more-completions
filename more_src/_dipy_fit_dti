#compdef dipy_fit_dti
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_fit_dti.html
# DIPY: fit diffusion tensor (DTI) model and save DTI metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--fit_method=[fitting method (WLS LS OLS NLLS RT restore)]:method:(WLS LS OLS NLLS RT restore RESTORE)' \
  '--b0_threshold=[threshold for b0 detection]:thr' \
  '--bvecs_tol=[tolerance for bvec norm checking]:tol' \
  '--npeaks=[number of peaks to save per voxel]:n' \
  '--sigma=[variance estimate]:sigma' \
  '--save_metrics=[list of metrics to save]:metrics' \
  '--nifti_tensor=[whether tensor follows Nifti format]:bool:(True False)' \
  '--extract_pam_values=[save pam volumes as individual files]:bool:(True False)' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_tensor=[tensor volume filename]:file:_files' \
  '--out_fa=[fractional anisotropy filename]:file:_files' \
  '--out_ga=[geodesic anisotropy filename]:file:_files' \
  '--out_rgb=[color FA filename]:file:_files' \
  '--out_md=[mean diffusivity filename]:file:_files' \
  '--out_ad=[axial diffusivity filename]:file:_files' \
  '--out_rd=[radial diffusivity filename]:file:_files' \
  '--out_mode=[mode volume filename]:file:_files' \
  '--out_evec=[eigenvectors filename]:file:_files' \
  '--out_eval=[eigenvalues filename]:file:_files' \
  '--out_pam=[peaks filename]:file:_files' \
  '--out_peaks_dir=[peaks directions filename]:file:_files' \
  '--out_peaks_values=[peaks values filename]:file:_files' \
  '--out_peaks_indices=[peaks indices filename]:file:_files' \
  '--out_sphere=[sphere vertices filename]:file:_files' \
  '--out_qa=[quantitative anisotropy filename]:file:_files' \
  '--out_s0=[S0 estimate filename]:file:_files' \
  '*:input (volumes bvals bvecs masks):_files' && ret=0

return ret
