#compdef aur-depends
# Documentation: https://man.archlinux.org/search?q=aur-depends
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[show all dependencies]' \
  '(-r --reverse)'{-r,--reverse}'[show reverse dependencies]' \
  '(-G --graph)'{-G,--graph}'[output dependency graph]' \
  '(-J --json)'{-J,--json}'[output JSON format]' \
  '(-t --table)'{-t,--table}'[output table format]' \
  '--no-provides[do not resolve provides]' \
  '--pkgbase[group results by pkgbase]' \
  '(-d --repo)'{-d,--repo}'[target repository]:repository' \
  '*:package' && ret=0

return ret
