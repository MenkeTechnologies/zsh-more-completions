#compdef centroid
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss17.html
# KAPPA: find the centroids of star-like features in an NDF

local ret=1

_arguments -s \
  'CATFRAME=[coordinate Frame for output catalogue]:catframe' \
  'CATEPOCH=[epoch for output-catalogue sky positions]:catepoch' \
  'CERROR=[calculate errors in centroid positions]:cerror:(TRUE FALSE)' \
  'COIN=[text file with initial coordinate guesses]:file:_files' \
  'DESCRIBE=[describe the coordinate Frame]:describe:(TRUE FALSE)' \
  'DEVICE=[graphics device for cursor input]:device' \
  'GUESS=[include supplied guesses in output]:guess:(TRUE FALSE)' \
  'INCAT=[input catalogue with position guesses]:catalogue:_files' \
  'INIT=[initial coordinate guess]:init' \
  'LOGFILE=[text file for logging results]:file:_files' \
  'MARK=[positions to mark on screen]:mark:(Initial Centroid None)' \
  'MARKER=[PGPLOT marker type]:marker' \
  'MAXITER=[maximum centroid-search iterations]:maxiter' \
  'MAXSHIFT=[maximum allowed pixel shift]:maxshift' \
  'MODE=[method for obtaining initial positions]:mode:(Interface Cursor Catalogue File)' \
  'NDF=[input NDF containing the data array]:NDF:_files' \
  'NSIM=[number of error-estimation simulations]:nsim' \
  'OUTCAT=[output catalogue for centroided positions]:catalogue:_files' \
  'PLOTSTYLE=[marker styling attributes]:plotstyle' \
  'POSITIVE=[features positive above background]:positive:(TRUE FALSE)' \
  'SEARCH=[search box size in pixels]:search' \
  'TITLE=[title for the output catalogue]:title' \
  'TOLER=[required centroiding accuracy in pixels]:toler' \
  '*:NDF:_files' && ret=0

return ret
