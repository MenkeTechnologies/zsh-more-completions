#compdef snmpenum
# _snmpenum — snmpenum (compact Perl SNMP enumerator from offensive-security; sends a curated list of community walks to discover the target's running services, processes and admin accounts; positional arguments: HOST COMMUNITY OS-config-file (default /etc/snmpenum/conf/*.conf))
# upstream: https://github.com/0x90/snmpenum
# Argument shape from snmpenum.pl on tip.

_snmpenum() {
    _arguments \
        '-h[show help]' \
        '1:host:_hosts' \
        '2:community:' \
        '3:OS config file:_files -g "*.conf"'
}

_snmpenum "$@"
