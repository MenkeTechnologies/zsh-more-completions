#compdef as-tree
# Documentation: https://man.archlinux.org/search?q=as-tree
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-)'{-h,--help}'[usage]' \
  '(-)'{-v,--version}'[print version]' \
  -f'[print full path prefixes]' \
  '--color+[colorization mode (also supports --color=value)]:mode:(always auto never)' \
  '::input path file (default stdin):_files'
