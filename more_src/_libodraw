#compdef odrawinfo odrawmount
# _libodraw — libodraw tools (libyal optical-disc raw image parser; odrawinfo prints metadata for .cue/.toc/.iso/.img/.cdr files including per-track + per-session info, odrawmount FUSE-mounts the disc as a flat raw image; -h help, -V version, -v verbose, -o image offset, -X exclusive; positional argument is the .cue/.toc/.iso file)
# upstream: https://github.com/libyal/libodraw
# Flags from libyal/libodraw odrawtools/odrawinfo.c on tip.

_libodraw() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-X[exclusive]' \
        '*:image file:_files -g "*.(cue|toc|iso|img|cdr)"'
}

_libodraw "$@"
