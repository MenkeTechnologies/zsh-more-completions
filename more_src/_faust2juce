#compdef faust2juce
# Documentation: https://faustdoc.grame.fr/manual/tools/
# Reference accessed: 2026-06-21
# Verified: flags parsed by the faust2juce script in grame-cncm/faust tools/faust2appls.

local ret=1

_arguments -s -S \
  '(--help -help -h)'{--help,-help,-h}'[show help]' \
  '-debug[enable debug mode]' \
  '-nvoices+[number of polyphonic voices]:n:' \
  '-standalone[generate standalone project instead of plugin]' \
  '-effect+[global output effect dsp]:file:_files -g "*.dsp"' \
  '-vst2sdkdir+[VST2 SDK directory]:dir:_files -/' \
  '-jucemodulesdir+[JUCE modules directory]:dir:_files -/' \
  '-disable-splash-screen[disable JUCE splash screen]' \
  '-jsynth[use JUCE polyphonic synthesizer]' \
  '-midi[add MIDI control]' \
  '-osc[add OSC control]' \
  '-llvm[use the LLVM compilation chain]' \
  '-magic[use the PluginGuiMagic GUI builder]' \
  '-soundfile[add soundfile support]' \
  '-double[use double precision floats]' \
  '*:dsp file:_files -g "*.dsp"' && ret=0

return ret
