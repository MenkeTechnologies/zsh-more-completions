#compdef cmbuild
# Documentation: https://manpages.debian.org/testing/infernal/cmbuild.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmbuild: build a covariance model from a structural alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-n[name the new CM]:name:' \
  '-F[allow overwriting output CM file]' \
  '-o[redirect summary output to file]:file:_files' \
  '-O[save annotated alignment to Stockholm file]:file:_files' \
  '--fast[automatically determine consensus columns (default)]' \
  '--hand[use reference coordinate annotation for consensus columns]' \
  '--symfrac[residue fraction threshold for consensus columns]:x:' \
  '--fragthresh[define fragments by aligned length fraction]:x:' \
  '--noss[ignore secondary structure annotation]' \
  '--rsearch[parameterize using RIBOSUM matrix]:file:_files' \
  '--consrf[use consensus sequence for reference annotation]' \
  '--wpb[Henikoff position-based weighting (default)]' \
  '--wgsc[Gerstein/Sonnhammer/Chothia weighting]' \
  '--wnone[disable sequence weighting]' \
  '--wgiven[use annotated weights]' \
  '--wblosum[BLOSUM filtering clustering]' \
  '--wid[clustering percent identity]:x:' \
  '--eent[entropy weighting (default)]' \
  '--enone[disable entropy weighting]' \
  '--ere[target mean relative entropy]:x:' \
  '--p7ere[filter HMM target relative entropy]:x:' \
  '--refine[refine alignment by EM]:file:_files' \
  '--gibbs[use Gibbs sampling instead of EM]' \
  '--seed[random number seed]:n:' \
  '--cpu[number of CPU threads]:n:' \
  '--informat[input alignment format]:format:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--devhelp[show developer options]' \
  '*:output CM and input alignment:_files' && ret=0
return ret
