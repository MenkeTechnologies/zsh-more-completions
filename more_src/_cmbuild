#compdef cmbuild

# Infernal cmbuild: build a covariance model from a structural alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-n[CM name]:name:' \
  '-F[overwrite output CM file]' \
  '-o[output report file]:file:_files' \
  '-O[save modified annotated alignment to file]:file:_files' \
  '--Rsearch[use original Rsearch RIBOSUM-85-60 matrix]:file:_files' \
  '--ignorant[treat as 0-th order Markov model]' \
  '--null[set null model background]:file:_files' \
  '--prior[set prior distribution file]:file:_files' \
  '--devhelp[show developer options]' \
  '--p7ml[use ML p7 filter]' \
  '--gapthresh[gap fraction threshold for match columns]:thresh:' \
  '--rsearch[set rsearch parameters]:file:_files' \
  '--rwgt[reset relative weights with method]:method:(weight gsc blosum pb none)' \
  '--wblosum[BLOSUM relative weighting]' \
  '--wgsc[Gerstein/Sonnhammer/Chothia weighting]' \
  '--wnone[no relative weighting]' \
  '--wpb[Henikoff position-based weighting]' \
  '--enone[disable effective sequence number scaling]' \
  '--eent[entropy weighting]' \
  '--eX[target rel-entropy in bits per match column]:bits:' \
  '--cpu[number of CPU threads]:n:' \
  '--informat[input alignment format]:format:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '*:output CM and input alignment:_files' && ret=0
return ret
