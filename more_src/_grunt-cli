#compdef grunt
# _grunt-cli — Grunt JavaScript task runner CLI (Ben Alman + community, Node.js); run Gruntfile-defined tasks
# upstream: https://github.com/gruntjs/grunt-cli

_grunt-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--gruntfile+[Gruntfile path]:file:_files -g "Gruntfile.{js,coffee,ts}"' \
        '--base+[base path]:dir:_files -/' \
        '--no-color[no color]' \
        '--debug[debug log]' \
        '-d[debug log]' \
        '--stack[print stack]' \
        '--force[continue on errors]' \
        '-f[continue on errors]' \
        '--tasks+[task dirs]:dir:_files -/' \
        '--npm+[npm tasks dirs]:str:' \
        '--write+[write to file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-write[dry run]' \
        '--completion+[print completion]:shell:(bash zsh)' \
        '--preload+[preload modules]:str:' \
        '*:task:'
}

_grunt-cli "$@"
