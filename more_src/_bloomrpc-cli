#compdef bloomrpc-cli bloomrpc
# _bloomrpc-cli — bloomrpc CLI command-line frontend wrapping the BloomRPC formerly Insomnia gRPC desktop client for testing gRPC services proto loading method-list unary-server-streaming-client-streaming-bidirectional-streaming calling with TLS authentication metadata-message-templates reflection-fallback gRPC-web (BloomRPC team, JS); commander
# upstream: https://github.com/bloomrpc/bloomrpc

_bloomrpc-cli() {
    local -a sub=(
        'call:invoke a gRPC method'
        'list:list services and methods from proto'
        'reflect:use reflection to list services'
        'export:export call as proto'
        'env:environment management'
        'workspace:workspace management'
        'collection:collection management'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--proto=+[file]:file:_files -g "*.proto"' \
        '-p+[proto file]:file:_files -g "*.proto"' \
        '--proto-path=+[dir]:dir:_files -/' \
        '-I+[import path]:dir:_files -/' \
        '--include=+[dir]:dir:_files -/' \
        '--server=+[host:port]:str:' \
        '-s+[server]:str:' \
        '--method=+[name]:str:' \
        '-m+[method]:str:' \
        '--message=+[json]:str:' \
        '--message-file=+[file]:file:_files -g "*.json *.yaml"' \
        '--metadata=+[k=v]:str:' \
        '--tls[use TLS]' \
        '--tls-cert=+[file]:file:_files' \
        '--tls-key=+[file]:file:_files' \
        '--tls-ca=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '--reflection[use reflection]' \
        '--web[use gRPC-Web]' \
        '--timeout=+[duration]:str:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bloomrpc-cli subcommand' sub ;;
        args)
            case $words[1] in
                call|reflect|list) _arguments '*:service or method:' ;;
                env|workspace|collection) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_bloomrpc-cli "$@"
