#compdef CreateWarpedGridImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CreateWarpedGridImage.cxx — render warp deformation as a grid image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:deformationField:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImage:_files' \
    '4::directions (e.g. 1x0x0):_default' \
    '5::gridSpacing (e.g. 10x10x10; default fieldSize/25):_default' \
    '6::gridSigma (e.g. 1x1x1; default gridSpacing/10):_default' \
    && ret=0

return ret
