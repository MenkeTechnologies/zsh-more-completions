#compdef tcpstates tcpstate tcpstate-bpfcc
# _tcpstate — IO Visor BCC tcpstates CLI eBPF-based TCP socket state change tracing tool printing per-event state transition LISTEN SYN_SENT SYN_RECV ESTABLISHED FIN_WAIT_1 FIN_WAIT_2 TIME_WAIT CLOSE CLOSE_WAIT LAST_ACK CLOSING delay durations for diagnosing TCP connection lifecycle issues (IO Visor team, Python); argparse
# upstream: https://github.com/iovisor/bcc

_tcpstate() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-T[print timestamps]' \
        '--timestamp[print timestamps]' \
        '-Y[print ASCII labels]' \
        '--ascii-labels[print ASCII labels]' \
        '-4[IPv4 only]' \
        '--ipv4[IPv4 only]' \
        '-6[IPv6 only]' \
        '--ipv6[IPv6 only]' \
        '-L+[ports]:str:' \
        '--localport=+[list]:str:' \
        '-D+[ports]:str:' \
        '--remoteport=+[list]:str:' \
        '-s[state filter]' \
        '--state=+[states]:str:' \
        '-w+[wide column output]' \
        '*::'
}

_tcpstate "$@"
