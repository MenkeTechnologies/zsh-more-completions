#compdef mri_label2label
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_label2label
# FreeSurfer: convert a label from one subject to another via surface or volume

local ret=1

_arguments -s -S \
  '--srcsubject[source subject]:subject' \
  '--srclabel[input label file]:label:_files' \
  '--trgsubject[target subject]:subject' \
  '--trglabel[output label file]:label:_files' \
  '--regmethod[registration method]:method:(surface volume)' \
  '--hemi[hemisphere]:hemi:(lh rh)' \
  '--srchemi[source hemisphere]:hemi:(lh rh)' \
  '--trghemi[target hemisphere]:hemi:(lh rh)' \
  '--srcicoorder[icosahedron order for source ico]:n' \
  '--trgicoorder[icosahedron order for target ico]:n' \
  '--trgsurf[surface for xyz coords (default white)]:surf' \
  '--surfreg[surface registration file (default sphere.reg)]:file' \
  '--srcsurfreg[source surface registration file]:file' \
  '--trgsurfreg[target surface registration file]:file' \
  '--srcmask[source mask data file]:file:_files' \
  '--srcmasksign[mask sign threshold]:sign:(abs pos neg)' \
  '--srcmaskframe[frame number for mask]:frameno' \
  '--projabs[project distance mm along normal]:dist' \
  '--projfrac[project fraction of thickness along normal]:frac' \
  '--sd[subjects directory]:dir:_files -/' \
  '--nohash[disable hash table for surface registration]' \
  '--norevmap[disable reverse mapping]' \
  '*:argument:_files' && ret=0

return ret
