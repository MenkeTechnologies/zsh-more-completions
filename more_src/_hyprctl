#compdef hyprctl

# Zsh completion for hyprctl - Hyprland compositor control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'activewindow:get active window'
  'activeworkspace:get active workspace'
  'animations:get running animations info'
  'binds:list all keybinds'
  'clients:list all windows'
  'configerrors:list config errors'
  'cursorpos:get cursor position'
  'decorations:list decorations of a window'
  'devices:list all input devices'
  'dispatch:dispatch an action'
  'getoption:get the value of a config option'
  'globalshortcuts:list all global shortcuts'
  'hyprpaper:interact with hyprpaper'
  'instances:list running instances'
  'keyword:set a config keyword'
  'kill:kill an app by clicking on it'
  'layers:list all layers'
  'layouts:list all layouts'
  'monitors:list all monitors'
  'notify:send a notification'
  'output:add or remove virtual outputs'
  'plugin:manage plugins'
  'reload:reload config'
  'rollinglog:get the rolling log'
  'setcursor:set the cursor theme and size'
  'seterror:set a custom error message'
  'setprop:set a window property'
  'splash:get the current splash'
  'switchxkblayout:switch xkb layout for device'
  'systeminfo:get system info'
  'version:show version'
  'workspacerules:list workspace rules'
  'workspaces:list all workspaces'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[output in JSON]' \
  '(-r --raw)'{-r,--raw}'[output raw]' \
  '--batch[execute batch of commands]:commands' \
  '(-i --instance)'{-i,--instance}'[specify instance]:instance' \
  '1:command:->command' \
  '*:argument' && ret=0

case $state in
  command)
    _describe -t commands 'hyprctl command' commands && ret=0
    ;;
esac

return ret
