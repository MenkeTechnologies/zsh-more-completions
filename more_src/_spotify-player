#compdef spotify_player

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config-folder)'{-c,--config-folder}'[path to config folder]:directory:_directories' \
  '(-C --cache-folder)'{-C,--cache-folder}'[path to cache folder]:directory:_directories' \
  '(-t --theme)'{-t,--theme}'[application theme]:theme' \
  '--no-image[disable image rendering]' \
  '--no-streaming[disable audio streaming]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'authenticate:authenticate with Spotify'
      'generate:generate shell completions'
      'get:get Spotify data'
      'playback:control playback'
      'connect:connect to a Spotify device'
      'like:like a track'
      'search:search Spotify'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      playback)
        _arguments -s -S \
          '1:action:(play pause next previous shuffle repeat volume seek)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      get)
        _arguments -s -S \
          '1:resource:(key)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '1:shell:(bash zsh fish elvish powershell)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
