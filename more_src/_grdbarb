#compdef grdbarb
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/windbarbs — plot wind barbs from two component grids

local ret=1

_arguments -s \
  '-A[grids are polar (speed,theta) not Cartesian (u,v)]' \
  '-B+[map frame and axes]:frame:_default' \
  '-C+[color palette table by wind speed]:cpt:_files' \
  '-G+[fill color for barb interiors]:color:_default' \
  '-I+[plot barbs at node intervals]:inc:_default' \
  '-K[do not finalize PostScript]' \
  '-N[do not clip barbs at map boundary]' \
  '-Q+[barb parameters length/angle/fill/pen]:opts:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '-T[adjust azimuths by x/y scale sign]' \
  '-U+[draw GMT timestamp logo]:stamp:_default' \
  '*-V[verbose (stackable)]' \
  '-W+[pen attributes for barb outlines]:pen:_default' \
  '-X+[shift origin horizontally]:x:_default' \
  '-Y+[shift origin vertically]:y:_default' \
  '-Z[interpret theta grid as azimuths]' \
  '-f+[column data types]:types:_default' \
  '-p+[perspective view]:view:_default' \
  '-t+[transparency level]:pct:_default' \
  '*:input grids:_files' \
  && ret=0

return ret
