#compdef photon

local -a arguments

arguments=(
  '(-u --url)'{-u,--url}'=[target URL]:url:'
  '(-l --level)'{-l,--level}'=[depth of crawling]:level:'
  '(-t --threads)'{-t,--threads}'=[number of threads]:threads:'
  '(-d --delay)'{-d,--delay}'=[delay between requests in seconds]:delay:'
  '(-c --cookies)'{-c,--cookies}'=[cookies]:cookies:'
  '(-o --output)'{-o,--output}'=[output directory]:directory:_files -/'
  '(-s --seeds)'{-s,--seeds}'=[additional seed URLs]:urls:'
  '(-r --regex)'{-r,--regex}'=[regex pattern for extraction]:pattern:'
  '--exclude=[exclude URLs matching pattern]:pattern:'
  '--timeout=[request timeout in seconds]:seconds:'
  '--user-agent=[custom user agent]:user-agent:'
  '--headers=[custom headers]:headers:'
  '--only-urls[only extract URLs]'
  '--keys[extract secret keys]'
  '--wayback[fetch URLs from Wayback Machine]'
  '--dns[enumerate subdomains via DNS]'
  '--clone[clone the website locally]'
  '--ninja[ninja mode - evade detection]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-h --help)'{-h,--help}'[show help message]'
  '--version[show version information]'
)

_arguments -s -S $arguments
