#compdef nettop

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-n[disable address to name resolution]' \
  '-m+[set the mode]:mode:(route tcp udp)' \
  '*-t+[interface type]:type:(wifi wired awdl expensive loopback undefined external)' \
  '*-p+[process pid or name]:pid/name:_pids' \
  '-c[be gentle on CPU, draw less often]' \
  '-d[delta mode]' \
  '-x[extended display of numbers (no suffixes)]' \
  '-s+[delay between updates in seconds]:seconds:' \
  '-l+[logging mode samples (0=infinity)]:samples:' \
  '-L+[CSV logging mode samples (0=infinity)]:samples:' \
  '-P[display per-process summaries only]' \
  '-j+[include columns (comma list)]:columns:' \
  '-J+[include only columns (comma list)]:columns:' \
  '-k+[exclude columns (comma list)]:columns:' && ret=0

return ret
