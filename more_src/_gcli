#compdef gcli
# Documentation: https://man.archlinux.org/search?q=gcli
# Reference accessed: 2026-05-16

# https://github.com/herrhotzenplotz/gcli — multi-forge Git CLI (v2.11.x)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-t --target)'{-t+,--target=}'[forge target]:target:(github gitlab gitea bugzilla forgejo)' \
  '*::arguments:_default'
