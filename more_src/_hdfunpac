#compdef hdfunpac
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdfunpac.1.en.html
# Unpack an HDF file by exporting SD elements to external data files

local ret=1

_arguments -s \
  '-d+[external data file name]:data file:_files' \
  '1:hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
