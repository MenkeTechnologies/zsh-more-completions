#compdef sudatumk2ds
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/datuming/sudatumk2ds.c
# Kirchhoff datuming of sources for 2D prestack data

local ret=1

_arguments -s -S \
  'infile=[input seismic traces file]:infile:_files' \
  'outfile=[common offset migration output file]:outfile:_files' \
  'ttfile=[traveltime tables input file]:ttfile:_files' \
  'fzt=[first depth sample in traveltime table]:fzt' \
  'nzt=[number of depth samples in traveltime table]:nzt' \
  'dzt=[depth interval in traveltime table]:dzt' \
  'fxt=[first lateral sample in traveltime table]:fxt' \
  'nxt=[number of lateral samples in traveltime table]:nxt' \
  'dxt=[lateral interval in traveltime table]:dxt' \
  'fs=[x-coordinate of first source]:fs' \
  'ns=[number of sources]:ns' \
  'ds=[x-coordinate increment of sources]:ds' \
  'fxi=[x-coordinate of first surface location]:fxi' \
  'dxi=[horizontal spacing on surface]:dxi' \
  'nxi=[number of input surface locations]:nxi' \
  'sgn=[datuming direction (up=-1 or down=1)]:sgn:(-1 1)' \
  'dt=[time sampling interval of input data]:dt' \
  'ft=[first time sample of input data]:ft' \
  'surf=[surface definitions (recording surface and new datum)]:surf' \
  'fzo=[first output depth sample]:fzo' \
  'dzo=[output depth interval]:dzo' \
  'nzo=[number of output depth samples]:nzo' \
  'v0=[reference velocity at surface]:v0' \
  'dvz=[reference velocity vertical gradient]:dvz' \
  'fmax=[frequency high-cut for input traces]:fmax' \
  'angmax=[migration angle aperture from vertical]:angmax' \
  'aperx=[migration lateral aperture]:aperx' \
  'mtr=[print verbal information at every mtr traces]:mtr' \
  'ntr=[maximum number of input traces to migrate]:ntr' \
  '*:file:_files' && ret=0

return ret
