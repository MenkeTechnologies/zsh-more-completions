#compdef melt
# Documentation: https://github.com/charmbracelet/melt
# Reference accessed: 2026-05-19
# Verified: upstream README. melt turns an SSH key into a recoverable
# mnemonic seed phrase. Default mode generates; `restore` rebuilds key.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--seed=[mnemonic seed phrase for restore]:phrase:' \
  '1:command or key file:->cmd' \
  '*:file:_files' && ret=0

case $state in
  cmd)
    _alternative \
      'commands:command:((restore\:rebuild\ SSH\ key\ from\ seed))' \
      'files:key file:_files' && ret=0
    ;;
esac

return ret
