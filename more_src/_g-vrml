#compdef g-vrml
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=g-vrml&sektion=1
# BRL-CAD geometry database to VRML converter

local ret=1

_arguments -s \
  '-v[verbose output]' \
  '-d[calculational distance tolerance in mm (default 0.005)]:tolerance' \
  '-a[absolute tessellation tolerance in mm]:tolerance' \
  '-n[surface normal tolerance in degrees]:tolerance' \
  '-r[relative tessellation tolerance]:tolerance' \
  '-x[librt debug flag]:flag' \
  '-X[NMG debug flag]:flag' \
  '-u[output units name (default mm)]:units' \
  '-o[output file (default stdout)]:output:_files' \
  '-b[BOT dump mode]' \
  '-e[evaluate all CSG and BOT objects]' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
