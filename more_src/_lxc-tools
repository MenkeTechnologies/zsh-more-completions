#compdef lxc-destroy lxc-cgroup lxc-checkconfig lxc-checkpoint lxc-clone lxc-config lxc-console lxc-copy lxc-device lxc-execute lxc-freeze lxc-monitor lxc-snapshot lxc-top lxc-unfreeze lxc-unshare lxc-update-config lxc-usernsexec lxc-wait

local curcontext="$curcontext" state line ret=1

case $service in
  (lxc-destroy)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[container name]:c:' \
      '-f[force]' \
      '--force[force]' \
      '-s[snapshots]' \
      '--snapshots[also destroy snapshots]' \
      '*: :' && ret=0 ;;
  (lxc-cgroup)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[container name]:c:' \
      '*:subsystem:' && ret=0 ;;
  (lxc-checkconfig)
    _arguments '*: :_files' && ret=0 ;;
  (lxc-checkpoint)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[container name]:c:' \
      '(-r --restore)'{-r,--restore}'[restore]' \
      '(-D --checkpoint-dir)'{-D+,--checkpoint-dir=}'[dir]:dir:_files -/' \
      '(-s --stop)'{-s,--stop}'[stop after dump]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-d --daemon)'{-d,--daemon}'[daemon]' \
      '(-F --foreground)'{-F,--foreground}'[foreground]' \
      '(-p --pre-dump-dir)'{-p+,--pre-dump-dir=}'[pre dump dir]:dir:_files -/' \
      '(-P --predump-dir)'{-P+,--predump-dir=}'[predump dir]:dir:_files -/' \
      '*: :' && ret=0 ;;
  (lxc-clone)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-o --orig)'{-o+,--orig=}'[original]:c:' \
      '(-n --new)'{-n+,--new=}'[new name]:c:' \
      '(-B --backingstore)'{-B+,--backingstore=}'[backing store]:b:(none dir lvm overlayfs btrfs zfs)' \
      '(-s --snapshot)'{-s,--snapshot}'[snapshot]' \
      '(-K --keepname)'{-K,--keepname}'[keep name]' \
      '(-M --keepmac)'{-M,--keepmac}'[keep MAC]' \
      '(-L --fssize)'{-L+,--fssize=}'[fs size]:s:' \
      '(-D --fstype)'{-D+,--fstype=}'[fs type]:t:' \
      '(-p --lxcpath)'{-p+,--lxcpath=}'[path]:dir:_files -/' \
      '(-N --newname)'{-N+,--newname=}'[new name]:c:' \
      '*: :' && ret=0 ;;
  (lxc-config)
    _arguments -C \
      '-h[help]' \
      '-l[list]' \
      '*:item:' && ret=0 ;;
  (lxc-console)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[container name]:c:' \
      '(-t --tty)'{-t+,--tty=}'[tty number]:n:' \
      '(-e --escape)'{-e+,--escape=}'[escape character]:e:' \
      '*: :' && ret=0 ;;
  (lxc-copy)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[name]:c:' \
      '(-N --newname)'{-N+,--newname=}'[new name]:c:' \
      '(-p --newpath)'{-p+,--newpath=}'[new path]:dir:_files -/' \
      '(-B --backingstorage)'{-B+,--backingstorage=}'[backing]:b:' \
      '(-s --snapshot)'{-s,--snapshot}'[snapshot]' \
      '(-K --keepname)'{-K,--keepname}'[keep name]' \
      '(-D --keepdata)'{-D,--keepdata}'[keep data]' \
      '(-M --keepmac)'{-M,--keepmac}'[keep MAC]' \
      '(-L --fssize)'{-L+,--fssize=}'[fs size]:s:' \
      '(-e --ephemeral)'{-e,--ephemeral}'[ephemeral]' \
      '(-m --mount)*'{-m+,--mount=}'[mount]:m:' \
      '*: :' && ret=0 ;;
  (lxc-device)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[name]:c:' \
      '1:command:(add del)' \
      '*: :' && ret=0 ;;
  (lxc-execute)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[name]:c:' \
      '(-f --rcfile)'{-f+,--rcfile=}'[config file]:file:_files' \
      '(-s --define)*'{-s+,--define=}'[k=v]:v:' \
      '(-u --uid)'{-u+,--uid=}'[uid]:n:' \
      '(-g --gid)'{-g+,--gid=}'[gid]:n:' \
      '*: :_command_names -e' && ret=0 ;;
  (lxc-freeze|lxc-unfreeze)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[name]:c:' \
      '*: :' && ret=0 ;;
  (lxc-monitor)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[name regex]:re:' \
      '(-Q --quit)'{-Q,--quit}'[quit on first event]' \
      '*: :' && ret=0 ;;
  (lxc-snapshot)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[container]:c:' \
      '(-L --list)'{-L,--list}'[list snapshots]' \
      '(-C --showcomments)'{-C,--showcomments}'[show comments]' \
      '(-r --restore)'{-r+,--restore=}'[snapshot to restore]:s:' \
      '(-c --comment)'{-c+,--comment=}'[comment file]:file:_files' \
      '(-d --destroy)'{-d+,--destroy=}'[snapshot to destroy]:s:' \
      '*: :' && ret=0 ;;
  (lxc-top)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-d --delay)'{-d+,--delay=}'[delay s]:s:' \
      '(-s --sort)'{-s+,--sort=}'[sort by]:s:(n c b m k)' \
      '(-r --reverse)'{-r,--reverse}'[reverse sort]' \
      '*:filter:' && ret=0 ;;
  (lxc-unshare)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-s --share)'{-s+,--share=}'[share]:s:' \
      '(-i --inherit)'{-i+,--inherit=}'[inherit]:i:' \
      '(-u --user)'{-u+,--user=}'[user]:u:_users' \
      '*: :_command_names -e' && ret=0 ;;
  (lxc-update-config)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
      '*: :' && ret=0 ;;
  (lxc-usernsexec)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-m+[map]:m:' \
      '*: :_command_names -e' && ret=0 ;;
  (lxc-wait)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --name)'{-n+,--name=}'[name]:c:' \
      '(-s --state)'{-s+,--state=}'[state]:s:(STOPPED STARTING RUNNING STOPPING ABORTING FREEZING FROZEN THAWED)' \
      '(-t --timeout)'{-t+,--timeout=}'[timeout s]:s:' \
      '*: :' && ret=0 ;;
esac

return ret
