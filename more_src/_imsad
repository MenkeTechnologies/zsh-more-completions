#compdef imsad
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imsad.html
# MIRIAD: find islands above cutoff and fit Gaussians

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image dataset]:in:_files' \
  'region=[region of interest]:region:' \
  'range=[image intensity display range]:range:' \
  'clip=[clip level threshold]:clip:' \
  'box=[minimum island pixel extents]:box:' \
  'max=[maximum number of detected boxes]:max:' \
  'rad=[angular radius limit]:rad:' \
  'options=[hist,gauss,fixed,point,box,arcsec,fiddle,nofit,noplt,nodet]:options:(hist gauss fixed point box arcsec fiddle nofit noplt nodet)' \
  'device=[PGPLOT device]:device:' \
  'out=[output fitted source dataset]:out:_files' \
  'log=[output log file]:log:_files' \
  'label=[label designation]:label:' \
  '*:image:_files' && ret=0

return ret
