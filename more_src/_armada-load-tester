#compdef armada-load-tester
# _armada-load-tester — Armada command-line load-test driver (submits many jobs from a YAML spec; optionally watches them to completion)
# upstream: https://github.com/armadaproject/armada
# Subcommands from cmd/armada-load-tester/cmd/{root,loadtest}.go on tip (cobra).

_armada-load-tester() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                loadtest:'run a load test from a YAML spec'
            )
            _describe -t commands 'armada-load-tester subcommand' subs
            ;;
        args)
            case $line[1] in
                loadtest)
                    _arguments \
                        '--watch[watch the events of all submitted jobs before exiting]' \
                        '--checkSuccess[exit -1 if any submitted job does not succeed]' \
                        '1:loadtest spec yaml:_files -g "*.yaml"'
                    ;;
            esac
            ;;
    esac
}

_armada-load-tester "$@"
