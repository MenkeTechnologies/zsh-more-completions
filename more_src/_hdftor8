#compdef hdftor8
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdftor8.1.en.html
# Extract 8-bit raster images and palettes from an HDF file

local ret=1

_arguments -s \
  '-i[run in interactive mode]' \
  '-v[run in verbose mode]' \
  '-r+[name of the raster image file]:raster image file:_files' \
  '-p+[name of the palette file]:palette file:_files' \
  '1:hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
