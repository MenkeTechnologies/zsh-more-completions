#compdef AnnotateVcfWithBamDepth
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/validation/AnnotateVcfWithBamDepth.java
# Annotate a VCF with a BAM's read depth at each variant locus

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'=[input VCF of variants]:vcf:_files' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-O --output)'{-O,--output}'=[output annotated VCF file]:output:_files' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf:_files' && ret=0

return ret
