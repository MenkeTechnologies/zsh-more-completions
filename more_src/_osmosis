#compdef osmosis
# Documentation: https://wiki.openstreetmap.org/wiki/Osmosis/Detailed_Usage
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# osmosis: command-line OSM data processor. Tasks chain via long flags like
# --read-xml, --write-pbf, --tag-filter, etc.
local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-v -verbose)'{-v,-verbose}'[increased logging]' \
  '(-q -quiet)'{-q,-quiet}'[reduced logging]' \
  '(-p -plugin)'{-p,-plugin}'+[load external plugin class]:class:' \
  '--read-xml[read OSM XML]' \
  '--read-pbf[read OSM PBF]' \
  '--read-apidb[read from API database]' \
  '--write-xml[write OSM XML]' \
  '--write-pbf[write OSM PBF]' \
  '--write-apidb[write to API database]' \
  '--bounding-box[filter by bounding box]' \
  '--bounding-polygon[filter by polygon]' \
  '--merge[merge two streams]' \
  '--sort[sort entities]' \
  '--buffer[buffer between tasks]' \
  '--tag-filter[filter by tag]' \
  '--used-node[keep only nodes used by ways]' \
  '--used-way[keep only ways used by relations]' \
  '--apply-change[apply OSC change]' \
  '--derive-change[derive OSC from two datasets]' \
  '*: :_files' && ret=0

return ret
