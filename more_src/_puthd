#compdef puthd
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/puthd.html
# MIRIAD puthd - set or add a header item in a dataset

local ret=1

_arguments -s -S \
  'in=[dataset item location dataset/item]:in:_files' \
  'value=[value to assign (optional units)]:value' \
  'type=[data type integer/real/double/ascii]:type:(integer real double ascii)' \
  '*:dataset:_files' && ret=0

return ret
