#compdef yay2
# _yay2 — Jguer yay2 CLI command-line frontend wrapping the Yay Yet Another Yaourt the AUR Arch User Repository helper for Arch Linux open-source written in Go originally Jguer Yiğit Sever inspired by yaourt and other AUR helpers wraps pacman to install and update packages from Arch User Repository AUR and official repositories sync remove query upgrade web tar deps PKGBUILD AUR pacman alias clean compose flag fetch numbed config print show stats info devel makepkg goproxy save (Jguer team, Go); custom argparse
# upstream: https://github.com/Jguer/yay

_yay2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-S[sync]' \
        '-R[remove]' \
        '-Q[query]' \
        '-D[database]' \
        '-T[deptest]' \
        '-U[upgrade]' \
        '-F[files]' \
        '-P[print]' \
        '-Y[yay command]' \
        '-W[web command]' \
        '--repo[use repos only]' \
        '--aur[use AUR only]' \
        '-a[use AUR only]' \
        '--needed[skip already installed]' \
        '--noconfirm[no confirm]' \
        '--confirm[confirm]' \
        '--asdeps[as deps]' \
        '--asexplicit[as explicit]' \
        '--rebuild[rebuild package]' \
        '--rebuildall[rebuild all]' \
        '--rebuildtree[rebuild whole tree]' \
        '--redownload[redownload]' \
        '--redownloadall[redownload all]' \
        '--noredownload[no redownload]' \
        '--norebuild[no rebuild]' \
        '--noprovides[no providers]' \
        '--mflags=+[flags]:str:' \
        '--gpgflags=+[flags]:str:' \
        '--builddir=+[dir]:dir:_files -/' \
        '--editor=+[name]:str:' \
        '--editorflags=+[flags]:str:' \
        '--makepkg=+[cmd]:str:' \
        '--makepkgconf=+[file]:file:_files -g "makepkg.conf"' \
        '--nomakepkgconf[no makepkg conf]' \
        '--pacman=+[cmd]:str:' \
        '--git=+[cmd]:str:' \
        '--gitflags=+[flags]:str:' \
        '--gpg=+[cmd]:str:' \
        '--sudo=+[cmd]:str:' \
        '--sudoflags=+[flags]:str:' \
        '--sudoloop[sudo loop]' \
        '--nosudoloop[no sudoloop]' \
        '--requestsplitn=+[N]:n:' \
        '--completioninterval=+[N]:n:' \
        '--aururl=+[url]:str:' \
        '--cleanafter[clean after]' \
        '--nocleanafter[no clean after]' \
        '--bottomup[bottom up search]' \
        '--topdown[top down search]' \
        '--singlelineresults[single line results]' \
        '--doublelineresults[double line results]' \
        '--sortby=+[s]:s:(votes popularity id baseid name base submitted modified)' \
        '--searchby=+[s]:s:(name name-desc maintainer depends checkdepends makedepends optdepends provides conflicts replaces groups keywords comaintainers)' \
        '--separatesources[separate sources]' \
        '--nodiffmenu[no diff menu]' \
        '--diffmenu[diff menu]' \
        '--editmenu[edit menu]' \
        '--noeditmenu[no edit menu]' \
        '--useask[use ask]' \
        '--nouseask[no use ask]' \
        '--combinedupgrade[combined upgrade]' \
        '--nocombinedupgrade[no combined upgrade]' \
        '--upgrademenu[upgrade menu]' \
        '--noupgrademenu[no upgrade menu]' \
        '--removemake[remove make deps]' \
        '--noremovemake[no remove make]' \
        '--keepsrc[keep src]' \
        '--nokeepsrc[no keep src]' \
        '--keepbuilddir[keep build dir]' \
        '--nokeepbuilddir[no keep build dir]' \
        '--devel[check devel]' \
        '--nodevel[no check devel]' \
        '--timeupdate[check time]' \
        '--notimeupdate[no check time]' \
        '--news[show news]' \
        '--nonews[no news]' \
        '-c[clean]' \
        '-w[show news only]' \
        '-g+[get pkgbuild]:str:' \
        '-p+[print]:str:' \
        '-s[stats]' \
        '--stats[stats]' \
        '-y[refresh]' \
        '-u[updates]' \
        '*:package:'
}

_yay2 "$@"
