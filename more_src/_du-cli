#compdef du-cli
# _du-cli — GNU coreutils du estimate file space usage CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_du-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-0[end with NUL]' \
        '--null[end with NUL]' \
        '-a[show all files, not just dirs]' \
        '--all[show all files, not just dirs]' \
        '--apparent-size[print apparent sizes]' \
        '-B+[block size]:str:' \
        '--block-size=+[block size]:str:' \
        '-b[apparent size in bytes]' \
        '--bytes[apparent size in bytes]' \
        '-c[grand total]' \
        '--total[grand total]' \
        '-D[follow command-line symlinks]' \
        '--dereference-args[follow command-line symlinks]' \
        '-d+[max depth]:n:' \
        '--max-depth=+[max depth]:n:' \
        '--files0-from=+[file]:file:_files' \
        '-h[print human readable]' \
        '--human-readable[print human readable]' \
        '--inodes[list inode info]' \
        '-k[block size 1024]' \
        '-L[follow all symlinks]' \
        '--dereference[follow all symlinks]' \
        '-l[count sizes multiple times if hard linked]' \
        '--count-links[count sizes multiple times if hard linked]' \
        '-m[block size 1MB]' \
        '-P[do not follow symlinks]' \
        '--no-dereference[do not follow symlinks]' \
        '-S[do not include size of subdirs]' \
        '--separate-dirs[do not include size of subdirs]' \
        '-s[total only]' \
        '--summarize[total only]' \
        '--si[human readable (1000)]' \
        '--time[show last modification time]' \
        '--time=+[mode]:m:(atime access use ctime status birth)' \
        '--time-style=+[style]:s:(full-iso long-iso iso)' \
        '-X+[exclude file]:file:_files' \
        '--exclude-from=+[exclude file]:file:_files' \
        '--exclude=+[pattern]:str:' \
        '-x[skip dirs on different fs]' \
        '--one-file-system[skip dirs on different fs]' \
        '-t+[threshold size]:str:' \
        '--threshold=+[threshold size]:str:' \
        '*:files:_files'
}

_du-cli "$@"
