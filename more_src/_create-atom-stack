#compdef create-atom-stack
# Documentation: https://www.npmjs.com/package/create-atom-stack
# Reference accessed: 2026-05-23
# Verified: npm view create-atom-stack bin; npm readme Scaffold Options and add generators.

# Zsh completion for create-atom-stack - Next.js atomic design scaffolder and generators

local curcontext="$curcontext" state line ret=1

_arguments -C   '--pm=[package manager]:manager:(npm pnpm yarn bun)'   '--state=[state library]:state:(zustand jotai react-query none)'   '--e2e=[end-to-end testing]:e2e:(playwright cypress none)'   '--rxjs[add RxJS and useObservable hook]'   '--xstate[add XState and useMachine integration]'   '--no-conventional-commits[skip Husky and Commitlint setup]'   '--no-git[skip git init]'   '--skip-install[scaffold files only; skip dependency install]'   '--dry[preview generator output without writing files]'   '--force[overwrite existing files without prompting]'   '--dir=[override default output directory]:directory:_directories'   '--name=[generator name flag for dynamic routes]:name:'   '--variants[component generator: add variant prop]'   '--with-test[component generator: add test file]'   '--with-styles[component generator: add styles file]'   '--with-story[component generator: add Storybook file]'   '--with=[feature subdirs]:with:(components hooks services store utils types)'   '--crud[api generator: full CRUD module]'   '--query[api generator: read-only queries]'   '--action[api generator: single mutation action]'   '--custom[api generator: empty API shell]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' add && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -C           ':generator type:(atom molecule organism template component page feature store api)'           ':name:'           '--variants[add variant prop to component]'           '--with-test[add test file]'           '--with-styles[add styles file]'           '--with-story[add Storybook file]'           '--with=[feature subdirs]:with:(components hooks services store utils types)'           '--crud[api generator: full CRUD module]'           '--query[api generator: read-only queries]'           '--action[api generator: single mutation action]'           '--custom[api generator: empty API shell]'           '--dry[preview without writing files]'           '--force[overwrite existing files]'           '--dir=[output directory]:directory:_directories'           '--name=[name flag for dynamic routes]:name:' && ret=0
        ;;
      *)
        _arguments -C           '--pm=[package manager]:manager:(npm pnpm yarn bun)'           '--state=[state library]:state:(zustand jotai react-query none)'           '--e2e=[end-to-end testing]:e2e:(playwright cypress none)'           '--rxjs[add RxJS integration]'           '--xstate[add XState integration]'           '--no-conventional-commits[skip Husky and Commitlint]'           '--no-git[skip git init]'           '--skip-install[skip dependency install]'           ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
