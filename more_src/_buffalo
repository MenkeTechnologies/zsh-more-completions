#compdef buffalo
# Documentation: https://gobuffalo.io/documentation/
# Reference accessed: 2026-06-04

# Zsh completion for Buffalo - Go web framework CLI

_buffalo() {
    local line state ret=1

    local -a subcmds=(
        'new:create a new Buffalo application'
        'dev:run the development server'
        'build:build the application binary'
        'test:run the tests for the application'
        'generate:generate application components'
        'g:generate application components (alias)'
        'destroy:destroy generated components'
        'd:destroy generated components (alias)'
        'info:print diagnostic information'
        'fix:attempt to fix a Buffalo application to latest version'
        'version:print the version of Buffalo'
        'help:help about any command'
    )

    _arguments -C \
        '(- *)--help[show help for buffalo]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'buffalo commands' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                new)
                    _arguments \
                        '--api[create an API-only application (skip frontend)]' \
                        '--ci-provider[choose a CI provider]:provider:(none travis gitlab-ci)' \
                        '--db-type[the type of database to use]:database:(postgres mysql sqlite3 cockroach)' \
                        '--docker[choose a Docker setup]:docker:(none multi standard)' \
                        '--force[overwrite existing files]' \
                        '--module[specify the Go module name]:module name' \
                        '--skip-config[skip using a config file]' \
                        '--skip-docker[skip generating Docker files]' \
                        '--skip-pop[skip adding Pop (database) to the application]' \
                        '--skip-webpack[skip adding Webpack to the application]' \
                        '--skip-yarn[skip using Yarn for frontend dependencies]' \
                        '--vcs[choose a version control system]:vcs:(none git bzr)' \
                        '(- *)--help[show help for new]' \
                        '1:application name' && ret=0
                    ;;
                dev)
                    _arguments \
                        '(- *)--help[show help for dev]' && ret=0
                    ;;
                build)
                    _arguments \
                        '--clean-assets[remove old assets before building]' \
                        '--dry-run[print commands that would be run without executing]' \
                        '(-e --environment)'{-e,--environment}'[set the environment for the binary]:environment' \
                        '--extract-assets[extract assets into a separate archive]' \
                        '--ldflags[set custom ldflags for the Go build]:ldflags' \
                        '--mod[set the -mod flag for Go commands]:mod:(vendor mod)' \
                        '(-o --output)'{-o,--output}'[set the output binary name]:file:_files' \
                        '--skip-assets[skip building assets]' \
                        '--skip-build-deps[skip installing build dependencies]' \
                        '--skip-template-validation[skip template validation]' \
                        '--static[build a statically linked binary]' \
                        '(-t --tags)'{-t,--tags}'[set build tags for the Go compiler]:tags' \
                        '(-v --verbose)'{-v,--verbose}'[print command output]' \
                        '(- *)--help[show help for build]' && ret=0
                    ;;
                test)
                    _arguments \
                        '(-c --count)'{-c,--count}'[number of times to run each test]:count' \
                        '(-d --debug)'{-d,--debug}'[enable debug output]' \
                        '--force-migrations[force running migrations before tests]' \
                        '(-m --run)'{-m,--run}'[run only tests matching the regexp]:regexp' \
                        '(-v --verbose)'{-v,--verbose}'[print command output]' \
                        '(- *)--help[show help for test]' \
                        '*:test path:_files -/' && ret=0
                    ;;
                generate|g)
                    local -a gen_subcmds=(
                        'action:generate a new action'
                        'mailer:generate a new mailer'
                        'model:generate a new model'
                        'resource:generate a new resource'
                        'task:generate a new task'
                    )
                    _arguments -C \
                        '(- *)--help[show help for generate]' \
                        '1: :->gen_cmds' \
                        '*::arg:->gen_args' && ret=0

                    case $state in
                        gen_cmds)
                            _describe -t commands 'generate subcommands' gen_subcmds && ret=0
                            ;;
                    esac
                    ;;
                destroy|d)
                    _arguments \
                        '(- *)--help[show help for destroy]' \
                        '*:name' && ret=0
                    ;;
                info)
                    _arguments \
                        '(- *)--help[show help for info]' && ret=0
                    ;;
                fix)
                    _arguments \
                        '(- *)--help[show help for fix]' && ret=0
                    ;;
                version)
                    _arguments \
                        '(- *)--help[show help for version]' && ret=0
                    ;;
                help)
                    _describe -t commands 'buffalo commands' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_buffalo "$@"
