#compdef ldns-zcat
# _ldns-zcat — NLnet Labs ldns-zcat (concatenate ldns-zsplit pieces back into a single zonefile; emits combined zone to stdout)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-zcat.c usage on tip.

_ldns-zcat() {
    _arguments \
        '-o+[initial $ORIGIN for zones starting with @]:origin:' \
        '-v[show version and exit]' \
        '*:zonefile:_files'
}

_ldns-zcat "$@"
