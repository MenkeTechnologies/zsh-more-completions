#compdef devbox
# Documentation: https://www.jetify.com/devbox/docs/cli_reference/devbox/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add packages to devbox'
  'auth:authentication'
  'cache:manage Devbox cache'
  'completion:print shell completion'
  'create:create devbox.json from template'
  'docs:open Devbox docs'
  'generate:generate Dockerfile/devcontainer/etc'
  'global:manage global devbox'
  'help:show help'
  'info:show info about a package'
  'init:initialize devbox.json'
  'install:install all packages'
  'integrate:integrate with editors'
  'log:show stream logs'
  'patch:patch a binary'
  'rm:remove packages'
  'run:run a script'
  'search:search for packages'
  'secrets:manage secrets'
  'services:manage long-running processes'
  'setup:setup devbox'
  'shell:start a shell with packages'
  'shellenv:print init script'
  'update:update packages'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-c+[config dir]:dir:_files -/' \
  '*--config=[config dir]:dir:_files -/' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*--debug[debug]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'devbox command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '(--platform)*--platform=[platform]:p:' \
          '(--exclude-platform)*--exclude-platform=[platform]:p:' \
          '(--allow-insecure)--allow-insecure[allow insecure]' \
          '(--patch-glibc)--patch-glibc[patch glibc]' \
          '(-d --disable-plugin)'{-d,--disable-plugin}'[disable plugin]' \
          '*:package:' && ret=0 ;;
      (rm)
        _arguments '*:package:' && ret=0 ;;
      (run)
        _arguments \
          '(-e --env)*'{-e+,--env=}'[env k=v]:e:' \
          '(--env-file)--env-file=[env file]:file:_files' \
          '(--pure)--pure[pure shell]' \
          '*: :' && ret=0 ;;
      (shell)
        _arguments \
          '(-e --env)*'{-e+,--env=}'[env]:e:' \
          '(--env-file)--env-file=[env file]:file:_files' \
          '(--pure)--pure[pure shell]' \
          '(--print-env)--print-env[print env]' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (services)
        _arguments \
          '1:subcommand:(attach ls restart start stop up)' \
          '*: :' && ret=0 ;;
      (secrets)
        _arguments \
          '1:subcommand:(download init list remove set upload)' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(clear copy info list)' \
          '*: :' && ret=0 ;;
      (global)
        _arguments \
          '1:subcommand:(add list path pull push rm shellenv update)' \
          '*: :' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(login logout token whoami)' \
          '*: :' && ret=0 ;;
      (generate)
        _arguments \
          '1:subcommand:(devcontainer dockerfile direnv install readme)' \
          '*: :' && ret=0 ;;
      (search)
        _arguments \
          '(-l --limit)'{-l+,--limit=}'[limit]:n:' \
          '(--show-all)--show-all[show all]' \
          '*:query:' && ret=0 ;;
      (info)
        _arguments \
          '(--markdown)--markdown[markdown output]' \
          '*:package:' && ret=0 ;;
      (update)
        _arguments \
          '(--sync-lock)--sync-lock[sync lock]' \
          '*:package:' && ret=0 ;;
      (integrate)
        _arguments '1:editor:(vscode)' '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
