#compdef xq

# Zsh completion for xq - XML/JSON processor (from python-yq)

local -a arguments

arguments=(
  {-x,--xml-output}'[output XML instead of JSON]'
  '--xml-item-depth[depth for splitting XML items]:depth'
  '--xml-dtd[preserve DTD in output]'
  '--xml-root[wrap output in a root element]:root element name'
  '--xml-force-list[comma-separated list of elements to force as lists]:element names'
  {-r,--raw-output}'[output raw strings, not JSON texts]'
  {-e,--exit-status}'[set exit status based on output]'
  {-s,--slurp}'[read all inputs into an array]'
  {-S,--sort-keys}'[sort keys of each object on output]'
  {-c,--compact-output}'[compact instead of pretty-printed output]'
  {-C,--color-output}'[colorize JSON output]'
  {-M,--monochrome-output}'[disable colored output]'
  '--tab[use tabs for indentation]'
  '--indent[set indentation level]:indentation level:(0 1 2 3 4 5 6 7 8)'
  {-j,--join-output}'[do not print newline after each output]'
  '*--arg[set variable to string value]: :_guard "^-*" name: :_guard "^-*" value'
  '*--argjson[set variable to JSON value]: :_guard "^-*" name: :_guard "^-*" value'
  '*--slurpfile[set variable to array from file]: :_guard "^-*" name:file:_files'
  '*--rawfile[set variable to string contents of file]: :_guard "^-*" name:file:_files'
  '--args[remaining arguments are string values]'
  '--jsonargs[remaining arguments are JSON values]'
  '1:jq filter'
  '*:input file:_files'
)

_arguments -s -S $arguments
