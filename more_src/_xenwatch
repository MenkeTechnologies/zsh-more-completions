#compdef xenwatch
# Documentation: https://man.archlinux.org/search?q=xenwatch
# Reference accessed: 2026-05-16

# xenwatch: monitor Xen xenstore changes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-D[debug]' \
  '*::xenwatch args:_files' && ret=0
return ret
