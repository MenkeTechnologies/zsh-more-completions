#compdef cargo-clean
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-clean.html

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --package)'{-p+,--package=}'[package to clean artifacts for]:package' \
  '--workspace[clean all packages in workspace]' \
  '--doc[clean only the documentation directory]' \
  '(-n --dry-run)'{-n,--dry-run}'[display what would be deleted without deleting]' \
  '(-r --release)'{-r,--release}'[clean release artifacts]' \
  '--profile=[clean artifacts of the specified profile]:profile' \
  '*--target=[target triple to clean output for]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '*'{-v,--verbose}'[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[--locked + --offline]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
  '*-Z+[unstable cargo flag]:flag'
