#compdef wstunnel
# _wstunnel — Erebe wstunnel (WebSocket-based TCP/UDP tunnel binary; subcommands: client, server; client takes -L local listener spec (tcp://0.0.0.0:port:target:port or stdio://), -R remote, --headers extra, --tls-server-name, --proxy, --upgrade-path-prefix; server takes --tls-cert/--tls-key, --restrict-to allow patterns, --upgrade-path-prefix, --hostname; both --version)
# upstream: https://github.com/erebe/wstunnel
# Subcommands from erebe/wstunnel src/main.rs on tip.

_wstunnel-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'wstunnel command' '(client server help)' ;;
        args)
            case $line[1] in
                client)
                    _arguments \
                        '*-L+[local listener]:spec:' \
                        '*-R+[remote listener]:spec:' \
                        '*--headers+[header]:KEY=VAL:' \
                        '--tls-server-name+[SNI]:sni:' \
                        '--proxy+[http proxy]:url:' \
                        '--upgrade-path-prefix+[upgrade path prefix]:prefix:' \
                        '*--http-upgrade-credentials+[creds]:creds:' \
                        '--connection-min-idle+[min idle conns]:n:' \
                        '--no-color[no color]' ;;
                server)
                    _arguments \
                        '--tls-certificate+[cert]:file:_files' \
                        '--tls-private-key+[key]:file:_files' \
                        '*--restrict-to+[pattern]:pattern:' \
                        '--upgrade-path-prefix+[upgrade path prefix]:prefix:' \
                        '--hostname+[hostname]:host:_hosts' \
                        '*--no-tls[disable TLS]' \
                        '1:listen url:' ;;
            esac
            ;;
    esac
}

_wstunnel-cli "$@"
