#compdef cfr-decompiler
# Documentation: https://github.com/leibnitz27/cfr
# CFR Java decompiler

local ret=1

_arguments -s -S \
  '--help[show help information]' \
  '--version[display version]' \
  '--outputdir[decompile to files in directory]:dir:_files -/' \
  '--outputpath[set output path]:path:_files -/' \
  '--clobber[overwrite existing files]' \
  '--silent[do not display state while decompiling]' \
  '--recover[enable recovery mode]' \
  '--eclipse[eclipse-compatible output]' \
  '--showops[display bytecode operations]' \
  '--hideutf[hide UTF characters]' \
  '--hidelongstrings[conceal lengthy strings]' \
  '--commentmonitors[add monitor comments]' \
  '--allowcorrecting[permit corrective transformations]' \
  '--labelledblocks[preserve labelled blocks]' \
  '--java4class[Java 4 compatibility mode]' \
  '--decodeenumswitch[decode enum switches]' \
  '--sugarenums[enhance enum syntax]' \
  '--decodestringswitch[decode string switches]' \
  '--decodelambdas[decode lambda expressions]' \
  '--arrayiter[array iteration syntax]' \
  '--collectioniter[collection iteration syntax]' \
  '--tryresources[try-with-resources support]' \
  '--innerclasses[inner class handling]' \
  '--forcetopsort[force topological sorting]' \
  '--comments[include comments]' \
  '--renamedupmembers[rename duplicate members]' \
  '--renameenumidents[rename enum identifiers]' \
  '--usenametable[use name tables]' \
  '--jarfilter[filter JAR contents]:filter' \
  '*:file:_files' && ret=0

return ret
