#compdef vboxautostart VBoxAutostart
# Documentation: https://man.archlinux.org/search?q=vboxautostart
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--start[start VMs]' \
  '--stop[stop VMs]' \
  '--config=+[config file]:file:_files' \
  '--logfile=+[log file]:file:_files' \
  '--logrotate=+[log rotation count]:n:' \
  '--logsize=+[max log size]:bytes:' \
  '--loginterval=+[log interval sec]:sec:' \
  '--quiet[quiet]' \
  '--verbose[verbose]' && ret=0

return ret
