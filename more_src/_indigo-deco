#compdef indigo-deco
# Documentation: https://lifescience.opensource.epam.com/indigo/utilities.html
# Indigo R-Group deconvolution utility

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-a[calculate approximate scaffold (default is exact)]' \
  '-s+[write maximum found scaffold to molfile]:file:_files' \
  '-S+[write all found scaffolds to SD-file]:file:_files' \
  '-l+[load scaffold from file instead of calculating]:file:_files' \
  '-sr+[write scaffold with R-sites to file]:file:_files' \
  '-o+[write highlighted molecules to file]:file:_files' \
  '-r+[write molecules with separated R-groups to file]:file:_files' \
  '-na[disable aromatic consideration]' \
  '*:molecule file:_files' && ret=0

return ret
