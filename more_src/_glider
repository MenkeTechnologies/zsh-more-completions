#compdef glider
# Documentation: https://man.archlinux.org/search?q=glider
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[show help]' \
  '-verbose[verbose mode]' \
  '-config=[config file]:config:_files' \
  '-listen=[listen address]:address:' \
  '-forward=[forward proxy address]:address:' \
  '-rulefile=[rule file]:file:_files' \
  '-strategy=[forward strategy]:strategy:(rr ha lha dh)' \
  '-checkwebsite=[website for connectivity check]:url:' \
  '-checkinterval=[connectivity check interval in seconds]:seconds:' \
  '-checktimeout=[connectivity check timeout in seconds]:seconds:' \
  '-checkdisabledonly[only check disabled forwarders]' \
  '-maxfailures=[max failures before disabling forwarder]:count:' \
  '-dialtimeout=[dial timeout in seconds]:seconds:' \
  '-relaytimeout=[relay timeout in seconds]:seconds:' \
  '-interface=[source IP or interface]:interface:_net_interfaces' \
  '-dns=[DNS forwarder address]:address:' \
  '-dnsserver=[DNS server address]:address:' \
  '-dnstimeout=[DNS timeout in seconds]:seconds:' \
  '-dnsrecords=[DNS records file]:file:_files' \
  '-dnsmaxttl=[max DNS TTL in seconds]:seconds:' \
  '-dnsminttl=[min DNS TTL in seconds]:seconds:' \
  '-dnscachesize=[DNS cache size]:size:' \
  '-dnsalwaystcp[always use TCP for DNS]' \
  '-dnsnoaaaa[do not query AAAA records]' \
  '*:config file:_files' && ret=0

return ret
