#compdef maskOutFa
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: produce a masked .fa from an unmasked .fa and a RepeatMasker .out or .bed

local ret=1

_arguments -s -S \
  '-soft[put masked parts in lower case, others in upper]' \
  '-softAdd[lower-case masked bits, leave others unchanged]' \
  '-clip[clip out of bounds mask records rather than dying]' \
  '-maskFormat=[out or bed for when input lacks required extension]:fmt:(out bed)' \
  '1:input fasta:_files' \
  '2:mask file or hard:_files' \
  '3:output masked fasta:_files' && ret=0

return ret
