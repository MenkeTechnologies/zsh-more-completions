#compdef chaosctl
# _chaosctl — ChaosNative chaos engineering CLI (chaosnative/chaosctl)
# upstream: https://github.com/chaosnative/chaosctl
# Subcommands from pkg/cmd/root/root.go (cobra).

_chaosctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'config:configure chaosctl context/auth'
                'connect:connect to a ChaosCenter instance'
                'create:create chaos resources (project/probe/etc.)'
                'get:list chaos resources'
                'upgrade:upgrade ChaosCenter agents/components'
                'hubgen:generate a chaos hub'
                'version:show chaosctl version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                create) _arguments '1:resource:(project agent probe)' ;;
                get) _arguments '1:resource:(projects agents probes chaos-experiment chaos-workflows)' ;;
            esac
            ;;
    esac
}

_chaosctl "$@"
