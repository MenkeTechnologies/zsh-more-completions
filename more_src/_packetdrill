#compdef packetdrill
# Documentation: https://github.com/google/packetdrill (gtests/net/packetdrill/config.c long_options)
# Reference accessed: 2026-05-30
# packetdrill — Google's TCP/UDP network stack test framework (DSL scripts test TCP/IP behavior).
# Three modes: local (default), wire_client (--wire_server_at), wire_server (--wire_server).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--ip_version=[IP version]:ver:(ipv4 ipv4-mapped-ipv6 ipv6)' \
  '--bind_port=[port for binding]:port:' \
  '--code_command=[command to execute code in script blocks]:cmd:' \
  '--code_format=[code format (e.g. python)]:fmt:(python)' \
  '--code_sockopt=[socket option to query in code blocks]:opt:' \
  '--connect_port=[port for connecting]:port:' \
  '--remote_ip=[remote IP address]:ip:' \
  '--local_ip=[local IP address (machine under test)]:ip:' \
  '--gateway_ip=[gateway IP address]:ip:' \
  '--netmask_ip=[netmask for IPv4 testing]:netmask:' \
  '--speed=[link speed in Mbps]:mbps:' \
  '--mss=[TCP MSS (Maximum Segment Size)]:bytes:' \
  '--mtu=[link MTU]:bytes:' \
  '--init_scripts=[CSV list of init script filenames]:scripts:' \
  '--tolerance_usecs=[timing tolerance in microseconds]:us:' \
  '--tolerance_percent=[timing tolerance as percentage]:pct:' \
  '(--wire_server --wire_server_at)--wire_client[enable wire client mode]' \
  '(--wire_client --wire_server)--wire_server[run as wire server]' \
  '(--wire_server)--wire_server_at=[wire server location (host:port)]:host\:port:' \
  '--wire_server_ip=[wire server IP address]:ip:' \
  '--wire_server_port=[wire server port]:port:' \
  '--wire_client_dev=[client device name]:dev:_net_interfaces' \
  '--wire_server_dev=[server device name]:dev:_net_interfaces' \
  '--so_filename=[shared object filename for SO init]:file:_files -g "*.so"' \
  '--so_flags=[flags passed to SO init function]:flags:' \
  '--tcp_ts_ecr_scaled[TCP timestamp ECR scaling]' \
  '--tcp_ts_tick_usecs=[microseconds per TCP timestamp tick]:us:' \
  '--strict_segments[enforce strict segment checking]' \
  '--non_fatal=[non-fatal error types (CSV)]:types:' \
  '--dry_run[execute without side effects]' \
  '--is_anyip[use anyip mode]' \
  '--send_omit_free[omit free in send path]' \
  '--psp_udp_port=[UDP port for PSP packets]:port:' \
  '--debug[enable debug output]' \
  '*'{-D,--define=}'[define symbol (e.g. symbol=value; repeatable)]:def:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:packetdrill script:_files -g "*.pkt"' \
  && ret=0

return ret
