#compdef otbcli_ZonalStatistics
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ZonalStatistics.html
# Orfeo ToolBox: compute zonal statistics from an image over vector or label zones

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input multiband image]:image:_files' \
  '-inbv[background value to ignore]:value:' \
  '-inzone[type of input for zone definitions]:type:(vector labelimage)' \
  '-inzone.vector.in[input vector data file]:vector:_files' \
  '-inzone.vector.reproject[reproject the input vector]:bool:(true false)' \
  '-inzone.labelimage.in[input label image]:image:_files' \
  '-inzone.labelimage.nodata[no-data value for label image]:value:' \
  '-out[format of the output statistics]:format:(vector xml raster)' \
  '-out.vector.filename[output vector data filename]:output:_files' \
  '-out.xml.filename[output XML filename]:output:_files' \
  '-out.raster.filename[output raster image filename]:output:_files' \
  '-out.raster.bv[background value for output raster]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
