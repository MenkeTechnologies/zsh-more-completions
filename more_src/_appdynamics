#compdef appdynamics appdctl
# _appdynamics — Cisco AppDynamics appdctl admin CLI (Cisco, Java); custom argparse
# upstream: https://github.com/CiscoDevNet/appdynamics-cli

_appdynamics() {
    local -a sub=(
        'start:start controller/EUM server'
        'stop:stop service'
        'status:show service status'
        'restart:restart service'
        'login:authenticate'
        'logout:logout'
        'config:manage config'
        'application:manage applications'
        'tier:manage tiers'
        'node:manage nodes'
        'business-transaction:manage business transactions'
        'metric:query metric data'
        'event:query events'
        'snapshot:fetch snapshots'
        'health-rule:manage health rules'
        'policy:manage policies'
        'action:manage actions'
        'dashboard:manage dashboards'
        'controller:manage controller'
        'license:manage license'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--controller-host=+[controller host]:host:_hosts' \
        '--controller-port=+[controller port]:port:' \
        '--account=+[account name]:str:' \
        '--user=+[user]:str:_users' \
        '--password=+[password]:str:' \
        '--api-token=+[api token]:str:' \
        '--ssl[use SSL]' \
        '--insecure[skip tls verify]' \
        '--output=+[output]:fmt:(json yaml table csv)' \
        '-o+[output]:fmt:(json yaml table csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appdynamics subcommand' sub ;;
        args)
            case $words[1] in
                application|tier|node|business-transaction|health-rule|policy|action|dashboard) _arguments \
                    '1:cmd:(list get create update delete)' \
                    '*:arg:' ;;
                metric) _arguments \
                    '1:cmd:(get list browse)' \
                    '--application=+[application]:str:' \
                    '--metric-path=+[metric path]:str:' \
                    '--time-range-type=+[time range type]:t:(BEFORE_NOW BEFORE_TIME AFTER_TIME BETWEEN_TIMES)' \
                    '--duration-in-mins=+[duration in mins]:n:' ;;
                event) _arguments \
                    '1:cmd:(get list)' \
                    '--application=+[application]:str:' \
                    '--event-types=+[event types csv]:list:' \
                    '--severity=+[severities csv]:list:' ;;
                snapshot) _arguments \
                    '1:cmd:(get list)' \
                    '--application=+[application]:str:' \
                    '--time-range-type=+[time range type]:t:(BEFORE_NOW)' ;;
                start|stop|restart|status) _arguments \
                    '1:service:(controller eum events appserver elasticsearch reports analytics)' ;;
            esac
            ;;
    esac
}

_appdynamics "$@"
