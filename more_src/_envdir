#compdef envdir
# _envdir — daemontools envdir (set/clear environment variables from a directory of files named after the variables, then exec child; standard DJB run-script idiom)
# upstream: https://github.com/schmonz/daemontools-encore
# Flags from envdir.8 on tip.

_envdir() {
    _arguments \
        '-p+[prefix all variable names]:prefix:' \
        '1:env-dir:_files -/' \
        '*::child:_command_names -e'
}

_envdir "$@"
