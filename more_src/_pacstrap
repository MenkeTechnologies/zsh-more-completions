#compdef pacstrap
# Documentation: https://man.archlinux.org/search?q=pacstrap
# Reference accessed: 2026-05-16

_arguments -s \
  '-C[alternate pacman config]:file:_files' \
  '-c[use host package cache]' \
  '-D[skip dependency checks]' \
  '-G[do not copy host pacman keyring]' \
  '-i[interactive]' \
  '-K[initialize empty keyring]' \
  '-M[do not copy host mirrorlist]' \
  '-N[run via unshare]' \
  '-P[copy host pacman config]' \
  '-U[install via pacman -U]' \
  '(- *)-h[show help]' \
  ':root:_files -/' \
  '*:package:'
