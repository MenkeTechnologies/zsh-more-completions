#compdef twisst twisst.py
# Documentation: https://github.com/simonhmartin/twisst
# twisst: topology weighting by iterative sampling of subtrees.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-t+[input tree file (newick)]:file:_files' \
  '-w+[output weights file]:file:_files' \
  '*-g+[group name and members]:group:' \
  '-o+[output topologies file]:file:_files' \
  '--groupsFile=[tab-delimited tip-to-group map]:file:_files' \
  '--method=[weighting method]:method:(complete fixed)' \
  '--iterations=[random subtree samples (fixed method)]:n:' \
  '--abortCutoff=[cutoff to revert complete to fixed]:n:' \
  '--outgroup=[outgroup taxon]:taxon:' && ret=0

return ret
