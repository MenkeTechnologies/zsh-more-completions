#compdef stap-prep
# Documentation: https://man.archlinux.org/search?q=stap-prep
# Reference accessed: 2026-05-16

# stap-prep: helper to install kernel debug packages for SystemTap
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*::stap-prep args:_files' && ret=0
return ret
