#compdef stap-prep
# Documentation: https://sourceware.org/systemtap/man/stap-prep.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# stap-prep: helper to install kernel debug packages for SystemTap.
# Accepts only an optional KERNEL_VERSION positional argument (no flags).

local curcontext="$curcontext" ret=1
_arguments -C \
  '1::kernel version:' && ret=0
return ret
