#compdef dmsetup

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'clear:remove device-mapper table'
  'create:create a device-mapper device'
  'deps:show dependencies'
  'help:show help'
  'info:show device info'
  'ls:list devices'
  'load:load a table'
  'mangle:mangle device names'
  'measure:measure device'
  'message:send message to a target'
  'mknodes:create device nodes'
  'reload:reload table'
  'remove:remove a device'
  'remove_all:remove all devices'
  'rename:rename a device'
  'resume:resume a device'
  'setgeometry:set device geometry'
  'splitname:split device name'
  'stats:device-mapper statistics'
  'status:show device status'
  'suspend:suspend a device'
  'table:show table'
  'targets:show targets'
  'udevcomplete:complete udev event'
  'udevcomplete_all:complete all udev events'
  'udevcookies:list udev cookies'
  'udevcreatecookie:create udev cookie'
  'udevreleasecookie:release udev cookie'
  'udevflags:show udev flags'
  'version:show version'
  'wait:wait for event'
  'wipe_table:wipe table'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-c -C --columns)'{-c,-C,--columns}'[columnar output]' \
  '(-f --force)'{-f,--force}'[force]' \
  '(-j --major)'{-j,--major=}'[major number]:major:' \
  '(-m --minor)'{-m,--minor=}'[minor number]:minor:' \
  '(-n --notable)'{-n,--notable}'[create with no table]' \
  '(-o --options)'{-o,--options=}'[output fields]:fields:' \
  '(-O --sort)'{-O,--sort=}'[sort fields]:fields:' \
  '(-r --readonly)'{-r,--readonly}'[read-only mode]' \
  '(-S --select)'{-S,--select=}'[selection]:expr:' \
  '(-u --uuid)'{-u,--uuid=}'[UUID]:uuid:' \
  '(-y --yes)'{-y,--yes}'[answer yes to prompts]' \
  '--addnodeoncreate[add nodes on create]' \
  '--addnodeonresume[add nodes on resume]' \
  '--checks[run checks]' \
  '--concise[concise output/spec]' \
  '--count=[iteration count]:n:' \
  '--deferred[deferred]' \
  '--exec=[command]:cmd:' \
  '--inactive[inactive table]' \
  '--interval=[interval seconds]:secs:' \
  '--manglename=[mangle mode]:mode:(auto hex none)' \
  '--nameprefixes[prefix names]' \
  '--noheadings[no headings]' \
  '--noflush[no flush]' \
  '--nolockfs[no lock fs]' \
  '--noopencount[no open count]' \
  '--noudevrules[no udev rules]' \
  '--noudevsync[no udev sync]' \
  '--readahead=[readahead spec]:spec:' \
  '--retry[retry on failure]' \
  '--separator=[separator]:sep:' \
  '--setuuid=[set UUID]:uuid:' \
  '--showkeys[show keys]' \
  '--table=[table spec]:table:' \
  '--target=[target type]:type:' \
  '--tree[tree view]' \
  '--udevcookie=[udev cookie]:cookie:' \
  '--verifyudev[verify udev]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dmsetup subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (stats)
        _values 'stats action' \
          'clear' 'create' 'delete' 'list' 'print' 'report' 'group' 'ungroup' && ret=0
        ;;
    esac
    ;;
esac

return ret
