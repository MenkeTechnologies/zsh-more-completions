#compdef selfcal
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/selfcal.html
# MIRIAD selfcal - antenna-based self-calibration

local ret=1

_arguments -s -S \
  'vis=[input visibility data file]:vis:_files' \
  'select=[uv data selection criteria]:select' \
  'model=[input model image(s) (Jy/pixel)]:model:_files' \
  'clip=[threshold; pixels below are zeroed]:clip' \
  'interval=[gain solution interval in minutes]:interval' \
  'nfbin=[number of frequency bins]:nfbin' \
  'minants=[minimum antenna count to retain data]:minants' \
  'refant=[reference antenna with zero phase]:refant' \
  'flux=[point source flux density in Jy]:flux' \
  'offset=[point source offset in arcsec]:offset' \
  'line=[visibility line type]:line' \
  'options=[amplitude,phase,mfs,mmfs,relax,noscale,mosaic]:options' \
  '*:visibility data:_files' && ret=0

return ret
