#compdef netToAxt
# UCSC kent: convert net (and chain) to axt

local ret=1

_arguments -s -S \
  '-qChain[net is with respect to the q side of chains]' \
  '-maxGap=[maximum size of gap before breaking (default 100)]:n' \
  '-gapOut=[output gap sizes to file]:file:_files' \
  '-noSplit[do not split chain at insertion of another chain]' \
  '1:input net:_files -g "*.net"' \
  '2:input chain:_files -g "*.chain"' \
  '3:target 2bit:_files -g "*.2bit"' \
  '4:query 2bit:_files -g "*.2bit"' \
  '5:output axt:_files -g "*.axt"' && ret=0

return ret
