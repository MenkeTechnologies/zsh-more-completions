#compdef texturepacker TexturePacker
# Documentation: https://www.codeandweb.com/texturepacker/documentation
# Create sprite sheets / texture atlases from the command line

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--format=[set the data format / framework]:format' \
  '--data=[output file for metadata]:file:_files' \
  '--sheet=[output texture file name]:file:_files' \
  '--texturepath=[prepend path to texture file name]:path:_files -/' \
  '--trim-sprite-names[remove image file extensions from sprite names]' \
  '--prepend-folder-name[include folder name in sprite name]' \
  '--enable-cache-busting[add hash query string to texture references]' \
  '--texture-format=[image format]:fmt:(png png8 jpg webp pvr3 ktx dds)' \
  '--png-opt-level=[PNG optimization level (0-7)]:level' \
  '--jpg-quality=[JPEG quality (0-100)]:quality' \
  '--webp-quality=[WebP quality (0-100)]:quality' \
  '--pixel-format=[pixel encoding]:fmt:(RGBA8888 RGBA4444 RGB565 RGBA5551)' \
  '--dither-type=[dithering algorithm]:type:(NearestNeighbour FloydSteinberg Atkinson)' \
  '--max-width=[maximum texture width]:px' \
  '--max-height=[maximum texture height]:px' \
  '--max-size=[set both width and height limits]:px' \
  '--width=[fixed texture width]:px' \
  '--height=[fixed texture height]:px' \
  '--size-constraints=[size constraint]:c:(POT MultipleOf4 WordAligned AnySize)' \
  '--force-squared[force square dimensions]' \
  '--scale=[scale factor for sprites]:factor' \
  '--scale-mode=[scaling algorithm]:mode:(Smooth Fast Scale2x Hq2x)' \
  '--algorithm=[packing algorithm]:algo:(Polygon MaxRects Grid Basic)' \
  '--pack-mode=[size search intensity]:mode:(Fast Good Best)' \
  '--multipack[create multiple sheets automatically]' \
  '--enable-rotation[allow 90 degree sprite rotation]' \
  '--disable-rotation[disallow sprite rotation]' \
  '--disable-auto-alias[disable identical sprite detection]' \
  '--trim-mode=[transparency removal mode]:mode:(None Trim CropKeepPos Crop Polygon)' \
  '--trim-margin=[transparent margin after trimming]:px' \
  '--trim-threshold=[alpha threshold for transparency (1-255)]:value' \
  '--extrude=[repeat border pixels]:px' \
  '--border-padding=[space around sheet border]:px' \
  '--shape-padding=[space between sprites]:px' \
  '--padding=[combined shape and border padding]:px' \
  '*:image:_files' && ret=0

return ret
