#compdef bsondump
# Documentation: https://www.mongodb.com/docs/database-tools/bsondump/
# Source: MongoDB Database Tools — convert BSON files to JSON / debug format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '--quiet[quiet mode]' \
    '(- *)--version[show version]' \
    '--objcheck[validate each BSON object before output]' \
    '--type=[output format]:type:(json debug)' \
    '--pretty[pretty-printed JSON]' \
    '--bsonFile=[input BSON file]:file:_files' \
    '--outFile=[output JSON file]:file:_files' \
    '*:.bson file:_files -g "*.bson"' \
    && ret=0

return ret
