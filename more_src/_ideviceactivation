#compdef ideviceactivation
# _ideviceactivation — libimobiledevice ideviceactivation handle iOS device activation CLI (libimobiledevice team, C); custom argparse
# upstream: https://github.com/libimobiledevice/ideviceactivation

_ideviceactivation() {
    local -a sub=(
        'activate:activate device'
        'deactivate:deactivate device'
        'state:show activation state'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--udid=+[device UDID]:str:' \
        '-u+[device UDID]:str:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--network[connect over network]' \
        '-n[connect over network]' \
        '--service-url=+[activation service URL]:url:_urls' \
        '-s+[activation service URL]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ideviceactivation subcommand' sub ;;
        args)
            case $words[1] in
                activate) _arguments \
                    '--file=+[activation record file]:file:_files' \
                    '-f+[activation record file]:file:_files' ;;
            esac
            ;;
    esac
}

_ideviceactivation "$@"
