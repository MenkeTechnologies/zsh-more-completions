#compdef crowdsec

# Zsh completion for crowdsec - collaborative security engine

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files -g "*.yaml *.yml"' \
  '(-t --type)'{-t,--type}'[type of acquisition]:type:(syslog file journalctl cloudwatch kinesis docker)' \
  '--dsn=[data source name]:DSN' \
  '(-i --info)'{-i,--info}'[display info about crowdsec]' \
  '--no-cs[disable CrowdSec Engine]' \
  '--no-capi[disable CAPI]' \
  '--no-api[disable local API]' \
  '-debug[set logging to debug]' \
  '-info[set logging to info]' \
  '-warning[set logging to warning]' \
  '-error[set logging to error]' \
  '-trace[set logging to trace]' \
  '--cpu-profile=[write CPU profile to file]:file:_files' \
  '*:file or DSN' && ret=0

return ret
