#compdef rhpict

# Radiance rhpict: holodeck-based image rendering
local curcontext="$curcontext" ret=1
_arguments -C \
  '-vf[view file]:file:_files' \
  '-vp[view point]:x y z:' \
  '-vd[view direction]:x y z:' \
  '-vu[view up]:x y z:' \
  '-vt[view type]:type:(v l a h s c)' \
  '-x[image width]:n:' \
  '-y[image height]:n:' \
  '-i[irradiance mode]' \
  '-o[output picture]:file:_files' \
  '-pf[pixel filter]:file:_files' \
  '-pa[pixel aspect ratio]:val:' \
  '*:holodeck file and oct:_files -g "*.(hdk|oct)"' && ret=0
return ret
