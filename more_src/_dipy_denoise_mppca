#compdef dipy_denoise_mppca
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_denoise_mppca.html
# DIPY: Marcenko-Pastur PCA (MPPCA) denoising

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--patch_radius=[radius of the local patch around each voxel]:radius' \
  '--pca_method=[PCA decomposition method]:method:(eig svd)' \
  '--return_sigma=[return noise standard deviation estimate]:bool:(True False)' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_denoised=[name of the resulting denoised volume]:file:_files' \
  '--out_sigma=[name of the resulting sigma volume]:file:_files' \
  '*:input volumes:_files' && ret=0

return ret
