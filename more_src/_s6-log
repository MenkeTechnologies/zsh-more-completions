#compdef s6-log

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[use blocking writes]' \
  '-p[set logging mode to pipe mode]' \
  '-t[prefix each line with a TAI64N timestamp]' \
  '-T[prefix each line with an ISO 8601 timestamp]' \
  '-e[log to stderr as well]' \
  '-d[set notify readiness fd]:fd number' \
  '-q[suppress warnings]' \
  '-v[verbose mode]' \
  '*:logging script or directory:_files -/' && ret=0

return ret
