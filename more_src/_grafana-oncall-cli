#compdef grafana-oncall-cli grafana-oncall
# _grafana-oncall-cli — Grafana Labs grafana-oncall-cli CLI command-line frontend wrapping the Grafana OnCall open-source alerting incident response and on-call management platform forked from amixr OnCall providing alert escalation policy schedule rotation integration team user notification channel route Slack Telegram MS-Teams call SMS phone-app MobileApp open-source API (Grafana Labs team, Python); custom argparse
# upstream: https://grafana.com/oncall/

_grafana-oncall-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'alert-group:alert group operations'
        'integration:integration operations'
        'escalation-chain:escalation chain operations'
        'escalation-policy:escalation policy operations'
        'schedule:schedule operations'
        'rotation:rotation operations'
        'on-call-shift:on-call shift operations'
        'user:user operations'
        'team:team operations'
        'webhook:webhook operations'
        'route:route operations'
        'slack-channel:Slack channel operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--api-key=+[key]:str:' \
        '--organization=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grafana-oncall subcommand' sub ;;
        args)
            case $words[1] in
                alert-group|integration|escalation-chain|escalation-policy|schedule|rotation|on-call-shift|user|team|webhook|route|slack-channel) _arguments '1:op:(list get create update delete acknowledge resolve silence unresolve)' '*:id:' ;;
            esac
            ;;
    esac
}

_grafana-oncall-cli "$@"
