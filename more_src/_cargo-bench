#compdef cargo-bench

# Zsh completion for cargo-bench (Rust benchmarks)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-p+[package to benchmark]:package' \
  '--package=[package to benchmark]:package' \
  '--all[benchmark all packages in workspace]' \
  '--workspace[benchmark all packages in workspace]' \
  '--exclude=[exclude packages]:package' \
  '--lib[benchmark library]' \
  '--bin=[benchmark specified binary]:binary' \
  '--bins[benchmark all binaries]' \
  '--example=[benchmark specified example]:example' \
  '--examples[benchmark all examples]' \
  '--test=[benchmark specified test target]:test' \
  '--tests[benchmark all tests]' \
  '--bench=[benchmark specified bench target]:bench' \
  '--benches[benchmark all bench targets]' \
  '--all-targets[benchmark all targets]' \
  '-j+[number of parallel jobs]:jobs' \
  '--jobs=[number of parallel jobs]:jobs' \
  '--features=[space-separated list of features]:features' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '--target=[target triple]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--message-format=[error format]:format:(human json short)' \
  '--no-run[compile but do not run benchmarks]' \
  '--no-fail-fast[run all benchmarks regardless of failure]' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock is up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '*:benchmark name or filter'
