#compdef datahub

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'actions:DataHub Actions framework operations'
  'check:run sanity checks'
  'container:operations on containers'
  'dataproduct:operations on data products'
  'dataset:operations on datasets'
  'delete:delete entities by URN or filter'
  'docker:run DataHub locally with docker'
  'exists:check if an entity exists'
  'forms:operations on forms'
  'get:get an entity by URN'
  'graphql:run a GraphQL query'
  'group:operations on groups'
  'ingest:run a metadata ingestion recipe'
  'init:initialize a DataHub config'
  'lite:lightweight DataHub local server'
  'migrate:migrate metadata between DataHub instances'
  'properties:manage structured properties'
  'put:upsert metadata onto an entity'
  'search:run a search query'
  'state:state management for ingestion'
  'telemetry:manage telemetry'
  'timeline:show change timeline for an entity'
  'user:operations on users'
  'version:show DataHub CLI version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '--no-debug[disable debug logging]' \
  '--log-file=[log file]:file:_files' \
  '--debug-vars[debug variable resolution]' \
  '--no-debug-vars[disable debug variable resolution]' \
  '(-dl --detect-memory-leaks)'{-dl,--detect-memory-leaks}'[detect memory leaks]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'datahub subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (docker)
        _values 'docker action' \
          'quickstart' 'check' 'nuke' 'ingest-sample-data' && ret=0
        ;;
      (ingest)
        _values 'ingest action' \
          'run' 'list-source-runs' 'mcps' 'rollback' 'show' 'list-runs' && ret=0
        ;;
      (delete)
        _values 'delete action' \
          'by-filter' 'by-registry' 'references' 'undo-by-filter' && ret=0
        ;;
      (lite)
        _values 'lite action' \
          'init' 'serve' 'destroy' 'reindex' && ret=0
        ;;
      (group|user|container|dataset|dataproduct)
        _values 'action' 'add' 'list' 'remove' 'upsert' 'get' && ret=0
        ;;
      (telemetry)
        _values 'telemetry action' 'enable' 'disable' && ret=0
        ;;
      (forms)
        _values 'forms action' 'upsert' && ret=0
        ;;
      (properties)
        _values 'properties action' \
          'upsert' 'get' 'list' && ret=0
        ;;
    esac
    ;;
esac

return ret
