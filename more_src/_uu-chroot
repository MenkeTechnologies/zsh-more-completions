#compdef uu-chroot
# Documentation: https://github.com/uutils/coreutils/blob/main/src/uu/chroot/src/chroot.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Source: Homebrew bottle (clap_complete output from uutils-coreutils)
# Formula: uutils-coreutils

autoload -U is-at-least

_uu-chroot() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--groups=[Comma-separated list of groups to switch to]:GROUP1,GROUP2...:_default' \
'--userspec=[Colon-separated user and group to switch to.]:USER:GROUP:_default' \
'--skip-chdir[Use this option to not change the working directory to / after changing the root directory to newroot, i.e., inside the chroot.]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':newroot:_files -/' \
'::command:_command_names -e' \
&& ret=0
}

(( $+functions[_uu-chroot_commands] )) ||
_uu-chroot_commands() {
    local commands; commands=()
    _describe -t commands 'uu-chroot commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-chroot" ]; then
    _uu-chroot "$@"
else
    compdef _uu-chroot uu-chroot
fi
