#compdef h264enc h264dec openh264 h264 h264-codec
# _openh264 — Cisco openh264 reference H.264 AVC encoder h264enc and decoder h264dec implementation (cisco team, C++); custom argparse
# upstream: https://github.com/cisco/openh264

_openh264() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input config]:file:_files -g "*.cfg *.txt *.yuv"' \
        '--input=+[input config]:file:_files -g "*.cfg *.txt *.yuv"' \
        '-o+[output file]:file:_files -g "*.264 *.h264 *.bin *.yuv"' \
        '--output=+[output file]:file:_files -g "*.264 *.h264 *.bin *.yuv"' \
        '-numl+[num layers]:n:' \
        '-utype+[unit type]:str:' \
        '-frms+[N frames]:n:' \
        '-frin+[frame rate]:f:' \
        '-frout+[output frame rate]:f:' \
        '-numtl+[temporal layers]:n:' \
        '-sw+[width]:n:' \
        '-sh+[height]:n:' \
        '-frout+[output frame rate]:f:' \
        '-rc+[rate control]:m:(0 1 2 3)' \
        '-tarb+[target bitrate kbps]:n:' \
        '-maxbrTotal+[max bitrate kbps]:n:' \
        '-iper+[I-frame period]:n:' \
        '-spsid+[SPS id]:n:' \
        '-ppsid+[PPS id]:n:' \
        '-denois+[denoise]:b:(0 1)' \
        '-bgd+[bg detection]:b:(0 1)' \
        '-aq+[AQ mode]:b:(0 1)' \
        '-ltr+[LTR]:b:(0 1)' \
        '-ltrnum+[N LTR]:n:' \
        '-trace+[trace level]:n:' \
        '-th+[N threads]:n:' \
        '-loss+[packet loss rate]:f:' \
        '-prl+[prefer reliability]:b:(0 1)' \
        '-poc+[POC]:b:(0 1)' \
        '-deblock+[deblock]:b:(0 1)' \
        '-cabac+[entropy]:b:(0 1)' \
        '-ec[enable error concealment]'
}

_openh264 "$@"
