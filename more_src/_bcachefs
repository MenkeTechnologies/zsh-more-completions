#compdef bcachefs

# Zsh completion for bcachefs filesystem tools

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'format:format one or more devices as a bcachefs filesystem'
      'show-super:print superblock information'
      'mount:mount a bcachefs filesystem'
      'fsck:check and repair a bcachefs filesystem'
      'device:manage devices in a bcachefs filesystem'
      'subvolume:manage subvolumes'
      'snapshot:manage snapshots'
      'data:manage data operations'
      'encryption:manage filesystem encryption'
      'migrate:migrate an existing filesystem to bcachefs'
      'dump:dump filesystem metadata'
      'list:list filesystem objects'
      'list_journal:list journal entries'
      'set-option:set filesystem options'
      'reset-counters:reset filesystem counters'
      'version:display version'
      'completions:generate shell completions'
    )
    _describe -t commands 'bcachefs command' commands && ret=0
    ;;
  args)
    case $line[1] in
      format)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-L+[filesystem label]:label' \
          '--label=[filesystem label]:label' \
          '-U+[filesystem UUID]:uuid' \
          '--uuid=[filesystem UUID]:uuid' \
          '--block_size=[block size]:size' \
          '--btree_node_size=[btree node size]:size' \
          '--errors=[error handling mode]:mode:(continue ro panic)' \
          '--data_checksum=[data checksum type]:type:(none crc32c crc64 xxhash)' \
          '--metadata_checksum=[metadata checksum type]:type:(none crc32c crc64 xxhash)' \
          '--compression=[compression algorithm]:algo:(none lz4 gzip zstd)' \
          '--background_compression=[background compression]:algo:(none lz4 gzip zstd)' \
          '--replicas=[number of data replicas]:num' \
          '--metadata_replicas=[number of metadata replicas]:num' \
          '--encrypted[enable encryption]' \
          '--no_passphrase[do not use passphrase]' \
          '--durability=[data durability]:num' \
          '--discard[enable discard/TRIM]' \
          '-f[force format]' \
          '--force[force format]' \
          '-q[quiet]' \
          '--quiet[quiet]' \
          '*:device:_files' && ret=0
        ;;
      mount)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[mount options]:options' \
          '-v[verbose]' \
          '--verbose[verbose]' \
          '-n[do not actually mount]' \
          '1:device:_files' \
          '2:mountpoint:_directories' && ret=0
        ;;
      fsck)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-n[do not repair, check only]' \
          '-y[assume yes to all questions]' \
          '-f[force check]' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '*:device:_files' && ret=0
        ;;
      show-super)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[fields to show]:fields' \
          '--fields=[fields to show]:fields' \
          '-l+[layout]:layout' \
          '--layout=[layout]:layout' \
          '1:device:_files' && ret=0
        ;;
      device)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add remove online offline evacuate set-state resize)' && ret=0
        ;;
      subvolume)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create delete snapshot)' && ret=0
        ;;
      encryption)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(unlock set-passphrase disable)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
