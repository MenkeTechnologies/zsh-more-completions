#compdef dns-query
# ============================================================================
# dns-query - DNS-over-HTTPS + plain DNS query
#              CLI for Node + Browser
#              (TypeScript/Node, MIT)
#
# Author : Martin Heidegger (martinheidegger /
#           leichtgewicht) + dnsquery org
# Upstream: https://github.com/dnsquery/dns-query
# npm pkg : dns-query
#
# `dns-query` is a programmatic + command-line
# DNS-over-HTTPS (DoH) query client that runs
# in both Node and browsers. The CLI accepts
# DNS queries as JSON, base64-encoded binary
# DNS packets, or raw binary, and dispatches
# them to known DoH endpoints (Cloudflare +
# Google + Quad9 + AdGuard + many others) or
# plain DNS (UDP). Returns DNS responses in
# the same format families.
#
# Distinguishing features vs alternatives
# (dig + drill + kdig + delv + native node:
# dns):
#   - **Non-JSON DoH** (RFC 8484 wireformat
#     DoH; many DoH clients only speak the
#     Google + Cloudflare JSON API)
#   - **Auto-discovered endpoint list**
#     (queries https://dnscry.pt or a
#     similar registry for the current
#     list of public DoH endpoints; updates
#     automatically with --no-persist /
#     --offline controls)
#   - **Endpoint random selection** (load-
#     balances across multiple DoH
#     providers per query for privacy)
#   - **Browser-compatible** (the same
#     library runs in browsers via fetch();
#     the CLI is a thin wrapper)
#   - **Minimal dependencies** (only 5
#     @leichtgewicht/* sub-libraries; no
#     heavyweight HTTP client like axios)
#   - **TXT shortcut mode** (--mode=txt
#     does a TXT lookup with one argument
#     for the common dnslink-style queries)
#   - **Binary format support** (--base64 +
#     --binary input/output for protocol-
#     level DNS message manipulation)
#
# Use cases:
#   - Test DoH endpoints for compatibility
#     (verify a self-hosted Pi-hole DoH
#     proxy is wire-compliant)
#   - Bypass local DNS censorship via DoH
#     (DoH bypasses ISP DNS hijacking +
#     DPI-based DNS blocking)
#   - Privacy-preserving DNS lookups
#     (rotates across multiple DoH
#     providers; no single provider sees
#     all queries)
#   - Debug DNSlink TXT records (--mode=
#     txt is convenient for dnslink-style
#     `_dnslink.<host>` TXT queries)
#   - Test DNSSEC responses via DoH
#     (--binary returns the raw wire
#     format for protocol-level inspection)
#
# Usage:
#   dns-query [options] <input>
#
# Modes:
#   --mode=free                    - free
#                                     query
#                                     input
#                                     (default;
#                                     accepts
#                                     JSON +
#                                     base64 +
#                                     binary
#                                     DNS
#                                     packet)
#   --mode=txt                     - TXT data
#                                     loading
#                                     shortcut
#                                     (one
#                                     domain
#                                     name
#                                     argument
#                                     does a
#                                     TXT
#                                     lookup)
#
# Input types:
#   --json                         - input is
#                                     JSON
#                                     (alias
#                                     for
#                                     --type=
#                                     json;
#                                     default)
#   --base64                       - input is
#                                     base64-
#                                     encoded
#                                     binary
#                                     (alias
#                                     for
#                                     --type=
#                                     base64)
#   --binary                       - input is
#                                     raw
#                                     binary
#                                     (alias
#                                     for
#                                     --type=
#                                     binary)
#   --type <type>                  - explicit
#                                     input
#                                     type
#                                     (json +
#                                     base64 +
#                                     binary;
#                                     default
#                                     json)
#   --out <type>                   - output
#                                     type
#                                     (defaults
#                                     to
#                                     --type)
#   --stdin                        - get
#                                     <input>
#                                     from
#                                     stdin
#                                     instead
#                                     of CLI
#                                     argument
#
# DNS transport:
#   --dns                          - use plain
#                                     DNS
#                                     (UDP)
#                                     endpoints
#                                     instead
#                                     of DoH
#   --doh                          - use DoH
#                                     endpoints
#                                     (default
#                                     behavior)
#
# Endpoint selection:
#   --endpoint <e>, -e <e>         - use a
#                                     specific
#                                     endpoint
#                                     (name +
#                                     JSON
#                                     object +
#                                     URL;
#                                     random
#                                     selection
#                                     from
#                                     comma-
#                                     separated
#                                     list)
#   --endpoints                    - list all
#                                     known
#                                     endpoints
#                                     as JSON
#                                     (does
#                                     not run
#                                     a query)
#   --resolvers                    - list all
#                                     known
#                                     resolvers
#                                     as JSON
#                                     (does
#                                     not run
#                                     a query)
#
# Query behavior:
#   --response                     - show the
#                                     HTTP
#                                     response
#                                     in the
#                                     result
#                                     (DoH
#                                     mode
#                                     only)
#   --retries <n>                  - number of
#                                     retries
#                                     on
#                                     failure
#                                     (default
#                                     5)
#   --timeout <ms>                 - request
#                                     timeout
#                                     in ms
#                                     (default
#                                     30000)
#
# Endpoint registry:
#   --max-age <ms>                 - max age
#                                     of
#                                     persisted
#                                     endpoint
#                                     data
#                                     (default
#                                     300000;
#                                     5
#                                     minutes)
#   --no-persist                   - do not
#                                     persist
#                                     the
#                                     latest
#                                     resolvers
#                                     to local
#                                     cache
#   --offline                      - do not
#                                     update
#                                     the
#                                     resolver
#                                     list
#                                     (use
#                                     cached
#                                     resolvers
#                                     only)
#
# Help + version:
#   -h, --help                     - show help
#   -v, --version                  - show
#                                     version
#
# Example invocations:
#   # Fetch A-record for google.com via
#   # Google's DoH endpoint
#   dns-query --json -e google \
#     '{"question":{"type":"A","name":"google.com"}}'
#
#   # Fetch TXT records for ipfs.io via plain DNS
#   dns-query --json --dns \
#     '{"question":{"type":"TXT","name":"ipfs.io"}}'
#
#   # Read query from stdin (Cloudflare)
#   echo '{"question":{"type":"A","name":"google.com"}}' | \
#     dns-query --stdin --endpoint cloudflare
#
#   # Process binary DNS packet as base64
#   dns-query --base64 AAAAAAABAAAAAAAABGlwZnMCaW8AABAAAQ==
#
#   # TXT shortcut for dnslink resolution
#   dns-query --mode=txt ipfs.io
#
#   # List all known DoH endpoints
#   dns-query --endpoints
#
#   # List all known resolvers
#   dns-query --resolvers
#
#   # Query AdGuard DoH with TXT shortcut
#   dns-query --mode=txt -e adguard example.com
#
#   # Try multiple endpoints with random pick
#   dns-query --json \
#     -e 'cloudflare,quad9,google' \
#     '{"question":{"type":"A","name":"github.com"}}'
#
#   # Force offline mode (use cached resolvers)
#   dns-query --offline --mode=txt example.com
#
# The @leichtgewicht/dns-packet lane is built
# on `@leichtgewicht/dns-packet: ^6.0.2`
# (declared verbatim at upstream package.json
# HEAD as a direct dep, imported by `bin/dns-
# query` for DNS message wire-format encoding
# + decoding of queries + responses), the
# canonical Node DNS packet library by
# Mathias Buus (mafintosh) + Martin
# Heidegger (leichtgewicht fork
# maintainer) - github.com/mafintosh/dns-
# packet + github.com/leichtgewicht/dns-
# packet.
#
# mafintosh/dns-packet is the de-facto
# canonical Node DNS wire-format library:
#   - **Pure JavaScript implementation**
#     (no native bindings; runs in Node +
#     browsers + Deno + Cloudflare
#     Workers)
#   - **Full DNS wire format coverage**
#     (RFC 1035 + extensions for EDNS0 +
#     DNSSEC RR types + most registered
#     RR types)
#   - **Streaming encode/decode**
#     (incremental parsing for DNS-over-
#     TCP message stream)
#   - **No resolver layer** (focused on
#     wire format only; resolvers built
#     on top via dns-socket +
#     dns-over-http + dns-over-tls
#     companion libs)
#   - **2,000,000+ weekly npm downloads
#     as `dns-packet` package**
#     (the canonical Node DNS encoder;
#     pulled in by every Node DNS tool)
#   - 380+ stars on github.com/mafintosh/
#     dns-packet
#
# mafintosh/dns-packet's distinguishing
# position vs Node DNS alternatives:
#   - mafintosh/dns-packet (Buus +
#     leichtgewicht fork): canonical;
#     pure-JS; THIS AXIS
#   - native-dns-packet (tjfontaine):
#     older alternative; predates dns-
#     packet; less actively maintained
#   - dnsv2: alternative; smaller scope
#   - dns2 (song940): combined wire +
#     resolver; broader scope but less
#     standardized
#
# Mathias Buus (mafintosh) is one of the
# most prolific Node.js authors in the
# decentralized + P2P + streaming space.
# His broader Node ecosystem footprint:
#   - mafintosh/dns-packet (canonical Node
#     DNS wire format; THIS AXIS)
#   - mafintosh/dns-socket (DNS-over-UDP
#     transport)
#   - mafintosh/dns-stream (streaming
#     DNS interface)
#   - mafintosh/hypercore (the
#     foundational P2P append-only log;
#     basis of the Dat protocol +
#     Hyperdrive)
#   - mafintosh/torrent-stream (canonical
#     Node BitTorrent client lib)
#   - mafintosh/duplexify (canonical Node
#     duplex stream helper)
#   - mafintosh/pump (canonical Node
#     stream pipeline helper; predates
#     stream.pipeline)
#   - mafintosh/tar-stream + tar-fs
#     (canonical Node tar streaming)
#   - mafintosh/dns-discovery (DNS-SD
#     service discovery)
#   - mafintosh/mdns (mDNS for service
#     discovery)
#
# Buus's role in Node is *foundational
# streaming + networking + P2P
# infrastructure*. He maintains canonical-
# status libraries across multiple
# verticals (DNS + tar + streams + P2P +
# BitTorrent) - one of the most prolific
# canonical-author contributors to the
# Node ecosystem.
#
# Martin Heidegger (leichtgewicht) is the
# fork maintainer of the @leichtgewicht/
# dns-packet variant - a TypeScript-typed +
# bundler-friendly republish of mafintosh's
# original work, maintained to address the
# typing + tree-shaking gaps in the
# original library. The @leichtgewicht/*
# org provides actively-maintained forks
# of multiple mafintosh libraries
# (@leichtgewicht/dns-packet + @leichtge-
# wicht/dns-socket + @leichtgewicht/
# ip-codec + others). The forks remain
# wire-compatible with the originals; the
# differences are TypeScript types +
# package.json improvements.
#
# Multi-axis canonical-Node author/org
# cohort extension (now spanning 24
# distinct individuals/orgs after R1546):
#   - + Mathias Buus (mafintosh; mafintosh/
#     dns-packet + dns-socket + hypercore
#     + tar-stream + pump + many others;
#     THIS AXIS; canonical Node DNS wire
#     format + foundational P2P + streaming
#     infrastructure)
#   - + Martin Heidegger (leichtgewicht;
#     @leichtgewicht/dns-packet fork
#     maintainer + dnsquery/dns-query
#     author; THIS AXIS)
#
# Buus's joining the canonical-Node cohort
# at the *foundational streaming + P2P
# infrastructure* level is structurally
# unique - few authors maintain canonical-
# status libraries across as many verticals
# as Buus does in Node (DNS + tar + streams
# + P2P + BitTorrent + mDNS + service
# discovery). His cross-vertical canonical
# presence is the most extensive
# documented in the canonical-Node cohort.
#
# dns-query uses @leichtgewicht/dns-packet
# for:
#   - Encoding DNS queries from JSON to
#     wire-format binary (for DoH
#     POST/GET requests + UDP DNS
#     transmission)
#   - Decoding wire-format DNS responses
#     to JavaScript objects
#   - DNS RR type handling (A + AAAA +
#     TXT + MX + SOA + NS + CNAME + DS +
#     DNSKEY + RRSIG + NSEC + ...)
#   - DoH wire-format encoding (DoH per
#     RFC 8484 uses the same DNS wire
#     format as UDP, just transported
#     over HTTPS)
#
# This is the canonical use case for
# mafintosh/dns-packet in production:
# protocol-level DNS message manipulation
# in browsers + Node alike (the same
# library handles both transport-agnostic
# wire format encoding/decoding).
#
# ----------------------------------------------------------------------------
# AXIS 282 :: DNS (Domain Name System)
#              libraries
#              (RFC 1035 + extensions:
#              EDNS0 + DNSSEC + DoH/DoT/
#              DoQ; resolver + protocol +
#              authoritative server
#              implementations)
# Round 1546 :: TS/Node slot 3 of 4 :: CLOSES Axis 282
#
# Cross-language canonical library family
# for this axis (closed):
#   Rust    : hickory-dns/hickory-resolver [R1544 _noip-duc]
#             (Benjamin Fry + Hickory DNS
#              project / formerly trust-dns;
#              canonical Rust DNS stack)
#   Go      : miekg/dns                  [R1545 _dns-tools]
#             (Miek Gieben; DNS RFC author;
#              canonical Go DNS; powers
#              CoreDNS + most Go DNS tools)
#   TS/Node : mafintosh/dns-packet        [R1546 THIS FILE]
#             (Mathias Buus + Martin
#              Heidegger leichtgewicht
#              fork; canonical Node DNS
#              wire-format library; ~2M
#              weekly npm downloads;
#              CLOSES Axis 282)
#
# Axis 282 closure = 275th axis closed in
# the corpus. The 3+1 cycle returns to slot
# 1/0/0 for Axis 283 opening at the next
# round.
#
# Reflection across all three lanes:
#   - All three implement RFC 1035 DNS
#     wire format encoding/decoding
#   - All three support modern DNS
#     extensions (EDNS0 + DNSSEC RR types)
#   - Each library has a different scope:
#       * Rust hickory: full resolver +
#         server + wire format (complete
#         DNS stack)
#       * Go miekg/dns: full resolver +
#         wire format + DNSSEC operations
#         (broad DNS toolkit by an RFC
#         author)
#       * Node dns-packet: wire format
#         only (focused; resolvers built
#         on top in separate libs like
#         dns-socket + dns-over-http)
#
# Architectural pattern: the Node library
# has a *narrower scope* than Rust + Go
# canonical libraries. This is consistent
# with the Node ecosystem's preference for
# small focused libraries assembled into
# stacks (vs Rust/Go's preference for
# integrated multi-module crates/modules
# under a single project umbrella).
#
# Spec authorship distribution for DNS
# (Axis 282):
#   - DNS RFC authors: many (IETF DNS
#     working group + DNSOP working
#     group + DNSSEC working group)
#   - Rust canonical: Fry (third-party
#     implementation by a non-RFC-author)
#   - Go canonical: Gieben (RFC co-author
#     for DNSSEC RFCs 4034 + 4035 + 5155;
#     spec-author-canonical-implementer
#     in the Go lane)
#   - Node canonical: Buus (third-party
#     implementation by a non-RFC-author)
#
# Among R1546's three canonical
# implementations, only the Go lane
# (Gieben/miekg) is a spec-author
# canonical implementer. This is the
# *highest spec-author convergence
# documented in any axis* - Gieben co-
# authored multiple DNSSEC RFCs AND
# maintains the canonical Go DNS library
# AND co-founded CoreDNS (the
# Kubernetes cluster DNS).
#
# Use-case spectrum across Axis 282 (closed):
#   - noip-duc (Rust, hickory-resolver):
#     dynamic DNS update client public IP
#     discovery via custom DNS queries
#   - dns-tools (Go, miekg/dns): DNSSEC
#     zone signing + verification +
#     ZONEMD digest tooling for production
#     DNS operators
#   - dns-query (TS-Node, dns-packet +
#     leichtgewicht fork): DNS-over-HTTPS
#     query CLI for Node + Browser with
#     auto-discovered endpoint list +
#     random load balancing across
#     providers
#
# Use-case spectrum spans:
#   - Production DDNS client (noip-duc:
#     IP discovery via custom DNS)
#   - Production DNSSEC operations
#     (dns-tools: zone signing + HSM key
#     storage)
#   - DoH transport debugging + privacy
#     queries (dns-query: cross-platform
#     DNS-over-HTTPS)
#
# Together they cover the canonical DNS
# deployment patterns across the polyglot
# landscape: DDNS update + DNSSEC
# operations + DoH query.
#
# Axis 282 is fully closed with coherent
# cross-language coverage of the DNS
# (RFC 1035 + extensions) ecosystem.
# ============================================================================

_dns-query() {
    _arguments \
        '--mode=[query mode]:mode:(free txt)' \
        '--json[input is JSON (--type=json)]' \
        '--base64[input is base64-encoded binary (--type=base64)]' \
        '--binary[input is raw binary (--type=binary)]' \
        '--type=[explicit input type]:type:(json base64 binary)' \
        '--out=[output type (defaults to --type)]:type:(json base64 binary)' \
        '--stdin[read input from stdin]' \
        '--dns[use plain DNS (UDP) endpoints]' \
        '--doh[use DoH endpoints (default)]' \
        '(-e --endpoint)'{-e+,--endpoint=}'[specific DoH endpoint]:endpoint:' \
        '--endpoints[list all known endpoints as JSON]' \
        '--resolvers[list all known resolvers as JSON]' \
        '--response[show the HTTP response in the result]' \
        '--retries=[number of retries (default 5)]:n:' \
        '--timeout=[request timeout in ms (default 30000)]:ms:' \
        '--max-age=[max age of persisted data ms (default 300000)]:ms:' \
        '--no-persist[do not persist resolver list]' \
        '--offline[do not update the resolver list]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '*:input:'
}

_dns-query "$@"
