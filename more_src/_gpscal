#compdef gpscal
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpscal.html
# Self-calibration for arrays with linear feeds

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'select=[select keyword]:select:' \
  'model=[model keyword]:model:' \
  'clip=[clip keyword]:clip:' \
  'flux=[flux keyword]:flux:' \
  'spec=[spec keyword]:spec:' \
  'offset=[offset keyword]:offset:' \
  'interval=[interval keyword]:interval:' \
  'options=[options keyword]:options:' \
  'minants=[minants keyword]:minants:' \
  'refant=[refant keyword]:refant:' \
  'line=[line keyword]:line:' \
  '*:visibility dataset:_files' && ret=0

return ret
