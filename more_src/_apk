#compdef apk

# Zsh completion for Alpine Package Keeper (apk)

_apk() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'add:add packages to the system'
    'del:remove packages from the system'
    'fix:fix or reinstall packages'
    'update:update repository indexes'
    'upgrade:upgrade installed packages'
    'cache:manage local package cache'
    'info:give detailed information about packages'
    'list:list packages matching a pattern'
    'dot:render dependencies as graphviz plot'
    'policy:show repository policy for packages'
    'index:create repository index'
    'fetch:download packages from repositories'
    'audit:audit directories for changes'
    'verify:verify package integrity and signature'
    'manifest:show checksums of package contents'
    'search:search for packages'
    'stats:show statistics about repositories and installations'
    'version:compare package versions'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'apk command' commands && ret=0
      ;;
    (args)
      local -a global_opts=(
        '(-f --force)'{-f,--force}'[force specified action]'
        '(-i --interactive)'{-i,--interactive}'[ask confirmation before performing actions]'
        '(-p --root)'{-p,--root}'[install to alternative root]:root dir:_files -/'
        '(-q --quiet)'{-q,--quiet}'[print less information]'
        '(-U --update-cache)'{-U,--update-cache}'[update repository index cache]'
        '(-v --verbose)'{-v,--verbose}'[print more information]'
        '(-V --version)'{-V,--version}'[print program version]'
        '(-X --repository)'{-X,--repository}'[use package from specified repo]:repository:'
        '--allow-untrusted[install packages with untrusted signatures]'
        '--arch=[use specified architecture]:architecture:(x86 x86_64 aarch64 armhf armv7 ppc64le s390x riscv64)'
        '--cache-dir=[cache directory]:directory:_files -/'
        '--cache-max-age=[maximum age for index cache]:seconds:'
        '--keys-dir=[directory with signing keys]:directory:_files -/'
        '--no-cache[do not use any local cache]'
        '--no-network[do not use the network]'
        '--no-progress[disable progress bar]'
        '--progress[show progress]'
        '--progress-fd=[file descriptor for progress]:fd:'
        '--purge[delete modified configuration files on removal]'
        '--repositories-file=[repo file]:file:_files'
        '--wait=[wait for lock in seconds]:seconds:'
      )
      case ${words[1]} in
        add)
          _arguments -s -S $global_opts \
            '--initdb[initialize database]' \
            '-u[upgrade package if already installed]' \
            '--upgrade[upgrade package if already installed]' \
            '-l[latest version]' \
            '--latest[select latest version]' \
            '-t+[install as virtual package]:virtual name:' \
            '--virtual=[install as virtual package]:virtual name:' \
            '--no-scripts[do not execute scripts]' \
            '*:package:' \
            && ret=0
          ;;
        del)
          _arguments -s -S $global_opts \
            '-r[recursively remove dependent packages]' \
            '--rdepends[recursively remove dependent packages]' \
            '--no-scripts[do not execute scripts]' \
            '*:package:' \
            && ret=0
          ;;
        upgrade)
          _arguments -s -S $global_opts \
            '-a[upgrade all packages]' \
            '--available[upgrade to latest available]' \
            '-l[select latest version]' \
            '--latest[select latest version]' \
            '--no-self-upgrade[do not upgrade apk-tools]' \
            '--self-upgrade-only[only upgrade apk-tools]' \
            '--ignore=[ignore upgrade of packages]:packages:' \
            '--prune[remove packages not in world]' \
            '--no-scripts[do not execute scripts]' \
            '*:package:' \
            && ret=0
          ;;
        info)
          _arguments -s -S $global_opts \
            '-a[all information]' \
            '--all[all information]' \
            '-d[description]' \
            '--description[description]' \
            '-e[check if package is installed]' \
            '--installed[check if package is installed]' \
            '-L[list contents]' \
            '--contents[list contents]' \
            '-s[print size]' \
            '--size[print size]' \
            '-w[print URL]' \
            '--webpage[print URL]' \
            '-R[print reverse dependencies]' \
            '--depends[print dependencies]' \
            '-P[print provides]' \
            '--provides[print provides]' \
            '-r[print reverse depends]' \
            '--rdepends[print reverse depends]' \
            '-W[who owns file]' \
            '--who-owns[who owns file]' \
            '--license[print license]' \
            '--triggers[print triggers]' \
            '--replaces[print replaces]' \
            '*:package or file:_files' \
            && ret=0
          ;;
        search)
          _arguments -s -S $global_opts \
            '-a[show all package versions]' \
            '--all[show all package versions]' \
            '-d[search in description]' \
            '--description[search in description]' \
            '-e[exact match]' \
            '--exact[exact match]' \
            '-o[print origin package]' \
            '--origin[print origin package]' \
            '--has-origin[search by origin]' \
            '*:pattern:' \
            && ret=0
          ;;
        list)
          _arguments -s -S $global_opts \
            '-I[only list installed packages]' \
            '--installed[only list installed packages]' \
            '-O[only list orphaned packages]' \
            '--orphaned[only list orphaned packages]' \
            '-a[list available packages]' \
            '--available[list available packages]' \
            '-u[only list upgradable packages]' \
            '--upgradable[only list upgradable packages]' \
            '-o[print origin package]' \
            '--origin[print origin package]' \
            '-d[print description]' \
            '--description[print description]' \
            '*:pattern:' \
            && ret=0
          ;;
        fetch)
          _arguments -s -S $global_opts \
            '-o+[output directory]:directory:_files -/' \
            '--output=[output directory]:directory:_files -/' \
            '-R[fetch dependencies recursively]' \
            '--recursive[fetch dependencies recursively]' \
            '-s[fetch source package]' \
            '--stdout[dump the package to stdout]' \
            '-l[create symlinks]' \
            '--link[create symlinks]' \
            '*:package:' \
            && ret=0
          ;;
        cache)
          _arguments -s -S $global_opts \
            '1:subcommand:(clean download sync purge)' \
            && ret=0
          ;;
        *)
          _arguments -s -S $global_opts \
            '*:package:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_apk "$@"
