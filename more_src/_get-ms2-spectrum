#compdef get-ms2-spectrum
# Documentation: https://crux.ms/commands/get-ms2-spectrum.html
# Crux get-ms2-spectrum: extract a single spectrum from an MS2 file.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--scan-number=[single scan or range (first-last) to extract]:range' \
  '--stats=[output summary statistics instead of the spectrum]:bool:(T F)' \
  '--remove-precursor-tolerance=[tolerance (Th) around precursor m/z]:tol' \
  '--spectrum-parser=[parser for reading MS/MS files]:parser:(pwiz mstoolkit)' \
  '--use-z-line=[get precursor mass from Z line vs S line]:bool:(T F)' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:ms2 file:_files' && ret=0

return ret
