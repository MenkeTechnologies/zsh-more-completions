#compdef check-manifest
# Documentation: https://github.com/mgedmin/check-manifest
# Reference accessed: 2026-06-04

# Zsh completion for check-manifest (check MANIFEST.in completeness)
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '(-c --create)'{-c,--create}'[create a MANIFEST.in if missing]'
  '(-u --update)'{-u,--update}'[append suggestions to MANIFEST.in]'
  '(-p --python)'{-p,--python}'[specify Python interpreter to use]:python:_files -g "*(#q*)"'
  '*--ignore[ignore files matching patterns]:pattern:'
  '--no-build-isolation[do not install build dependencies in an isolated environment]'
  '(-q --quiet)'{-q,--quiet}'[suppress output]'
  '(-v --verbose)'{-v,--verbose}'[increase output verbosity]'
)

_arguments -s -S $arguments
