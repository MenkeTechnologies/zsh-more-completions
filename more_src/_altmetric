#compdef altmetric
# _altmetric — Altmetric altmetric CLI client to the Altmetric.com REST API fetching alternative-impact metrics social-media attention Twitter Wikipedia news-outlets Mendeley readers F1000 reviews policy-doc mentions for a DOI ARXIV PMID HANDLE-id score badge JSON output (Altmetric LLP team, Python); custom argparse
# upstream: https://api.altmetric.com/

_altmetric() {
    local -a sub=(
        'fetch:fetch altmetrics for a single id'
        'search:search across attention sources'
        'badge:generate altmetric badge URL'
        'top:list top mentioned papers'
        'sources:list attention sources'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--id-type=+[t]:t:(doi pmid arxiv isbn handle nct ads uri)' \
        '--limit=+[N]:n:' \
        '--page=+[N]:n:' \
        '--sort=+[s]:s:(score_change pub_date)' \
        '--from-date=+[unix]:n:' \
        '--until-date=+[unix]:n:' \
        '--source=+[src]:s:(twitter facebook googleplus reddit wikipedia news blogs policy peer_review f1000 video forum patent linkedin)' \
        '-f+[format]:f:(json csv yaml table)' \
        '--format=+[format]:f:(json csv yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'altmetric subcommand' sub ;;
        args)
            case $words[1] in
                fetch|badge) _arguments '*:id:' ;;
                search|top) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_altmetric "$@"
