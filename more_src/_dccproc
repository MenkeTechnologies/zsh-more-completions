#compdef dccproc
# Documentation: https://man.cx/dccproc(8)
# DCC procmail interface: check a mail message against a DCC server

local ret=1

_arguments -s -S \
  '-h[DCC home directory]:dir:_files -/' \
  '-d[enable debugging output]' \
  '-V[display version]' \
  '-Q[query only, do not report checksums]' \
  '-C[output checksums as well as the X-DCC header]' \
  '-H[output only the X-DCC header]' \
  '-A[add to existing X-DCC headers]' \
  '-E[add envelope information to logs]' \
  '-R[parse Received line for client IP address]' \
  '-m[memory mapped parameter file]:map:_files' \
  '-w[whitelist file]:file:_files' \
  '-T[temporary directory]:dir:_files -/' \
  '-a[SMTP client IP address]:ip' \
  '-f[envelope Mail From value]:from' \
  '-t[number of message recipients]:targets' \
  '-x[exit code when bulk threshold reached]:exitcode' \
  '-c[spam/log thresholds]:thresholds' \
  '-g[believe white-listed counts]:type' \
  '-S[substitute headers to check]:header' \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '-l[log directory]:dir:_files -/' \
  '-B[DNS blacklist checks]:dnsbl' \
  '-L[syslog ltype,facility.level]:logspec' && ret=0

return ret
