#compdef chokidar

# Zsh completion for chokidar - cross-platform file watcher CLI

_arguments -s -S \
  '(-c --command)'{-c,--command}'[command to run on changes]:command:' \
  '(-d --debounce)'{-d,--debounce}'[debounce timeout in ms]:ms:' \
  '(-t --throttle)'{-t,--throttle}'[throttle timeout in ms]:ms:' \
  '(-s --follow-symlinks)'{-s,--follow-symlinks}'[follow symlinks]' \
  '(-i --ignore)'{-i,--ignore}'[ignore patterns]:pattern:' \
  '--initial[run command initially before any changes]' \
  '(-p --polling)'{-p,--polling}'[use polling]' \
  '--poll-interval[polling interval in ms]:ms:' \
  '--poll-interval-binary[polling interval for binary files]:ms:' \
  '--verbose[show verbose output]' \
  '--silent[silence output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:pattern:_files'
