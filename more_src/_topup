#compdef topup
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/diffusion/topup/users_guide/index.html
# topup - estimate and correct susceptibility-induced off-resonance field

local ret=1

_arguments -s -S \
  '--imain=[input image (opposing phase-encode volumes)]:file:_files' \
  '--datain=[acquisition parameters text file]:file:_files' \
  '--config=[config file with parameter settings]:file:_files' \
  '--out=[output basename for field coefficients and movement]:basename:_files' \
  '--fout=[output off-resonance field image]:file:_files' \
  '--iout=[output unwarped/movement-corrected images]:file:_files' \
  '--logout=[output log file]:file:_files' \
  '--featout=[output FEAT-compatible directory]:dir:_files -/' \
  '--warpres=[warp resolution mm per level]:res:' \
  '--subsamp=[subsampling per level]:sub:' \
  '--fwhm=[FWHM smoothing per level mm]:fwhm:' \
  '--miter=[max iterations per level]:n:' \
  '--lambda=[regularisation weight per level]:lambda:' \
  '--ssqlambda=[weight lambda by sum-of-squares (1) or not (0)]:flag:(0 1)' \
  '--regmod=[regularisation model (bending_energy/membrane_energy)]:model:(bending_energy membrane_energy)' \
  '--estmov=[estimate movements per level (0/1)]:flag:(0 1)' \
  '--minmet=[minimisation method per level (0=LM,1=SCG)]:method:(0 1)' \
  '--splineorder=[spline order (2=quadratic,3=cubic)]:order:(2 3)' \
  '--numprec=[numerical precision (float/double)]:prec:(float double)' \
  '--interp=[interpolation (linear/spline)]:interp:(linear spline)' \
  '--scale=[scale intensities to common mean (0/1)]:flag:(0 1)' \
  '--regrid=[regrid images to be isotropic (0/1)]:flag:(0 1)' \
  '--nthr=[number of threads]:n:' \
  '--verbose[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
