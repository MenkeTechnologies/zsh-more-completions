#compdef fpdoc
# Documentation: fpdoc --help (Free Pascal Documentation Tool 3.2.2)
# Source: generate documentation from Free Pascal source + XML descriptions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--base-descr-dir=[base directory for description files]:dir:_files -/' \
    '--base-input-dir=[base directory for input files]:dir:_files -/' \
    '--content[create content file for cross-references]' \
    '--cputarget=[target CPU]:cpu:' \
    '*--descr=[description XML file (repeatable)]:file:_files -g "*.xml"' \
    '*--descr-dir=[directory of description XMLs]:dir:_files -/' \
    '--format=[output format]:fmt:(html htm chm xml latex tex man)' \
    '--hide-protected[hide protected methods]' \
    '--import=[import content file]:file:_files' \
    '*--input=[source command (file + options)]:cmd:' \
    '*--input-dir=[directory of .pp/.pas]:dir:_files -/' \
    '--lang=[output language]:lang:' \
    '*--macro=[name=value preprocessor macro]:name=value:' \
    '--ostarget=[target OS]:os:' \
    '--output=[output name]:name:' \
    '--package=[package name]:name:' \
    '--project=[project file]:file:_files' \
    && ret=0

return ret
