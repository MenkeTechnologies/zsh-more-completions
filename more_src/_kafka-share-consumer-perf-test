#compdef kafka-share-consumer-perf-test
# Documentation: https://kafka.apache.org/documentation/ (kafka-share-consumer-perf-test.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[REQUIRED. The server(s) to connect to]:host\:port:'
    '--command-config[Config properties file]:file:_files'
    '--command-property[Kafka share consumer config properties (prop1=val1)]:properties:'
    '--consumer.config[(DEPRECATED) Share consumer config properties file]:file:_files'
    '--date-format[The date format to use for formatting the time field]:format:'
    '--fetch-size[The amount of data to fetch in a single request]:size:'
    '--group[The group id to consume on]:group:'
    '--help[Print usage information]'
    '--hide-header[Skip printing the header for the stats]'
    '--messages[(DEPRECATED) The number of records to consume]:count:'
    '--num-records[REQUIRED: The number of records to consume]:count:'
    '--print-metrics[Print out the metrics]'
    '--reporting-interval[Interval in ms at which to print progress info]:ms:'
    '--show-consumer-stats[Report stats for each share consumer]'
    '--show-detailed-stats[Report stats for each reporting interval]'
    '--socket-buffer-size[The size of the tcp RECV size]:size:'
    '--threads[The number of share consumers to use]:count:'
    '--timeout[Maximum allowed time in ms between returned records]:ms:'
    '--topic[REQUIRED: The topic to consume from]:topic:'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
