#compdef xan

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'count:count rows'
  'c:count rows (alias)'
  'headers:show header names'
  'h:show header names (alias)'
  'view:preview CSV'
  'v:preview CSV (alias)'
  'flatten:flattened per-row view'
  'hist:histogram'
  'plot:scatter or line chart'
  'heatmap:heatmap of CSV matrix'
  'progress:progress bar'
  'search:search/replace patterns'
  'filter:keep rows matching expression'
  'head:first rows'
  'tail:last rows'
  'slice:slice rows'
  'top:top rows by column'
  'sample:random sample'
  'bisect:binary search on sorted CSV'
  'sort:sort rows'
  'dedup:deduplicate rows'
  'shuffle:shuffle rows'
  'frequency:frequency counts'
  'freq:frequency counts (alias)'
  'groupby:group by column'
  'stats:summary statistics'
  'agg:aggregations'
  'bins:bucket rows'
  'window:window functions'
  'cat:concatenate files'
  'join:join CSVs'
  'merge:merge sorted CSVs'
  'select:select columns'
  'drop:drop columns'
  'map:map columns via expression'
  'transform:transform columns'
  'enum:add enumeration column'
  'fill:fill missing values'
  'complete:complete rows'
  'blank:blank values'
  'separate:separate columns'
  'behead:remove header'
  'rename:rename columns'
  'input:CSV input parsing'
  'fixlengths:fix row lengths'
  'fmt:format CSV'
  'explode:explode rows'
  'implode:implode rows'
  'from:read from format'
  'to:write to format'
  'scrape:scrape data'
  'reverse:reverse rows'
  'transpose:transpose CSV'
  't:transpose CSV (alias)'
  'pivot:pivot CSV'
  'unpivot:unpivot CSV'
  'split:split file'
  'partition:partition rows'
  'parallel:run in parallel'
  'p:run in parallel (alias)'
  'range:generate range'
  'tokenize:tokenize text'
  'vocab:vocabulary stats'
  'matrix:matrix operations'
  'network:network operations'
  'eval:debug eval'
  'help:show help'
)

_arguments -C \
  '(-d --delimiter)'{-d,--delimiter=}'[input field delimiter]:char:' \
  '(-n --no-headers)'{-n,--no-headers}'[no header row]' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '--color=[color output]:when:(auto always never)' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'xan subcommand' subcommands && ret=0
    ;;
  (args)
    _arguments '*:csv file:_files -g "*.(csv|tsv)"' && ret=0
    ;;
esac

return ret
