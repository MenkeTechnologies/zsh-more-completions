#compdef xtefilt
# Assemble the scientifically important parameters from XTE Spacecraft and Orbit data

local ret=1

_arguments -s \
  '-a[name of the file containing the AppIds to be collected]:appid file:_files' \
  '-o[the ObsId to be filtered]:obsid:' \
  '-p[full pathname for the top of the XTE FITS database]:path:_files -/' \
  '-t[delta T for the filter file in seconds]:timestep:' \
  '-b[name of the PCA breakdown file, NONE or CALDB]:breakfile:_files' \
  '-c[overwrite existing files with the same name]' \
  '-f[output filename (.xfl is appended)]:filename:_files' \
  '-g[maximum gap in seconds to interpolate across]:maxgap:' \
  '-h[print help page]' \
  '-i[prompt for confirmation before modifying the index file]' \
  '-s[put output in STDPROD directory and update the index]' \
  '*:file:_files' && ret=0

return ret
