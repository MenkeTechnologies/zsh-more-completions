#compdef resizecons
# _resizecons — Linux kbd-project resizecons change kernel idea of console size by writing VTSIZE ioctl (legion team, C); custom argparse
# upstream: https://github.com/legionus/kbd

_resizecons() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-lines+[N]:n:' \
        '*:WIDTHxHEIGHT:'
}

_resizecons "$@"
