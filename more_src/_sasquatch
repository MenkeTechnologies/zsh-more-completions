#compdef sasquatch

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-d+[output dir]:dir:_files -/' \
  '-f[force overwrite]' \
  '-i[print version info]' \
  '-l[list files only]' \
  '-ll[list files with details]' \
  '-p+[password]:pw:' \
  '*:squashfs image:_files' && ret=0

return ret
