#compdef sasquatch
# Documentation: https://github.com/devttys0/sasquatch
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: sasquatch is a vendor-quirk patch set over the standard unsquashfs
# utility; upstream README states "advanced command line options have been
# added for testing/debugging" but does not enumerate the flag set. Limit
# completion to SquashFS image file argument.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:squashfs image:_files' && ret=0
return ret
