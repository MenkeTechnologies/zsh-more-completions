#compdef nickel

# Zsh completion for Nickel - programmable configuration language

local curcontext="$curcontext" state line ret=1

local -a nickel_commands
nickel_commands=(
  'eval:evaluate a Nickel expression'
  'export:evaluate and export to a format'
  'query:query a value in a configuration'
  'typecheck:typecheck a Nickel program'
  'format:format Nickel source files'
  'repl:start an interactive REPL'
  'doc:generate documentation'
  'test:run tests'
  'pprint-ast:pretty-print the AST'
  'completions:generate shell completions'
  'gen-manpage:generate man pages'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:_describe -t commands command nickel_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      eval)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'=[input file]:file:_files -g "*.ncl"' \
          '--format=[output format]:format:(json yaml toml raw)' \
          '--field=[field to evaluate]:field:' \
          '--color=[color output]:color:(auto always never)' \
          '*--override=[override a field value]:override:' \
          '*:expression:' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'=[input file]:file:_files -g "*.ncl"' \
          '--format=[output format]:format:(json yaml toml raw)' \
          '--field=[field to export]:field:' \
          '--color=[color output]:color:(auto always never)' \
          '*--override=[override a field value]:override:' \
          '*:expression:' && ret=0
        ;;
      query)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'=[input file]:file:_files -g "*.ncl"' \
          '--field=[field to query]:field:' \
          '--doc[show documentation]' \
          '--type[show type]' \
          '--default[show default value]' \
          '--contracts[show contracts]' \
          '--color=[color output]:color:(auto always never)' \
          '*:expression:' && ret=0
        ;;
      format)
        _arguments -s -S \
          '--in-place[format files in place]' \
          '*:files:_files -g "*.ncl"' && ret=0
        ;;
      typecheck)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'=[input file]:file:_files -g "*.ncl"' \
          '--color=[color output]:color:(auto always never)' \
          '*:files:_files -g "*.ncl"' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      doc|test|repl|pprint-ast|gen-manpage)
        _arguments -s -S \
          '*:files:_files -g "*.ncl"' && ret=0
        ;;
    esac
    ;;
esac

return ret
