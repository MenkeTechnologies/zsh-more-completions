#compdef crm_error

# crm_error: translate Pacemaker numeric error codes to names/messages
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-X[long form output (with explanation)]' \
  '--exit[input is exit/return codes]' \
  '-e[input is exit/return codes]' \
  '-l[list all known errors]' \
  '--list[list all known errors]' \
  '-r[input is reverse (name -> code)]' \
  '--rc[only show rc range]' \
  '-n[name lookup]' \
  '--name[name lookup]' \
  '*:error codes:' && ret=0
return ret
