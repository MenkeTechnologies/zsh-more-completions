#compdef crm_error

# Pacemaker crm_error: display human readable Pacemaker error codes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-l --list)'{-l,--list}'[list all error codes]' \
  '(-X --exit)'{-X,--exit}'[error is an exit code]' \
  '(-r --rc)'{-r,--rc}'[error is an LRMD return code]' \
  '(-n --name)'{-n,--name}'[show name instead of message]' \
  '*:error code or name:' && ret=0
return ret
