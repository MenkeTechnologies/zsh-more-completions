#compdef crm_error
# Documentation: https://www.mankier.com/8/crm_error
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_error: translate Pacemaker numeric return/exit codes to names/messages
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-output[show output help]' \
  '(- *)'{-\$,--version}'[display software version]' \
  '*'{-V,--verbose}'[increase debug output]' \
  '(-n --name)'{-n,--name}'[show error name with its description]' \
  '(-l --list)'{-l,--list}'[show all known errors]' \
  '(-X --exit)'{-X,--exit}'[interpret as exit code]' \
  '(-r --rc)'{-r,--rc}'[interpret as return code]' \
  '--output-as=[output format]:fmt:(text xml)' \
  '--output-to=[output file (- for stdout)]:file:_files' \
  '*:return/exit code:' && ret=0
return ret
