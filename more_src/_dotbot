#compdef dotbot

# Zsh completion for dotbot - Dotfile bootstrapper

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-c,--config-file}'=[configuration file]:config file:_files' \
  {-d,--base-directory}'=[base directory]:directory:_directories' \
  '*'{-p,--plugin}'=[plugin file]:plugin file:_files' \
  {-Q,--super-quiet}'[suppress almost all output]' \
  {-q,--quiet}'[suppress most output]' \
  {-v,--verbose}'[enable verbose output]' \
  '--no-color[disable color output]'
