#compdef msieve
# Documentation: https://github.com/radii/msieve
# msieve - integer factorization (SIQS and GNFS)

local ret=1

_arguments -s -S \
  '-s[save intermediate results to file]:file:_files' \
  '-l[append log information to file]:file:_files' \
  '-i[read integers to factor from file]:file:_files' \
  '-m[manual mode: enter numbers via standard input]' \
  '-mb[hint for megabytes of memory for postprocessing]:mb' \
  '-q[quiet: only print factors found]' \
  '-d[deadline in minutes before graceful shutdown]:min' \
  '-r[stop sieving after finding num relations]:num' \
  '-p[run at idle priority]' \
  '-v[verbose: write log to screen as well as logfile]' \
  '-g[use GPU num]:num' \
  '-t[use at most num threads]:num' \
  '-e[perform deep ECM, seek factors > 15 digits]' \
  '-c[client: only perform QS sieving]' \
  '-n[use the number field sieve (80+ digits)]' \
  '-nf[NFS factor base file]:file:_files' \
  '-np[perform only NFS polynomial selection]' \
  '-np1[perform stage 1 of NFS polynomial selection]' \
  '-np2[perform stage 2 of NFS polynomial selection]' \
  '-ns[perform only NFS sieving]' \
  '-nc[perform only NFS combining (all phases)]' \
  '-nc1[perform only NFS filtering]' \
  '-nc2[perform only NFS linear algebra]' \
  '-ncr[perform NFS linear algebra, restart from checkpoint]' \
  '-nc3[perform only NFS square root]' \
  '*:number:_files' && ret=0

return ret
