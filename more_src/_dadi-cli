#compdef dadi-cli
# Documentation: https://dadi-cli.readthedocs.io/en/latest/
# dadi-cli: command-line interface to dadi for demographic / DFE inference. Subcommands from the docs (fourteen subcommands).

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    GenerateFs\:"generate frequency spectrum from VCF"
    GenerateCache\:"generate cache of frequency spectra for DFE inference"
    SimulateDM\:"simulate frequency spectrum under a demographic model"
    SimulateDFE\:"simulate frequency spectrum under a DFE"
    SimulateDemes\:"simulate frequency spectrum from a demes model"
    InferDM\:"infer demographic model parameters"
    InferDFE\:"infer distribution of fitness effects"
    Plot\:"plot frequency spectra and model fits"
    StatDM\:"statistics / uncertainty for a demographic model"
    StatDFE\:"statistics / uncertainty for a DFE"
    BestFit\:"obtain best-fit parameters from inference output"
    Model\:"display available demographic models"
    Pdf\:"display available DFE probability density functions"
    LowPass\:"apply low-pass sequencing coverage correction"
  ))' \
  '*::arg:_files' && ret=0

return ret
