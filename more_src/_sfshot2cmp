#compdef sfshot2cmp
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mshot2cmp.c
# Madagascar: convert shots to CMPs for regular 2-D geometry

local ret=1

_arguments -s -S \
  'positive=[initial offset orientation]:positive:(y n)' \
  'half=[if y, second axis is half-offset instead of full offset]:half:(y n)' \
  'mask=[optional mask output file]:mask:_files' \
  '*:RSF file:_files' && ret=0

return ret
