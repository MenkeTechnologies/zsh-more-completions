#compdef rw-scripts
# Documentation: https://github.com/redwoodjs/sdk
# RedwoodSDK script runner (dispatches dist/scripts/<name>.mjs)

local ret=1

_arguments -s -S \
  '1:script:(addon debug-sync dev-init ensure-deploy-env ensure-env migrate-new seed smoke-test worker-run)' \
  '*::script args:_default' && ret=0

return ret
