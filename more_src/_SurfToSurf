#compdef SurfToSurf
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfToSurf.html
# Map data between two surfaces

local ret=1

_arguments -s \
  '-i_TYPE[input surface with type]:surface:_files' \
  '-o_TYPE[output surface format]:surface:_files' \
  '-sv[surface volume for alignment]:dataset:_files' \
  '-prefix[output file prefix]:prefix' \
  '-output_params[mapping parameters]:params' \
  '-node_indices[1D file of S1 node indices]:file:_files' \
  '-proj_dir[1D file of projection directions]:file:_files' \
  '-data[1D data to interpolate]:file:_files' \
  '-dset[dataset for interpolation]:dataset:_files' \
  '-node_debug[debug for a node]:node' \
  '-debug[debug level]:level' \
  '-make_consistent[force triangle consistency check]' \
  '-mapfile[use precomputed mapping file]:file:_files' \
  '-closest_possible[substitute closest node 0-3]:value' \
  '-novolreg[ignore transforms in surface volume]' \
  '-noxform[same as -novolreg]' \
  '-setenv[set environment variable]:var' \
  '-trace[debug and memory tracing]' \
  '-TRACE[extreme tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing]' \
  '(-h -help)-h[mini help]' \
  '(-h -help)-help[full help]' \
  '*:surface:_files' && ret=0

return ret
