#compdef todors
# Documentation: https://github.com/meysam81/todors
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. Clap-generated zsh completion
# shipped by upstream (todors v0.10.7, probed via `todors completion zsh`).
# Subcommands: serve (grpc/http), create, delete, list, update, get,
# completion, help.

autoload -U is-at-least

_todors() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_todors_commands" \
"*::: :->todors" \
&& ret=0
    case $state in
    (todors)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todors-command-$line[1]:"
        case $line[1] in
            (serve)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_todors__serve_commands" \
"*::: :->serve" \
&& ret=0

    case $state in
    (serve)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todors-serve-command-$line[1]:"
        case $line[1] in
            (grpc)
_arguments "${_arguments_options[@]}" : \
'-p+[]:PORT: ' \
'--port=[]:PORT: ' \
'-H+[]:HOST: ' \
'--host=[]:HOST: ' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(http)
_arguments "${_arguments_options[@]}" : \
'-p+[]:PORT: ' \
'--port=[]:PORT: ' \
'-H+[]:HOST: ' \
'--host=[]:HOST: ' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_todors__serve__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todors-serve-help-command-$line[1]:"
        case $line[1] in
            (grpc)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(http)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(create)
_arguments "${_arguments_options[@]}" : \
'-d[Whether or not the provided TODOs are done]' \
'--done[Whether or not the provided TODOs are done]' \
'-h[Print help]' \
'--help[Print help]' \
'*::title -- The title of the TODO:' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':id -- The ID of the TODO to delete:' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-o+[Start of the query]:OFFSET: ' \
'--offset=[Start of the query]:OFFSET: ' \
'-l+[Number of results to return]:LIMIT: ' \
'--limit=[Number of results to return]:LIMIT: ' \
'-p[Whether or not to print indented JSON]' \
'--pretty[Whether or not to print indented JSON]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'-t+[The new title of the TODO]:TITLE: ' \
'--title=[The new title of the TODO]:TITLE: ' \
'-d[]' \
'--done[]' \
'-u[]' \
'--undone[]' \
'-h[Print help]' \
'--help[Print help]' \
':id -- The ID of the TODO to update:' \
&& ret=0
;;
(get)
_arguments "${_arguments_options[@]}" : \
'-p[Whether or not to print indented JSON]' \
'--pretty[Whether or not to print indented JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':id -- The ID of the TODO to get:' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Generate completion scripts for your shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_todors__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todors-help-command-$line[1]:"
        case $line[1] in
            (serve)
_arguments "${_arguments_options[@]}" : \
":: :_todors__help__serve_commands" \
"*::: :->serve" \
&& ret=0

    case $state in
    (serve)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:todors-help-serve-command-$line[1]:"
        case $line[1] in
            (grpc)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(http)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(create)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(get)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_todors_commands] )) ||
_todors_commands() {
    local commands; commands=(
'serve:Serve either the gRPC or REST over HTTP server' \
'create:Create a new TODO with a title' \
'delete:Delete a TODO by ID' \
'list:List all TODOs' \
'update:Update a TODO by ID' \
'get:Get a TODO by ID' \
'completion:Generate shell completion' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'todors commands' commands "$@"
}
(( $+functions[_todors__completion_commands] )) ||
_todors__completion_commands() {
    local commands; commands=()
    _describe -t commands 'todors completion commands' commands "$@"
}
