#compdef cliphist-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'store:store entries from stdin'
  'list:list clipboard history'
  'decode:decode an entry by id'
  'delete:delete an entry by id'
  'delete-query:delete entries matching a query'
  'wipe:remove all entries'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-config-path=[clipboard DB path]:dir:_files -/' \
  '-db-path=[explicit DB path]:file:_files' \
  '-max-dedupe-search=[dedupe search size]:n:' \
  '-max-items=[max items kept]:n:' \
  '-preview-width=[preview width]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cliphist-cli command' commands && ret=0 ;;
esac

return ret
