#compdef xprintidle
# Documentation: https://man.archlinux.org/search?q=xprintidle
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-H --human-readable)'{-H,--human-readable}'[print human-readable time]' && ret=0

return ret
