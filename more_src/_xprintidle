#compdef xprintidle
# Documentation: https://manpages.debian.org/testing/xprintidle/xprintidle.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-H --human-readable)'{-H,--human-readable}'[print human-readable time]' && ret=0

return ret
