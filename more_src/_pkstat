#compdef pkstat
# Documentation: https://pktools.nongnu.org/html/pkstat.html
# calculate statistics on raster dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[name of the input raster dataset]:file:_files' \
  '(-b --band)'{-b,--band}'[band(s) on which to calculate statistics]:value:' \
  '(-f --filename)'{-f,--filename}'[Shows image filename]' \
  '(-stats --statistics)'{-stats,--statistics}'[Shows basic statistics (min,max, mean and stdDev of the raster dataset]' \
  '(-nodata --nodata)'{-nodata,--nodata}'[Set nodata value(s)]:value:' \
  '(-mean --mean)'{-mean,--mean}'[calculate mean]' \
  '(-median --median)'{-median,--median}'[calculate median]' \
  '(-var --var)'{-var,--var}'[calculate variance]' \
  '(-stdev --stdev)'{-stdev,--stdev}'[calculate standard deviation]' \
  '(-mm --minmax)'{-mm,--minmax}'[calculate minimum and maximum value]' \
  '(-min --min)'{-min,--min}'[calculate minimum value]' \
  '(-max --max)'{-max,--max}'[calculate maximum value]' \
  '(-hist --hist)'{-hist,--hist}'[calculate histogram]' \
  '(-nbin --nbin)'{-nbin,--nbin}'[number of bins to calculate histogram]:value:' \
  '(-rel --relative)'{-rel,--relative}'[use percentiles for histogram to calculate histogram]' \
  '(-hist2d --hist2d)'{-hist2d,--hist2d}'[calculate 2-dimensional histogram based on two images]' \
  '(-cor --correlation)'{-cor,--correlation}'[calculate Pearson produc-moment correlation coefficient between two ra]' \
  '(-rmse --rmse)'{-rmse,--rmse}'[calculate root mean square error between two raster datasets]' \
  '(-reg --regression)'{-reg,--regression}'[calculate linear regression between two raster datasets and get correl]' \
  '(-regerr --regerr)'{-regerr,--regerr}'[calculate linear regression between two raster datasets and get root m]' \
  '(-preg --preg)'{-preg,--preg}'[calculate perpendicular regression between two raster datasets and get]' \
  '(-ulx --ulx)'{-ulx,--ulx}'[Upper left x value bounding box]:value:' \
  '(-uly --uly)'{-uly,--uly}'[Upper left y value bounding box]:value:' \
  '(-lrx --lrx)'{-lrx,--lrx}'[Lower right x value bounding box]:value:' \
  '(-lry --lry)'{-lry,--lry}'[Lower right y value bounding box]:value:' \
  '(-down --down)'{-down,--down}'[Down sampling factor (for raster sample datasets only). Can be used to]:value:' \
  '(-rnd --rnd)'{-rnd,--rnd}'[generate random numbers]' \
  '(-scale --scale)'{-scale,--scale}'[Scale(s) for reading input image(s)]:value:' \
  '(-offset --offset)'{-offset,--offset}'[Offset(s) for reading input image(s)]:value:' \
  '(-src_min --src_min)'{-src_min,--src_min}'[start reading source from this minimum value]:value:' \
  '(-src_max --src_max)'{-src_max,--src_max}'[stop reading source from this maximum value]:value:' \
  '(-kde --kde)'{-kde,--kde}'[Use Kernel density estimation when producing histogram. The standard d]:value:' \
  '*:file:_files' && ret=0

return ret
