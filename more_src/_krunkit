#compdef krunkit
# Documentation: https://github.com/containers/krunkit
# Source: https://github.com/containers/krunkit/blob/main/docs/usage.md
# Reference accessed: 2026-06-01
# macOS-only (requires macOS 14+); launches VMs via libkrun.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--krun-log-level=[libkrun log level (0=off..5=trace)]:level:(0 1 2 3 4 5)' \
    '--log-file=[file path for libkrun + krunkit logs]:file:_files' \
    '--restful-uri=[URI of RESTful service (tcp/none/unix scheme)]:uri:_default' \
    '--pidfile=[path to write process ID]:file:_files' \
    '--timesync=[Vsock port for host-to-guest time sync]:port:_default' \
    '--cpus=[number of vCPUs]:n:_default' \
    '--memory=[RAM in MiB]:mib:_default' \
    '--nested[enable nested virtualization (M3+, macOS 15+)]' \
    '--bootloader=[bootloader spec (e.g. efi,variable-store=PATH,create=true)]:spec:_default' \
    '*--device=[device spec (virtio-blk/virtio-net/virtio-serial/virtio-vsock/virtio-fs)]:spec:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
