#compdef wtfutil wtf

# Zsh completion for wtfutil - WTF terminal dashboard

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[display version information]' \
  '--config=[path to config file]:config file:_files' \
  '--module=[run only the specified module]:module name' \
  '--opt-in[opt into sending anonymous usage data]' \
  && ret=0

return ret
