#compdef BeefBuild
# =============================================================================
# BeefBuild — the Beef Programming Language build tool and standalone
#             compiler driver.  Beef is a high-performance compiled
#             programming language created by Brian Fiete (co-founder of
#             PopCap Games, original author of Plants vs Zombies' core
#             engine, ex-Riot Games engine engineer) starting in 2017.
#             Beef draws from C++, C#, and Rust to provide a systems-
#             oriented language with deterministic memory, value-type
#             generics, hot-reloading edit-and-continue at runtime, an
#             integrated debugger, and a full IDE that compiles to native
#             code via LLVM.  Used in production game development by
#             Beefy Tech LLC (Brian's studio) and increasingly adopted
#             for indie game engines.
#
# Author:  Brian Fiete (founder of Beefy Tech LLC and PopCap Games)
# Source:  https://github.com/beefytech/Beef
# CLI:     BeefBuild/src/Program.bf + BeefLibs/Beefy2D/src/BFApp.bf
# Library: BFApp.ParseCommandLine
#          (in-house Beef-language virtual-method class-inheritance parser)
# License: MIT
# Status:  Active development — 2,815+ stars; the language and IDE
#          are written in Beef itself (self-hosted since ~2019);
#          stable enough for production game development.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — BEEF IS NOW LANGUAGE 52
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 51 to 52 documented languages.  Beef joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, Beluga, REBOL, Io, Pure, Yeti, Whiley, Boogie, and now Beef.
# BeefBuild is documented as the FIRST Beef CLI library variant in the
# taxonomy (in-house BFApp.ParseCommandLine virtual-method class-inheritance
# parser written in Beef itself, with key=value split-on-equals parsing and
# manual quote-aware string tokenization) — bringing the total to 216
# cross-language CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS BEEF AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# Beef is a high-performance compiled language designed for performance-
# critical software with edit-and-continue REPL ergonomics.  Brian Fiete's
# motivation was the gap between systems languages (C++, Rust) and
# productivity languages (C#, Java) for game development specifically:
# game devs want manual memory management AND fast iteration cycles AND
# powerful debugging.  Beef tries to combine all three.
#
# Beef's distinctive features:
#
#   * VALUE-TYPE GENERICS like C# (not template-based like C++) but
#     monomorphized for zero-cost abstraction
#   * EDIT-AND-CONTINUE HOT RELOAD at runtime — change source while the
#     program runs, compiler patches the binary live (similar to .NET
#     edit-and-continue but for native code; rare in compiled languages)
#   * INTEGRATED DEBUGGER (the IDE includes its own native debugger written
#     in Beef itself, distinct from VS Code's DAP layer)
#   * DETERMINISTIC MEMORY — manual `delete` like C++ but with leak detection
#     and use-after-free detection via "lifetime hints"
#   * MIXINS as first-class language construct — compile-time code injection
#     into types from outside (similar to Ruby mixins but compile-time)
#   * SCOPE-CONTROLLED CHECKED ARITHMETIC — `[Checked]`, `[Unchecked]`,
#     `[Optimized]` attributes per code scope
#   * GAME-DEV-FRIENDLY STANDARD LIBRARY — built-in 2D math, vector types,
#     networking, image loading
#   * SELF-HOSTED COMPILER — the BeefBuild driver, the IDE, the debugger,
#     and the standard library are ALL written in Beef.  Bootstrapping
#     was done in C++ around 2019; current builds compile Beef using Beef.
#
# Beef is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented language with NATIVE EDIT-AND-CONTINUE
#     for compiled native code.  Erlang/Elixir have hot code reload but
#     for VM bytecode; Lisp has SLIME redefinition for interpreted code;
#     C++ has nothing comparable.  Beef's edit-and-continue patches the
#     LLVM-emitted x86_64 in memory at the function level.
#   * It is the FIRST documented language with C#-LIKE SYNTAX targeting
#     MANUAL MEMORY MANAGEMENT.  C# has GC; Rust has ownership; Beef has
#     manual delete with leak detection — a synthesis specific to Beef.
#   * Its INTEGRATED IDE (BeefIDE) is written in Beef and ships in the
#     same repo; not a VS Code extension but a standalone editor.  This
#     architectural choice is shared with Smalltalk image systems and
#     Squeak — rare among modern languages.
#
# -----------------------------------------------------------------------------
# BEEF'S CLI LIBRARY — BFApp.ParseCommandLine (in-house Beef parser)
# -----------------------------------------------------------------------------
#
# Beef's CLI parser is `BFApp.ParseCommandLine` in `BeefLibs/Beefy2D/src/
# BFApp.bf`.  It is the FIRST documented "VIRTUAL-METHOD CLASS-INHERITANCE
# CLI parser written in the language itself" pattern in the corpus's cross-
# language taxonomy.
#
# The parser architecture (verbatim from BFApp.bf):
#
#     public virtual void ParseCommandLine(String[] args)
#     {
#         for (var str in args)
#         {
#             int eqPos = str.IndexOf('=');
#             if (eqPos == -1)
#             {
#                 if (!HandleCommandLineParam(str, null))
#                     UnhandledCommandLine(str, null);
#             }
#             else
#             {
#                 var cmd = scope String(str, 0, eqPos);
#                 var param = scope String(str, eqPos + 1);
#                 if (!HandleCommandLineParam(cmd, param))
#                     UnhandledCommandLine(cmd, param);
#             }
#         }
#     }
#
#     // Subclasses override:
#     public virtual bool HandleCommandLineParam(String key, String value)
#     {
#         // Return true if this subclass handles the flag; false otherwise
#         if (key.StartsWith("--"))
#             key.Remove(0, 1);  // Normalize -- to single -
#         switch (key) { ... }
#         return false;
#     }
#
# The driver also has a STRING-OVERLOAD `ParseCommandLine(String theString)`
# that performs MANUAL QUOTE-AWARE TOKENIZATION (walks the string char-by-
# char tracking `"..."` segments and spaces) before dispatching each token
# through the args-array form.  This is used when the CLI receives a single
# command line string (e.g., from Windows GetCommandLine() or when reading
# args from a config file).
#
# DISTINCTIVE PROPERTIES OF BFApp.ParseCommandLine:
#
#   1. KEY=VALUE SPLIT-ON-EQUALS PARSING — Beef's primary flag syntax is
#      `-flag=value`, NOT `-flag value`.  The `=` is mandatory for value-
#      taking flags.  This is the VS PROJECT FILE convention (MSBuild
#      `/p:Configuration=Debug`) and matches Beef's Windows roots.  This
#      is unique among documented compiler CLIs — most accept BOTH forms,
#      but Beef requires `=`.
#
#   2. DOUBLE-DASH STRIPPED TO SINGLE-DASH — `--config=Debug` and
#      `-config=Debug` are equivalent because `HandleCommandLineParam`
#      strips a leading second dash.  This is GENEROUS — accepts both
#      Microsoft (`/flag`, `-flag`) and GNU (`--flag`) conventions.
#
#   3. VIRTUAL METHOD CLASS-INHERITANCE EXTENSION — `BFApp` is a base
#      class shared across ALL Beef binaries (BeefBuild, BeefIDE,
#      BeefPerf, LogViewer, MemProfiler, BeefBoot).  Each binary's
#      `App` subclass overrides `HandleCommandLineParam` to add its
#      OWN flags on top of BFApp's base flags (which include `-help`,
#      `-version`, common workspace/project handling).  This is the
#      EXACT pattern of Microsoft.Boogie.CommandLineOptionEngine (R473)
#      but in BEEF code rather than C#.
#
#   4. IN-LANGUAGE PARSER — BFApp.ParseCommandLine is written in Beef
#      itself.  This is the THIRD documented "interpreter-language self-
#      hosted CLI parser" pattern, after Io's CLI.io (R463, Io) and
#      Yeti's yeti.yeti (R468, Yeti).  Beef differs in being a COMPILED
#      language where the parser is compiled to native code rather than
#      interpreted at startup.
#
#   5. UNHANDLED-FALLBACK PROTOCOL — when `HandleCommandLineParam`
#      returns false, the parser calls `UnhandledCommandLine(key, value)`
#      which by default reports an error.  This separation lets
#      subclasses override `UnhandledCommandLine` to implement
#      passthrough or alternate behavior without re-parsing argv.
#
#   6. SCOPE-ALLOCATED STRINGS — the parser uses Beef's `scope String(...)`
#      allocator pattern for substring extraction.  `scope` allocations
#      live until end of scope and don't require manual `delete`.  This
#      is the Beef-idiomatic way to avoid GC AND avoid leaks.
#
#   7. -ARGS PASSTHROUGH FLAG — `-args` switches the parser into PASSTHROUGH
#      mode where all subsequent argv elements are quoted and appended
#      to `mRunArgs` to be passed to the compiled program at run time.
#      This is similar to `--` in POSIX getopt but Beef uses `-args`
#      because `--` is normalized to `-` (which would be ambiguous).
#
# CONTRAST WITH OTHER CLASS-INHERITANCE CLI PARSERS DOCUMENTED IN THE CORPUS
#
#   * Boogie CommandLineOptionEngine (R473, C#) — class inheritance with
#                                                  /flag slash-prefix
#   * Beef BFApp.ParseCommandLine (THIS, Beef)  — class inheritance with
#                                                  -flag=value equals
#
# Both Boogie and Beef use VIRTUAL METHODS on a base class as the extension
# point.  Boogie uses `/flag` slash prefix; Beef uses `-flag=value` equals.
# Both ship the CLI library as part of the language's compiler framework
# rather than as a standalone NuGet/crates.io package.  But Beef's parser
# is written in Beef itself (self-hosted) where Boogie's is in C#
# (cross-hosted from the .NET ecosystem).
#
# -----------------------------------------------------------------------------
# BEEFBUILD'S CLI SURFACE (verbatim from BeefBuild/src/Program.bf help)
# -----------------------------------------------------------------------------
#
# USAGE:
#   BeefBuild [args]
#
# If no arguments are specified, a build will occur using current working
# directory as the workspace.
#
# Options:
#   -config=<config>           Sets the config (defaults to Debug)
#                              Common configs: Debug, Release, Paranoid
#   -generate                  Generates startup code for an empty project
#   -new                       Creates a new workspace and project
#   -platform=<platform>       Sets the platform (defaults to system platform)
#                              Common platforms: Win64, Linux64, macOS, iOS
#   -run                       Compile and run the startup project
#                              in the workspace
#   -test                      Run tests in the workspace
#   -verbosity=<verbosity>     Set verbosity level:
#                              quiet | minimal | normal | detailed | diagnostic
#   -version                   Get version
#   -workspace=<path>          Sets workspace path (defaults to cwd)
#   -project=<name>            Constrain build to a specific project within
#                              the workspace
#   -define=<name>             Add workspace preprocessor define
#                              (e.g., -define=DEBUG_VERBOSE)
#   -args                      Arguments to pass to the compiled program
#                              (must come after -run, all following args
#                              are passed through to the executable)
#   -help                      Print this help and exit
#
# Note: BeefBuild also accepts `--flag=value` form (the leading -- is
# stripped to a single -); this is the same convention used by BeefIDE,
# BeefPerf, MemProfiler, and other Beef binaries.
#
# =============================================================================

_BeefBuild() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a configs platforms verbosities

    configs=(
        'Debug:debug configuration (default)'
        'Release:optimized release build'
        'Paranoid:debug with extra runtime checks'
    )

    platforms=(
        'Win64:64-bit Windows'
        'Linux64:64-bit Linux'
        'macOS:macOS x86_64'
        'macOS-arm:macOS Apple Silicon'
        'iOS:iOS device'
        'wasm32:WebAssembly'
    )

    verbosities=(
        'quiet:minimal output'
        'minimal:errors and warnings only'
        'normal:default output'
        'detailed:verbose output'
        'diagnostic:full diagnostic trace'
    )

    _arguments -s \
        '-config=-[set build configuration]:config:->config' \
        '-generate[generate startup code for an empty project]' \
        '-new[create a new workspace and project]' \
        '-platform=-[set target platform]:platform:->platform' \
        '-run[compile and run the startup project]' \
        '-test[run tests in the workspace]' \
        '-verbosity=-[set verbosity level]:verbosity:->verbosity' \
        '-version[show version and exit]' \
        '-workspace=-[set workspace path]:workspace:_directories' \
        '-project=-[constrain build to specific project]:project name:' \
        '*-define=-[add workspace preprocessor define]:name:' \
        '-args[pass remaining args to compiled program (use after -run)]' \
        '-help[show help and exit]' \
        '*::passthrough:_default' \
        && ret=0

    case $state in
        (config)
            _describe -t configs 'build configuration' configs && ret=0
            ;;
        (platform)
            _describe -t platforms 'target platform' platforms && ret=0
            ;;
        (verbosity)
            _describe -t verbosities 'verbosity level' verbosities && ret=0
            ;;
    esac

    return ret
}

_BeefBuild "$@"
