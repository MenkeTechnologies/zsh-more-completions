#compdef fappend
# Append an extension from one FITS file onto the end of another

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "outfile=[output FITS file to append to]:file:_files" \
  "pkeywds=[copy primary array keywords]:bool:(yes no)" \
  "history=[add HISTORY keywords]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
