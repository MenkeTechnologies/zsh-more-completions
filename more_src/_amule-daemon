#compdef amule-daemon amuled
# Documentation: https://manpages.debian.org/bookworm/amule-daemon/amuled.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm amuled(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL.

# amule-daemon: aMule eD2k/Kad daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config-dir)'{-c+,--config-dir=}'[config directory]:dir:_files -/' \
  '(-f --full-daemon)'{-f,--full-daemon}'[fork to background]' \
  '(-p --pid-file)'{-p+,--pid-file=}'[PID file after fork]:file:_files' \
  '(-e --ec-config)'{-e,--ec-config}'[configure external connections]' \
  '(-o --log-stdout)'{-o,--log-stdout}'[print log messages to stdout]' \
  '(-r --reset-config)'{-r,--reset-config}'[reset config to defaults]' \
  '(-w --use-amuleweb)'{-w+,--use-amuleweb=}'[amuleweb binary path]:path:_files' \
  '(-d --disable-fatal)'{-d,--disable-fatal}'[do not handle fatal exception]' \
  '(-i --enable-stdin)'{-i,--enable-stdin}'[do not disable stdin]' \
  '(-t --category)'{-t+,--category=}'[category for passed eD2k links]:num:' \
  '*:eD2k or magnet link:' && ret=0
return ret
