#compdef dipoles gmx-dipoles
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-dipoles.html
# gmx dipoles: compute the total dipole plus fluctuations

local ret=1

_arguments -s \
  '-en[energy file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[total dipole moment output]:file:_files' \
  '-eps[dielectric constant data]:file:_files' \
  '-a[averaged dipole statistics]:file:_files' \
  '-d[dipole moment distribution]:file:_files' \
  '-c[autocorrelation function]:file:_files' \
  '-g[Kirkwood G-factor plot]:file:_files' \
  '-adip[additional dipole data]:file:_files' \
  '-dip3d[3D dipole information]:file:_files' \
  '-cos[average cosine values]:file:_files' \
  '-cmap[color map matrix]:file:_files' \
  '-slab[slab analysis]:file:_files' \
  '-b[first frame start time]:time:' \
  '-e[last frame end time]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output files]' \
  '-xvg[plot format]:format:(xmgrace xmgr none)' \
  '-mu[single molecule dipole in Debye]:real:' \
  '-mumax[maximum dipole for histogram in Debye]:real:' \
  '-epsilonRF[reaction field epsilon]:real:' \
  '-temp[average simulation temperature in K]:real:' \
  '-skip[frame skip interval]:int:' \
  '-corr[correlation calculation mode]:mode:(none mol molsep total)' \
  '-pairs[calculate pairwise cosine values]' \
  '-quad[include quadrupole contributions]' \
  '-ncos[polynomial order 1 or 2]:int:' \
  '-axis[box normal direction]:axis:(X Y Z)' \
  '-sl[number of box slices]:int:' \
  '-gkratom[atom index for distance calculation]:int:' \
  '-gkratom2[second atom index for two-group analysis]:int:' \
  '-rcmax[maximum distance for orientation distribution]:real:' \
  '-phi[plot torsion angle instead of dipole cosine]' \
  '-nlevels[color map levels]:int:' \
  '-ndegrees[Y-axis divisions for 180 degree range]:int:' \
  '-acflen[autocorrelation length]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[fit function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[fit start time]:real:' \
  '-endfit[fit end time]:real:' && ret=0

return ret
