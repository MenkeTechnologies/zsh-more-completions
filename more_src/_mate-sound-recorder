#compdef mate-sound-recorder
# Documentation: https://man.archlinux.org/search?q=mate-sound-recorder
# Reference accessed: 2026-05-16

# mate-sound-recorder: MATE GUI sound recorder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '*::mate-sound-recorder args:_files' && ret=0
return ret
