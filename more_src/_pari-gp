#compdef pari-gp gp

# PARI/GP: computer algebra system (number theory)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-f[no .gprc startup]' \
  '--fast[no .gprc startup]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-D[set default key=val]:key=val:' \
  '--default=[set default key=val]:key=val:' \
  '-s[stack size]:bytes:' \
  '--stacksize=[stack size]:bytes:' \
  '-p[primelimit]:n:' \
  '--primelimit=[primelimit]:n:' \
  '-e[errors as exceptions]' \
  '--emacs[Emacs mode]' \
  '--test[regression test mode]' \
  '--texmacs[TeXmacs mode]' \
  '--mpi[MPI mode]' \
  '*:gp script:_files -g "*.gp"' && ret=0
return ret
