#compdef tofu-ls
# _tofu-ls — OpenTofu language server (opentofu/tofu-ls)
# upstream: https://github.com/opentofu/tofu-ls
# Subcommands from main.go; serve flags from internal/cmd/serve_command.go.

_tofu-ls() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'serve:start the language server'
                'version:print version'
                'providers:provider schema utilities'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                serve)
                    _arguments \
                        '-port=[TCP port to listen on (0=stdio)]:port:' \
                        '-log-file=[log file path]:file:_files' \
                        '-cpuprofile=[CPU profile output file]:file:_files' \
                        '-memprofile=[memory profile output file]:file:_files' \
                        '-req-concurrency=[concurrent RPC request limit]:n:'
                    ;;
                providers)
                    _arguments '1:subcommand:(bundled)'
                    ;;
            esac
            ;;
    esac
}

_tofu-ls "$@"
