#compdef pwn
# Documentation: https://github.com/Gallopsled/pwntools/blob/dev/pwnlib/commandline/main.py
# Reference accessed: 2026-05-27
# Verified: upstream pwnlib/commandline/main.py commands dictionary

local curcontext="$curcontext" state line ret=1

local -a _pwn_subcommands
_pwn_subcommands=(
  'asm:assemble shellcode or assembly into bytes'
  'checksec:check binary security properties (NX/PIE/RELRO/Canary)'
  'constgrep:search constants from header files'
  'cyclic:generate or look up de Bruijn cyclic patterns'
  'debug:debug a process with GDB integration'
  'disasm:disassemble bytes to assembly'
  'disablenx:disable NX bit on an ELF binary'
  'elfdiff:diff two ELF binaries'
  'elfpatch:patch bytes in an ELF binary'
  'errno:look up errno value by number or name'
  'hex:hex-encode input data'
  'libcdb:query libc-database for matching libc'
  'phd:pretty hexdump (similar to xxd)'
  'pwnstrip:strip pwntools imports from a script'
  'scramble:generate self-decoding shellcode wrappers'
  'shellcraft:generate platform-specific shellcode'
  'template:generate a pwntools exploit template'
  'unhex:decode hex-encoded input data'
  'update:check for and apply pwntools updates'
  'version:print pwntools version'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'pwn subcommand' _pwn_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      checksec|disablenx|elfpatch|phd)
        _arguments \
          '(-h --help)'{-h,--help}'[show help and exit]' \
          '*:file:_files' && ret=0
        ;;
      elfdiff)
        _arguments \
          '(-h --help)'{-h,--help}'[show help and exit]' \
          '1:file a:_files' \
          '2:file b:_files' && ret=0
        ;;
      asm|disasm|cyclic|errno|hex|unhex|constgrep|scramble|pwnstrip)
        _arguments \
          '(-h --help)'{-h,--help}'[show help and exit]' \
          '*::arg:' && ret=0
        ;;
      debug|template|libcdb|shellcraft)
        _arguments \
          '(-h --help)'{-h,--help}'[show help and exit]' \
          '*::arg:_files' && ret=0
        ;;
      update|version)
        _arguments \
          '(-h --help)'{-h,--help}'[show help and exit]' && ret=0
        ;;
      *)
        _arguments '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
