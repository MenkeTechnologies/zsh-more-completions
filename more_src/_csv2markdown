_csv2markdown() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-q --quiet)'{-q,--quiet}'[suppress logger output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose logger output]' \
    '--no-color[disable colored logger output]' \
    '(-i --input)'{-i,--input}'[CSV file that you want to convert (REQUIRED)]:file:_files -g "*.csv"' \
    '(-o --output)'{-o,--output}'[Markdown file that this program should create (REQUIRED)]:file:_files -g "*.md"'
}

_csv2markdown "$@"
