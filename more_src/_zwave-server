#compdef zwave-server
# Documentation: https://github.com/zwave-js/zwave-js-server/blob/master/README.md
# Z-Wave JS WebSocket server

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[path to JSON or JS configuration file]:file:_files' \
  '--port=[WebSocket server listening port]:port' \
  '--host=[interface to bind to]:host' \
  '--mock-driver[use a fake USB stick for testing]' \
  '--disable-dns-sd[disable DNS-SD discovery]' \
  '--reconnect[enable automatic reconnection]' \
  '*:serial port:_files' && ret=0

return ret
