#compdef git-abort git-alias git-authors git-browse git-bulk git-coauthor git-commits-since git-count git-fork git-fresh-branch git-graft git-guilt git-merge-into
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 2. Companion to the round-150 _git-effort multi-stem
# and the pre-existing _git-changelog / _git-info / _git-ignore standalone
# files. Adds 13 more tj/git-extras subcommands.

local curcontext="$curcontext" state line ret=1

case $service in

  git-abort)
    # man/git-abort.1 — aborts the current operation. No flags or positionals.
    _arguments -s -S \
      && ret=0
    ;;

  git-alias)
    # man/git-alias.1 — 9 synopsis shapes, all variations of:
    #   git-alias [--global|--local] [<search-pattern> | <alias-name> <command>]
    _arguments -s -S \
      '(--global --local)--global[display/create alias in system config]' \
      '(--global --local)--local[display/create alias in repository config]' \
      '*:search pattern OR alias-name + git command:' \
      && ret=0
    ;;

  git-authors)
    # man/git-authors.1 — display author list.
    _arguments -s -S \
      '(-l --list)-l[show authors]' \
      '(-l --list)--list[show authors]' \
      '--no-email[do not show author emails]' \
      && ret=0
    ;;

  git-browse)
    # man/git-browse.1 — open repository in browser.
    #   git-browse [remote_name] [file_name] [line_1] [line_2]
    _arguments -s -S \
      '1:remote (default first remote):__git_remotes' \
      '2:file:_files' \
      '3:line number:' \
      '4:end line number for range:' \
      && ret=0
    ;;

  git-bulk)
    # man/git-bulk.1 — bulk git operations across registered workspaces.
    # Five distinct shapes share the same #compdef stem:
    #   git bulk [-g] ([-a]|-w <ws-name>) <git command>
    #   git bulk --addworkspace <ws-name> <ws-root> (--from <URL or file>)
    #   git bulk --removeworkspace <ws-name>
    #   git bulk --addcurrent <ws-name>
    #   git bulk --purge
    #   git bulk --listall
    _arguments -s -S \
      '-g[prompt for confirmation before each execution]' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)-a[execute git command across all workspaces]' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)-w+[execute on specific workspace]:workspace name:' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)--addworkspace=[register a new workspace]:workspace name:' \
      '--from=[clone repositories from URL or list file]:source URL or file:_files' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)--removeworkspace=[delete a registered workspace]:workspace name:' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)--addcurrent=[register current dir as workspace]:workspace name:' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)--purge[remove all defined repository locations]' \
      '(-a -w --addworkspace --removeworkspace --addcurrent --purge --listall)--listall[display all registered repositories]' \
      '*:git command or workspace root:' \
      && ret=0
    ;;

  git-coauthor)
    # man/git-coauthor.1 — append Co-authored-by trailer.
    #   git-coauthor <co-author> <co-author-email>
    _arguments -s -S \
      '1:co-author username:' \
      '2:co-author email:' \
      && ret=0
    ;;

  git-commits-since)
    # man/git-commits-since.1 — show commits more recent than a date.
    # Defaults to "last week" when no date is supplied.
    _arguments -s -S \
      '1:date (e.g. yesterday, "2 days ago", 2026-05-01):' \
      && ret=0
    ;;

  git-count)
    # man/git-count.1 — total commit count, or per-author with --all.
    _arguments -s -S \
      '--all[show commit count details per author]' \
      && ret=0
    ;;

  git-fork)
    # man/git-fork.1 — optional GitHub repo URL; works without args inside
    # an existing GitHub repository directory.
    _arguments -s -S \
      '1:GitHub repository URL (optional):' \
      && ret=0
    ;;

  git-fresh-branch)
    # man/git-fresh-branch.1 — create an orphan branch with no history.
    _arguments -s -S \
      '1:branch name to create:' \
      && ret=0
    ;;

  git-graft)
    # man/git-graft.1 — merge src-branch commits into dest-branch.
    _arguments -s -S \
      '1:source branch:__git_branch_names' \
      '2:destination branch:__git_branch_names' \
      && ret=0
    ;;

  git-guilt)
    # man/git-guilt.1 — blame stats between two commits.
    #   git guilt [<option>]
    #   git guilt [<option>] <since> [<until>]
    _arguments -s -S \
      '(- *)-h[output usage information]' \
      '(-e --email)-e[display author emails instead of names]' \
      '(-e --email)--email[display author emails instead of names]' \
      '(-w --ignore-whitespace)-w[ignore whitespace-only changes when attributing blame]' \
      '(-w --ignore-whitespace)--ignore-whitespace[ignore whitespace-only changes when attributing blame]' \
      '(-d --debug)-d[output debug information]' \
      '(-d --debug)--debug[output debug information]' \
      '1:since revision:__git_revisions' \
      '2:until revision (optional, default HEAD):__git_revisions' \
      && ret=0
    ;;

  git-merge-into)
    # man/git-merge-into.1 — merge into a branch other than HEAD.
    #   git merge-into [src] <dest> [--ff-only]
    _arguments -s -S \
      '--ff-only[refuse merge unless fast-forwardable]' \
      '1:source branch (default current):__git_branch_names' \
      '2:destination branch:__git_branch_names' \
      && ret=0
    ;;

esac

return ret
