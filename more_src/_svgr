#compdef svgr
# Documentation: https://man.archlinux.org/search?q=svgr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-file=[svgr config file]:file:_files -g "*.{js,json,cjs,mjs,ts}"' \
  '--no-runtime-config[disable runtime config]' \
  '(-d --out-dir)'{-d+,--out-dir=}'[output directory]:dir:_files -/' \
  '--ignore-existing[ignore existing files in out-dir]' \
  '--ext=[output file extension]:ext:(js jsx ts tsx)' \
  '--typescript[generate TypeScript components]' \
  '--filename-case=[filename casing]:case:(pascal kebab camel snake)' \
  '--template=[custom template file]:file:_files' \
  '--index-template=[custom index template]:file:_files' \
  '--no-prettier[disable Prettier formatting]' \
  '--prettier-config=[Prettier config file]:file:_files' \
  '--no-svgo[disable SVGO optimization]' \
  '--svgo-config=[SVGO config file]:file:_files' \
  '--icon[use 1em width and height]' \
  '--native[add react-native support]' \
  '--memo[wrap in React.memo]' \
  '--ref[forward ref to SVG root]' \
  '--title-prop[add title prop]' \
  '--desc-prop[add desc prop]' \
  '--no-dimensions[remove width/height from root SVG]' \
  '--expand-props=[expand props position]:pos:(start end none)' \
  '--replace-attr-values=[replace attribute value (old=new)]:map:' \
  '--svg-props=[add prop to <svg>]:kv:' \
  '--silent[suppress non-error output]' \
  '--jsx-runtime=[JSX runtime]:runtime:(classic automatic classic-preact)' \
  '--namespace=[icon namespace]:name:' \
  '*:svg_file_or_dir:_files -g "*.svg"' && ret=0

return ret
