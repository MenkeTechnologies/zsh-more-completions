#compdef terraform-bundle
# Documentation: https://github.com/hashicorp/terraform/blob/v0.15/tools/terraform-bundle/README.md
# Create a Terraform bundle archive with selected provider plugins

local ret=1

_arguments -s -S \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    if (( CURRENT == 1 )); then
      _values 'terraform-bundle command' \
        'package[create a bundle zip with terraform and provider plugins]' && ret=0
    else
      _arguments -s -S \
        '-os=[target operating system for the bundle]:os:(darwin freebsd linux openbsd solaris windows)' \
        '-arch=[target CPU architecture for the bundle]:arch:(386 amd64 arm arm64)' \
        '-plugin-dir=[directory to search for custom plugins]:dir:_files -/' \
        '*:config file:_files -g "*.hcl"' && ret=0
    fi
    ;;
esac

return ret
