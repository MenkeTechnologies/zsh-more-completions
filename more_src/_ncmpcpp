#compdef ncmpcpp
# Documentation: https://github.com/ncmpcpp/ncmpcpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for ncmpcpp - NCurses Music Player Client Plus Plus

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-h --host)'{-h+,--host=}'[connect to host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[connect to port]:port:' \
  '(-c --config)'{-c+,--config=}'[specify config file]:config file:_files' \
  '(-b --bindings)'{-b+,--bindings=}'[specify bindings file]:bindings file:_files' \
  '(-s --screen)'{-s+,--screen=}'[start on screen]:screen:(help playlist browser search_engine media_library playlist_editor tag_editor outputs visualizer clock lyrics)' \
  '(-S --slave-screen)'{-S+,--slave-screen=}'[set slave screen]:screen:(help playlist browser search_engine media_library playlist_editor tag_editor outputs visualizer clock lyrics)' \
  '(-q --quiet)'{-q,--quiet}'[suppress logs and excess output]' \
  '--current-song=[print current song using format and exit]:format:' \
  '--ignore-config-errors[ignore unknown and invalid options in config]' \
  '--test-lyrics-fetchers[check if lyrics fetchers work]' \
  && ret=0

return ret
