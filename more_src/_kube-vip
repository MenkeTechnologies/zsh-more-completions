#compdef kube-vip

# Zsh completion for kube-vip - Virtual IP manager for Kubernetes

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start kube-vip'
      'manager:start kube-vip manager'
      'manifest:generate manifest'
      'kubeconfig:generate kubeconfig'
    )
    _describe -t commands 'kube-vip command' commands && ret=0
    ;;
  args)
    case $line[1] in
      start|manager)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--interface=[network interface]:interface:_net_interfaces' \
          '--address=[virtual IP address]:address' \
          '--vip=[virtual IP address]:vip' \
          '--controlplane[enable control plane load balancing]' \
          '--services[enable service load balancing]' \
          '--arp[enable ARP]' \
          '--bgp[enable BGP]' \
          '--leaderElection[enable leader election]' \
          '--inCluster[run in-cluster]' \
          '--taint[taint nodes]' \
          '--bgppeers=[BGP peers]:peers' \
          '--localAS=[local AS number]:as' \
          '--bgpRouterID=[BGP router ID]:id' \
          '--annotations=[annotations]:annotations' \
          '--port=[port for VIP]:port' \
          '--namespace=[namespace]:namespace' \
          '--cidr=[CIDR for address range]:cidr' \
          '--enableLoadBalancer[enable load balancer]' && ret=0
        ;;
      manifest)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:type:->manifest_types' \
          '*::arg:->manifest_args' && ret=0
        case $state in
          manifest_types)
            local -a types=(
              'pod:generate pod manifest'
              'daemonset:generate daemonset manifest'
            )
            _describe -t types 'manifest type' types && ret=0
            ;;
          manifest_args)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '--interface=[network interface]:interface:_net_interfaces' \
              '--address=[virtual IP address]:address' \
              '--vip=[virtual IP address]:vip' \
              '--controlplane[enable control plane load balancing]' \
              '--services[enable service load balancing]' \
              '--arp[enable ARP]' \
              '--bgp[enable BGP]' \
              '--leaderElection[enable leader election]' \
              '--inCluster[run in-cluster]' \
              '--taint[taint nodes]' \
              '--bgppeers=[BGP peers]:peers' \
              '--localAS=[local AS number]:as' \
              '--bgpRouterID=[BGP router ID]:id' \
              '--annotations=[annotations]:annotations' && ret=0
            ;;
        esac
        ;;
      kubeconfig)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
