#compdef termdown
# Documentation: https://github.com/trehn/termdown
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for termdown - terminal countdown timer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --alt-format)'{-a,--alt-format}'[use colon-separated time format]' \
  '(-f --font)'{-f,--font=}'[ASCII art font name or OTF/TTF path]:font:' \
  '--font-charset=[charset for OTF/TTF rendering]:charset:' \
  '--font-size=[font size for custom font]:size:' \
  '(-s --no-seconds)'{-s,--no-seconds}'[hide seconds except final minute]' \
  '(-t --text)'{-t,--text=}'[text to display when countdown ends]:text:' \
  '(-T --title)'{-T,--title=}'[title above timer]:title:' \
  '(-z --time)'{-z,--time}'[display current time]' \
  '(-Z --time-format)'{-Z,--time-format=}'[time display format]:format:' \
  '(-D --date-format)'{-D,--date-format=}'[date display format]:format:' \
  '--no-art[disable ASCII art rendering]' \
  '--no-text-magic[do not interpret text as time]' \
  '(-W --no-window-title)'{-W,--no-window-title}'[do not update window title]' \
  '(-b --blink)'{-b,--blink}'[blink terminal on expiration]' \
  '(-B --no-bell)'{-B,--no-bell}'[suppress terminal bell]' \
  '(-c --critical)'{-c,--critical=}'[critical threshold seconds]:seconds:' \
  '(-v --voice)'{-v,--voice=}'[voice name for speech output]:voice:' \
  '(-p --voice-prefix)'{-p,--voice-prefix=}'[prefix for voice announcements]:text:' \
  '--exec-cmd=[command to execute each second]:cmd:' \
  '(-o --outfile)'{-o,--outfile=}'[write remaining time to file]:file:_files' \
  '(-e --end)'{-e,--end}'[display target datetime]' \
  '(-q --quit-after)'{-q,--quit-after=}'[quit N seconds past expiration]:seconds:' \
  '1:time (e.g. 5m, 1h30m, 10):' && ret=0

return ret
