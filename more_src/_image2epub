#compdef image2epub
# ============================================================================
# image2epub - convert image folders to EPUB (Node)
#
# Author : rni-l
# Upstream: https://github.com/rni-l/image2epub
# npm    : image2epub
#
# image2epub recursively walks a folder of .jpg / .jpeg / .png
# images and bundles them into one EPUB per subfolder (or one
# combined EPUB at the root). Each image becomes a page in the
# EPUB, wrapped in an `<img>` tag inside a per-page XHTML content
# document. The first image of each folder becomes the cover.
# Supports `--deep` for recursive multi-folder export and a
# required `--output` directory for the emitted .epub files.
#
# The EPUB emission lane is built on `epub-gen ^0.1.0` (declared
# verbatim at upstream package.json HEAD), the canonical Node EPUB
# writer by Cyril (cyrilis, github.com/cyrilis/epub-gen, 450+
# stars). epub-gen is a declarative builder: instead of method
# chaining, the caller passes a single options object with title,
# author, cover, content[], CSS, and fonts to `new Epub(options)`,
# and the constructor returns a `.promise` that resolves when the
# file is written. The library handles OCF zip framing, OPF
# manifest + spine, NCX + nav.xhtml table of contents, XHTML 1.1
# content profile, and asset embedding.
#
# Verbatim usage pattern from upstream `index.js`:
#
#     #!/usr/bin/env node
#     const Epub = require("epub-gen");
#     const option = {
#         title: options.title || 'Album',
#         author: options.author || 'Author',
#         output: options.output,
#         content: [],
#         cover: `${path.join(imagesPath, imageFiles[0])}`
#     };
#     imageFiles.forEach((file, i) => {
#         option.content.push({
#             data: `<img src="file://${path.join(imagesPath, file)}" />`
#         });
#     });
#     const ins = new Epub(option);
#     return ins.promise.then(...)
#
# ----------------------------------------------------------------------------
# AXIS 203 :: EPUB GENERATION (EPUB 2 / EPUB 3 / OPF / NCX)  [CLOSES]
# Round 1309 :: TS-Node slot 3 of 4 :: CLOSES Axis 203 (196th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : crowdagger/epub-builder      [R1307 _manga-tui]
#   Go      : bmaupin/go-epub              [R1308 _comics-downloader]
#   TS/Node : cyrilis/epub-gen             [R1309 THIS FILE]
#
# All three closes converged thematically on the image-heavy
# EPUB workload: manga-tui downloads manga panels and bundles
# chapter EPUBs; comics-downloader does the same for Western
# comics + manga across multiple sources; image2epub generalizes
# to arbitrary image folders. This is a deliberate axis closure
# pattern - each lane's closer exercises the EPUB-generator
# library against many embedded images and per-page Spine
# entries rather than the typical text-only novel that the
# README examples show.
#
# Structural note: the three canonical libs all target EPUB 3.x
# with EPUB 2 back-compat (nav.xhtml + NCX both emitted), and
# all three rely on a zip implementation underneath - JSZip in
# Node, the Go stdlib `archive/zip`, and the `zip` crate in
# Rust. The OCF wrapper is the load-bearing reason EPUB needs
# a zip lib at all.
# ============================================================================

_image2epub() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :((g\:"generate EPUB from image folder"))' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                g) _image2epub_generate ;;
            esac
            ;;
    esac

    return ret
}

_image2epub_generate() {
    _arguments -s -S \
        '(-t --title)'{-t,--title}'[set EPUB title]:title:' \
        '(-a --author)'{-a,--author}'[set EPUB author]:author:' \
        '(-d --deep)'{-d,--deep}'[recursively walk subfolders]:depth:' \
        '(-o --output)'{-o,--output}'[output folder (required)]:directory:_files -/' \
        '(- *)'{-h,--help}'[help]' \
        '1:image folder:_files -/'
}

_image2epub "$@"
