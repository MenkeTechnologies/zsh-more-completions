#compdef abidiff
# Documentation: https://sourceware.org/libabigail/manual/abidiff.html
# libabigail tool to compare the ABIs of two ELF binaries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug-info-dir1[first debug info directory]:dir:_files -/' \
  '--debug-info-dir2[second debug info directory]:dir:_files -/' \
  '--headers-dir1[first public headers directory]:dir:_files -/' \
  '--headers-dir2[second public headers directory]:dir:_files -/' \
  '--header-file1[first public header file]:file:_files' \
  '--header-file2[second public header file]:file:_files' \
  '--stat[show statistics about the work done]' \
  '--symtabs[only display the symbol tables]' \
  '--deleted-fns[show deleted functions]' \
  '--changed-fns[show changed functions]' \
  '--added-fns[show added functions]' \
  '--deleted-vars[show deleted variables]' \
  '--changed-vars[show changed variables]' \
  '--added-vars[show added variables]' \
  '--no-linkage-name[do not display linkage names]' \
  '--no-show-locs[do not show source locations]' \
  '*--suppressions[suppression specification file]:file:_files' \
  '--drop[drop functions/variables matching a regexp]:regexp' \
  '--drop-fn[drop functions matching a regexp]:regexp' \
  '--drop-var[drop variables matching a regexp]:regexp' \
  '--keep[keep functions/variables matching a regexp]:regexp' \
  '--keep-fn[keep functions matching a regexp]:regexp' \
  '--keep-var[keep variables matching a regexp]:regexp' \
  '--harmless[display only the harmless changes]' \
  '--no-harmful[do not display the harmful changes]' \
  '--redundant[display redundant changes]' \
  '--no-redundant[do not display redundant changes]' \
  '--impacted-interfaces[show impacted interfaces]' \
  '--dump-diff-tree[dump the internal diff tree]' \
  '--fail-no-debug-info[fail if no debug info is found]' \
  '*:file:_files' && ret=0

return ret
