#compdef netspoc
# ============================================================================
#  _netspoc — netspoc: network security policy compiler
#             (Heinz Knutzen, hknutzen/Netspoc) — compiles
#             high-level service descriptions into ACLs for
#             Cisco IOS/NX-OS/ASA, Fortinet, Linux iptables,
#             OpenBSD pf, Palo Alto, IPsec, and other network-
#             device platforms
#
#  Source-direct extraction from
#    https://github.com/hknutzen/Netspoc/blob/master/go/pkg/conf/GetArgs.go
#    https://github.com/hknutzen/Netspoc/blob/master/go/pkg/pass1/spoc.go (SpocMain + getArgs)
#    https://github.com/octago/sflags (the octago/sflags library
#    — struct-tag based flag GENERATOR for stdlib flag /
#    urfave-cli / pflag / cobra / kingpin)
#
#  Maintained by Heinz Knutzen (heinz.knutzen@googlemail.com —
#  long-running open-source network-policy project).  77 GH
#  stars on hknutzen/Netspoc.  Netspoc is a network security
#  policy compiler — administrators write HIGH-LEVEL SERVICE
#  DESCRIPTIONS (using Netspoc's declarative policy language)
#  and Netspoc generates the LOW-LEVEL device-specific ACLs +
#  routes + firewall rules to enforce those policies.  Targets
#  Cisco IOS / IOS-XE / NX-OS / ASA, Fortinet FortiGate, Linux
#  iptables / nftables, OpenBSD pf, Palo Alto, IPsec, and more.
#  Netspoc is a 30+ year network ops project (originally a Perl
#  codebase, now in Go) with a rich service description language
#  (services, hosts, networks, groups, routers, areas, owners,
#  policy_distribution_points, etc.) and EXTENSIVE static-
#  analysis checks (redundancy detection, supernet rule analysis,
#  unused-owner detection, etc.).  Netspoc ships 17 companion
#  binaries: netspoc (main compiler), check-acl, cut-netspoc,
#  expand-group, export-netspoc, export-netvis, format-netspoc,
#  modify-netspoc-api, add-to-netspoc, print-group, print-path,
#  print-service, remove-from-netspoc, remove-service, rename-
#  netspoc, transpose-service, export-netspoc-syntax — all using
#  the same Config struct + sflags/gpflag flag generation.
#  Sister tools: capirca (Google's policy compiler — in corpus
#  via _capirca), nipper (network device auditor), batfish
#  (Intentionet's network config analysis), cisco-iosfw (Cisco
#  IOS firewall analyzer), pfsense-config (pfSense management),
#  network-config-management (NCM tooling), ipinfusion (commercial
#  alternative).
#
#  CLI library taxonomy update: 16th Go CLI library — octago's
#  **sflags** (octago/sflags).  Go ecosystem now has 16
#  documented CLI libraries — RE-TAKING THE SOLO LEAD as the
#  MOST-DOCUMENTED CLI LANGUAGE in the cross-language taxonomy
#  ahead of Rust (15) and TypeScript-Node (15).  🎉 Go BREAKS
#  the THREE-WAY TIE.
#
#  sflags (octago/sflags) is a STRUCT-TAG-BASED FLAG GENERATOR
#  by octago.  165 GH stars.  Distinguishing philosophy: sflags
#  is NOT a standalone CLI framework — it's a META-LIBRARY that
#  GENERATES flag registrations FOR OTHER libraries.  Caller
#  defines a Config struct with field tags, then calls one of
#  sflags's "gen" subpackages to emit appropriate flag
#  registrations for the target library:
#    - `gen/gflag`     → stdlib `flag` registrations
#    - `gen/gpflag`    → `spf13/pflag` registrations (also
#                        usable with `spf13/cobra`)
#    - `gen/gcli`      → `urfave/cli` registrations
#    - `gen/gkingpin`  → `alecthomas/kingpin` registrations
#  This GENERATOR PATTERN bridges the gap between struct-tag
#  declarative style (popular for config files via mitchellh/
#  mapstructure / envconfig / json-tags) and Go's various
#  legacy/idiomatic CLI frameworks.  Used by hknutzen/Netspoc
#  (77 stars) + 16 companion binaries, cockroachdb/cockroach-
#  operator (CockroachDB K8s operator 315 stars; uses gen/gpflag
#  for kubetest2-k3d and kubetest2-eks deployers), BBVA/qed
#  (BBVA's tamper-evident log 102 stars; uses gen/gpflag inside
#  cobra commands), containerum/chkit (Containerum desktop CLI
#  22 stars), sethpollack/dockerbox (docker-run config mgr),
#  cyberark/idsec-cli-golang (CyberArk official CLI),
#  RyoJerryYu/schemax, yindaheng98/vmessconfig, and many other
#  Go CLIs that prefer struct-tag declarative ergonomics with
#  flag registration delegated to an existing framework.
#
#  sflags API:
#    import (
#      "github.com/octago/sflags"
#      "github.com/octago/sflags/gen/gpflag"  // pick a generator
#      "github.com/spf13/pflag"
#    )
#
#    type Config struct {
#      // Field NAMES become flag names (default CamelCase →
#      // kebab-case; configurable via FlagDivider("_") for
#      // snake_case)
#      MaxErrors int    `flag:"max_errors m"`        // long+short
#      Quiet     bool   `flag:"quiet q"`
#      LogLevel  string `desc:"Log verbosity level"` // desc tag
#      Tags      []string                            // slice → repeatable
#      Region    string `env:"AWS_REGION"`           // env var fallback
#      Verbose   int    `flag:",hidden"`             // hidden flag
#    }
#
#    fs := pflag.NewFlagSet("mytool", pflag.ContinueOnError)
#    cfg := &Config{
#      MaxErrors: 10,                                // defaults via
#      Quiet: false,                                  // struct init
#    }
#    // Generate pflag registrations from cfg's struct tags
#    err := gpflag.ParseTo(cfg, fs,
#      sflags.FlagDivider("_"),                     // snake_case
#      sflags.FlagTag("flag"),                      // tag name to read
#    )
#    if err != nil { /* handle */ }
#
#    fs.Parse(os.Args[1:])
#    // cfg.MaxErrors now reflects -m / --max_errors value
#
#  sflags distinctive features:
#    - GENERATOR PATTERN: sflags itself does NOT define a
#      FlagSet/parser API — instead it READS struct tags and
#      DELEGATES flag registration to existing libraries via
#      `gen/<target>` subpackages
#    - STRUCT TAGS supported:
#      * `flag:"name shorthand"` — explicit flag long+short names
#        (sflags's primary tag)
#      * `flag:",hidden"` — hidden flag (excluded from --help)
#      * `flag:",deprecated"` — deprecated flag with warning
#      * `desc:"help text"` — flag description
#      * `env:"VAR_NAME"` — env-var fallback
#    - FIELD-NAME-TO-FLAG-NAME conversion (default kebab-case;
#      configurable):
#      * `MaxErrors`     → `--max-errors` (default kebab-case)
#      * With `sflags.FlagDivider("_")` → `--max_errors`
#        (snake_case)
#      * `sflags.FlagTag("flag")` — use custom tag name
#    - TYPE INFERENCE from struct field types:
#      * `bool` → boolean flag
#      * `int`/`int64`/`uint` → integer flag
#      * `string` → string flag
#      * `[]string`/`[]int` → REPEATABLE slice flag
#      * `time.Duration` → duration flag
#      * `net.IP`/`net.IPMask` → IP-typed flag (pflag-specific)
#      * Custom types implementing `pflag.Value`/`flag.Value`
#        interface → custom-typed flag
#    - DEFAULT VALUES from struct initialization (e.g.
#      `cfg := &Config{ MaxErrors: 10 }` sets default 10)
#    - NESTED STRUCTS supported via `flag-prefix` tag — fields of
#      embedded structs get prefixed flag names
#    - INSPIRED BY mitchellh/mapstructure (struct-tag config
#      mapping) + jessevdk/go-flags (struct-tag CLI flags), but
#      OPPOSITE PHILOSOPHY: jessevdk/go-flags is a self-contained
#      framework; sflags is a flag-GENERATOR for OTHER frameworks
#  Distinct from R237 Go spf13/cobra (subcommand-TREE framework —
#  Hugo/Kubernetes/Docker; sflags can BE USED WITH cobra via
#  gen/gpflag to generate cobra's pflag registrations from
#  structs — Netspoc uses this combination), R237 Go spf13/pflag
#  (POSIX-flag-compat replacement for stdlib flag — sflags has
#  gen/gpflag for pflag), R237 Go urfave/cli (action-callback
#  framework — sflags has gen/gcli for urfave/cli), R237 Go
#  alecthomas/kingpin (chained-builder — sflags has gen/gkingpin),
#  R237 Go jessevdk/go-flags (struct-tag based; CLOSEST RIVAL —
#  jessevdk/go-flags is a SELF-CONTAINED struct-tag parser, sflags
#  is a struct-tag GENERATOR for OTHER frameworks; sflags wins on
#  flexibility-to-pair-with-cobra, jessevdk wins on simplicity),
#  R237 Go mitchellh/cli (HashiCorp Terraform), R262 Go stdlib
#  `flag` (sflags has gen/gflag for stdlib flag), R363 Go
#  peterbourgon/ff (functional-options 3-way config flag/env/file
#  merge), R367 Go akamensky/argparse (Python-argparse-style port),
#  R408 Go pborman/getopt (POSIX-getopt(3) faithful BSD/C-style
#  — oklog/ulid), R411 Go integrii/flaggy (package-level functional-
#  builder — joanbono/Gurp + jesseduffield/lazydocker), R414 Go
#  alecthomas/kong (modern struct-tag — charmbracelet/freeze + gum
#  + mtg), R417 Go google/subcommands (pure subcommand dispatch
#  using stdlib flag — future-architect/vuls + gvisor), R421 Go
#  namsral/flag (stdlib flag drop-in with env-var fallback —
#  smocker-dev/smocker).  Go documented libraries so far: stdlib
#  flag, pflag, cobra, urfave-cli, kingpin, jessevdk/go-flags,
#  mitchellh/cli, ff, akamensky/argparse, pborman/getopt, flaggy,
#  kong, google/subcommands, namsral/flag, sflags (this round)...
#  16 total.  sflags's distinguishing feature vs all other Go
#  libs: sflags is the ONLY Go CLI library in the corpus that is
#  a META-GENERATOR — it doesn't define a parser, it GENERATES
#  flag registrations for the parser of your choice.  Bridges
#  struct-tag declarative ergonomics with existing frameworks
#  (cobra/urfave/kingpin) WITHOUT requiring migration off them.
#  sflags's approach: STRUCT-TAG-DRIVEN FLAG GENERATOR with
#  `flag:"name short"`/`desc:"..."`/`env:"VAR"` struct tags +
#  `gen/gflag`/`gen/gpflag`/`gen/gcli`/`gen/gkingpin` subpackage
#  generators emitting registrations for the target library +
#  `sflags.FlagDivider("_")`/`sflags.FlagTag("name")`/`sflags.
#  EnvDivider("_")` configuration options + TYPE INFERENCE from
#  struct field types (bool/int/string/[]T/time.Duration/net.IP)
#  + DEFAULT VALUES from struct initialization + NESTED struct
#  support with `flag-prefix` tag + INSPIRED BY mitchellh/
#  mapstructure + jessevdk/go-flags (but generator-pattern not
#  framework) — corpus's **first documented meta-flag-generator
#  Go CLI library**.  Brings cross-language CLI library taxonomy
#  variant count to 165; Go ecosystem now has 16 documented CLI
#  libraries — RE-TAKING THE SOLO LEAD as the MOST-DOCUMENTED CLI
#  LANGUAGE in the cross-language taxonomy ahead of Rust (15) and
#  TypeScript-Node (15).
#
#  Surface (verbatim from `go/pkg/conf/GetArgs.go` Config struct +
#  `go/pkg/pass1/spoc.go` getArgs usage with
#  `sflags.FlagDivider("_")` snake_case option):
#
#  Usage:
#    netspoc [options] IN-DIR|IN-FILE [CODE-DIR]
#
#  Positional:
#    IN-DIR | IN-FILE               Input Netspoc source — either
#                                   a directory containing .info
#                                   .net .group .protocol .owner
#                                   .service .topology files, or
#                                   a single Netspoc input file
#    CODE-DIR                       Output directory for generated
#                                   ACL/route/firewall files (one
#                                   file per managed router).
#                                   Optional — if absent, runs
#                                   syntax check only (no codegen)
#
#  Tri-state check options (accept 0|no|false / 1|err|error /
#  warn|w; default-empty values map to "no check"):
#    --check_duplicate_rules        Check for duplicate rules
#                                   (default: warn)
#    --check_redundant_rules        Check for redundant rules
#                                   (default: warn)
#    --check_fully_redundant_rules  Check for fully redundant rules
#                                   (default: off)
#    --check_identical_services     Check for identical service defs
#                                   (default: off)
#    --check_service_empty_user     Check for services with empty user
#                                   (default: warn)
#    --check_service_multi_owner    Check for services with multiple
#                                   derived owners (default: warn)
#    --check_service_unknown_owner  Check for services where owner
#                                   can't be derived (default: off)
#    --check_service_useless_attribute  Check for useless attributes
#                                   in service (default: warn)
#    --check_subnets                Check subnets only if enclosing
#                                   network has has_subnets or
#                                   subnet_of (default: warn)
#    --check_supernet_rules         Check for missing supernet rules
#                                   (default: warn)
#    --check_transient_supernet_rules  Check for transient supernet
#                                   rules (default: warn)
#    --check_unenforceable          Check for unenforceable rules
#                                   (no managed device between src
#                                   and dst; default: warn)
#    --check_unused_groups          Check for unused groups (default:
#                                   warn)
#    --check_unused_owners          Check for unused owners (default:
#                                   warn)
#    --check_unused_protocols       Check for unused protocol defs
#                                   (default: off)
#    --check_empty_files            Check for files without content
#                                   (default: warn)
#    --check_policy_distribution_point  Check that managed routers
#                                   have policy_distribution_point
#                                   either directly or inherited
#                                   (default: off)
#
#  Compilation options:
#    --auto_default_route           Optimize routing table by
#                                   collapsing largest-hop set into
#                                   default route (default: true)
#    --concurrency_pass1 <N>        Pass-1 concurrency level
#                                   (default: 1; set >=2 for
#                                   parallel processing)
#    --concurrency_pass2 <N>        Pass-2 concurrency level
#                                   (default: 1)
#
#  Output/diagnostic options:
#    -m, --max_errors <N>           Abort after N errors (default: 10)
#    -q, --quiet                    Suppress progress messages
#    -t, --time_stamps              Print progress messages with
#                                   timestamps; print "finished"
#                                   with timestamp when done
#        --debug_pass2 <NAME>       Debug pass2 for device NAME
#                                   (e.g. "ROUTER1" or "ipv6/ROUTER1")
#
#  Auto from pflag (since gpflag generates spf13/pflag bindings):
#    -h, --help                     Show this help and exit
#
#  Examples:
#    netspoc src/                                     # Syntax check src/ Netspoc files
#    netspoc src/ out/                                # Compile to out/ (ACL files per router)
#    netspoc src/main.netspoc out/                    # Single-file input
#    netspoc -q src/ out/                             # Quiet mode (suppress progress)
#    netspoc -t src/ out/                             # Timestamped progress
#    netspoc -m 50 src/ out/                          # Allow up to 50 errors
#    netspoc --check_redundant_rules=err src/ out/    # Treat redundant rules as errors
#    netspoc --check_duplicate_rules=0 src/ out/      # Disable duplicate check
#    netspoc --concurrency_pass1=4 --concurrency_pass2=4 src/ out/
#    netspoc --debug_pass2 ROUTER1 src/ out/          # Debug pass2 for ROUTER1
#
#  Companion binaries (out of scope for this completion; each
#  ships its own binary using shared sflags Config):
#    add-to-netspoc, check-acl, cut-netspoc, expand-group,
#    export-netspoc-syntax, export-netspoc, export-netvis,
#    format-netspoc, modify-netspoc-api, print-group, print-path,
#    print-service, remove-from-netspoc, remove-service,
#    rename-netspoc, transpose-service — each has its own
#    completion file or similar getArgs surface
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also sflags users):
#    - chkit (containerum/chkit 22 stars — Containerum desktop
#      CLI; FUTURE candidate)
#    - qed (BBVA/qed 102 stars — tamper-evident log; uses
#      sflags gen/gpflag inside cobra commands; FUTURE candidate)
#    - cockroach-operator (cockroachdb/cockroach-operator 315
#      stars — K8s operator; runs in cluster not as user CLI)
#    - dockerbox (sethpollack/dockerbox 21 stars — too niche)
#    - idsec-cli-golang (cyberark/idsec-cli-golang 6 stars CyberArk
#      official CLI — too niche)
#    - schemax (RyoJerryYu/schemax — schema tool; FUTURE)
#    - vmessconfig (yindaheng98/vmessconfig — V2Ray config tool;
#      FUTURE)
# ============================================================================

_netspoc() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '--check_duplicate_rules=[check for duplicate rules]:value:(0 1 warn)' \
    '--check_redundant_rules=[check for redundant rules]:value:(0 1 warn)' \
    '--check_fully_redundant_rules=[check for fully redundant rules]:value:(0 1 warn)' \
    '--check_identical_services=[check for identical service definitions]:value:(0 1 warn)' \
    '--check_service_empty_user=[check for services with empty user]:value:(0 1 warn)' \
    '--check_service_multi_owner=[check for services with multiple derived owners]:value:(0 1 warn)' \
    '--check_service_unknown_owner=[check for services where owner cannot be derived]:value:(0 1 warn)' \
    '--check_service_useless_attribute=[check for useless attributes in service]:value:(0 1 warn)' \
    '--check_subnets=[check subnets only if enclosing network marked]:value:(0 1 warn)' \
    '--check_supernet_rules=[check for missing supernet rules]:value:(0 1 warn)' \
    '--check_transient_supernet_rules=[check for transient supernet rules]:value:(0 1 warn)' \
    '--check_unenforceable=[check for unenforceable rules]:value:(0 1 warn)' \
    '--check_unused_groups=[check for unused groups]:value:(0 1 warn)' \
    '--check_unused_owners=[check for unused owners]:value:(0 1 warn)' \
    '--check_unused_protocols=[check for unused protocol definitions]:value:(0 1 warn)' \
    '--check_empty_files=[check for files without content]:value:(0 1 warn)' \
    '--check_policy_distribution_point=[check managed routers have policy_distribution_point]:value:(0 1 warn)' \
    '--auto_default_route=[optimize routing table by collapsing largest-hop set]:value:(true false)' \
    '--concurrency_pass1=[pass-1 concurrency level]:n:' \
    '--concurrency_pass2=[pass-2 concurrency level]:n:' \
    '(-m --max_errors)'{-m,--max_errors=}'[abort after N errors]:n:' \
    '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
    '(-t --time_stamps)'{-t,--time_stamps}'[print progress with timestamps]' \
    '--debug_pass2=[debug pass2 for device NAME]:name:' \
    ':input:_files' \
    '::output-dir:_directories'
}

_netspoc "$@"
