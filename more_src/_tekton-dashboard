#compdef tekton-dashboard
# _tekton-dashboard — Tekton Dashboard web UI server
# upstream: https://github.com/tektoncd/dashboard
# Flags from cmd/dashboard/main.go on tip.

_tekton-dashboard() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--pipelines-namespace=[Tekton Pipelines install namespace]:ns:' \
        '--triggers-namespace=[Tekton Triggers install namespace]:ns:' \
        '--port=[dashboard listen port]:port:' \
        '--read-only=[enable read-only mode]:bool:(true false)' \
        '--logout-url=[logout URL for frontend logout button]:url:' \
        '--default-namespace=[default selected namespace]:ns:' \
        '--namespaces=[comma-separated tenant namespaces]:csv:' \
        '--log-level=[minimum log level]:level:(debug info warn error)' \
        '--log-format=[log output format]:fmt:(json console)' \
        '--stream-logs=[stream logs instead of polling]:bool:(true false)' \
        '--external-logs=[external logs provider URL]:url:' \
        '--x-frame-options=[X-Frame-Options response header value]:value:(DENY SAMEORIGIN)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_tekton-dashboard "$@"
