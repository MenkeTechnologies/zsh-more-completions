#compdef palentry
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss134.html
# KAPPA: enter a colour into an image display's palette

local ret=1

_arguments -s \
  'PALNUM=[palette entry number to modify]:palnum' \
  'COLOUR=[colour to add to the palette]:colour' \
  'DEVICE=[graphics device to use]:device' \
  '*:NDF:_files' && ret=0

return ret
