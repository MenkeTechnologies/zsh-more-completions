#compdef hubPublicCheck
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: check that labels in hubPublic match the hub labels

local ret=1

_arguments -s -S \
  '-udcDir=[place to put cache for remote bigBed/bigWigs]:dir:_files -/' \
  '-addHub=[output statements to add url to table]:url' \
  '1:table name:' && ret=0

return ret
