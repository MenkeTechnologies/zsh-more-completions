#compdef mako-utils makoctl
# Documentation: https://manpages.debian.org/bookworm/mako-notifier/makoctl.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm makoctl(1) manpage SUBCOMMANDS section. The
# mako-utils package provides makoctl(1).

# makoctl: control mako notification daemon
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'dismiss:dismiss a notification'
  'restore:restore most recently expired notification'
  'invoke:invoke action on a notification'
  'menu:use program to select an action'
  'list:list current notifications'
  'reload:reload configuration file'
  'mode:set notification mode'
  'history:show notification history'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'makoctl command' commands && ret=0 ;;
  args)
    case $line[1] in
      dismiss)
        _arguments \
          '(-a --all)'{-a,--all}'[dismiss all]' \
          '(-g --group)'{-g,--group}'[dismiss group]' \
          '-n[notification ID]:id:' && ret=0 ;;
      invoke|menu)
        _arguments \
          '-n[notification ID]:id:' '*::rest:_files' && ret=0 ;;
      mode)
        _arguments \
          '(-s --set)'{-s,--set=}'[set mode]:mode:' \
          '(-a --add)'{-a,--add=}'[add mode]:mode:' \
          '(-r --remove)'{-r,--remove=}'[remove mode]:mode:' && ret=0 ;;
    esac ;;
esac
return ret
