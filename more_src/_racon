#compdef racon
# Documentation: https://github.com/isovic/racon
# consensus module for raw de novo assembly of long uncorrected reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '--version[print version number]' \
  '(-u --include-unpolished)'{-u,--include-unpolished}'[output unpolished target sequences]' \
  '(-f --fragment-correction)'{-f,--fragment-correction}'[perform fragment correction]' \
  '(-w --window-length)'{-w,--window-length}'+[size of window for POA]:size' \
  '(-q --quality-threshold)'{-q,--quality-threshold}'+[threshold for average base quality]:threshold' \
  '(-e --error-threshold)'{-e,--error-threshold}'+[maximum allowed error rate]:rate' \
  '--no-trimming[disable consensus trimming at window ends]' \
  '(-m --match)'{-m,--match}'+[score for matching bases]:score' \
  '(-x --mismatch)'{-x,--mismatch}'+[score for mismatching bases]:score' \
  '(-g --gap)'{-g,--gap}'+[gap penalty (negative)]:penalty' \
  '(-t --threads)'{-t,--threads}'+[number of threads]:threads' \
  '(-c --cudapoa-batches)'{-c,--cudapoa-batches}'+[CUDA polishing batches per GPU]:batches' \
  '(-b --cuda-banded-alignment)'{-b,--cuda-banded-alignment}'[use banding approximation for GPU polishing]' \
  '--cudaaligner-batches=[CUDA alignment batches per GPU]:batches' \
  '--cudaaligner-band-width=[band width for CUDA alignment]:width' \
  '*:file:_files' && ret=0

return ret
