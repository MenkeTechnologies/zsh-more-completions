#compdef screenkey

# Zsh completion for screenkey - screencast tool to display key presses

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-detach[do not detach from terminal]' \
  '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds:' \
  '(-p --position)'{-p,--position}'[position on screen]:position:(top center bottom fixed)' \
  '(-g --geometry)'{-g,--geometry}'[geometry of the window]:geometry:' \
  '(-s --font-size)'{-s,--font-size}'[font size]:size:(small medium large)' \
  '--font=[font description]:font:' \
  '--font-color=[font color]:color:' \
  '--bg-color=[background color]:color:' \
  '--opacity=[background opacity]:opacity:' \
  '(-f --key-format)'{-f,--key-format}'[key format]:format:(translated keysyms composed)' \
  '--compr-cnt=[compression threshold count]:count:' \
  '--persist[make window persistent]' \
  '--no-whitespace[disable whitespace display]' \
  '--scr=[screen number]:screen:' \
  '--vis-shift[always show Shift modifier]' \
  '--vis-space[show space as unicode symbol]' \
  '--multiline[display multiple lines]' \
  '--no-systray[do not show systray icon]' \
  '--start-disabled[start with display disabled]' \
  '--mouse[show mouse buttons]' \
  '--no-modifier-only[do not display modifier-only key presses]' \
  '--bak-mode=[backspace mode]:mode:(normal baked full)' \
  '--mods-mode=[modifier key display mode]:mode:(normal emacs mac win)' \
  '--mods-only[show only modifier keys]' \
  '--ignore=[ignore specific keys]:keys:' \
  '--show-settings[show settings dialog on start]'
