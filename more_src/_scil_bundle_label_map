#compdef scil_bundle_label_map
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_bundle_label_map.html
# Compute a label map along bundles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--nb_pts=[number of divisions for the bundles]:n' \
  '--threshold=[max distance between two points to be overlapping]:mm' \
  '--colormap=[colormap for colored trk]:colormap' \
  '--hyperplane[use the hyperplane method instead of euclidian]' \
  '--use_manhattan[use the manhattan distance instead of euclidian]' \
  '--skip_uniformize[skip uniformization of the bundles orientation]' \
  '--correlation_thr=[threshold for the correlation map]:thr' \
  '--streamlines_thr=[min streamlines in a voxel to be included]:thr' \
  '--transformation=[transformation matrix to apply to the centroid]:file:_files' \
  '--inverse[inverse the transformation matrix]' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwriting of output files]' \
  '1:in_bundles:_files' \
  '2:in_centroid:_files' \
  '3:out_dir:_files -/' && ret=0

return ret
