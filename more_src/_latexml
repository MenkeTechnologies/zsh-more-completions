#compdef latexml
# Documentation: https://manpages.debian.org/testing/latexml/latexml.1p.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# latexml(1p) accepts long options only; no documented short forms.
_arguments -s \
  '--destination=[output file]:file:_files' \
  '--output=[obsolete synonym for --destination]:file:_files' \
  '*--preload=[load optional module (repeatable)]:module:' \
  '--preamble=[prepend preamble file]:file:_files' \
  '--postamble=[append postamble file]:file:_files' \
  '--includestyles[allow loading .sty files]' \
  '*--path=[add search directory]:dir:_files -/' \
  '--log=[log file]:file:_files' \
  '--documentid=[assign document root id]:id:' \
  '*--quiet[reduce verbosity (repeatable)]' \
  '*--verbose[increase verbosity (repeatable)]' \
  '--strict[treat errors as fatal]' \
  '--bibtex[treat input as BibTeX bibliography]' \
  '--xml[XML output (default)]' \
  '--tex[output TeX after expansion]' \
  '--box[output box format]' \
  '--noparse[disable math parsing]' \
  '--nocomments[omit comments from output]' \
  '--inputencoding=[input character encoding]:encoding:' \
  '--VERSION[show version]' \
  '--debug=[enable debugging for named package]:package:' \
  '--help[show help]' \
  '*:file:_files -g "*.tex"'
