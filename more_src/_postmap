#compdef postmap

_arguments -s \
  '(- *)-h[show help]' \
  '-b[byte-stream input mode]' \
  '-c=[config directory]:dir:_files -/' \
  '-d=[delete entry by key]:key:' \
  '-f[fold case]' \
  '-i[incremental update]' \
  '-m=[lookup table type]:type:(btree cdb dbm hash fail sdbm lmdb)' \
  '-N[output null-terminated]' \
  '-n[do not run as daemon]' \
  '-o[no auto-create file]' \
  '-p[do not preserve permissions]' \
  '-q=[query by key]:key:' \
  '-r[no warning on duplicate key]' \
  '-s[print first line of map]' \
  '-u[upgrade map mode]' \
  '-U[full upgrade]' \
  '-v[verbose]' \
  '-w[suppress duplicate warning]' \
  '*:input:_files'
