#compdef spampd
# Documentation: https://github.com/mpaperno/spampd/blob/master/spampd.pod
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--man[show full manpage]' \
  '(- *)--version[show version]' \
  '--config=[load configuration file]:file:_files' \
  '--host=+[listen address]:addr:' \
  '--port=+[listen port]:port:' \
  '--socket=+[listen UNIX socket]:file:_files' \
  '--relayhost=+[relay host]:host:_hosts' \
  '--relayport=+[relay port]:port:' \
  '--relaysocket=+[relay UNIX socket]:file:_files' \
  '--min-servers=+[minimum child server processes]:n:' \
  '--max-servers=+[maximum child server processes]:n:' \
  '--min-spare=+[minimum spare child processes]:n:' \
  '--max-spare=+[maximum spare child processes]:n:' \
  '--maxrequests=+[requests per child before exit]:n:' \
  '--maxsize=+[max message size to scan (KB)]:kb:' \
  '--childtimeout=+[child timeout (seconds)]:sec:' \
  '--satimeout=+[SpamAssassin timeout (seconds)]:sec:' \
  '--user=+[user to run as]:user:_users' \
  '--group=+[group to run as]:group:_groups' \
  '--pid=+[PID file]:file:_files' \
  '--detach[detach from terminal]' \
  '--setsid[start new session]' \
  '--logfile=+[log destination (syslog/stderr/file path)]:dest:' \
  '--logsock=+[syslog socket type]:sock:(unix inet)' \
  '--logident=+[syslog identifier]:ident:' \
  '--logfacility=+[syslog facility]:facility:' \
  '--debug[enable debug logging]' \
  '--log-rules-hit[log matched SpamAssassin rules]' \
  '--tagall[tag all mail with X-Spam headers]' \
  '--local-only[disable network-based SA tests]' \
  '--add-sc-header[add X-Spam-Checker header]' \
  '--hostname=+[hostname to identify as]:host:_hosts' \
  '--dose[die on SpamAssassin errors]' \
  '--set-envelope-headers[insert envelope headers]' \
  '--set-envelope-from[insert envelope-from header]' \
  '--saconfig=+[additional SpamAssassin config file]:file:_files' \
  '--homedir=+[SpamAssassin home directory]:dir:_files -/' && ret=0

return ret
