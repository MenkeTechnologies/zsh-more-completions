#compdef knative-serving-activator
# _knative-serving-activator — Knative Serving activator (sharedmain)
# upstream: https://github.com/knative/serving
# Flags from cmd/activator/main.go + knative.dev/pkg sharedmain on tip.

_knative-serving-activator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-serving-activator "$@"
