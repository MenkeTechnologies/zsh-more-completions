#compdef cairo cairo-compile cairo-format cairo-run cairo-test cairo-language-server
# _cairo — StarkWare Cairo provable computation language toolchain cairo-compile cairo-run cairo-format cairo-test (starkware-libs team, Rust); clap-derive
# upstream: https://github.com/starkware-libs/cairo

_cairo() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--starknet[enable starknet plugin]' \
        '--single-file[single file mode]' \
        '--allow-warnings[allow warnings]' \
        '--output=+[output file]:file:_files -g "*.sierra *.casm *.json"' \
        '-o+[output file]:file:_files -g "*.sierra *.casm *.json"' \
        '--replace-ids[replace ids]' \
        '-r[replace ids]' \
        '--add-statements-functions-debug-info[debug info]' \
        '--add-statements-code-locations-debug-info[debug info]' \
        '--inlining-strategy=+[strategy]:s:(default avoid avoid-most aggressive)' \
        '--available-gas=+[gas]:n:' \
        '--max-bytecode-size=+[bytes]:n:' \
        '--filter=+[test filter]:str:' \
        '-f+[test filter]:str:' \
        '--include-ignored[run ignored tests]' \
        '--ignored[only ignored tests]' \
        '--print-resource-usage[print resource usage]' \
        '--detailed-resource-usage[detailed resource usage]' \
        '--gas-disabled[disable gas]' \
        '--check[only check format]' \
        '-c[only check format]' \
        '--print-parsing-errors[print parsing errors]' \
        '--allow-fail[allow fail]' \
        '-l+[layout]:l:(plain small dex recursive starknet starknet_with_keccak recursive_large_output recursive_with_poseidon all_solidity all_cairo dynamic)' \
        '--layout=+[layout]:l:(plain small dex recursive starknet starknet_with_keccak recursive_large_output recursive_with_poseidon all_solidity all_cairo dynamic)' \
        '--trace=+[trace file]:file:_files -g "*.bin"' \
        '--memory=+[memory file]:file:_files -g "*.bin"' \
        '--air-public-input=+[file]:file:_files -g "*.json"' \
        '--air-private-input=+[file]:file:_files -g "*.json"' \
        '--cairo-pie-output=+[pie file]:file:_files -g "*.pie"' \
        '--proof-mode[proof mode]' \
        '--proof[proof mode]' \
        '--secure-run=+[bool]:b:(true false)' \
        '*:source:_files -g "*.cairo *.casm *.sierra *.json"'
}

_cairo "$@"
