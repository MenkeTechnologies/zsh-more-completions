#compdef redisinsight
# _redisinsight — Redis Insight GUI launcher (Redis Ltd, Node/Electron); CLI for headless server mode
# upstream: https://github.com/RedisInsight/RedisInsight

_redisinsight() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[server port]:port:' \
        '--host=+[server host]:host:_hosts' \
        '--encryption=+[encryption key]:str:' \
        '--no-encryption[disable encryption]' \
        '--no-update-check[disable update check]' \
        '--no-analytics[disable analytics]' \
        '--log-level=+[log level]:level:(silly debug info warn error fatal)' \
        '--db=+[database path]:file:_files' \
        '--working-dir=+[working dir]:dir:_files -/' \
        '--server-tls-cert=+[server tls cert]:file:_files' \
        '--server-tls-key=+[server tls key]:file:_files' \
        '*:arg:'
}

_redisinsight "$@"
