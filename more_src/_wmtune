#compdef wmtune
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# wmtune: WMaker dockapp radio tuner
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-display[X display]:display:' \
  '-bg[background color]:color:' \
  '-fg[foreground color]:color:' \
  '-position[geometry]:WxH+X+Y:' \
  '-version[show version]' \
  '*::wmtune args:_files' && ret=0
return ret
