#compdef create-turbocraft
# Documentation: https://github.com/sustinbebustin/turbocraft/blob/main/docs/guides/cli-reference.md
# Reference accessed: 2026-05-23
# Verified: npm view create-turbocraft bin/readme; turbocraft CLI reference create flags.

# Zsh completion for create-turbocraft - npm create shim forwarding to turbocraft create

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--framework=[app framework]:framework:(nextjs tanstack)' \
  '--layout=[repo layout]:layout:(monorepo single)' \
  '--features=[comma-separated features]:features:(shadcn convex better-auth)' \
  '--shadcn-preset=[shadcn preset code]:preset:' \
  '--shadcn-components=[shadcn components]:components:(all none)' \
  '--pm=[package manager]:manager:(pnpm npm bun)' \
  '--install[run package manager install after scaffold]' \
  '--no-install[skip dependency installation]' \
  '--git[run git init after scaffold]' \
  '--no-git[skip git initialization]' \
  ':project name:' && ret=0

return ret
