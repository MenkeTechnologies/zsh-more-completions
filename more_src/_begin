#compdef begin
# Documentation: https://docs.generic-mapping-tools.org/latest/begin.html
# Source: GenericMappingTools/gmt src/begin.c — start a GMT modern-mode session (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[clean start; ignore existing gmt.conf]' \
    '*-V[verbose (stackable)]' \
    '1::prefix:_default' \
    '2::format(s):_values -s , format bmp eps jpg pdf png PNG ppm ps tif' \
    '*:psconvert options:_default' \
    && ret=0

return ret
