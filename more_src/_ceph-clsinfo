#compdef ceph-clsinfo
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-clsinfo/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-clsinfo: show Ceph class file info
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-n[print class name only]' \
  '--name[print class name only]' \
  '-v[print class version only]' \
  '--version[print class version only]' \
  '-a[print class architecture only]' \
  '--arch[print class architecture only]' \
  '*:class .so file:_files -g "*.so"' && ret=0
return ret
