#compdef oneagent

# oneagent: Dynatrace OneAgent installer/runner
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
case oneagent in
  oneagentctl)
    commands=(
      'set_app_log_content_access:enable app log access'
      'get_app_log_content_access:show app log access'
      'set_extract_modules:set the modules to extract'
      'restart:restart agent'
      'stop:stop agent'
      'start:start agent'
      'restart_modules:restart specific modules'
      'set_host_group:set host group'
      'get_host_group:get host group'
      'set_network_zone:set network zone'
      'get_network_zone:get network zone'
      'set_communication_endpoints:set ActiveGate endpoints'
      'get_communication_endpoints:get ActiveGate endpoints'
      'set_proxy:set proxy'
      'get_proxy:get proxy'
      'set_tenant_token:set tenant token'
      'get_tenant_token:get tenant token'
      'set_log_level:set log level'
      'get_log_level:get log level'
      'set_self_monitoring:enable self monitoring'
      'set_optional_log_level:set optional log level'
      'restart_oneagent:restart the OneAgent'
      'version:show version'
    )
    ;;
  oneagent|dynatrace-agent)
    commands=(
      'install:install agent'
      'uninstall:uninstall agent'
      'restart:restart agent'
      'start:start agent'
      'stop:stop agent'
      'status:show status'
      'version:show version'
    )
    ;;
esac
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'oneagent command' commands && ret=0 ;;
esac
return ret
