#compdef oneagent
# Documentation: https://docs.dynatrace.com/docs/ingest-from/dynatrace-oneagent/oneagent-configuration-via-command-line-interface
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# oneagent: Dynatrace OneAgent installer/runner
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  'INSTALL_PATH=[set installer install path]:path:_files -/' \
  'PLATFORM_INSTALL=[platform install]:value:' \
  'INSTALLER_TYPE=[installer type]:value:' \
  'PROXY=[proxy URL]:url:' \
  'HOST_GROUP=[host group]:group:' \
  'HOST_NAME=[override host name]:name:' \
  'NETWORK_ZONE=[network zone]:zone:' \
  'INFRA_ONLY=[install in infra-only mode (0|1)]:value:(0 1)' \
  'APP_LOG_CONTENT_ACCESS=[allow app log access (0|1)]:value:(0 1)' \
  'SYSTEM_LOGS_ACCESS_ENABLED=[allow system logs access (0|1)]:value:(0 1)' \
  '*::arguments: _default' && ret=0
return ret
