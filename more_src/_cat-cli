#compdef cat-cli
# _cat-cli — GNU coreutils cat concatenate files and print on stdout CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_cat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A[equiv to -vET]' \
        '--show-all[equiv to -vET]' \
        '-b[number non-blank output lines]' \
        '--number-nonblank[number non-blank output lines]' \
        '-e[equiv to -vE]' \
        '-E[show $ at end of each line]' \
        '--show-ends[show $ at end of each line]' \
        '-n[number all output lines]' \
        '--number[number all output lines]' \
        '-s[squeeze blank lines]' \
        '--squeeze-blank[squeeze blank lines]' \
        '-t[equiv to -vT]' \
        '-T[display TAB chars as ^I]' \
        '--show-tabs[display TAB chars as ^I]' \
        '-u[ignored for POSIX compat]' \
        '-v[show non-printing chars]' \
        '--show-nonprinting[show non-printing chars]' \
        '*:files:_files'
}

_cat-cli "$@"
