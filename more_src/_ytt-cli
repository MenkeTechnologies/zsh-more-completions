#compdef ytt
# Documentation: https://man.archlinux.org/search?q=ytt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cmd:run a Starlark function'
  'fmt:format ytt files'
  'website:run docs website'
  'completion:generate completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*-f+[file or URL]:file:_files' \
  '*--file=[file or URL]:file:_files' \
  '*--data-value=[k=v]:v:' \
  '*-v+[k=v]:v:' \
  '*--data-value-file=[k=file]:v:' \
  '*--data-value-yaml=[k=yaml]:v:' \
  '*--data-values-file=[file]:file:_files' \
  '*--data-values-env=[env prefix]:e:' \
  '*--data-values-env-yaml=[env prefix yaml]:e:' \
  '*--data-values-inspect[inspect data values]' \
  '*--debug[debug]' \
  '*--file-mark=[file mark]:f:' \
  '*--ignore-unknown-comments[ignore unknown comments]' \
  '*--implied-overlays[implied overlays]' \
  '*--strict[strict mode]' \
  '*--symlink-allow=[allow symlink dir]:dir:_files -/' \
  '*-o+[output type]:o:(yaml json pos files)' \
  '*--output=[output type]:o:(yaml json pos files)' \
  '*--output-files=[output dir]:dir:_files -/' \
  '*--dangerous-data-values-disable-validation[disable validation]' \
  '*--dangerous-emit-json-with-no-pretty-print[no pretty json]' \
  '*--dangerous-allow-all-symlink-destinations[allow all symlinks]' \
  '*--filter-yaml-doc=[filter yaml doc]:f:' \
  '*--list-data-values-schema-inspect[list schema]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ytt command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (fmt)
        _arguments \
          '(-w --write)'{-w,--write}'[write to file]' \
          '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
