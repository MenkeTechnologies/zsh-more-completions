#compdef dte

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[run command after opening files]:command' \
  '-t+[jump to tag]:tag' \
  '-r+[read-only mode for file]:file:_files' \
  '-B[use built-in syntax highlighting]' \
  '-H[show available commands]' \
  '-K[show key bindings]' \
  '-R[read-only mode]' \
  '-s+[load syntax file]:syntax file:_files' \
  '-b+[specify built-in config to dump]:config' \
  '*:file:_files' && return 0
