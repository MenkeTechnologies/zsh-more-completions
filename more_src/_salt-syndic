#compdef salt-syndic
# _salt-syndic — SaltStack salt-syndic (multi-master fan-out daemon: bridges a master-of-masters with downstream masters; -d daemonize, -c config dir, -l/--log-* logging, --pid-file)
# upstream: https://github.com/saltstack/salt (salt/cli/daemons.py)
# Flags from salt cli/daemons.py on tip.

_salt-syndic() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-d[daemonize]' \
        '--user+[run as user]:user:_users' \
        '-l+[log level]:level:(all garbage trace debug profile info warning error critical quiet)' \
        '--log-file+[log file]:file:_files' \
        '--log-file-level+[file log level]:level:(all garbage trace debug profile info warning error critical quiet)' \
        '--pid-file+[pidfile]:file:_files' \
        '--hard-crash[abort on exceptions]'
}

_salt-syndic "$@"
