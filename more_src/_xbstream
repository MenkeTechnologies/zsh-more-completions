#compdef xbstream
# Documentation: https://docs.percona.com/percona-xtrabackup/2.4/xbstream/xbstream.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-x -c)-x[extract files from stream to current directory]' \
  '(-c -x)-c[stream named files to stdout]' \
  '(-C --directory)'{-C,--directory=}'[change to directory before extract/stream]:dir:_files -/' \
  '--parallel=[number of parallel threads]:n:' \
  '--decrypt=[decryption algorithm]:algo:(AES128 AES192 AES256)' \
  '(--encrypt-key-file)--encrypt-key=[encryption key]:key:' \
  '(--encrypt-key)--encrypt-key-file=[file containing encryption key]:file:_files' \
  '--encrypt-threads=[parallel encryption threads]:n:' \
  '--read-buffer-size=[chunk file size]:size:' \
  '--encrypt-chunk-size=[chunk size when encrypting]:size:' \
  '*:file:_files'
