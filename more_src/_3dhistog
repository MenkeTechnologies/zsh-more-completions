#compdef 3dhistog
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dhistog.html
# AFNI compute histogram of a 3D dataset

local ret=1

_arguments -s -S \
  '-nbin[number of histogram bins]:n:' \
  '-dind[extract data from sub-brick i]:i:' \
  '-omit[exclude a value from count]:x:' \
  '-mask[dataset of which voxels to include]:mask:_files' \
  '-roi_mask[separate histogram per nonzero value]:roi:_files' \
  '-doall[include all sub-bricks]' \
  '-noempty[output only non-empty bins]' \
  '-notitle[omit title line from output]' \
  '-log10[output log10 of counts]' \
  '-pdf[output counts divided by number of samples]' \
  '-min[inclusive minimum value]:x:' \
  '-max[inclusive maximum value]:x:' \
  '-igfac[ignore sub-brick scale factors]' \
  '-int[treat data and output as integers]' \
  '-float[treat data and output as floats]' \
  '-unq[write sorted unique values to file]:file:_files' \
  '-prefix[write histogram to file]:prefix:_files' \
  '*:dataset:_files' && ret=0

return ret
