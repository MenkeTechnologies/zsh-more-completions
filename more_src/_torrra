#compdef torrra

# Zsh completion for torrra (stabldev/torrra, click)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '--no-cache[disable caching mechanism]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values -s 'torrra' download search downloads jackett prowlarr config && ret=0
    ;;
  args)
    case $line[1] in
      download)
        _arguments -s -S '--no-cache' '1:magnet_url_or_file:_files' && ret=0
        ;;
      search)
        _arguments -s -S '--no-cache' '1:query:_default' && ret=0
        ;;
      downloads) _arguments -s -S '--no-cache' && ret=0 ;;
      jackett|prowlarr)
        _arguments -s -S '--no-cache' '--url[server URL]' '--api-key[API key]' && ret=0
        ;;
      config)
        _values -s 'torrra config' get set list && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
