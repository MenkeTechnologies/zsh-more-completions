#compdef linstor linstor-controller linstor-satellite
# Documentation: https://man.archlinux.org/search?q=linstor
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

case $service in
  (linstor)
    commands=(
      'controller:controller commands'
      'node:node commands'
      'storage-pool:storage pool commands'
      'resource-definition:resource definition commands'
      'volume-definition:volume definition commands'
      'resource:resource commands'
      'snapshot:snapshot commands'
      'volume:volume commands'
      'volume-group:volume group commands'
      'resource-group:resource group commands'
      'remote:remote commands'
      'backup:backup commands'
      'physical-storage:physical storage'
      'error-reports:error reports'
      'sos-report:create SOS report'
      'space-reporting:space reports'
      'controller-name:controller name'
      'list-commands:list all commands'
      'help:show help'
      'completion:generate completion'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '*--controllers=[controllers csv]:list:' \
      '*--no-color[no color output]' \
      '*--utf8[UTF8 mode]' \
      '*--warn-as-error[treat warnings as errors]' \
      '*--config-directory=[config dir]:dir:_files -/' \
      '*--curl[print curl commands]' \
      '*-m+[output mode]:m:(text json yaml)' \
      '*--output-version=[API version]:v:(v0 v1)' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'linstor command' commands && ret=0 ;;
      (args) _arguments '*: :_files' && ret=0 ;;
    esac ;;
  (linstor-controller|linstor-satellite)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '-c+[config dir]:dir:_files -/' \
      '--config-directory=[config dir]:dir:_files -/' \
      '-d[debug]' \
      '--debug-console[debug console]' \
      '-l+[log level]:l:(TRACE DEBUG INFO WARN ERROR)' \
      '--logs=[logs dir]:dir:_files -/' \
      '--keep-res=[keep res]:res:' \
      '--override-node-name=[node name]:n:' \
      '--bind-address=[bind addr]:addr:' \
      '--rest-bind=[REST bind]:addr:' \
      '--rest-bind-secure=[REST secure bind]:addr:' \
      '*: :' && ret=0 ;;
esac

return ret
