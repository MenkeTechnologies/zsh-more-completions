#compdef kata-collect-data
# Documentation: https://man.archlinux.org/search?q=kata-collect-data
# Reference accessed: 2026-05-16

# kata-collect-data: collect Kata Containers diagnostic data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::kata-collect-data args:_files' && ret=0
return ret
