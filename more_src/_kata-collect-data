#compdef kata-collect-data
# Documentation: https://github.com/kata-containers/kata-containers/blob/main/src/runtime/data/kata-collect-data.sh.in
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kata-collect-data: collect Kata Containers diagnostic data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show this usage summary]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '*::kata-collect-data args:_files' && ret=0
return ret
