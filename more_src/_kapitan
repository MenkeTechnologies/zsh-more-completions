#compdef kapitan
# Documentation: https://github.com/kapicorp/kapitan/blob/master/kapitan/cli.py
# Reference accessed: 2026-05-19
# Verified: upstream source (argparse subparsers) at the URL above.

# kapitan: generic templated configuration management. Corrected from prior
# file: real subcommands are eval/compile/inventory/searchvar/secrets/refs/
# lint/init (no top-level "validate" subcommand; --validate is a compile
# flag). secrets is deprecated alias of refs; removed invented secrets
# sub-subcommands (write/reveal/gpg-create were fabricated).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'eval:evaluate jsonnet file'
      'e:evaluate jsonnet file'
      'compile:compile targets'
      'c:compile targets'
      'inventory:show inventory'
      'i:show inventory'
      'searchvar:show inventory files where a variable is declared'
      'sv:show inventory files where a variable is declared'
      'secrets:(DEPRECATED) please use refs'
      's:(DEPRECATED) please use refs'
      'refs:manage refs'
      'r:manage refs'
      'lint:linter for inventory and refs'
      'l:linter for inventory and refs'
      'init:initialize a directory with the recommended kapitan project skeleton'
    )
    _describe -t commands 'kapitan subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      compile|c)
        _arguments \
          '(-t --targets)'{-t,--targets}'[targets to compile]:target:' \
          '(-l --labels)'{-l,--labels}'[compile targets matching labels]:key=value:' \
          '(-J --search-paths)'{-J,--search-paths}'[set search paths]:jpath:_directories' \
          '(-J2F --jinja2-filters)'{-J2F,--jinja2-filters}'[load custom jinja2 filters]:fpath:_files' \
          '(-v --verbose)'{-v,--verbose}'[set verbose mode]' \
          '--prune[prune jsonnet output]' \
          '--quiet[set quiet mode]' \
          '--output-path=[set output path]:path:_directories' \
          '--fetch[fetch remote inventories and/or external dependencies]' \
          '--force-fetch[overwrite existing inventory and/or dependency item]' \
          '--validate[validate compile output against schemas]' \
          '(-p --parallelism)'{-p,--parallelism}'[number of concurrent compile processes]:int:' \
          '(-i --indent)'{-i,--indent}'[indentation spaces for YAML/JSON]:int:' \
          '--refs-path=[set refs path]:path:_directories' \
          '--reveal[reveal refs]' \
          '--embed-refs[embed ref contents]' \
          '--inventory-path=[set inventory path]:path:_directories' \
          '(-c --cache)'{-c,--cache}'[enable compilation caching]' \
          '--ignore-version-check[ignore the version from .kapitan]' \
          '--use-go-jsonnet[use go-jsonnet]' \
          '--schemas-path=[set schema cache path]:path:_directories' \
          '(-L --yaml-multiline-string-style)'{-L,--yaml-multiline-string-style}'[multiline string style]:style:(literal folded double-quotes)' && ret=0
        ;;
      inventory|i)
        _arguments \
          '(-t --target-name)'{-t,--target-name}'[set target name]:target:' \
          '--inventory-path=[set inventory path]:path:_directories' \
          '(-F --flat)'{-F,--flat}'[flatten nested inventory variables]' \
          '(-p --pattern)'{-p,--pattern}'[filter pattern]:pattern:' \
          '(-v --verbose)'{-v,--verbose}'[set verbose mode]' \
          '(-i --indent)'{-i,--indent}'[indentation spaces]:int:' && ret=0
        ;;
    esac
    ;;
esac

return ret
