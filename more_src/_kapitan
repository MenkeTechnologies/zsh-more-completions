#compdef kapitan

# Zsh completion for kapitan (Kubernetes config management)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'compile:compile targets'
      'inventory:show inventory'
      'searchvar:search for variables in inventory'
      'secrets:manage secrets'
      'lint:lint templates'
      'init:initialize a new kapitan project'
      'validate:validate compiled output'
      'refs:manage references'
    )
    _describe -t commands 'kapitan subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      compile)
        _arguments \
          '(-t --targets)'{-t,--targets}'[specific targets to compile]:targets' \
          '(-l --labels)'{-l,--labels}'[filter targets by labels]:labels' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
          '--fetch[fetch remote inventories]' \
          '--force-fetch[force fetch remote inventories]' \
          '--validate[validate compilation output]' \
          '--output-path[output path]:path:_directories' \
          '--inventory-path[inventory path]:path:_directories' && ret=0
        ;;
      inventory)
        _arguments \
          '(-t --target)'{-t,--target}'[target name]:target' \
          '--inventory-path[inventory path]:path:_directories' \
          '--flat[flatten output]' && ret=0
        ;;
      secrets)
        local -a secrets_subcmds=(
          'write:write a secret'
          'reveal:reveal secrets'
          'gpg-create:create GPG key'
        )
        _describe -t commands 'secrets subcommand' secrets_subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
