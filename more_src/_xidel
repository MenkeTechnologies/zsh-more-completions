#compdef xidel

# Zsh completion for xidel - XML/HTML/JSON data extraction tool

local -a arguments

arguments=(
  {-e,--extract}'[extraction expression]:expression'
  '--css[CSS selector for extraction]:CSS selector'
  '--xpath[XPath expression for extraction]:XPath expression'
  '--xquery[XQuery expression for extraction]:XQuery expression'
  {-f,--follow}'[follow links matching expression]:follow expression'
  '--input-format[input format]:format:(auto xml html json text)'
  '--output-format[output format]:format:(adhoc xml html xml-wrapped json json-wrapped bash cmd)'
  '--output-separator[separator between outputs]:separator'
  '--output-encoding[output character encoding]:encoding'
  '--output-header[string to print before output]:header'
  '--output-footer[string to print after output]:footer'
  {-s,--silent}'[suppress status messages]'
  '*'{-v,--variable}'[set variable name=value]:variable assignment'
  '--default-variable-name[name for _ default variable]:variable name'
  '--printed-node-format[format for printing nodes]:format'
  '--color[colorize output]:color mode:(auto never always json xml)'
  '--stdin[read input from stdin]'
  '--data[HTTP POST data]:post data'
  '--method[HTTP method]:method:(GET POST PUT DELETE HEAD PATCH OPTIONS)'
  '--header[additional HTTP header]:header'
  '--user-agent[set User-Agent header]:user agent string'
  '*:URL or file:_files'
)

_arguments -s -S $arguments
