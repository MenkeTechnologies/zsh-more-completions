#compdef television
# Documentation: https://alexpasmantier.github.io/television/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream Television CLI reference.
# Removed from prior file: fabricated channel list 'env files git-repos text alias'
# (only files/text/git-repos are documented core channels; the channel list is
# user-extensible via the cable directory) and the bogus '--tick-rate ms' /
# '--frame-rate fps' descriptions. tick-rate is a documented flag but takes
# updates/sec, not ms; frame-rate is not a documented flag.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-t --tick-rate)'{-t+,--tick-rate=}'[updates per second]:n:' \
  '--watch=[reload source every N seconds]:seconds:' \
  '(-i --input)'{-i+,--input=}'[prefill prompt]:string:' \
  '(-p --preview-command)'{-p+,--preview-command=}'[preview command]:cmd:' \
  '--no-preview[disable preview]' \
  '--layout=[layout orientation]:layout:(landscape portrait)' \
  '--exact[substring matching instead of fuzzy]' \
  '--select-1[auto-select if only one entry]' \
  '--take-1[select first entry after loading]' \
  '--take-1-fast[select first entry immediately]' \
  '(-k --keybindings)'{-k+,--keybindings=}'[override default keybindings]:spec:' \
  '--config-file=[custom config file]:file:_files' \
  '--cable-dir=[custom cable directory]:dir:_directories' \
  '1: :->cmd_or_chan' \
  '*:: :->args' && ret=0

case $state in
  cmd_or_chan)
    local -a commands=(
      'list-channels:list available channels'
      'init:initialize shell completion'
      'update-channels:download latest channel prototypes'
      'help:print help'
    )
    _describe -t commands 'television command' commands && ret=0
    _files && ret=0
    ;;
  args)
    case ${words[1]} in
      init) _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
