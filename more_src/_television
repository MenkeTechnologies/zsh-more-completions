#compdef television
# Documentation: https://man.archlinux.org/search?q=television
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tick-rate=[set tick rate in ms]:rate' \
  '--frame-rate=[set frame rate in fps]:rate' \
  '*:channel:(env files git-repos text alias)' && ret=0

return ret
