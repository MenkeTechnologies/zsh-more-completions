#compdef television

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tick-rate=[set tick rate in ms]:rate' \
  '--frame-rate=[set frame rate in fps]:rate' \
  '*:channel:(env files git-repos text alias)' && ret=0

return ret
