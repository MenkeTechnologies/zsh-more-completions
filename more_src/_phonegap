#compdef phonegap
# Documentation: https://man.archlinux.org/search?q=phonegap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new PhoneGap project'
  'build:build the project for one or more platforms'
  'install:install the project on a connected device'
  'run:build, install, and run on a device or emulator'
  'serve:run a local development server'
  'local:run a local-only subcommand'
  'remote:use the PhoneGap Build cloud service'
  'platform:manage platforms (add/remove/list/update)'
  'plugin:manage plugins (add/remove/list/search)'
  'login:log in to PhoneGap Build'
  'logout:log out of PhoneGap Build'
  'analytics:enable/disable analytics'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --verbose)'{-d,--verbose}'[verbose output]' \
  '(-s --silent)'{-s,--silent}'[silent output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'phonegap command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build|install|run)
        _arguments \
          '--device[target a physical device]' \
          '--emulator[target an emulator]' \
          '--target=[specific device/emulator name]:target:' \
          '*::platforms:(android ios wp8 windows blackberry10 amazon-fireos)' && ret=0 ;;
      (serve)
        _arguments \
          '--port=[port]:port:' \
          '--browser[open in browser]' \
          '--autoreload[reload on file change]' \
          '--no-autoreload[disable reload]' && ret=0 ;;
      (platform)
        _arguments \
          '*::sub:(add remove rm ls list update check)' && ret=0 ;;
      (plugin)
        _arguments \
          '*::sub:(add remove rm ls list search check)' && ret=0 ;;
      (local|remote)
        _arguments \
          '*::sub:(build install run plugin login logout)' && ret=0 ;;
    esac ;;
esac

return ret
