#compdef traj gmx-traj
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-traj.html
# gmx traj: plot x, v, f, box, temperature and rotational energy from trajectories

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-ox[coordinates output]:file:_files' \
  '-oxt[trajectory coordinates output]:file:_files' \
  '-ov[velocities output]:file:_files' \
  '-of[forces output]:file:_files' \
  '-ob[box dimensions output]:file:_files' \
  '-ot[temperature output]:file:_files' \
  '-ekt[translational kinetic energy output]:file:_files' \
  '-ekr[rotational kinetic energy output]:file:_files' \
  '-vd[velocity distribution output]:file:_files' \
  '-cv[average velocities as PDB]:file:_files' \
  '-cf[average forces as PDB]:file:_files' \
  '-av[all velocities output]:file:_files' \
  '-af[all forces output]:file:_files' \
  '-b[first frame time]:time:' \
  '-e[last frame time]:time:' \
  '-dt[frame selection interval]:time:' \
  '-tu[time unit]:unit:(fs ps ns us ms s)' \
  '-w[view output files]' \
  '-xvg[plot format]:format:(xmgrace xmgr none)' \
  '-com[center-of-mass calculation]' \
  '-pbc[make molecules whole]' \
  '-mol[interpret index as molecule numbers]' \
  '-nojump[remove box-crossing jumps]' \
  '-x[plot X-component]' \
  '-y[plot Y-component]' \
  '-z[plot Z-component]' \
  '-ng[number of groups]:int:' \
  '-len[plot vector length]' \
  '-fp[full precision output]' \
  '-bin[velocity histogram bin width in nm/ps]:real:' \
  '-ctime[frame time for averaging]:real:' \
  '-scale[PDB output scaling factor]:real:' && ret=0

return ret
