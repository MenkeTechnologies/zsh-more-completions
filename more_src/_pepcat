#compdef pepcat
# Documentation: https://proteowizard.sourceforge.io/tools/tools_base.html
# ProteoWizard: concatenate peptide identification data to delimited text

local ret=1

_arguments -s -S \
  '(-d --delim)'{-d,--delim}'[delimiter separating fields (default tab)]:delim:' \
  '(-r --record)'{-r,--record}'[delimiter separating records (default newline)]:delim:' \
  '(-q --quote)'{-q,--quote}'[character used for quoting text fields]:char:' \
  '(-h --headers)'{-h,--headers}'[print headers]' \
  '--quiet[do not print headers]' \
  '*:identification file:_files' && ret=0

return ret
