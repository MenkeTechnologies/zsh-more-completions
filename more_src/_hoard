#compdef hoard
# Documentation: https://github.com/Hyde46/hoard
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Hyde46/hoard: command snippet manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'new:save a new command'
      'list:search through commands interactively'
      'remove:delete a specific command'
      'remove_namespace:delete all commands in a namespace'
      'edit:modify an existing command'
      'info:show config and trove file locations'
      'set_parameter_token:change the parameter token'
      'import:import a trove file'
      'export:export your trove file'
      'sync:synchronize commands across devices'
      'help:show help for a subcommand'
    )
    _describe -t commands 'hoard subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      export|import)
        _files && ret=0
        ;;
      remove|remove_namespace|edit)
        _message 'command name' && ret=0
        ;;
      help)
        local -a subcmds=(new list remove remove_namespace edit info set_parameter_token import export sync help)
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
