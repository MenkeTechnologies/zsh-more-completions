#compdef hoard

# Zsh completion for hoard (command snippet manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'new:create a new command snippet'
      'list:list saved snippets'
      'pick:pick and run a snippet interactively'
      'remove:remove a snippet'
      'edit:edit a snippet'
      'export:export snippets to file'
      'import:import snippets from file'
      'sync:synchronize snippets'
      'help:show help for a subcommand'
    )
    _describe -t commands 'hoard subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      export|import)
        _files && ret=0
        ;;
      remove|edit|pick)
        _message 'snippet name' && ret=0
        ;;
      help)
        local -a subcmds=(new list pick remove edit export import sync help)
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
