#compdef cpphs
# Documentation: https://hackage.haskell.org/package/cpphs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Haskell C preprocessor (Malcolm Wallace)

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-D+[define macro]:def:' \
  '-U+[undef macro]:macro:' \
  '-I+[include path]:dir:_files -/' \
  '-O+[output file]:file:_files' \
  '--include=+[force include]:file:_files' \
  '--noline[do not output line directives]' \
  '--nomacro[no macro expansion]' \
  '--nowarn[suppress warnings]' \
  '--linepragma[output #line pragmas]' \
  '--strip[strip cpp directives]' \
  '--strip-eol[strip end-of-line]' \
  '--hashes[allow # in identifiers]' \
  '--text[output as text not source]' \
  '--cpp=[traditional cpp compatibility mode]:compatopts:' \
  '--unlit[unliterate first]' \
  '--layout[preserve layout]' \
  '--pragma[emit pragmas]' \
  '*:source file:_files' && ret=0

return ret
