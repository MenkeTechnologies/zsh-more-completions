#compdef xcodes

# Zsh completion for xcodes - install and switch between Xcode versions

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:download a specific version of Xcode'
  'install:download and install a specific version of Xcode'
  'installed:list the versions of Xcode that are installed'
  'list:list all versions of Xcode that are available to install'
  'runtimes:list all simulator runtimes that are available to install'
  'select:change the selected Xcode'
  'signout:clears the stored username and password'
  'update:update the list of available versions of Xcode'
  'uninstall:uninstall a specific version of Xcode'
  'version:print the version number of xcodes itself'
  'help:display help about the xcodes command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xcodes command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install|download)
        _arguments -s -S \
          '--latest[update and then install the latest non-prerelease version available]' \
          '--latest-prerelease[update and then install the latest prerelease version]' \
          '--directory[the directory to install Xcode into]:directory:_files -/' \
          '--path[local path to Xcode .xip to install]:file:_files -g "*.xip"' \
          '--experimental-unxip[use experimental faster unxip]' \
          '--no-superuser[don''t attempt to authenticate as a superuser]' \
          '--color[color the terminal output]' \
          '--no-color[do not color the terminal output]' \
          '*:version:' && ret=0
        ;;
      (runtimes)
        _arguments '1:subcommand:(install download)' && ret=0
        ;;
      (select|uninstall)
        _arguments '*:version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
