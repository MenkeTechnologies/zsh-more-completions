#compdef xcodes
# Documentation: https://github.com/XcodesOrg/xcodes
# Reference accessed: 2026-05-21
# Verified: Sources/xcodes/App.swift (Xcodes subcommands and per-command flags
# via swift-argument-parser).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:download a specific version of Xcode'
  'install:download and install a specific version of Xcode'
  'installed:list the versions of Xcode that are installed'
  'list:list all versions of Xcode that are available to install'
  'runtimes:list all simulator runtimes that are available to install'
  'select:change the selected Xcode'
  'signout:clears the stored username and password'
  'update:update the list of available versions of Xcode'
  'uninstall:uninstall a specific version of Xcode'
  'version:print the version number of xcodes itself'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xcodes command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install)
        _arguments -s -S \
          '--latest[update and install the latest release version]' \
          '--latest-prerelease[update and install the latest prerelease version]' \
          '--path=[local path to Xcode .xip]:file:_files -g "*.xip"' \
          '--aria2=[path to aria2 executable]:file:_files' \
          '--no-aria2[do not use aria2 even if available]' \
          '--select[select the installed Xcode after installation]' \
          '--update[update the list before installing]' \
          '(-p --print-path)'{-p,--print-path}'[print path of the selected Xcode]' \
          '--experimental-unxip[use experimental faster unxip]' \
          '--no-superuser[do not request superuser permission]' \
          '--empty-trash[delete .xip after install instead of keeping in trash]' \
          '--directory=[install directory]:dir:_files -/' \
          '--use-fastlane-auth[use fastlane spaceship session]' \
          '--fastlane-user=[fastlane spaceship user]:user:' \
          '--data-source=[data source]:source:(apple xcodeReleases)' \
          '--color[colorize terminal output]' \
          '--no-color[do not colorize terminal output]' \
          '*:version:' && ret=0
        ;;
      (download)
        _arguments -s -S \
          '--latest[update and download the latest release version]' \
          '--latest-prerelease[update and download the latest prerelease version]' \
          '--aria2=[path to aria2 executable]:file:_files' \
          '--no-aria2[do not use aria2 even if available]' \
          '--directory=[download directory]:dir:_files -/' \
          '--use-fastlane-auth[use fastlane spaceship session]' \
          '--fastlane-user=[fastlane spaceship user]:user:' \
          '--data-source=[data source]:source:(apple xcodeReleases)' \
          '--color[colorize terminal output]' \
          '--no-color[do not colorize terminal output]' \
          '*:version:' && ret=0
        ;;
      (runtimes)
        _arguments '1:subcommand:(install download)' && ret=0
        ;;
      (select|uninstall)
        _arguments \
          '--directory=[install directory]:dir:_files -/' \
          '*:version:' && ret=0
        ;;
      (list|installed|update)
        _arguments \
          '--data-source=[data source]:source:(apple xcodeReleases)' \
          '--directory=[install directory]:dir:_files -/' \
          '--color[colorize terminal output]' \
          '--no-color[do not colorize terminal output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
