#compdef bdftruncate
# Documentation: https://manpages.debian.org/bookworm/xfonts-utils/bdftruncate.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-w[remove East Asian Wide and FullWidth characters]' \
  '+w[keep East Asian Wide and FullWidth characters]' \
  '1:threshold (e.g. 0x3200):' && ret=0

return ret
