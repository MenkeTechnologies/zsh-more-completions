#compdef bdftruncate
# Documentation: https://man.archlinux.org/search?q=bdftruncate
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-w[remove East Asian Wide and FullWidth characters]' \
  '+w[keep East Asian Wide and FullWidth characters]' \
  '1:threshold (e.g. 0x3200):' && ret=0

return ret
