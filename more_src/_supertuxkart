#compdef supertuxkart

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-N[no graphics mode]' \
  '-R[print frame rate]' \
  '--screen=[screen size WxH]:WxH:' \
  '--fullscreen[fullscreen]' \
  '--windowed[windowed]' \
  '--track=[track ident]:track:' \
  '--kart=[kart ident]:kart:' \
  '--ai=[AI karts]:csv:' \
  '--players=[number of players]:n:' \
  '--difficulty=[difficulty 0-3]:n:(0 1 2 3)' \
  '--type=[race type]:type:(normal time_trial follow_leader 3_strikes ftl str3)' \
  '--laps=[laps]:n:' \
  '--mode=[render mode]:mode:' \
  '--no-graphics[no graphics]' \
  '--profile-laps=[profile laps]:n:' \
  '--profile-time=[profile sec]:sec:' \
  '--profile-rec=[record profile]:file:_files' \
  '--unlock-all[unlock all]' \
  '--no-start-screen[skip start screen]' \
  '--connect-now=[server addr]:host\:port:' \
  '--server=[server config]:cfg:' \
  '--login=[STK online login]:user:' \
  '--password=[STK online password]:pw:' \
  '--init-user=[set username]:user:' \
  '--port=[server port]:port:' \
  '--max-players=[server max players]:n:' \
  '--with-profile=[profile name]:name:' \
  '--no-graphics[no graphics]' \
  '--cutscene=[play cutscene]:scene:' \
  '--soccer-goals=[soccer goals]:n:' \
  '--soccer-time-limit=[soccer time limit min]:min:' \
  '--data-dir=[data dir]:dir:_files -/' \
  '--addon-dir=[add-on dir]:dir:_files -/' && ret=0

return ret
