#compdef supertuxkart
# Documentation: https://github.com/supertuxkart/stk-code/blob/master/src/main.cpp
# Reference accessed: 2026-05-21
# Verified: upstream stk-code main.cpp handleCmdLine() argument parsing.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-N --no-start-screen)'{-N,--no-start-screen}'[skip start screen]' \
  '(-R --race-now)'{-R,--race-now}'[skip ready phase]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-w --windowed)'{-w,--windowed}'[windowed]' \
  '(-s --screensize)'{-s+,--screensize=}'[display resolution WxH]:WxH:' \
  '(-t --track)'{-t+,--track=}'[start specific track]:track:' \
  '--gp=[start Grand Prix]:gp:' \
  '(-k --numkarts)'{-k+,--numkarts=}'[number of karts]:n:' \
  '--kart=[choose kart]:kart:' \
  '--ai=[AI karts]:csv:' \
  '--aiNP=[non-player AI karts]:csv:' \
  '--laps=[lap count]:n:' \
  '--mode=[game mode]:mode:' \
  '--difficulty=[difficulty 0-3]:n:(0 1 2 3)' \
  '--reverse[play track reversed]' \
  '--wan-server=[start WAN server]:name:' \
  '--lan-server=[start LAN server]:name:' \
  '--connect-now=[connect to server]:host:' \
  '--server-password=[set server password]:pw:' \
  '--port=[set port]:port:' \
  '--max-players=[max clients]:n:' \
  '--min-players=[min clients]:n:' \
  '--use-keyboard=[assign keyboard device]:n:' \
  '--use-gamepad=[assign gamepad device]:n:' \
  '--enable-glow[enable glow]' \
  '--disable-glow[disable glow]' \
  '--enable-bloom[enable bloom]' \
  '--disable-bloom[disable bloom]' \
  '--shadows=[shadow level]:n:' \
  '--anisotropic=[anisotropic filtering]:n:' \
  '--log=[verbosity level]:n:' \
  '--seed=[RNG seed]:n:' \
  '--unlock-all[unlock all content]' \
  '--demo-mode=[enable demo after idle time]:t:' \
  '--history[replay history file]' && ret=0

return ret
