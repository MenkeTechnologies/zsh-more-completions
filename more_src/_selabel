#compdef selabel_lookup selabel_partial_match selabel_open selabel_close
# _selabel — SELinux libselinux selabel CLI demos (small libselinux/utils helpers: selabel_lookup probes a context for a path, selabel_partial_match tests a prefix, selabel_open / selabel_close exercise the SELABEL_CTX_FILE backend on a custom file_contexts; -f file_contexts override, -p path, -m type letter (a|b|c|d|l|s|p), -v verbose)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libselinux/utils/selabel_*.c on tip.

_selabel() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[file_contexts]:file:_files' \
        '-p+[path]:path:_files' \
        '-m+[type]:type:(a b c d l s p)' \
        '-v[verbose]'
}

_selabel "$@"
