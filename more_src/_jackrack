#compdef jackrack
# Documentation: https://man.archlinux.org/search?q=jackrack
# Reference accessed: 2026-05-16

# JACK Rack: LADSPA effects rack for JACK
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-c[channel count]:n:' \
  '--channels=[channel count]:n:' \
  '-n[JACK client name]:name:' \
  '--name=[JACK client name]:name:' \
  '-s[server name]:name:' \
  '--server=[server name]:name:' \
  '*:JACK Rack saved file:_files -g "*.rack"' && ret=0
return ret
