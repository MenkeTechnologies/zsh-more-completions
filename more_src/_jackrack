#compdef jackrack jack-rack jack_rack
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/jack-rack.1.html
# Reference accessed: 2026-05-19
# Verified: Ubuntu xenial jack-rack(1) manpage. NOTE: real binary is
# `jack-rack` (hyphen) — also completed here for compatibility under
# the legacy `jackrack` and `jack_rack` names.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -s/--server flag (real upstream has -p/--pid-name,
# -s/--string-name, -i/-o auto-connect, -D/--tmpdir, no JACK server
# flag).

# jack-rack: LADSPA effects rack for JACK
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --pid-name)'{-p,--pid-name}'[use PID-based JACK client name (default)]' \
  '(-s --string-name)'{-s+,--string-name=}'[use string for JACK client name]:string:' \
  '(-n --name)'{-n,--name}'[use bare jack_rack as client name]' \
  '(-i --input)'{-i,--input}'[auto-connect inputs]' \
  '(-o --output)'{-o,--output}'[auto-connect outputs]' \
  '(-c --channels)'{-c+,--channels=}'[channel count (default 2)]:n:' \
  '(-D --tmpdir)'{-D+,--tmpdir=}'[temp directory]:dir:_files -/' \
  '*:JACK Rack saved file:_files -g "*.(jrk|rack)(-.)"' && ret=0
return ret
