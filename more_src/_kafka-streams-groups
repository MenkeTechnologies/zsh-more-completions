#compdef kafka-streams-groups
# Documentation: https://kafka.apache.org/documentation/ (kafka-streams-groups.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--all-groups[Apply to all streams groups]'
    '--all-input-topics[Consider all source topics used in the topology of the group]'
    '--bootstrap-server[REQUIRED: The server(s) to connect to]:host\:port:'
    '--by-duration[Reset offsets to offset by duration from current timestamp (PnDTnHnMnS)]:duration:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--delete[Pass in groups to delete topic partition offsets and ownership]'
    '--delete-all-internal-topics[Delete all internal topics linked to the streams group]'
    '--delete-internal-topic[Delete specified internal topic of the streams group]:topic:'
    '--delete-offsets[Delete offsets of streams group]'
    '--describe[Describe streams group and list offset lag]'
    '--dry-run[Only show results without executing changes (reset-offsets)]'
    '--execute[Execute operation (reset-offsets)]'
    '--export[Export operation execution to a CSV file (reset-offsets)]'
    '--from-file[Reset offsets to values defined in CSV file]:file:_files'
    '--group[The streams group we wish to act on]:group:'
    '--help[Print usage information]'
    '--input-topic[The input topic whose committed offset should be deleted or reset]:topic:'
    '--list[List all streams groups]'
    '--members[Describe members of the group (with --describe only)]'
    '--offsets[Describe the group and list topic partitions with offsets]'
    '--reset-offsets[Reset offsets of streams group]'
    '--shift-by[Reset offsets shifting current offset by n]:n:'
    "--state[Display/filter by the state of all groups]::state:(Empty NotReady Stable Assigning Reconciling Dead)"
    '--timeout[Timeout in ms used e.g. when describing the group]:ms:'
    '--to-current[Reset offsets to current offset]'
    '--to-datetime[Reset offsets to offset from datetime (YYYY-MM-DDThh:mm:ss.sss)]:datetime:'
    '--to-earliest[Reset offsets to earliest offset]'
    '--to-latest[Reset offsets to latest offset]'
    '--to-offset[Reset offsets to a specific offset]:offset:'
    '--verbose[Show additional info with --describe --state/--members/--offsets]'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
