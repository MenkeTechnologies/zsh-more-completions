#compdef kafka-streams-groups
# Documentation: https://man.archlinux.org/search?q=kafka-streams-groups
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--list[List all streams groups]'
    '--describe[Describe a streams group]'
    '--delete[Delete a streams group]'
    '--group[Streams group ID]:group:'
    '--all-groups[Apply to all streams groups]'
    '--members[Describe members of the group]'
    '--verbose[Provide additional information if available]'
    '--state[Filter by group state]:state:'
)

_arguments -s -S $arguments
