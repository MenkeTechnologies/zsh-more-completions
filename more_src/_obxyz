#compdef obxyz
# Documentation: https://openbabel.org/docs/Command-line_tools.html
# Open Babel: re-orient a molecule by centering and aligning atoms to axes

local ret=1

_arguments -s -S \
  '-c+[atom index to be centered at the origin]:atom index' \
  '-x+[atom index to align to the x-axis]:atom index' \
  '-y+[atom index to align to the y-axis]:atom index' \
  '-z+[atom index to align to the z-axis]:atom index' \
  ':input file:_files' && ret=0

return ret
