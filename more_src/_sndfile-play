#compdef sndfile-play
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-play.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy sndfile-play(1) manpage. No flags documented;
# usage is `sndfile-play file ...`.

local -a arguments

arguments=(
    '*:sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
)

_arguments -s -S $arguments
