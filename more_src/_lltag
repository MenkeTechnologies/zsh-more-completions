#compdef lltag
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/lltag.1.html
# lltag - tag and rename mp3/ogg/flac music files automagically

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[print usage message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --ARTIST)'{-a,--ARTIST}'+[add a value for the ARTIST tag]:artist' \
  '(-t --TITLE)'{-t,--TITLE}'+[add a value for the TITLE tag]:title' \
  '(-A --ALBUM)'{-A,--ALBUM}'+[add a value for the ALBUM tag]:album' \
  '(-n --NUMBER)'{-n,--NUMBER}'+[add a value for the NUMBER tag]:number' \
  '(-g --GENRE)'{-g,--GENRE}'+[add a value for the GENRE tag]:genre' \
  '(-d --DATE)'{-d,--DATE}'+[add a value for the DATE tag]:date' \
  '(-c --COMMENT)'{-c,--COMMENT}'+[add a value for the COMMENT tag]:comment' \
  '--tag=[add an explicit tag value]:TAG=value' \
  '(-C --cddb)'{-C,--cddb}'[find tags in the CDDB online database]' \
  '(-E --edit)'{-E,--edit}'[edit tags immediately]' \
  '(-F --format)'{-F,--format}'+[add specified format string]:format' \
  '(-G --guess)'{-G,--guess}'[guess format using internal database]' \
  '(-p --no-path)'{-p,--no-path}'[do not consider file path when matching]' \
  '--clear[force clearing all tags before tagging]' \
  '--append[force appending tags instead of replacing]' \
  '--regexp=[replace values in tags before tagging]:regexp' \
  '--sep=[replace specified characters with spaces]:string' \
  '--spaces[allow multiple/no spaces when matching]' \
  '--maj[upcase first letter of each word in tags]' \
  '--mp3[tag all files as MP3 files]' \
  '--ogg[tag all files as OGG files]' \
  '--flac[tag all files as FLAC files]' \
  '--type=[tag all files as specified type]:type' \
  '--rename=[rename file according to format after tagging]:format' \
  '--rename-ext[assume extension provided by rename format]' \
  '--rename-min[lowcase all tags before renaming]' \
  '--rename-sep=[replace spaces with separator when renaming]:sep' \
  '--rename-slash=[replace slashes with character when renaming]:char' \
  '--rename-regexp=[replace values in tags before renaming]:regexp' \
  '(-S)-S[show tags in files instead of tagging]' \
  '--show-tags=[show specified tags from files]:tags' \
  '(-L --list)'{-L,--list}'[list internal formats]' \
  '--cddb-query=[automatically search CDDB database]:keywords' \
  '--cddb-server=[change CDDB server and port]:server' \
  '--yes[always accept tagging without confirmation]' \
  '--ask[always ask confirmation for user-specified parser]' \
  '--dry-run[show what would be done without tagging]' \
  '--no-tagging[do not tag files]' \
  '(-T --preserve-time)'{-T,--preserve-time}'[preserve file modification time]' \
  '(-R --recursive)'{-R,--recursive}'[recursively search subdirectories]' \
  '--config=[parse additional configuration file]:file:_files' \
  '--gencfg=[generate configuration file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[increase message verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease message verbosity]' \
  '*:music file:_files' && ret=0

return ret
