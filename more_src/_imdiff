#compdef imdiff
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imdiff.html
# MIRIAD: shift and expand an image to match another

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in1=[reference image]:in1:_files' \
  'in2=[image to adjust]:in2:_files' \
  'adjust=[output adjusted dataset]:adjust:_files' \
  'resid=[output residual image]:resid:_files' \
  'region=[region of interest]:region:' \
  'guard=[edge guard band width in pixels]:guard:' \
  'xshift=[initial x shift estimate]:xshift:' \
  'yshift=[initial y shift estimate]:yshift:' \
  'expand=[initial expansion factor]:expand:' \
  'amp=[initial amplitude scale factor]:amp:' \
  'offset=[initial DC offset]:offset:' \
  'options=[parameters to solve for]:options:' \
  '*:image:_files' && ret=0

return ret
