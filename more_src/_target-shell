#compdef target-shell
# Documentation: https://github.com/fox-it/dissect.target/blob/main/dissect/target/tools/shell.py
# dissect.target interactive shell over a forensic target

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --python)'{-p,--python}'[(I)Python shell]' \
  '(-r --registry)'{-r,--registry}'[registry shell]' \
  '(-c --commands)'{-c,--commands}'=[commands to execute]:commands' \
  '(-K --keychain-file)'{-K,--keychain-file}'=[keychain file in CSV format]:file:_files' \
  '(-Kv --keychain-value)'{-Kv,--keychain-value}'=[passphrase, recovery key or key file path value]:value' \
  '(-L --loader)'{-L,--loader}'=[select a specific loader]:loader' \
  '--child=[load child of target by path or index]:child' \
  '--children[include children]' \
  '--list-children[list children indices and paths, then exit]' \
  '--recursive[make --(list-)children behave recursively]' \
  '*'{-v,--verbose}'[increase output verbosity]' \
  '--version[print version]' \
  '(-q --quiet)'{-q,--quiet}'[do not output logging information]' \
  '--plugin-path=[a file or directory containing plugins and extensions]:path:_files' \
  '*:target:_files' && ret=0

return ret
