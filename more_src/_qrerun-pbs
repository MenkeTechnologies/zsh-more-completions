#compdef qrerun
# _qrerun-pbs — PBS qrerun (request the requeue of a running PBS job: terminates the job on its execution host, places it back in the queue, increments its rerun counter; -W force forces requeue even when job is non-rerunnable, -t array selector limits which sub-jobs; positional jobIDs)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qrerun.c on tip.

_qrerun-pbs() {
    _arguments \
        '-W+[extension list]:list:(force)' \
        '-t+[array selector]:range:' \
        '*:jobID:'
}

_qrerun-pbs "$@"
