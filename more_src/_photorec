#compdef photorec
# Documentation: https://www.cgsecurity.org/wiki/Scripted_run
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '/log[create a photorec.log file]' \
  '/debug[add debug info]' \
  '/d+[set destination directory for recovered files]:directory:_files -/' \
  '/cmd[run in command-line mode]' \
  '/version[display version]' \
  '/help[display help]' \
  '*:disk or image:_files' && ret=0

return ret
