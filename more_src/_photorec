#compdef photorec
# Documentation: https://man.archlinux.org/search?q=photorec
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '/log[create a photorec.log file]' \
  '/debug[add debug info]' \
  '/d+[set destination directory for recovered files]:directory:_files -/' \
  '/cmd[run in command-line mode]' \
  '/version[display version]' \
  '/help[display help]' \
  '*:disk or image:_files' && ret=0

return ret
