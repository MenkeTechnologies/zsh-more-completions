#compdef arce
# Documentation: https://www.npmjs.com/package/arce
# Reference accessed: 2026-05-23
# Verified: npm view arce bin; upstream GitHub README.

# Zsh completion for arce - Arcane CLI utility

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '*::args:' && ret=0

return ret
