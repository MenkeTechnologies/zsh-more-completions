#compdef suspecfk
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/transforms/suspecfk.c
# F-K Fourier SPECtrum of SU data set

local ret=1

_arguments -s -S \
  'dt=[time sampling interval]:dt' \
  'dx=[spatial sampling interval]:dx' \
  'verbose=[verbose=1 echoes information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
