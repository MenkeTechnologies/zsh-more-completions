#compdef genePredToBed
# UCSC kent: convert a genePred file to a BED file

local ret=1

_arguments -s -S \
  '-tab[genePred fields are separated by tab instead of whitespace]' \
  '-fillSpace[with tab input, fill space chars in name with underscore]' \
  '-score=[set score to N in bed output (default 0)]:n' \
  '1:input genePred:_files' \
  '2:output bed:_files' && ret=0

return ret
