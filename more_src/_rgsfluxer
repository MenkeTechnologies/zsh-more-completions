#compdef rgsfluxer
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgsfluxer/node4.html
# Combine and flux RGS spectra

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--pha=[list of spectrum files produced by rgsspectrum]:files:_files' \
  '--rmf=[response matrix files produced by rgsrmfgen]:files:_files' \
  '--bkg=[background spectrum files produced by rgsspectrum]:files:_files' \
  '--witharf=[enable separate response matrix and effective area files]:bool:(yes no)' \
  '--arf=[effective area files produced by rgsrmfgen]:files:_files' \
  '--format=[output fluxed spectrum format]:format:(dal text qdp)' \
  '--file=[output filename for the fluxed spectrum]:file:_files' \
  '--mode=[computational mode units]:mode:(wavelength energy)' \
  '--tryspectrumgrid=[use input spectra grid if consistent]:bool:(yes no)' \
  '--min=[lower edge of the first output bin]:value' \
  '--max=[upper edge of the last output bin]:value' \
  '--bins=[number of output bins]:n' \
  '--quality=[how quality flags propagate to output]:quality' \
  '--withaltnan=[replace NaN with finite alternative values]:bool:(yes no)' \
  '--nan=[finite value to replace NaN]:value' \
  '*:param=value:_default' && ret=0

return ret
