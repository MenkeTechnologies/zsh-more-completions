#compdef crudini

_arguments -s -S \
  '--existing=[fail if missing]:what:(file section param)' \
  '--format=[--get output format]:format:(sh ini lines)' \
  '--ini-options=[iniparse style options]:opts:(nospace space sectionspace ignoreindent)' \
  '--inplace[edit files with lock in-place]' \
  '--list[treat value as delimited list]' \
  '--list-sep=[list delimiter string]:sep:' \
  '--output=[write to file (- for stdout)]:file:_files' \
  '--verbose[report whether changes were made]' \
  '--help[show help]' \
  '--version[show version]' \
  '*::ini path section param value: _default'
