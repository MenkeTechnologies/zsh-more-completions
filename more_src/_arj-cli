#compdef arj-cli unarj-cli
# _arj-cli — Open Source ARJ Software arj/unarj archive utility CLI alias (arj team, C); custom argparse
# upstream: https://arj.sourceforge.net/

_arj-cli() {
    local -a sub=(
        'a:add files to archive'
        'c:set/reset/show archive comment'
        'd:delete files from archive'
        'e:extract files (no path)'
        'f:freshen files in archive'
        'g:encrypt/decrypt archive'
        'h:show help'
        'i:show technical info'
        'j:join archives'
        'k:remove deleted markers'
        'l:list archive contents'
        'm:move files to archive'
        'n:rename files in archive'
        'o:reorder files in archive'
        'p:print files to stdout'
        'r:remove paths from filenames'
        's:set archive attributes'
        't:test archive integrity'
        'u:update files in archive'
        'v:verbose archive listing'
        'w:wipe deleted file contents'
        'x:extract with full paths'
        'y:copy archive'
    )
    _arguments -C \
        '--help[show help]' \
        '-?[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arj command' sub ;;
        args)
            _arguments \
                '-a[any attribute selection]' \
                '-b+[backup files]:str:' \
                '-c+[skip time check]:str:' \
                '-d[delete after archiving]' \
                '-e[no directory paths]' \
                '-f[freshen mode]' \
                '-g+[garble password]:str:' \
                '-i+[index character]:str:' \
                '-jf+[fields in archive header]:str:' \
                '-jh+[heap size]:str:' \
                '-l+[list filename]:file:_files' \
                '-m+[compression mode 0-4]:n:(0 1 2 3 4)' \
                '-n[new file only]' \
                '-o+[date]:str:' \
                '-p[match full path]' \
                '-r[recursive]' \
                '-s+[sfx file]:file:_files' \
                '-t+[type]:str:' \
                '-u[update mode]' \
                '-v[verbose]' \
                '-w[wildcards in filenames]' \
                '-x+[exclude files]:str:' \
                '-y[yes to all queries]' \
                '*:archive files:_files -g "*.{arj,exe}"' ;;
    esac
}

_arj-cli "$@"
