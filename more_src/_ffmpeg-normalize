#compdef ffmpeg-normalize

# Zsh completion for ffmpeg-normalize - audio normalization with ffmpeg

_arguments -s -S \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-of --output-folder)'{-of,--output-folder}'[output folder]:directory:_files -/' \
  '(-f --force)'{-f,--force}'[force overwrite existing files]' \
  '(-d --debug)'{-d,--debug}'[print debug output]' \
  '(-v --verbose)'{-v,--verbose}'[print verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-n --dry-run)'{-n,--dry-run}'[perform a dry run]' \
  '(-pr --progress)'{-pr,--progress}'[show progress bar]' \
  '(-nt --normalization-type)'{-nt,--normalization-type}'[normalization type]:type:(ebu rms peak)' \
  '(-t --target-level)'{-t,--target-level}'[target normalization level in dB]:level:' \
  '(-p --print-stats)'{-p,--print-stats}'[print loudness statistics]' \
  '(-lrt --loudness-range-target)'{-lrt,--loudness-range-target}'[loudness range target in LU]:range:' \
  '(-tp --true-peak)'{-tp,--true-peak}'[true peak level in dBTP]:level:' \
  '(-offset --offset)'{-offset,--offset}'[audio offset in dB]:offset:' \
  '--dual-mono[treat mono as dual-mono]' \
  '--keep-loudness-range-target[keep loudness range target]' \
  '--keep-lra-above-loudness-range-target[keep LRA above target]' \
  '(-c --audio-codec -c:a)'{-c,-c:a,--audio-codec}'[audio codec]:codec:(aac libmp3lame flac pcm_s16le pcm_s24le libvorbis libopus wavpack)' \
  '(-b --audio-bitrate -b:a)'{-b,-b:a,--audio-bitrate}'[audio bitrate]:bitrate:' \
  '(-ar --sample-rate -ar)'{-ar,--sample-rate}'[audio sample rate]:rate:(44100 48000 96000)' \
  '(-ac --audio-channels)'{-ac,--audio-channels}'[number of audio channels]:channels:' \
  '--video-codec[video codec]:codec:(copy libx264 libx265)' \
  '--video-disable[disable video stream]' \
  '--subtitle-disable[disable subtitle stream]' \
  '--metadata-disable[disable metadata copying]' \
  '--chapters-disable[disable chapters copying]' \
  '(-e --extra-input-options)'{-e,--extra-input-options}'[extra ffmpeg input options]:options:' \
  '(-ofmt --output-format)'{-ofmt,--output-format}'[output format]:format:(mp3 mp4 flac ogg wav mkv)' \
  '(-ext --extension)'{-ext,--extension}'[output file extension]:extension:' \
  '--pre-filter[pre-normalization filter]:filter:' \
  '--post-filter[post-normalization filter]:filter:' \
  '*:input file:_files -g "*.{mp3,mp4,flac,ogg,wav,mkv,avi,m4a,aac,wma,opus,webm}"' && return 0
