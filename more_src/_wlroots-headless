#compdef wlroots-headless
# Documentation: https://man.archlinux.org/search?q=wlroots-headless
# Reference accessed: 2026-05-16

# wlroots-headless: launch a wlroots compositor with a headless backend (test)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[run program inside session]:cmd:' \
  '*::wlroots-headless args:_files' && ret=0
return ret
