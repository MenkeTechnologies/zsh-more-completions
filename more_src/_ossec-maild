#compdef ossec-maild
# Documentation: https://www.ossec.net/docs/programs/ossec-maild.html
# OSSEC email alerting daemon

local ret=1

_arguments -s \
  '-V[version and license message]' \
  '-h[show help]' \
  '*-d[debug mode (repeat to increase verbosity)]' \
  '-t[test configuration]' \
  '-f[run in foreground]' \
  '-u[run as this user]:user:_users' \
  '-g[run as this group]:group:_groups' \
  '-D[chroot directory]:directory:_directories' \
  '-c[configuration file]:config file:_files' && ret=0

return ret
