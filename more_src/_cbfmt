#compdef cbfmt
# Documentation: https://github.com/lukas-reineke/cbfmt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cbfmt formats code blocks inside markdown/org/restructuredtext documents.
# Flags below verified against src/main.rs in lukas-reineke/cbfmt.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--config=[custom config file path]:file:_files' \
  '(-c --check)'{-c,--check}'[check formatting; print paths of unformatted files]' \
  '--fail-fast[stop processing on first unformatted file]' \
  '(-w --write)'{-w,--write}'[write changes back to files in place]' \
  '--best-effort[continue past formatting errors]' \
  '(-p --parser)'{-p+,--parser=}'[parser to use]:parser:(markdown org restructuredtext)' \
  '--stdin-filepath=[source path for stdin input]:file:_files' \
  '--color=[control coloring]:mode:(never auto always)' \
  '*:files:_files' && ret=0

return ret
