#compdef cbfmt

# Zsh completion for cbfmt (code block formatter)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-c+[Config file path]:file:_files' \
  '--config=[Config file path]:file:_files' \
  '--check[Check formatting without writing changes]' \
  '-w[Write changes to files in place]' \
  '--write[Write changes to files in place]' \
  '--stdin-filepath=[Path hint for stdin input]:file:_files' \
  '-v[Verbose output]' \
  '--verbose[Verbose output]' \
  '*:files:_files' && ret=0

return ret
