#compdef dbt

# Zsh completion for dbt (data build tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log-format=[set log format]:format:(text json default)' \
  '--no-use-colors[disable colored output]' \
  '-d[debug logging]' \
  '--debug[debug logging]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:run all seeds, models, snapshots and tests'
      'clean:delete all build artifacts'
      'clone:clone selected models from a specified state'
      'compile:compile dbt models'
      'debug:debug dbt configuration'
      'deps:install dbt packages'
      'docs:generate or serve documentation'
      'init:initialize a new dbt project'
      'list:list resources in the project'
      'ls:list resources in the project'
      'parse:parse the project'
      'retry:retry the last failed run'
      'run:run dbt models'
      'run-operation:run a macro'
      'seed:load CSV files into the data warehouse'
      'show:show a preview of a model'
      'snapshot:execute snapshots'
      'source:manage sources'
      'test:run tests'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      run|build|test|compile|snapshot|seed)
        _arguments -s -S \
          '(-s --select)'{-s,--select}'[select nodes]:selector' \
          '--exclude=[exclude nodes]:selector' \
          '(-m --models)'{-m,--models}'[select models]:model selector' \
          '--full-refresh[drop incremental models and rebuild]' \
          '--target=[target profile]:target' \
          '--profiles-dir=[directory for profiles.yml]:directory:_directories' \
          '--project-dir=[directory for dbt_project.yml]:directory:_directories' \
          '--vars=[supply variables]:json' \
          '--threads=[number of threads]:threads' \
          '--no-version-check[skip version check]' \
          '--fail-fast[exit immediately on first failure]' \
          '--defer[defer to manifest from a previous state]' \
          '--state=[directory with previous state]:directory:_directories' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      docs)
        _arguments -s -S \
          '1:subcommand:(generate serve)' && ret=0
        ;;
      init)
        _arguments -s -S \
          '--skip-profile-setup[skip profile setup]' \
          '1:project name' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          '--resource-type=[resource type]:type:(model test snapshot seed source exposure metric analysis)' \
          '(-s --select)'{-s,--select}'[select nodes]:selector' \
          '--exclude=[exclude nodes]:selector' \
          '--output=[output format]:format:(json name path selector)' \
          '--output-keys=[output keys]:keys' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      source)
        _arguments -s -S \
          '1:subcommand:(freshness snapshot)' && ret=0
        ;;
    esac
    ;;
esac

return ret
