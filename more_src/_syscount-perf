#compdef syscount-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/syscount.8
# count system calls (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-c[show counts by syscall name]' \
  '-d+[duration of trace in seconds]:secs' \
  '-p+[trace this PID only]:pid:_pids' \
  '-t+[show top number only]:num' \
  '-v[verbose, shows PID]' \
  '*:command:_command_names -e' && ret=0

return ret
