#compdef impacket-secretsdump

# Impacket secretsdump.py: dump SAM/LSA/NTDS hashes and Kerberos keys
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug output]' \
  '-ts[print timestamps]' \
  '-system[SYSTEM hive file]:file:_files' \
  '-bootkey[bootkey hex]:hex:' \
  '-security[SECURITY hive file]:file:_files' \
  '-sam[SAM hive file]:file:_files' \
  '-ntds[NTDS.dit file]:file:_files' \
  '-history[also dump password history]' \
  '-pwd-last-set[show last password set date]' \
  '-resumefile[checkpoint resume file]:file:_files' \
  '-outputfile[output file prefix]:prefix:' \
  '-use-vss[use Volume Shadow Copy]' \
  '-just-dc-user[only dump this user]:user:' \
  '-just-dc[only NTDS DC hashes]' \
  '-just-dc-ntlm[only NTLM hashes, no Kerberos keys]' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target host IP]:ip:' \
  '-keytab[Kerberos keytab file]:file:_files' \
  '-rodcNo[rodc krbtgt number]:n:' \
  '-rodcKey[rodc krbtgt key]:key:' \
  '*:target user[:password]@host:' && ret=0
return ret
