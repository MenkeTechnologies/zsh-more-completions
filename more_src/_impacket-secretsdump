#compdef impacket-secretsdump
# Documentation: https://man.archlinux.org/search?q=impacket-secretsdump
# Reference accessed: 2026-05-16

# impacket-secretsdump: dump SAM/LSA secrets, DPAPI keys, NTDS.dit from remote target
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -system[SYSTEM hive]:file:_files -bootkey[boot key]:hex: -security[SECURITY hive]:file:_files -sam[SAM hive]:file:_files -ntds[NTDS.dit file]:file:_files -resumefile[resume file]:file:_files -outputfile[output file]:file:_files -use-vss[use VSS for online dump] -exec-method[remote exec method]:method:(smbexec wmiexec mmcexec) -just-dc[only NTDS.dit secrets] -just-dc-ntlm[only NTLM hashes] -just-dc-user[only this user]:user: -no-pwd-last-set[skip password last set] -user-status[show account status flags] -pwd-last-set[show password last set] -history[show all password history] -dc-ip[domain controller IP]:ip: \
  '*::impacket-secretsdump args:_files' && ret=0
return ret
