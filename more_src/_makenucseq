#compdef makenucseq

# EMBOSS makenucseq: create random nucleotide sequence(s)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-amount=[number of sequences to generate]:n:' \
  '-length=[length of each sequence]:length:' \
  '-pepstatsfile=[codon usage / pepstats input file]:file:_files' \
  '-useinsert=[insertion sequence to include]:seq:' \
  '-insertpos=[insert position in each sequence]:pos:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank gff swiss raw)' \
  '*:output:_files' && ret=0
return ret
