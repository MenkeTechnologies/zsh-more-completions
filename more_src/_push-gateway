#compdef pushgateway push-gateway
# _push-gateway — Prometheus pushgateway (push-based metrics aggregator that accepts metric pushes from batch jobs and exposes them for Prometheus to scrape; --web.listen-address, --web.external-url, --web.route-prefix, --web.config.file TLS+auth, --web.enable-admin-api, --web.enable-lifecycle, --persistence.file, --persistence.interval, --log.level, --log.format)
# upstream: https://github.com/prometheus/pushgateway
# Flags from prometheus/pushgateway main.go on tip.

_push-gateway() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--web.listen-address+[addr:port]:listen:' \
        '--web.external-url+[external URL]:url:' \
        '--web.route-prefix+[route prefix]:prefix:' \
        '--web.telemetry-path+[telemetry path]:path:' \
        '--web.config.file+[web config file]:file:_files' \
        '--web.enable-admin-api[enable admin API]' \
        '--web.enable-lifecycle[enable shutdown via HTTP]' \
        '--persistence.file+[persistence file]:file:_files' \
        '--persistence.interval+[interval]:duration:' \
        '--push.disable-consistency-check[skip consistency check]' \
        '--log.level=*[log level]:level:(debug info warn error)' \
        '--log.format=*[log format]:format:(json logfmt)'
}

_push-gateway "$@"
