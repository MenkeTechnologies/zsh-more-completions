#compdef cargo-locate-project
# Documentation: https://man.archlinux.org/search?q=cargo-locate-project
# Reference accessed: 2026-05-16

_arguments -s \
  '--workspace[workspace root]' \
  '--message-format=[format]:fmt:(json plain)' \
  '*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--color=[when]:when:(auto always never)' \
  '--manifest-path=[manifest]:file:_files' \
  '*--config=[KEY=VALUE]:setting:' \
  '-C[change dir]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-Z[unstable]:flag:'
