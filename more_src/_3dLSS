#compdef 3dLSS
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLSS.html
# AFNI: least squares sum estimation of single-trial response amplitudes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-matrix[.xmat.1D matrix file from 3dDeconvolve]:matrix:_files' \
  '-input[input 3D+time dataset]:dataset:_files' \
  '-nodata[compute LSS matrix without input data]' \
  '-mask[mask dataset]:mask:_files' \
  '-automask[create mask from input]' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-save1D[save LSS coefficient matrix to .1D file]:file:_files' \
  '-verb[verbose output]' \
  '*:dataset:_files' && ret=0

return ret
