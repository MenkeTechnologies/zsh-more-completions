#compdef listmake
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss85.html
# KAPPA: creates a catalogue holding a positions list

local ret=1

_arguments -s \
  'NDF=[NDF defining the WCS for the positions]:ndf:_files -g "*.sdf"' \
  'MODE=[how positions are obtained]:mode:(Interface File Catalogue Random Grid Pixel)' \
  'FILE=[text file supplying positions]:file:_files' \
  'OUTCAT=[output positions catalogue]:catalogue:_files' \
  'CATEPOCH=[epoch of the output catalogue]:epoch' \
  'CATFRAME=[WCS Frame for the catalogue]:frame' \
  'DESCRIBE=[describe the WCS Frame]:bool:(TRUE FALSE)' \
  'DIM=[dimensionality of the positions]:n' \
  'EPOCH=[epoch of the supplied positions]:epoch' \
  'FRAME=[coordinate Frame of the positions]:frame' \
  'INCAT=[input catalogue of positions]:catalogue:_files' \
  'POSITION=[position to add]:position' \
  'TITLE=[title for the output catalogue]:title' \
  '*:file:_files' && ret=0

return ret
