#    - lys-lang/lys (lys-lang/lys — Lys compiler, smaller community)
#    - many Vercel-team internal CLI tools (uses arg across the
#      Vercel/Next.js ecosystem)
# ============================================================================

_zenn() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'init:initialize Zenn directory structure'
        'preview:start local preview server (default)'
        'new\:article:create a new article with frontmatter'
        'new\:book:create a new book with chapters'
        'list\:articles:list all articles in repo'
        'list\:books:list all books in repo'
        'help:show general help'
        'version:show version'
      )
      _describe -t commands 'zenn subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        preview)
          _arguments -s -S \
            '(-p --port)'{-p,--port}'=[listen port (default 8000)]:port' \
            '--no-watch[disable file watching]' \
            '--open[open browser after start]' \
            '--host=[bind hostname]:host:_hosts' \
            '(-h --help)'{-h,--help}'[show preview help]'
          ;;
        init)
          _arguments '(-h --help)'{-h,--help}'[show init help]'
          ;;
        new:article)
          _arguments -s -S \
            '--slug=[article slug]:slug' \
            '--title=[article title]:title' \
            '--type=[article type]:type:(tech idea)' \
            '--emoji=[article emoji]:emoji' \
            '--published=[published state]:state:(true false)' \
            '--publication-name=[publication name]:name' \
            '--machine-readable[output machine-readable result]' \
            '(-h --help)'{-h,--help}'[show new:article help]'
          ;;
        new:book)
          _arguments -s -S \
            '--slug=[book slug]:slug' \
            '--title=[book title]:title' \
            '--published=[published state]:state:(true false)' \
            '(-h --help)'{-h,--help}'[show new:book help]'
          ;;
        list:articles|list:books)
          _arguments '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_zenn "$@"
