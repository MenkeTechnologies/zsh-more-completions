#compdef i3lock-fancy

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --desktop)'{-d,--desktop}'[minimize all windows before locking]' \
  '(-g --greyscale)'{-g,--greyscale}'[greyscale background]' \
  '(-p --pixelate)'{-p,--pixelate}'[pixelate instead of blur]' \
  '(-f --font)'{-f+,--font=}'[custom font]:font:' \
  '(-t --text)'{-t+,--text=}'[custom prompt text]:text:' \
  '(-l --listfonts)'{-l,--listfonts}'[list available fonts]' \
  '(-n --nofork)'{-n,--nofork}'[do not fork i3lock]' \
  '*: :' && ret=0

return ret
