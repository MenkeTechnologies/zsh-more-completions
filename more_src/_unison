#compdef unison

# Zsh completion for unison - file synchronizer

_arguments -s -S \
  '-auto[automatically accept default (nonconflicting) actions]' \
  '-batch[batch mode, ask no questions]' \
  '-confirmbigdel[request confirmation for large deletions]' \
  '-confirmmerge[request confirmation before merging]' \
  '-contactquietly[suppress the contacting server message]' \
  '-doc[show documentation for a given section]:section' \
  '-dumbtty[do not change terminal settings]' \
  '-fat[use FAT-compatible mode]' \
  '-fastcheck=[use fast update detection]:mode:(true false default)' \
  '*-follow=[follow symbolic links matching pattern]:pattern' \
  '-force=[force changes from this root]:root:_files -/' \
  '-group[synchronize group attributes]' \
  '-halfduplex[force half-duplex communication]' \
  '-height=[set height of the main window]:lines' \
  '*-ignore=[ignore paths matching pattern]:pattern' \
  '-ignorearchives[ignore existing archive files]' \
  '-ignorelocks[ignore leftover lock files]' \
  '*-ignorenot=[negate an ignore pattern]:pattern' \
  '*-immutable=[mark paths as immutable]:pattern' \
  '-killserver[kill the server after synchronization]' \
  '-label=[provide a descriptive label for this profile]:label' \
  '-log[record actions in logfile]' \
  '-logfile=[set the log file name]:log file:_files' \
  '-maxbackups=[set maximum number of backups]:count' \
  '-maxerrors=[set maximum non-fatal errors]:count' \
  '-maxthreads=[set maximum number of concurrent threads]:count' \
  '*-merge=[set merge command for a given pattern]:merge command' \
  '-nocreation=[prevent file creation on root]:root:_files -/' \
  '-nodeletion=[prevent file deletion on root]:root:_files -/' \
  '-noupdate=[prevent updates on root]:root:_files -/' \
  '-numericids[do not map user/group names]' \
  '-owner[synchronize owner attributes]' \
  '*-path=[synchronize only this path]:path' \
  '-perms=[set permission bits to synchronize]:permission bits' \
  '-prefer=[choose this root for conflicts]:root:_files -/' \
  '-repeat=[synchronize repeatedly at interval]:interval' \
  '-retry=[set number of retries on transient errors]:count' \
  '*-root=[specify a synchronization root]:root path:_files -/' \
  '-rsrc=[synchronize resource forks]:mode:(true false default)' \
  '-rsync[activate rsync transfer mode]' \
  '-servercmd=[specify path to unison on the server]:path:_files' \
  '-silent[print nothing except error messages]' \
  '-socket=[act as server on the given port]:port' \
  '-sortbysize[sort entries by size]' \
  '-sortfirst=[sort matching paths first]:pattern' \
  '-sortlast=[sort matching paths last]:pattern' \
  '-sortnewfirst[sort new entries first]' \
  '-sshargs=[pass arguments to ssh]:ssh arguments' \
  '-sshcmd=[path to ssh command]:ssh path:_files' \
  '-terse[suppress status messages]' \
  '-testserver[test server mode and exit]' \
  '-times[synchronize modification times]' \
  '-ui=[select user interface]:interface:(text graphic)' \
  '(- *)-version[print version and exit]' \
  '*:profile or root:_files -/'
