#compdef unison

# Zsh completion for unison - file synchronizer

_arguments -s -S \
  '-auto[automatically accept non-conflicting changes]' \
  '-batch[batch mode, no user interaction]' \
  '-confirmbigdel[request confirmation for large deletions]' \
  '-confirmmerge[request confirmation before merging]' \
  '-contactquietly[suppress contacting server message]' \
  '-debug[debug module]:module:' \
  '-doc[show documentation section]:section:' \
  '-dumbtty[do not use terminal control codes]' \
  '-fat[use FAT-compatible mode]' \
  '-fastcheck[use fast checking]:mode:(true false default)' \
  '-follow[follow symbolic links matching pattern]:pattern:' \
  '-force[force changes from this root]:root:_files -/' \
  '-group[synchronize group attributes]' \
  '-halfduplex[half-duplex mode]' \
  '-height[height of main window]:lines:' \
  '-host[remote host name]:host:_hosts' \
  '-ignore[ignore paths matching pattern]:pattern:' \
  '-ignorearchives[ignore existing archives]' \
  '-ignorelocks[ignore lock files]' \
  '-ignorenot[negate an ignore pattern]:pattern:' \
  '-immutable[paths matching pattern are immutable]:pattern:' \
  '-immutablenot[negate an immutable pattern]:pattern:' \
  '-key[define a keyboard shortcut]:keybinding:' \
  '-killserver[kill server when done]' \
  '-label[provide a descriptive label]:label:' \
  '-log[record actions in logfile]' \
  '-logfile[log file name]:file:_files' \
  '-maxbackups[maximum number of backups]:count:' \
  '-maxerrors[maximum number of errors before stopping]:count:' \
  '-maxthreads[maximum number of threads]:count:' \
  '-merge[command for merging conflicting files]:command:' \
  '-mountpoint[mount point to synchronize]:path:_files -/' \
  '-nocreation[prevent file creation on this root]:root:_files -/' \
  '-nodeletion[prevent file deletion on this root]:root:_files -/' \
  '-noupdate[prevent updates on this root]:root:_files -/' \
  '-numericids[use numeric user and group IDs]' \
  '-owner[synchronize owner attributes]' \
  '*-path[path to synchronize]:path:_files' \
  '-perms[permission bits to synchronize]:bits:' \
  '-prefer[choose this root in case of conflict]:root:_files -/' \
  '-pretendwin[emulate Windows file system limitations]' \
  '-repeat[synchronize repeatedly at interval]:interval:' \
  '-retry[number of retries on transient errors]:count:' \
  '*-root[root of a replica]:root:_files -/' \
  '-rsrc[synchronize resource forks]:mode:(true false default)' \
  '-rsync[use rsync for file transfer]' \
  '-servercmd[path to unison on server]:path:_files' \
  '-silent[print nothing except error messages]' \
  '-socket[act as a server on this port]:port:' \
  '-sortbysize[sort files by size]' \
  '-sortfirst[synchronize paths matching pattern first]:pattern:' \
  '-sortlast[synchronize paths matching pattern last]:pattern:' \
  '-sortnewfirst[list new items before changed ones]' \
  '-sshargs[extra arguments for ssh]:args:' \
  '-sshcmd[path to ssh]:path:_files' \
  '-terse[suppress status messages]' \
  '-testserver[test server and exit]' \
  '-times[synchronize modification times]' \
  '-ui[user interface type]:type:(text graphic)' \
  '-unicode[assume Unicode encoding]:mode:(true false default)' \
  '(- *)-version[show version]' \
  '-xferbycopying[optimize transfers using copies]' \
  '*:profile or root:_files'
