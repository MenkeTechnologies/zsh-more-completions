#compdef footclient foot-client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-o[override config option]:key=value:' \
  '-T[window title]:title:' \
  '-a[app-id]:app id:' \
  '-w[initial window size]:WxH:' \
  '-m[maximize]' \
  '-F[fullscreen]' \
  '-L[log level]:level:(info warning error none)' \
  '-s[socket path]:socket:_files' \
  '-N[do not wait for server]' \
  '-e[start command]:command:_command_names' \
  '-d[working directory]:directory:_files -/' \
  '-D[enable log colorization]:when:(auto always never)' \
  '--hold[keep terminal open after command exits]' && ret=0

return ret
