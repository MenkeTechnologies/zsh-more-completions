#compdef rtedge
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=rtedge&sektion=1
# BRL-CAD edge-detection raytracer producing line drawings

local ret=1

_arguments -s \
  '-a[auto-size and set view azimuth in degrees]:azimuth' \
  '-b[fire single ray at pixel for debugging]:x y' \
  '-e[auto-size and set view elevation in degrees]:elevation' \
  '-g[grid cell width in millimeters]:width' \
  '-m[exponential haze density,r,g,b]:haze' \
  '-i[enable incremental mode]' \
  '-j[process sub-rectangle xmin,ymin,xmax,ymax]:rect' \
  '-k[cutting plane xdir,ydir,zdir,dist]:plane' \
  '-l[select lighting model (0-7)]:model' \
  '-n[image height in scanlines]:height' \
  '-o[output file (.pix)]:output:_files' \
  '-p[perspective in degrees (0-180)]:perspective' \
  '-r[report overlapping regions]' \
  '-s[grid size, rays in X and Y (default 512)]:size' \
  '-t[reverse grid traversal order]' \
  '-u[units]:units' \
  '-v[verbosity level]:level' \
  '-w[scanline width in pixels]:width' \
  '-x[librt debug flags (hex)]:flags' \
  '-A[shading angle in degrees (default 5.0)]:angle' \
  '-B[benchmark mode]' \
  '-C[background color #/#/#]:color' \
  '-D[starting frame number]:frame' \
  '-E[eye-to-model-center distance]:distance' \
  '-F[output framebuffer]:framebuffer' \
  '-G[grid cell height in millimeters]:height' \
  '-H[hypersample count]:count' \
  '-J[jitter flag bit vector]:jitter' \
  '-K[final frame number]:frame' \
  '-M[read animation matrix from stdin]' \
  '-N[NMG debug flags (hex)]:flags' \
  '-O[double-precision output file (.dpix)]:output:_files' \
  '-P[max number of processors]:cpus' \
  '-Q[debug pixel x,y]:pixel' \
  '-R[do not report overlapping regions]' \
  '-S[enable stereo viewing]' \
  '-T[calculation tolerances]:tol' \
  '-U[set use_air boolean]:value' \
  '-V[view aspect ratio]:ratio' \
  '-W[black lines on white background]' \
  '-X[rt program debug flags]:flags' \
  '-c[set rtedge config variable (e.g. fg=r,g,b)]:config' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
