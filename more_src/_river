#compdef riverctl

local -a _river_commands
_river_commands=(
  'close:close focused view'
  'csd-filter-add:add CSD filter'
  'csd-filter-remove:remove CSD filter'
  'exit:exit the compositor'
  'float-filter-add:add float filter'
  'float-filter-remove:remove float filter'
  'focus-follows-cursor:set focus follows cursor mode'
  'focus-output:focus an output'
  'focus-view:focus next/previous view'
  'input:configure input device'
  'keyboard-layout:set keyboard layout'
  'map:add a key mapping'
  'map-pointer:add a pointer mapping'
  'map-switch:add a switch mapping'
  'move:move focused view'
  'resize:resize focused view'
  'rule-add:add a window rule'
  'rule-del:delete a window rule'
  'send-layout-cmd:send command to layout generator'
  'set-cursor-warp:set cursor warp mode'
  'set-repeat:set keyboard repeat rate'
  'snap:snap focused view to edge'
  'spawn:spawn a command'
  'swap:swap focused view'
  'toggle-float:toggle floating'
  'toggle-fullscreen:toggle fullscreen'
  'unmap:remove a key mapping'
  'unmap-pointer:remove a pointer mapping'
  'unmap-switch:remove a switch mapping'
  'xcursor-theme:set Xcursor theme'
  'zoom:zoom focused view'
  'default-layout:set default layout generator'
  'output-layout:set output layout generator'
  'send-to-output:send view to output'
  'set-focused-tags:set focused tags'
  'set-view-tags:set view tags'
  'spawn-tagmask:set spawn tagmask'
  'toggle-focused-tags:toggle focused tags'
  'toggle-view-tags:toggle view tags'
  'background-color:set background color'
  'border-color-focused:set focused border color'
  'border-color-unfocused:set unfocused border color'
  'border-color-urgent:set urgent border color'
  'border-width:set border width'
  'declare-mode:declare a new mode'
  'enter-mode:enter a mode'
  'attach-mode:set attach mode'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-version --version)'{-version,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'riverctl commands' _river_commands
    ;;
  args)
    case "$words[1]" in
      spawn)
        _arguments '*:command:_command_names -e'
        ;;
      map|unmap)
        _arguments \
          '-release[trigger on release]' \
          '-repeat[repeat while held]' \
          '-layout[use layout index]:index' \
          '1:mode' \
          '2:modifiers' \
          '3:key' \
          '4:command'
        ;;
      focus-output|send-to-output)
        _arguments '1:direction:(next previous up down left right)'
        ;;
      focus-view|swap)
        _arguments '1:direction:(next previous up down left right)'
        ;;
      set-repeat)
        _arguments '1:rate' '2:delay'
        ;;
      focus-follows-cursor)
        _arguments '1:mode:(disabled normal always)'
        ;;
      set-cursor-warp)
        _arguments '1:mode:(disabled on-output-change on-focus-change)'
        ;;
      attach-mode)
        _arguments '1:mode:(top bottom above below after)'
        ;;
      border-width)
        _arguments '1:width'
        ;;
      background-color|border-color-focused|border-color-unfocused|border-color-urgent)
        _arguments '1:color'
        ;;
      input)
        _arguments '1:device' '2:setting' '3:value'
        ;;
    esac
    ;;
esac
