#compdef huggingface-cli

# Zsh completion for huggingface-cli - HuggingFace Hub CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:download files from the Hub'
  'upload:upload files to the Hub'
  'repo:manage repos on the Hub'
  'login:log in to Hugging Face'
  'logout:log out from Hugging Face'
  'whoami:find out which HuggingFace account you are logged in as'
  'env:print information about the environment'
  'scan-cache:scan cache directory'
  'delete-cache:delete revisions from the cache directory'
  'tag:tag a repo on the Hub'
  'lfs-enable-largefiles:configure repository to use Git LFS'
  'lfs-multipart-upload:multipart upload for Git LFS'
  'version:print version'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'huggingface-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (download)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repo-type=[type of repo]:type:(model dataset space)' \
          '--revision=[git revision to download from]:revision' \
          '--include=[glob patterns to include]:pattern' \
          '--exclude=[glob patterns to exclude]:pattern' \
          '--cache-dir=[path to the cache directory]:directory:_files -/' \
          '--local-dir=[download to a local directory]:directory:_files -/' \
          '--local-dir-use-symlinks=[use symlinks for local dir]:option:(auto true false)' \
          '--force-download[force re-download even if files exist]' \
          '--resume-download[resume interrupted download]' \
          '--token=[Hugging Face access token]:token' \
          '--quiet[suppress output]' \
          '1:repo_id' \
          '*:filenames' && ret=0
        ;;
      (upload)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repo-type=[type of repo]:type:(model dataset space)' \
          '--revision=[git revision to upload to]:revision' \
          '--commit-message=[commit message]:message' \
          '--commit-description=[commit description]:description' \
          '--create-pr[create a pull request]' \
          '--private[create a private repo if it does not exist]' \
          '--include=[glob patterns to include]:pattern' \
          '--exclude=[glob patterns to exclude]:pattern' \
          '--delete=[glob patterns for files to delete]:pattern' \
          '--token=[Hugging Face access token]:token' \
          '--quiet[suppress output]' \
          '1:repo_id' \
          '2:local_path:_files' \
          '3:path_in_repo' && ret=0
        ;;
      (repo)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(create)' && ret=0
        ;;
      (login)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--token=[Hugging Face access token]:token' \
          '--add-to-git-credential[save token to git credential helper]' && ret=0
        ;;
      (scan-cache)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dir=[cache directory to scan]:directory:_files -/' \
          '--verbose[show detailed information]' && ret=0
        ;;
      (delete-cache)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--dir=[cache directory]:directory:_files -/' \
          '--disable-tui[disable TUI mode]' && ret=0
        ;;
      (tag)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repo-type=[type of repo]:type:(model dataset space)' \
          '--revision=[git revision to tag]:revision' \
          '--token=[Hugging Face access token]:token' \
          '-y[do not ask for confirmation]' \
          '1:repo_id' \
          '2:tag' && ret=0
        ;;
      (whoami|logout|env|version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--token=[Hugging Face access token]:token' && ret=0
        ;;
    esac
    ;;
esac

return ret
