#compdef otbcli_VectorClassifier
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_VectorClassifier.html
# Orfeo ToolBox: classify vector data using a trained model

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input vector data file to classify]:vector:_files' \
  '-instat[XML file with mean and stddev for normalization]:file:_files' \
  '-model[model file from TrainVectorClassifier]:model:_files' \
  '-cfield[field name for predicted class labels]:name:' \
  '-feat[field names to use as classification features]:names:' \
  '-confmap[enable confidence map output]:bool:(true false)' \
  '-out[output vector data file]:output:_files' \
  '*::arg:_files' && ret=0

return ret
