#compdef analyze
# Documentation: https://github.com/hunspell/hunspell
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:affix file:_files -g "*.aff"' \
  '2:dictionary file:_files -g "*.dic"' \
  '3:file of words to check:_files' && ret=0

return ret
