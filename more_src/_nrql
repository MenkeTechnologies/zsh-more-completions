#compdef nrql
# _nrql — New Relic nrql query CLI for executing New Relic Query Language statements against NRDB returning JSON/table/csv results selecting timeseries facets buckets percentiles histograms apdex from spans transactions logs (newrelic team, Python); argparse
# upstream: https://github.com/newrelic/nrql-cli

_nrql() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-a+[account id]:n:' \
        '--account-id=+[account id]:n:' \
        '-k+[user api key]:str:' \
        '--api-key=+[user api key]:str:' \
        '-r+[region]:r:(US EU Staging)' \
        '--region=+[region]:r:(US EU Staging)' \
        '-o+[output format]:f:(table json csv jsonl yaml plain)' \
        '--output=+[output format]:f:(table json csv jsonl yaml plain)' \
        '-f+[file with NRQL]:file:_files -g "*.nrql *.txt *.sql"' \
        '--file=+[file with NRQL]:file:_files -g "*.nrql *.txt *.sql"' \
        '-e+[NRQL string]:str:' \
        '--query=+[NRQL string]:str:' \
        '-t+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '--metadata[show metadata]' \
        '--explain[explain]' \
        '--watch[watch mode]' \
        '--interval=+[seconds]:n:' \
        '--limit=+[N]:n:' \
        '--max-results=+[N]:n:' \
        '--no-color[no color]' \
        '*:NRQL query:'
}

_nrql "$@"
