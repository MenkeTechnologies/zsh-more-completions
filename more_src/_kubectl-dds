#compdef kubectl-dds
# Documentation: https://github.com/aws-containers/kubectl-detector-for-docker-socket
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-dds (aws-containers): detect workloads mounting docker.sock.
# Runs with no arguments to scan all namespaces.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--namespace=[limit scanning to a specific namespace]:namespace:' \
  '(-f --filename)'{-f+,--filename=}'[scan manifest files or folders recursively]:path:_files' \
  '--verbose=[verbose output log level (1-10)]:level:' \
  '--exit-with-error[exit 1 if docker.sock volumes detected]' \
  '*:args:_default'
