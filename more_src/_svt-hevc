#compdef SvtHevcEncApp svt-hevc svt-hevc-enc
# _svt-hevc — Scalable Video Technology for HEVC encoder (OpenVisualCloud/SVT-HEVC)
# upstream: https://github.com/OpenVisualCloud/SVT-HEVC
# Flags from Source/App/EbAppConfig.c (custom token table).

_svt-hevc() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '-nch+[channel/encoder count]:n:' \
        '-c+[config file]:file:_files -g "*.cfg"' \
        '-i+[input YUV file]:file:_files' \
        '-b+[output HEVC bitstream]:file:_files -g "*.(hevc|265|bin)"' \
        '-o+[output reconstructed YUV]:file:_files' \
        '-errlog+[error log file]:file:_files' \
        '-stat-file+[statistics file]:file:_files' \
        '-qp-file+[per-frame QP file]:file:_files' \
        '-segment-ov-file+[segment override file]:file:_files' \
        '-w+[input width]:px:' \
        '-h+[input height]:px:' \
        '-n+[number of pictures to encode]:n:' \
        '-nb+[number of buffered input pictures]:n:' \
        '-base-layer-switch-mode+[base layer switching mode]:n:' \
        '-q+[QP value]:qp:' \
        '-use-q-file+[use QP file]:bool:(0 1)' \
        '-tile_row_cnt+[tile row count]:n:' \
        '-tile_col_cnt+[tile column count]:n:' \
        '-tile_slice_mode+[per-tile slicing mode]:n:' \
        '-tune+[tune]:tune:(sq oq vmaf)' \
        '-fps+[framerate]:fps:' \
        '-fps-num+[framerate numerator]:n:' \
        '-fps-denom+[framerate denominator]:n:' \
        '-bit-depth+[encoder bit depth]:bits:(8 10)' \
        '-color-format+[chroma format]:fmt:(0 1 2 3)' \
        '-compressed-ten-bit-format+[compressed 10-bit input]:bool:(0 1)' \
        '-encMode+[encoder mode 0-12]:n:' \
        '-hierarchical-levels+[hierarchical level]:n:(0 1 2 3 4 5)' \
        '-pred-struct+[prediction structure]:n:(0 1 2)' \
        '-intra-period+[intra period]:n:' \
        '-profile+[HEVC profile]:n:(1 2 3)' \
        '-tier+[HEVC tier]:n:(0 1)' \
        '-level+[HEVC level]:lvl:' \
        '-interlaced-video+[interlaced input]:bool:(0 1)' \
        '-separate-fields+[separate fields]:bool:(0 1)' \
        '-irefresh-type+[intra-refresh type]:n:(0 1 2)' \
        '-dlf+[deblocking loop filter]:bool:(0 1)' \
        '-sao+[SAO]:bool:(0 1)' \
        '-use-default-me-hme+[use default ME/HME]:bool:(0 1)' \
        '-hme+[enable HME]:bool:(0 1)' \
        '-search-w+[motion-search width]:n:' \
        '-search-h+[motion-search height]:n:' \
        '-constrd-intra+[constrained intra]:bool:(0 1)' \
        '-sharp+[sharpness improvement]:n:' \
        '-brr+[bitrate reduction]:n:' \
        '-vid-info+[VUI info]:bool:(0 1)' \
        '-hdr+[HDR input]:bool:(0 1)' \
        '-hrd+[enable HRD]:bool:(0 1)' \
        '-rc+[rate-control mode]:mode:(0 1 2 3)' \
        '-tbr+[target bitrate (bps)]:n:' \
        '-vbv-maxrate+[VBV maxrate]:n:' \
        '-vbv-bufsize+[VBV buffer size]:n:' \
        '-vbv-init+[VBV init level (%)]:n:' \
        '-min-qp+[minimum QP]:n:' \
        '-max-qp+[maximum QP]:n:' \
        '-scd+[scene-change detection]:bool:(0 1)' \
        '-lad+[lookahead distance]:n:' \
        '-rt+[real-time mode]:bool:(0 1)' \
        '-pbuff+[picture buffer count]:n:' \
        '-tpic+[total pictures]:n:' \
        '-fpsinvps+[FPS in VPS]:bool:(0 1)' \
        '-recovery-point+[recovery-point SEI]:bool:(0 1)' \
        '-inj+[buffered input injection]:bool:(0 1)' \
        '-inj-frm-rt+[injection frame rate]:fps:' \
        '-ua-delm+[unit access delimiter]:bool:(0 1)' \
        '-reg-user-data+[registered user-data SEI]:file:_files' \
        '-unreg-user-data+[unregistered user-data SEI]:file:_files' \
        '-master-display+[master display SEI]:str:' \
        '-use-master-display+[enable master display SEI]:bool:(0 1)' \
        '-max-cll+[max content light level]:n:' \
        '-max-fall+[max frame average light level]:n:' \
        '-dolby-vision-profile+[Dolby Vision profile]:n:' \
        '-dolby-vision-rpu+[Dolby Vision RPU file]:file:_files' \
        '-nalu-file+[NALU insertion file]:file:_files' \
        '-speed-ctrl+[speed control]:bool:(0 1)'
}

_svt-hevc "$@"
