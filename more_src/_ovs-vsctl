#compdef ovs-vsctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize the database'
  'show:show overview of database'
  'emer-reset:reset OVSDB to a known state'
  'add-br:add a bridge'
  'del-br:delete a bridge'
  'list-br:list bridges'
  'br-exists:test bridge existence'
  'br-to-vlan:print fake-bridge VLAN tag'
  'br-to-parent:print parent of fake bridge'
  'br-set-external-id:set bridge external id'
  'br-get-external-id:get bridge external id'
  'list-ports:list ports on a bridge'
  'add-port:add a port'
  'del-port:delete a port'
  'port-to-br:print bridge containing port'
  'add-bond:add a bond'
  'add-bond-iface:add an interface to a bond'
  'del-bond-iface:remove an interface from a bond'
  'list-ifaces:list interfaces on a bridge'
  'iface-to-br:print bridge containing interface'
  'add-zone-tp:add conntrack zone timeout policy'
  'del-zone-tp:delete conntrack zone timeout policy'
  'list-zone-tp:list conntrack zone timeout policies'
  'set-zone-limit:set conntrack zone limit'
  'del-zone-limit:delete conntrack zone limit'
  'list-zone-limits:list conntrack zone limits'
  'list-dp-cap:list datapath capabilities'
  'get-controller:get OpenFlow controllers'
  'del-controller:delete OpenFlow controllers'
  'set-controller:set OpenFlow controllers'
  'get-fail-mode:get controller fail mode'
  'del-fail-mode:delete controller fail mode'
  'set-fail-mode:set controller fail mode'
  'get-manager:get OVSDB managers'
  'del-manager:delete OVSDB managers'
  'set-manager:set OVSDB managers'
  'get-ssl:get SSL configuration'
  'del-ssl:delete SSL configuration'
  'set-ssl:set SSL configuration'
  'add-aa-mapping:add Auto-Attach mapping'
  'del-aa-mapping:delete Auto-Attach mapping'
  'get-aa-mapping:get Auto-Attach mapping'
  'list:list rows in a table'
  'find:find rows matching conditions'
  'get:get column values'
  'set:set column values'
  'add:add to a column value'
  'remove:remove from a column value'
  'clear:clear a column value'
  'create:create a new row'
  'destroy:destroy rows'
  'wait-until:wait for condition'
  'comment:add a comment'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--db=[OVSDB connection]:url:' \
  '--no-wait[do not wait for ovs-vswitchd]' \
  '--no-syslog[do not log to syslog]' \
  '--oneline[print output on a single line]' \
  '--dry-run[do not commit changes]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout in seconds]:secs:' \
  '--retry[retry on transient errors]' \
  '(-f --format)'{-f,--format=}'[output format]:format:(table list html csv json)' \
  '(-d --data)'{-d,--data=}'[data formatting]:format:(string bare json)' \
  '--no-headings[no column headings]' \
  '--pretty[pretty-print JSON]' \
  '--bare[bare output]' \
  '--max-column-width=[max column width]:n:' \
  '--may-exist[succeed if object exists]' \
  '--if-exists[succeed if object missing]' \
  '--real[show only real bridges]' \
  '--fake[show only fake bridges]' \
  '--with-iface[del-port with interface]' \
  '--fake-iface[create fake interface]' \
  '--bootstrap[trust unknown CA on first connect]' \
  '--filter=[show filter]:filter:' \
  '*--columns=[columns to show]:cols:' \
  '--id=[record id]:id:' \
  '--all[apply to all]' \
  '(-p --private-key)'{-p,--private-key=}'[private key file]:file:_files' \
  '(-c --certificate)'{-c,--certificate=}'[certificate file]:file:_files' \
  '(-C --ca-cert)'{-C,--ca-cert=}'[CA cert file]:file:_files' \
  '--ssl-server-name=[SSL server name]:name:' \
  '--bootstrap-ca-cert=[bootstrap CA cert]:file:_files' \
  '--peer-ca-cert=[peer CA cert]:file:_files' \
  '(-v --verbose)'{-v,--verbose=}'[verbosity spec]:spec:' \
  '--log-file=[log file]:file:_files' \
  '--syslog-target=[syslog target]:target:' \
  '--syslog-method=[syslog method]:method:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovs-vsctl subcommand' subcommands && ret=0
    ;;
esac

return ret
