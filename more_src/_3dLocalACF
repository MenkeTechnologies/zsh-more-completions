#compdef 3dLocalACF
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLocalACF.html
# Compute local (voxelwise) ACF spatial autocorrelation function parameters

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-prefix[output dataset prefix]:prefix:' \
  '-input[input time series dataset]:dataset:_files' \
  '-nbhd[neighborhood for local ACF estimation]:nbhd:' \
  '-mask[apply a brain mask]:dataset:_files' \
  '-automask[generate mask automatically from input]' \
  '*:dataset:_files' && ret=0

return ret
