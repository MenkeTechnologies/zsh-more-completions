#compdef logcli
# Documentation: https://grafana.com/docs/loki/latest/query/logcli/getting-started/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for logcli - Grafana Loki CLI for querying logs

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'query:run a LogQL query'
  'instant-query:run an instant LogQL query'
  'labels:find values for a given label'
  'series:run a series query'
  'detected-fields:run a detected fields query'
  'stats:run a stats query'
  'volume:run a volume query'
  'fmt:format LogQL queries'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '--addr=[server address]:url:' \
  '--username=[username for HTTP basic auth]:username:' \
  '--password=[password for HTTP basic auth]:password:' \
  '--ca-cert=[path to CA certificate]:file:_files' \
  '--tls-skip-verify[skip TLS certificate verification]' \
  '--cert=[path to client certificate]:file:_files' \
  '--key=[path to client certificate key]:file:_files' \
  '--org-id=[org ID header to send]:id:' \
  '--query-tags=[X-Query-Tags HTTP header]:tags:' \
  '--bearer-token=[bearer token]:token:' \
  '--bearer-token-file=[file containing bearer token]:file:_files' \
  '--retries=[number of retries]:count:' \
  '--min-backoff=[minimum retry backoff]:duration:' \
  '--max-backoff=[maximum retry backoff]:duration:' \
  '--proxy-url=[proxy URL]:url:' \
  '--compress[request data compression]' \
  '--stdin[take LogQL queries from stdin]' \
  '--stats[show query statistics]' \
  '(-q --quiet)'{-q,--quiet}'[suppress query metadata]' \
  '(-o --output)'{-o,--output}'=[output mode]:mode:(default raw jsonl)' \
  '(-z --timezone)'{-z,--timezone}'=[timezone for timestamps]:tz:(Local UTC)' \
  '--output-timestamp-format=[timestamp format]:format:' \
  '--help[show help]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'logcli subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (query)
        _arguments \
          '--limit=[max number of entries to return]:limit:' \
          '--since=[lookback window]:duration:' \
          '--from=[start time]:time:' \
          '--to=[end time]:time:' \
          '--step=[query resolution step width]:duration:' \
          '--interval=[query interval]:duration:' \
          '--batch=[query batch size]:size:' \
          '--forward[scan forwards through logs]' \
          '--no-labels[do not print any labels]' \
          '--exclude-label=[exclude labels by name]:label:' \
          '--include-label=[include labels by name]:label:' \
          '--labels-length=[fixed padding for label output]:length:' \
          '--store-config=[execute query against a configured storage]:file:_files' \
          '--colored-output[show output with colored labels]' \
          '(-t --tail)'{-t,--tail}'[tail the logs]' \
          '(-f --follow)'{-f,--follow}'[alias for --tail]' \
          '--delay-for=[delay in tailing in seconds to accumulate logs]:seconds:' \
          '--part-path-prefix=[prefix for per-response output files]:prefix:' \
          '1:LogQL query:' && ret=0
        ;;
      (instant-query)
        _arguments \
          '--limit=[max number of entries]:limit:' \
          '--now=[time for instant query]:time:' \
          '1:LogQL query:' && ret=0
        ;;
      (labels)
        _arguments \
          '--since=[lookback window]:duration:' \
          '--from=[start time]:time:' \
          '--to=[end time]:time:' \
          '1:label name:' && ret=0
        ;;
      (series)
        _arguments \
          '--since=[lookback window]:duration:' \
          '--from=[start time]:time:' \
          '--to=[end time]:time:' \
          '--analyze-labels[show cardinality summary]' \
          '--match=[series selector]:selector:' && ret=0
        ;;
    esac
    ;;
esac

return ret
