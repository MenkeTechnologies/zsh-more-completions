#compdef condor_check_password
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_check_password.html
# check the security of the HTCondor pool password file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a usage reminder]' \
  '--truncate[truncate insecure keys to pre-8.9.12 behavior]' && ret=0

return ret
