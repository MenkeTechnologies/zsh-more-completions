#compdef hdifftopam
# Documentation: man hdifftopam (Netpbm)
# Source: reconstruct a PAM image from a horizontal-difference image (inverse of pamtohdiff).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-pnm[output PNM instead of PAM]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:hdiff pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
