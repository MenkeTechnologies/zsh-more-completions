#compdef setsebool
# Source: https://github.com/OKay2c/zsh-selinux-completions/blob/1d39fd873d99b9eb38b78aa85c43010adcf7fcdb/_setsebool
# Repository: OKay2c/zsh-selinux-completions (_setsebool)

# Zsh completion for setsebool

_setsebool_bools() {
  [[ -z $words[CURRENT] ]] && PREFIX+='-'
  local -a bools
  bools=( ${(f)"$(getsebool -a 2>/dev/null | awk '{print $1}')"} )
  (( ${#bools} )) && _describe 'SELinux boolean' bools || _message 'SELinux boolean name'
}

_setsebool() {
  [[ -z $words[CURRENT] ]] && PREFIX+='-'
  _arguments -s -S \
    '(-P --persistent)'{-P,--persistent}'[make the change permanent across reboots]' \
    '(-N --noreload)'{-N,--noreload}'[do not reload policy]' \
    '(-V --verbose)'{-V,--verbose}'[verbose output]' \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '*:boolean and value:->boolval'

  if [[ $state == boolval ]]; then
    case $(( ${#words} % 2 )) in
      # Odd position after flags: boolean name
      0) _setsebool_bools ;;
      # Even position: value
      1) _values 'boolean value' on off 1 0 true false ;;
    esac
  fi
}

_setsebool "$@"
