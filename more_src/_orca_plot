#compdef orca_plot
# Documentation: https://www.faccts.de/docs/orca/6.0/manual/contents/detailed/utilities.html
# ORCA utility to generate orbital/density plots (cube files) from a .gbw file

local ret=1

_arguments -s -S \
  '-i[run in interactive menu mode]' \
  '-m+[set maximum memory in MB]:memory_MB:' \
  '*:gbw file:_files -g "*.gbw"' && ret=0

return ret
