#compdef evalite
# =============================================================================
# evalite — Evaluate your LLM-powered apps with TypeScript.  Created by
#           Matt Pocock (the creator of Total TypeScript), evalite is a
#           Vitest-integrated framework for systematically evaluating LLM
#           outputs against ground truth.  It supports defining evals as
#           TypeScript test files, running them in CI, exporting static
#           HTML reports, and watching files for development iteration.
#
# Author:  Matt Pocock (Total TypeScript) and contributors
# Source:  https://github.com/mattpocock/evalite
# CLI:     packages/evalite/src/command.ts (uses @stricli/core)
# Library: @stricli/core (bloomberg/stricli)
#          ("Build complex CLIs with type safety and no dependencies")
# License: MIT
# Status:  Active development — 1,580+ stars, used in CI by AI startups
#          and LLM-app teams; tightly integrated with Vitest's test runner.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 24
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 24TH TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 23 to 24 documented libraries (Stricli via evalite).  New leaderboard:
# Rust=24, Go=24, TypeScript-Node=24 — THREE-WAY TIE RESTORED at the top.
# Taxonomy now spans 205 cross-language CLI library variants across 47
# documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS @stricli/core AND WHY IS IT A DISTINCT 24TH TS-NODE CLI LIBRARY?
#
# @stricli/core (https://github.com/bloomberg/stricli, 1,050+ stars) is
# Bloomberg's command-line parsing library for TypeScript.  It is the SECOND
# documented "Bloomberg open-source TypeScript CLI library" in the corpus
# (the FIRST being any prior Bloomberg tooling — Bloomberg has open-sourced
# extensive internal TS/JS infrastructure including BSL, the Bloomberg
# Software License, ChrisCommands, and the BLP/JS terminal SDK).
#
# Stricli's defining characteristics are:
#
#   1. ZERO RUNTIME DEPENDENCIES — Stricli's `package.json` `dependencies`
#      block is empty.  This is rare for a TypeScript CLI library; most
#      modern TS CLI libraries pull in chalk, picocolors, ansi-regex,
#      string-width, or similar.  Stricli implements its own formatting,
#      argv parsing, and completion logic without any transitive runtime
#      cost.
#   2. STRONG STATIC TYPE SAFETY via TS GENERIC INFERENCE — every flag
#      declaration carries a `kind` discriminator (`"parsed" | "boolean" |
#      "enum" | "counter"`) that drives type inference for the flag's
#      runtime type.  The function passed to `buildCommand({ func })` is
#      typed AGAINST the parameters declaration, so referencing
#      `flags.unknownProp` is a compile error.
#   3. APPLICATION-ROUTES-COMMAND HIERARCHY — Stricli organizes CLI
#      structure into three levels:
#        a. Commands (`buildCommand`) — leaf nodes with parameters + func
#        b. Routes (`buildRouteMap`) — internal nodes mapping names to
#           commands or to sub-route-maps (recursive)
#        c. Applications (`buildApplication`) — top-level wrapper with
#           name + version + bin metadata
#      This hierarchy supports arbitrarily nested subcommands like
#      `mytool service create --name x` without manual recursion.
#   4. NATIVE BUILD-TIME-FRIENDLY DESIGN — Stricli's API is structured for
#      tree-shaking.  Unused command branches can be eliminated by modern
#      bundlers (esbuild, rollup, swc) because Stricli avoids dynamic
#      imports and `require()` calls in the spec definitions.  Most other
#      TS CLI libraries pull in their full code surface at load time.
#   5. SEPARATE @stricli/auto-complete PACKAGE — shell completion is NOT
#      bundled into core; it's a separate npm package that provides
#      `buildInstallCommand` and `buildUninstallCommand` helpers.  Users
#      opt in to completion by adding `install` and `uninstall` routes to
#      their route map.  The install command WRITES shell completion
#      scripts to the user's bash/zsh/fish completion directories.
#   6. PARAMETERS-AS-DATA — the parameters object is plain data, not
#      a builder chain.  Compare to commander.js where you write
#      `.option('-v, --verbose', 'verbose output')` (method chain) vs
#      Stricli where you write `{ verbose: { kind: 'boolean', brief:
#      'verbose output' } }` (declarative object).  This is similar to
#      Kong's struct tags in Go (R465) — both use a STATIC DATA STRUCTURE
#      to declare the CLI rather than a fluent builder.
#
# THE Stricli API SURFACE (verbatim from @stricli/core exports)
#
#   import {
#       buildCommand,        // leaf command with parameters + handler
#       buildRouteMap,       // internal node mapping name→command/route
#       buildApplication,    // top-level wrapper with name + version
#       run,                 // execute the application against argv
#       proposeCompletions,  // generate completions for current cursor
#   } from "@stricli/core";
#
# Command shape (verbatim from evalite source):
#
#   const runOnce = buildCommand({
#       parameters: {
#           positional: {
#               kind: "tuple",
#               parameters: [{ parse: String, brief: "path", optional: true }],
#           },
#           flags: {
#               threshold: {
#                   kind: "parsed",
#                   parse: parseFloat,
#                   brief: "Fails the process if score < threshold (0-100)",
#                   optional: true,
#               },
#               outputPath: {
#                   kind: "parsed",
#                   parse: String,
#                   brief: "Path to write test results in JSON",
#                   optional: true,
#               },
#               hideTable: {
#                   kind: "boolean",
#                   brief: "Hides the detailed table output in the CLI",
#                   optional: true,
#               },
#           },
#       },
#       func: async (flags, path) => commands.runOnceAtPath({ path, ... }),
#       docs: { brief: "Run evals once and exit" },
#   });
#
# Route map shape:
#
#   const routes = buildRouteMap({
#       routes: {
#           run: runOnce,
#           serve,
#           watch,
#           export: exportCmd,
#           install: buildInstallCommand("evalite",
#               { bash: "__evalite_bash_complete" }),
#           uninstall: buildUninstallCommand("evalite", { bash: true }),
#       },
#       defaultCommand: "run",
#       docs: {
#           brief: "",
#           hideRoute: { install: true, uninstall: true },
#       },
#   });
#
# Application shape:
#
#   return buildApplication(routes, {
#       name: packageJson.name,
#       versionInfo: { currentVersion: packageJson.version },
#   });
#
# Flag KIND vocabulary:
#   "parsed"  — value-taking flag with a parse function (e.g., parseFloat)
#   "boolean" — flag without value; presence sets to true
#   "enum"    — flag restricted to enumerated string values
#   "counter" — flag counted by occurrences (e.g., -v -v -v for verbosity)
#
# Positional KIND vocabulary:
#   "tuple"    — fixed sequence of positional arguments
#   "array"    — variadic list of positional arguments
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander.js                — fluent builder, method chains
#                                   (.option(), .command(), .action())
#   * yargs                       — chainable builder with subcommand
#                                   handlers; lots of inference magic
#   * minimist                    — pure argv parser, no help/usage gen
#   * arg (vercel/arg)            — small typed parser, no subcommands
#   * meow                        — opinionated CLI helper; wraps yargs
#   * mri                         — minimist successor by lukeed
#   * caporal                     — declarative, programmatic, plugin
#   * nopt                        — npm's classic CLI parser
#   * cmd-ts                      — type-safe TS CLI builder
#   * clipanion                   — class-based with decorators (Yarn 2)
#   * citty (UnJS)                — minimal, defineCommand({ ... })
#   * cac                         — chainable + typed; popular
#   * sade                        — small + opinionated by lukeed
#   * type-flag                   — type inference flag parser
#   * dthree/vorpal (R442)        — REPL-style interactive CLI
#   * gluegun                     — full toolkit; opinionated framework
#   * @stricli/core (THIS)        — data-driven, zero deps, type-safe,
#                                   build-time friendly, separate
#                                   auto-complete package
#
# Stricli is the closest TS-Node analog to Kong (R465 Go) and clap-derive
# (R275 Rust) — all three use STATIC DATA STRUCTURES (struct tags in Go,
# derive macros in Rust, plain JavaScript objects in TS) to declare the
# CLI rather than a fluent builder.  But Stricli is unique in:
#   * being the ONLY zero-dependency declarative TS CLI library
#   * supporting RECURSIVE ROUTE MAPS for arbitrarily nested subcommands
#   * separating auto-complete into a sibling package for opt-in usage
#
# REAL-WORLD @stricli/core USERS:
#
#   * mattpocock/evalite — LLM eval framework (THIS completion)
#   * getsentry/cli — Sentry's TS wrapper around their Rust binary
#   * HipsterBrown/xs-dev — XS embedded JS devtool
#   * saas-js/saas-ui — SaaS UI CLI scaffolder
#   * divyenduz/plv8ify — PostgreSQL PLV8 function builder
#   * majiayu000/claude-skill-registry — Claude Code skill installer
#   * Unstructured-IO/unstructured-js-client — Unstructured.io client
#   * YoYoGames/gm-cli — GameMaker Studio CLI
#
# -----------------------------------------------------------------------------
# EVALITE'S CLI SURFACE (verbatim from packages/evalite/src/command.ts)
# -----------------------------------------------------------------------------
#
# USAGE:
#   evalite [run | serve | watch | export] [<path>] [flags]
#
# Subcommands (defaultCommand is "run"):
#   run                     Run evals once and exit (default if no subcmd)
#   serve                   Run evals once and serve interactive UI
#   watch                   Watch evals for file changes and rerun
#   export                  Export static UI bundle for CI artifacts
#   install                 (hidden) Install shell completion scripts
#   uninstall               (hidden) Uninstall shell completion scripts
#
# Common flags (run, serve, watch):
#   --threshold <float>     Fail process if score < threshold (0-100, default 100)
#   --outputPath <path>     Write test results as JSON after evaluation
#                           (NOT supported in watch mode)
#   --hideTable             Hide detailed table output in CLI
#
# Common positional:
#   <path>                  Optional path to specific eval file or directory
#
# Export subcommand flags:
#   --output <dir>          Output directory (default ./evalite-export)
#   --runId <int>           Specific run ID (default latest)
#   --basePath <path>       Base path for hosting at non-root URL
#                           (must start with /, default /)
#
# =============================================================================

_evalite() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands

    subcommands=(
        'run:run evals once and exit (default)'
        'serve:run evals once and serve interactive UI'
        'watch:watch evals for file changes and rerun'
        'export:export static UI bundle for CI artifacts'
    )

    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _alternative \
                'subcommands:subcommand:(($subcommands))' \
                'eval-path:eval path:_files' \
                && ret=0
            ;;
        (args)
            case $line[1] in
                (run|serve|watch)
                    _arguments \
                        '--threshold[fail if score < N (0-100)]:threshold:' \
                        '--outputPath[write results as JSON to path (not in watch)]:output:_files' \
                        '--hideTable[hide detailed table output in CLI]' \
                        '*:eval path:_files' \
                        && ret=0
                    ;;
                (export)
                    _arguments \
                        '--output[output directory]:dir:_directories' \
                        '--runId[specific run ID]:run id:' \
                        '--basePath[base path for hosting]:path:' \
                        && ret=0
                    ;;
                (*)
                    _arguments \
                        '--threshold[fail if score < N (0-100)]:threshold:' \
                        '--outputPath[write results as JSON to path]:output:_files' \
                        '--hideTable[hide detailed table output in CLI]' \
                        '*:eval path:_files' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_evalite "$@"
