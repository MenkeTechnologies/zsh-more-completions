#compdef wordmatch
# Documentation: https://man.archlinux.org/search?q=wordmatch
# Reference accessed: 2026-05-16

# EMBOSS wordmatch: find exact word matches between two sequences
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output filename]:file:_files' \
  '-asequence=[first sequence]:file:_files' \
  '-bsequence=[second sequence]:file:_files' \
  '-wordsize=[word size]:size:' \
  '-logfile=[log file]:file:_files' \
  '-aoutfeat=[feature output for a]:file:_files' \
  '-boutfeat=[feature output for b]:file:_files' \
  '*:sequence:_files' && ret=0

return ret
