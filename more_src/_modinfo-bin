#compdef modinfo
# _modinfo-bin — show information about a kernel module (kmod); print description, license, parm, alias info
# upstream: https://github.com/kmod-project/kmod

_modinfo-bin() {
    _arguments \
        '(-a --author)'{-a,--author}'[show author]' \
        '(-d --description)'{-d,--description}'[show description]' \
        '(-l --license)'{-l,--license}'[show license]' \
        '(-p --parameters)'{-p,--parameters}'[show parameters]' \
        '(-n --filename)'{-n,--filename}'[show filename]' \
        '(-0 --null)'{-0,--null}'[null-separated fields]' \
        '(-F --field)'{-F,--field}'+[only this field]:field:(author description license parm alias depends intree retpoline name vermagic srcversion sig_id signer sig_key sig_hashalgo signature)' \
        '(-k --set-version)'{-k,--set-version}'+[kernel version]:ver:' \
        '(-b --basedir)'{-b,--basedir}'+[base dir]:dir:_files -/' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:module:'
}

_modinfo-bin "$@"
