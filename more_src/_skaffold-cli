#compdef skaffold-cli
# Documentation: https://skaffold.dev/docs/references/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (same binary as skaffold).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apply:apply hydrated manifests to cluster'
  'build:build artifacts'
  'completion:generate shell completion'
  'config:configuration management'
  'credits:show open source credits'
  'debug:run app in debug mode'
  'delete:delete resources from cluster'
  'deploy:deploy artifacts to cluster'
  'dev:run continuous build/deploy'
  'diagnose:run diagnostics'
  'exec:execute custom action'
  'filter:filter manifests with skaffold'
  'find-configs:find skaffold config files'
  'fix:fix skaffold.yaml schema versions'
  'init:initialize skaffold.yaml'
  'inspect:inspect skaffold config'
  'lint:lint skaffold.yaml'
  'options:list global options'
  'render:render manifests with image refs'
  'run:run a one-off pipeline'
  'schema:print JSON schema'
  'survey:open user survey'
  'test:run tests'
  'verify:run verification tests against deployed app'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--color=[color code]:n:(0 30 31 32 33 34 35 36 37)' \
  '*--detect-minikube=[detect minikube]:b:(true false)' \
  '*--interactive=[interactive]:b:(true false)' \
  '*--keep-running-on-failure=[keep running on failure]:b:(true false)' \
  '*--metrics-file=[metrics file]:file:_files' \
  '*--update-check=[check for updates]:b:(true false)' \
  '*--user=[user agent]:u:' \
  '*--verbosity=[log level]:l:(panic fatal error warning info debug trace)' \
  '*-v+[log level]:l:(panic fatal error warning info debug trace)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'skaffold command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dev|run|debug)
        _arguments \
          '(-f --filename)'{-f+,--filename=}'[skaffold file]:file:_files -g "*.yaml *.yml"' \
          '(-d --default-repo)'{-d+,--default-repo=}'[default repo]:r:' \
          '(-l --label)*'{-l+,--label=}'[label]:l:' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
          '(-p --profile)*'{-p+,--profile=}'[profile]:p:' \
          '(-t --tag)'{-t+,--tag=}'[tag override]:t:' \
          '(--cache-artifacts)--cache-artifacts=[cache artifacts]:b:(true false)' \
          '(--cache-file)--cache-file=[cache file]:file:_files' \
          '(--cleanup)--cleanup=[cleanup]:b:(true false)' \
          '(--port-forward)--port-forward=[port forward]:p:(user services debug pods off)' \
          '(--no-prune)--no-prune[no prune]' \
          '(--no-prune-children)--no-prune-children[no prune children]' \
          '(--render-only)--render-only[render only]' \
          '(--render-output)--render-output=[render output]:file:_files' \
          '(--skip-tests)--skip-tests[skip tests]' \
          '(--status-check)--status-check=[status check]:b:(true false)' \
          '(--tail)--tail=[tail logs]:b:(true false)' \
          '(--toot)--toot[boop on success]' \
          '(--trigger)--trigger=[trigger]:t:(polling notify manual)' \
          '(--watch-image)*--watch-image=[watch image]:img:' \
          '(--watch-poll-interval)--watch-poll-interval=[interval ms]:ms:' \
          '(--build-concurrency)--build-concurrency=[build concurrency]:n:' \
          '(--platform)*--platform=[platform]:p:' \
          '(--auto-build)--auto-build=[auto build]:b:(true false)' \
          '(--auto-deploy)--auto-deploy=[auto deploy]:b:(true false)' \
          '(--auto-sync)--auto-sync=[auto sync]:b:(true false)' \
          '(--mute-logs)*--mute-logs=[mute log phase]:p:' \
          '(--push)--push=[push images]:b:(true false)' \
          '(--remote-cache-dir)--remote-cache-dir=[remote cache]:dir:_files -/' \
          '(--cluster-type)--cluster-type=[cluster type]:t:' \
          '(--digest-source)--digest-source=[digest source]:s:(remote local none)' \
          '(--manifest-output)--manifest-output=[manifest file]:file:_files' \
          '(--rpc-port)--rpc-port=[gRPC port]:port:' \
          '(--rpc-http-port)--rpc-http-port=[HTTP port]:port:' \
          '(--enable-rpc)--enable-rpc=[enable RPC]:b:(true false)' \
          '(--event-log-file)--event-log-file=[event log]:file:_files' \
          '(--kube-context)--kube-context=[kube context]:c:' \
          '(--kubeconfig)--kubeconfig=[kubeconfig]:file:_files' \
          '*: :' && ret=0 ;;
      (build)
        _arguments \
          '(-f --filename)'{-f+,--filename=}'[skaffold file]:file:_files' \
          '(-b --build-image)*'{-b+,--build-image=}'[image to build]:img:' \
          '(-d --default-repo)'{-d+,--default-repo=}'[default repo]:r:' \
          '(-p --profile)*'{-p+,--profile=}'[profile]:p:' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(-o --output)'{-o+,--output=}'[output template]:t:' \
          '(--file-output)--file-output=[output file]:file:_files' \
          '(--cache-artifacts)--cache-artifacts=[cache artifacts]:b:(true false)' \
          '(--push)--push=[push images]:b:(true false)' \
          '(--platform)*--platform=[platform]:p:' \
          '*: :' && ret=0 ;;
      (deploy)
        _arguments \
          '(-f --filename)'{-f+,--filename=}'[skaffold file]:file:_files' \
          '(-a --build-artifacts)'{-a+,--build-artifacts=}'[build artifacts file]:file:_files -g "*.json"' \
          '(-i --images)*'{-i+,--images=}'[image]:img:' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
          '(-p --profile)*'{-p+,--profile=}'[profile]:p:' \
          '(--port-forward)--port-forward=[port forward]:p:(user services debug pods off)' \
          '(--status-check)--status-check=[status check]:b:(true false)' \
          '(--tail)--tail=[tail]:b:(true false)' \
          '(--cleanup)--cleanup=[cleanup]:b:(true false)' \
          '(--load-images)--load-images[load images]' \
          '*: :' && ret=0 ;;
      (delete)
        _arguments \
          '(-f --filename)'{-f+,--filename=}'[skaffold file]:file:_files' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
          '(-p --profile)*'{-p+,--profile=}'[profile]:p:' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '(-a --artifact)*'{-a+,--artifact=}'[artifact]:a:' \
          '(--analyze)--analyze[analyze project]' \
          '(--compose-file)--compose-file=[docker-compose file]:file:_files' \
          '(--default-kustomization)--default-kustomization=[default kustomization]:dir:_files -/' \
          '(--enable-jib-init)--enable-jib-init[enable jib init]' \
          '(--enable-buildpacks-init)--enable-buildpacks-init[enable buildpacks init]' \
          '(--enable-new-init-format)--enable-new-init-format[new init format]' \
          '(-f --filename)'{-f+,--filename=}'[skaffold file]:file:_files' \
          '(--force)--force[force]' \
          '(-k --kubernetes-manifest)*'{-k+,--kubernetes-manifest=}'[manifest]:file:_files' \
          '(--skip-build)--skip-build[skip build init]' \
          '(--skip-deploy)--skip-deploy[skip deploy init]' \
          '(--xx-default-repo)--xx-default-repo=[default repo]:r:' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(get list set unset)' \
          '*: :' && ret=0 ;;
      (inspect)
        _arguments \
          '1:subcommand:(build-env config-dependencies executions-environment modules profiles tests)' \
          '*: :' && ret=0 ;;
      (schema)
        _arguments \
          '1:subcommand:(get list)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
