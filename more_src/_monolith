#compdef monolith
# Documentation: https://github.com/Y2Z/monolith
# Reference accessed: 2026-05-19
# Verified: upstream src/main.rs flag definitions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --no-audio)'{-a,--no-audio}'[remove audio sources]' \
  '(-b --base-url)'{-b,--base-url}'[set custom base URL]:url' \
  '(-B --blacklist-domains)'{-B,--blacklist-domains}'[treat specified domains as blacklist]' \
  '(-c --no-css)'{-c,--no-css}'[remove CSS]' \
  '(-C --cookie-file)'{-C,--cookie-file}'[specify cookie file]:file:_files' \
  '(-d --domain)'{-d,--domain}'[specify domain for white/black-listing]:domain' \
  '(-e --ignore-errors)'{-e,--ignore-errors}'[ignore network errors]' \
  '(-E --encoding)'{-E,--encoding}'[enforce custom charset]:encoding' \
  '(-f --no-frames)'{-f,--no-frames}'[remove frames and iframes]' \
  '(-F --no-fonts)'{-F,--no-fonts}'[remove fonts]' \
  '(-i --no-images)'{-i,--no-images}'[remove images]' \
  '(-I --isolate)'{-I,--isolate}'[cut off document from the Internet]' \
  '(-j --no-js)'{-j,--no-js}'[remove JavaScript]' \
  '(-k --insecure)'{-k,--insecure}'[allow invalid X.509 certificates]' \
  '(-m --mhtml)'{-m,--mhtml}'[use MHTML as output format]' \
  '(-M --no-metadata)'{-M,--no-metadata}'[exclude timestamp and source info]' \
  '(-n --unwrap-noscript)'{-n,--unwrap-noscript}'[replace NOSCRIPT elements with their contents]' \
  '(-o --output)'{-o,--output}'[output file (- for STDOUT)]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress verbosity]' \
  '(-t --timeout)'{-t,--timeout}'[adjust network request timeout]:seconds' \
  '(-u --user-agent)'{-u,--user-agent}'[set custom User-Agent string]:agent' \
  '(-v --no-video)'{-v,--no-video}'[remove video sources]' \
  '1:URL or file:_files' && ret=0

return ret
