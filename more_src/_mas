#compdef mas

_mas_commands() {
  local -a commands=(
    'account:Print the Apple ID signed in to the Mac App Store'
    'home:Open app homepage in browser'
    'info:Display app information'
    'install:Install an application'
    'list:List installed applications'
    'lucky:Install the first search result'
    'open:Open app page in Mac App Store'
    'outdated:List pending updates'
    'purchase:Purchase and download a free app'
    'reset:Reset Mac App Store'
    'search:Search for applications'
    'signin:Sign in to the Mac App Store'
    'signout:Sign out of the Mac App Store'
    'uninstall:Uninstall an application'
    'upgrade:Upgrade outdated applications'
    'vendor:Open vendor homepage in browser'
    'version:Print version'
    'help:Show help'
  )
  _describe -t commands 'mas command' commands
}

_mas() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--version[Print version]' \
    '1:command:_mas_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        install|info|home|open|vendor|uninstall|purchase)
          _arguments \
            '(-f --force)'{-f,--force}'[Force operation]' \
            '*:app ID:'
          ;;
        search)
          _arguments \
            '(-p --price)'{-p,--price}'[Show price]' \
            '*:search term:'
          ;;
        lucky)
          _arguments \
            '(-f --force)'{-f,--force}'[Force install]' \
            '*:search term:'
          ;;
        upgrade)
          _arguments \
            '*:app ID (leave empty to upgrade all):'
          ;;
        signin)
          _arguments \
            '--dialog[Complete sign in with a GUI dialog]' \
            '1:Apple ID:'
          ;;
        list)
          _arguments
          ;;
      esac
      ;;
  esac
}

_mas "$@"
