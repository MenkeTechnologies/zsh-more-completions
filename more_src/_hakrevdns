#compdef hakrevdns
# _hakrevdns — Luke Stephens hakrevdns CLI for performing reverse DNS lookups on IP addresses concurrently using a configurable resolver wordlist with optional PTR record output JSON formatting (hakluke team, Go); flag
# upstream: https://github.com/hakluke/hakrevdns

_hakrevdns() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[resolver IP]:str:' \
        '--resolver=+[resolver IP]:str:' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-d[also include domain]' \
        '--domain[also include domain]' \
        '-j[JSON output]' \
        '--json[JSON output]' \
        '-i[IPv4 only]' \
        '--ipv4-only[IPv4 only]' \
        '-I[IPv6 only]' \
        '--ipv6-only[IPv6 only]' \
        '*:IP addresses:'
}

_hakrevdns "$@"
