#compdef kamaji
# Documentation: https://man.archlinux.org/search?q=kamaji
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(* -)'{-v,--version}'[show version]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--leader-elect[enable leader election]' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '1:subcommand: _default' \
  '*::manager flags: _default'
