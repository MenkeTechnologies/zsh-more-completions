#compdef triton-inference-server tritonserver
# Documentation: https://man.archlinux.org/search?q=triton-inference-server
# Reference accessed: 2026-05-16

# NVIDIA Triton Inference Server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--log-verbose=[verbose log level]:n:' \
  '--log-info=[info log level]:n:' \
  '--log-warning=[warning log level]:n:' \
  '--log-error=[error log level]:n:' \
  '--log-format=[log format]:fmt:(default ISO8601)' \
  '--log-file=[log file]:file:_files' \
  '--id=[server id]:id:' \
  '--model-store=[model repository directory]:dir:_files -/' \
  '--model-repository=[model repository directory]:dir:_files -/' \
  '--exit-on-error=[exit on error]:bool:(true false)' \
  '--strict-readiness=[strict readiness]:bool:(true false)' \
  '--allow-http=[allow HTTP]:bool:(true false)' \
  '--http-port=[HTTP port]:port:' \
  '--http-thread-count=[HTTP thread count]:n:' \
  '--allow-grpc=[allow GRPC]:bool:(true false)' \
  '--grpc-port=[GRPC port]:port:' \
  '--allow-metrics=[allow metrics]:bool:(true false)' \
  '--metrics-port=[metrics port]:port:' \
  '--allow-sagemaker=[allow SageMaker]:bool:(true false)' \
  '--allow-vertex-ai=[allow Vertex AI]:bool:(true false)' \
  '--allow-cpu-metrics=[allow CPU metrics]:bool:(true false)' \
  '--allow-gpu-metrics=[allow GPU metrics]:bool:(true false)' \
  '--metrics-interval-ms=[metrics interval ms]:ms:' \
  '--model-control-mode=[model control mode]:mode:(none explicit poll)' \
  '--repository-poll-secs=[repository poll secs]:s:' \
  '--load-model=[load model]:name:' \
  '--rate-limit=[rate-limit policy]:policy:(off execution_count)' \
  '--rate-limit-resource=[rate-limit resource]:resource:' \
  '--response-cache-byte-size=[response cache bytes]:n:' \
  '--cache-config=[cache config]:cfg:' \
  '--cache-dir=[cache directory]:dir:_files -/' \
  '--min-supported-compute-capability=[min compute capability]:cap:' \
  '--pinned-memory-pool-byte-size=[pinned mem MB]:bytes:' \
  '--cuda-memory-pool-byte-size=[CUDA mem MB]:bytes:' \
  '--cuda-virtual-address-size=[CUDA virtual mem size]:size:' \
  '--backend-config=[backend config]:cfg:' \
  '--host-policy=[host policy]:policy:' \
  '--backend-directory=[backend directory]:dir:_files -/' \
  '--repoagent-directory=[repoagent directory]:dir:_files -/' \
  '--buffer-manager-thread-count=[buffer manager threads]:n:' \
  '--model-load-thread-count=[model load threads]:n:' \
  '--exit-timeout-secs=[exit timeout seconds]:s:' \
  '*::triton-inference-server args:_files' && ret=0
return ret
