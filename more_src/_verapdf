#compdef verapdf
# Documentation: https://docs.verapdf.org/cli/validation/
# verapdf - PDF/A and PDF/UA validation command-line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --flavour)'{-f,--flavour}'=[validation profile (1b, 2a, ua1, 0=auto)]:flavour' \
  '(-df --defaultflavour)'{-df,--defaultflavour}'=[default profile when metadata unavailable]:flavour' \
  '(-p --profile)'{-p,--profile}'=[validate against custom profile file]:file:_files' \
  '--format=[output format]:format:(text raw html json)' \
  '--maxfailures=[stop after specified failure count]:count' \
  '--maxfailuresdisplayed=[limit failures shown per rule]:count' \
  '(--success --passed)'{--success,--passed}'[include successful checks in reports]' \
  '--addlogs[include console logs in output]' \
  '--loglevel=[log verbosity 0-4]:level' \
  '(-v --verbose)'{-v,--verbose}'[show validation errors in text reports]' \
  '(-r --recurse)'{-r,--recurse}'[process subdirectories]' \
  '(-l --list)'{-l,--list}'[list available profiles]' \
  '--nonpdfext[validate PDFs with non-PDF extensions]' \
  '(-d --debug)'{-d,--debug}'[display all processed file names]' \
  '--disableerrormessages[remove detailed error messages]' \
  '--progress[show validation status]' \
  '--processes=[use multiple CPU processes]:count' \
  '(-o --off)'{-o,--off}'[disable validation]' \
  '--password=[decrypt PDFs with password]:password' \
  '--config=[use GUI configuration files]' \
  '--extract[feature extraction mode]' \
  '*:PDF file:_files' && ret=0

return ret
