#compdef bertini
# Documentation: https://bertini.nd.edu/BertiniUsersManual.pdf
# Bertini: numerical algebraic geometry via homotopy continuation

local ret=1

# Bertini takes an optional input file (default: ./input); all configuration
# is done with CONFIG keywords inside the input file, not via CLI flags.
_arguments -s -S \
  '1:input file:_files' \
  '2:start file:_files' && ret=0

return ret
