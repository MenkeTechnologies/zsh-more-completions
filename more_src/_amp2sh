#compdef amp2sh
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/amp2sh.html
# Source: MRtrix3/mrtrix3 cmd/amp2sh.cpp — convert DW amplitude images to spherical harmonics (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-lmax+[maximum spherical-harmonic order]:order:_default' \
    '-normalise[normalise DW signal to b=0 image]' \
    '-directions+[directions text file]:file:_files' \
    '-rician+[Rician noise correction using supplied noise map]:file:_files -g "*.{nii,nii.gz,mif}"' \
    '1:amp (input amplitude image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:SH (output spherical-harmonic image):_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
