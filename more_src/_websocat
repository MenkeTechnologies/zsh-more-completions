#compdef websocat

# Zsh completion for websocat (WebSocket command-line client)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '(- *)--help-long[show detailed help]' \
  '(- *)--list-alladdrs[list all address types]' \
  {-t,--text}'[send and receive text messages (default)]' \
  {-b,--binary}'[send and receive binary messages]' \
  {-n,--no-close}'[do not send close frame on EOF]' \
  {-u,--unidirectional}'[inhibit copying data in one direction]' \
  {-U,--unidirectional-reverse}'[inhibit copying data in the other direction]' \
  {-E,--exit-on-eof}'[close a data transfer direction if the other direction is closed]' \
  '-0[use null byte as line separator instead of newline]' \
  '--oneshot[serve only one client then exit]' \
  {-e,--set-environment}'[set environment variables for exec: addresses]' \
  '*--exec-args[append arguments to exec: invocations]:args:' \
  '*'{-H,--header}'[add custom HTTP header]:header:' \
  '--origin[add Origin HTTP header]:origin:' \
  '--websocket-version[override WebSocket version]:version:' \
  '--protocol[specify WebSocket subprotocol]:protocol:' \
  '--ping-interval[send WebSocket pings every N seconds]:seconds:' \
  '--ping-timeout[drop connection if ping not answered in N seconds]:seconds:' \
  {-k,--insecure}'[accept invalid TLS certificates]' \
  '--tls-domain[override domain for TLS verification]:domain:_hosts' \
  '-q[suppress all diagnostic messages]' \
  '1:address (URL or specifier):_urls' \
  '2::second address (URL or specifier):_urls'
