#compdef iotbx.cif.validate
# Documentation: https://cci.lbl.gov/docs/cctbx/
# iotbx.cif.validate - validate CIF files against a dictionary (cctbx/iotbx)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--file_ext=[file extension to validate]:ext:' \
  '--dic=[dictionary to validate against]:dict:_files' \
  '--show_warnings[show validation warnings]' \
  '--show_timings[show timing information]' \
  '--strict[use strict validation]' \
  '*:cif file:_files -g "*.cif"' && ret=0

return ret
