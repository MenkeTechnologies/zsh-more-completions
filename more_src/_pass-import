#compdef pass-import
# Documentation: https://github.com/roddhjav/pass-import
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pass-import - password store importer

local -a managers=(
  '1password:1Password'
  'aegis:Aegis'
  'andotp:andOTP'
  'applekeychain:Apple Keychain'
  'bitwarden:Bitwarden'
  'blur:Blur'
  'buttercup:Buttercup'
  'chrome:Chrome'
  'clipperz:Clipperz'
  'csv:Generic CSV'
  'dashlane:Dashlane'
  'encryptr:Encryptr'
  'enpass:Enpass'
  'firefox:Firefox'
  'fpm:Figaro Password Manager'
  'freeotp:FreeOTP+'
  'gnome:GNOME Keyring'
  'gnomeauth:GNOME Authenticator'
  'gopass:Gopass'
  'gorilla:Password Gorilla'
  'kedpm:Ked Password Manager'
  'keepass:KeePass'
  'keepassx:KeePassX'
  'keepassx2:KeePassX2'
  'keepassxc:KeePassXC'
  'keeper:Keeper'
  'lastpass:LastPass'
  'myki:Myki'
  'networkmanager:NetworkManager'
  'nordpass:NordPass'
  'padlock:Padlock'
  'pass:pass'
  'passman:Passman'
  'passpack:Passpack'
  'passpie:Passpie'
  'pwsafe:pwsafe'
  'revelation:Revelation'
  'roboform:RoboForm'
  'safeincloud:SafeInCloud'
  'saferpass:SaferPass'
  'upm:UPM'
  'zoho:Zoho'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-r --root)'{-r,--root}'=[import from specific subfolder]:folder:' \
  '(-p --path)'{-p,--path}'=[import to specific subfolder]:folder:' \
  '(-k --key)'{-k,--key}'=[path to keyfile]:file:_files' \
  '(-a --all)'{-a,--all}'[include all extra data]' \
  '(-f --force)'{-f,--force}'[overwrite existing entries]' \
  '(-c --clean)'{-c,--clean}'[make paths CLI-friendly]' \
  '(-C --convert)'{-C,--convert}'[convert invalid characters]' \
  '(-P --pwned)'{-P,--pwned}'[check against haveibeenpwned.com]' \
  '(-d --dry-run)'{-d,--dry-run}'[preview without importing]' \
  '--sep=[path separator replacement]:char:' \
  '--del=[CSV delimiter]:char:' \
  '--cols=[CSV column mapping]:cols:' \
  '--filter=[JSONPath filter]:filter:' \
  '--config=[config file]:file:_files' \
  '(-l --list)'{-l,--list}'[list supported managers]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '1:manager:->managers' \
  '2:file:_files' && return 0

case $state in
  managers)
    _describe -t managers 'password manager' managers
    ;;
esac
