#compdef pass-import

# Zsh completion for pass-import - password store importer

local -a managers=(
  '1password:1Password'
  'aegis:Aegis'
  'andotp:andOTP'
  'apple-keychain:Apple Keychain'
  'bitwarden:Bitwarden'
  'buttercup:Buttercup'
  'chrome:Chrome'
  'csv:Generic CSV'
  'dashlane:Dashlane'
  'encryptr:Encryptr'
  'enpass:Enpass'
  'firefox:Firefox'
  'fpm:Figaro Password Manager'
  'freeotp:FreeOTP+'
  'gnome-keyring:GNOME Keyring'
  'gorilla:Password Gorilla'
  'keepass:KeePass'
  'keepassx:KeePassX'
  'keepassxc:KeePassXC'
  'lastpass:LastPass'
  'myki:Myki'
  'networkmanager:NetworkManager'
  'nordpass:NordPass'
  'passpie:Passpie'
  'pwsafe:pwsafe'
  'revelation:Revelation'
  'roboform:RoboForm'
  'upm:UPM'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --path)'{-p,--path}'[import to specific subfolder]:path' \
  '(-a --all)'{-a,--all}'[import all entries]' \
  '(-c --clean)'{-c,--clean}'[clean imported data]' \
  '(-C --convert)'{-C,--convert}'[convert invalid characters]' \
  '(-s --separator)'{-s,--separator}'[path separator]:separator' \
  '(-d --delimiter)'{-d,--delimiter}'[CSV delimiter]:delimiter' \
  '(-l --list)'{-l,--list}'[list supported managers]' \
  '(-f --force)'{-f,--force}'[overwrite existing entries]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '1:manager:->managers' \
  '2:file:_files' && return 0

case $state in
  managers)
    _describe -t managers 'password manager' managers
    ;;
esac
