#compdef carbonyl

# Zsh completion for Carbonyl - Chromium-based browser in the terminal

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--no-sandbox[disable sandbox mode]' \
  '--disable-gpu[disable GPU hardware acceleration]' \
  '--user-data-dir=[path to user data directory]:directory:_directories' \
  '--incognito[start in incognito mode]' \
  '--proxy-server=[proxy server]:proxy' \
  '--no-first-run[skip first run dialogs]' \
  '--disable-extensions[disable extensions]' \
  '--disable-default-apps[disable default apps]' \
  '--headless[headless mode]' \
  '--remote-debugging-port=[remote debugging port]:port' \
  '--window-size=[window size]:size' \
  '*:URL' && ret=0

return ret
