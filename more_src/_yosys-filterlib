#compdef yosys-filterlib
# Documentation: https://man.archlinux.org/search?q=yosys-filterlib
# Reference accessed: 2026-05-16

# Yosys yosys-filterlib: filter a Liberty .lib by command list
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-verbose[verbose filter info]' \
  '-cell_drop[drop cells matching pattern]:pattern:' \
  '-cell_keep[keep only cells matching pattern]:pattern:' \
  '*:Liberty .lib file:_files -g "*.lib"' && ret=0
return ret
