#compdef kvkbd
# Documentation: https://www.huge-man-linux.net/man1/kvkbd.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kvkbd: KDE virtual keyboard. KDE/Qt standard option set plus the
# --loginhelper application-specific flag.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help about options]' \
  '(- *)--help-qt[show Qt-specific options]' \
  '(- *)--help-kde[show KDE-specific options]' \
  '(- *)--help-all[show all options]' \
  '(- *)--author[show author information]' \
  '(- *)'{-v,--version}'[show version information]' \
  '(- *)--license[show license information]' \
  '--loginhelper[stand-alone version for KDM or XDM]' \
  '--caption=[window caption]:caption:' \
  '--icon=[window icon]:icon:' \
  '--config=[alternative configuration file]:file:_files' \
  '--nocrashhandler[disable crash handler to get core dumps]' \
  '--waitforwm[wait for a WM_NET compatible window manager]' \
  '--style=[Qt widget style]:style:' \
  '--geometry=[main widget geometry]:geometry:' \
  '--nofork[do not run in the background]' \
  '--display=[X-server display]:display:' \
  '--session=[restore application session]:session:' \
  '--name=[application name]:name:' \
  '--title=[application title]:title:' \
  '--reverse[mirror the whole layout of widgets]' \
  '--stylesheet=[apply Qt stylesheet]:file:_files -g "*.qss"' && ret=0
return ret
