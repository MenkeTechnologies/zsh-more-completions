#compdef kvkbd
# Documentation: https://www.huge-man-linux.net/man1/kvkbd.html
# Reference accessed: 2026-05-16
# Verified: kvkbd(1) manpage on huge-man-linux.net.
# Removed from prior file: bogus man.archlinux.org search URL.

# kvkbd: KDE virtual keyboard
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--help-qt[show Qt-specific options]' \
  '--help-kde[show KDE-specific options]' \
  '--help-all[show all options]' \
  '--version[show version]' \
  '--loginhelper[stand-alone version for KDM/XDM]' \
  '--caption=[window caption]:caption:' \
  '--icon=[window icon]:icon:' \
  '--style=[Qt widget style]:style:' \
  '--geometry=[window geometry]:geometry:' \
  '--nofork[do not fork]' && ret=0
return ret
