#compdef duplicati

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'backup:run a backup job'
      'restore:restore files from backup'
      'compact:compact backup data'
      'test:test backup integrity'
      'compare:compare two backups'
      'purge:purge files from backups'
      'vacuum:vacuum the local database'
      'delete:delete a backup'
      'repair:repair the local database'
      'affected:show affected files'
      'list:list backup contents'
      'find:find files in backups'
      'verify:verify backup files'
      'create-report:create a backup report'
      'send-mail:send an email report'
      'system-info:show system information'
    )
    _describe -t commands 'duplicati command' commands && ret=0
    ;;
  args)
    local -a common_opts=(
      '(- *)'{-h,--help}'[show help]'
      '--dbpath=[path to local database]:database:_files'
      '--encryption-module=[encryption module]:module:(aes gpg)'
      '--compression-module=[compression module]:module:(zip 7z)'
      '--passphrase=[encryption passphrase]:passphrase'
      '--no-encryption[disable encryption]'
      '--backup-name=[name of the backup]:name'
      '--tempdir=[temporary directory]:directory:_directories'
      '--log-file=[log file path]:log file:_files'
      '--log-level=[log verbosity]:level:(Error Warning Information Profiling)'
      '--threads=[number of threads]:threads'
    )
    case $line[1] in
      backup)
        _arguments -s -S \
          $common_opts \
          '--keep-time=[keep backups newer than duration]:duration' \
          '--keep-versions=[number of versions to keep]:count' \
          '--upload-speed-limit=[upload speed limit]:limit' \
          '--download-speed-limit=[download speed limit]:limit' \
          '--skip-files-larger-than=[skip files larger than]:size' \
          '--exclude=[exclude filter]:pattern' \
          '--include=[include filter]:pattern' \
          '--snapshot-policy=[snapshot policy]:policy:(auto on off required)' \
          '--full-if-older-than=[full backup interval]:duration' \
          '1:backup URL or path' && ret=0
        ;;
      restore)
        _arguments -s -S \
          $common_opts \
          '--restore-path=[restore to path]:directory:_directories' \
          '--time=[restore from specific time]:time' \
          '--version=[restore from specific version]:version' \
          '--overwrite[overwrite existing files]' \
          '--restore-permissions[restore file permissions]' \
          '1:backup URL or path' \
          '*:files to restore' && ret=0
        ;;
      compact)
        _arguments -s -S \
          $common_opts \
          '--small-file-size=[compact files smaller than]:size' \
          '--small-file-max-count=[max small files before compact]:count' \
          '1:backup URL or path' && ret=0
        ;;
      test)
        _arguments -s -S \
          $common_opts \
          '--full-remote-verification[verify all remote data]' \
          '1:backup URL or path' && ret=0
        ;;
      compare)
        _arguments -s -S \
          $common_opts \
          '1:backup URL or path' \
          '2:version or time' && ret=0
        ;;
      purge)
        _arguments -s -S \
          $common_opts \
          '--version=[version to purge from]:version' \
          '--dry-run[do not actually purge]' \
          '1:backup URL or path' && ret=0
        ;;
      vacuum|repair|system-info)
        _arguments -s -S \
          $common_opts && ret=0
        ;;
      list|find)
        _arguments -s -S \
          $common_opts \
          '--time=[list at specific time]:time' \
          '--version=[list specific version]:version' \
          '1:backup URL or path' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $common_opts \
          '--version=[version to delete]:version' \
          '--keep-time=[keep backups newer than duration]:duration' \
          '--keep-versions=[number of versions to keep]:count' \
          '--dry-run[do not actually delete]' \
          '1:backup URL or path' && ret=0
        ;;
      verify)
        _arguments -s -S \
          $common_opts \
          '1:backup URL or path' && ret=0
        ;;
      create-report)
        _arguments -s -S \
          $common_opts \
          '1:backup URL or path' && ret=0
        ;;
      send-mail)
        _arguments -s -S \
          $common_opts \
          '--send-mail-to=[recipient email]:email' \
          '--send-mail-from=[sender email]:email' \
          '--send-mail-subject=[email subject]:subject' \
          '--send-mail-url=[SMTP server URL]:url' \
          '1:backup URL or path' && ret=0
        ;;
      affected)
        _arguments -s -S \
          $common_opts \
          '1:backup URL or path' \
          '2:file or remote volume' && ret=0
        ;;
    esac
    ;;
esac

return ret
