#compdef google-play
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/tree/master/docs/google-play
# Codemagic CLI tools - utility to get the latest build numbers from Google Play

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(get-latest-build-number apks bundles deobfuscation-files expansion-files internal-app-sharing tracks)' \
  '*::args:->args' && ret=0

return ret
