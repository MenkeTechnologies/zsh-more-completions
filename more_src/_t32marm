#compdef t32marm
# Documentation: https://www2.lauterbach.com/pdf/debugger_user.pdf
# Lauterbach TRACE32 ARM debugger front-end — start with config file and PRACTICE script

local ret=1

_arguments -s -S \
  '-c[user-specific TRACE32 configuration file (optional args follow)]:config file:_files' \
  '-s[PRACTICE start-up script (.cmm, optional args follow)]:script:_files -g "*.cmm"' \
  '*::arg:' && ret=0

return ret
