#compdef dnsproxy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '(-l --listen)'{-l,--listen}'=[listen address]:address:' \
  '(-p --port)'{-p,--port}'=[listen port]:port:' \
  '(-u --upstream)'{-u,--upstream}'=[upstream DNS server]:server:' \
  '(-b --bootstrap)'{-b,--bootstrap}'=[bootstrap DNS server]:server:' \
  '(-f --fallback)'{-f,--fallback}'=[fallback DNS server]:server:' \
  '--all-servers[use all upstream servers in parallel]' \
  '--fastest-addr[respond with fastest IP address]' \
  '--cache[enable DNS cache]' \
  '--cache-size=[DNS cache size]:size:' \
  '--cache-min-ttl=[minimum TTL value for cache]:ttl:' \
  '--cache-max-ttl=[maximum TTL value for cache]:ttl:' \
  '--cache-optimistic[return expired cache entries while refreshing]' \
  '(-r --ratelimit)'{-r,--ratelimit}'=[rate limit per client]:rps:' \
  '--ratelimit-subnet-len-ipv4=[subnet length for IPv4 rate limiting]:length:' \
  '--ratelimit-subnet-len-ipv6=[subnet length for IPv6 rate limiting]:length:' \
  '--refuse-any[refuse ANY requests]' \
  '--edns[enable EDNS Client Subnet]' \
  '--edns-addr=[EDNS address]:address:' \
  '--dns64[enable DNS64]' \
  '--dns64-prefix=[DNS64 prefix]:prefix:' \
  '--ipv6-disabled[disable IPv6 responses]' \
  '--bogus-nxdomain=[transform responses with given IP to NXDOMAIN]:ip:' \
  '--udp-buf-size=[UDP buffer size]:size:' \
  '--max-go-routines=[max goroutines]:count:' \
  '--pprof[enable pprof server]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-o --output)'{-o,--output}'=[log output]:file:_files' \
  '--insecure[skip TLS certificate verification]' \
  '--tls-min-version=[minimum TLS version]:version:(1.0 1.1 1.2 1.3)' \
  '--tls-max-version=[maximum TLS version]:version:(1.0 1.1 1.2 1.3)' \
  '--tls-crt=[TLS certificate]:cert:_files' \
  '--tls-key=[TLS key]:key:_files' \
  '--https-port=[HTTPS port for DNS-over-HTTPS]:port:' \
  '--http3[enable HTTP/3 for DNS-over-HTTPS]' \
  '--tls-port=[TLS port for DNS-over-TLS]:port:' \
  '--quic-port=[QUIC port for DNS-over-QUIC]:port:' \
  '--dnscrypt-port=[DNSCrypt port]:port:' \
  '--dnscrypt-config=[DNSCrypt config file]:file:_files' \
  '--config-path=[path to config file]:file:_files' \
  '*:config file:_files' && ret=0

return ret
