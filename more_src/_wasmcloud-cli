#compdef wasmcloud-host wash-cli
# Documentation: https://github.com/wasmCloud/wasmCloud (crates/wash/src/bin/wash.rs, release-1.9.x)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: primary wash completion lives in _wasmcloud. This file handles legacy
# wasmcloud-host and wash-cli binary names that share the same flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*--ctl-host=[control interface host]:host' \
  '*--ctl-port=[control interface port]:port' \
  '*--rpc-host=[RPC host]:host' \
  '*--rpc-port=[RPC port]:port' \
  '*--cluster-seed=[cluster seed]:seed' \
  '*--allowed-insecure=[comma-separated insecure registries]:list' \
  '*--enable-structured-logging[enable structured logging]' \
  '*--log-level=[log level]:level:(trace debug info warn error)' \
  '*--config-service-enabled[enable config service]' \
  '*: :_files' && ret=0

return ret
