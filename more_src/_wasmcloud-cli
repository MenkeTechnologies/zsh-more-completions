#compdef wash wasmcloud wasmcloud-host wash-cli

local curcontext="$curcontext" state line ret=1

case $service in
  (wash|wash-cli)
    local -a commands
    commands=(
      'app:application commands (wadm)'
      'build:build a wasmCloud component'
      'call:call a component function'
      'capture:capture observability data'
      'claims:JWT claims for components/providers'
      'completions:generate shell completions'
      'config:get/set wash config'
      'ctx:context management'
      'ctl:invoke wasmCloud control commands'
      'dev:run a component dev session'
      'down:stop wasmCloud host'
      'drain:drain a host'
      'get:get info about hosts/inventory/links/claims'
      'inspect:inspect components/providers'
      'keys:generate cryptographic keys'
      'label:label hosts'
      'link:link components and providers'
      'new:scaffold a new project'
      'par:create signed provider archive'
      'plugin:plugin commands'
      'pull:pull artifact from OCI'
      'push:push artifact to OCI'
      'reg:registry commands'
      'spy:spy on component invocations'
      'start:start components/providers'
      'stop:stop components/providers'
      'up:start a wasmCloud host'
      'update:update components/providers'
      'wit:WIT helpers'
      'help:show help'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '*--output=[output format]:f:(text json)' \
      '*-o+[output]:f:(text json)' \
      '*--experimental[enable experimental]' \
      '*--help-markdown[markdown help]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'wash command' commands && ret=0 ;;
      (args)
        case $line[1] in
          (build)
            _arguments \
              '--config-path=[config file]:file:_files -g "*.toml"' \
              '--build-only[build only]' \
              '--skip-fetch[skip fetch]' \
              '--no-sign[no sign]' \
              '--sign-only[sign only]' \
              '*: :' && ret=0 ;;
          (call)
            _arguments \
              '--http-port=[HTTP port]:port:' \
              '--http-body=[HTTP body]:b:' \
              '--bin=[binary]:b:' \
              '*: :' && ret=0 ;;
          (up)
            _arguments \
              '--detached[detached]' \
              '--ctl-host=[ctl host]:h:' \
              '--ctl-port=[ctl port]:p:' \
              '--rpc-host=[rpc host]:h:' \
              '--rpc-port=[rpc port]:p:' \
              '--cluster-seed=[cluster seed]:s:' \
              '--config-service-enabled[config service]' \
              '--enable-structured-logging[structured logging]' \
              '--allowed-insecure=[insecure registries csv]:list:' \
              '*: :' && ret=0 ;;
          (down|drain)
            _arguments '*: :' && ret=0 ;;
          (completions)
            _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
          (*) _files ;;
        esac ;;
    esac ;;
  (wasmcloud|wasmcloud-host)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '*--ctl-host=[ctl host]:h:' \
      '*--ctl-port=[ctl port]:p:' \
      '*--rpc-host=[rpc host]:h:' \
      '*--rpc-port=[rpc port]:p:' \
      '*--cluster-seed=[seed]:s:' \
      '*--allowed-insecure=[insecure regs csv]:list:' \
      '*--enable-structured-logging[structured logging]' \
      '*--log-level=[log level]:l:(trace debug info warn error)' \
      '*--config-service-enabled[config service]' \
      '*: :' && ret=0 ;;
esac

return ret
