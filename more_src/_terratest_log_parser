#compdef terratest_log_parser
# Documentation: https://github.com/gruntwork-io/terratest/tree/main/cmd/terratest_log_parser
# Parse and break out Terratest test logs by test name

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--log-level=[set the log level]:level:(panic fatal error warning info debug)' \
  '(-l --testlog)'{-l,--testlog}'=[path to file containing test log, default stdin]:test log:_files' \
  '(-o --outputdir)'{-o,--outputdir}'=[directory to output test output to]:dir:_files -/' && ret=0

return ret
