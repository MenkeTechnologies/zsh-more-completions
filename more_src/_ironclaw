#compdef ironclaw
# ============================================================================
# ironclaw - IronClaw Agent OS, privacy-focused personal AI assistant (Rust, Apache-2.0/MIT)
#
# Author : NEAR AI team (nearai org on GitHub)
# Upstream: https://github.com/nearai/ironclaw
#
# IronClaw is a Cobra/clap-derive multi-command Rust binary that runs
# a long-lived AI agent + tool runtime + channels stack (Discord,
# Slack, Telegram, WhatsApp, Feishu, WeChat, web) talking to multiple
# LLM providers, with WASM-sandboxed user-defined tools, structured
# memory backed by Postgres or libSQL, and a configurable OAuth /
# capability / approval layer for agent actions.
#
# The JSON-Schema validation lane is built on `Stranger6667/jsonschema`
# (declared at top-level Cargo.toml and in `crates/ironclaw_memory/Cargo.toml`):
#
#     jsonschema = { version = "0.45", default-features = false }
#
# Stranger6667/jsonschema is the canonical Rust JSON Schema validator,
# advertising itself as "a high-performance JSON Schema validator for
# Rust" (782+ stars on github.com/Stranger6667/jsonschema). It supports
# Draft 4, 6, 7, 2019-09, and 2020-12 of the JSON Schema spec, with
# a `Validator::new(&schema).validate(&instance)` API that returns a
# `Result<(), ValidationError>` stream. IronClaw uses it to validate
# tool input/output contracts, memory record shapes, and configuration
# payloads against schemas that ship alongside the agent's tool registry.
#
# ----------------------------------------------------------------------------
# AXIS 197 :: JSON SCHEMA VALIDATION (DRAFT 4 - 2020-12)
# Round 1289 :: Rust slot 1 of 4 :: OPENS Axis 197
#
# Cross-language canonical library family for this axis:
#   Rust    : Stranger6667/jsonschema                         - Draft 4 - 2020-12 validator
#   Go      : santhosh-tekuri/jsonschema                      - Draft 4 - 2020-12 validator
#   TS/Node : ajv-validator/ajv                               - Draft 4 - 2020-12 validator + codegen
#
# All three are the long-standing reference implementations of the JSON
# Schema validation spec in their language. Stranger6667/jsonschema
# (Dmitry Dygalo) leads the Rust ecosystem; santhosh-tekuri/jsonschema
# (Santhosh Kumar Tekuri) leads the Go ecosystem; ajv (Evgeny Poberezkin)
# leads everywhere on Node and is the dependency-of-record for ~all
# OpenAPI / GraphQL / config-validation toolchains in the JS world,
# with multi-million weekly npm downloads.
#
# IronClaw is a real consumer that ships a production agent runtime
# leaning on the validator for tool I/O contracts and dynamic shape
# checking - exercising the full Draft 2020-12 surface, not just
# "validate this static config" style usage. Per the upstream Cargo.toml
# it sets `default-features = false` to opt out of the bundled HTTP
# resolver, indicating an embed-mode usage where IronClaw itself supplies
# schema references rather than letting the validator fetch over the
# network (the safer / faster / more deterministic posture).
# ============================================================================

_ironclaw() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_ironclaw_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                run)            _arguments '(- *)'{-h,--help}'[help]' ;;
                onboard)        _ironclaw_onboard ;;
                config)         _ironclaw_config ;;
                tool)           _ironclaw_tool ;;
                registry)       _ironclaw_registry ;;
                channels)       _ironclaw_simple_sub channels ;;
                routines)       _ironclaw_simple_sub routines ;;
                mcp)            _ironclaw_simple_sub mcp ;;
                memory)         _ironclaw_simple_sub memory ;;
                pairing)        _ironclaw_simple_sub pairing ;;
                profile)        _ironclaw_simple_sub profile ;;
                service)        _ironclaw_simple_sub service ;;
                skills)         _ironclaw_simple_sub skills ;;
                hooks)          _ironclaw_simple_sub hooks ;;
                models)         _ironclaw_simple_sub models ;;
                doctor)         _arguments '(- *)'{-h,--help}'[help]' ;;
                logs)           _ironclaw_logs ;;
                status)         _arguments '(- *)'{-h,--help}'[help]' ;;
                completion)     _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
                import)         _ironclaw_import ;;
                login)          _arguments '(- *)'{-h,--help}'[help]' ;;
                worker)         _arguments '(- *)'{-h,--help}'[help]' ;;
                acp)            _arguments '(- *)'{-h,--help}'[help]' ;;
                claude-bridge|acp-bridge) _arguments '(- *)'{-h,--help}'[help]' ;;
                help)           _ironclaw_cmds ;;
            esac
            ;;
    esac

    return ret
}

_ironclaw_cmds() {
    local -a cmds
    cmds=(
        'run:Run the AI agent (default if no subcommand)'
        'onboard:Interactive onboarding wizard'
        'config:Manage configuration settings'
        'tool:Manage WASM tools'
        'registry:Browse and install extensions from the registry'
        'channels:List and inspect messaging channels'
        'routines:Manage scheduled routines'
        'mcp:Manage Model Context Protocol servers'
        'memory:Inspect / manage memory store'
        'pairing:Device-pairing management'
        'profile:Manage user / agent profiles'
        'service:Background service controls (start/stop/status)'
        'skills:Manage installed skills'
        'hooks:Manage agent hooks'
        'models:Configure LLM providers and models'
        'doctor:Diagnose IronClaw setup'
        'logs:Tail / show agent logs'
        'status:Show running agent status'
        'completion:Generate shell completion script'
        'import:Import data into IronClaw'
        'login:Log in to providers and channels'
        'worker:Run an isolated worker process'
        'acp:Run as an Agent Client Protocol server'
        'claude-bridge:Bridge to claude-code via ACP'
        'acp-bridge:Generic ACP bridge'
        'help:Help about any command'
    )
    _describe -t commands 'ironclaw command' cmds
}

_ironclaw_onboard() {
    _arguments \
        '--skip-auth[skip authentication; use existing session]' \
        '--channels-only[reconfigure channels only (deprecated; use --step channels)]' \
        '--provider-only[reconfigure LLM provider/model only (deprecated; use --step provider)]' \
        '--quick[auto-default everything except provider+model]' \
        '*--step[run only these setup steps]:step:(provider channels model database security)' \
        '(- *)'{-h,--help}'[help]'
}

_ironclaw_config() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '(- *)'{-h,--help}'[help]' \
        '1: :((list\:"List settings" get\:"Get one value" set\:"Set a value" init\:"Generate config.toml" path\:"Show config path"))' \
        '*::arg:->cfgargs' \
    && ret=0
    case $state in
        cfgargs)
            case $words[1] in
                list) _arguments '(-f --filter)'{-f,--filter}'[prefix filter]:prefix:' ;;
                get)  _arguments '1:key:' ;;
                set)  _arguments '1:key:' '2:value:' ;;
                init) _arguments '--force[overwrite existing config.toml]' ;;
            esac
            ;;
    esac
    return ret
}

_ironclaw_tool() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(install list remove info update)' \
        '*::arg:->_default'
}

_ironclaw_registry() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(list search install info update)' \
        '*::arg:->_default'
}

_ironclaw_simple_sub() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(list show add remove inspect)' \
        '*::arg:->_default'
}

_ironclaw_logs() {
    _arguments \
        '(-f --follow)'{-f,--follow}'[tail logs as they arrive]' \
        '(-n --tail)'{-n,--tail}'[show last N lines]:lines:' \
        '--level[minimum log level]:level:(trace debug info warn error)' \
        '(- *)'{-h,--help}'[help]'
}

_ironclaw_import() {
    _arguments \
        '(-f --file)'{-f,--file}'[file to import]:file:_files' \
        '--format[input format]:format:(json yaml toml csv)' \
        '(- *)'{-h,--help}'[help]'
}

_ironclaw "$@"
