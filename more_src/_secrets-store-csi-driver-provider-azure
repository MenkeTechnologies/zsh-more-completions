#compdef secrets-store-csi-driver-provider-azure
# _secrets-store-csi-driver-provider-azure — Azure provider for Secrets Store CSI Driver
# upstream: https://github.com/Azure/secrets-store-csi-driver-provider-azure
# Flags from cmd/main.go on tip.

_secrets-store-csi-driver-provider-azure() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version information]' \
        '--endpoint=[CSI gRPC endpoint]:endpoint:' \
        '--log-format-json=[emit logs in JSON]:bool:(true false)' \
        '--enable-pprof=[enable pprof profiling]:bool:(true false)' \
        '--pprof-port=[pprof port]:port:' \
        '--healthz-port=[health check port]:port:' \
        '--healthz-path=[health check path]:path:' \
        '--healthz-timeout=[health check RPC timeout]:dur:' \
        '--metrics-backend=[metrics backend]:backend:(Prometheus opencensus)' \
        '--prometheus-port=[Prometheus metrics port]:port:' \
        '--construct-pem-chain=[reconstruct PEM chain (server,intermediate,root)]:bool:(true false)' \
        '--write-cert-and-key-in-separate-files=[write cert + key in separate files]:bool:(true false)' \
        '--cloud-name=[Azure cloud environment]:cloud:(AzurePublicCloud AzureChinaCloud AzureGermanCloud AzureUSGovernmentCloud)' \
        '--token-proxy-url=[token proxy URL for identity binding]:url:_urls' \
        '--sni-name=[TLS SNI server name for identity proxy]:host:' \
        '-v[klog verbosity level]:n:'
}

_secrets-store-csi-driver-provider-azure "$@"
