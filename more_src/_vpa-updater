#compdef vpa-updater
# _vpa-updater — Vertical Pod Autoscaler updater (kubernetes/autoscaler/vertical-pod-autoscaler)
# upstream: https://github.com/kubernetes/autoscaler/tree/master/vertical-pod-autoscaler
# Flags from pkg/updater/{main,config/config}.go + common/flags.go on tip.

_vpa-updater() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--updater-interval=[updater loop interval]:dur:' \
        '--min-replicas=[min replicas required to perform updates]:n:' \
        '--eviction-tolerance=[evictable fraction of replicas]:f:' \
        '--eviction-rate-limit=[pods evictable per second (0/-1 disables)]:f:' \
        '--eviction-rate-burst=[evict burst size]:n:' \
        '--address=[Prometheus metrics bind address]:host\:port:' \
        '--use-admission-controller-status=[require valid admission-controller status]:bool:(true false)' \
        '--in-place-skip-disruption-budget=[skip PDB checks for in-place resize]:bool:(true false)' \
        '--pod-update-threshold=[ignore updates below this priority]:f:' \
        '--in-recommendation-bounds-eviction-lifetime-threshold=[evict in-bounds pods older than this]:dur:' \
        '--evict-after-oom-threshold=[evict pods OOMed within this window]:dur:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--profiling[expose /debug/pprof endpoints]' \
        '--vpa-object-namespace=[namespace to search VPAs in]:ns:' \
        '--ignored-vpa-object-namespaces=[comma-sep namespaces to ignore]:list:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '-v[klog verbosity level]:n:'
}

_vpa-updater "$@"
