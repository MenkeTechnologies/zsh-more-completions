#compdef cinder-csi-plugin
# _cinder-csi-plugin — OpenStack Cinder block-storage CSI driver
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from cmd/cinder-csi-plugin/main.go on tip.

_cinder-csi-plugin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoint=[CSI endpoint (unix sock or tcp host\:port)]:endpoint:' \
        '--nodeid=[DEPRECATED: node ID]:id:' \
        '*--cloud-config=[OpenStack cloud config file (repeatable)]:file:_files' \
        '*--cloud-name=[OpenStack cloud config subsection name (repeatable)]:name:' \
        '*--additional-topology=[additional topology key=value]:k=v:' \
        '--cluster=[cluster identifier]:id:' \
        '--http-endpoint=[HTTP metrics endpoint host\:port]:host\:port:' \
        '--with-topology=[cluster is topology-aware]:bool:(true false)' \
        '--provide-controller-service=[run the controller service]:bool:(true false)' \
        '--provide-node-service=[run the node service]:bool:(true false)' \
        '--node-service-no-os-client=[DEPRECATED: node service skips OpenStack client]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_cinder-csi-plugin "$@"
