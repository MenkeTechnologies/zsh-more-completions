#compdef conduktor-cli conduktor2 conductorctl
# _conduktor-cli — Conduktor conduktor-cli CLI command-line frontend wrapping the Conduktor enterprise data platform built atop Apache Kafka managing clusters environments resources topics consumer-groups schemas connect-clusters acls users teams permissions roles testing-suites kafka-protos chaos-engineering data-masking-PII (Conduktor team Stéphane Maarek, Scala); custom argparse
# upstream: https://conduktor.io/

_conduktor-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'apply:apply resource'
        'get:get resource'
        'delete:delete resource'
        'export:export resources'
        'import:import resources'
        'lint:lint manifest'
        'context:context operations'
        'cluster:cluster operations'
        'environment:environment operations'
        'topic:topic operations'
        'consumer-group:consumer group operations'
        'schema:schema operations'
        'connect:Connect operations'
        'acl:ACL operations'
        'user:user operations'
        'team:team operations'
        'role:role operations'
        'permission:permission operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--insecure[skip TLS verify]' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '-c+[config file]:file:_files -g ".conduktorrc *.yml *.yaml"' \
        '--config=+[file]:file:_files -g ".conduktorrc *.yml *.yaml"' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '-f+[manifest]:file:_files -g "*.yml *.yaml"' \
        '--file=+[file]:file:_files -g "*.yml *.yaml"' \
        '-o+[format]:f:(json yaml table wide name)' \
        '--output=+[format]:f:(json yaml table wide name)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conduktor-cli subcommand' sub ;;
        args)
            case $words[1] in
                cluster|environment|topic|consumer-group|schema|connect|acl|user|team|role|permission) _arguments '1:op:(list get apply create delete describe)' '*:name:' ;;
                apply|get|delete) _arguments '*:resource file:_files -g "*.yml *.yaml"' ;;
                context) _arguments '1:op:(list get use create delete set-cluster set-credentials)' '*:name:' ;;
            esac
            ;;
    esac
}

_conduktor-cli "$@"
