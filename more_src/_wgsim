#compdef wgsim
# Documentation: https://github.com/lh3/wgsim
# simulate short sequence reads from a reference genome with SNPs and indels

local ret=1

_arguments -s -S \
  '-e+[base error rate]:rate' \
  '-d+[outer distance between the two ends]:distance' \
  '-s+[standard deviation]:stddev' \
  '-N+[number of read pairs]:count' \
  '-1+[length of the first read]:length' \
  '-2+[length of the second read]:length' \
  '-r+[rate of mutations]:rate' \
  '-R+[fraction of indels]:fraction' \
  '-X+[probability an indel is extended]:probability' \
  '-S+[seed for random generator]:seed' \
  '-A+[discard if fraction of ambiguous bases higher than FLOAT]:fraction' \
  '-h[haplotype mode]' \
  ':reference fasta:_files -g "*.(fa|fasta|fa.gz|fasta.gz)"' \
  ':read1 output fastq:_files' \
  ':read2 output fastq:_files' && ret=0

return ret
