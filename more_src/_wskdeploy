#compdef wskdeploy
# Documentation: https://github.com/apache/openwhisk-wskdeploy
# Apache OpenWhisk wskdeploy - deploy and manage OpenWhisk projects from a manifest

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[whisk property file]:file:_files' \
  '(-p --project)'{-p,--project}'=[project path]:dir:_files -/' \
  '(-m --manifest)'{-m,--manifest}'=[manifest file]:file:_files' \
  '(-d --deployment)'{-d,--deployment}'=[deployment file]:file:_files' \
  '(-s --strict)'{-s,--strict}'[strict mode, do not allow runtime version override]' \
  '--preview[preview deployment without deploying]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--apihost=[whisk API host]:host:_hosts' \
  '(-n --namespace)'{-n,--namespace}'=[whisk namespace]:namespace:' \
  '(-u --auth)'{-u,--auth}'=[authorization key]:key:' \
  '--apiversion=[whisk API version]:version:' \
  '(-k --key)'{-k,--key}'=[client key file]:file:_files' \
  '(-c --cert)'{-c,--cert}'=[client certificate file]:file:_files' \
  '--managed[deploy as a managed project]' \
  '--projectname=[managed project name]:name:' \
  '(-t --trace)'{-t,--trace}'[enable trace output]' \
  '--param=[bind a parameter key/value]:param:' \
  '(-P --param-file)'{-P,--param-file}'=[parameter file]:file:_files' \
  '1:command:(deploy undeploy export report sync version help)' \
  '*::arg:->args' && ret=0

return ret
