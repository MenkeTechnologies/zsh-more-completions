#compdef opendkim-testssp
# Documentation: https://man.archlinux.org/search?q=opendkim-testssp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --domain)'{-d,--domain}'+[domain]:domain:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0

return ret
