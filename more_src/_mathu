#compdef mathu
# Documentation: https://github.com/dmytro/zsh-compdef/blob/master/_mathu
# Reference accessed: 2026-05-19
# Verified: third-party completion file in dmytro/zsh-compdef. No canonical CLI reference
# could be located for any tool named `mathu`; the completion assumes a `-l` flag that
# emits configuration names.
# STUB: pattern preserved from upstream completion source.

local expl ret=1

if [[ CURRENT -eq 2 ]]; then
  _wanted configurations expl 'configuration' compadd "$@" - \
    $(_call_program mathu mathu -l) && ret=0
fi

return ret
