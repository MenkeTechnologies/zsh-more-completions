#compdef updatemem
# Documentation: https://docs.amd.com/r/en-US/ug1580-updatemem
# AMD Vivado UpdateMEM: merge ELF/MEM data into block RAM of a bitstream

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-meminfo[memory map information file (.mmi)]:file:_files -g "*.mmi"' \
  '-bit[input bitstream file]:file:_files -g "*.bit"' \
  '-data[ELF or MEM data file to merge]:file:_files -g "*.elf *.mem"' \
  '-proc[processor instance path matching the MMI]:proc:' \
  '-out[output bitstream file]:file:_files' \
  '-force[overwrite output without prompting]' \
  '-debug[emit debug information]' \
  '*:file:_files' && ret=0

return ret
