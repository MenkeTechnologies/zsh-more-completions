#compdef pf

# Zsh completion for Azure AI Prompt Flow CLI (promptflow)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'flow:manage prompt flows'
      'run:manage flow runs'
      'connection:manage connections'
      'config:manage configuration'
      'tool:manage tools'
      'upgrade:upgrade promptflow'
      'trace:manage traces'
      'service:manage promptflow service'
    )
    _describe -t commands 'pf command' commands && ret=0
    ;;
  args)
    case $line[1] in
      flow)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->flow_cmds' \
          '*::arg:->flow_args' && ret=0
        case $state in
          flow_cmds)
            local -a flow_commands=(
              'init:initialize a flow'
              'test:test a flow'
              'validate:validate a flow'
              'build:build a flow'
              'serve:serve a flow'
            )
            _describe -t commands 'flow subcommand' flow_commands && ret=0
            ;;
          flow_args)
            case $line[1] in
              init)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--flow=[flow directory]:flow directory:_directories' \
                  '--type=[flow type]:type:(standard chat evaluation)' \
                  '--prompt=[prompt template]:prompt' \
                  '--yes[skip confirmation]' && ret=0
                ;;
              test)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--flow=[flow directory]:flow directory:_directories' \
                  '--inputs=[input values]:inputs' \
                  '--node=[test specific node]:node' \
                  '--variant=[variant to test]:variant' \
                  '--interactive[run in interactive mode]' \
                  '--multi-modal[enable multi-modal input]' \
                  '--detail=[detail level]:level' && ret=0
                ;;
              validate)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--flow=[flow directory]:flow directory:_directories' && ret=0
                ;;
              build)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--source=[flow source]:source:_directories' \
                  '--output=[output directory]:output:_directories' \
                  '--format=[output format]:format:(docker executable)' \
                  '--variant=[variant to build]:variant' && ret=0
                ;;
              serve)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--source=[flow source]:source:_directories' \
                  '--port=[port number]:port' \
                  '--host=[host address]:host' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      run)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->run_cmds' \
          '*::arg:->run_args' && ret=0
        case $state in
          run_cmds)
            local -a run_commands=(
              'create:create a new run'
              'list:list runs'
              'show:show run details'
              'show-details:show run step details'
              'show-metrics:show run metrics'
              'visualize:visualize run results'
              'delete:delete a run'
              'update:update a run'
              'stream:stream run logs'
              'archive:archive a run'
              'restore:restore an archived run'
            )
            _describe -t commands 'run subcommand' run_commands && ret=0
            ;;
          run_args)
            case $line[1] in
              create)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--flow=[flow directory]:flow:_directories' \
                  '--data=[data file]:data:_files' \
                  '--column-mapping=[column mapping]:mapping' \
                  '--run=[reference run name]:run' \
                  '--variant=[variant]:variant' \
                  '--name=[run name]:name' \
                  '--stream[stream run logs]' && ret=0
                ;;
              list|show|show-details|show-metrics|delete|archive|restore|stream)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--name=[run name]:name' && ret=0
                ;;
              visualize)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--names=[run names]:names' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      connection)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->conn_cmds' \
          '*::arg:->conn_args' && ret=0
        case $state in
          conn_cmds)
            local -a conn_commands=(
              'create:create a connection'
              'update:update a connection'
              'show:show connection details'
              'list:list connections'
              'delete:delete a connection'
            )
            _describe -t commands 'connection subcommand' conn_commands && ret=0
            ;;
          conn_args)
            case $line[1] in
              create)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--file=[connection YAML file]:file:_files -g "*.yaml"' \
                  '--name=[connection name]:name' \
                  '--type=[connection type]:type:(azure_open_ai open_ai custom)' \
                  '--set=[set key-value pairs]:key=value' && ret=0
                ;;
              show|delete)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--name=[connection name]:name' && ret=0
                ;;
              list)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      config)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->config_cmds' \
          '*::arg:->config_args' && ret=0
        case $state in
          config_cmds)
            local -a config_commands=(
              'set:set configuration'
              'show:show configuration'
            )
            _describe -t commands 'config subcommand' config_commands && ret=0
            ;;
          config_args)
            case $line[1] in
              set)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '*:key=value' && ret=0
                ;;
              show)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      tool)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->tool_cmds' && ret=0
        case $state in
          tool_cmds)
            local -a tool_commands=(
              'list:list available tools'
              'validate:validate tools'
              'init:initialize a tool'
            )
            _describe -t commands 'tool subcommand' tool_commands && ret=0
            ;;
        esac
        ;;
      upgrade)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      trace)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--destination=[trace destination]:destination' && ret=0
        ;;
      service)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->svc_cmds' && ret=0
        case $state in
          svc_cmds)
            local -a svc_commands=(
              'start:start the service'
              'stop:stop the service'
              'status:show service status'
            )
            _describe -t commands 'service subcommand' svc_commands && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
