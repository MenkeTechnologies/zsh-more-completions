#compdef cheat
# _cheat — cheat (community cheatsheets in the terminal; positional cheatsheet name shows the file; -e edits with $EDITOR, -l lists cheatsheets, -d shows path, -t/-T filter by tag, -s searches across sheets, -p picks a specific cheatpath, -c colorize)
# upstream: https://github.com/cheat/cheat
# Flags from cheat cmd/cheat/cmd_default.go on tip.

_cheat() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-e+[edit cheatsheet]:sheet:' \
        '--edit+[edit cheatsheet]:sheet:' \
        '-l[list cheatsheets]' \
        '--list[list cheatsheets]' \
        '-d[show config location]' \
        '--directories[show config location]' \
        '-c[colorize output]' \
        '--colorize[colorize output]' \
        '-r[regex search]' \
        '--regex[regex search]' \
        '-s+[search pattern]:pattern:' \
        '--search+[search pattern]:pattern:' \
        '-t+[filter by tag]:tag:' \
        '--tag+[filter by tag]:tag:' \
        '-T[list tags]' \
        '--tags[list tags]' \
        '-p+[cheatpath]:cheatpath:' \
        '--path+[cheatpath]:cheatpath:' \
        '-a[init config]' \
        '--init[init config]' \
        '*:cheatsheet:'
}

_cheat "$@"
