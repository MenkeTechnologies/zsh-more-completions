#compdef clang-format
# Documentation: clang-format --help (LLVM)
# Source: LLVM clang-format — format C / C++ / Java / JavaScript / JSON / Objective-C / Protobuf / C# code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--Werror[treat formatting warnings as errors]' \
    '--Wno-error=[skip error-out on warning type]:type:(unknown)' \
    '--assume-filename=[filename to determine language]:name:' \
    '--cursor=[cursor position for editor integration]:N:' \
    '--dry-run[do not actually make formatting changes]' \
    '--dump-config[dump configuration options and exit]' \
    '--fail-on-incomplete-format[exit 1 on incomplete format]' \
    '--fallback-style=[fallback style name (default LLVM, "none" to skip)]:style:(LLVM Google Chromium Mozilla WebKit Microsoft GNU InheritParentConfig none)' \
    '--ferror-limit=[max number of clang-format errors to emit]:N:' \
    '(-i)-i[edit files in place]' \
    '--length=[length of region to format]:N:' \
    '--lines=[format only the given line ranges (a:b)]:range:' \
    '--list-ignored[list files clang-format would skip]' \
    '(-n --dry-run)'{-n,--dry-run}'[do not actually make formatting changes]' \
    '--offset=[byte offset of region to format]:N:' \
    '--output-replacements-xml[output XML of replacements]' \
    '--sort-includes[sort #includes]' \
    '--style=[coding style]:style:(file LLVM Google Chromium Mozilla WebKit Microsoft GNU InheritParentConfig)' \
    '--verbose[show name of file being formatted]' \
    '(- *)--help[show help]' \
    '(- *)--help-hidden[show hidden help]' \
    '(- *)--version[show version]' \
    '*:file:_files -g "*.{c,cc,cpp,cxx,c++,h,hh,hpp,hxx,m,mm,java,js,mjs,cjs,ts,json,ipynb,proto,protodevel,td,txtpb,textpb,pb.txt,textproto,asciipb,sv,svh,v,vh,cs}"' \
    && ret=0

return ret
