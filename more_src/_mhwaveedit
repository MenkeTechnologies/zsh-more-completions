#compdef mhwaveedit
# Documentation: https://manpages.debian.org/bookworm/mhwaveedit/mhwaveedit.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--no-ladspa[disable LADSPA plugins]' \
  '--driver[select sound driver]:driver:(alsa oss jack pulse dummy)' \
  '--test[run conversion functions test]' \
  '--perftest[run conversion performance test]' \
  '*:audio file:_files' && ret=0

return ret
