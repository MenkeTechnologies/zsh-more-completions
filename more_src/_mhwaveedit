#compdef mhwaveedit
# Documentation: https://man.archlinux.org/search?q=mhwaveedit
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--driver=+[audio driver]:drv:(jack alsa oss sun pulse esound dummy)' \
  '*:audio file:_files -g "*.{wav,mp3,ogg,flac,aiff,au}"' && ret=0

return ret
