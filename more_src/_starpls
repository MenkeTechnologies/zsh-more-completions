#compdef starpls
# Documentation: https://github.com/withered-magic/starpls
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# starpls: LSP implementation for Starlark (Bazel/Buck2).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:analyze the specified Starlark files and report errors'
  'server:start the language server'
  'version:print version information and exit'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'starpls command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--bazel_path=[path to the Bazel binary]:file:_files' \
          '--experimental_enable_label_completions[enable label completions]' \
          '--experimental_goto_definition_skip_re_exports[skip re-exports in goto definition]' \
          '--experimental_infer_ctx_attributes[infer rule ctx attributes]' \
          '--experimental_use_code_flow_analysis[enable code-flow analysis]' \
          '--analysis_debounce_interval=[edit-event analysis debounce (ms)]:ms:' && ret=0 ;;
      (check)
        _arguments \
          '--output_base=[Bazel output base path]:dir:_files -/' \
          '*--ignore_pattern=[file/dir patterns to ignore]:pattern:' \
          '*--ext=[file extension to include]:ext:' \
          '--experimental_infer_ctx_attributes[infer rule ctx attributes]' \
          '--experimental_use_code_flow_analysis[enable code-flow analysis]' \
          '*:file:_files -g "*.{bzl,star,bazel,BUILD,WORKSPACE,MODULE,sky}"' && ret=0 ;;
    esac ;;
esac

return ret
