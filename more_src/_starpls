#compdef starpls

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:run the Starlark language server'
  'check:type-check Starlark files without running the server'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'starpls command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--experimental_infer_ctx_attributes[infer ctx attributes from analysis]' \
          '--experimental_use_code_flow_analysis[enable code flow analysis]' \
          '--bazel-path=[bazel binary path]:file:_files' \
          '--workspace-folders=[workspace folders]:dirs:' \
          '--bazel-workspace-output-base=[Bazel output base]:dir:_files -/' \
          '*--prelude-file=[Starlark prelude file]:file:_files -g "*.{star,bzl}"' \
          '*--bzlmod-enabled[enable Bzlmod features]' && ret=0 ;;
      (check)
        _arguments \
          '*:file:_files -g "*.{bzl,star,bazel,BUILD,WORKSPACE,MODULE,sky}"' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
