#compdef bioawk
# Documentation: https://github.com/lh3/bioawk
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# lh3/bioawk — main.c usage string
_arguments -s -S \
  '-F[field separator]:sep' \
  '-v[assign awk var]:var=value:' \
  '-c[input data format]:format:(help hdr header sam vcf bed gff fastx)' \
  '-t[tab separator (shortcut for -F"\\t" -v OFS="\\t")]' \
  '-H[include header line in processing]' \
  '(-f)-f+[awk program file]:file:_files' \
  '*:input:_files'
