#compdef bioawk

# https://github.com/lh3/bioawk — main.c usage string
_arguments -s -S \
  '-F[field separator]' \
  '-v[assign awk var]:var=value:' \
  '-c[program format]' \
  '-t[do not use header line]' \
  '-H[use first input line as header]' \
  '(-f)-f+[awk program file]:file:_files' \
  '*:input:_files'
