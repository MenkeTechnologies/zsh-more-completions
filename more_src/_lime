#compdef lime
# Documentation: https://lime.openfl.org/docs/command-line-tools/basic-commands/
# Lime command-line tools for Haxe cross-platform games

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '2:target:->targets' \
  '*::options:->opts' && ret=0

case $state in
  cmds)
    _values 'lime command' \
      'setup[download and install platform dependencies]' \
      'build[compile a project for a target]' \
      'run[launch the application]' \
      'test[build and run in a single command]' \
      'help[display help]' && ret=0
    ;;
  targets)
    _values 'target' \
      windows mac linux ios android tvos flash air html5 hl electron webassembly neko && ret=0
    ;;
  opts)
    _arguments -s -S \
      '-debug[perform a debug build]' \
      '-verbose[get verbose output]' \
      '-clean[remove output directory and perform a clean build]' \
      '-32[compile for 32-bit (mac|linux)]' \
      '-64[compile for 64-bit (mac|linux)]' \
      '-simulator[target device simulator (ios|tvos)]' \
      '-ipad[build for iPad Simulator (ios)]' \
      '-emulator[target device emulator (android)]' \
      '-minify[minify application file (html5)]' \
      '-web[test using web template (flash)]' \
      '-air[build with AIR instead of C++]' \
      '-neko[build with Neko instead of C++]' \
      '*-D-[add a custom define]:define' \
      '*:project:_files' && ret=0
    ;;
esac

return ret
