#compdef devmoji
# Documentation: https://github.com/folke/devmoji
# Source: folke/devmoji src/cli.ts — emojify conventional commit messages.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-c --config)'{-c+,--config=}'[location of the devmoji.config.js file]:file:_files' \
    '(-l --list)'{-l,--list}'[list all known devmojis]' \
    '(-t --text)'{-t+,--text=}'[text to format (reads from stdin when omitted)]:text:_default' \
    '--lint[lint the conventional commit (disabled for --log)]' \
    '(-f --format)'{-f+,--format=}'[output format]:format:(unicode shortcode devmoji strip)' \
    '--commit[add a devmoji to the conventional commit header]' \
    '--no-commit[do not process conventional commit headers]' \
    '(-e --edit)'{-e,--edit}'[read last commit message from .git/COMMIT_EDITMSG]' \
    '--log[format conventional commits in text similar to git log]' \
    '--color[use colors for formatting]' \
    '--no-color[do not use colors]' \
    '(- *)--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
