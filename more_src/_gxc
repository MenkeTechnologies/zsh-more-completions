#compdef gxc gxi
# _gxc — Dimitris Vyzovitis Gerbil Scheme compiler gxc and interpreter gxi opinionated meta-dialect of Gambit (vyzo team, Scheme); custom argparse
# upstream: https://github.com/mighty-gerbils/gerbil

_gxc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-O+[opt level]:l:(0 1 2 3)' \
        '-d+[output dir]:dir:_files -/' \
        '-o+[output file]:file:_files' \
        '-cc[generate C code]' \
        '-exe[generate executable]' \
        '-static[static binary]' \
        '-d-h[dump headers]' \
        '-g[debug build]' \
        '-debug[debug build]' \
        '-prelude+[prelude]:str:' \
        '-postlude+[postlude]:str:' \
        '-cppopt+[cpp opt]:str:' \
        '-ldopt+[ld opt]:str:' \
        '-no-ssi[no SSI]' \
        '-syntax-tree[dump syntax tree]' \
        '-no-show-bytecode[no bytecode dump]' \
        '-essentials-only[essentials only]' \
        '-keep-scm[keep scm]' \
        '-keep-c[keep c]' \
        '-keep-o[keep object]' \
        '-cache=+[cache dir]:dir:_files -/' \
        '*:source:_files -g "*.ss *.sld *.scm"'
}

_gxc "$@"
