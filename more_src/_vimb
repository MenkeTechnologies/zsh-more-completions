#compdef vimb
# Documentation: https://fanglingsu.github.io/vimb/man.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.
# Removed from prior file: -d/--dump-config (does not exist in upstream),
# -D/--no-maximize (does not exist), -x/--no-xembed (does not exist;
# XEmbed itself is deprecated upstream in the GTK4 build).
# Added: --bug-info from upstream.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display help options]' \
  '(- *)'{-v,--version}'[print build and version information]' \
  '(-C --cmd)*'{-C+,--cmd=}'[run CMD as ex command line before first page]:cmd:' \
  '(-c --config)'{-c+,--config=}'[use custom configuration file]:file:_files' \
  '(-e --embed)'{-e+,--embed=}'[embed in XEmbed-aware window (deprecated)]:winid:' \
  '(-i --incognito)'{-i,--incognito}'[start instance with user data read-only]' \
  '(-p --profile)'{-p+,--profile=}'[create or open specified configuration profile]:profile:' \
  '--bug-info[print library information for bug reports]' \
  '*:URI or file or "-":_files' && ret=0

return ret
