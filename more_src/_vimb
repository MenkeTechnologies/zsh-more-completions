#compdef vimb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-C --cmd)*'{-C+,--cmd=}'[run ex command before first page]:cmd:' \
  '(-e --embed)'{-e+,--embed=}'[embed in XEmbed-aware window]:winid:' \
  '(-i --incognito)'{-i,--incognito}'[incognito (read-only user data)]' \
  '(-p --profile)'{-p+,--profile=}'[profile name]:profile:' \
  '(-d --dump-config)'{-d,--dump-config}'[dump default config and exit]' \
  '(-D --no-maximize)'{-D,--no-maximize}'[do not maximize the window]' \
  '(-x --no-xembed)'{-x,--no-xembed}'[disable XEmbed]' \
  '*:url_or_file:_files' && ret=0

return ret
