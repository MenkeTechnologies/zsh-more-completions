#compdef bibtexparser
# _bibtexparser — sciunto bibtexparser CLI Python library command-line wrapper parsing BibTeX bibliography files .bib reading writing emitting normalized cross-referenced JSON YAML CSV output filtering by author year journal type validating duplicates DOI-resolving tags for citation pipelines (sciunto-org team, Python); custom argparse
# upstream: https://github.com/sciunto-org/python-bibtexparser

_bibtexparser() {
    local -a sub=(
        'parse:parse a BibTeX file'
        'write:write entries back to BibTeX'
        'convert:convert to JSON YAML CSV'
        'merge:merge multiple BibTeX files'
        'dedupe:remove duplicate entries'
        'validate:validate fields and types'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input]:file:_files -g "*.bib *.bibtex"' \
        '--input=+[file]:file:_files -g "*.bib *.bibtex"' \
        '-o+[output]:file:_files' \
        '--output=+[file]:file:_files' \
        '-f+[format]:f:(bib json yaml csv)' \
        '--format=+[format]:f:(bib json yaml csv)' \
        '--ignore-nonstandard-types[ignore non-standard types]' \
        '--customization=+[name]:str:' \
        '--encoding=+[enc]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bibtexparser subcommand' sub ;;
        args)
            _arguments '*:bib file:_files -g "*.bib"' ;;
    esac
}

_bibtexparser "$@"
