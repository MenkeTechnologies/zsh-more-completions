#compdef casr-cli
# Documentation: https://github.com/ispras/casr/blob/master/docs/usage.md
# View CASR reports and convert to SARIF format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --view)'{-v,--view}'=[view mode]:mode:(tree slider stdout)' \
  '(-u --unique)'{-u,--unique}'[print only unique crash lines in statistics]' \
  '--sarif=[generate SARIF report from CASR reports]:output:_files' \
  '--source-root=[source root path for SARIF generation]:path:_files -/' \
  '--tool=[tool name for SARIF report]:name' \
  '--strip-path=[path prefix to strip from crash path]:prefix' \
  '*:report:_files' && ret=0

return ret
