#compdef gparted

# Zsh completion for gparted - GNOME Partition Editor

_gparted_devices() {
  local -a devices
  devices=( /dev/sd*(N) /dev/nvme*(N) /dev/vd*(N) /dev/hd*(N) /dev/mmcblk*(N) )
  if [[ -d /sys/class/block ]]; then
    local -a sysdevs
    sysdevs=( /sys/class/block/*(N:t) )
    for d in $sysdevs; do
      [[ -b /dev/$d ]] && devices+=( /dev/$d )
    done
  fi
  # deduplicate
  devices=( ${(u)devices} )
  _values 'block device' ${devices[@]}
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:device:_gparted_devices'
