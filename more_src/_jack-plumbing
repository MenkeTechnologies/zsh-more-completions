#compdef jack-plumbing
# Documentation: https://github.com/jackaudio/jack-example-tools
# manage JACK connections from rule files

local ret=1

_arguments -s -S \
  '-d[do not operate as a daemon]' \
  '-o[do not load ordinary rule files]' \
  '-q[quiet operation]' \
  '-u+[microseconds after a notification to end a notification set]:usec' \
  '*:rule file:_files' && ret=0

return ret
