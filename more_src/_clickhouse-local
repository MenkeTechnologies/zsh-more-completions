#compdef clickhouse-local

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --query)'{-q,--query}'[query to execute]:query' \
  '--queries-file=[file with queries]:file:_files' \
  '(-m --multiquery)'{-m,--multiquery}'[execute multiple queries separated by semicolons]' \
  '(-N --table)'{-N,--table}'[name of the table]:table name' \
  '(-S --structure)'{-S,--structure}'[structure of the table]:structure' \
  '--input-format=[input format]:format:(CSV TSV JSONEachRow Parquet ORC Avro Native LineAsString RawBLOB)' \
  '(-f --file)'{-f,--file}'[input file]:file:_files' \
  '--output-format=[output format]:format:(CSV TSV JSONEachRow JSON JSONCompact Pretty PrettyCompact Vertical Markdown)' \
  '--stacktrace[print stack traces of exceptions]' \
  '--echo-queries[echo queries before execution]' \
  '--verbose[enable verbose logging]' \
  '--logger.console[log to console]' \
  '--logger.log=[log file]:file:_files' \
  '--logger.level=[log level]:level:(trace debug information warning error)' \
  '--path=[path to data directory]:directory:_directories' \
  '--max_threads=[maximum number of threads]:threads' \
  '--max_memory_usage=[maximum memory usage in bytes]:bytes' \
  '--max_block_size=[maximum block size]:size' \
  '--format_csv_delimiter=[CSV delimiter]:delimiter' \
  '--output_format_csv_crlf_end_of_line[use CRLF for CSV output]' \
  '--interactive[interactive mode]' \
  '--pager=[pager for output]:pager:_command_names' \
  '--progress[show progress]' \
  '*:file:_files' && ret=0

return ret
