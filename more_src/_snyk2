#compdef snyk2
# _snyk2 — Snyk snyk2 CLI command-line frontend wrapping the Snyk developer security platform find fix prevent and monitor known open-source vulnerabilities for npm Ruby Java Maven Gradle SBT Nuget pip pipenv poetry composer yarn berry yarn-workspaces yarn-pnpm Go-modules CocoaPods Hex Mix Cargo open-source-CLI written in TypeScript snyk-open-source snyk-code snyk-container snyk-iac snyk-aws snyk-azure snyk-gcp policy auth monitor test container iac log4shell sbom apps issues woke (Snyk team Guy Podjarny Geva Solomonovich, TypeScript); commander
# upstream: https://snyk.io/

_snyk2() {
    local -a sub=(
        'auth:authenticate'
        'apps:Snyk Apps management'
        'cli:meta CLI commands'
        'code:Snyk Code SAST scan'
        'config:configure CLI'
        'container:container scan'
        'fix:apply fixes'
        'help:show help'
        'iac:Infrastructure as Code scan'
        'ignore:add ignore'
        'log4shell:Log4Shell scan'
        'monitor:monitor for vulns'
        'policy:manage policies'
        'protect:legacy protect'
        'sbom:generate SBOM'
        'test:test for vulns'
        'version:show version'
        'woke:offensive language linter'
        'completion:generate shell completion'
        'aws:AWS account scan'
        'azure:Azure account scan'
        'gcp:GCP account scan'
        'issues:issue ops'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--token=+[token]:str:' \
        '--api=+[url]:str:' \
        '--org=+[name]:str:' \
        '--insecure[skip TLS verify]' \
        '--all-projects[scan all projects]' \
        '--detection-depth=+[N]:n:' \
        '--prune-repeated-subdependencies[prune repeated]' \
        '--exclude=+[paths]:str:' \
        '--strict-out-of-sync[strict out of sync]' \
        '--print-deps[print deps]' \
        '--print-graph[print graph]' \
        '--remote-repo-url=+[url]:str:' \
        '--severity-threshold=+[s]:s:(low medium high critical)' \
        '--fail-on=+[f]:f:(all upgradable patchable)' \
        '--json[JSON output]' \
        '--json-file-output=+[file]:file:_files -g "*.json"' \
        '--sarif[SARIF output]' \
        '--sarif-file-output=+[file]:file:_files -g "*.sarif"' \
        '--dev[include dev deps]' \
        '--show-vulnerable-paths=+[v]:v:(none some all)' \
        '--target-reference=+[ref]:str:' \
        '--project-name=+[name]:str:' \
        '--target-name=+[name]:str:' \
        '--project-business-criticality=+[c]:str:' \
        '--project-environment=+[env]:str:' \
        '--project-lifecycle=+[l]:str:' \
        '--project-tags=+[tags]:str:' \
        '--tags=+[tags]:str:' \
        '--policy-path=+[file]:file:_files' \
        '--ignore-policy[ignore policy]' \
        '--trust-policies[trust policies]' \
        '--file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '--package-manager=+[pm]:pm:(npm yarn pip poetry pipenv composer gradle maven gomodules golangdep sbt nuget cocoapods rubygems hex paket cargo)' \
        '--scan-all-unmanaged[scan all unmanaged]' \
        '--unmanaged[unmanaged]' \
        '--maven-aggregate-project[maven aggregate]' \
        '--scan-unmanaged[scan unmanaged]' \
        '--reachable[reachable]' \
        '--reachable-timeout=+[sec]:n:' \
        '--container-include-base-image-vulns[include base]' \
        '--exclude-base-image-vulns[exclude base]' \
        '--app-vulns[app vulns]' \
        '--platform=+[os/arch]:str:' \
        '--exclude-app-vulns[exclude app vulns]' \
        '--file-output=+[file]:file:_files' \
        '--config-matching-strategy=+[s]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snyk subcommand' sub ;;
        args)
            case $words[1] in
                container) _arguments '1:op:(test monitor)' '*:image:' ;;
                iac) _arguments '1:op:(test capture describe rules update-exclusions)' '*:arg:_files' ;;
                aws|azure|gcp) _arguments '*:arg:' ;;
                auth) _arguments '*:token:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_snyk2 "$@"
