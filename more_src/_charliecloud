#compdef ch-run

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b+[bind mount]:source\:dest' \
  '--bind=[bind mount]:source\:dest' \
  '-c+[initial working directory]:directory' \
  '--cd=[initial working directory]:directory' \
  '--gid=[run as GID]:gid' \
  '-j[use all host CPUs]' \
  '--join[use all host CPUs]' \
  '--join-ct=[number of peers]:count' \
  '--join-pid=[PID to join]:pid' \
  '--join-tag=[tag for peer group]:tag' \
  '--no-home[do not bind home directory]' \
  '--private[hide all host filesystems]' \
  '-t[bind /tmp]' \
  '--set-env=[set environment variable]:name=value' \
  '--uid=[run as UID]:uid' \
  '--unset-env=[unset environment variable]:name' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-w[mount image writable]' \
  '--write[mount image writable]' \
  '1:image directory:_directories' \
  '*::command:_command_names -e' && return 0
