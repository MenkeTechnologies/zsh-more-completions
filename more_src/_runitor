#compdef runitor
# Documentation: https://man.archlinux.org/search?q=runitor
# Reference accessed: 2026-05-16

# bdd.fi/x/runitor — Healthchecks.io / compatible runner.

_arguments -s -S \
  '--api-url=[API base URL]:url:_urls' \
  '--api-retries=[retries on transient errors]:count' \
  '--api-timeout=[per-request timeout]:duration' \
  '--ping-key=[project ping key]:key:' \
  '--slug=[check slug]:slug:' \
  '--create[create missing slug check]' \
  '--uuid=[check UUID]:uuid:' \
  '--every=[run command on interval]:duration' \
  '--at=[cron schedule expression]:cron:' \
  '--quiet[omit command stdout from capture]' \
  '--silent[omit stdout and stderr from capture]' \
  '--on-success=[ping kind on success]:kind:' \
  '--on-nonzero-exit=[ping kind on non-zero exit]:kind:' \
  '--on-exec-fail=[ping kind when exec fails]:kind:' \
  '--no-start-ping[omit start ping]' \
  '--no-output-in-ping[omit command output in pings]' \
  '--no-run-id[omit per-run id]' \
  '--ping-body-limit=[truncate ping body bytes]:bytes' \
  '--version[version]' \
  '*-req-header=[extra HTTP header as key\\: value]:header:' \
  '*::command:_default'
