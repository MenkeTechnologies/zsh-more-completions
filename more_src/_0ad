#compdef 0ad pyrogenesis
# Documentation: https://github.com/0ad/0ad/blob/master/binaries/system/readme.txt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-mod=[load mod]:mod:' \
  '-conf=[set config value KEY=VALUE]:opt:' \
  '-autostart=[autostart map]:map:' \
  '-autostart-host[host an autostart game]' \
  '-autostart-host-players=[number of players]:n:' \
  '-autostart-client=[connect as client]:host:' \
  '-autostart-ai=[set AI for player]:N\:AI:' \
  '-autostart-aidiff=[set AI difficulty]:N\:lvl:' \
  '-autostart-civ=[set civ for player]:N\:civ:' \
  '-autostart-team=[set team]:N\:team:' \
  '-autostart-seed=[set random seed]:seed:' \
  '-autostart-playername=[player name]:name:' \
  '-autostart-disable-replay[disable replay save]' \
  '-replay=[run replay]:file:_files' \
  '-replay-visual=[run replay visually]:file:_files' \
  '-rpgseed=[set RNG seed]:seed:' \
  '-archivebuild=[build archive from dir]:dir:_files -/' \
  '-archivebuild-output=[output archive]:file:_files' \
  '-archivebuild-compress[compress archive]' \
  '-test[run unit tests]' \
  '-testlist[list unit tests]' \
  '-shadows=[shadow quality]:val:' \
  '-quickstart[skip splash and start menu]' \
  '-editor[start in editor mode]' \
  '-userdir=[user data dir]:dir:_files -/' && ret=0

return ret
