#compdef lassplit
# Documentation: https://github.com/LAStools/LAStools
# LAStools: split a LAS/LAZ file into multiple files by various criteria

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display version information]' \
  '-gui[start with GUI]' \
  '-demo[run in demo mode]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '-by_classification[split based on classification code]' \
  '-by_gps_time_interval+[split into intervals of n seconds]:seconds' \
  '-by_intensity_interval+[split by intensity intervals]:n' \
  '-by_scan_angle_interval+[split by scan angle intervals]:n' \
  '-by_user_data_interval+[split by user data intervals]:n' \
  '-by_x_interval+[split by x coordinate intervals]:n' \
  '-by_y_interval+[split by y coordinate intervals]:n' \
  '-by_z_interval+[split by z coordinate intervals]:n' \
  '-by_attribute_interval+[split by extra byte attribute intervals]:n' \
  '-recover_flightlines[recover flight lines from GPS time gaps]' \
  '-recover_flightlines_interval+[recover flight lines using GPS interval]:n' \
  '-split+[split into files of n points each]:n' \
  '-split_offset+[add offset to split ID for filenames]:n' \
  '-update_point_source[rewrite point_source with split ID]' \
  '-point_source_offset+[additional offset for point_source]:n' \
  '-digits+[digits for naming split files (default 7)]:n' \
  '-rescale+[set new scale factors x y z]:x' \
  '-reoffset+[set new coordinate offsets x y z]:x' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output base name]:output:_files' \
  '-merged[merge inputs before splitting]' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
