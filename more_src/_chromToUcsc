#compdef chromToUcsc
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# change NCBI or Ensembl chromosome names to UCSC names

local ret=1

_arguments -s -S \
  '--get[download a chrom alias table from UCSC and exit]' \
  '(-a --chromAlias)'{-a,--chromAlias}'[UCSC chromAlias file in tab-sep format or URL]:file:_files' \
  '(-i --in)'{-i,--in}'[input filename (default /dev/stdin)]:file:_files' \
  '(-o --out)'{-o,--out}'[output filename (default /dev/stdout)]:file:_files' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-s --skipUnknown)'{-s,--skipUnknown}'[skip unknown sequence rather than error]' \
  '(-k --field)'{-k,--field}'[1-based index of field with chromosome name (default 1)]:n' \
  '*:file:_files' && ret=0

return ret
