#compdef zita-a2j
# ALSA capture to JACK bridge with resampling

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[print tracing information]' \
  '-L[force 16-bit and 2 channels]' \
  '-S[word clock sync, no resampling]' \
  '-w[wait until soundcard is available]' \
  '-j+[name as JACK client]:name' \
  '-d+[ALSA capture device]:device' \
  '-r+[sample rate]:rate' \
  '-p+[period size]:frames' \
  '-n+[number of fragments]:count' \
  '-c+[number of channels]:count' \
  '-Q+[resampling quality, 16..96]:quality' \
  '-I+[latency adjustment]:frames' && ret=0

return ret
