#compdef streamflow
# Documentation: https://streamflow.di.unito.it/documentation/latest/
# StreamFlow hybrid workflow management system

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:((
    run\:"execute a workflow"
    list\:"list executed workflows"
    prov\:"export workflow provenance"
    plugin\:"manage and inspect plugins"
    report\:"generate an execution report"
    ext\:"inspect StreamFlow extensions"
    schema\:"display the StreamFlow file schema"
    version\:"show version"
  ))' \
  '*::arg:_files' && ret=0

return ret
