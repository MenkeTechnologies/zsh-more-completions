#compdef losoto
# Documentation: https://revoltek.github.io/losoto/losoto.html
# LoSoTo (LOFAR Solution Tool) — process calibration solutions stored in H5parm.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show the version number and exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress standard output]' \
  '(-v -V --verbose)'{-v,-V,--verbose}'[enable detailed debug output]' \
  '(-f --filter)'{-f,--filter}'[filter on solution set names (used with -i)]:filter:' \
  '(-i --info)'{-i,--info}'[list information about the H5parm file]' \
  '(-d --delete)'{-d,--delete}'[delete a soltab using solset/soltab syntax]:soltab:' \
  '1:h5parm:_files -g "*.h5"' \
  '2:parset:_files' && ret=0

return ret
