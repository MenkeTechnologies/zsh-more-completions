#compdef create-admin-platform
# Documentation: https://www.npmjs.com/package/create-admin-platform
# Reference accessed: 2026-05-24
# Verified: npm view create-admin-platform bin; npm readme CLI Options table.

# Zsh completion for create-admin-platform - React admin console scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--preset=[project preset]:preset:(blank chain-bill minimal normal fintech)' \
  '--features=[comma-separated feature modules]:features:(mock admin security form-builder)' \
  '--router-mode=[router mode]:mode:(hash browser)' \
  '--theme=[initial theme key]:theme:(default fintech compact dark linear stripe apple ibm)' \
  '--registry=[npm registry URL for generated .npmrc]:url:' \
  '--link-workspace-root=[local scaffold source root override]:path:_directories' \
  '--interactive[force prompts even when project name is provided]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':project name:' && ret=0

return ret
