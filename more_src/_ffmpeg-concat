#compdef ffmpeg-concat
# Documentation: https://github.com/transitive-bullshit/ffmpeg-concat
# Concatenate videos with GL transitions between them

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-o --output)'{-o,--output}'[path to output mp4 file]:output:_files' \
  '(-t --transition-name)'{-t,--transition-name}'[name of gl-transition to apply]:name:' \
  '(-d --transition-duration)'{-d,--transition-duration}'[transition duration in ms]:ms:' \
  '(-T --transitions)'{-T,--transitions}'[JSON file of custom transitions]:file:_files' \
  '(-f --frame-format)'{-f,--frame-format}'[format for temporary frame images]:format:' \
  '(-c --concurrency)'{-c,--concurrency}'[number of videos to process in parallel]:number:' \
  '(-C --no-cleanup-frames)'{-C,--no-cleanup-frames}'[do not delete intermediate frame images]' \
  '(-O --temp-dir)'{-O,--temp-dir}'[temp directory for storing frame data]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose ffmpeg logging]' \
  '*:video:_files' && ret=0

return ret
