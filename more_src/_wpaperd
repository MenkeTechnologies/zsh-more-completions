#compdef wpaperd
# Documentation: https://man.archlinux.org/search?q=wpaperd
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-daemon[do not daemonize]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose output]'
