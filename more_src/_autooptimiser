#compdef autooptimiser
# Documentation: https://man.archlinux.org/search?q=autooptimiser
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[auto align mode]' \
  '-m[auto photometric mode]' \
  '-l[auto leveling]' \
  '-s[auto compute output size]' \
  '-n[no photometric]' \
  '-q[quiet]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
