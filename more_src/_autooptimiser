#compdef autooptimiser
# Documentation: https://hugin.sourceforge.io/docs/manual/Autooptimiser.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[auto align mode]' \
  '-m[auto photometric mode]' \
  '-l[auto leveling]' \
  '-s[auto compute output size]' \
  '-n[no photometric]' \
  '-q[quiet]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
