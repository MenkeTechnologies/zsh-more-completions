#compdef crm_shadow

# Pacemaker crm_shadow: manage shadow CIB instances for offline edits
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-c --create)'{-c,--create=}'[create shadow CIB copy]:name:' \
  '(-e --create-empty)'{-e,--create-empty=}'[create empty shadow CIB]:name:' \
  '(-w --which)'{-w,--which}'[show active shadow CIB]' \
  '(-p --display)'{-p,--display}'[display contents of active shadow]' \
  '(-d --diff)'{-d,--diff}'[diff shadow CIB against live CIB]' \
  '(-r --reset)'{-r,--reset=}'[reset shadow CIB from live]:name:' \
  '(-D --delete)'{-D,--delete=}'[delete shadow CIB]:name:' \
  '(-s --switch)'{-s,--switch=}'[switch to shadow CIB]:name:' \
  '(-C --commit)'{-C,--commit=}'[commit shadow to live CIB]:name:' \
  '(-f --force)'{-f,--force}'[do not prompt for confirmation]' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '(-F --file)'{-F,--file}'[use absolute file path]' \
  '*::crm_shadow args:_files' && ret=0
return ret
