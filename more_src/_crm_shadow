#compdef crm_shadow

# crm_shadow: shadow / sandbox copy of the CIB for testing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-w[which shadow is currently in use]' \
  '--which[which shadow is currently in use]' \
  '-d[display contents of named shadow]' \
  '--display[display contents of named shadow]' \
  '-D[delete shadow]:name:' \
  '--delete=[delete shadow]:name:' \
  '-r[reset shadow to live cib]' \
  '--reset[reset shadow to live cib]' \
  '-c[create shadow (copy of current)]:name:' \
  '--create=[create shadow (copy of current)]:name:' \
  '-e[create empty shadow]:name:' \
  '--create-empty=[create empty shadow]:name:' \
  '-s[switch to named shadow]:name:' \
  '--switch=[switch to named shadow]:name:' \
  '-C[commit shadow to live]:name:' \
  '--commit=[commit shadow to live]:name:' \
  '-f[force overwrite]' \
  '--force[force overwrite]' \
  '-b[batch mode (no prompts)]' \
  '--batch[batch mode (no prompts)]' \
  '*::crm_shadow args:_files' && ret=0
return ret
