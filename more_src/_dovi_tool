#compdef dovi_tool
# Documentation: https://github.com/quietvoid/dovi_tool
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dovi_tool: Dolby Vision metadata editor (RPU manipulation)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'info:display parsed RPU information'
  'generate:create binary RPU from various sources'
  'editor:modify binary RPU using JSON configuration'
  'export:convert binary RPU to text-based formats'
  'plot:generate graphical visualizations of metadata'
  'convert:transform RPU within single-layer HEVC files'
  'demux:separate dual-layer Dolby Vision into base and enhancement layers'
  'mux:combine enhancement layer with base layer bitstream'
  'extract-rpu:retrieve Dolby Vision RPU from HEVC files'
  'inject-rpu:insert RPU NAL units into HEVC bitstream'
  'remove:strip enhancement layer and RPU data'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --mode)'{-m,--mode}'[set conversion mode]:mode:(0 1 2 3 4)' \
  '--crop[set L5 active area offsets to zero (RPU only)]' \
  '--drop-hdr10plus[ignore HDR10+ metadata when processing]' \
  '--edit-config=[JSON config used to edit RPU]:file:_files' \
  '--start-code=[NAL unit start code length]:len:(four-bytes annex-b)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'dovi_tool command' commands && ret=0 ;;
esac

return ret
