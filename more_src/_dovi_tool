#compdef dovi_tool
# Documentation: https://man.archlinux.org/search?q=dovi_tool
# Reference accessed: 2026-05-16

# Zsh completion for dovi_tool Dolby Vision metadata editor

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-m --mode)'{-m,--mode}'[mode]:mode' \
  '(-i --input)'{-i,--input}'[input RPU/HEVC]:file:_files' \
  '(-o --output)'{-o,--output}'[output]:file:_files' \
  '*:: : _message "see dovi_tool --help"' && ret=0

return ret
