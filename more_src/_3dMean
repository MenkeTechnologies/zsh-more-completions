#compdef 3dMean
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dMean.html
# AFNI voxel-by-voxel mean of all input datasets

local ret=1

_arguments -s -S \
  '-verbose[display progress information]' \
  '-prefix[output dataset prefix name]:prefix:' \
  '-datum[output data type]:datum:(byte short float)' \
  '-fscale[force scaling of output to max integer range]' \
  '-gscale[uniform scaling across all sub-bricks]' \
  '-nscale[disable scaling for byte or short datasets]' \
  '-non_zero[exclude zero values from computations]' \
  '(-sd -stdev)-sd[compute standard deviation instead of mean]' \
  '(-sd -stdev)-stdev[compute standard deviation instead of mean]' \
  '-sqr[average squared values]' \
  '-sum[return sum without dividing by dataset count]' \
  '-count[count of non-zero voxels]' \
  '-max[maximum value at each voxel]' \
  '-min[minimum value at each voxel]' \
  '-absmax[maximum absolute value at each voxel]' \
  '-signed_absmax[max absolute value preserving sign]' \
  '-mask_inter[intersection mask from non-zero voxels]' \
  '-mask_union[union mask from non-zero voxels]' \
  '-weightset[weighting from a float-type volume]:dataset:_files' \
  '*:dataset:_files' && ret=0

return ret
