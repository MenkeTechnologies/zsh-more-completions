#compdef reorderPatches
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/
# Utility to reorder the patches of a case

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-patchOrder+[specify the list of patch names in the new order]:wordList:' \
  '-referenceCase+[specify the reference case path]:fileName:_files -/' \
  '-referenceRegion+[specify the reference region]:word:' \
  '-region+[specify alternative mesh region]:region:' \
  '-overwrite[overwrite existing data]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
