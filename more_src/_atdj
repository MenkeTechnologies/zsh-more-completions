#compdef atdj
# _atdj — generate Java JSON serialization from ATD definitions (ahrefs/atd)
# upstream: https://github.com/ahrefs/atd
# Flags from atdj/src/atdj_main.ml (Arg.parse spec).

_atdj() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-package=[package name of generated files]:package:' \
        '*:atd file:_files -g "*.atd"'
}

_atdj "$@"
