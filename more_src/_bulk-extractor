#compdef bulk-extractor
# _bulk-extractor — Simson Garfinkel bulk_extractor digital forensics tool CLI alias (simsong team, C++); custom argparse
# upstream: https://github.com/simsong/bulk_extractor

_bulk-extractor() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-o+[output dir]:dir:_files -/' \
        '-i[info mode]' \
        '-b+[banner file]:file:_files' \
        '-r+[alert list file]:file:_files' \
        '-w+[stop list file]:file:_files' \
        '-F+[regex list file]:file:_files' \
        '-f+[regex]:str:' \
        '-q+[quiet level]:n:' \
        '-s+[seek to byte]:n:' \
        '-Y+[start:end bytes]:str:' \
        '-G+[page size]:n:' \
        '-g+[margin]:n:' \
        '-j+[threads]:n:' \
        '-M+[max recursion depth]:n:' \
        '-m+[max sub-pages]:n:' \
        '-S+[name=value]:str:' \
        '-C+[char per output line]:n:' \
        '-d+[debug]:n:' \
        '-D+[hashdb dir]:dir:_files -/' \
        '-Z[zap]' \
        '-x+[disable scanner]:str:' \
        '-e+[enable scanner]:str:' \
        '-E+[only this scanner]:str:' \
        '-l[list scanners]' \
        '-p+[probe byte offset]:n:' \
        '-PB[print bytes]' \
        '-T+[temp dir]:dir:_files -/' \
        '-R+[recursive dir]:dir:_files -/' \
        '*:image file:_files'
}

_bulk-extractor "$@"
