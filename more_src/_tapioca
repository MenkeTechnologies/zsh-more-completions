#compdef tapioca
# Generate RBI type definitions for Sorbet from gems and DSLs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize Tapioca in the project'
      'configure:configure Tapioca'
      'annotations:pull community RBI annotations'
      'dsl:generate DSL RBI files'
      'gem:generate gem RBI files'
      'check-shims:check for unnecessary shim RBI definitions'
      'todo:generate todo RBI file for unresolved constants'
    )
    _describe -t commands 'tapioca command' commands && ret=0
    ;;
  args)
    _arguments \
      '--out[output directory]:dir:_files -/' \
      '--workers[number of workers]:n:' \
      '*:gem name:' && ret=0
    ;;
esac

return ret
