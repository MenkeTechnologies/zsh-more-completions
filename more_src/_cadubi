#compdef cadubi
# Documentation: https://manpages.debian.org/testing/cadubi/cadubi.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# CADUBI = "Creative ASCII Drawing Utility By Ian" (statico/cadubi).
# Interactive ASCII art editor. Manpage documents -h/--help, -m/--mute,
# -s/--size W H, -v/--version.

_arguments -s -S \
  '(- *)'{-h,--help}'[display documentation]' \
  '(- *)'{-v,--version}'[show version number]' \
  '(-m --mute)'{-m,--mute}'[turn off beeping]' \
  '(-s --size)'{-s,--size}'[set console size]:width:: :height:' \
  '*:file:_files'
