#compdef git-iris

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'gen:generate context-aware commit messages'
  'review:multi-dimensional code review'
  'changelog:generate Keep a Changelog format'
  'release-notes:produce user-focused release notes'
  'pr:generate PR descriptions'
  'config:configure AI provider'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'git-iris subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (gen)
        _arguments \
          '--print[print without committing]' \
          '-a[auto-commit]' && ret=0
        ;;
      (review)
        _arguments \
          '--from=[from branch]:branch:' \
          '--to=[to branch]:branch:' \
          '--commit=[specific commit]:hash:' && ret=0
        ;;
      (changelog)
        _arguments \
          '--from=[from version]:ver:' \
          '--update[update existing changelog]' && ret=0
        ;;
      (release-notes)
        _arguments '--from=[from version]:ver:' && ret=0
        ;;
      (pr)
        _arguments \
          '--from=[from branch]:branch:' \
          '--to=[to branch]:branch:' && ret=0
        ;;
      (config)
        _arguments \
          '--provider=[AI provider]:provider:(openai anthropic google)' \
          '--api-key=[API key]:key:' && ret=0
        ;;
    esac
    ;;
esac

return ret
