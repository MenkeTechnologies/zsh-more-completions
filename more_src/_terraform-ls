#compdef terraform-ls

_terraform-ls() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '1:command:_terraform-ls_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                serve)
                    _arguments \
                        '-port[Port number to listen on]:port:' \
                        '-log-file[Path to a file to log into]:file:_files' \
                        '-tcp[Use TCP for the transport]' \
                        '-cpuprofile[Path to CPU profile output]:file:_files' \
                        '-memprofile[Path to memory profile output]:file:_files' \
                        '-reqconcurrency[Number of concurrent requests]:number:' \
                        '-req-forwarding[Enable request forwarding]'
                    ;;
                completion)
                    _arguments \
                        '1:shell:(bash zsh fish)'
                    ;;
                inspect-module)
                    _arguments \
                        '-verbose[Enable verbose output]' \
                        '*:path:_directories'
                    ;;
            esac
            ;;
    esac
}

_terraform-ls_commands() {
    local -a commands
    commands=(
        'serve:Start the language server'
        'completion:Generate shell completion script'
        'inspect-module:Lists available information about a module'
        'version:Show version information'
    )
    _describe -t commands 'terraform-ls command' commands
}

_terraform-ls "$@"
