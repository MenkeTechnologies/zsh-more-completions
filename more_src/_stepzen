#compdef stepzen

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'init:initialize a StepZen project'
      'start:deploy and watch for changes'
      'deploy:deploy to StepZen'
      'request:execute a GraphQL request'
      'import:import data sources'
      'login:log in to StepZen'
      'logout:log out'
      'whoami:show current user'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments \
          '--endpoint=[endpoint name]:endpoint:' \
          '1:directory:_files -/' && ret=0
        ;;
      (start)
        _arguments \
          '--endpoint=[endpoint name]:endpoint:' \
          '--dashboard=[open dashboard]:when:(auto never always)' \
          '--dir=[project directory]:dir:_files -/' && ret=0
        ;;
      (deploy)
        _arguments \
          '--endpoint=[endpoint name]:endpoint:' \
          '--dir=[project directory]:dir:_files -/' && ret=0
        ;;
      (import)
        _arguments \
          '1:source type:(mysql postgresql curl graphql)' \
          '--name=[import name]:name:' \
          '--prefix=[prefix]:prefix:' \
          '--header=[HTTP header]:header:' \
          '--url=[data source URL]:url:' \
          '--db-host=[database host]:host:' \
          '--db-name=[database name]:name:' \
          '--db-user=[database user]:user:' \
          '--db-password=[database password]:password:' && ret=0
        ;;
      (request)
        _arguments \
          '--endpoint=[endpoint name]:endpoint:' \
          '--header=[HTTP header]:header:' \
          '--var=[variable]:key=value:' \
          '1:query or file:_files -g "*.graphql"' && ret=0
        ;;
    esac
    ;;
esac

return ret
