#compdef bitmex-cli bitmex
# _bitmex-cli — BitMEX bitmex-cli CLI command-line frontend wrapping the BitMEX cryptocurrency derivatives exchange Perpetual Futures Options REST WebSocket API managing accounts wallets orders trades positions market kline tickers depth funding leaderboard insurance-fund instruments execution liquidation withdraw deposit history (BitMEX team, Go); cobra
# upstream: https://www.bitmex.com/

_bitmex-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'wallet:wallet operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'execution:execution operations'
        'liquidation:liquidation operations'
        'funding:funding operations'
        'instrument:instrument operations'
        'insurance:insurance fund'
        'leaderboard:leaderboard operations'
        'market:market data'
        'kline:kline data'
        'ticker:ticker operations'
        'depth:order book'
        'deposit:deposit operations'
        'withdraw:withdrawal operations'
        'history:trade history'
        'announcement:announcement operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--testnet[use testnet]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bitmex-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel cancel-all amend history)' \
                    '--symbol=+[sym]:str:' \
                    '--side=+[s]:s:(Buy Sell)' \
                    '--order-type=+[t]:t:(Market Limit Stop StopLimit MarketIfTouched LimitIfTouched)' \
                    '--quantity=+[N]:n:' \
                    '--price=+[N]:str:' \
                    '--stop-price=+[N]:str:' \
                    '--exec-inst=+[i]:str:' \
                    '*:order id:' ;;
                account|wallet|trade|position|execution|liquidation|funding|instrument|insurance|leaderboard|deposit|withdraw|history|announcement) _arguments '1:op:(list get create update delete cancel)' '*:id:' ;;
                kline|ticker|depth|market) _arguments \
                    '--symbol=+[sym]:str:' \
                    '--bin-size=+[b]:b:(1m 5m 1h 1d)' \
                    '--count=+[N]:n:' ;;
            esac
            ;;
    esac
}

_bitmex-cli "$@"
