#compdef gtk4-rendernode-tool
# _gtk4-rendernode-tool — GNOME GTK4 gtk4-rendernode-tool CLI utility for inspecting transforming benchmarking GskRenderNode serialization format files used by GTK4 GPU GL Vulkan Cairo renderers loading reserializing converting to PNG diff replay-test benchmarking pipeline (GNOME team, C); custom argparse
# upstream: https://gitlab.gnome.org/GNOME/gtk

_gtk4-rendernode-tool() {
    local -a sub=(
        'info:show information about a rendernode'
        'show:display a rendernode in a window'
        'render:render to a PNG/SVG/PDF'
        'compare:compare two rendernodes'
        'benchmark:benchmark a rendernode'
        'extract:extract textures from a rendernode'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--renderer=+[r]:r:(default gl vulkan cairo opengl)' \
        '--num-runs=+[N]:n:' \
        '--no-gpu[disable GPU acceleration]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gtk4-rendernode-tool subcommand' sub ;;
        args)
            _arguments '*:rendernode file:_files -g "*.node *.png"'
            ;;
    esac
}

_gtk4-rendernode-tool "$@"
