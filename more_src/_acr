#compdef acr

_acr_subcommands() {
  local -a subcmds=(
    'build:Queue a new build request'
    'check-health:Check health of an ACR'
    'check-name:Check if an ACR name is available'
    'create:Create an Azure Container Registry'
    'credential:Manage login credentials'
    'delete:Delete an Azure Container Registry'
    'helm:Manage helm charts for ACR'
    'import:Import an image to ACR'
    'list:List Azure Container Registries'
    'login:Log in to an ACR'
    'manifest:Manage manifests in ACR'
    'network-rule:Manage network rules'
    'pack:Manage Buildpack tasks'
    'replication:Manage geo-replicated regions'
    'repository:Manage repositories in ACR'
    'run:Queue a run request'
    'scope-map:Manage scope maps'
    'show:Show details of an ACR'
    'show-endpoints:Show registry endpoints'
    'show-usage:Show storage usage for an ACR'
    'tag:Manage tags in ACR'
    'task:Manage tasks for ACR'
    'taskrun:Manage taskruns for ACR'
    'token:Manage tokens for ACR'
    'update:Update an Azure Container Registry'
    'webhook:Manage webhooks for ACR'
  )
  _describe -t commands 'acr subcommand' subcmds
}

_acr() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '--debug[Increase logging verbosity]' \
    '--only-show-errors[Only show errors]' \
    '--output[Output format]:format:(json jsonc table tsv yaml yamlc none)' \
    '--query[JMESPath query string]:query:' \
    '--subscription[Name or ID of subscription]:subscription:' \
    '--verbose[Increase logging verbosity]' \
    '1:subcommand:_acr_subcommands' \
    '*::arg:->args'
}

_acr "$@"
