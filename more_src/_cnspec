#compdef cnspec

# Zsh completion for cnspec (Mondoo security scanner)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'scan:scan a target for security issues'
  'shell:interactive security shell'
  'login:log in to Mondoo Platform'
  'logout:log out of Mondoo Platform'
  'status:show cnspec status and configuration'
  'vault:manage vault configuration'
  'policy:manage security policies'
  'bundle:manage policy bundles'
  'framework:manage compliance frameworks'
  'report:generate reports'
  'providers:manage and list providers'
  'version:display version information'
)

_arguments -s -S \
  '1:subcommand:->subcommand' \
  '--config=[path to config file]:config file:_files' \
  '--log-level=[set log level]:log level:(error warn info debug trace)' \
  '(-o --output)'{-o,--output=}'[set output format]:output format:(compact full json csv yaml junit2)' \
  '--score-threshold=[set minimum score threshold]:threshold:' \
  '(-t --target)'{-t,--target=}'[target to scan (e.g. ssh://user@host)]:target:' \
  '--asset-name=[set asset name]:asset name:' \
  '--annotation=[set annotation key=value]:annotation:' \
  '--policy=[policy to use]:policy name:' \
  '--policy-bundle=[path to policy bundle file]:policy bundle:_files' \
  '--incognito[run in incognito mode without uploading results]' \
  '--sudo[elevate privileges using sudo]' \
  '--record=[record session to file]:record file:_files' \
  '*:file:_files' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
esac

return ret
