#compdef phoronix-test-suite

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'benchmark:run a test or suite benchmark'
      'install:install a test or suite'
      'run:run a test or suite'
      'list-tests:list available tests'
      'list-suites:list available test suites'
      'list-installed-tests:list installed tests'
      'list-available-tests:list available tests from OpenBenchmarking.org'
      'info:show test/suite information'
      'test-info:show test information'
      'result-info:show result information'
      'merge-results:merge multiple result files'
      'remove-result:remove a saved result'
      'list-saved-results:list saved test results'
      'system-info:display system hardware/software info'
      'system-sensors:show available system sensors'
      'diagnostics:system diagnostics'
      'interactive:interactive benchmarking interface'
      'default-benchmark:run the default benchmark suite'
      'stress-run:run a stress test'
      'finish-run:finish an incomplete run'
      'batch-setup:set up batch mode defaults'
      'batch-benchmark:run benchmark in batch mode'
      'batch-install:install tests in batch mode'
      'batch-run:run tests in batch mode'
      'network-setup:set up Phoromatic network'
      'enterprise-setup:enterprise benchmarking setup'
      'dump-documentation:dump documentation'
      'version:show version'
      'help:show help'
      'download-test-profile:download a test profile'
      'search:search for tests'
      'openbenchmarking-login:log in to OpenBenchmarking.org'
      'openbenchmarking-refresh:refresh repository cache'
      'openbenchmarking-uploads:list OpenBenchmarking.org uploads'
      'upload-result:upload result to OpenBenchmarking.org'
      'clone-result:clone result from OpenBenchmarking.org'
      'compare-results-to-baseline:compare to baseline'
      'result-export:export result to CSV/PDF/JSON'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (benchmark|install|run|info|test-info|stress-run|batch-benchmark|batch-install|batch-run)
        _message 'test or suite name'
        ;;
      (result-info|merge-results|remove-result|upload-result|result-export|compare-results-to-baseline)
        _message 'result identifier'
        ;;
    esac
    ;;
esac

return ret
