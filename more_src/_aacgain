#compdef aacgain
# _aacgain — AACGain ReplayGain analyzer for AAC/MP4/M4A files (fork of mp3gain); writes ReplayGain tags + can apply lossless gain
# upstream: https://github.com/mvdh7/aacgain

_aacgain() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c[ignore clipping warnings]' \
        '-d+[modify suggested DB gain]:n:' \
        '-e[skip Album field calculation]' \
        '-f[force assume gain even with bad MPEG header]' \
        '-g+[apply gain (track or album)]:n:' \
        '-l+[apply default gain to file]:n:' \
        '-m+[modify suggested MP3 gain]:n:' \
        '-o[output stats only]' \
        '-p[preserve file modification timestamp]' \
        '-q[quiet]' \
        '-r[track gain (default)]' \
        '-a[album gain]' \
        '-s+[stored tag action]:action:(c d r m i)' \
        '-t[write only ReplayGain tags]' \
        '-u[undo gain change]' \
        '-w[lock files for write]' \
        '-x[only output stats]' \
        '-T[input files are tab-separated list]' \
        '-?[show help]' \
        '*:audio file:_files -g "*.(m4a|aac|mp4)"'
}

_aacgain "$@"
