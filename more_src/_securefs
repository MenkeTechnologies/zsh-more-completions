#compdef securefs
# Documentation: https://github.com/netheril96/securefs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'create:create a new encrypted filesystem'
      'c:create (alias)'
      'mount:mount an encrypted filesystem'
      'm:mount (alias)'
      'chpass:change password'
      'fix:fix a corrupted filesystem'
      'info:show information about an encrypted filesystem'
      'version:show version information'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      create|c)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--keyfile=[use keyfile instead of password]:file:_files' \
          '--max-padding=[maximum random padding bytes]:bytes:' \
          '--format=[filesystem format]:format:(lite full)' \
          '--case=[case sensitivity mode]:mode:' \
          '--uninorm=[Unicode normalization]:mode:' \
          ':data directory:_directories' && ret=0
        ;;
      mount|m)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-b[run in background]' \
          '--keyfile=[key file]:file:_files' \
          '--plain-text-names[disable filename encryption]' \
          '--log=[log file]:file:_files' \
          ':data directory:_directories' \
          ':mount point:_directories' && ret=0
        ;;
      chpass|fix|info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          ':data directory:_directories' && ret=0
        ;;
      version)
        ;;
    esac
    ;;
esac

return ret
