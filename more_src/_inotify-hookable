#compdef inotify-hookable
# Documentation: https://metacpan.org/pod/App::Inotify::Hookable
# blocking command-line interface to inotify

local ret=1

_arguments -s -S \
  '*'{-w+,--watch-directories=}'[watch a directory, repeatable]:directory:_files -/' \
  '*'{-f+,--watch-files=}'[watch a file, repeatable]:file:_files' \
  '(-r --recursive)'{-r,--recursive}'[recursively watch given directories (on by default)]' \
  '*'{-c+,--on-modify-command=}'[command to run when something is modified]:command:_command_names -e' \
  '*'{-C+,--on-modify-path-command=}'[regex=command pair run on matching modified path]:regex=command' \
  '(-t --buffer-time)'{-t+,--buffer-time=}'[microseconds to sleep while buffering events]:microseconds' \
  '*'{-i+,--ignore-paths=}'[regex of files/directories to ignore events for]:regex' \
  '(-d --debug)'{-d,--debug}'[spew out verbose debug output while running]' && ret=0

return ret
