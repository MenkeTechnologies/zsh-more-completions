#compdef sfstoltstr
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: Stolt stretch

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'vel=[stretch velocity]:vel:' \
  'eps=[stretch regularization]:eps:' \
  'pad=[padding]:pad:' \
  'nstretch=[number of stretch nodes]:nstretch:' \
  'inv=[apply inverse stretch (y/n)]:inv:(y n)' \
  '*: :_files' && ret=0

return ret
