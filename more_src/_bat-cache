#compdef bat-cache
# bat cache - Manage bat's syntax and theme cache

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'build:parse and serialize syntax/theme definitions into cache'
  'clear:remove cached syntax/theme definitions'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'bat-cache command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      build)
        _arguments \
          '--source=[directory with syntax/theme .sublime files]:directory:_files -/' \
          '--target=[directory to store cached files]:directory:_files -/' \
          '--blank[create a blank cache (ignore bundled assets)]' \
          '--acknowledgements[build acknowledgements document]' \
          && ret=0
        ;;
      clear)
        _arguments \
          '--target=[directory containing cached files to clear]:directory:_files -/' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
