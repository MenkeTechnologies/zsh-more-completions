#compdef asoundconf asoundconf-gtk

# asoundconf: simple ALSA configuration helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(get set unset reset is-active list set-default-card)' \
  '2:key:' \
  '3:value:' \
  '*::asoundconf args:_files' && ret=0
return ret
