#compdef asoundconf asoundconf-gtk
# Documentation: https://manpages.debian.org/bookworm/asoundconf/asoundconf.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# asoundconf: simple ALSA configuration helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(get set unset reset is-active list set-default-card)' \
  '2:key:' \
  '3:value:' \
  '*::asoundconf args:_files' && ret=0
return ret
