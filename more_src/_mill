#compdef mill

# Zsh completion for mill (Scala build tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '-i[Run in interactive mode (REPL)]' \
  '--interactive[Run in interactive mode (REPL)]' \
  '--no-server[Do not use a background server]' \
  '-s[Make ivy resolution quiet]' \
  '--silent[Make ivy resolution quiet]' \
  '-w[Watch and re-run on file changes]' \
  '--watch[Watch and re-run on file changes]' \
  '--no-default-preprocessor[Do not use default preprocessor]' \
  '-j+[Number of parallel threads]:threads' \
  '--jobs=[Number of parallel threads]:threads' \
  '-k[Continue building after failures]' \
  '--keep-going[Continue building after failures]' \
  '-d[Show debug output]' \
  '--debug[Show debug output]' \
  '--color=[Enable or disable colored output]:bool:(true false)' \
  '--ticker=[Enable or disable ticker output]:bool:(true false)' \
  '--disable-ticker[Disable ticker output]' \
  '--bsp[Run as BSP server]' \
  '--import=[Additional ivy dependencies to load]:dep' \
  '--meta-level=[Execute at the given meta-level]:level' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'resolve:Show matching tasks or targets'
      'inspect:Display task metadata'
      'show:Evaluate a task and print result'
      'showNamed:Evaluate tasks and print with names'
      'path:Show execution path between tasks'
      'plan:Show execution plan for a task'
      'visualize:Create a visual plan representation'
      'visualizePlan:Create a visual plan of the build graph'
      'clean:Delete generated files and caches'
      'shutdown:Stop the Mill server'
      'init:Generate example Mill build'
      'version:Print the Mill version'
    )
    _describe -t commands 'mill command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      resolve)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:pattern' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:task' && ret=0
        ;;
      show)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:task' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:task' && ret=0
        ;;
      init)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1::example ID' && ret=0
        ;;
      path)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:from task' \
          '2:to task' && ret=0
        ;;
      plan)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:task' && ret=0
        ;;
      visualize)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:task' && ret=0
        ;;
      visualizePlan)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:task' && ret=0
        ;;
    esac
    ;;
esac

return ret
