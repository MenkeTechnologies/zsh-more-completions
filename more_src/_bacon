#compdef bacon

# Zsh completion for bacon - background Rust code checker

local curcontext="$curcontext" state line ret=1

local -a jobs=(
  'check:run cargo check (default)'
  'clippy:run cargo clippy'
  'test:run cargo test'
  'doc:run cargo doc'
  'doc-open:run cargo doc --open'
  'run:run cargo run'
  'build:run cargo build'
  'expand:run cargo expand'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-j --job)'{-j,--job}'[initial job to run]:job:((${(j: :)jobs}))' \
  '--no-default-features[do not use default features]' \
  '--all-features[use all features]' \
  '(-f --features)'{-f,--features}'[space or comma separated list of features]:features:' \
  '--all-targets[check all targets]' \
  '--lib[check only lib target]' \
  '--bins[check all binary targets]' \
  '--bin[check specific binary]:binary:' \
  '--examples[check all example targets]' \
  '--example[check specific example]:example:' \
  '--tests[check all test targets]' \
  '--test[check specific test]:test:' \
  '--benches[check all benchmark targets]' \
  '--bench[check specific benchmark]:benchmark:' \
  '(-p --package)'{-p,--package}'[package to check]:package:' \
  '--workspace[check all workspace members]' \
  '--exclude[exclude packages from check]:package:' \
  '--target[target triple]:target:' \
  '--release[use release profile]' \
  '--profile[build profile]:profile:' \
  '--config[path to bacon config file]:file:_files -g "*.toml"' \
  '--prefs[path to prefs file]:file:_files -g "*.toml"' \
  '--no-gitignore[do not use .gitignore]' \
  '--path[path to cargo project]:directory:_files -/' \
  '--export-locations[export diagnostic locations]:file:_files' \
  '--headless[run in headless mode]' \
  '--summary[print summary on completion]' \
  '*:additional args:' && ret=0

return ret
