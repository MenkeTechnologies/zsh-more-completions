#compdef rekor-server
# _rekor-server — sigstore transparency log server (sigstore/rekor)
# upstream: https://github.com/sigstore/rekor
# Flags from cmd/rekor-server/app/root.go (cobra).

_rekor-server() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file]:file:_files' \
        '--log_type=[logger type]:type:(dev prod)' \
        '--enable_pprof[enable pprof on port 6060]' \
        '--trillian_log_server.address=[Trillian log server address]:host:' \
        '--trillian_log_server.port=[Trillian log server port]:port:' \
        '--trillian_log_server.tlog_id=[Trillian tree id]:id:' \
        '--trillian_log_server.sharding_config=[inactive shards config file]:file:_files' \
        '--trillian_log_server.grpc_default_service_config=[gRPC service config JSON]:json:' \
        '--trillian_log_server.tls[use TLS to Trillian server]' \
        '--trillian_log_server.tls_ca_cert=[Trillian TLS CA cert]:file:_files' \
        '--publish_frequency=[checkpoint publish frequency (minutes)]:minutes:' \
        '--rekor_server.hostname=[public hostname]:host:' \
        '--rekor_server.address=[bind address]:host:' \
        '--rekor_server.signer=[signer type]:signer:(memory awskms gcpkms hashivault filesystem tink)' \
        '--rekor_server.signer.gcpkms.retries=[GCP KMS retries]:n:' \
        '--rekor_server.signer.gcpkms.timeout=[GCP KMS RPC timeout (s)]:seconds:' \
        '--rekor_server.signer-passwd=[signer private key password]:password:' \
        '--rekor_server.tink_kek_uri=[Tink key encryption key URI]:uri:' \
        '--rekor_server.tink_keyset_path=[Tink encrypted keyset path]:file:_files' \
        '--rekor_server.new_entry_publisher=[pub/sub URL for new entries]:url:' \
        '--rekor_server.publish_events_protobuf[publish events in protobuf]' \
        '--rekor_server.publish_events_json[publish events in CloudEvents JSON]' \
        '--port=[port to bind to]:port:' \
        '--search_index.storage_provider=[search index storage]:provider:(redis mysql)' \
        '--redis_server.address=[Redis address]:host:' \
        '--redis_server.port=[Redis port]:port:' \
        '--redis_server.password=[Redis password]:password:' \
        '--redis_server.enable-tls[enable TLS to Redis]' \
        '--redis_server.insecure-skip-verify[skip Redis TLS verification]' \
        '--enable_attestation_storage[enable rich attestation storage]' \
        '--attestation_storage_bucket=[attestation storage bucket URL]:url:' \
        '--max_attestation_size=[max attestation size (bytes)]:bytes:' \
        '--enabled_api_endpoints=[comma-separated enabled API ops]:list:' \
        '--gcp_cloud_profiling.enabled[enable GCP Cloud Profiling]' \
        '--gcp_cloud_profiling.service=[GCP profiling service name]:name:' \
        '--gcp_cloud_profiling.service_version=[GCP profiling service version]:version:' \
        '--gcp_cloud_profiling.project_id=[GCP project ID]:id:' \
        '--gcp_cloud_profiling.enable_oc_telemetry[enable Cloud Tracing/Monitoring]' \
        '1: :->cmd'

    case $state in
        cmd)
            local -a cmds=(
                'serve:start the Rekor server'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_rekor-server "$@"
