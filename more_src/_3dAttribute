#compdef 3dAttribute
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dAttribute.html
# AFNI retrieve attribute values from dataset headers

local ret=1

_arguments -s -S \
  '-name[include attribute name in output]' \
  '-all[display all attributes; implies -name]' \
  '-center[show center of volume in RAI coordinates]' \
  '-ssep[separator string between multi-brick values]:sep:' \
  '-sprep[replace blanks in string attributes]:str:' \
  '-quote[wrap string values in single quotes]' \
  '*:dataset:_files' && ret=0

return ret
