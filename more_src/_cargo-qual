#compdef cargo-qual
# Source: cargo binstall cargo-quality@0.2.0
# Probed via: completions zsh
# Repository: https://github.com/RAprogramm/cargo-quality

autoload -U is-at-least

_cargo-qual() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-V[Print version]' \
'--version[Print version]' \
":: :_cargo-qual_commands" \
"*::: :->cargo-qual" \
&& ret=0
    case $state in
    (cargo-qual)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cargo-qual-command-$line[1]:"
        case $line[1] in
            (check)
_arguments "${_arguments_options[@]}" : \
'-a+[Run specific analyzer only (e.g., inline_comments, empty_lines)]:ANALYZER:_default' \
'--analyzer=[Run specific analyzer only (e.g., inline_comments, empty_lines)]:ANALYZER:_default' \
'-v[Show detailed output]' \
'--verbose[Show detailed output]' \
'-c[Enable colored output]' \
'--color[Enable colored output]' \
'::path -- Path to analyze (default\: current directory):_default' \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
'-a+[Run specific analyzer only (e.g., inline_comments, empty_lines)]:ANALYZER:_default' \
'--analyzer=[Run specific analyzer only (e.g., inline_comments, empty_lines)]:ANALYZER:_default' \
'-d[Dry run - show changes without applying]' \
'--dry-run[Dry run - show changes without applying]' \
'::path -- Path to analyze (default\: current directory):_default' \
&& ret=0
;;
(format)
_arguments "${_arguments_options[@]}" : \
'::path -- Path to analyze (default\: current directory):_default' \
&& ret=0
;;
(fmt)
_arguments "${_arguments_options[@]}" : \
'::path -- Path to format (default\: current directory):_default' \
&& ret=0
;;
(diff)
_arguments "${_arguments_options[@]}" : \
'-a+[Run specific analyzer only (e.g., inline_comments, empty_lines)]:ANALYZER:_default' \
'--analyzer=[Run specific analyzer only (e.g., inline_comments, empty_lines)]:ANALYZER:_default' \
'-s[Show brief summary only]' \
'--summary[Show brief summary only]' \
'-i[Interactive mode - select changes to apply]' \
'--interactive[Interactive mode - select changes to apply]' \
'-c[Enable colored output]' \
'--color[Enable colored output]' \
'::path -- Path to analyze (default\: current directory):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
':shell -- Shell to generate completions for:(bash fish zsh power-shell elvish)' \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(mod-rs)
_arguments "${_arguments_options[@]}" : \
'--fix[Apply fixes automatically]' \
'::path -- Path to analyze (default\: current directory):_default' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_cargo-qual_commands] )) ||
_cargo-qual_commands() {
    local commands; commands=(
'check:Check code quality without modifying files' \
'fix:Automatically fix quality issues' \
'format:Format code according to quality rules' \
'fmt:Format code using cargo +nightly fmt with project configuration' \
'diff:Show diff of proposed changes before applying' \
'help:Display beautiful help with examples and usage' \
'completions:Generate shell completions' \
'setup:Setup shell completions automatically' \
'mod-rs:Find and fix mod.rs files (convert to modern module style)' \
    )
    _describe -t commands 'cargo-qual commands' commands "$@"
}
(( $+functions[_cargo-qual__check_commands] )) ||
_cargo-qual__check_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual check commands' commands "$@"
}
(( $+functions[_cargo-qual__completions_commands] )) ||
_cargo-qual__completions_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual completions commands' commands "$@"
}
(( $+functions[_cargo-qual__diff_commands] )) ||
_cargo-qual__diff_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual diff commands' commands "$@"
}
(( $+functions[_cargo-qual__fix_commands] )) ||
_cargo-qual__fix_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual fix commands' commands "$@"
}
(( $+functions[_cargo-qual__fmt_commands] )) ||
_cargo-qual__fmt_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual fmt commands' commands "$@"
}
(( $+functions[_cargo-qual__format_commands] )) ||
_cargo-qual__format_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual format commands' commands "$@"
}
(( $+functions[_cargo-qual__help_commands] )) ||
_cargo-qual__help_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual help commands' commands "$@"
}
(( $+functions[_cargo-qual__mod-rs_commands] )) ||
_cargo-qual__mod-rs_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual mod-rs commands' commands "$@"
}
(( $+functions[_cargo-qual__setup_commands] )) ||
_cargo-qual__setup_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-qual setup commands' commands "$@"
}

if [ "$funcstack[1]" = "_cargo-qual" ]; then
    _cargo-qual "$@"
else
    compdef _cargo-qual cargo-qual
fi
