#compdef sugetqcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/sugetqcsv.c
# SUGETQCSV - write trace header key values and sample values to a Q-file

local ret=1

_arguments -s -S \
  'qout=[output Q-file for records]:f:_files' \
  'keys=[header key names to write]:k:' \
  'fsamp=[first sample to write]:f:' \
  'lsamp=[last sample to write]:l:' \
  'formsv=[format of sample values]:f:' \
  'formxy=[format of x-y coordinate values]:f:' \
  '*:SU file:_files' && ret=0

return ret
