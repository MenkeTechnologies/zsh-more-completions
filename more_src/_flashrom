#compdef flashrom

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-R,--version}'[show version]' \
  '(-r --read)'{-r+,--read=}'[read flash to file]:file:_files' \
  '(-w --write)'{-w+,--write=}'[write file to flash]:file:_files' \
  '(-v --verify)'{-v+,--verify=}'[verify flash against file]:file:_files' \
  '(-E --erase)'{-E,--erase}'[erase flash chip]' \
  '(-N --noverify)'{-N,--noverify}'[skip post-write verification]' \
  '--noverify-all[skip out-of-region verification]' \
  '(-V --verbose)*'{-V,--verbose}'[increase verbosity]' \
  '(-c --chip)'{-c+,--chip=}'[chip family/model]:chip:' \
  '(-p --programmer)'{-p+,--programmer=}'[programmer]:prog:(internal dummy nic3com nicrealtek nicnatsemi gfxnvidia drkaiser satasii satamv it8212 ft2232_spi serprog buspirate_spi dediprog rayer_spi nicintel nicintel_spi nicintel_eeprom ogp_spi linux_spi linux_mtd dummy ch341a_spi pony_spi nicrtl8169 ft4232h_spi mstarddc_spi pickit2_spi atavia stlinkv3_spi)' \
  '(-l --layout)'{-l+,--layout=}'[layout file]:file:_files' \
  '(-i --image)'{-i+,--image=}'[layout region name]:region:' \
  '--ifd[load layout from Intel Flash Descriptor]' \
  '--fmap[load layout from fmap]' \
  '--fmap-file=[load fmap from file]:file:_files' \
  '--extract[extract regions to files]' \
  '(-n --noverify)'{-n,--noverify}'[skip verification after writes]' \
  '--flash-name[print flash name]' \
  '--flash-size[print flash size]' \
  '--get-size[print flash size]' \
  '--wp-disable[disable hardware write protect]' \
  '--wp-enable[enable hardware write protect]' \
  '--wp-list[list write-protect ranges]' \
  '--wp-status[print write-protect status]' \
  '--wp-range=[start,len for protect range]:range:' \
  '--wp-region=[layout region for write protect]:region:' \
  '--progress[show progress]' \
  '-L[list supported devices]' \
  '-z[list supported programmers]' \
  '-o+[log file]:file:_files' \
  '--output=[log file]:file:_files' && ret=0

return ret
