#compdef cfssljson
# Documentation: https://man.archlinux.org/search?q=cfssljson
# Reference accessed: 2026-05-16

# Zsh completion for cfssljson - CFSSL JSON processor

_arguments -s -S \
  '-f[input file (use - for stdin)]:input file:_files' \
  '-stdout[output to stdout]' \
  '-bare[do not include .pem extension]' \
  '-cert[only output certificate]' \
  '-key[only output key]' \
  '-csr[only output CSR]'
