#compdef pxcat
# Documentation: https://github.com/FePhyFoFum/phyx/wiki/Program-list
# phyx pxcat: alignment concatenator.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-s+[input sequence files (wildcards ok)]:file:_files' \
  '-f+[file listing sequence files]:file:_files' \
  '-p+[output partition file]:file:_files' \
  '-o+[output concatenated alignment]:file:_files' && ret=0

return ret
