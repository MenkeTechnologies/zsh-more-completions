#compdef oasis
# _oasis-ssb — Oasis Secure Scuttlebutt social network web client (Node.js); local HTTP front-end to a ssb-server peer
# upstream: https://github.com/fraction/oasis

_oasis-ssb() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--port+[HTTP port]:port:' \
        '--host+[HTTP host]:host:_hosts' \
        '--public[bind to 0.0.0.0]' \
        '--open[open browser on launch]' \
        '--no-open[do not open browser]' \
        '--theme+[theme]:theme:(atelier-savanna gruvbox-dark gruvbox-light light-default unikitty-dark unikitty-light)' \
        '--debug[enable debug log]' \
        '--allow-host+[allowed host]:host:_hosts' \
        '*:ssb URI:'
}

_oasis-ssb "$@"
