#compdef otbcli_SARDeburst
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SARDeburst.html
# Orfeo ToolBox: deburst a Sentinel-1 IW SLC image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[raw Sentinel-1 IW SLC image input]:image:_files' \
  '-out[deburst output image]:output:_files' \
  '-onlyvalidsamples[output only valid samples]:bool:(true false)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
