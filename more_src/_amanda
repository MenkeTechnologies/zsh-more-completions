#compdef amanda
# _amanda — AMANDA Advanced Maryland Automatic Network Disk Archiver CLI alias (zmanda team, C); custom argparse
# upstream: https://github.com/zmanda/amanda

_amanda() {
    local -a sub=(
        'amadmin:administrative commands'
        'amaespipe:encryption helper'
        'amarchiver:create archive'
        'amaspell:check amanda config'
        'amcheck:check amanda config'
        'amcheckdump:check dump integrity'
        'amcleanup:cleanup after run'
        'amcleanupdisk:cleanup disk'
        'amcrypt:encryption helper'
        'amcrypt-ossl:openssl encryption'
        'amcryptsimple:simple encryption'
        'amdump:run amanda dump'
        'amfetchdump:fetch dump from tape'
        'amflush:flush holding disk'
        'amgetconf:get amanda config option'
        'amgpgcrypt:gpg encryption helper'
        'amgtar:gnu tar application'
        'amlabel:label tape'
        'amoverview:print backup overview'
        'amplot:plot amanda performance'
        'amrecover:interactive recovery'
        'amreport:generate report'
        'amrestore:restore from tape'
        'amrmtape:remove tape from catalog'
        'amserverconfig:setup server config'
        'amstar:star application'
        'amstatus:show status'
        'amtape:tape operations'
        'amtapetype:figure tape characteristics'
        'amvault:run vault job'
        'amverifytape:verify tape contents'
        'amzfs-sendrecv:zfs send/recv'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amanda subcommand' sub ;;
        args)
            case $words[1] in
                amadmin) _arguments \
                    '1:config:' \
                    '*:command:(version config force unforce force-bump unforce-bump force-no-bump unforce-no-bump no-reuse reuse find delete due bumpsize estimate testforce print listfile import export holding)' ;;
                amcheck) _arguments \
                    '1:config:' \
                    '-t[test config]' \
                    '-c[check client]' \
                    '-l[check local]' \
                    '-s[check server]' \
                    '-w[warning]' \
                    '-m+[mail]:str:' \
                    '-M+[mail]:str:' ;;
                amlabel) _arguments \
                    '1:config:' \
                    '2:label:' \
                    '-f[force]' ;;
                amrecover|amstatus|amreport) _arguments \
                    '1:config:' \
                    '-C+[config]:str:' \
                    '-s+[server]:host:_hosts' \
                    '-t+[tape]:str:' \
                    '-d+[device]:str:' ;;
                amrestore|amfetchdump) _arguments \
                    '*:tape file or host:' \
                    '-c[compress with gzip]' \
                    '-r[raw mode]' \
                    '-h[output to stdout]' \
                    '-n[no header]' \
                    '-p[pipe to stdout]' ;;
                amtape) _arguments \
                    '1:config:' \
                    '2:command:(taper reset eject clean show inventory current update label slot)' \
                    '*:argument:' ;;
            esac
            ;;
    esac
}

_amanda "$@"
