#compdef sustackup
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stacking/sustackup.c
# input any trace order and stack to any key combination

local ret=1

_arguments -s -S \
  'keyloc=[list of keys defining output stack trace locations]:keyloc' \
  'keyabs=[key name for absolute value range limit]:keyabs' \
  'keyabs2=[subtracted from keyabs then absolute valued]:keyabs2' \
  'minabs=[minimum absolute range limit]:minabs' \
  'maxabs=[maximum absolute range limit]:maxabs' \
  'keysign=[key name for signed value range limit]:keysign' \
  'keysign2=[subtracted from keysign before range]:keysign2' \
  'minsign=[minimum signed range limit]:minsign' \
  'maxsign=[maximum signed range limit]:maxsign' \
  'keep=[1 output all keyloc combos even if range eliminates traces, 0 only if in range]:keep:(0 1)' \
  'maxstack=[maximum amount of stacked output traces]:maxstack' \
  '*:file:_files' && ret=0

return ret
