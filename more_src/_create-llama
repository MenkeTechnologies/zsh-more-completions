#compdef create-llama
# Documentation: https://github.com/run-llama/create-llama
# create-llama - scaffold LlamaIndex-powered apps

local ret=1

_arguments -s -S \
  '--use-npm[bootstrap the application using npm]' \
  '--use-pnpm[bootstrap the application using pnpm]' \
  '--use-yarn[bootstrap the application using Yarn]' \
  '--framework=[select a framework to bootstrap with]:framework:(nextjs express fastapi)' \
  '--port=[select UI port]:port:' \
  '--post-install-action=[choose an action after installation]:action:(none runApp dependencies)' \
  '--vector-db=[select which vector database to use]:db:(none mongo pg pinecone milvus astra qdrant chroma weaviate llamacloud)' \
  '--llama-cloud-key=[provide a LlamaCloud API key]:key:' \
  '--ask-models[interactively select LLM and embedding models]' \
  '--use-case=[select which use case to use for the template]:usecase:' \
  '*:app-name:_files -/' && ret=0

return ret
