#compdef kong-operator
# Documentation: https://developer.konghq.com/operator/dataplanes/reference/metrics/operator/
# Reference accessed: 2026-05-19
# Verified: Kong Operator metrics docs (--metrics-bind-address default :8080)
# + sigs.k8s.io/controller-runtime zap Options.BindFlags for the --zap-* set.

# kong-operator: Kong Gateway Operator for Kubernetes manager binary.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--metrics-bind-address=[address the metrics endpoint binds to (default :8080)]:addr:' \
  '--health-probe-bind-address=[address the health probe endpoint binds to]:addr:' \
  '--enable-leader-election[enable leader election for controller manager]' \
  '--zap-devel[development mode (console encoder, debug level)]' \
  '--zap-encoder=[zap log encoding]:enc:(json console)' \
  '--zap-log-level=[zap log verbosity level]:level:(debug info error panic)' \
  '--zap-stacktrace-level=[level at and above which stacktraces are captured]:level:(info error panic)' \
  '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
  '--feature-gates=[comma-delimited set of key=value feature gates]:gates:' \
  '*::kong-operator args:_files' && ret=0
return ret
