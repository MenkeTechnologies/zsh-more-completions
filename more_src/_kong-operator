#compdef kong-operator
# Documentation: https://man.archlinux.org/search?q=kong-operator
# Reference accessed: 2026-05-16

# kong-operator: Kong Gateway Operator for Kubernetes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--enable-leader-election[enable leader election]' \
  '--zap-devel[zap dev mode]' \
  '--zap-encoder=[zap encoder]:enc:(json console)' \
  '--zap-log-level=[zap log level]:level:(debug info error)' \
  '--zap-stacktrace-level=[zap stacktrace level]:level:(info error panic)' \
  '--feature-gates=[feature gates]:gates:' \
  '*::kong-operator args:_files' && ret=0
return ret
