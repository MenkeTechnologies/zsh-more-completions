#compdef assert.sh
# _assert-sh — assert.sh tiny Bash assertion library (Lehmann Hauschild); JUnit-style assert API for shell tests
# upstream: https://github.com/lehmannro/assert.sh

_assert-sh() {
    _arguments \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-x --invariant)'{-x,--invariant}'[exit on first failure]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:script:_files -g "*.sh"'
}

_assert-sh "$@"
