#compdef surescsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/surescsv.c
# SURESCSV - surface consistent residual statics determination

local ret=1

_arguments -s -S \
  'sout=[output source statics Q-file]:f:_files' \
  'rout=[output receiver statics Q-file]:f:_files' \
  'skeyloc=[source location key name]:k:' \
  'rkeyloc=[receiver location key name]:k:' \
  'ckeyloc=[cdp location key name]:k:' \
  'cdivider=[cdp divider value]:c:' \
  'maxshift=[maximum static shift]:m:' \
  'maxcdps=[maximum number of cdps]:m:' \
  'maxsources=[maximum number of sources]:m:' \
  'maxreceivers=[maximum number of receivers]:m:' \
  'maxtraces=[maximum number of traces]:m:' \
  'numiter=[number of iterations]:n:' \
  'longwave=[long wavelength filter value]:l:' \
  'iuseoff=[use offset option]:i:(0 1)' \
  'useoff=[offset usage value]:u:' \
  'srderive=[source-receiver derivation option]:s:' \
  '*:SU file:_files' && ret=0

return ret
