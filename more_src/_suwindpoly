#compdef suwindpoly
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/suwindpoly.c
# window data to extract traces on or within a polygonal line or polygon

local ret=1

_arguments -s -S \
  'x=[list of X coordinates for vertices]:x' \
  'y=[list of Y coordinates for vertices]:y' \
  'file=[output filename(s)]:file:_files' \
  'xkey=[X coordinate header key]:xkey' \
  'ykey=[Y coordinate header key]:ykey' \
  'pass=[0 polyline mode, 1 interior to polygon, 2 exterior to polygon]:pass:(0 1 2)' \
  'dx=[unit increment distance in X direction]:dx' \
  'dy=[unit increment distance in Y direction]:dy' \
  'ilkey=[key for resulting inline index in polyline mode]:ilkey' \
  'xlkey=[key for resulting xline index in polyline mode]:xlkey' \
  'dw=[distance in X-Y units of extracted line to pass points]:dw' \
  '*:file:_files' && ret=0

return ret
