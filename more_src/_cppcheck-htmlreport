#compdef cppcheck-htmlreport
# Documentation: https://github.com/danmar/cppcheck/blob/main/htmlreport/cppcheck-htmlreport
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# danmar/cppcheck HTML report generator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--file=[input cppcheck XML file]:file:_files -g "*.xml"' \
  '--report-dir=[output directory for HTML report]:dir:_files -/' \
  '--source-dir=[directory containing source files]:dir:_files -/' \
  '--source-encoding=[source file encoding]:encoding:' \
  '--title=[report title]:title:' \
  '--checkers-report-file=[cppcheck checkers report file]:file:_files' \
  '--add-author-information=[blame info fields]:fields:' \
  '--blame-options=[options passed to git blame]:opts:' && ret=0

return ret
