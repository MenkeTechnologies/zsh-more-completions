#compdef stm32cubeide STM32CubeIDE
# _stm32cubeide — STMicroelectronics STM32CubeIDE CLI for the Eclipse-based IDE for STM32 microcontrollers supporting headless workspace project import build clean rebuild profile launch debug headless-build tool-chain selection (st team, Java); custom argparse
# upstream: https://www.st.com/en/development-tools/stm32cubeide.html

_stm32cubeide() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-data+[workspace dir]:dir:_files -/' \
        '-clean[clean workspace cache]' \
        '-application+[application]:a:(org.eclipse.cdt.managedbuilder.core.headlessbuild org.eclipse.equinox.app.error org.eclipse.equinox.console.application com.st.stm32cube.ide.mcu.gnumcumlibsutilities.gnumcuclassloaderapp)' \
        '-import+[project dir]:dir:_files -/' \
        '-importAll+[parent dir]:dir:_files -/' \
        '-build+[project[/buildconfig]]:str:' \
        '-cleanBuild+[project[/buildconfig]]:str:' \
        '-no-indexer[no indexer]' \
        '-vmargs+[JVM args]:str:' \
        '-nosplash[no splash]' \
        '-product+[product]:str:' \
        '-arch+[arch]:a:(x86 x86_64 ppc ppc64)' \
        '-os+[os]:o:(linux win32 macosx)' \
        '-ws+[ws]:w:(gtk win32 cocoa)' \
        '-launcher.appendVmargs[append vmargs]' \
        '-launcher.suppressErrors[suppress errors]' \
        '-launcher.openFile=+[file]:file:_files' \
        '-name+[name]:str:' \
        '-vm+[vm]:file:_files' \
        '-console[use console]' \
        '-noExit[no exit]' \
        '-perspective+[perspective]:str:' \
        '*:workspace:_files -/'
}

_stm32cubeide "$@"
