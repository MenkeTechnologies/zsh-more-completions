#compdef cdktf

# Zsh completion for CDK for Terraform (CDKTF CLI)

local curcontext="$curcontext" state line ret=1

local -a cdktf_commands
cdktf_commands=(
  'init:create a new cdktf project'
  'get:generate CDK constructs for Terraform providers and modules'
  'convert:convert a Terraform configuration to CDKTF'
  'deploy:deploy the given stacks'
  'destroy:destroy the given stacks'
  'diff:perform a diff on the given stack'
  'list:list stacks in the app'
  'synth:synthesize Terraform configuration'
  'watch:watch for file changes and redeploy'
  'output:print the output of a stack'
  'debug:get debug information'
  'login:log in to Terraform Cloud'
  'provider:manage providers'
  'completion:generate shell completion scripts'
)

local -a cdktf_global_flags
cdktf_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version number]'
  '--disable-plugin-cache-env[disable plugin cache]'
  '--log-level=[set log level]:level:(debug info warn error)'
  '--no-color[disable colorized output]'
)

_arguments -s -S \
  $cdktf_global_flags \
  '1:command:_describe -t commands command cdktf_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          $cdktf_global_flags \
          '--template=[the template to use]:template:(typescript python java csharp go)' \
          '--project-name=[project name]:name:' \
          '--project-description=[project description]:description:' \
          '--dist=[output directory]:directory:_directories' \
          '--local[use local storage for state]' \
          '--cdktf-version=[cdktf version]:version:' \
          '--from-terraform-project=[path to Terraform project]:directory:_directories' \
          '--enable-crash-reporting[enable crash reporting]' \
          '--providers=[list of providers to install]:providers:' \
          '--providers-force-local[force local providers]' && ret=0
        ;;
      get)
        _arguments -s -S \
          $cdktf_global_flags \
          '--output=[output directory]:directory:_directories' \
          '--language=[target language]:language:(typescript python java csharp go)' \
          '--force[regenerate all constructs]' \
          '--parallelism=[number of parallel provider generations]:number:' && ret=0
        ;;
      convert)
        _arguments -s -S \
          $cdktf_global_flags \
          '--language=[target language]:language:(typescript python java csharp go)' \
          '--provider=[providers to convert]:providers:' \
          '--stack=[stack name]:name:' \
          '1:terraform file:_files' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--auto-approve[skip interactive approval]' \
          '--outputs-file=[path to file for outputs]:file:_files' \
          '--outputs-file-include-sensitive-outputs[include sensitive outputs]' \
          '--ignore-missing-stack-dependencies[ignore missing stack dependencies]' \
          '--parallelism=[number of concurrent operations]:number:' \
          '--refresh-only[only refresh state]' \
          '--terraform-parallelism=[terraform parallelism]:number:' \
          '--no-tf-log[disable Terraform log output]' \
          '--skip-synth[skip synthesis step]' \
          '--var=[set a Terraform variable]:variable:' \
          '--var-file=[path to a Terraform variable file]:file:_files' \
          '*:stack:' && ret=0
        ;;
      destroy)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--auto-approve[skip interactive approval]' \
          '--ignore-missing-stack-dependencies[ignore missing stack dependencies]' \
          '--parallelism=[number of concurrent operations]:number:' \
          '--terraform-parallelism=[terraform parallelism]:number:' \
          '--no-tf-log[disable Terraform log output]' \
          '--skip-synth[skip synthesis step]' \
          '--var=[set a Terraform variable]:variable:' \
          '--var-file=[path to a Terraform variable file]:file:_files' \
          '*:stack:' && ret=0
        ;;
      diff)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--refresh-only[only refresh state]' \
          '--terraform-parallelism=[terraform parallelism]:number:' \
          '--no-tf-log[disable Terraform log output]' \
          '--skip-synth[skip synthesis step]' \
          '--var=[set a Terraform variable]:variable:' \
          '--var-file=[path to a Terraform variable file]:file:_files' \
          '1:stack:' && ret=0
        ;;
      synth)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--hcl[generate HCL output]' \
          '--json[generate JSON output]' \
          '*:stack:' && ret=0
        ;;
      list)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' && ret=0
        ;;
      output)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--outputs-file=[path to file for outputs]:file:_files' \
          '--outputs-file-include-sensitive-outputs[include sensitive outputs]' \
          '--skip-synth[skip synthesis step]' \
          '*:stack:' && ret=0
        ;;
      watch)
        _arguments -s -S \
          $cdktf_global_flags \
          '-a=[app command]:command:' \
          '--app=[app command]:command:' \
          '-o=[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--auto-approve[skip interactive approval]' \
          '--parallelism=[number of concurrent operations]:number:' \
          '--terraform-parallelism=[terraform parallelism]:number:' \
          '*:stack:' && ret=0
        ;;
      provider)
        local -a provider_commands
        provider_commands=(
          'add:add a provider to the project'
          'upgrade:upgrade a provider'
          'list:list installed providers'
        )
        _arguments -s -S \
          $cdktf_global_flags \
          '1:provider command:_describe -t commands command provider_commands' \
          '*::provider args:' && ret=0
        ;;
      login)
        _arguments -s -S \
          $cdktf_global_flags \
          '--tfe-hostname=[Terraform Enterprise hostname]:hostname:' && ret=0
        ;;
      *)
        _arguments -s -S $cdktf_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
