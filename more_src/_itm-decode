#compdef itm-decode
# Documentation: https://github.com/rtic-scope/itm
# itm-decode — parse and dump ARM Cortex-M ITM packets from a raw trace file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--ignore-eof[continue processing without halting at end-of-file]' \
  '--timestamps[enable timestamp decoding (requires --itm-freq)]' \
  '--itm-prescaler=[local timestamp prescaler]:prescaler:(1 4 16 64)' \
  '--itm-freq=[trace clock frequency in Hz]:hz:' \
  '--expect-malformed[expect malformed packets]' \
  '*:trace file:_files' && ret=0

return ret
