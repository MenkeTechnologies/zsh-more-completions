#compdef xpamb
# Documentation: https://github.com/ericmandel/xpa/blob/master/doc/pod/xpamb.pod
# XPA message bus: store and route data buffers between clients and servers

local ret=1

_arguments -s -S \
  '-data+[store a data buffer under a name]:name' \
  '-replace+[replace stored data with the same name]:name' \
  '-info+[associate an info string with stored data]:info string' \
  '-send+[broadcast a stored data buffer to a template]:name' \
  '-del+[delete a named data buffer]:name' \
  '*:argument' && ret=0

return ret
