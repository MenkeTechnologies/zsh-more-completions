#compdef sfafac
# Documentation: https://ahay.org/RSF/sfafac.html
# Madagascar: Wilson-Burg factorization

local ret=1

_arguments -s \
  'lag=[auxiliary output file name]:file:_files' \
  'nf=[factor coefficients]:int:' \
  'niter=[Wilson iterations]:int:' \
  'nn=[helix diameter]:int:' \
  'ompchunk=[OMP chunk size]:int:' \
  'stable=[stability flag (y/n)]:bool:(y n)' \
  'verb=[verbosity flag (y/n)]:bool:(y n)' \
  '*:rsf file:_files' && ret=0

return ret
