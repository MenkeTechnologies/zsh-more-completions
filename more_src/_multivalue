#compdef multivalue
# Documentation: https://apbs.readthedocs.io/en/latest/using/tools.html
# Evaluate OpenDX scalar data at user-specified points

local ret=1

_arguments -s \
  '1:CSV coordinates file:_files' \
  '2:OpenDX formatted file:_files -g "*.dx"' \
  '3:output file:_files' && ret=0

return ret
