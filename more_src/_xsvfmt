#compdef xsvfmt

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --delimiter)'{-d+,--delimiter=}'[CSV delimiter]:char:' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--align[align columns]' \
  '--minify[minify (no whitespace)]' \
  '*:csv_file:_files -g "*.csv"' && ret=0

return ret
