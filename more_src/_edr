#compdef edr
# Documentation: https://docs.elementary-data.com/oss/cli-commands
# Elementary data observability CLI (edr) - monitor, report, send-report

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--project-dir=[dbt project directory]:dir:_files -/' \
  '(-p --profiles-dir)'{-p,--profiles-dir=}'[dbt profiles.yml directory]:dir:_files -/' \
  '(-c --config-dir)'{-c,--config-dir=}'[Elementary config.yml directory]:dir:_files -/' \
  '--target-path=[output directory for logs/reports]:dir:_files -/' \
  '(-t --profile-target)'{-t,--profile-target=}'[Elementary target selection]:target' \
  '--project-profile-target=[dbt project target selection]:target' \
  '--select=[filter alerts/reports using selectors]:selector' \
  '(-s --slack-webhook)'{-s,--slack-webhook=}'[Slack channel webhook URL]:url' \
  '(-st --slack-token)'{-st,--slack-token=}'[Slack authentication token]:token' \
  '(-ch --slack-channel-name)'{-ch,--slack-channel-name=}'[target Slack channel]:channel' \
  '(-f --full-refresh-dbt-package)'{-f,--full-refresh-dbt-package=}'[force full refresh of incremental models]:bool:(true false)' \
  '(-d --days-back)'{-d,--days-back=}'[historical data collection limit]:days' \
  '--file-path=[local report save location]:file:_files' \
  '--file-name=[report filename for cloud platforms]:name' \
  '--s3-endpoint-url=[S3-compatible service endpoint]:url' \
  '(-tz --timezone)'{-tz,--timezone=}'[alert time calculation timezone]:tz' \
  '(-q --dbt-quoting)'{-q,--dbt-quoting=}'[control dbt quoting behavior]:quoting' \
  '--disable-samples=[disable data sampling in reports]:bool:(true false)' \
  '--project-name=[custom project name display]:name' \
  '--env=[environment designation]:env:(dev prod)' \
  '--suppression-interval=[alert suppression duration in hours]:hours' \
  '--override-dbt-project-config[override model-level configurations]' \
  '--google-service-account-path=[GCS service account keyfile]:file:_files' \
  '--aws-profile-name=[AWS profile name]:profile' \
  '1:command:(monitor report send-report)' \
  '*::arg:->args' && ret=0

return ret
