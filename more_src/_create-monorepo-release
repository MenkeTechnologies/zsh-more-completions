#compdef create-monorepo-release
# Documentation: https://www.npmjs.com/package/create-monorepo-release
# Reference accessed: 2026-05-24
# Verified: npm view create-monorepo-release bin; npx create-monorepo-release --help output.

# Zsh completion for create-monorepo-release - monorepo release automation CLI

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[display help]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' init release help && ret=0
    ;;
  args)
    case $line[1] in
      release)
        _arguments -C           '--dry-run[do not perform write operations]'           '--push[push changes and tags to remote branch]'           '--git.username=[git username for tagging]:user:'           '--git.email=[git email for tagging]:email:'           '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      *)
        _arguments -C           '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
