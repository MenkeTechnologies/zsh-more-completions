'--db=[Path to OpenCode SQLite database file]:PATH:_files' \
'--json=[Path to OpenCode usage JSON file]:PATH:_files' \
'--theme=[Theme to use for the application]:THEME:(auto dark light)' \
'--ignore-zero[Treat zero stored costs as missing and estimate them]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_oc-stats_commands" \
"*::: :->oc-stats" \
&& ret=0
