(( $+functions[_oc-stats_commands] )) ||
_oc-stats_commands() {
    local commands; commands=(
'cache:Manage the local cache of model pricing data' \
'completions:Generate shell completions for oc-stats' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'oc-stats commands' commands "$@"
