#compdef kioclient6
# _kioclient6 — KDE6 kioclient KIO command-line tool (KDE Project, C++); QCommandLineParser
# upstream: https://invent.kde.org/frameworks/kio

_kioclient6() {
    local -a sub=(
        'openProperties:open properties dialog'
        'exec:execute URL'
        'download:download a URL'
        'copy:copy a URL to another URL'
        'cp:copy a URL to another URL (alias)'
        'move:move/rename a URL'
        'mv:move/rename a URL (alias)'
        'remove:delete a URL'
        'rm:delete a URL (alias)'
        'stat:show metadata'
        'cat:print URL contents'
        'ls:list URL contents'
        'mkdir:create directory'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--commands[print supported commands]' \
        '--noninteractive[no interaction]' \
        '--overwrite[overwrite]' \
        '--platform=+[Qt platform plugin]:str:' \
        '--continue[continue on errors]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kioclient6 subcommand' sub ;;
        args)
            case $words[1] in
                exec|openProperties|download|stat|cat|ls|mkdir|remove|rm) _arguments '*:url:_urls' ;;
                copy|cp|move|mv) _arguments \
                    '1:src-url:_urls' \
                    '2:dst-url:_urls' ;;
            esac
            ;;
    esac
}

_kioclient6 "$@"
