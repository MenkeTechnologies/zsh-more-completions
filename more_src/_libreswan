#compdef ipsec pluto whack

local curcontext="$curcontext" state line ret=1
local -a commands

case $service in
  (ipsec)
    commands=(
      'addconn:add a connection'
      'auto:auto-control connections'
      'barf:create a debugging tarball'
      'briefstatus:brief status'
      'checknflog:check NFLOG capture'
      'checknss:check NSS DB'
      'fipsstatus:show FIPS status'
      'globalstatus:show global status'
      'initnss:initialize NSS DB'
      'newhostkey:create a new host RSA key'
      'pluto:start pluto IKE daemon'
      'rereadall:reread all secrets and certs'
      'rereadsecrets:reread ipsec.secrets'
      'restart:restart IPsec'
      'setup:start/stop/restart IPsec'
      'showhostkey:show host key in IPsec format'
      'shuntstatus:show shunt status'
      'start:start IPsec'
      'status:show status'
      'stop:stop IPsec'
      'trafficstatus:show traffic status'
      'unbound-control:unbound control wrapper'
      'verify:verify configuration'
      'whack:control pluto via whack'
    )
    _arguments -C \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'ipsec command' commands && ret=0 ;;
      (args)
        case $line[1] in
          (auto)
            _arguments \
              '--add[add connection]' \
              '--up[bring up]' \
              '--down[bring down]' \
              '--delete[delete]' \
              '--replace[replace]' \
              '--start[start]' \
              '--ready[ready]' \
              '--rereadsecrets[reread secrets]' \
              '--config+[config file]:file:_files' \
              '--asynchronous[async]' \
              '--ctlbase+[ctl base]:base:_files' \
              '*: :' && ret=0 ;;
          (status|trafficstatus|globalstatus|briefstatus)
            _arguments '*: :' && ret=0 ;;
          (*) _files ;;
        esac ;;
    esac ;;
  (pluto)
    _arguments -C \
      '(- *)--help[help]' \
      '(- *)--version[version]' \
      '--ctlbase+[ctl base]:base:_files' \
      '--config+[config file]:file:_files' \
      '--secretsfile+[secrets file]:file:_files' \
      '--ipsecdir+[ipsec dir]:dir:_files -/' \
      '--nssdir+[nss dir]:dir:_files -/' \
      '--ddos-mode+[DDoS mode]:m:(auto busy unlimited)' \
      '--debug+[debug flags]:f:' \
      '--debug-all[all debug]' \
      '--logfile+[log file]:file:_files' \
      '--syslog[log to syslog]' \
      '--no-syslog[no syslog]' \
      '--listen+[listen IP]:ip:' \
      '--listen-tcp[listen TCP]' \
      '--listen-udp[listen UDP]' \
      '--ikev1[allow IKEv1]' \
      '--ikev2[allow IKEv2]' \
      '--no-process-hold[no process hold]' \
      '--force-busy[force busy]' \
      '*: :' && ret=0 ;;
  (whack)
    _arguments -C \
      '(- *)--help[help]' \
      '--name+[connection name]:name:' \
      '--add[add]' \
      '--delete[delete]' \
      '--initiate[initiate]' \
      '--terminate[terminate]' \
      '--rekey-ike[rekey IKE]' \
      '--rekey-ipsec[rekey IPsec]' \
      '--status[status]' \
      '--trafficstatus[traffic status]' \
      '--briefstatus[brief status]' \
      '--shutdown[shutdown]' \
      '--listen[listen]' \
      '--unlisten[unlisten]' \
      '--ddos-busy[DDoS busy]' \
      '--ddos-unlimited[DDoS unlimited]' \
      '--ddos-auto[DDoS auto]' \
      '*: :' && ret=0 ;;
esac

return ret
