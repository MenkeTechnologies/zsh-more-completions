#compdef libreswan ipsec
# Documentation: https://manpages.debian.org/bookworm/libreswan/ipsec.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ipsec(8) manpage.

# libreswan (ipsec): IPsec management dispatcher
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'setup:start/stop/restart IPsec'
  'barf:dump diagnostic info'
  'auto:operate on connections'
  'whack:control daemon directly'
  'initnss:initialize NSS database'
  'checknss:verify NSS database'
  'import:import config'
  'checknflog:verify nflog setup'
  'stopnflog:stop nflog'
)
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--directory=[change to directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'ipsec command' commands && ret=0 ;;
esac
return ret
