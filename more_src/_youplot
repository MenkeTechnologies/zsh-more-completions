#compdef youplot

# Zsh completion for YouPlot (red-data-tools/YouPlot)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-t --transpose)'{-t,--transpose}'[transpose table]' \
  '(-H --no-header)'{-H,--no-header}'[no header row]' \
  '*::subcommand: _message "youplot bar line hist ...; see youplot --help"' && ret=0

return ret
