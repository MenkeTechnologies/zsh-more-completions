#compdef i3bar

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b+[bar ID]:bar ID:' \
  '--bar_id=[bar ID]:bar ID:' \
  '-s+[i3 IPC socket]:socket:_files' \
  '--socket=[i3 IPC socket]:socket:_files' \
  '-V[verbose mode]' \
  '--verbose[verbose mode]' && ret=0

return ret
