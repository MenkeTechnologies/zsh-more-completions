#compdef indigo-depict
# Documentation: https://lifescience.opensource.epam.com/indigo/indigo-depict.html
# Indigo molecule and reaction rendering utility

local ret=1

_arguments -s -S \
  '-help[print help message]' \
  '-w+[picture width in pixels]:width:' \
  '-h+[picture height in pixels]:height:' \
  '-bond+[average bond length in pixels (conflicts with -w and -h)]:length:' \
  '-margins+[horizontal and vertical margins in pixels]:margins:' \
  '-commentmargins+[margins around comment]:margins:' \
  '-thickness+[relative thickness factor (default 1.0)]:factor:' \
  '-hydro+[implicit hydrogen display mode]:mode:' \
  '-label+[atom label display mode]:mode:' \
  '(-arom -dearom)-arom[force aromatization]' \
  '(-arom -dearom)-dearom[force dearomatization]' \
  '-stereo+[stereogroups display mode]:mode:' \
  '-cdbwsa[center double bonds with adjacent stereo bond]' \
  '-query[treat input as a query molecule or reaction]' \
  '-idfield+[SDF/RDF field to put in place of %s in file names]:field:' \
  '-comment+[text comment above molecule or reaction]:comment:' \
  '-commentfield+[use SDF/RDF field as a comment]:field:' \
  '-commentname[use molecule/reaction name as a comment]' \
  '-commentsize+[comment font size factor (default 6)]:size:' \
  '-commentpos+[comment position]:pos:' \
  '-commentalign+[comment alignment]:align:' \
  '-coloring+[enable/disable coloring]:state:' \
  '-hlthick[highlight with thick lines and bold characters]' \
  '-hlcolor+[highlight color (0..255)]:color:' \
  '-bgcolor+[background color (0..255)]:color:' \
  '-basecolor+[default foreground color (0..255)]:color:' \
  '-aamcolor+[color of AAM indices (0..255)]:color:' \
  '-commentcolor+[color of the comment (0..255)]:color:' \
  '-atomnumbers[show atom numbers (debugging)]' \
  '-bondnumbers[show bond numbers (debugging)]' \
  '*:input file:_files' && ret=0

return ret
