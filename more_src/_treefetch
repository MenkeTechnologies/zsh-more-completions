#compdef treefetch
# Documentation: https://github.com/angelofallars/treefetch/blob/main/README.md
# treefetch - a plant-based system fetch tool made with Rust

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help message]' \
  '(-b --bonsai)'{-b,--bonsai}'[show a bonsai tree]' \
  '(-x --xmas)'{-x,--xmas}'[show a Christmas tree]' && ret=0

return ret
