#compdef ip-mptcp
# Documentation: https://man.archlinux.org/man/ip-mptcp.8.en
# ip mptcp - MPTCP path manager configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip mptcp command' \
      'endpoint[manage MPTCP endpoints]' 'limits[configure subflow limits]' \
      'monitor[track connection changes]' \
      'add[create new endpoint]' 'delete[remove existing endpoint]' \
      'show[display endpoint or limits]' 'flush[remove all endpoints]' \
      'set[modify subflow constraints]' \
      'id[numeric endpoint ID]' 'dev[network interface]' \
      'port[incoming subflow port]' 'signal[announce via ADD_ADDR]' \
      'subflow[create additional subflows]' 'laminar[subflows to announced addresses]' \
      'backup[mark subflows as backup]' 'nobackup[clear backup status]' \
      'fullmesh[subflow per known peer address]' 'nofullmesh[clear full-mesh]' \
      'implicit[system-created endpoint]' \
      'add_addr_accepted[max accepted ADD_ADDR options]' && ret=0
    ;;
esac

return ret
