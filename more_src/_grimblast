#compdef grimblast
# Documentation: https://github.com/hyprwm/contrib/blob/main/grimblast/grimblast.1.scd
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a actions=(
  'copy:copy screenshot to clipboard'
  'save:save screenshot to file'
  'copysave:copy and save screenshot'
  'edit:edit screenshot with $GRIMBLAST_EDITOR'
  'check:verify dependencies are installed'
  'usage:display help message'
)

local -a targets=(
  'screen:capture the entire screen'
  'output:capture the active output'
  'active:capture the active window'
  'area:select an area to capture'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --notify)'{-n,--notify}'[send notification after capture]' \
  '(-o --openparentdir)'{-o,--openparentdir}'[open parent dir via dbus notification]' \
  '(-e --expire-time)'{-e+,--expire-time=}'[notification expiry ms]:ms:' \
  '(-c --cursor)'{-c,--cursor}'[include cursor in capture]' \
  '(-f --freeze)'{-f,--freeze}'[freeze screen before selection]' \
  '(-w --wait)'{-w+,--wait=}'[wait before capture]:seconds:' \
  '(-s --scale)'{-s+,--scale=}'[scale factor]:scale:' \
  '(-t --filetype)'{-t+,--filetype=}'[output format]:type:(png ppm jpeg)' \
  '1:action:->action' \
  '2:target:->target' \
  '3:file:_files' && ret=0

case $state in
  (action)
    _describe -t actions 'action' actions && ret=0
    ;;
  (target)
    _describe -t targets 'target' targets && ret=0
    ;;
esac

return ret
