#compdef debpkg
# Documentation: https://manpages.debian.org/debpkg
# Source: debian/devscripts scripts/debpkg.pl — sanitised setuid wrapper around dpkg (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*::dpkg options:_default' \
    && ret=0

return ret
