#compdef eclipse
# _eclipse-cli — Eclipse IDE launcher (Java); cross-platform Eclipse Platform IDE
# upstream: https://github.com/eclipse-platform

_eclipse-cli() {
    _arguments \
        '-arch+[arch]:arch:(x86_64 aarch64 ppc64le)' \
        '-application+[application id]:id:' \
        '-clean[clear OSGi runtime config]' \
        '-configuration+[config dir]:dir:_files -/' \
        '-consoleLog[also log to console]' \
        '-data+[workspace]:dir:_files -/' \
        '-debug+[debug options]:file:_files' \
        '-dev+[dev paths]:path:' \
        '-eeRoots+[EE roots]:roots:' \
        '-feature+[feature id]:id:' \
        '-keyring+[secure storage]:file:_files' \
        '-noExit[do not exit]' \
        '-nl+[locale]:locale:' \
        '-noLazyRegistryCacheLoading[no lazy registry]' \
        '-nosplash[no splash]' \
        '-os+[os]:os:(linux macosx win32)' \
        '-password+[secure storage password]:file:_files' \
        '-perspective+[perspective id]:id:' \
        '-plugincustomization+[customization ini]:file:_files' \
        '-pluginCustomization+[customization ini]:file:_files' \
        '-product+[product id]:id:' \
        '-refresh[refresh workspace]' \
        '-showLocation+[show workspace path]:path:' \
        '-skipRegistryCacheLoading[skip registry cache]' \
        '-startup+[startup jar]:file:_files' \
        '-suppressErrors[suppress errors]' \
        '-user+[user dir]:dir:_files -/' \
        '-vm+[VM path]:file:_files' \
        '-vmargs+[VM args]:args:' \
        '-ws+[window system]:ws:(gtk cocoa win32)' \
        '*:file:_files'
}

_eclipse-cli "$@"
