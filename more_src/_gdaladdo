#compdef gdaladdo
# Documentation: https://gdal.org/programs/gdaladdo.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--long-usage[detailed usage]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-r+[resampling method (default nearest)]:resampling:(nearest average rms gauss cubic cubicspline lanczos average_magphase mode bilinear)' \
  '*-b+[band number]:band:' \
  '-minsize+[max width/height of smallest overview (default 256)]:n:' \
  '-ro[open dataset read-only]' \
  '-clean[remove all overviews]' \
  '*-oo+[open option]:NAME=VALUE:' \
  '--partial-refresh-from-source-timestamp[refresh based on source mtime]' \
  '--partial-refresh-from-projwin+[refresh region]:ulx uly lrx lry:' \
  '--partial-refresh-from-source-extent+[refresh by source extents]:filenames:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '1:input file:_files -g "*.(tif|tiff|vrt|nc|hdf|grib|grb)"' \
  '*:overview level:' && ret=0

return ret
