#compdef gdaladdo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-r+[resampling method]:resampling:(nearest average rms gauss cubic cubicspline lanczos average_magphase mode bilinear)' \
  '-b+[band number]:band:' \
  '-minsize+[minimum size for overviews]:n:' \
  '-ro[open dataset read-only]' \
  '-clean[remove all overviews]' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-oo+[open option]:NAME=VALUE:' \
  '--config+[config option]:NAME VALUE:' \
  '-q[quiet]' \
  '1:input file:_files -g "*.(tif|tiff|vrt|nc|hdf|grib|grb)"' \
  '*:overview level:' && ret=0

return ret
