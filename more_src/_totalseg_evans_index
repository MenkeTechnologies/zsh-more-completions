#compdef totalseg_evans_index
# Documentation: https://github.com/wasserth/TotalSegmentator
# Compute the Evans index from a brain CT/MR image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input image]:input:_files' \
  '-o[output file]:output:_files' \
  '-p[preview image]:preview:_files' \
  '*:arg:_files' && ret=0

return ret
