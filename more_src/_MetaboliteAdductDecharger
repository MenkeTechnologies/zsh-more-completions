#compdef MetaboliteAdductDecharger
# Documentation: https://www.openms.org/documentation/html/TOPP_MetaboliteAdductDecharger.html
# OpenMS: decharges and annotates adducts for metabolite features

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input file (featureXML)]:file:_files -g "*.featureXML"' \
  '-out_cm[output consensus map (consensusXML)]:file:_files' \
  '-out_fm[output feature map (featureXML)]:file:_files' \
  '-outpairs[output file (consensusXML)]:file:_files' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
