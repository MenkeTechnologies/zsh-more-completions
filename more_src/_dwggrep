#compdef dwggrep
# Documentation: https://github.com/LibreDWG/libredwg/blob/master/programs/dwggrep.1
# LibreDWG: search DWG files for a text string via regular expressions

local ret=1

_arguments -s -S \
  '-i[case-insensitive pattern]' \
  '-x[extended regex pattern]' \
  '(-c --count)'{-c,--count}'[print only the count of matched elements]' \
  '(-h --no-filename)'{-h,--no-filename}'[print no filename]' \
  '(-y --type)'{-y+,--type=}'[search only NAME entities or objects]:name:' \
  '(-d --dxf)'{-d+,--dxf=}'[search only DXF group NUM fields]:num:' \
  '(-t --text)'{-t,--text}'[search only in TEXT-like entities]' \
  '(-b --blocks)'{-b,--blocks}'[search also in all block definitions]' \
  '(-n --tables)'{-n,--tables}'[search only in table names]' \
  '--help[display help and exit]' \
  '--version[output version information and exit]' \
  '1:pattern:' \
  '*:DWG file:_files -g "*.(dwg|DWG)"' && ret=0

return ret
