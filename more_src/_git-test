#compdef git-test
# Documentation: https://github.com/mhagger/git-test/blob/master/README.md
# git test — run automated tests against a range of git commits and track results.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '1:command:(run add remove forget-results help)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      run)
        _arguments -s \
          '(-t --test)'{-t+,--test=}'[name of the test to run]:test:' \
          '*'{-v,--verbosity}'[increase verbosity]' \
          '*'{-q,--quiet}'[decrease verbosity]' \
          '(-f --force --retest)'{-f,--force}'[re-run test despite existing result]' \
          '(-f --force --retest)--retest[re-run test despite existing result]' \
          '--forget[forget existing results without retesting]' \
          '(-k --keep-going)'{-k,--keep-going}'[continue testing after a failure]' \
          '--stdin[read list of commits to test from stdin]' \
          '*:commit:__git_commits' && ret=0
        ;;
      add)
        _arguments -s \
          '(-t --test)'{-t+,--test=}'[name of the test to define]:test:' \
          '--forget[forget any existing results for this test]' \
          '--keep[keep any existing results for this test]' \
          '*:command:' && ret=0
        ;;
      remove|forget-results)
        _arguments -s \
          '(-t --test)'{-t+,--test=}'[name of the test]:test:' && ret=0
        ;;
    esac
    ;;
esac

return ret
