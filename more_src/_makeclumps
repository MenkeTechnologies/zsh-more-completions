#compdef makeclumps
# Documentation: https://starlink.eao.hawaii.edu/docs/sun255.htx/sun255ss6.html
# CUPID: create simulated data containing clumps and noise.

local ret=1

_arguments -s -S \
  'OUT=[output NDF with blurring and noise]:ndf:_files' \
  'MODEL=[output NDF excluding noise]:ndf:_files' \
  'OUTCAT=[output clump catalogue]:cat:_files' \
  'ANGLE=[position angle distribution]:dist:' \
  'BEAMFWHM=[spatial beam FWHM in pixels]:fwhm:' \
  'VELFWHM=[velocity resolution FWHM in pixels]:fwhm:' \
  'DECONV=[account for beam smoothing]:flag:(TRUE FALSE)' \
  'FWHM1=[clump FWHM distribution axis 1]:dist:' \
  'FWHM2=[clump FWHM distribution axis 2]:dist:' \
  'FWHM3=[clump FWHM distribution axis 3]:dist:' \
  'GRID=[regular grid border width]:n:' \
  'LBND=[lower pixel bounds of output]:bounds:' \
  'UBND=[upper pixel bounds of output]:bounds:' \
  'LIKE=[reference NDF for WCS]:ndf:_files' \
  'NCLUMP=[number of clumps per axis]:n:' \
  'PARDIST=[distribution shape]:dist:(Normal Uniform Poisson)' \
  'PEAK=[peak value distribution]:dist:' \
  'PRECAT=[catalogue before smoothing]:flag:(TRUE FALSE)' \
  'RMS=[Gaussian noise level]:rms:' \
  'SHAPE=[catalogue shape]:shape:(None Polygon Ellipse Ellipse2 Ellipse3)' \
  'TRUNC=[truncation level]:level:' \
  'VGRAD1=[velocity gradient distribution axis 1]:dist:' \
  'VGRAD2=[velocity gradient distribution axis 2]:dist:' \
  '*:ndf:_files' && ret=0

return ret
