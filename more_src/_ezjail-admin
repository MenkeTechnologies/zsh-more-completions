#compdef ezjail-admin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install a base jail flavour'
  'create:create a new jail'
  'console:attach to running jail'
  'list:list jails'
  'start:start jails'
  'stop:stop jails'
  'restart:restart jails'
  'startcrypto:start encrypted jails'
  'stopcrypto:stop encrypted jails'
  'config:configure jail'
  'delete:delete a jail'
  'archive:archive jails'
  'restore:restore from archive'
  'snapshot:take ZFS snapshot'
  'update:update sources/jails'
  'cryptoinit:initialize crypto jail'
  'freeze:freeze jail'
  'thaw:thaw jail'
  'troubleshoot:troubleshoot common issues'
  'log:show log'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ezjail-admin subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '-m[install ports]' \
          '-M[do not install ports]' \
          '-p[install ports tree]' \
          '-P[do not install ports tree]' \
          '-s[install src]' \
          '-S[do not install src]' \
          '-h[host]:host:_hosts' \
          '-r[release]:release:' && ret=0
        ;;
      (create)
        _arguments \
          '-b[bind interface]' \
          '-x[exclusive IP]' \
          '-f[flavour]:flavour:' \
          '-r[jail root]:dir:_files -/' \
          '-a[archive]:file:_files' \
          '-c[jail type]:type:(simple zfs bde geli)' \
          '-s[image size]:size:' \
          '-C[attach args]:args:' \
          '-z[parent ZFS dataset]:dataset:' \
          '-i[simple type alias]' \
          '*:jail/ip: ' && ret=0
        ;;
      (console)
        _arguments \
          '-f[force]' \
          '-e[exec command]:cmd:' \
          '*:jail: ' && ret=0
        ;;
      (config)
        _arguments \
          '-r[run state]:state:(run norun test)' \
          '-n[new name]:name:' \
          '-i[image action]:action:(attach detach fsck)' \
          '-z[new dataset]:dataset:' \
          '-c[new cpuset]:cpuset:' \
          '-f[new fib]:fib:' \
          '*:jail: ' && ret=0
        ;;
      (delete)
        _arguments \
          '-w[wipe all jail data]' \
          '-f[force]' \
          '*:jail: ' && ret=0
        ;;
      (archive)
        _arguments \
          '-A[archive without stop]' \
          '-f[force]' \
          '-a[archive file]:file:_files' \
          '-d[archive dir]:dir:_files -/' \
          '*:jail: ' && ret=0
        ;;
      (restore)
        _arguments \
          '-f[force]' \
          '-d[archive dir]:dir:_files -/' \
          '*:archive: ' && ret=0
        ;;
      (update)
        _arguments \
          '-s[source tree path or version]:src:' \
          '-p[also update ports]' \
          '-b[buildworld and installworld]' \
          '-i[install only]' \
          '-P[ports tree update]' \
          '-u[freebsd-update fetch+install]' \
          '-U[run freebsd-update]' && ret=0
        ;;
    esac
    ;;
esac

return ret
