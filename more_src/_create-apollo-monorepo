#compdef create-apollo-monorepo
# Documentation: https://www.npmjs.com/package/create-apollo-monorepo
# Reference accessed: 2026-05-23
# Verified: npm view create-apollo-monorepo bin; npm readme Flags section.

# Zsh completion for create-apollo-monorepo - Next.js + Apollo CMS monorepo scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--frontend-name=[frontend package.json name]:name:'   '--backend-url=[Apollo CMS submodule git URL]:url:'   '--backend-branch=[submodule branch to track]:branch:'   '(-d --db)'{-d,--db=}'[DATABASE_URL for backend]:url:'   '(-u --url)'{-u,--url=}'[NEXT_PUBLIC_SITE_URL]:url:'   '(-l --locale)'{-l,--locale=}'[NEXT_PUBLIC_DEFAULT_LOCALE]:locale:'   '--admin-prefix=[single-origin admin namespace; none to disable]:path:'   '--asset-prefix=[alias of --admin-prefix]:path:'   '--skip-install[do not run pnpm install]'   '--skip-submodule[do not add the git submodule]'   '(-h --help)'{-h,--help}'[show help]'   ':project directory:_directories' && ret=0

return ret
