#compdef kbd_mode kbd-mode
# _kbd-mode — Linux kbd kbd_mode (set or report the active Linux console keyboard mode: K_RAW (scancodes), K_MEDIUMRAW (kbd keycodes), K_XLATE (8-bit translated), K_UNICODE (UTF-8), K_OFF; -a/-k/-s/-u select the mode, -C picks target VT)
# upstream: https://github.com/legionus/kbd
# Flags from kbd src/kbd_mode.c on tip.

_kbd-mode() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a[ASCII (K_XLATE)]' \
        '-k[keycodes (K_MEDIUMRAW)]' \
        '-s[scancodes (K_RAW)]' \
        '-u[Unicode (K_UNICODE)]' \
        '-o[no input (K_OFF)]' \
        '-f[force]' \
        '-C+[VT device]:file:_files -g "/dev/tty*"'
}

_kbd-mode "$@"
