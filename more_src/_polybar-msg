#compdef polybar-msg

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[display help]' \
  '-p+[send to specific polybar PID]:PID:_pids' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'action:send action to a module'
      'cmd:send command to polybar'
      'hook:deprecated, use action instead'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (cmd)
        local -a cmds=(
          'quit:quit polybar'
          'restart:restart polybar'
          'hide:hide the bar'
          'show:show the bar'
          'toggle:toggle bar visibility'
        )
        _describe -t commands 'bar command' cmds && ret=0
        ;;
      (action)
        _message 'module action (format: #module.action or #module.action.data)'
        ;;
      (hook)
        _message 'module name and hook index'
        ;;
    esac
    ;;
esac

return ret
