#compdef basedpyright

# Zsh completion for basedpyright - fork of pyright type checker

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --project)'{-p,--project}'[path to pyrightconfig.json]:config file:_files' \
  '--pythonpath=[path to Python interpreter]:python:_files' \
  '--pythonplatform=[target platform]:platform:(Linux Darwin Windows All)' \
  '--pythonversion=[Python version]:version' \
  '--typeshedpath=[path to typeshed]:path:_directories' \
  '--venvpath=[path to venvs directory]:path:_directories' \
  '--createstub=[create type stub for package]:package' \
  '--dependencies[emit errors for dependencies]' \
  '--ignoreexternal[ignore external imports for stub generation]' \
  '--level=[type checking level]:level:(basic standard strict all)' \
  '--lib[use library code for type information]' \
  '--outputjson[output results in JSON format]' \
  '--skipunannotated[skip analysis of unannotated functions]' \
  '--stats[print detailed performance stats]' \
  '--threads=[number of threads]:threads' \
  '--verifytypes=[verify type completeness of package]:package' \
  '--verbose[verbose output]' \
  '--warnings[emit warnings]' \
  '(-w --watch)'{-w,--watch}'[watch for file changes]' \
  '*:file or directory:_files'
