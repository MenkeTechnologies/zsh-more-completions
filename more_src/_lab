#compdef lab

# Zsh completion for lab - GitLab command line client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'browse:open the GitLab page for the current project in a browser'
  'ci:work with GitLab CI pipelines and jobs'
  'clone:clone a remote project'
  'fork:fork a remote repository'
  'help:show help'
  'issue:describe, list, and create issues'
  'label:list, create, and delete labels'
  'merge-request:describe, list, and create merge requests'
  'mr:describe, list, and create merge requests'
  'milestone:describe, list, create, and delete milestones'
  'project:describe, list, and create projects'
  'project-list:list projects'
  'snippet:create, list, and delete snippets'
  'todo:describe, list, and create todos'
  'transfer:transfer a project to a new namespace'
  'user:list user information'
  'version:show version'
  'protect:protect a branch'
  'unprotect:unprotect a branch'
  'pipeline:work with GitLab CI pipelines'
  'merge-request-create:create a new merge request'
  'completion:generate shell completion'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '--no-pager[disable use of pager]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'lab command' commands && ret=0
    ;;
  args)
    case $words[1] in
      issue)
        local -a issue_commands=(
          'browse:browse an issue in browser'
          'close:close an issue'
          'create:create a new issue'
          'edit:edit an issue'
          'list:list issues'
          'note:add a comment to an issue'
          'reopen:reopen a closed issue'
          'show:show an issue'
          'subscribe:subscribe to an issue'
          'unsubscribe:unsubscribe from an issue'
        )
        _describe -t issue-commands 'issue command' issue_commands && ret=0
        ;;
      mr|merge-request)
        local -a mr_commands=(
          'approve:approve a merge request'
          'browse:browse a merge request in browser'
          'checkout:checkout a merge request locally'
          'close:close a merge request'
          'create:create a new merge request'
          'edit:edit a merge request'
          'list:list merge requests'
          'merge:merge a merge request'
          'note:add a comment to a merge request'
          'rebase:rebase a merge request'
          'reopen:reopen a closed merge request'
          'show:show a merge request'
          'subscribe:subscribe to a merge request'
          'unsubscribe:unsubscribe from a merge request'
          'thumb:thumbs up or down on a merge request'
          'unapprove:unapprove a merge request'
        )
        _describe -t mr-commands 'mr command' mr_commands && ret=0
        ;;
      ci)
        local -a ci_commands=(
          'artifacts:download CI artifacts'
          'cancel:cancel a CI pipeline'
          'create:create a new CI pipeline'
          'delete:delete a CI pipeline'
          'lint:lint .gitlab-ci.yml'
          'list:list pipelines'
          'retry:retry a CI pipeline'
          'run:run a CI pipeline'
          'status:show pipeline status'
          'trace:trace a job'
          'trigger:trigger a CI pipeline'
          'view:view a pipeline'
        )
        _describe -t ci-commands 'ci command' ci_commands && ret=0
        ;;
      project)
        local -a project_commands=(
          'browse:browse a project'
          'create:create a new project'
          'delete:delete a project'
          'list:list projects'
        )
        _describe -t project-commands 'project command' project_commands && ret=0
        ;;
      snippet)
        local -a snippet_commands=(
          'browse:browse a snippet'
          'create:create a new snippet'
          'delete:delete a snippet'
          'list:list snippets'
        )
        _describe -t snippet-commands 'snippet command' snippet_commands && ret=0
        ;;
      label)
        local -a label_commands=(
          'create:create a new label'
          'delete:delete a label'
          'list:list labels'
        )
        _describe -t label-commands 'label command' label_commands && ret=0
        ;;
      milestone)
        local -a milestone_commands=(
          'create:create a new milestone'
          'delete:delete a milestone'
          'list:list milestones'
        )
        _describe -t milestone-commands 'milestone command' milestone_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
