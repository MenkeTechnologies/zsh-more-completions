#compdef virt-xml
# _virt-xml — virt-manager virt-xml (apply libvirt domain XML add/edit/remove/build operations from the command line; --add-device, --edit, --remove-device, --build-xml; per-device flags like --disk, --network, --memory, --cpu, --boot, --graphics, --controller, --filesystem)
# upstream: https://github.com/virt-manager/virt-manager (virt-xml)
# Flags from virt-manager virtinst/virtxml.py on tip.

_virt-xml() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[libvirt URI]:uri:' \
        '--connect+[libvirt URI]:uri:' \
        '--add-device[add device]' \
        '--edit+[edit operation]:edit:' \
        '--remove-device[remove device]' \
        '--build-xml[print xml only]' \
        '--update[apply to running domain]' \
        '--print-diff[print diff only]' \
        '--print-xml[print xml only]' \
        '--define[redefine offline]' \
        '*--disk+[disk spec]:spec:' \
        '*--network+[net spec]:spec:' \
        '*--graphics+[graphics spec]:spec:' \
        '*--memory+[memory spec]:spec:' \
        '*--cpu+[cpu spec]:spec:' \
        '*--vcpus+[vcpu spec]:spec:' \
        '*--boot+[boot spec]:spec:' \
        '*--controller+[controller spec]:spec:' \
        '*--filesystem+[filesystem spec]:spec:' \
        '*--hostdev+[hostdev spec]:spec:' \
        '*--metadata+[metadata spec]:spec:' \
        '*--memorybacking+[memorybacking spec]:spec:' \
        '*--soundhw+[sound spec]:spec:' \
        '*--serial+[serial spec]:spec:' \
        '*--video+[video spec]:spec:' \
        '*--features+[features spec]:spec:' \
        '*--clock+[clock spec]:spec:' \
        '*--input+[input spec]:spec:' \
        '*--rng+[rng spec]:spec:' \
        '*--tpm+[tpm spec]:spec:' \
        '*--xml+[xpath xml]:spec:' \
        '*:domain:'
}

_virt-xml "$@"
