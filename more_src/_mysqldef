#compdef mysqldef
# Documentation: https://github.com/sqldef/sqldef
# Source: sqldef/sqldef cmd/mysqldef/mysqldef.go — declarative MySQL schema migration tool.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-u --user)'{-u+,--user=}'[MySQL user name]:user:_default' \
    '(-p --password)'{-p+,--password=}'[MySQL user password (overridden by MYSQL_PWD)]:password:_default' \
    '(-h --host)'{-h+,--host=}'[host to connect to the MySQL server]:host:_hosts' \
    '(-P --port)'{-P+,--port=}'[port for the connection]:port:_default' \
    '(-S --socket)'{-S+,--socket=}'[socket file to use for connection]:file:_files' \
    '--ssl-mode=[SSL connection mode]:mode:(PREFERRED REQUIRED DISABLED)' \
    '--ssl-ca=[file listing trusted SSL Certificate Authorities]:file:_files' \
    '--password-prompt[force password prompt]' \
    '--enable-cleartext-plugin[enable the clear text authentication plugin]' \
    '*--file=[read desired SQL from a file instead of stdin]:file:_files -g "*.sql"' \
    '--dry-run[do not run DDLs, just show them]' \
    '--check[exit code 2 when DDL would be applied (CI gate for drift)]' \
    '--apply[apply DDLs to the database]' \
    '--export[dump the current schema to stdout]' \
    '--enable-drop[enable destructive changes such as DROP]' \
    '--skip-view[skip managing views]' \
    '--before-apply=[execute the given SQL before applying regular DDLs]:sql:_default' \
    '*--config=[YAML configuration file]:file:_files -g "*.(yml|yaml)"' \
    '*--config-inline=[YAML configuration as inline string]:yaml:_default' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:database-or-sqlfile:_default' \
    && ret=0

return ret
