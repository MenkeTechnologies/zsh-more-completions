#compdef ora2pg
# Documentation: https://github.com/darold/ora2pg/blob/master/README
# Migrate an Oracle/MySQL/MSSQL database to a PostgreSQL compatible schema

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help]' \
  '(-a --allow)'{-a,--allow}'=[comma separated list of objects to allow from export]:objects' \
  '(-b --basedir)'{-b,--basedir}'=[set the default output directory]:dir:_files -/' \
  '(-c --conf)'{-c,--conf}'=[set an alternate configuration file]:file:_files' \
  '(-C --cdc_file)'{-C,--cdc_file}'=[file used to store/read SCN per table]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable verbose output]' \
  '(-D --data_type)'{-D,--data_type}'=[custom type replacement at command line]:types' \
  '(-e --exclude)'{-e,--exclude}'=[comma separated list of objects to exclude]:objects' \
  '(-g --grant_object)'{-g,--grant_object}'=[extract privilege from the given object type]:type' \
  '(-i --input)'{-i,--input}'=[file containing Oracle PL/SQL code to convert]:file:_files' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel process to send data to PostgreSQL]:jobs' \
  '(-J --copies)'{-J,--copies}'=[number of parallel connections to extract data from Oracle]:copies' \
  '(-l --log)'{-l,--log}'=[set a log file]:file:_files' \
  '(-L --limit)'{-L,--limit}'=[number of tuples extracted before writing to memory]:limit' \
  '(-m --mysql)'{-m,--mysql}'[export a MySQL database instead of an Oracle schema]' \
  '(-M --mssql)'{-M,--mssql}'[export a Microsoft SQL Server database]' \
  '(-n --namespace)'{-n,--namespace}'=[set the Oracle schema to extract from]:schema' \
  '(-N --pg_schema)'{-N,--pg_schema}'=[set PostgreSQL search_path]:schema' \
  '(-o --out)'{-o,--out}'=[set the path to the output file]:file:_files' \
  '(-O --options)'{-O,--options}'=[override any configuration parameter]:options' \
  '(-p --plsql)'{-p,--plsql}'[enable PLSQL to PLPGSQL code conversion]' \
  '(-P --parallel)'{-P,--parallel}'=[number of parallel tables to extract simultaneously]:num' \
  '(-q --quiet)'{-q,--quiet}'[disable progress bar]' \
  '(-r --relative)'{-r,--relative}'[use \\ir instead of \\i in psql scripts]' \
  '(-s --source)'{-s,--source}'=[set the Oracle DBI datasource]:dsn' \
  '(-S --scn)'{-S,--scn}'=[set the Oracle System Change Number]:scn' \
  '(-t --type)'{-t,--type}'=[set the export type]:type' \
  '(-T --temp_dir)'{-T,--temp_dir}'=[set a distinct temporary directory]:dir:_files -/' \
  '(-u --user)'{-u,--user}'=[set the Oracle database connection user]:user' \
  '(-v --version)'{-v,--version}'[show Ora2Pg version and exit]' \
  '(-w --password)'{-w,--password}'=[set the password of the Oracle database user]:password' \
  '(-W --where)'{-W,--where}'=[set the WHERE clause to apply to the Oracle query]:where' && ret=0

return ret
