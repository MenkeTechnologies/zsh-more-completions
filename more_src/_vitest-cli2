#compdef vitest-cli2 vitest2
# _vitest-cli2 — Anthony Fu Vladimir Tagirov vitest-cli2 CLI command-line frontend wrapping the Vitest a next generation testing framework powered by Vite next-generation Jest-compatible test runner powered by Vite open-source written in TypeScript Node also Anthony Fu Vue ecosystem maintainer fast unit test framework using Vite tests-snapshots smart-watcher-mode TypeScript-JSX-tooling-supported-out-of-the-box ESM-Jest-compatible-suite-of-snapshot-rich-mocking-built-in-coverage-thread-pool-browser-mode-shard-isolation-listing-related (Anthony Fu Vladimir Tagirov team, TypeScript); cac
# upstream: https://vitest.dev/

_vitest-cli2() {
    local -a sub=(
        'run:run tests once'
        'watch:run tests in watch mode'
        'related:run only related tests'
        'list:list tests'
        'bench:run benchmarks'
        'mergeReports:merge multiple JSON reports'
        'init:initialize Vitest in a project'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[root dir]:dir:_files -/' \
        '--root=+[dir]:dir:_files -/' \
        '-c+[config file]:file:_files -g "vitest.config.* vite.config.* *.ts *.js"' \
        '--config=+[file]:file:_files -g "vitest.config.* vite.config.* *.ts *.js"' \
        '-w[watch]' \
        '--watch[watch]' \
        '--watch-triggered-by=+[v]:str:' \
        '-u[update snapshot]' \
        '--update[update snapshot]' \
        '-t+[test name pattern]:str:' \
        '--testNamePattern=+[pattern]:str:' \
        '*--testNamePattern=+[pattern]:str:' \
        '--dir=+[dir]:dir:_files -/' \
        '--reporter=+[r]:r:(default verbose dot junit json html github-actions hanging-process tap tap-flat)' \
        '*--reporter=+[r]:r:(default verbose dot junit json html github-actions hanging-process tap tap-flat)' \
        '--coverage[enable coverage]' \
        '--coverage.enabled[enable coverage]' \
        '--coverage.provider=+[p]:p:(v8 istanbul custom)' \
        '--coverage.reporter=+[r]:str:' \
        '--coverage.reportsDirectory=+[dir]:dir:_files -/' \
        '--coverage.all[include all files]' \
        '--coverage.clean[clean coverage]' \
        '--coverage.include=+[glob]:str:' \
        '--coverage.exclude=+[glob]:str:' \
        '--passWithNoTests[pass with no tests]' \
        '--allowOnly[allow only]' \
        '--bail=+[N]:n:' \
        '--browser=+[name]:str:' \
        '--browser.enabled[enable browser]' \
        '--browser.headless[headless]' \
        '--browser.name=+[name]:str:' \
        '--browser.provider=+[p]:p:(playwright webdriverio)' \
        '--shard=+[N/M]:str:' \
        '--isolate=+[v]:v:(true false)' \
        '--no-isolate[no isolation]' \
        '--threads=+[v]:v:(true false)' \
        '--singleThread[single thread]' \
        '--maxThreads=+[N]:n:' \
        '--minThreads=+[N]:n:' \
        '--maxConcurrency=+[N]:n:' \
        '--maxWorkers=+[N]:n:' \
        '--minWorkers=+[N]:n:' \
        '--pool=+[p]:p:(threads forks vmThreads vmForks)' \
        '--mode=+[m]:str:' \
        '--api=+[host:port]:str:' \
        '--silent[silent]' \
        '--hideSkippedTests[hide skipped]' \
        '--diff=+[file]:file:_files' \
        '--diff.expand[expand diff]' \
        '--diff.maxDepth=+[N]:n:' \
        '--ui[open UI]' \
        '--open[open browser]' \
        '--inspect[inspect]' \
        '--inspect-brk[inspect break]' \
        '--inspector=+[v]:str:' \
        '--testTimeout=+[ms]:n:' \
        '--hookTimeout=+[ms]:n:' \
        '--slowTestThreshold=+[ms]:n:' \
        '--outputFile=+[file]:file:_files' \
        '--outputFile.json=+[file]:file:_files -g "*.json"' \
        '--outputFile.junit=+[file]:file:_files -g "*.xml"' \
        '--outputFile.html=+[file]:file:_files -g "*.html"' \
        '--retry=+[N]:n:' \
        '--changed[run only changed]' \
        '--changed.branch=+[ref]:str:' \
        '--changed.lastN=+[N]:n:' \
        '--logHeapUsage[log heap usage]' \
        '--no-color[no color]' \
        '--printConsoleTrace[print console trace]' \
        '--exclude=+[glob]:str:' \
        '*--exclude=+[glob]:str:' \
        '--includeTaskLocation[include task location]' \
        '--no-typecheck[no typecheck]' \
        '--typecheck.enabled[enable typecheck]' \
        '--typecheck.only[only typecheck]' \
        '--typecheck.tsconfig=+[file]:file:_files -g "tsconfig*.json"' \
        '--inspect-brk[debug brk]' \
        '--env=+[k=v]:str:' \
        '*--env=+[k=v]:str:' \
        '--workspace=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vitest subcommand' sub ;;
        args)
            case $words[1] in
                run|watch|related|list|bench) _arguments '*:filter:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_vitest-cli2 "$@"
