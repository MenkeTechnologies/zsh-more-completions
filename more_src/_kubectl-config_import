#compdef kubectl-config_import
# Documentation: https://github.com/rafi/kubectl-config-import
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-config_import (rafi/kubectl-config-import): merge kubeconfigs from
# a file, stdin, or a kubernetes secret. Positional [namespace] [secret].

_arguments -s -S \
  '(- *)'{-h,--help}'[show this help overview]' \
  '(-f --file)'{-f+,--file=}'[import kubeconfig from file]:file:_files' \
  '--url=[set server URL when importing secret]:url:' \
  '--jsonpath=[JSONPath for kubectl get secret]:jsonpath:' \
  '(-d --delete)'{-d,--delete}'[delete context interactively]' \
  '(-e --edit)'{-e,--edit}'[edit kubeconfig(s)]' \
  '*:args:_default'
