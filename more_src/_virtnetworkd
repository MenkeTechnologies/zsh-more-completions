#compdef virtnetworkd
# _virtnetworkd — libvirt virtnetworkd (per-driver daemon owning the virtual-network subsystem in the libvirt split-daemon architecture; -d daemonize, -f config file, -p pidfile, -t timeout seconds, -v verbose)
# upstream: https://gitlab.com/libvirt/libvirt (src/network)
# Flags from libvirt src/remote/remote_daemon.c on tip.

_virtnetworkd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d[daemonize]' \
        '-f+[config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-t+[timeout seconds]:seconds:'
}

_virtnetworkd "$@"
