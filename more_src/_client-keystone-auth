#compdef client-keystone-auth
# _client-keystone-auth — OpenStack Keystone client-go exec credential plugin
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from cmd/client-keystone-auth/main.go on tip.

_client-keystone-auth() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--keystone-url=[Keystone API URL]:url:_urls' \
        '--domain-name=[Keystone domain name]:name:' \
        '--user-name=[Keystone user name]:user:' \
        '--project-name=[Keystone project name]:name:' \
        '--password=[user password]:pw:' \
        '--cert=[client certificate file]:file:_files' \
        '--key=[client certificate key file]:file:_files' \
        '--cacert=[CA cert file]:file:_files' \
        '--application-credential-id=[application credential ID]:id:' \
        '--application-credential-name=[application credential name]:name:' \
        '--application-credential-secret=[application credential secret]:secret:' \
        '-v[klog verbosity level]:n:'
}

_client-keystone-auth "$@"
