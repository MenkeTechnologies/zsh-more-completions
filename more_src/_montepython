#compdef montepython MontePython.py
# Documentation: https://monte-python.readthedocs.io/en/latest/parser_mp.html
# MontePython: MCMC sampler for cosmological parameter estimation

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((run\:"run a sampler" info\:"analyze chains"))' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$line[1]" in
      run)
        _arguments -s -S \
          '-N[number of steps in the chain]:steps' \
          '(-o --output)'{-o,--output}'=[output folder]:folder:_files -/' \
          '(-p --param)'{-p,--param}'=[input parameter file]:file:_files -g "*.param"' \
          '(-c --covmat)'{-c,--covmat}'=[input covariance matrix]:file:_files -g "*.covmat"' \
          '(-j --jumping)'{-j,--jumping}'=[jumping method]:method:(global sequential fast)' \
          '(-m --method)'{-m,--method}'=[sampling method]:method:(MH NS PC CH IS Der Fisher)' \
          '-f[jumping factor]:factor' \
          '-T[sample from P^(1/T)]:temperature' \
          '--update=[covariance matrix update frequency]:steps' \
          '--superupdate=[update jumping factor and covmat]:steps' \
          '--superupdate-ar=[target acceptance rate for superupdate]:rate' \
          '--superupdate-ar-tol=[acceptance rate tolerance]:tol' \
          '--adaptive=[adaptive Metropolis starting step]:step' \
          '--adaptive-ts=[adaptive jumping factor starting step]:step' \
          '--minimize[minimize log likelihood before running]' \
          '--minimize-tol=[tolerance for minimize algorithm]:tol' \
          '--fisher[calculate Fisher matrix and stop]' \
          '--fisher-asymmetric[use asymmetric steps for Fisher]' \
          '--fisher-step-it=[Fisher step-size iterations]:iterations' \
          '--fisher-delta=[target delta log-likelihood for Fisher]:delta' \
          '--fisher-tol=[tolerance for Fisher iteration]:tol' \
          '--conf=[configuration file path]:file:_files -g "*.conf"' \
          '--chain-number=[user-assigned chain index]:number' \
          '(-r --restart)'{-r,--restart}'=[restart from last point in chain]:file:_files' \
          '(-b --bestfit)'{-b,--bestfit}'=[start from bestfit file]:file:_files -g "*.bestfit"' \
          '--silent[silence standard output]' && ret=0
        ;;
      info)
        _arguments -s -S \
          '--minimal[skip posterior distribution computation]' \
          '--bins=[histogram bins for posteriors]:bins' \
          '-T[raise posteriors to power T]:temperature' \
          '--plot-mean[show mean likelihood in 1D plots]' \
          '--short-title-1d[remove mean/confidence limits from titles]' \
          '--extra=[extra customization file for plots]:file:_files' \
          '--noplot[compute posteriors without plotting]' \
          '--noplot-2d[output only 1D posteriors]' \
          '--noplot-2d-diag[2D contours without 1D plots]' \
          '--contours-only[unfilled contours on 2D plots]' \
          '--all[output separate files for all subplots]' \
          '--ext=[output file extension]:ext:(pdf png eps)' \
          '--num-columns-1d=[1D plots per horizontal row]:columns' \
          '--fontsize=[plot font size]:size' \
          '--ticksize=[plot tick label size]:size' \
          '--line-width=[1D plot line width]:width' \
          '--decimal=[decimal places on tick labels]:places' \
          '--ticknumber=[number of ticks per axis]:number' \
          '--legend-style=[legend position]:style:(sides top)' \
          '--keep-non-markovian[include non-Markovian chain portion]' \
          '--keep-only-markovian[analyze only Markovian portion]' \
          '--keep-fraction=[fraction of chains to analyze post-burnin]:fraction' \
          '--want-covmat[calculate covariance matrix]' \
          '--plot-fisher[add Fisher ellipses to contours]' \
          '*:chain files or folders:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
