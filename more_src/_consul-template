#compdef consul-template

# Zsh completion for consul-template

_arguments -s -S \
  '-config[path to config file or directory]:path:_files' \
  '-consul-addr[address of the Consul agent]:address:' \
  '-consul-auth[Consul HTTP auth]:username\:password:' \
  '-consul-retry[enable Consul retry]' \
  '-consul-retry-attempts[max retry attempts]:attempts:' \
  '-consul-retry-backoff[retry backoff time]:duration:' \
  '-consul-retry-max-backoff[max retry backoff]:duration:' \
  '-consul-ssl[use HTTPS for Consul]' \
  '-consul-ssl-ca-cert[CA cert file]:file:_files' \
  '-consul-ssl-ca-path[CA cert directory]:dir:_files -/' \
  '-consul-ssl-cert[client cert file]:file:_files' \
  '-consul-ssl-key[client key file]:file:_files' \
  '-consul-ssl-server-name[Consul server name for SNI]:name:' \
  '-consul-ssl-verify[verify Consul SSL]' \
  '-consul-token[Consul ACL token]:token:' \
  '-consul-transport-dial-keep-alive[dial keep-alive]:duration:' \
  '-consul-transport-dial-timeout[dial timeout]:duration:' \
  '-consul-transport-max-idle-conns-per-host[max idle conns per host]:count:' \
  '-consul-transport-tls-handshake-timeout[TLS handshake timeout]:duration:' \
  '-dedup[enable template de-duplication mode]' \
  '-dry[dry run, print templates without writing]' \
  '-exec[command to execute]:command:' \
  '-exec-kill-signal[signal to send to child process]:signal:' \
  '-exec-kill-timeout[time to wait for child to exit]:duration:' \
  '-exec-reload-signal[signal to send for reload]:signal:' \
  '-exec-splay[splay time for exec]:duration:' \
  '-kill-signal[signal to listen for termination]:signal:' \
  '-log-level[log level]:level:(trace debug info warn err)' \
  '-max-stale[max staleness of a query]:duration:' \
  '-once[run template once and exit]' \
  '-pid-file[PID file]:file:_files' \
  '-reload-signal[signal for a graceful reload]:signal:' \
  '-retry[retry duration]:duration:' \
  '-syslog[send log output to syslog]' \
  '-syslog-facility[syslog facility]:facility:' \
  '-template[template config]:source\:dest\:cmd:' \
  '-vault-addr[Vault server address]:address:' \
  '-vault-grace[grace period for Vault lease renewal]:duration:' \
  '-vault-renew-token[renew Vault token]' \
  '-vault-retry[enable Vault retry]' \
  '-vault-ssl[use HTTPS for Vault]' \
  '-vault-ssl-ca-cert[CA cert for Vault]:file:_files' \
  '-vault-ssl-ca-path[CA cert directory for Vault]:dir:_files -/' \
  '-vault-ssl-cert[client cert for Vault]:file:_files' \
  '-vault-ssl-key[client key for Vault]:file:_files' \
  '-vault-ssl-verify[verify Vault SSL]' \
  '-vault-token[Vault token]:token:' \
  '-vault-unwrap-token[unwrap Vault token]' \
  '-wait[min:max time to wait before rendering]:wait:' \
  '-v[show version]' \
  '-version[show version]' && return 0
