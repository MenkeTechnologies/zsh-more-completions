#compdef ofonod ofono
# Documentation: https://man.archlinux.org/search?q=ofonod
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-b --block)'{-b,--block}'+[block these plugins]:plugins:' \
  '(-d --debug)'{-d,--debug}'+[debug patterns]:patterns:' \
  '(-n --nodetach)'{-n,--nodetach}'[do not detach from controlling terminal]' \
  '(-p --plugin)'{-p,--plugin}'+[specify plugin]:plugin:' \
  '(-P --noplugin)'{-P,--noplugin}'+[block plugin]:plugin:' \
  '(-s --syslog)'{-s,--syslog}'[use syslog]' \
  '(-u --user)'{-u,--user}'+[user to run as]:user:_users' && ret=0

return ret
