#compdef ofonod ofono
# Documentation: https://manpages.debian.org/testing/ofono/ofonod.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'+[debug patterns (comma/colon/space separated)]:patterns:' \
  '(-n --nodetach)'{-n,--nodetach}'[do not detach from controlling terminal]' && ret=0

return ret
