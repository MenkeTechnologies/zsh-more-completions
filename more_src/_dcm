#compdef dcm
# Documentation: https://dcm.dev/docs/cli/
# DCM (Dart Code Metrics) command-line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--show-installation-hint[show installation hint]' \
  '1:command:((
    init\:"set up DCM"
    run\:"run multiple DCM commands"
    analyze\:"report lint rule issues"
    analyze-widgets\:"evaluate Flutter widget quality"
    analyze-assets\:"identify image asset problems"
    analyze-structure\:"show file dependencies"
    fix\:"resolve analysis issues"
    format\:"format dart files"
    calculate-metrics\:"generate code metric reports"
    check-code-duplication\:"detect duplicate code"
    check-unused-code\:"identify unused declarations"
    check-unused-files\:"find unused Dart files"
    check-dependencies\:"analyze dependency problems"
    check-parameters\:"report parameter issues"
    check-unnecessarily-public-code\:"flag over-exposed code"
    check-unused-l10n\:"detect unused localization strings"
    check-exports-completeness\:"report incomplete exports"
  ))' \
  '*::args:_files' && ret=0

return ret
