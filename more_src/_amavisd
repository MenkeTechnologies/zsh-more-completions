#compdef amavisd amavisd-new
# Documentation: https://man.archlinux.org/search?q=amavisd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start daemon'
  'stop:stop daemon'
  'restart:restart daemon'
  'reload:reload config'
  'debug:run in debug mode'
  'debug-sa:run in SpamAssassin debug mode'
  'foreground:run in foreground'
  'status:show status'
  'check:check config'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-u --user)'{-u,--user}'+[run as user]:user:_users' \
  '(-g --group)'{-g,--group}'+[run as group]:group:_groups' \
  '(-X --no-altertab)'{-X,--no-altertab}'[suppress altertab]' \
  '(-D --debug)'{-D,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'amavisd command' commands && ret=0 ;;
esac

return ret
