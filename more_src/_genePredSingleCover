#compdef genePredSingleCover
# UCSC kent: create single-coverage genePred from overlapping gene predictions

local ret=1

_arguments -s -S \
  '-scores=[read gene-selection scores from this file (name chrom txStart score)]:file:_files' \
  '1:input genePred:_files' \
  '2:output genePred:_files' && ret=0

return ret
