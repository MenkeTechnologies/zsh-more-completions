#compdef bparams
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=reference-bparams
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bparams: show LSF mbatchd parameters
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-a[all parameters]' \
  '-l[long format]' \
  '*:param:' && ret=0
return ret
