#compdef bparams
# Documentation: https://man.archlinux.org/search?q=bparams
# Reference accessed: 2026-05-16

# bparams: show LSF mbatchd parameters
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-a[all parameters]' \
  '-l[long format]' \
  '*:param:' && ret=0
return ret
