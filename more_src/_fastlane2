#compdef fastlane2
# _fastlane2 — Felix Krause Twitter Fabric Fastlane fastlane2 CLI command-line frontend wrapping the fastlane the easiest way to automate beta deployments and releases for your iOS and Android apps open-source written in Ruby originally by Felix Krause now Google Fabric fastlane lanes match snapshot scan gym deliver supply pilot pem produce sigh fabric_app_distribution screengrab cert spaceship apple Fastfile Pluginfile Appfile actions plugins lanes available run setup init add_plugin install_plugins update_plugins remove_plugin (Fastlane team Felix Krause Google, Ruby); commander
# upstream: https://fastlane.tools/

_fastlane2() {
    local -a sub=(
        'add_plugin:add a plugin'
        'action:show action info'
        'actions:list all actions'
        'add_extra_platform:add custom platform'
        'completion:generate shell completion'
        'create_config_yaml:create CI config'
        'docs:open docs'
        'enable_crash_reporting:enable crash reporting'
        'enable_auto_complete:enable autocomplete'
        'env:show env info'
        'fastfile_lint:lint Fastfile'
        'gem-build:gem build'
        'help:show help'
        'init:initialize'
        'install_plugins:install Gemfile plugins'
        'lanes:list lanes'
        'list:list lanes'
        'match:sync iOS code signing'
        'new_action:scaffold a new action'
        'new_plugin:scaffold a new plugin'
        'plugins:plugin operations'
        'remove_plugin:remove a plugin'
        'run:run a single action'
        'search_plugins:search for plugins'
        'setup:setup fastlane'
        'update_plugins:update plugins'
        'snapshot:run snapshot'
        'scan:run scan tests'
        'gym:build app'
        'deliver:upload to App Store'
        'supply:upload to Play Store'
        'pilot:TestFlight ops'
        'pem:push notification cert'
        'produce:create new app'
        'sigh:provisioning profile'
        'cert:create cert'
        'spaceship:Spaceship operations'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--swift_server_port=+[port]:n:' \
        '--env=+[name]:str:' \
        '-e+[env]:str:' \
        '--env-file=+[file]:file:_files' \
        '--capture_output[capture output]' \
        '--troubleshoot[troubleshoot]' \
        '--show-actions[show actions]' \
        '--show-options[show options]' \
        '--skip_docs[skip docs]' \
        '--print_all[print all]' \
        '--filename=+[file]:file:_files' \
        '--fabric_path=+[path]:_files' \
        '--analytics[analytics]' \
        '--no-update-check[no update check]' \
        '--platform=+[p]:p:(ios android mac)' \
        '-p+[platform]:p:(ios android mac)' \
        '--app_identifier=+[id]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--team_id=+[id]:str:' \
        '--team_name=+[name]:str:' \
        '--scheme=+[name]:str:' \
        '--workspace=+[file]:_files' \
        '--project=+[file]:_files' \
        '--output_directory=+[dir]:dir:_files -/' \
        '--output_name=+[name]:str:' \
        '--configuration=+[name]:str:' \
        '--build_path=+[path]:_files' \
        '--archive_path=+[path]:_files' \
        '--export_method=+[m]:m:(app-store ad-hoc enterprise development)' \
        '--export_options=+[file]:_files' \
        '--include_bitcode=+[v]:v:(true false)' \
        '--clean[clean]' \
        '--skip_metadata[skip metadata]' \
        '--skip_screenshots[skip screenshots]' \
        '--force[force]' \
        '--api_key_path=+[file]:_files' \
        '--key_id=+[id]:str:' \
        '--issuer_id=+[id]:str:' \
        '*:lane:'
}

_fastlane2 "$@"
