#compdef wtfutil

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
  '(-m --module)'{-m,--module}'[display info about a module]:module name' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'save-secret:save a secret into the secret store'
    )
    _describe -t commands 'wtfutil command' cmds && ret=0
    ;;
esac
return ret
