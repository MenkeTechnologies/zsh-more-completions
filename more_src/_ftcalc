#compdef ftcalc
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftcalc.html
# Calculate FITS table column values from an expression

local ret=1

_arguments -s -S \
  'infile=[input table with optional extension]:infile:_files' \
  'outfile=[output modified-copy file]:outfile:_files' \
  'column=[column to write calculated values to]:column:' \
  'expression=[expression to calculate column values]:expression:' \
  'rows=[rows or ranges to process, default all]:rows:' \
  'element=[vector element to receive scalar result]:element:' \
  'tform=[TFORM datatype for new columns]:tform:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
