#             .help('h', 'Show help.').alias('h', 'help')
#             .version('V', 'Show version.', () =>
#               require('../../package').version).alias('V', 'version')
#     raw.githubusercontent.com openstf/stf master lib/cli/auth-ldap/
#         index.js
#       → module.exports.command = 'auth-ldap'
#       → module.exports.describe = 'Start an LDAP auth unit.'
#       → 14 typed options: app-url, ldap-bind-credentials,
#         ldap-bind-dn, ldap-search-class, ldap-search-dn,
#         ldap-search-field, ldap-search-scope, ldap-search-filter,
#         ldap-timeout, ldap-url, ldap-username-field, port,
#         secret
#
#   This entry is the TS-Node=171 leader bump that **CLOSES Axis
#   116 (LDAP / RFC-4511 directory access protocol)** at 1/1/1
#   — TRIPLE-171 landmark + 109th Axis closed — paired with R1046
#   _ldap_authz_proxy (Rust=171 OPENED via elonen/ldap_authz_proxy
#   on inejge/ldap3) and R1047 _signmykey (Go=171 continued via
#   signmykeyio/signmykey on go-ldap/ldap/v3).  R1049 on deck for
#   Rust=172 OPENING new Axis 117.
#
#   No completion for `stf` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_stf() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _stf_cmds=(
                'api:start the REST API server'
                'app:start the web frontend'
                'auth-ldap:start an LDAP auth unit'
                'auth-mock:start a mock (dev-only) auth unit'
                'auth-oauth2:start an OAuth2 auth unit'
                'auth-openid:start an OpenID auth unit'
                'auth-saml2:start a SAML2 auth unit'
                'device:start a single-device worker (spawned by provider)'
                'doctor:verify cluster wiring'
                'generate-fake-device:insert a fake device (test fixture)'
                'generate-fake-group:insert a fake group (test fixture)'
                'generate-fake-user:insert a fake user (test fixture)'
                'groups-engine:start the group-booking quota engine'
                'local:single-host quick-start bring-up'
                'log-rethinkdb:start the RethinkDB event-log writer'
                'migrate:run RethinkDB schema migrations'
                'notify-hipchat:start a HipChat notifier (legacy)'
                'notify-slack:start a Slack notifier'
                'poorxy:start the reverse-proxy front-end'
                'processor:start a background event processor'
                'provider:start a per-host device provider'
                'reaper:re-attach disconnected devices'
                'storage-plugin-apk:start the APK blob store plugin'
                'storage-plugin-image:start the screenshot blob store plugin'
                'storage-s3:start the S3 blob backend'
                'storage-temp:start the tmp blob backend'
                'triproxy:start the ZeroMQ input bus'
                'websocket:start the WebSocket gateway'
            )
            _describe -t commands 'stf unit' _stf_cmds && ret=0
            ;;
        args)
            case $words[1] in
                auth-ldap)
                    _arguments \
                        '(-a --app-url)'{-a,--app-url}'=[URL to the app unit (required)]:url:' \
                        '(-u --ldap-url)'{-u,--ldap-url}'=[URL to the LDAP server (required)]:url:' \
                        '--ldap-bind-credentials=[LDAP bind credentials]:password:' \
                        '--ldap-bind-dn=[LDAP bind DN]:dn:' \
                        '--ldap-search-class=[LDAP search objectClass (default top)]:class:' \
                        '--ldap-search-dn=[LDAP search DN (required)]:dn:' \
                        '--ldap-search-field=[LDAP search field (required)]:field:' \
                        '--ldap-search-scope=[LDAP search scope (default sub)]:scope:(base one sub)' \
                        '--ldap-search-filter=[LDAP search filter]:filter:' \
                        '(-t --ldap-timeout)'{-t,--ldap-timeout}'=[LDAP timeout ms (default 1000)]:ms:' \
                        '--ldap-username-field=[LDAP username field (default cn)]:field:' \
                        '(-p --port)'{-p,--port}'=[port to bind to (default 7120)]:port:' \
                        '(-s --secret)'{-s,--secret}'=[JWT signing secret]:secret:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_stf "$@"
