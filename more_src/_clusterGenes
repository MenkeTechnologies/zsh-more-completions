#compdef clusterGenes
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/hg/geneBounds/clusterGenes/clusterGenes.c
# Cluster genes from genePred tracks

local ret=1

_arguments -s -S \
  '-verbose=[print debugging info: 0 for none, 3 for loads]:n:' \
  '*-chrom=[just work this chromosome, maybe repeated]:chrom:' \
  '-cds[cluster only on CDS exons, non-coding genes dropped]' \
  '-trackNames[input are pairs of track names and files]' \
  '-ignoreStrand[cluster positive and negative strand together]' \
  '-clusterBed=[output BED file for each cluster]:bed:_files' \
  '-clusterTxBed=[output BED file with full transcript bounds per cluster]:bed:_files' \
  '-flatBed=[output BED with exons of all genes flattened into one record]:bed:_files' \
  '-joinContained[join genes contained within a larger loci into that loci]' \
  '-conflicted[detect conflicted loci]' \
  '-ignoreBases=[ignore this many bases at start/end of each transcript]:n:' \
  '*:outputFile database table:_files' && ret=0

return ret
