#compdef addons-linter
# Documentation: https://github.com/mozilla/addons-linter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Mozilla addons-linter — yargs CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--version[show version]' \
  '--log-level=[verbosity]:level:(fatal error warn info debug trace)' \
  '--warnings-as-errors[treat warnings as errors]' \
  '(-o)'{-o+,--output=}'[output format]:format:(json text)' \
  '--metadata[output only metadata JSON]' \
  '--pretty[pretty-print JSON]' \
  '--stack[print JS stack traces]' \
  '--boring[disable color]' \
  '--enterprise[lint as enterprise extension]' \
  '--privileged[lint as privileged extension]' \
  '--self-hosted[disable AMO hosting messages]' \
  '--enable-background-service-worker[MV3 service worker support]' \
  '--min-manifest-version=[minimum manifest_version]:ver:' \
  '--max-manifest-version=[maximum manifest_version]:ver:' \
  '--disable-linter-rules=[comma-separated eslint rules]:rules:' \
  '--disable-xpi-autoclose[disable XPI auto-close]' \
  '*:add-on path:_files' && ret=0

return ret
