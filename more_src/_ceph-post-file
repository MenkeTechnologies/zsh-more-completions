#compdef ceph-post-file
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-post-file/
# Upload a file to the Ceph project for support analysis.

local ret=1

_arguments -s -S \
  '(-d --description)'{-d+,--description=}'[short description for the upload]:description:' \
  '-u+[set the user metadata for the upload]:user:' \
  '*:file:_files' && ret=0

return ret
