#compdef payload_dumper

# payload_dumper: extract Android OTA payload.bin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--out=[output dir]:dir:_files -/' \
  '--partitions=[partitions to extract]:list:' \
  '--workers=[worker threads]:n:' \
  '--list_partitions[list partitions only]' \
  '--save_metadata[save metadata]' \
  '--print_metadata[print metadata]' \
  '*:payload.bin file:_files -g "payload.bin"' && ret=0
return ret
