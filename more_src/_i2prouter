#compdef i2prouter
# Documentation: https://man.archlinux.org/search?q=i2prouter
# Reference accessed: 2026-05-16

# i2prouter: I2P router launcher / service manager script
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1:action:(start stop graceful restart status console dump condrestart)' && ret=0
return ret
