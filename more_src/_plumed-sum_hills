#compdef plumed-sum_hills
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/sum_hills.html
# plumed sum_hills: integrate a HILLS file into a free energy surface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-debug[show special options for regtests]' \
  '--hills=[hills file to process]:file:_files' \
  '--histo=[file for histogram analysis]:file:_files' \
  '--outfile=[output filename for free energy results]:file:_files' \
  '--outhisto=[output filename for histogram results]:file:_files' \
  '--fmt=[output format]:fmt' \
  '--bin=[number of bins for the grid]:bins' \
  '--spacing=[grid spacing]:spacing' \
  '--min=[lower bounds for the grid]:min' \
  '--max=[upper bounds for the grid]:max' \
  '--stride=[stride for integrating hills]:stride' \
  '--idw=[variables to use]:vars' \
  '--kt=[temperature in energy units]:kt' \
  '--sigma=[width vector for histogram binning]:sigma' \
  '--negbias[output negative bias instead of free energy]' \
  '--nohistory[process stride blocks independently]' \
  '--mintozero[shift minimum values to zero]' && ret=0

return ret
