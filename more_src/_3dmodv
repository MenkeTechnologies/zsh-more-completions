#compdef 3dmodv
# Documentation: https://bio3d.colorado.edu/imod/doc/man/3dmodv.html
# 3dmodv - view an IMOD model in the model view window

local ret=1

_arguments -s -S \
  '-f[open model view window to maximum size supported by graphics]' \
  '-b[set color used as the rendering background]:color' \
  '-s[set initial size of model view area as width,height]:width,height' \
  '-E[open windows specified by key letters]:keys' \
  '-L[listen for messages on standard input instead of the clipboard]' \
  '-D[run in debug mode with diagnostic output]' \
  '*:model file:_files' && ret=0

return ret
