#compdef fsharpi fsi
# _fsharpi — F# Interactive shell (Microsoft + Mono + F# community, F#); REPL for F# scripts
# upstream: https://github.com/dotnet/fsharp

_fsharpi() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--use:+[evaluate file]:file:_files -g "*.fsx"' \
        '--load:+[load file]:file:_files -g "*.fsx"' \
        '--reference:+[add reference]:dll:_files' \
        '-r:+[add reference]:dll:_files' \
        '--lib:+[search path]:dir:_files -/' \
        '-I:+[search path]:dir:_files -/' \
        '--debug[debug info]' \
        '-g[debug info]' \
        '--debug+[debug type]:type:(full pdbonly portable embedded)' \
        '--optimize+[optimization]:val:(+ -)' \
        '-O+[optimization]:val:(+ -)' \
        '--tailcalls+[tail calls]:val:(+ -)' \
        '--define:+[define]:def:' \
        '-d:+[define]:def:' \
        '--nologo[no logo]' \
        '--quotations-debug+[quotations debug]:val:(+ -)' \
        '--readline+[readline]:val:(+ -)' \
        '--gui+[gui]:val:(+ -)' \
        '--use-magic+[use magic]:val:(+ -)' \
        '--exec[exec script]' \
        '--codepage:+[codepage]:cp:' \
        '--utf8output[utf8 output]' \
        '--mlcompatibility[ml compat]' \
        '--noframework[no framework]' \
        '--nointerfacedata[no interface data]' \
        '--nooptimizationdata[no optimization data]' \
        '--target+[target]:target:(exe winexe library module)' \
        '--targetprofile:+[target profile]:profile:(mscorlib netcore netstandard)' \
        '--checked+[checked arithmetic]:val:(+ -)' \
        '--platform:+[platform]:platform:(anycpu anycpu32bitpreferred x64 x86 itanium)' \
        '*:script:_files -g "*.fsx"'
}

_fsharpi "$@"
