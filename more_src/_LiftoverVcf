#compdef LiftoverVcf
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/vcf/LiftoverVcf.java
# Picard: lift over a VCF between genome builds using a chain file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input VCF/BCF to lift over]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[lifted-over VCF/BCF output]:file:_files' \
  '(-C --CHAIN)'{-C,--CHAIN}'=[liftover chain file]:file:_files -g "*.chain"' \
  '--REJECT=[file for rejected records]:file:_files' \
  '(-WMC --WARN_ON_MISSING_CONTIG)'{-WMC,--WARN_ON_MISSING_CONTIG}'=[warn on missing contig]:b:(true false)' \
  '(-LFI --LOG_FAILED_INTERVALS)'{-LFI,--LOG_FAILED_INTERVALS}'=[log intervals failing min match]:b:(true false)' \
  '--WRITE_ORIGINAL_POSITION=[write original contig/position to INFO]:b:(true false)' \
  '--WRITE_ORIGINAL_ALLELES=[write original alleles to INFO]:b:(true false)' \
  '--LIFTOVER_MIN_MATCH=[min percent match to lift a variant]:f:' \
  '--ALLOW_MISSING_FIELDS_IN_HEADER=[allow INFO/FORMAT not in header]:b:(true false)' \
  '--RECOVER_SWAPPED_REF_ALT=[swap ref/alt for matching biallelic SNPs]:b:(true false)' \
  '*--TAGS_TO_REVERSE=[allele-frequency-like INFO tag to transform on swap]:tag:' \
  '*--TAGS_TO_DROP=[INFO tag to delete on swap]:tag:' \
  '--DISABLE_SORT=[write unsorted, unindexed output]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
