#compdef cryodrgn
# Documentation: https://ez-lab.gitbook.io/cryodrgn/cryodrgn-user-guide.md
# cryoDRGN heterogeneous cryo-EM reconstruction CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(train_vae train_nn train_dec abinit abinit_homo_old abinit_het_old analyze analyze_landscape analyze_landscape_full backproject_voxel downsample eval_vol eval_images filter graph_traversal direct_traversal pc_traversal dashboard parse_ctf_csparc parse_ctf_star parse_pose_csparc parse_pose_star parse_star)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $words[1] in
      train_vae) _arguments \
        '(-o --outdir)'{-o,--outdir}'=[output directory]:dir:_files -/' \
        '--zdim=[latent dimension]:n:' \
        '--poses=[image poses pkl]:file:_files' \
        '--ctf=[CTF parameters pkl]:file:_files' \
        '--load=[checkpoint to load]:file:_files' \
        '(-n --num-epochs)'{-n,--num-epochs}'=[epochs]:n:' \
        '(-b --batch-size)'{-b,--batch-size}'=[batch size]:n:' \
        '--lr=[learning rate]:lr:' \
        '--beta=[beta]:beta:' \
        '--ind=[indices pkl]:file:_files' \
        '--datadir=[data directory]:dir:_files -/' \
        '--lazy[lazy loading]' \
        '--uninvert-data[do not invert data sign]' \
        '--no-window[disable windowing]' \
        '--max-threads=[max threads]:n:' \
        '--seed=[random seed]:n:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '1:particles:_files' && ret=0 ;;
      downsample) _arguments \
        '-D[new box size]:size:' \
        '(-o --outfile)'{-o,--outfile}'=[output stack]:file:_files' \
        '--outdir=[output directory]:dir:_files -/' \
        '(-b --batch-size)'{-b,--batch-size}'=[batch size]:n:' \
        '--is-vol[input mrc is a volume]' \
        '--chunk=[chunk size]:n:' \
        '--datadir=[data directory]:dir:_files -/' \
        '--max-threads=[max threads]:n:' \
        '--ind=[indices pkl]:file:_files' \
        '1:input:_files' && ret=0 ;;
      analyze) _arguments \
        '--device=[CUDA device]:dev:' \
        '(-o --outdir)'{-o,--outdir}'=[output directory]:dir:_files -/' \
        '--skip-vol[skip volume generation]' \
        '--skip-umap[skip UMAP]' \
        '--pc=[num PC traversals]:n:' \
        '--ksample=[num kmeans samples]:n:' \
        '--Apix=[pixel size]:apix:' \
        '--flip[flip handedness]' \
        '--invert[invert contrast]' \
        '(-d --downsample)'{-d,--downsample}'=[downsample box size]:n:' \
        '1:workdir:_files -/' '2:epoch:' && ret=0 ;;
      backproject_voxel) _arguments \
        '--poses=[image poses pkl]:file:_files' \
        '(-o --outdir)'{-o,--outdir}'=[output folder]:dir:_files -/' \
        '--ctf=[CTF parameters pkl]:file:_files' \
        '(-b --batch-size)'{-b,--batch-size}'=[batch size]:n:' \
        '--ctf-alg=[CTF algorithm]:alg:(flip mul)' \
        '--reg-weight=[regularization weight]:w:' \
        '--no-half-maps[skip half-maps]' \
        '--datadir=[data directory]:dir:_files -/' \
        '--lazy[lazy loading]' \
        '--ind=[indices pkl]:file:_files' \
        '--first=[first N images]:n:' \
        '--uninvert-data[do not invert data sign]' \
        '--tilt[treat as tilt series]' \
        '1:particles:_files' && ret=0 ;;
      abinit) _arguments \
        '(-o --outdir)'{-o,--outdir}'=[output directory]:dir:_files -/' \
        '--zdim=[latent dimension]:n:' \
        '--ctf=[CTF parameters pkl]:file:_files' \
        '(-n --num-epochs)'{-n,--num-epochs}'=[epochs]:n:' \
        '--lr=[learning rate]:lr:' \
        '--l-start=[first pose search freqs]:n:' \
        '--l-end=[last pose search freqs]:n:' \
        '--t-extent=[translation grid extent]:n:' \
        '--t-ngrid=[translation grid points]:n:' \
        '--nkeptposes=[poses kept per image]:n:' \
        '--base-healpy=[base healpy index]:n:' \
        '--seed=[random seed]:n:' \
        '--load=[checkpoint to load]:file:_files' \
        '--ind=[indices pkl]:file:_files' \
        '--datadir=[data directory]:dir:_files -/' \
        '--lazy[lazy loading]' \
        '--uninvert-data[do not invert data sign]' \
        '1:particles:_files' && ret=0 ;;
      parse_pose_star) _arguments \
        '(-o --outpkl)'{-o,--outpkl}'=[output pose pkl]:file:_files' \
        '-D[box size override]:size:' \
        '--Apix=[pixel size]:apix:' \
        '1:input:_files' && ret=0 ;;
      *) _files ;;
    esac
    ;;
esac

return ret
