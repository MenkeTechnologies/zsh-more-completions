#compdef sam

# Zsh completion for AWS SAM CLI (Serverless Application Model)

local curcontext="$curcontext" state line ret=1

local -a sam_commands
sam_commands=(
  'init:initialize a serverless application'
  'validate:validate an AWS SAM template'
  'build:build your Lambda function code'
  'local:run your serverless application locally'
  'package:package an AWS SAM application'
  'deploy:deploy an AWS SAM application'
  'delete:delete an AWS SAM application'
  'logs:fetch logs for a function'
  'publish:publish a packaged AWS SAM template'
  'traces:fetch AWS X-Ray traces'
  'sync:sync local changes to AWS'
  'pipeline:manage CI/CD pipeline'
  'list:list resources and outputs'
  'remote:invoke or send events to cloud resources'
)

local -a sam_global_flags
sam_global_flags=(
  '--help[show help message]'
  '--debug[turn on debug logging]'
  '--version[show version]'
  '--info[show system and dependencies info]'
)

_arguments -s -S \
  $sam_global_flags \
  '1:command:_describe -t commands command sam_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          $sam_global_flags \
          '--no-interactive[disable interactive prompting]' \
          '-l[location of SAM template]:location:_files' \
          '--location=[location of SAM template]:location:_files' \
          '-r=[Lambda runtime]:runtime:(python3.9 python3.10 python3.11 python3.12 nodejs18.x nodejs20.x java11 java17 java21 dotnet6 dotnet8 go1.x ruby3.2 rust)' \
          '--runtime=[Lambda runtime]:runtime:(python3.9 python3.10 python3.11 python3.12 nodejs18.x nodejs20.x java11 java17 java21 dotnet6 dotnet8 go1.x ruby3.2 rust)' \
          '-d=[dependency manager]:dep manager:(pip npm maven gradle bundler mod cargo)' \
          '--dependency-manager=[dependency manager]:dep manager:(pip npm maven gradle bundler mod cargo)' \
          '--app-template=[identifier of the managed application template]:template:' \
          '-n=[name of the project]:name:' \
          '--name=[name of the project]:name:' \
          '-o=[where to output the initialized app]:directory:_directories' \
          '--output-dir=[where to output the initialized app]:directory:_directories' \
          '--package-type=[package type]:type:(Zip Image)' \
          '--base-image=[base image for Image package type]:image:' \
          '--tracing[enable AWS X-Ray tracing]' \
          '--application-insights[enable Amazon CloudWatch Application Insights]' \
          '--no-tracing[disable AWS X-Ray tracing]' && ret=0
        ;;
      build)
        _arguments -s -S \
          $sam_global_flags \
          '-b=[path to the build directory]:directory:_directories' \
          '--build-dir=[path to the build directory]:directory:_directories' \
          '-s=[path to the base directory]:directory:_directories' \
          '--base-dir=[path to the base directory]:directory:_directories' \
          '-u[build inside a Docker container]' \
          '--use-container[build inside a Docker container]' \
          '-e=[path to a file with environment variables for build containers]:file:_files' \
          '--container-env-var-file=[path to a file with environment variables]:file:_files' \
          '--build-image=[container image URIs for building]:image:' \
          '-m=[path to a custom dependency manifest]:manifest:_files' \
          '--manifest=[path to a custom dependency manifest]:manifest:_files' \
          '-t=[path to the AWS SAM template]:template:_files' \
          '--template-file=[path to the AWS SAM template]:template:_files' \
          '--parameter-overrides=[string of CloudFormation parameter overrides]:overrides:' \
          '-p[enable parallel builds]' \
          '--parallel[enable parallel builds]' \
          '--cached[enable cached builds]' \
          '--cache-dir=[build cache directory]:directory:_directories' \
          '--mount-with=[mount mode for container builds]:mode:(read write)' \
          '--skip-pull-image[skip pulling the latest Docker image]' \
          '--docker-network=[name or id of Docker network]:network:' \
          '--container-env-var=[environment variable for build container]:env var:' \
          '::resource id:' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          $sam_global_flags \
          '-t=[path to the AWS SAM template]:template:_files' \
          '--template-file=[path to the AWS SAM template]:template:_files' \
          '--stack-name=[name of the CloudFormation stack]:stack name:' \
          '--s3-bucket=[S3 bucket for packaged artifacts]:bucket:' \
          '--s3-prefix=[prefix for the S3 bucket]:prefix:' \
          '--image-repository=[ECR repository for container images]:repo:' \
          '--image-repositories=[ECR repos for container images]:repos:' \
          '--capabilities=[list of capabilities]:capabilities:(CAPABILITY_IAM CAPABILITY_NAMED_IAM CAPABILITY_AUTO_EXPAND)' \
          '--region=[AWS region]:region:' \
          '--profile=[AWS profile]:profile:' \
          '--parameter-overrides=[CloudFormation parameter overrides]:overrides:' \
          '--no-execute-changeset[create changeset but do not execute]' \
          '--role-arn=[IAM role ARN for CloudFormation]:arn:' \
          '--kms-key-id=[KMS key ID for encryption]:key id:' \
          '--force-upload[override existing files in S3]' \
          '--no-fail-on-empty-changeset[do not fail on empty changeset]' \
          '--tags=[list of tags]:tags:' \
          '--notification-arns=[SNS topic ARNs]:arns:' \
          '--resolve-s3[automatically create and use S3 bucket]' \
          '--resolve-image-repos[automatically create ECR repos]' \
          '--guided[use guided interactive deployment]' \
          '-g[use guided interactive deployment]' \
          '--config-file=[path to config file]:config file:_files' \
          '--config-env=[environment name in config file]:env:' \
          '--confirm-changeset[prompt before executing changeset]' \
          '--disable-rollback[disable rollback on failure]' \
          '--on-failure=[action on failure]:action:(ROLLBACK DELETE DO_NOTHING)' \
          '--signing-profiles=[code signing profiles]:profiles:' && ret=0
        ;;
      local)
        local -a local_commands
        local_commands=(
          'invoke:invoke a Lambda function locally'
          'start-api:start a local API Gateway'
          'start-lambda:start a local Lambda endpoint'
          'generate-event:generate sample event payloads'
        )
        _arguments -s -S \
          $sam_global_flags \
          '1:local command:_describe -t commands command local_commands' \
          '*::local args:->local_args' && ret=0
        case "$state" in
          local_args)
            case "${line[1]}" in
              invoke)
                _arguments -s -S \
                  $sam_global_flags \
                  '-e=[path to event file]:event file:_files' \
                  '--event=[path to event file]:event file:_files' \
                  '-t=[path to the template]:template:_files' \
                  '--template=[path to the template]:template:_files' \
                  '-n=[path to environment variables file]:env file:_files' \
                  '--env-vars=[path to environment variables file]:env file:_files' \
                  '--parameter-overrides=[parameter overrides]:overrides:' \
                  '-d=[port for the debug]:debug port:' \
                  '--debug-port=[port for the debug]:debug port:' \
                  '--debugger-path=[path to debugger]:path:_directories' \
                  '--debug-args=[additional debug args]:args:' \
                  '--docker-volume-basedir=[basedir for Docker volume]:basedir:_directories' \
                  '--docker-network=[Docker network]:network:' \
                  '-l=[log file]:log file:_files' \
                  '--log-file=[log file]:log file:_files' \
                  '--layer-cache-basedir=[layer cache directory]:directory:_directories' \
                  '--skip-pull-image[skip pulling the latest Docker image]' \
                  '--force-image-build[rebuild Docker image]' \
                  '--shutdown[emulate a shutdown event after invoke]' \
                  '--container-host=[host for Docker]:host:' \
                  '--container-host-interface=[interface for Docker]:interface:' \
                  '1:function logical id:' && ret=0
                ;;
              start-api)
                _arguments -s -S \
                  $sam_global_flags \
                  '-t=[path to the template]:template:_files' \
                  '--template=[path to the template]:template:_files' \
                  '--host=[local hostname]:host:' \
                  '-p=[local port]:port:' \
                  '--port=[local port]:port:' \
                  '-s=[static assets directory]:directory:_directories' \
                  '--static-dir=[static assets directory]:directory:_directories' \
                  '-n=[path to environment variables file]:env file:_files' \
                  '--env-vars=[path to environment variables file]:env file:_files' \
                  '--parameter-overrides=[parameter overrides]:overrides:' \
                  '-d=[debug port]:debug port:' \
                  '--debug-port=[debug port]:debug port:' \
                  '--debugger-path=[path to debugger]:path:_directories' \
                  '--debug-args=[debug args]:args:' \
                  '--docker-volume-basedir=[basedir]:basedir:_directories' \
                  '--docker-network=[Docker network]:network:' \
                  '-l=[log file]:log file:_files' \
                  '--log-file=[log file]:log file:_files' \
                  '--skip-pull-image[skip pulling latest image]' \
                  '--force-image-build[rebuild Docker image]' \
                  '--warm-containers=[warm container mode]:mode:(EAGER LAZY)' \
                  '--shutdown[emulate shutdown event]' && ret=0
                ;;
              start-lambda)
                _arguments -s -S \
                  $sam_global_flags \
                  '-t=[path to the template]:template:_files' \
                  '--template=[path to the template]:template:_files' \
                  '--host=[local hostname]:host:' \
                  '-p=[local port]:port:' \
                  '--port=[local port]:port:' \
                  '-n=[path to environment variables file]:env file:_files' \
                  '--env-vars=[path to environment variables file]:env file:_files' \
                  '--parameter-overrides=[parameter overrides]:overrides:' \
                  '-d=[debug port]:debug port:' \
                  '--debug-port=[debug port]:debug port:' \
                  '--docker-volume-basedir=[basedir]:basedir:_directories' \
                  '--docker-network=[Docker network]:network:' \
                  '-l=[log file]:log file:_files' \
                  '--log-file=[log file]:log file:_files' \
                  '--skip-pull-image[skip pulling latest image]' \
                  '--force-image-build[rebuild Docker image]' \
                  '--warm-containers=[warm container mode]:mode:(EAGER LAZY)' && ret=0
                ;;
              generate-event)
                _arguments -s -S \
                  $sam_global_flags \
                  '1:service:(alexa-skills-kit alexa-smart-home apigateway batch cloudformation cloudfront cloudwatch codecommit codepipeline cognito config connect dynamodb kinesis lex rekognition s3 ses sns sqs stepfunctions)' \
                  '*::event args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      delete)
        _arguments -s -S \
          $sam_global_flags \
          '--stack-name=[name of the CloudFormation stack]:stack name:' \
          '--region=[AWS region]:region:' \
          '--profile=[AWS profile]:profile:' \
          '--config-file=[path to config file]:config file:_files' \
          '--config-env=[environment name in config file]:env:' \
          '--no-prompts[skip all prompts]' \
          '--s3-bucket=[S3 bucket for artifacts]:bucket:' \
          '--s3-prefix=[S3 prefix]:prefix:' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $sam_global_flags \
          '--name=[resource name]:function name:' \
          '--stack-name=[CloudFormation stack name]:stack name:' \
          '--filter=[expression to filter logs]:filter:' \
          '-n=[number of log entries]:number:' \
          '-s=[start time]:start time:' \
          '--start-time=[start time]:start time:' \
          '-e=[end time]:end time:' \
          '--end-time=[end time]:end time:' \
          '-t[tail the logs]' \
          '--tail[tail the logs]' \
          '--region=[AWS region]:region:' \
          '--profile=[AWS profile]:profile:' \
          '--config-file=[path to config file]:config file:_files' \
          '--config-env=[environment name in config file]:env:' \
          '--cw-log-group=[CloudWatch log group]:log group:' \
          '--output=[output format]:format:(text json)' && ret=0
        ;;
      sync)
        _arguments -s -S \
          $sam_global_flags \
          '-t=[path to the template]:template:_files' \
          '--template-file=[path to the template]:template:_files' \
          '--stack-name=[CloudFormation stack name]:stack name:' \
          '--region=[AWS region]:region:' \
          '--profile=[AWS profile]:profile:' \
          '--s3-bucket=[S3 bucket]:bucket:' \
          '--s3-prefix=[S3 prefix]:prefix:' \
          '--image-repository=[ECR repository]:repo:' \
          '--image-repositories=[ECR repos]:repos:' \
          '--capabilities=[capabilities]:capabilities:(CAPABILITY_IAM CAPABILITY_NAMED_IAM CAPABILITY_AUTO_EXPAND)' \
          '--parameter-overrides=[parameter overrides]:overrides:' \
          '--tags=[tags]:tags:' \
          '--kms-key-id=[KMS key ID]:key id:' \
          '--role-arn=[IAM role ARN]:arn:' \
          '--notification-arns=[SNS topic ARNs]:arns:' \
          '--watch[watch for local changes]' \
          '--code[sync only code resources]' \
          '--no-watch[do not watch for changes]' \
          '--config-file=[path to config file]:config file:_files' \
          '--config-env=[environment name]:env:' \
          '--build-in-source[build in source directory]' \
          '--dependency-layer[separate dependency layer]' \
          '--no-dependency-layer[do not use dependency layer]' \
          '--skip-deploy-sync[skip deploy sync]' \
          '--use-container[build inside Docker]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          $sam_global_flags \
          '-t=[path to the template]:template:_files' \
          '--template-file=[path to the template]:template:_files' \
          '--region=[AWS region]:region:' \
          '--profile=[AWS profile]:profile:' \
          '--config-file=[path to config file]:config file:_files' \
          '--config-env=[environment name]:env:' \
          '--lint[lint the template using cfn-lint]' && ret=0
        ;;
      pipeline)
        local -a pipeline_commands
        pipeline_commands=(
          'init:initialize a CI/CD pipeline'
          'bootstrap:bootstrap pipeline resources'
        )
        _arguments -s -S \
          $sam_global_flags \
          '1:pipeline command:_describe -t commands command pipeline_commands' \
          '*::pipeline args:' && ret=0
        ;;
      list)
        local -a list_commands
        list_commands=(
          'endpoints:list cloud endpoints'
          'resources:list resources'
          'stack-outputs:list stack outputs'
        )
        _arguments -s -S \
          $sam_global_flags \
          '1:list command:_describe -t commands command list_commands' \
          '*::list args:' && ret=0
        ;;
      remote)
        local -a remote_commands
        remote_commands=(
          'invoke:invoke a Lambda function in the cloud'
          'test-event:manage test events'
        )
        _arguments -s -S \
          $sam_global_flags \
          '1:remote command:_describe -t commands command remote_commands' \
          '*::remote args:' && ret=0
        ;;
      *)
        _arguments -s -S $sam_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
