#compdef goose

# Zsh completion for goose (Go database migration CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '-dir=[Directory with migration files]:dir:_directories' \
  '-table=[Migrations table name]:table' \
  '-verbose[Enable verbose mode]' \
  '-allow-missing[Allow missing in-order migrations]' \
  '-no-versioning[Apply migration commands without tracking version]' \
  '-s[Use sequential numbering for new migrations]' \
  '-sequential[Use sequential numbering for new migrations]' \
  '-certfile=[TLS client certificate file]:file:_files' \
  '-keyfile=[TLS client key file]:file:_files' \
  '-ssl-cert=[Path to SSL cert]:file:_files' \
  '-ssl-key=[Path to SSL key]:file:_files' \
  '-ssl-ca=[Path to SSL CA cert]:file:_files' \
  '1:driver:(postgres mysql sqlite3 mssql redshift tidb clickhouse vertica ydb turso)' \
  '2:dbstring' \
  '3:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'up:Migrate the DB to the most recent version available'
      'up-by-one:Migrate the DB up by 1'
      'up-to:Migrate the DB to a specific version'
      'down:Roll back the version by 1'
      'down-to:Roll back to a specific version'
      'redo:Re-run the latest migration'
      'reset:Roll back all migrations'
      'status:Dump the migration status for the current DB'
      'version:Print the current version of the database'
      'create:Create a new migration file'
      'fix:Apply sequential ordering to existing migrations'
      'validate:Check migration files without running them'
      'env:Print the environment variables used by goose'
    )
    _describe -t commands 'goose command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      up-to|down-to)
        _arguments -s -S \
          '1:version' && ret=0
        ;;
      create)
        _arguments -s -S \
          '1:migration name' \
          '2:type:(sql go)' && ret=0
        ;;
    esac
    ;;
esac

return ret
