#compdef astal
# _astal — Aylur Astal toolkit and CLI for building GTK-based status bars and widgets (aylur team, Vala/Gjs); custom argparse
# upstream: https://github.com/Aylur/astal

_astal() {
    local -a sub=(
        'init:create a new astal project'
        'pkg:package subcommands'
        'install:install dependencies'
        'inspect:open GTK inspector'
        'list:list running instances'
        'quit:quit an instance'
        'toggle:toggle a window'
        'run:run code in instance'
        'request:send IPC message'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--instance=+[instance name]:str:' \
        '-i+[instance name]:str:' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--gjs-args=+[gjs args]:str:' \
        '--no-inspector[no GTK inspector]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'astal subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--directory=+[dir]:dir:_files -/' \
                    '-d+[dir]:dir:_files -/' \
                    '--template=+[template]:t:(gjs lua vala typescript)' \
                    '--name=+[project name]:str:' ;;
                pkg) _arguments '1:pkg cmd:(install remove list update build)' ;;
                run|request|toggle) _arguments \
                    '--instance=+[instance]:str:' \
                    '*:argument:' ;;
                quit) _arguments '--instance=+[instance]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_astal "$@"
