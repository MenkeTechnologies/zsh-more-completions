#compdef dials.refine_bravais_settings
# Documentation: https://dials.github.io/documentation/programs/dials_refine_bravais_settings.html
# DIALS: refine all possible Bravais settings from an indexing solution

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--show-config[show full list of parameters]' \
  '--phil=[read parameters from phil file]:phil file:_files' \
  'lepage_max_delta=[deviation tolerance for Bravais setting identification]:delta' \
  'nproc=[number of processes to use]:n' \
  'cc_n_bins=[number of resolution bins for correlation coefficients]:n' \
  'best_monoclinic_beta=[prefer I2 over C2 if less oblique]:bool:(True False)' \
  'crystal_id=[select specific crystal for refinement]:id' \
  'output.directory=[output directory]:dir:_files -/' \
  'output.log=[log filename]:file:_files' \
  'output.prefix=[output file prefix]:prefix' \
  'refinement.parameterisation.scan_varying=[enable scan-varying refinement]:bool:(True False Auto)' \
  'refinement.parameterisation.beam.fix=[fix beam parameters]:fix' \
  'refinement.parameterisation.crystal.fix=[fix crystal parameters]:fix' \
  'refinement.parameterisation.detector.fix=[fix detector parameters]:fix' \
  'refinement.parameterisation.goniometer.fix=[fix goniometer parameters]:fix' \
  'refinement.reflections.outlier.algorithm=[outlier rejection method]:algorithm' \
  '*:file:_files' && ret=0

return ret
