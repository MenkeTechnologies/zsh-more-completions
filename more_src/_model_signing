#compdef model_signing
# Documentation: https://github.com/sigstore/model-transparency
# sign and verify ML models with sigstore (supply chain security for ML)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--signature=[signature file path]:file:_files' \
  '--ignore-paths=[paths to ignore]:path:_files' \
  '--ignore-git-paths[ignore git paths]' \
  '--no-ignore-git-paths[do not ignore git paths]' \
  '--allow-symlinks[allow following symlinks]' \
  '--ignore-unsigned-files[ignore unsigned files on verify]' \
  '--no-ignore-unsigned-files[do not ignore unsigned files on verify]' \
  '--use-staging[use sigstore staging instance]' \
  '--trust-config=[trust config for a private sigstore instance]:file:_files' \
  '--use-ambient-credentials[use ambient OIDC credentials]' \
  '--identity-token=[OIDC identity token]:token:' \
  '--oauth-force-oob[force out-of-band OAuth flow]' \
  '--client-id=[OIDC client id]:id:' \
  '--client-secret=[OIDC client secret]:secret:' \
  '--identity=[claimed signing identity]:identity:' \
  '--identity-provider=[OIDC provider used during signing]:provider:' \
  '--private-key=[private key file]:file:_files' \
  '--public-key=[public key file]:file:_files' \
  '--password=[private key password]:password:' \
  '--signing-certificate=[signing certificate file]:file:_files' \
  '--certificate-chain=[certificate chain file]:file:_files' \
  '--pkcs11-uri=[PKCS #11 URI]:uri:' \
  '--module-paths=[PKCS #11 module paths]:path:_files' \
  '--log-fingerprints[log certificate fingerprints]' \
  '1:command:->cmds' \
  '*::arg:_files' && ret=0

case $state in
  cmds)
    _values 'model_signing command' \
      'sign[sign a model]' \
      'verify[verify a model]' \
      'digest[compute and output model digest]' && ret=0
    ;;
esac

return ret
