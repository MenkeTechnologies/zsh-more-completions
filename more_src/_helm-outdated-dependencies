#compdef helm-outdated-dependencies
# Documentation: https://github.com/sapcc/helm-outdated-dependencies
# helm outdated-dependencies: manage outdated Helm chart dependencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--repositories=[repositories to check (comma-separated)]:repos:' \
  '--increment-chart-version[increment chart version after updating dependencies]' \
  '--auto-update[enable git integration to contribute updated charts]' \
  '--only-pull-requests[create pull requests instead of committing to master]' \
  '--author-name=[git commit author name]:name:' \
  '--author-email=[git commit author email]:email:' \
  '1:command:(list update)' \
  '*::path:_files -/' && ret=0

return ret
