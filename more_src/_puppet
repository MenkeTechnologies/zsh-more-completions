#compdef puppet

# Zsh completion for puppet - configuration management tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'agent:Run the Puppet agent daemon'
  'apply:Apply Puppet manifests locally'
  'ca:Manage the Puppet certificate authority'
  'catalog:Compile, save, and view Puppet catalogs'
  'cert:Manage certificates and requests'
  'config:Interact with Puppet configuration'
  'describe:Display help about resource types'
  'device:Manage remote network devices'
  'doc:Generate Puppet references'
  'epp:Interact with Embedded Puppet templates'
  'facts:Retrieve and store facts'
  'filebucket:Manage the file bucket'
  'generate:Generate Puppet objects'
  'help:Display Puppet help'
  'lookup:Perform Hiera lookups'
  'module:Find, install, and manage modules'
  'node:View and manage node definitions'
  'parser:Interact with the Puppet parser'
  'plugin:Interact with the Puppet plugin system'
  'report:Create, display, and submit reports'
  'resource:Interact with native Puppet types'
  'ssl:Manage SSL keys and certificates'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-l --logdest)'{-l,--logdest}'[log destination]:dest:(syslog console)' \
  '--confdir=[set the configuration directory]:dir:_directories' \
  '--codedir=[set the code directory]:dir:_directories' \
  '--vardir=[set the var directory]:dir:_directories' \
  '--color=[whether to use colors]:when:(ansi false true)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'puppet command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      agent)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --test)'{-t,--test}'[run a one-time catalog and exit]' \
          '--noop[run in no-op mode]' \
          '--no-daemonize[do not send the process into background]' \
          '--onetime[run the configuration once and exit]' \
          '--server=[puppet server hostname]:server' \
          '--masterport=[puppet server port]:port' \
          '--environment=[set the environment]:environment' \
          '--certname=[set the certificate name]:name' \
          '--waitforcert=[wait for certificate approval]:seconds' \
          '--detailed-exitcodes[provide detailed exit codes]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '(-d --debug)'{-d,--debug}'[enable debug output]' && ret=0
        ;;
      apply)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--noop[run in no-op mode]' \
          '--execute=[execute a specific piece of Puppet code]:code' \
          '--modulepath=[path to the module directory]:path:_directories' \
          '--environment=[set the environment]:environment' \
          '--detailed-exitcodes[provide detailed exit codes]' \
          '--catalog=[apply a JSON catalog]:file:_files' \
          '--test[enable most useful options for a single run]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '(-d --debug)'{-d,--debug}'[enable debug output]' \
          '*:manifest:_files -g "*.pp"' && ret=0
        ;;
      config)
        local -a config_cmds=(
          'print:Examine Puppet settings'
          'set:Set Puppet settings'
          'delete:Delete a Puppet setting'
        )
        _describe -t config_cmds 'config command' config_cmds && ret=0
        ;;
      module)
        local -a module_cmds=(
          'build:Build a module release package'
          'changes:Show modified files in an installed module'
          'generate:Generate boilerplate for a new module'
          'install:Install a module from the Puppet Forge'
          'list:List installed modules'
          'search:Search the Puppet Forge'
          'uninstall:Uninstall a puppet module'
          'upgrade:Upgrade a puppet module'
        )
        _describe -t module_cmds 'module command' module_cmds && ret=0
        ;;
      resource)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--types[list all available resource types]' \
          '1:type:(augeas computer cron exec file filebucket group host interface k5login macauthorization mailalias maillist mount nagios_command nagios_contact nagios_contactgroup nagios_host nagios_hostdependency nagios_hostescalation nagios_hostextinfo nagios_hostgroup nagios_service nagios_servicedependency nagios_serviceescalation nagios_serviceextinfo nagios_servicegroup nagios_timeperiod notify package resources router schedule scheduled_task selboolean selmodule service ssh_authorized_key sshkey stage tidy user vlan yumrepo zfs zone zpool)' \
          '2:name:' && ret=0
        ;;
      lookup)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--merge=[merge strategy]:strategy:(first unique hash deep)' \
          '--type=[assert the value has this type]:type' \
          '--default=[default value if key is not found]:value' \
          '--node=[node name]:node' \
          '--environment=[environment]:environment' \
          '--render-as=[output format]:format:(s string json yaml binary msgpack)' \
          '--explain[explain the details of the lookup]' \
          '*:key:' && ret=0
        ;;
      parser)
        local -a parser_cmds=(
          'dump:Outputs a dump of the internal parse tree'
          'validate:Validate the syntax of Puppet manifests'
        )
        _describe -t parser_cmds 'parser command' parser_cmds && ret=0
        ;;
      epp)
        local -a epp_cmds=(
          'render:Render an EPP template'
          'validate:Validate EPP template syntax'
        )
        _describe -t epp_cmds 'epp command' epp_cmds && ret=0
        ;;
      describe)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-s[show short description]' \
          '--short[show short description]' \
          '--list[list all resource types]' \
          '--providers[describe providers for each type]' \
          '*:type:' && ret=0
        ;;
      ssl)
        local -a ssl_cmds=(
          'bootstrap:Bootstrap the SSL configuration'
          'clean:Remove SSL certificates'
          'download_cert:Download the CA certificate'
          'submit_request:Generate and submit a certificate signing request'
          'verify:Verify the local SSL configuration'
        )
        _describe -t ssl_cmds 'ssl command' ssl_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
