#compdef sfsegywrite
# Documentation: http://www.ahay.org/RSF/sfsegywrite.html
# Madagascar: convert an RSF dataset to SEG-Y or SU

local ret=1

_arguments -s \
  'tape=[output data file]:file:_files' \
  'tfile=[input trace header file (from sfsegyheader)]:file:_files' \
  'hfile=[input text data header file]:file:_files' \
  'bfile=[input binary data header file]:file:_files' \
  'su=[y for SU output, n for SEGY]:flag:(y n)' \
  'suxdr=[y if SU has XDR support]:flag:(y n)' \
  'endian=[auto-estimate endianness]:flag:(y n)' \
  'verb=[verbosity flag]:flag:(y n)' \
  '*:rsf file:_files' && ret=0

return ret
