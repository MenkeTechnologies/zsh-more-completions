#compdef sqlite-utils-cli
# _sqlite-utils-cli — Simon Willison sqlite-utils tool for SQLite databases CLI alias (simonw team, Python); click
# upstream: https://github.com/simonw/sqlite-utils

_sqlite-utils-cli() {
    local -a sub=(
        'add-column:add column to table'
        'add-foreign-key:add foreign key constraint'
        'add-foreign-keys:add multiple foreign keys'
        'add-geometry-column:add SpatiaLite geometry column'
        'analyze:run ANALYZE'
        'analyze-tables:summarize column distinct counts'
        'attach:attach another db'
        'bulk:bulk INSERT/UPDATE from CSV/JSON'
        'convert:apply Python conversion to column'
        'create-database:create empty db'
        'create-index:create index'
        'create-spatial-index:create SpatiaLite spatial index'
        'create-table:create table'
        'create-view:create view'
        'disable-fts:disable FTS on table'
        'drop-table:drop table'
        'drop-view:drop view'
        'duplicate:duplicate a table'
        'enable-counts:track row count via triggers'
        'enable-fts:enable FTS on table columns'
        'enable-wal:enable WAL mode'
        'disable-wal:disable WAL mode'
        'extract:extract column into lookup table'
        'fts:run FTS search'
        'index-foreign-keys:create indexes on foreign keys'
        'indexes:show indexes'
        'insert:insert data from CSV/TSV/JSON/JSONL'
        'insert-files:insert binary files as blobs'
        'install:install plugins'
        'memory:run query against in-memory db'
        'optimize:optimize FTS and reindex'
        'plugins:list installed plugins'
        'populate-fts:populate FTS index'
        'prefix:filter rows by column prefix'
        'query:run SQL query'
        'rebuild-fts:rebuild FTS index'
        'rename-table:rename table'
        'rows:list rows in a table'
        'schema:show CREATE statements'
        'search:full-text search'
        'tables:list tables'
        'transform:transform table schema'
        'triggers:list triggers'
        'uninstall:uninstall plugins'
        'upsert:upsert rows'
        'vacuum:run VACUUM'
        'views:list views'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--load-extension=+[extension path]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sqlite-utils subcommand' sub ;;
        args)
            case $words[1] in
                insert|insert-files|upsert) _arguments \
                    '1:db:_files -g "*.{db,sqlite,sqlite3}"' \
                    '2:table:' \
                    '3:input:_files' \
                    '--pk=+[primary key]:str:' \
                    '--csv[csv input]' \
                    '--tsv[tsv input]' \
                    '--json[json input]' \
                    '--nl[newline-delimited json]' \
                    '--text[text input]' \
                    '--alter[allow alter table]' \
                    '--ignore[ignore conflicts]' \
                    '--replace[replace conflicts]' \
                    '--truncate[truncate before insert]' \
                    '--detect-types[detect types]' \
                    '-d[detect types]' \
                    '--batch-size=+[batch size]:n:' \
                    '--analyze[run ANALYZE after]' \
                    '--no-headers[no headers]' \
                    '--flatten[flatten nested json]' ;;
                query|memory) _arguments \
                    '1:db_or_query:_files' \
                    '*:queries or files:' \
                    '--csv[csv output]' \
                    '--tsv[tsv output]' \
                    '--json[json output]' \
                    '--nl[newline-delimited json]' \
                    '--no-headers[no headers]' \
                    '--table[table output]' \
                    '-t[table output]' \
                    '--save=+[save view name]:str:' \
                    '--save-table=+[save table name]:str:' ;;
                rows|search|fts|prefix) _arguments \
                    '1:db:_files -g "*.{db,sqlite,sqlite3}"' \
                    '2:table:' \
                    '--columns=+[columns csv]:str:' \
                    '-c+[columns csv]:str:' \
                    '--where=+[where clause]:str:' \
                    '--limit=+[limit]:n:' \
                    '--csv[csv output]' \
                    '--json[json output]' \
                    '--table[table output]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_sqlite-utils-cli "$@"
