#compdef pidcat
# Documentation: https://github.com/JakeWharton/pidcat
# Reference accessed: 2026-05-20
# Verified: upstream JakeWharton/pidcat pidcat.py argparse calls.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --tag-width)'{-w+,--tag-width=}'[width of log tag]:n:' \
  '(-l --min-level)'{-l+,--min-level=}'[minimum log level]:lvl:(V D I W E F)' \
  '--color-gc[color garbage collection]' \
  '--always-display-tags[always display tags]' \
  '--current[filter by current running app]' \
  '(-s --serial)'{-s+,--serial=}'[device serial]:serial:' \
  '(-d --device)'{-d,--device}'[use first device]' \
  '(-e --emulator)'{-e,--emulator}'[use first emulator]' \
  '(-c --clear)'{-c,--clear}'[clear log before running]' \
  '*'{-t+,--tag=}'[filter by tag]:tag:' \
  '*'{-i+,--ignore-tag=}'[ignore tag]:tag:' \
  '(-a --all)'{-a,--all}'[show all output]' \
  '*:package name:' && ret=0

return ret
