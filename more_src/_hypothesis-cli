#compdef hypothesis-cli hypothesis
# _hypothesis-cli — David MacIver Hypothesis hypothesis-cli CLI command-line frontend for the Python Hypothesis property-based testing framework providing write-codemod ghostwriter strategies fuzz hypothesis-write hypothesis-statistics-test-database-management for downstream pytest unittest-based test pipelines (David MacIver team, Python); click
# upstream: https://hypothesis.readthedocs.io/

_hypothesis-cli() {
    local -a sub=(
        'write:ghostwriter-generate property tests'
        'fuzz:fuzz-driver mode'
        'codemod:apply codemods to existing tests'
        'statistics:report run statistics'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--style=+[s]:s:(pytest unittest)' \
        '--annotate=+[bool]:s:(true false)' \
        '--no-annotate[no type annotations]' \
        '--annotate-types[annotate types]' \
        '--except=+[exc]:str:' \
        '-e+[exception]:str:' \
        '--operations=+[ops]:str:' \
        '--strategy=+[name]:str:' \
        '--max-examples=+[N]:n:' \
        '--seed=+[seed]:str:' \
        '--profile=+[name]:str:' \
        '--no-rejected-examples[no rejected examples]' \
        '--database=+[uri]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hypothesis-cli subcommand' sub ;;
        args)
            case $words[1] in
                write) _arguments '*:module/function:' ;;
                fuzz) _arguments '*:pytest args:_files' ;;
                codemod) _arguments '*:path:_files' ;;
            esac
            ;;
    esac
}

_hypothesis-cli "$@"
