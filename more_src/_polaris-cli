#compdef polaris
# _polaris-cli — Fairwinds Polaris k8s policy validator (Fairwinds, Go); validates k8s manifests against best practices
# upstream: https://github.com/FairwindsOps/polaris

_polaris-cli() {
    local -a sub=(
        'audit:audit a cluster, file, or helm chart'
        'dashboard:run web dashboard'
        'webhook:run admission controller'
        'fix:apply auto-fixes to manifests'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--disable-color-output[no color]' \
        '--log-level+[log level]:level:(trace debug info warn error fatal panic)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'polaris subcommand' sub ;;
        args)
            case $words[1] in
                audit) _arguments \
                    '--audit-path+[audit path]:path:_files' \
                    '--helm-chart+[helm chart path]:path:_files' \
                    '--helm-values+[helm values]:file:_files' \
                    '--format+[output format]:fmt:(yaml json score pretty)' \
                    '-f+[output format]:fmt:' \
                    '--output-file+[output file]:file:_files' \
                    '--output-url+[output url]:url:_urls' \
                    '--display-name+[display name]:name:' \
                    '--cluster-name+[cluster name]:name:' \
                    '--set-exit-code-on-danger[exit 3 if dangerous]' \
                    '--set-exit-code-on-error[exit 4 if error]' \
                    '--set-exit-code-below-score+[exit 4 if score below]:n:' \
                    '--only-show-failed-tests[only failed tests]' \
                    '--quiet[suppress non-error output]' \
                    '--severity+[min severity]:level:(warning danger)' \
                    '--checks+[only run checks]:checks:' \
                    '--resource+[only resource type]:type:' \
                    '--kube-context+[kube context]:context:' ;;
                dashboard) _arguments \
                    '--port+[port]:port:' \
                    '--base-path+[base path]:path:' \
                    '--load-audit-file+[load audit file]:file:_files' \
                    '--listening-address+[listen addr]:addr:' \
                    '--audit-path+[audit dir]:dir:_files -/' \
                    '--kube-context+[kube context]:context:' ;;
                webhook) _arguments \
                    '--port+[port]:port:' \
                    '--disable-webhook-config-installer[disable installer]' \
                    '--cert-file+[cert]:file:_files' \
                    '--key-file+[key]:file:_files' ;;
                fix) _arguments \
                    '--files+[files]:file:_files' \
                    '--checks+[checks]:checks:' ;;
            esac
            ;;
    esac
}

_polaris-cli "$@"
