#compdef cadence-server
# _cadence-server — Uber Cadence workflow engine server (cadence-workflow/cadence)
# upstream: https://github.com/cadence-workflow/cadence
# Subcommands from cmd/server/cadence/cadence.go (urfave/cli/v2).

_cadence-server() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-r --root)'{-r+,--root=}'[root directory of execution environment]:dir:_files -/' \
        '(-c --config)'{-c+,--config=}'[config directory relative to root]:dir:_files -/' \
        '(-e --env)'{-e+,--env=}'[runtime environment]:env:(development production)' \
        '(--az --zone)'{--az+,--zone=}'[availability zone]:az:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start cadence server'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '(-s --services)'{-s+,--services=}'[comma-separated services to start]:services:(frontend history matching worker sharddistributor)' ;;
            esac
            ;;
    esac
}

_cadence-server "$@"
