#compdef xzgrep xzegrep xzfgrep lzgrep lzegrep lzfgrep
# _xzgrep — XZ Utils xzgrep family (transparently decompresses .xz/.lzma/.gz/.bz2/.lz/.zst inputs and pipes them to grep/egrep/fgrep — script lives in src/scripts/xzgrep.in)
# upstream: https://github.com/tukaani-project/xz
# Flags forwarded directly to grep(1); see xz/src/scripts/xzgrep.in on tip.

_xzgrep() {
    _arguments \
        '-E[extended regex (egrep mode)]' \
        '-F[fixed strings (fgrep mode)]' \
        '-G[basic regex]' \
        '-i[case-insensitive]' \
        '-n[print line numbers]' \
        '-l[print only filenames with match]' \
        '-c[count matches]' \
        '-q[quiet]' \
        '-s[suppress error messages]' \
        '-v[invert match]' \
        '-w[whole word]' \
        '-x[whole line]' \
        '-h[suppress filename prefix]' \
        '-H[force filename prefix]' \
        '-e+[pattern]:pattern:' \
        '-f+[pattern file]:file:_files' \
        '-A+[N trailing context]:n:' \
        '-B+[N leading context]:n:' \
        '-C+[N context]:n:' \
        '1:pattern:' \
        '*:file:_files'
}

_xzgrep "$@"
