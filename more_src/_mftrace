#compdef mftrace
# mftrace — trace TeX bitmap fonts to scalable outlines

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--formats=[output formats]:formats (comma-separated):(pfb pfa ttf svg)' \
  '--magnification=[set magnification]:magnification:' \
  '--dpi=[set resolution in dpi]:dpi:' \
  '--simplify[simplify outlines]' \
  '--keep-trying[continue after errors]' \
  '--autotrace[use autotrace for tracing]' \
  '--potrace[use potrace for tracing]' \
  '--encoding=[set encoding file]:encoding file:_files' \
  '-o+[set output file]:output file:_files' \
  '--glyphs=[select glyph range]:range:' \
  '--tfmfile=[set TFM file]:TFM file:_files' \
  '--gffile=[set GF file]:GF file:_files' \
  '--nocorrect[do not correct bitmap outline]' \
  '--verbose[be verbose]' \
  '--warranty[show warranty]' \
  '*:Metafont name:' && ret=0

return ret
