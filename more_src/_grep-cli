#compdef grep-cli egrep-cli fgrep-cli
# _grep-cli — GNU grep print lines matching a pattern CLI alias (GNU team, C); custom argparse
# upstream: https://www.gnu.org/software/grep/

_grep-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-E[extended regex]' \
        '--extended-regexp[extended regex]' \
        '-F[fixed strings]' \
        '--fixed-strings[fixed strings]' \
        '-G[basic regex]' \
        '--basic-regexp[basic regex]' \
        '-P[perl regex]' \
        '--perl-regexp[perl regex]' \
        '-e+[pattern]:str:' \
        '--regexp=+[pattern]:str:' \
        '-f+[pattern file]:file:_files' \
        '--file=+[pattern file]:file:_files' \
        '-i[ignore case]' \
        '--ignore-case[ignore case]' \
        '--no-ignore-case[no ignore case]' \
        '-y[ignore case]' \
        '-w[match whole words]' \
        '--word-regexp[match whole words]' \
        '-x[match whole lines]' \
        '--line-regexp[match whole lines]' \
        '-z[NUL terminator]' \
        '--null-data[NUL terminator]' \
        '-s[suppress error messages]' \
        '--no-messages[suppress error messages]' \
        '-v[invert match]' \
        '--invert-match[invert match]' \
        '--include=+[pattern]:str:' \
        '--exclude=+[pattern]:str:' \
        '--exclude-from=+[file]:file:_files' \
        '--exclude-dir=+[pattern]:str:' \
        '--no-filename[suppress filename in output]' \
        '-H[show filename]' \
        '--with-filename[show filename]' \
        '--label=+[label]:str:' \
        '-n[show line number]' \
        '--line-number[show line number]' \
        '--line-buffered[line buffered]' \
        '-T[align]' \
        '--initial-tab[align]' \
        '-u[no msdos /r]' \
        '--unix-byte-offsets[no msdos /r]' \
        '-Z[NUL after filename]' \
        '--null[NUL after filename]' \
        '-A+[after context lines]:n:' \
        '--after-context=+[after context lines]:n:' \
        '-B+[before context lines]:n:' \
        '--before-context=+[before context lines]:n:' \
        '-C+[context lines]:n:' \
        '--context=+[context lines]:n:' \
        '--group-separator=+[separator]:str:' \
        '--no-group-separator[no group separator]' \
        '--color=+[when]:w:(auto always never)' \
        '--colour=+[when]:w:(auto always never)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--silent[quiet]' \
        '-c[count]' \
        '--count[count]' \
        '-L[show files without match]' \
        '--files-without-match[show files without match]' \
        '-l[show files with match]' \
        '--files-with-matches[show files with match]' \
        '-m+[max count]:n:' \
        '--max-count=+[max count]:n:' \
        '-o[only matching]' \
        '--only-matching[only matching]' \
        '--null[NUL terminator for filenames]' \
        '-a[treat binary as text]' \
        '--text[treat binary as text]' \
        '-I[ignore binary]' \
        '--binary-files=+[mode]:m:(text binary without-match)' \
        '--devices=+[mode]:m:(read skip)' \
        '-D+[mode]:m:(read skip)' \
        '--directories=+[mode]:m:(read skip recurse)' \
        '-d+[mode]:m:(read skip recurse)' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-R[recursive following symlinks]' \
        '--dereference-recursive[recursive following symlinks]' \
        '--binary[binary mode]' \
        '*:pattern files:_files'
}

_grep-cli "$@"
