#compdef bitlbee
# Documentation: https://www.bitlbee.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bitlbee - IRC gateway to IM chat networks

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose (with -n)]' \
  '-V[show version]' \
  '-c[config file path]:file:_files' \
  '-d[user config directory]:dir:_directories' \
  '-D[run in daemon mode]' \
  '-F[run in ForkDaemon mode]' \
  '-i[bind to IP address]:ip' \
  '-I[run in inetd(8) mode (default)]' \
  '-n[do not fork into background]' \
  '-p[listen port (default 6667)]:port' \
  '-P[PID file]:file:_files' \
  '-R[run as a specific user]:user:_users' \
  '-u[user to run as]:user:_users' \
  '-x[run encryption/decryption utility]' && ret=0

return ret
