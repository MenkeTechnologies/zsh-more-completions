#compdef bitlbee

# Zsh completion for bitlbee - an IRC to other chat networks gateway

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[show version]' \
  '-c[config file path]:file:_files' \
  '-d[user config directory]:dir:_directories' \
  '-D[daemonize (background)]' \
  '-F[forkdaemon mode]' \
  '-i[bind to IP address]:ip' \
  '-I[inetd mode (default)]' \
  '-n[do not fork]' \
  '-p[listen port]:port' \
  '-P[PID file]:file:_files' \
  '-R[run as a specific user]:user:_users' \
  '-u[user to run as]:user:_users' \
  '-x[run encryption/decryption utility]' && ret=0

return ret
