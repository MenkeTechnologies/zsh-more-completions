#compdef butteraugli_main
# Documentation: https://github.com/google/butteraugli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# google/butteraugli — perceptual image quality metric.
# Usage: butteraugli_main image1.{png|jpg|jpeg} image2.{png|jpg|jpeg} [heatmap.ppm]
# Project archived 2023-11-14; accepts positional args only, no flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:reference image:_files -g "*.(png|jpg|jpeg)"' \
  '2:distorted image:_files -g "*.(png|jpg|jpeg)"' \
  '3:heatmap output (optional):_files -g "*.ppm"' && ret=0

return ret
