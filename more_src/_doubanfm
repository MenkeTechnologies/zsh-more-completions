_doubanfm() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'help:show help screen with keyboard shortcut reference'
        'config:open the interactive configuration menu (inquirer)'
        'account:authenticate with Douban email+password and save bearer token'
        'download:update the local download directory path'
        'id3:batch-update ID3 tags on local tracks in the download directory'
        'http_proxy:configure HTTP proxy for accessing Douban FM servers'
        'quit:quit the player and close the audio device'
    )

    _arguments -C \
        '(-): :->cmd' && ret=0

    case $state in
        cmd)
            _describe -t commands 'doubanfm subcommand (omit to start playing)' subcmds && ret=0
            ;;
    esac
    return ret
}

_doubanfm "$@"
