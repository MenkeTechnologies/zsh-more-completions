#compdef tile38

# Tile38: geospatial database / real-time geofence
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-h[bind host]:host:_hosts' \
  '-p[bind port]:port:' \
  '-d[data directory]:dir:_files -/' \
  '-l[log level]:level:(debug info warn error)' \
  '--protected-mode=[protected mode]:mode:(yes no)' \
  '--appendonly=[append-only file]:val:(yes no)' \
  '--appendfilename=[AOF file]:file:_files' \
  '--auth=[require password]:pass:' \
  '--persistence=[enable persistence]:bool:(true false)' \
  '--no-hh[disable HSET history]' \
  '--vendor[vendor mode]' \
  '-v[show version]' \
  '--version[show version]' \
  '*::tile38 args:_files' && ret=0
return ret
