#compdef tile38 tile38-server
# Documentation: https://github.com/tidwall/tile38/blob/master/cmd/tile38-server/main.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Tile38: geospatial database / real-time geofence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[bind host]:host:_hosts' \
  '-p[listening port (default 9851)]:port:' \
  '-s[listen on a unix socket]:socket:_files' \
  '-d[data directory]:dir:_files -/' \
  '-l[log encoding]:format:(json text)' \
  '-v[verbose logging]' \
  '-vv[very verbose logging]' \
  '-q[quiet (silent) logging]' \
  '-pidfile[file containing the pid]:file:_files' \
  '-pprofport[pprof http port]:port:' \
  '-cpuprofile[write CPU profile to file]:file:_files' \
  '-memprofile[write memory profile to file]:file:_files' \
  '-metrics-addr[Prometheus metrics listening addr]:addr:' \
  '--protected-mode=[protected mode]:mode:(yes no)' \
  '--appendonly=[append-only file]:val:(yes no)' \
  '--appendfilename=[AOF file]:file:_files' \
  '--queuefilename=[queue file]:file:_files' \
  '--dev[development mode]' \
  '--nohup[ignore SIGHUP]' \
  '--http-transport=[http transport]:val:(yes no)' \
  '--threads=[worker threads]:n:' \
  && ret=0
return ret
