#compdef snap-cli2 snap2
# _snap-cli2 — Canonical Snapcraft snap-cli2 CLI command-line frontend wrapping the snap command tool to interact with the snapd service which manages snaps universal Linux packages for desktop server and IoT open-source written in Go originally Canonical Snapcraft self-contained snap packages run in a sandbox under AppArmor seccomp profiles install remove refresh revert disable enable list find search info download try changes tasks abort ack create-key sign export-snap import-snap snap-pack pack run shell connect disconnect interfaces interface plug slot login logout whoami known recovery set-base unset alias unalias prefer aliases revert recovery-chooser-trigger recovery-chooser-trigger set get unset wait services start stop restart enable disable logs services-restart services-stop services-start system-mode set-base reboot model assertion get-assertion (Canonical Snapcraft team Gustavo Niemeyer, Go); custom argparse
# upstream: https://snapcraft.io/

_snap-cli2() {
    local -a sub=(
        'abort:abort a change'
        'ack:add an assertion'
        'aliases:list aliases'
        'alias:set up an alias'
        'auto-import:auto-import assertions'
        'buy:buy a snap'
        'changes:list system changes'
        'connect:connect a plug to a slot'
        'connections:list connections'
        'create-cohort:create a cohort'
        'create-key:create signing key'
        'disable:disable a snap'
        'disconnect:disconnect a plug from a slot'
        'download:download a snap'
        'enable:enable a snap'
        'export-snapshot:export a snapshot'
        'find:find snaps'
        'forget:forget snapshots'
        'get:get config values'
        'help:show help'
        'hold:hold refreshes'
        'info:show snap info'
        'install:install a snap'
        'interface:show interface info'
        'interfaces:list interfaces'
        'keys:list signing keys'
        'known:list known assertions'
        'list:list installed snaps'
        'login:authenticate'
        'logout:revoke session'
        'logs:show service logs'
        'managed:check managed status'
        'mark-pre-seeded:mark pre-seeded'
        'model:show model assertion'
        'okay:acknowledge warnings'
        'pack:pack a snap'
        'prepare-image:prepare a UC image'
        'prefer:prefer a snap aliases'
        'quota:quota operations'
        'recovery:show recovery info'
        'reboot:reboot system'
        'refresh:refresh snaps'
        'remove:remove a snap'
        'remove-user:remove a user'
        'restart:restart services'
        'restore-snapshot:restore a snapshot'
        'revert:revert a snap'
        'routine:routine maintenance'
        'run:run a snap'
        'save-snapshot:save a snapshot'
        'services:list services'
        'set:set config values'
        'set-base:set base'
        'sign:sign an assertion'
        'sign-build:sign build assertion'
        'snap-op:internal'
        'snapshots:list snapshots'
        'start:start services'
        'stop:stop services'
        'switch:switch channel'
        'system-mode:show system mode'
        'tasks:show tasks of a change'
        'try:install from a directory'
        'unalias:remove an alias'
        'unhold:unhold refreshes'
        'unset:unset config values'
        'validate:validate validation sets'
        'version:show version'
        'wait:wait for an apply'
        'warnings:show warnings'
        'watch:watch a change'
        'whoami:show identity'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--name=+[name]:str:' \
        '--channel=+[name]:str:' \
        '--track=+[name]:str:' \
        '--devmode[dev mode]' \
        '--jailmode[jail mode]' \
        '--classic[classic confinement]' \
        '--dangerous[dangerous install]' \
        '--unaliased[unaliased]' \
        '--ignore-validation[ignore validation]' \
        '--ignore-running[ignore running]' \
        '--revision=+[rev]:str:' \
        '-r+[revision]:str:' \
        '--cohort=+[key]:str:' \
        '--leave-cohort[leave cohort]' \
        '--purge[purge]' \
        '--terminate[terminate processes]' \
        '--time[show timing]' \
        '--abs-time[show absolute time]' \
        '--unicode=+[c]:c:(auto always never)' \
        '--color=+[c]:c:(auto always never)' \
        '--list[list refreshable]' \
        '--all[all]' \
        '--last=+[t]:str:' \
        '--changes[show changes]' \
        '--debug[debug]' \
        '--socket=+[path]:_files' \
        '--type=+[t]:t:(app gadget kernel base os snapd core)' \
        '--unicode=+[c]:c:(auto always never)' \
        '--shell[open shell in snap]' \
        '--gdb[open gdb]' \
        '--strace[strace snap]' \
        '--list-aliases[list aliases]' \
        '--use-system-key=+[v]:v:(yes no)' \
        '--auto[auto]' \
        '--no-wait[no wait]' \
        '--gdbserver=+[host:port]:_hosts' \
        '--gtkrun=+[port]:n:' \
        '--account-key=+[name]:str:' \
        '--brand=+[brand]:str:' \
        '--name=+[name]:str:' \
        '--username=+[name]:_users' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snap subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|refresh|revert|enable|disable|list|find|info|download|try|run|connect|disconnect|interface|connections|alias|unalias|prefer|hold|unhold|services|start|stop|restart|logs|get|set|unset|switch|forget|save-snapshot|restore-snapshot|export-snapshot|abort|tasks|watch|wait) _arguments '*:snap:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_snap-cli2 "$@"
