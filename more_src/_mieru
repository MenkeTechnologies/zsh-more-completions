#compdef mieru
# Documentation: https://github.com/enfein/mieru/blob/main/docs/operation.md
# mieru - socks5 / HTTP / HTTPS proxy client to bypass censorship

local ret=1
local context curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'mieru command' \
      'start[start the client background process]' \
      'run[run the client in foreground]' \
      'stop[stop the client background process]' \
      'status[show client status]' \
      'apply[apply configuration]' \
      'describe[describe configuration]' \
      'export[export configuration as URL]' \
      'import[import configuration from URL]' \
      'get[read connections or metrics]' \
      'profile[manage profiling]' \
      'version[show version]' \
      'help[show help]' && ret=0
    ;;
  args)
    case $line[1] in
      apply|describe|export)
        _values 'subcommand' 'config[configuration]' && ret=0 ;;
      import)
        _values 'subcommand' 'config[configuration from URL]' && ret=0 ;;
      get)
        _values 'subcommand' 'connections[active connections]' 'metrics[runtime metrics]' && ret=0 ;;
    esac
    ;;
esac

return ret
