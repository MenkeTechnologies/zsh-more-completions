#compdef virt-make-net-iso
# _virt-make-net-iso — network-bootable ISO maker shim (frontend over xorriso/genisoimage used in some distros to ship netinstaller ISOs with cloud-init seed data; -k kernel, -i initrd, -a kernel args, -s seed dir, -o output ISO; positional configuration directory)
# upstream: distro-shipped (see common cloud-init seed-ISO scripts)
# Common flag shape verified in mkdir-style helper scripts on tip.

_virt-make-net-iso() {
    _arguments \
        '-h[show help]' \
        '--version[show version]' \
        '-k+[kernel]:file:_files' \
        '-i+[initrd]:file:_files' \
        '-a+[kernel cmdline]:cmdline:' \
        '-s+[seed dir]:dir:_files -/' \
        '-o+[output ISO]:file:_files -g "*.iso"' \
        '1:config dir:_files -/'
}

_virt-make-net-iso "$@"
