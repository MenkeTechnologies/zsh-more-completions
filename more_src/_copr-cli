#compdef copr-cli copr
# Documentation: https://github.com/fedora-copr/copr (cli/copr_cli/main.py setup_parser)
# Reference accessed: 2026-05-29
# Fedora Copr — Community-build-system CLI for projects, builds, packages, permissions.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'whoami:identify the authenticated user'
  'new-api-token:generate a fresh API token (destroys previous)'
  'new-webhook-secret:regenerate webhook secret for a project'
  'list:list all projects for a user'
  'create:initialize a new Copr project'
  'modify:adjust settings on an existing project'
  'delete:remove an entire project'
  'fork:duplicate a project and its builds'
  'get:retrieve project details'
  'regenerate-repos:rebuild repository metadata'
  'mock-config:print mock chroot config'
  'build:submit a build (default URL or SRPM)'
  'build-distgit:submit a distgit-based build'
  'buildpypi:submit a build from PyPI'
  'buildgem:submit a build from RubyGems'
  'buildscm:submit a build from SCM (git/svn)'
  'buildcustom:submit a custom build'
  'status:check build state by id'
  'cancel:stop an active build'
  'watch-build:monitor build progress'
  'download-build:retrieve build artifacts'
  'delete-build:remove completed builds'
  'list-builds:list builds for a project'
  'edit-chroot:edit chroot settings'
  'get-chroot:get chroot settings'
  'list-chroots:list available chroots'
  'add-package-pypi:add a PyPI package'
  'edit-package-pypi:edit a PyPI package'
  'add-package-scm:add an SCM package'
  'edit-package-scm:edit an SCM package'
  'add-package-distgit:add a distgit package'
  'edit-package-distgit:edit a distgit package'
  'add-package-rubygems:add a RubyGems package'
  'edit-package-rubygems:edit a RubyGems package'
  'add-package-custom:add a custom package'
  'edit-package-custom:edit a custom package'
  'list-packages:list packages'
  'list-package-names:list package names'
  'get-package:retrieve package info'
  'delete-package:remove a package'
  'reset-package:reset a package'
  'build-package:build a package'
  'edit-permissions:edit project permissions'
  'list-permissions:list project permissions'
  'request-permissions:request permissions'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '--config=[configuration file path]:file:_files'
  '--debug[enable debug output]'
  '--no-color[disable color output]'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'copr-cli subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      build|buildpypi|buildgem|buildscm|buildcustom|build-distgit|build-package)
        _arguments \
          $_global \
          '*'{-r,--chroot=}'[chroot to build for (repeatable)]:chroot:' \
          '--memory=[memory in MiB]:mb:' \
          '--timeout=[build timeout in seconds]:seconds:' \
          '--background[run as background build]' \
          '--nowait[do not wait for completion]' \
          '--isolation=[isolation method]:method:(default nspawn simple)' \
          '--exclude-chroot=[exclude chroot]:chroot:' \
          '--enable-net=[enable network]:bool:(on off)' \
          '*--packit-forge-project=[Packit forge project]:project:' \
          ':project_or_url_or_srpm:' && ret=0
        ;;
      list-builds|status|cancel|watch-build|delete-build|download-build)
        _arguments \
          $_global \
          ':build_id_or_project:' && ret=0
        ;;
      create|modify|get|delete|regenerate-repos|fork|new-webhook-secret|mock-config|list-packages|list-package-names|list-chroots|list-permissions|edit-permissions|request-permissions)
        _arguments \
          $_global \
          ':project (owner/name):' && ret=0
        ;;
      list)
        _arguments \
          $_global \
          ':user/group:' && ret=0
        ;;
      add-package-pypi|edit-package-pypi)
        _arguments \
          '--name=[package name]:name:' \
          '--pythonversions=[python versions (CSV)]:vers:' \
          '--packagename=[pypi project name]:name:' \
          '--packageversion=[pypi version]:ver:' \
          '--spec-template=[spec template]:tmpl:' \
          ':project (owner/name):' && ret=0
        ;;
      add-package-scm|edit-package-scm)
        _arguments \
          '--name=[package name]:name:' \
          '--clone-url=[git/SVN clone URL]:url:_urls' \
          '--commit=[git ref / SVN rev]:ref:' \
          '--subdir=[subdirectory]:dir:' \
          '--spec=[spec file path]:file:' \
          '--type=[SCM type]:type:(git svn)' \
          '--method=[source build method]:method:(rpkg tito tito_test make_srpm)' \
          ':project (owner/name):' && ret=0
        ;;
      add-package-distgit|edit-package-distgit)
        _arguments \
          '--name=[package name]:name:' \
          '--distgit=[distgit instance]:inst:' \
          '--namespace=[namespace]:ns:' \
          '--committish=[committish (branch/tag/sha)]:ref:' \
          ':project (owner/name):' && ret=0
        ;;
      add-package-rubygems|edit-package-rubygems)
        _arguments \
          '--name=[package name]:name:' \
          '--gem=[gem name]:gem:' \
          ':project (owner/name):' && ret=0
        ;;
      add-package-custom|edit-package-custom)
        _arguments \
          '--name=[package name]:name:' \
          '--script=[build script]:file:_files' \
          '--script-builddeps=[build deps for script]:deps:' \
          '--script-resultdir=[script results directory]:dir:' \
          '--script-chroot=[script chroot]:chroot:' \
          ':project (owner/name):' && ret=0
        ;;
      edit-chroot|get-chroot)
        _arguments \
          ':project/chroot:' && ret=0
        ;;
      delete-package|get-package|reset-package)
        _arguments \
          '--name=[package name]:name:' \
          ':project (owner/name):' && ret=0
        ;;
    esac
    ;;
esac

return ret
