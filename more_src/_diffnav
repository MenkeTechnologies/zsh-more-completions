#compdef diffnav

# Zsh completion for diffnav (diff file navigator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-w --width)'{-w,--width}'[terminal width]:width' \
  '--color[color mode]:mode:(auto always never)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:diff file:_files' && ret=0

return ret
