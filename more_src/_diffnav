#compdef diffnav
# Documentation: https://github.com/dlvhdr/diffnav
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dlvhdr/diffnav — diff file navigator (Go, urfave/cli)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-s --side-by-side)'{-s,--side-by-side}'[force side-by-side view]' \
  '(-u --unified)'{-u,--unified}'[force unified diff view]' \
  '(-w --watch)'{-w,--watch}'[watch mode: re-run command periodically]' \
  '--watch-cmd=[command to run in watch mode]:cmd:' \
  '--watch-interval=[refresh interval (default 2s)]:duration:' \
  '*::file:_files' && ret=0

return ret
