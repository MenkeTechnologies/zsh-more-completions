#compdef kubescape
# _kubescape-bin — ARMO Kubescape cluster + IaC scanner (ARMO, Go); CNCF k8s security tool covering NSA-CISA + MITRE
# upstream: https://github.com/kubescape/kubescape

_kubescape-bin() {
    local -a sub=(
        'scan:scan k8s cluster, manifest, or helm chart'
        'list:list resources/frameworks/controls'
        'submit:submit results to Kubescape SaaS'
        'config:manage Kubescape config'
        'delete:delete cached data'
        'download:download artifacts'
        'fix:apply auto-fix to manifests'
        'operator:manage Kubescape operator on cluster'
        'patch:patch container image'
        'prescan:run pre-scan checks'
        'update:update kubescape'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--logger+[logger]:level:(debug info warning error)' \
        '--cache-dir+[cache dir]:dir:_files -/' \
        '--disable-color[no color]' \
        '--enable-color[force color]' \
        '--enable-host-scan[enable host scanner]' \
        '--use-from+[load framework from file]:file:_files' \
        '--use-default[use default framework]' \
        '--use-artifacts-from+[load artifacts from dir]:dir:_files -/' \
        '--use-from-url+[load framework from URL]:url:_urls' \
        '--include-namespaces+[include ns]:str:' \
        '--exclude-namespaces+[exclude ns]:str:' \
        '--account+[ARMO account]:str:' \
        '--customer-guid+[customer GUID]:str:' \
        '--cluster-name+[cluster name]:str:' \
        '--scan-id+[scan id]:str:' \
        '--credentials+[credentials file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubescape subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '1:scan type:(cluster framework control image)' \
                    '-f+[output format]:fmt:(pretty-printer json junit pdf prometheus sarif html)' \
                    '--format+[output format]:fmt:' \
                    '--format-version+[format version]:v:(v1 v2)' \
                    '-o+[output file]:file:_files' \
                    '--output+[output file]:file:_files' \
                    '--exceptions+[exceptions file]:file:_files' \
                    '--results-file+[results file]:file:_files' \
                    '--submit[submit results to ARMO]' \
                    '--keep-local[do not submit]' \
                    '-t+[fail threshold]:score:' \
                    '--severity-threshold+[severity threshold]:level:(low medium high critical)' \
                    '--fail-threshold+[fail threshold]:score:' \
                    '--compliance-threshold+[compliance threshold]:score:' \
                    '--controls-config+[controls config]:file:_files' \
                    '--enable-host-scan[enable host scanner]' \
                    '--silent[silent]' \
                    '--no-summary[no summary]' \
                    '*:targets:_files' ;;
                list) _arguments '1:list type:(frameworks controls exceptions)' ;;
                submit) _arguments '1:submit type:(results)' ;;
                config) _arguments '1:config cmd:(view set delete)' ;;
                download) _arguments '1:artifact:(framework artifacts controls-inputs exceptions controls attack-tracks)' '*:name:' ;;
            esac
            ;;
    esac
}

_kubescape-bin "$@"
