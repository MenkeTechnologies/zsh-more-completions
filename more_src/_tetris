#compdef tetris
# Documentation: https://man.openbsd.org/tetris
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tetris (BSD)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-c[classic tetris mode with clockwise rotation]' \
  '-k[customize control keys]:keys' \
  '-l[difficulty level]:level' \
  '-p[preview next shape]' \
  '-s[display top scores]' && ret=0

return ret
