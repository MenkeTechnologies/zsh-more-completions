#compdef otbcli_VectorDataTransform
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_VectorDataTransform.html
# Orfeo ToolBox: apply a translation, rotation and scaling to vector data

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-vd[input vector data file to transform]:vector:_files' \
  '-out[output vector data file]:output:_files' \
  '-in[support image defining reference coordinate system]:image:_files' \
  '-transform.tx[translation in X direction in pixels]:value:' \
  '-transform.ty[translation in Y direction in pixels]:value:' \
  '-transform.ro[angle of rotation in degrees]:value:' \
  '-transform.centerx[X coordinate of rotation/scaling center]:value:' \
  '-transform.centery[Y coordinate of rotation/scaling center]:value:' \
  '-transform.scale[scale coefficient to apply]:value:' \
  '*::arg:_files' && ret=0

return ret
