#compdef pulsar-client pulsar-admin pulsar-perf

# Zsh completion for Apache Pulsar CLI tools

_pulsar() {
  local curcontext="$curcontext" state line ret=1
  local prog=${words[1]:t}

  case $prog in
    pulsar-client)
      local -a commands=(
        'produce:produce messages to a topic'
        'consume:consume messages from a topic'
      )
      _arguments -s -S \
        '--url=[Pulsar service URL]:URL:' \
        '--auth-plugin=[authentication plugin class]:class:' \
        '--auth-params=[authentication parameters]:params:' \
        '--listener-name=[listener name]:name:' \
        '--tls-allow-insecure[allow insecure TLS connection]' \
        '--tls-enable-hostname-verification[enable TLS hostname verification]' \
        '--tls-trust-cert-path=[TLS trust certificate path]:path:_files' \
        '1:command:->command' \
        '*:: :->args' \
        && ret=0

      case $state in
        (command)
          _describe -t commands 'pulsar-client command' commands && ret=0
          ;;
        (args)
          case ${words[1]} in
            produce)
              _arguments -s -S \
                '-m+[message to produce]:message:' \
                '--messages=[messages to produce]:message:' \
                '-f+[file with messages]:file:_files' \
                '--files=[files with messages]:file:_files' \
                '-n+[number of messages]:count:' \
                '--num-produce=[number of messages]:count:' \
                '-r+[rate of messages per second]:rate:' \
                '--rate=[rate of messages per second]:rate:' \
                '-s+[message separator]:separator:' \
                '--separator=[message separator]:separator:' \
                '-k+[message key]:key:' \
                '--key=[message key]:key:' \
                '-p+[message properties]:properties:' \
                '--properties=[message properties]:properties:' \
                '-db[disable batching]' \
                '--disable-batching[disable batching]' \
                '-c[enable chunking]' \
                '--chunking[enable chunking]' \
                '1:topic:' \
                && ret=0
              ;;
            consume)
              _arguments -s -S \
                '-s+[subscription name]:subscription:' \
                '--subscription-name=[subscription name]:subscription:' \
                '-st+[subscription type]:type:(Exclusive Shared Failover Key_Shared)' \
                '--subscription-type=[subscription type]:type:(Exclusive Shared Failover Key_Shared)' \
                '-sp+[subscription position]:position:(Latest Earliest)' \
                '--subscription-position=[subscription position]:position:(Latest Earliest)' \
                '-n+[number of messages to consume]:count:' \
                '--num-messages=[number of messages to consume]:count:' \
                '-r+[rate of messages per second]:rate:' \
                '--rate=[rate of messages per second]:rate:' \
                '--hex[display message payload in hex]' \
                '--hide-content[do not display message content]' \
                '-q+[size of receiver queue]:size:' \
                '--receiver-queue-size=[size of receiver queue]:size:' \
                '-mc[enable multi-topic consumer]' \
                '-p+[regex pattern for multi-topic]:pattern:' \
                '1:topic:' \
                && ret=0
              ;;
          esac
          ;;
      esac
      ;;
    pulsar-admin)
      local -a commands=(
        'brokers:manage brokers'
        'clusters:manage clusters'
        'functions:manage Pulsar Functions'
        'namespaces:manage namespaces'
        'ns-isolation-policy:manage namespace isolation policies'
        'packages:manage packages'
        'persistent:manage persistent topics'
        'non-persistent:manage non-persistent topics'
        'schemas:manage schemas'
        'sinks:manage Pulsar IO sinks'
        'sources:manage Pulsar IO sources'
        'tenants:manage tenants'
        'topics:manage topics'
        'topicPolicies:manage topic policies'
        'resourcegroups:manage resource groups'
        'transactions:manage transactions'
      )
      _arguments -s -S \
        '--admin-url=[admin service URL]:URL:' \
        '--auth-plugin=[authentication plugin class]:class:' \
        '--auth-params=[authentication parameters]:params:' \
        '--tls-allow-insecure[allow insecure TLS connection]' \
        '--tls-trust-cert-path=[TLS trust certificate path]:path:_files' \
        '1:command:->command' \
        '*:: :->args' \
        && ret=0

      case $state in
        (command)
          _describe -t commands 'pulsar-admin command' commands && ret=0
          ;;
      esac
      ;;
    *)
      _arguments -s -S '*:' && ret=0
      ;;
  esac

  return ret
}

_pulsar "$@"
