#compdef tfplugingen-openapi
# Documentation: https://github.com/hashicorp/terraform-plugin-codegen-openapi
# tfplugingen-openapi - generate a Terraform Provider Code Specification from an OpenAPI spec

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[path to the generator configuration file]:file:_files' \
  '--output=[destination path for the generated Provider Code Specification]:file:_files' \
  '1:command:(generate)' \
  '*:openapi spec:_files' && ret=0

return ret
