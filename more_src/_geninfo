#compdef geninfo

# Zsh completion for geninfo (lcov coverage data collector)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --output-filename)'{-o,--output-filename}'[output file]:file:_files' \
  '(-t --test-name)'{-t,--test-name}'[test name]:name' \
  '(-b --base-directory)'{-b,--base-directory}'[base directory]:directory:_files -/' \
  '(-i --initial)'{-i,--initial}'[capture initial zero coverage data]' \
  '--gcov-tool[path to gcov]:gcov:_files' \
  '--branch-coverage[include branch coverage]' \
  '--no-branch-coverage[exclude branch coverage]' \
  '--function-coverage[include function coverage]' \
  '--no-function-coverage[exclude function coverage]' \
  '--checksum[calculate line checksums]' \
  '--no-checksum[do not calculate checksums]' \
  '--compat-libtool[adjust for libtool]' \
  '--no-compat-libtool[do not adjust for libtool]' \
  '--derive-func-data[derive function data from line data]' \
  '--no-recursion[do not recurse into subdirectories]' \
  '--external[include external source files]' \
  '--no-external[exclude external source files]' \
  '--ignore-errors[ignore errors]:errors' \
  '--config-file[config file]:file:_files' \
  '--rc[override config option]:key=value' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:directory:_files -/' && ret=0

return ret
