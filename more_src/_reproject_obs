#compdef reproject_obs
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/reproject_obs.html
# Reproject a set of observations to a common tangent point and merge them

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infiles=[input event files]:files:_files' \
  'outroot=[root name for the output merged files]:root:' \
  'asolfiles=[input aspect solutions]:files:_files' \
  'merge=[merge event files into single output]:merge:(yes no)' \
  'refcoord=[reference coordinates or evt2 file]:refcoord:' \
  'parallel=[enable parallel processing]:parallel:(yes no)' \
  'nproc=[number of processors to use]:nproc:' \
  'linkfiles=[link or copy ancillary files to output]:linkfiles:(yes no)' \
  'tmpdir=[directory for temporary files]:dir:_files -/' \
  'clobber=[overwrite existing output files]:clobber:(yes no)' \
  'verbose=[screen output verbosity level]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
