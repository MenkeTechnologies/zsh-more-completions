#compdef aliyun

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'configure:configure profiles and credentials'
  'auto-completion:install shell completion'
  'help:show help'
  'oss:OSS commands (ossutil)'
  'test:test commands'
  'ecs:Elastic Compute Service'
  'rds:Relational Database Service'
  'vpc:Virtual Private Cloud'
  'slb:Server Load Balancer'
  'cs:Container Service for Kubernetes'
  'ess:Auto Scaling'
  'ros:Resource Orchestration Service'
  'sls:Log Service'
  'kms:Key Management Service'
  'dns:DNS'
  'cdn:Content Delivery Network'
  'ots:Tablestore (OTS)'
  'dts:Data Transmission Service'
  'polardb:PolarDB'
  'redis:ApsaraDB for Redis'
  'mongodb:ApsaraDB for MongoDB'
  'alidns:Alibaba DNS'
  'fc:Function Compute'
  'mse:Microservices Engine'
  'eci:Elastic Container Instance'
  'ram:RAM (Resource Access Management)'
  'sts:Security Token Service'
  'vod:ApsaraVideo VOD'
  'waf:Web Application Firewall'
  'actiontrail:ActionTrail'
  'alikafka:ApsaraMQ for Kafka'
  'arms:Application Real-Time Monitoring'
  'cloudauth:Real-name Verification'
  'dataworks:DataWorks'
  'dms:Data Management'
  'imm:Intelligent Media Management'
  'kvstore:KVStore'
  'live:ApsaraVideo Live'
  'mns:Message Notification Service'
  'nas:NAS'
  'nlb:Network Load Balancer'
  'openapi:Meta OpenAPI'
  'pvtz:Private Zone'
  'sas:Security Center'
  'scdn:Secure CDN'
  'tag:Tag Service'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show CLI version]' \
  '(-p --profile)'{-p,--profile=}'[profile name]:profile:' \
  '--mode=[credential mode]:mode:(AK StsToken RamRoleArn EcsRamRole RsaKeyPair ChainableRamRoleArn External CredentialsURI OIDC CloudSSO)' \
  '--access-key-id=[access key ID]:id:' \
  '--access-key-secret=[access key secret]:secret:' \
  '--sts-token=[STS token]:token:' \
  '--sts-region=[STS region]:region:' \
  '--ram-role-name=[RAM role name]:name:' \
  '--ram-role-arn=[RAM role ARN]:arn:' \
  '--role-session-name=[role session name]:name:' \
  '--external-id=[external ID]:id:' \
  '--source-profile=[source profile]:name:' \
  '--private-key=[private key path]:file:_files' \
  '--key-pair-name=[key pair name]:name:' \
  '--region=[region]:region:' \
  '--RegionId=[region ID]:region:' \
  '--language=[CLI language]:lang:(en zh ja)' \
  '--config-path=[config path]:file:_files' \
  '--expired-seconds=[token expire seconds]:secs:' \
  '--process-command=[process command]:cmd:' \
  '--oidc-provider-arn=[OIDC provider ARN]:arn:' \
  '--oidc-token-file=[OIDC token file]:file:_files' \
  '--cloud-sso-sign-in-url=[Cloud SSO sign-in URL]:url:' \
  '--cloud-sso-access-config=[Cloud SSO access config]:name:' \
  '--cloud-sso-account-id=[Cloud SSO account ID]:id:' \
  '--endpoint=[endpoint URL]:url:' \
  '--endpoint-type=[endpoint type]:type:(vpc public)' \
  '--secure[force HTTPS]' \
  '--force[force operation]' \
  '*--header=[extra HTTP header K=V]:header:' \
  '--body=[request body string]:body:' \
  '--body-file=[request body file]:file:_files' \
  '--pager[use pager]' \
  '--accept=[accept type]:type:' \
  '(-o --output)'{-o,--output=}'[output column spec]:cols:' \
  '--waiter[wait for completion]' \
  '--dryrun[dry run]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-y --yes)'{-y,--yes}'[answer yes to prompts]' \
  '--cli-query=[JMESPath query]:expr:' \
  '--roa[ROA-style call]' \
  '--method=[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD)' \
  '--user-agent=[user agent]:ua:' \
  '--read-timeout=[read timeout seconds]:secs:' \
  '--connect-timeout=[connect timeout seconds]:secs:' \
  '--retry-count=[retry count]:n:' \
  '--skip-secure-verify[skip TLS verification]' \
  '--auto-plugin-install[auto install plugins]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'aliyun product' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (configure)
        _values 'configure action' \
          'set' 'get' 'list' 'switch' 'delete' && ret=0
        ;;
      (auto-completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
