#compdef amtool

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--alertmanager.url=[Alertmanager URL]:url:' \
  '-o+[output format]:format:(simple extended json)' \
  '--output=[output format]:format:(simple extended json)' \
  '--date.format=[date format]:format:' \
  '--timeout=[connection timeout]:duration:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'alert:view and search through current alerts'
      'silence:manage silences'
      'check-config:validate Alertmanager configuration'
      'cluster:manage Alertmanager cluster'
      'config:view current Alertmanager configuration'
      'template:render template files'
    )
    _describe -t commands 'amtool command' commands && ret=0
    ;;
  args)
    case $line[1] in
      alert)
        local -a alert_commands=(
          'query:view and search alerts'
          'add:add a new alert'
        )
        _describe -t commands 'alert command' alert_commands && ret=0
        ;;
      silence)
        local -a silence_commands=(
          'add:add a new silence'
          'expire:expire a silence'
          'import:import silences'
          'query:query silences'
          'update:update a silence'
        )
        _describe -t commands 'silence command' silence_commands && ret=0
        ;;
      check-config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:config file:_files' && ret=0
        ;;
      config)
        local -a config_commands=(
          'show:show current configuration'
          'routes:display routing tree'
        )
        _describe -t commands 'config command' config_commands && ret=0
        ;;
      cluster)
        local -a cluster_commands=(
          'show:show cluster status'
        )
        _describe -t commands 'cluster command' cluster_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
