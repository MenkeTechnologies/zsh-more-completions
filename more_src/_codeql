#compdef codeql

# Zsh completion for codeql - GitHub CodeQL CLI

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '--search-path[search path for queries and packs]:path:_files -/' \
  '--additional-packs[additional packs path]:path:_files -/' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'database:manage CodeQL databases'
      'query:run and compile queries'
      'bqrs:manipulate binary query result sets'
      'resolve:resolve metadata'
      'pack:manage CodeQL packs'
      'version:show version information'
      'generate:generate supporting files'
      'github:commands for GitHub integration'
    )
    _describe -t commands 'codeql command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      database)
        local -a db_cmds=(
          'create:create a CodeQL database'
          'analyze:analyze a database'
          'upgrade:upgrade a database'
          'bundle:bundle a database'
          'unbundle:unbundle a database'
          'init:initialize a database'
          'trace-command:trace a build command'
          'finalize:finalize a database'
          'index-files:index files into a database'
          'cleanup:clean up a database'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'database command' db_cmds && ret=0
        else
          case ${line[2]} in
            create)
              _arguments -s \
                '(-l --language)'{-l,--language}'[language]:language' \
                '(-s --source-root)'{-s,--source-root}'[source root]:directory:_files -/' \
                '(-j --threads)'{-j,--threads}'[number of threads]:threads' \
                '--command[build command]:command' \
                '--no-cleanup[do not clean up]' \
                '--overwrite[overwrite existing database]' \
                '(-O --output)'{-O,--output}'[output directory]:directory:_files -/' \
                '--db-cluster[create a multi-language database]' \
                '--codescanning-config[code scanning config file]:file:_files' \
                '--extractor-option[extractor option]:key=value' \
                '*:database:_files -/' && ret=0
              ;;
            analyze)
              _arguments -s \
                '--format[output format]:format:(csv sarif sarifv2.1.0 sarifv1 graphtext dgml dot)' \
                '(-o --output)'{-o,--output}'[output file]:file:_files' \
                '(-j --threads)'{-j,--threads}'[number of threads]:threads' \
                '--ram[RAM in MB]:mb' \
                '--rerun[rerun queries]' \
                '--no-rerun[do not rerun queries]' \
                '--sarif-category[SARIF category]:category' \
                '*:database or query:_files' && ret=0
              ;;
            *)
              _files -/ && ret=0
              ;;
          esac
        fi
        ;;
      query)
        local -a query_cmds=(
          'run:run a query'
          'compile:compile a query'
          'decompile:decompile a query'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'query command' query_cmds && ret=0
        else
          _files && ret=0
        fi
        ;;
      bqrs)
        local -a bqrs_cmds=(
          'decode:decode a BQRS file'
          'info:show BQRS info'
          'diff:diff two BQRS files'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'bqrs command' bqrs_cmds && ret=0
        else
          _files && ret=0
        fi
        ;;
      resolve)
        local -a resolve_cmds=(
          'languages:list available languages'
          'queries:resolve query paths'
          'library-path:resolve library path'
          'qlpacks:resolve QL packs'
          'extractor:resolve extractor'
          'database:resolve database'
          'ram:resolve RAM settings'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'resolve command' resolve_cmds && ret=0
        fi
        ;;
      pack)
        local -a pack_cmds=(
          'init:initialize a new pack'
          'add:add a dependency'
          'install:install dependencies'
          'create:create a pack'
          'publish:publish a pack'
          'download:download a pack'
          'ls:list packs'
          'resolve:resolve pack dependencies'
          'ci:install dependencies for CI'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'pack command' pack_cmds && ret=0
        else
          _files -/ && ret=0
        fi
        ;;
      version)
        _arguments -s \
          '--format[output format]:format:(terse json text)' && ret=0
        ;;
    esac
    ;;
esac

return ret
