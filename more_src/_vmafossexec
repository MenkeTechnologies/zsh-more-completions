#compdef vmafossexec
# Documentation: https://github.com/Netflix/vmaf/blob/master/libvmaf/tools/README.md
# legacy VMAF video quality metric executable

local ret=1

_arguments -s \
  '--log[log file name and path]:file:_files' \
  '--log-fmt[log format]:fmt:(xml json)' \
  '--thread[max threads to use]:n:' \
  '--subsample[compute on one of every n frames]:n:' \
  '--disable-clip[disable score clipping]' \
  '--disable-avx[disable AVX optimizations]' \
  '--psnr[also compute PSNR]' \
  '--ssim[also compute SSIM]' \
  '--ms-ssim[also compute MS-SSIM]' \
  '--phone-model[enable phone viewing model]' \
  '--ci[enable confidence interval]' \
  '1:pixel format:(yuv420p yuv422p yuv444p yuv420p10le yuv422p10le yuv444p10le)' \
  '2:width:' \
  '3:height:' \
  '4:reference YUV:_files' \
  '5:distorted YUV:_files' \
  '6:model path:_files' && ret=0

return ret
