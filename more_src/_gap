#compdef gap
# Documentation: https://docs.gap-system.org/doc/ref/chap3.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help summary]' \
  '(- *)--version[print version and exit]' \
  '-A[disable loading of suggested packages]' \
  '-b[suppress banner]' \
  '-D[print debug messages when reading files/loading modules]' \
  '-E[disable readline library for command editing]' \
  '-e[disable quit on Ctrl-D with empty input]' \
  '-M[do not use compiled library file versions]' \
  '-O[disable loading obsolete variables]' \
  '-q[quiet mode, suppress banner and prompts]' \
  '-r[ignore user-specific configuration files]' \
  '-R[do not load previously saved workspace]' \
  '-T[suppress break loop behavior for automated testing]' \
  '*-g[print GC messages (repeat for more verbose)]' \
  '-f[enable line editing and history]' \
  '-n[disable line editing]' \
  '-c+[execute given GAP code]:code:' \
  '-K+[set memory limit, exit if exceeded]:memory:' \
  '--limitworkspace=[set memory limit, exit if exceeded]:memory:' \
  '-L+[load saved workspace]:workspace:_files' \
  '-l+[set GAP root directories]:path_list:' \
  '--roots=[set GAP root directories]:path_list:' \
  '-m+[allocate startup memory]:memory:' \
  '--minworkspace=[allocate startup memory]:memory:' \
  '-o+[set maximum memory allocation]:memory:' \
  '--maxworkspace=[set maximum memory allocation]:memory:' \
  '-s+[use mmap/malloc instead of sbrk for memory]:memory:' \
  '-x+[set terminal line width]:length:' \
  '--width=[set terminal line width]:length:' \
  '-y+[set terminal line count]:length:' \
  '--line=[set terminal line count]:length:' \
  '--packagedirs=[add package directories]:path_list:' \
  '*:GAP file:_files -g "*.g(|ap|d)"' && ret=0

return ret
