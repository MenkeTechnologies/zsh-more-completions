#compdef gap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-b[suppress banner]' \
  '-q[quiet mode, suppress banner and prompts]' \
  '-e[disable quit on ctrl-D]' \
  '-f[force line editing]' \
  '-n[disable line editing]' \
  '-E[do not quit on errors in test mode]' \
  '-r[disable break loop]' \
  '-A[do not read lib/init.g or lib/hpc/init.g]' \
  '-B[do not read any startup files]' \
  '-D[enable debug mode]' \
  '-M[enable memory management debug]' \
  '-T[enable break loop on error]' \
  '-N[do not use default root paths]' \
  '-x[enable tracing]' \
  '-X[enable full tracing]' \
  '-m+[set workspace size]:size:' \
  '-o+[set output file]:file:_files' \
  '-c+[set cache size]:size:' \
  '-s+[set stack size]:size:' \
  '-g+[set number of GC messages]:level:' \
  '-l+[load GAP root path]:path:_files -/' \
  '-L+[load workspace]:workspace:_files' \
  '-R+[restore workspace]:workspace:_files' \
  '-p+[set package directory]:dir:_files -/' \
  '*:GAP file:_files -g "*.g(|ap|d)"' && ret=0

return ret
