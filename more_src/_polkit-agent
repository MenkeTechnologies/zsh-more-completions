#compdef polkit-gnome-authentication-agent-1 polkit-mate-authentication-agent-1 polkit-kde-authentication-agent-1 lxqt-policykit-agent
# _polkit-agent — polkit GUI authentication agents (polkit-gnome / polkit-kde / polkit-mate / lxqt-policykit-agent register with polkitd on the session bus and pop up a password dialog whenever an action needs interactive authorization; --help, --version; otherwise headless once launched by the session manager)
# upstream: https://gitlab.gnome.org/GNOME/polkit-gnome ; https://invent.kde.org/plasma/polkit-kde-agent-1
# Argument shape from GNOME/polkit-gnome polkit-gnome-authentication-agent-1 on tip.

_polkit-agent() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_polkit-agent "$@"
