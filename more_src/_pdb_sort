#compdef pdb_sort
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Sorts the ATOM/HETATM/ANISOU/CONECT records in a PDB file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-C[sort by chain only]' \
  '-R[sort by residue number/icode only]' \
  '-CR[sort by chain then residue (default)]' \
  '*:PDB file:_files' && ret=0

return ret
