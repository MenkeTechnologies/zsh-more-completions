#compdef gelly
# Documentation: https://www.globalphasing.com/buster/manual/gelly/manual/index.html
# BUSTER gelly - geometry and restraint setup for refinement

local ret=1

_arguments -s -S \
  '-autoncs[automated setup of LSSR for NCS]' \
  '-autoncs_noprune[autoncs without outlier pruning]' \
  '-autoncs_weight[set the weight for automated NCS restraints]:weight' \
  '-target[automated LSSR setup to an external target pdb structure]:target pdb:_files' \
  '-target_weight[set the weight for automated target restraints]:weight' \
  '-sim_swap_equiv[swap equivalent atoms to improve NCS/target restraints]' \
  '-sim_swap_equiv_plus[swap equivalent atoms with enhanced functionality]' \
  '*:file:_files' && ret=0

return ret
