#compdef mount-s3 mountpoint-s3
# _mount-s3 — Mountpoint for Amazon S3 FUSE filesystem (awslabs/mountpoint-s3)
# upstream: https://github.com/awslabs/mountpoint-s3
# Flags from mountpoint-s3/src/cli.rs (clap).

_mount-s3() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--prefix=[bucket prefix to mount]:prefix:' \
        '--region=[AWS region]:region:' \
        '--endpoint-url=[custom S3 endpoint URL]:url:' \
        '--profile=[AWS credentials profile]:profile:' \
        '--no-sign-request[disable request signing]' \
        '--force-path-style[force path-style addressing]' \
        '--transfer-acceleration[use S3 Transfer Acceleration]' \
        '--dual-stack[use dual-stack endpoints]' \
        '--requester-pays[set x-amz-request-payer: requester]' \
        '--bucket-type=[bucket type]:type:(general-purpose directory)' \
        '--expected-bucket-owner=[expected bucket-owner account ID]:account:' \
        '--storage-class=[new-object storage class]:class:(STANDARD STANDARD_IA INTELLIGENT_TIERING GLACIER GLACIER_IR DEEP_ARCHIVE EXPRESS_ONEZONE)' \
        '--sse=[server-side encryption]:sse:(AES256 aws:kms aws:kms:dsse)' \
        '--sse-kms-key-id=[KMS key id for SSE-KMS]:key:' \
        '--upload-checksums=[upload checksum algorithm]:algo:(off crc32 crc32c sha1 sha256)' \
        '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
        '--auto-unmount[automatically unmount on exit]' \
        '--allow-other[allow other users access]' \
        '--allow-root[allow root access]' \
        '--allow-delete[allow file deletion]' \
        '--allow-overwrite[allow file overwrite]' \
        '--read-only[mount read-only]' \
        '--uid=[POSIX uid]:n:' \
        '--gid=[POSIX gid]:n:' \
        '--dir-mode=[directory permissions]:mode:' \
        '--file-mode=[file permissions]:mode:' \
        '--max-memory-target=[max memory target (MB)]:n:' \
        '--maximum-throughput-gbps=[max throughput (Gbps)]:n:' \
        '--part-size=[part size (bytes)]:n:' \
        '--read-part-size=[read part size (bytes)]:n:' \
        '--write-part-size=[write part size (bytes)]:n:' \
        '--metadata-ttl=[metadata cache TTL]:ttl:' \
        '--negative-metadata-ttl=[negative metadata cache TTL]:ttl:' \
        '--cache=[disk/Express cache directory]:dir:_files -/' \
        '--cache-block-size=[cache block size]:n:' \
        '--cache-xz[compress disk cache blocks with xz]' \
        '--incremental-upload[stream incremental uploads]' \
        '--infer-content-type[infer object Content-Type from extension]' \
        '--bind=[bind address for OTLP exporter]:addr:' \
        '--otlp-endpoint=[OTLP exporter endpoint]:url:' \
        '--otlp-export-interval=[OTLP export interval]:duration:' \
        '--log-directory=[log directory]:dir:_files -/' \
        '--log-metrics[log summarized metrics]' \
        '--no-log[disable file logging]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '--debug-crt[enable AWS Common Runtime debug logging]' \
        '--user-agent-prefix=[custom user-agent prefix]:prefix:' \
        '1:BUCKET or s3://uri:' \
        '2:mountpoint directory:_files -/'
}

_mount-s3 "$@"
