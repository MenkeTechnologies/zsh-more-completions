#compdef knative-serving-autoscaler
# _knative-serving-autoscaler — Knative Serving multi-tenant autoscaler (sharedmain)
# upstream: https://github.com/knative/serving
# Flags from cmd/autoscaler/main.go + knative.dev/pkg sharedmain on tip.

_knative-serving-autoscaler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-serving-autoscaler "$@"
