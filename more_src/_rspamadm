#compdef rspamadm

# Zsh completion for rspamadm - Rspamd administration utility

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'configdump:dump rspamd configuration'
  'confighelp:show help for configuration options'
  'configtest:test rspamd configuration'
  'configwizard:run configuration wizard'
  'control:manage rspamd processes'
  'cookie:DKIM cookie manipulation'
  'corpustest:test rspamd against a message corpus'
  'dkim_keygen:generate DKIM key pair'
  'fuzzyconvert:convert fuzzy hashes from sqlite to redis'
  'grep:grep rspamd logs'
  'keypair:generate encryption key pair'
  'lua:run lua scripts'
  'mime:manipulate MIME messages'
  'pw:manage passwords'
  'signtool:sign and verify files'
  'statconvert:convert statistics from sqlite to redis'
  'vault:manage hashicorp vault'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      configdump|confighelp|configtest)
        _arguments \
          '(-c --config)'{-c,--config}'[config file]:file:_files' && ret=0
        ;;
      control)
        _arguments ':action:(reload reresolve stat fuzzy_stat fuzzy_sync)' && ret=0
        ;;
      dkim_keygen)
        _arguments \
          '-s+[selector name]:selector:' \
          '-d+[domain name]:domain:' \
          '-k+[output key file]:file:_files' \
          '-b+[key bits]:bits:(1024 2048 4096)' \
          '-t+[key type]:type:(rsa ed25519)' && ret=0
        ;;
      lua)
        _arguments \
          '-s+[lua script string]:script:' \
          '*:script file:_files -g "*.lua"' && ret=0
        ;;
      pw)
        _arguments \
          '-p+[password]:password:' \
          '-c[check password]' \
          '-e[encrypt password]' && ret=0
        ;;
    esac
    ;;
esac

return ret
