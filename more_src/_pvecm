#compdef pvecm

# Zsh completion for pvecm - Proxmox VE cluster manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new cluster'
  'add:add a node to the cluster'
  'addnode:add a node by address'
  'delnode:delete a node from the cluster'
  'status:show cluster status'
  'nodes:show cluster nodes'
  'expected:set expected votes'
  'updatecerts:update SSL certificates'
  'keygen:generate a cluster join key'
  'join:join an existing cluster with a join address'
  'apiver:return the cluster join API version'
  'mtunnel:used by VM migration'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pvecm command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '1:cluster name' \
          '--bindnet0_addr=[address for corosync ring 0]:address' \
          '--bindnet1_addr=[address for corosync ring 1]:address' \
          '--ring0_addr=[address for ring 0]:address' \
          '--ring1_addr=[address for ring 1]:address' \
          '--link*=[corosync link]:config' && ret=0
        ;;
      (add|join)
        _arguments -s -S \
          '1:hostname or IP' \
          '--nodeid=[node id]:id' \
          '--votes=[number of votes]:count' \
          '--ring0_addr=[address for ring 0]:address' \
          '--ring1_addr=[address for ring 1]:address' \
          '--fingerprint=[certificate fingerprint]:fingerprint' \
          '--password=[superuser password]:password' \
          '--force[force operation]' \
          '--link*=[corosync link]:config' && ret=0
        ;;
      (delnode)
        _arguments -s -S '1:node name' && ret=0
        ;;
      (expected)
        _arguments -s -S '1:expected votes:' && ret=0
        ;;
      (status|nodes|updatecerts|keygen|apiver)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
