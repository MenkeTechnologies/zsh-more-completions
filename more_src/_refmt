#compdef refmt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse[input syntax]:syntax:(re ml binary binary_reason)' \
  '--print[output syntax]:syntax:(re ml ast binary binary_reason)' \
  '--interface[parse as interface]:bool:(true false)' \
  '--use-stdin[read from stdin]:bool:(true false)' \
  '--is-interface-pp[parse as interface for preprocessor]' \
  '--recoverable[enable error recovery]' \
  '--assume-explicit-arity[assume explicit arity]' \
  '--in-place[modify file in-place]' \
  '--print-width[set print width]:width:' \
  '*:file:_files' && ret=0

return ret
