#compdef methylartist
# Documentation: https://github.com/adamewing/methylartist
# methylartist - visualisation of nanopore methylation data

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((locus\:"plot methylation over a locus" region\:"plot methylation over a region" segmeth\:"segment-level methylation table" segplot\:"plot segment methylation distributions" scoredist\:"plot methylation score distribution" composite\:"composite plot over aggregated loci" wgmeth\:"whole-genome methylation summary"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      locus)
        _arguments -s \
          '(-b --bams)'{-b,--bams}'[bam/cram files]:bams:_files' \
          '(-d --data)'{-d,--data}'[methylation data]:data:_files' \
          '-i[interval/locus]:interval' \
          '(-g --gtf)'{-g,--gtf}'[gtf file]:gtf:_files' \
          '--genes[gene names to highlight]:genes' \
          '-l[locus list]:list:_files' \
          '-p[output prefix]:prefix' \
          '--samplepalette[sample palette]:palette' \
          '--highlight_bed[bed of regions to highlight]:bed:_files' \
          '--highlightpalette[highlight palette]:palette' \
          '--ctbam[bam for CpG context]:bam:_files' \
          '--ref[reference fasta]:fasta:_files' \
          '--motif[methylation motif]:motif' \
          '--slidingwindowsize[sliding window size]:size' \
          '-s[sample names]:samples' \
          '--phased[plot phased reads]' \
          '--variants[variants file]:vcf:_files' \
          '--nomask[do not mask]' \
          '--splitvar[split by variant]:var' \
          '--panelratios[panel height ratios]:ratios' && ret=0
        ;;
      region)
        _arguments -s \
          '-i[interval/region]:interval' \
          '-d[methylation data]:data:_files' \
          '-g[gtf file]:gtf:_files' \
          '-p[output prefix]:prefix' \
          '-n[sample names]:names' \
          '-r[reference fasta]:fasta:_files' \
          '--samplepalette[sample palette]:palette' \
          '-l[locus list]:list:_files' \
          '--highlightpalette[highlight palette]:palette' \
          '(-w --windows)'{-w,--windows}'[number of windows]:n' \
          '(-s --smoothwindowsize)'{-s,--smoothwindowsize}'[smoothing window size]:size' \
          '--skip_align_plot[skip alignment plot]' \
          '--panelratio[panel height ratios]:ratios' \
          '--height[plot height]:height' \
          '--genepalette[gene palette]:palette' && ret=0
        ;;
      segmeth)
        _arguments -s \
          '(-d --data)'{-d,--data}'[methylation data]:data:_files' \
          '(-b --bams)'{-b,--bams}'[bam/cram files]:bams:_files' \
          '-i[interval bed]:bed:_files' \
          '(-p --proc)'{-p,--proc}'[number of processes]:n' && ret=0
        ;;
      segplot)
        _arguments -s \
          '-s[segmeth table]:table:_files' \
          '(-v --violin)'{-v,--violin}'[violin plot]' \
          '--svg[output svg]' \
          '(-g --ridge)'{-g,--ridge}'[ridge plot]' \
          '-c[category column]:col' \
          '--palette[color palette]:palette' \
          '--ridge_group_by_annotation[group ridge by annotation]' && ret=0
        ;;
      scoredist)
        _arguments -s \
          '-d[methylation data]:data:_files' \
          '-m[methylation motif]:motif' && ret=0
        ;;
      composite)
        _arguments -s \
          '-d[methylation data]:data:_files' \
          '-s[sample names]:samples' \
          '-r[reference fasta]:fasta:_files' \
          '-t[interval table]:table:_files' \
          '(-p --procs)'{-p,--procs}'[number of processes]:n' \
          '--blocks[block definitions]:blocks' && ret=0
        ;;
      wgmeth)
        _arguments -s \
          '--dss[output DSS-compatible table]' && ret=0
        ;;
    esac
    ;;
esac

return ret
