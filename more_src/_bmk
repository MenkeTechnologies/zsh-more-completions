#compdef bmk
# Documentation: https://github.com/aclindsa/bmk
# Reference accessed: 2026-05-16
# Verified: upstream aclindsa/bmk completion/zsh/_bmk — this completion
# is the upstream-shipped one. (Not Galen Abell's sourcehut bmk — that
# is a different tool with the same binary name.)
# Removed from prior file: bogus man.archlinux.org search URL.

_all_bmk_arguments="-a --add -h --help -e --edit -r --remove -l --list -c --completion-list"
_list_of_bookmarks=$(bmk -c)

_arguments "($_all_bmk_arguments)"{-h,--help}"[display help messages]" \
	"($_all_bmk_arguments)"{-a,--add}"[Add bookmark with path]:bookmark directory:_files -/" \
	"($_all_bmk_arguments)"{-e,--edit}"[Update bookmark to point to new path]:new bookmark directory:_files -/" \
	"($_all_bmk_arguments)"{-r,--remove}"[Remove bookmark]" \
	"($_all_bmk_arguments)"{-l,--list}"[List bookmarks that begin with string]:bookmark prefix:($_list_of_bookmarks)" \
	"1:bmkname:($_list_of_bookmarks)"
