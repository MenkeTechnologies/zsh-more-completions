#compdef richgo
# Documentation: https://github.com/kyoh86/richgo
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# richgo is a thin wrapper around `go`: the first arg is a go subcommand
# (notably `test`) or richgo's own `testfilter`. All other arguments are
# forwarded to `go`. Configuration is via .richstyle YAML and env vars
# (RICHGO_LOCAL, RICHGO_FORCE_COLOR), not CLI flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:(test testfilter build run install vet fmt bench generate get list mod tool)' \
  '*:arguments' && ret=0

return ret
