#compdef mailgraph
# Documentation: https://manpages.org/mailgraph/8
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mailgraph: RRDtool frontend for postfix/sendmail mail stats
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-V --version)'{-V,--version}'[output version]' \
  '(-c --cat)'{-c,--cat}'[read logfile once and exit (do not monitor)]' \
  '(-l --logfile)'{-l,--logfile=}'[monitor this logfile instead of /var/log/syslog]:file:_files' \
  '(-t --logtype)'{-t,--logtype=}'[logfile type]:type:(syslog metalog multilog)' \
  '(-y --year)'{-y,--year=}'[start year of logfile]:year:' \
  '--host=[only entries for HOST (regexp)]:host:' \
  '(-d --daemon)'{-d,--daemon}'[run in background]' \
  '--daemon-pid=[PID file path]:file:_files' \
  '--daemon-rrd=[directory for RRD files]:dir:_files -/' \
  '--daemon-log=[verbose log file]:file:_files' \
  '--ignore-localhost[ignore mail to/from localhost]' \
  '--ignore-host=[ignore mail to/from this host (regexp)]:host:' \
  '--no-mail-rrd[do not update the mail rrd]' \
  '--no-virus-rrd[do not update the virus rrd]' \
  '--no-greylist-rrd[do not update the greylist rrd]' \
  '--rrd-name=[base name for RRD files]:name:' \
  '--rbl-is-spam[count rbl rejects as spam]' \
  '--virbl-is-virus[count virbl rejects as viruses]' && ret=0
return ret
