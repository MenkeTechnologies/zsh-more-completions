#compdef cf-check cfcheck cloudflare-check
# _cf-check — Daniel Miessler cf-check CLI for checking whether a target domain or URL is served behind Cloudflare CDN matching IP ranges DNS CNAME headers Server response patterns and SSL certificate issuer (DanielMiessler team, Go); flag
# upstream: https://github.com/DanielMiessler/cf-check

_cf-check() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input file]:file:_files' \
        '--input=+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-j[JSON output]' \
        '--json[JSON output]' \
        '--show-not-cf[show not behind CF]' \
        '--ipv6[use IPv6]' \
        '*:domain or URL:'
}

_cf-check "$@"
