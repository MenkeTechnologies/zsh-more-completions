#compdef create-hono
# Documentation: https://man.archlinux.org/search?q=create-hono
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-t,--template}'[template to use]:template:(aws-lambda bun cloudflare-pages cloudflare-workers deno fastly lambda-edge netlify nextjs nodejs vercel)' \
  '--install[install dependencies]' \
  '--pm[package manager]:pm:(npm yarn pnpm bun)' \
  '1:project name:' && ret=0

return ret
