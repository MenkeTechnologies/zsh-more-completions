#compdef wondershaper
# Documentation: https://github.com/magnific0/wondershaper
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wondershaper: command line utility to limit an adapter's bandwidth.
# Flags verified from getopts in upstream wondershaper script.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[display help/usage message]' \
  '-v[show version number]' \
  '-a+[network adapter (required, e.g. eth0)]:interface:_net_interfaces' \
  '-d+[maximum download rate in Kbps]:rate:' \
  '-u+[maximum upload rate in Kbps]:rate:' \
  '-p[load presets from configuration file]' \
  '-f+[alternative preset file path]:file:_files' \
  '-c[clear bandwidth limits from adapter]' \
  '-s[show current adapter status]' && ret=0

return ret
