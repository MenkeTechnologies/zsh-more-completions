#compdef wondershaper
# Documentation: https://man.archlinux.org/search?q=wondershaper
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --adapter)'{-a,--adapter}'=[network interface]:interface:_net_interfaces' \
  '(-d --download)'{-d,--download}'=[download rate in kbps]:rate:' \
  '(-u --upload)'{-u,--upload}'=[upload rate in kbps]:rate:' \
  '(-c --clear)'{-c,--clear}'[clear all limits]' \
  '(-s --status)'{-s,--status}'[show current status]' \
  '(-p --show)'{-p,--show}'[show current configuration]' \
  '*:interface:_net_interfaces' && ret=0

return ret
