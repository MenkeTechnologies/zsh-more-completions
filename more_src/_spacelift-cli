#compdef spacelift-cli
# _spacelift-cli — Spacelift CLI for infrastructure-as-code orchestration platform (Spacelift, Go); urfave/cli
# upstream: https://github.com/spacelift-io/spacelift-cli

_spacelift-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:logout'
        'whoami:show current user'
        'profile:manage profiles'
        'stack:manage stacks'
        'module:manage modules'
        'run:trigger runs'
        'task:manage tasks'
        'completion:generate shell completions'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spacelift-cli subcommand' sub ;;
        args)
            case $words[1] in
                login|logout|whoami) _arguments '*:arg:' ;;
                profile) _arguments \
                    '1:profile-cmd:(select list current export)' \
                    '*:arg:' ;;
                stack) _arguments \
                    '1:stack-cmd:(list show trigger lock unlock confirm discard cancel logs local-preview)' \
                    '--id=+[stack id]:id:' \
                    '*:arg:' ;;
                module) _arguments \
                    '1:module-cmd:(list show trigger logs local-preview)' \
                    '--id=+[module id]:id:' \
                    '*:arg:' ;;
                run) _arguments \
                    '--id=+[stack id]:id:' \
                    '--commit-sha=+[commit sha]:sha:' \
                    '--tail[tail logs]' \
                    '*:arg:' ;;
                task) _arguments \
                    '--id=+[stack id]:id:' \
                    '--command=+[command]:cmd:' \
                    '--tail[tail logs]' \
                    '*:arg:' ;;
                completion) _arguments \
                    '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_spacelift-cli "$@"
