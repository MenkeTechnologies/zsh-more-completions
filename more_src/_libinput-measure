#compdef libinput-measure

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'fuzz:print device pointer fuzz'
  'touchpad-pressure:measure touchpad pressure'
  'touchpad-size:measure touchpad size'
  'touchpad-tap:measure tap-to-click delay'
  'touch-size:measure touch size'
  'trackpoint-range:measure trackpoint range'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'libinput-measure command' commands && ret=0 ;;
  (args)
    _arguments \
      '*:device:_files -g "/dev/input/*"' && ret=0 ;;
esac

return ret
