#compdef janitor
# Source: nixpkgs (https://github.com/NixOS/nixpkgs)
# Package: nix-janitor
# Type: maintainer-shipped (nixpkgs)
# Harvested: 2026-05-15

autoload -U is-at-least

_janitor() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-d+[The number of days to keep generations]:KEEP_DAYS: ' \
'--keep-days=[The number of days to keep generations]:KEEP_DAYS: ' \
'-l+[The minimum number of generations to keep]:KEEP_AT_LEAST: ' \
'--keep-at-least=[The minimum number of generations to keep]:KEEP_AT_LEAST: ' \
'--completions=[Generate shell completions]:COMPLETIONS:(bash elvish fish powershell zsh)' \
'(-l --keep-at-least -c --by-count-only)-a[Delete by age only (still keeps at least 1 generation, regardless of age)]' \
'(-l --keep-at-least -c --by-count-only)--by-age-only[Delete by age only (still keeps at least 1 generation, regardless of age)]' \
'(-d --keep-days -a --by-age-only)-c[Delete by count only]' \
'(-d --keep-days -a --by-age-only)--by-count-only[Delete by count only]' \
'(-q --quiet)*-v[Increase verbosity (up to three times)]' \
'(-q --quiet)*--verbose[Increase verbosity (up to three times)]' \
'(-v --verbose)-q[Only log warnings and errors]' \
'(-v --verbose)--quiet[Only log warnings and errors]' \
'(--gc)--dry-run[Do a dry run (do not delete anything)]' \
'(--dry-run)--gc[perform garbage collection after profile deletion]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_janitor_commands] )) ||
_janitor_commands() {
    local commands; commands=()
    _describe -t commands 'janitor commands' commands "$@"
}

if [ "$funcstack[1]" = "_janitor" ]; then
    _janitor "$@"
else
    compdef _janitor janitor
fi
