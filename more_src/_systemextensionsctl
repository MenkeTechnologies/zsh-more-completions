#compdef systemextensionsctl
# Documentation: man systemextensionsctl (macOS); verified locally
# Reference accessed: 2026-05-21
# Verified: /usr/bin/systemextensionsctl usage on macOS 25.4.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
    'list:list system extensions (optionally filtered by category)'
    'reset:forcibly reset all System Extensions state'
    'uninstall:uninstall a system extension by teamID and bundleID'
    'developer:enable or disable developer mode'
    'gc:garbage collect orphaned system extension(s)'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*:: :->args' && ret=0

case $state in
    subcmd)
        _describe 'systemextensionsctl subcommand' subcommands && ret=0
        ;;
    args)
        case $words[1] in
            list)
                _arguments '1::category:' && ret=0
                ;;
            uninstall)
                _arguments \
                    '1:team identifier (or - for empty Team ID)' \
                    '2:bundle identifier' && ret=0
                ;;
            developer)
                _arguments '1:mode:(on off)' && ret=0
                ;;
        esac
        ;;
esac

return ret
