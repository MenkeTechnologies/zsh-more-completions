#compdef home-manager
# _home-manager — rycee Home Manager Nix-based per-user dotfiles manager CLI (rycee / Robert Helgesson, Nix); custom argparse
# upstream: https://github.com/nix-community/home-manager

_home-manager() {
    local -a sub=(
        'help:show help'
        'edit:edit home-manager configuration'
        'option:show options'
        'build:build configuration without activating'
        'instantiate:instantiate the configuration'
        'init:initialize a new home-manager configuration'
        'switch:build and activate configuration'
        'generations:list generations'
        'remove-generations:remove specified generations'
        'expire-generations:expire generations older than given date'
        'packages:list packages in current generation'
        'news:show home-manager news'
        'uninstall:uninstall home-manager'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--file=+[home.nix file]:file:_files -g "home.nix *.nix"' \
        '-f+[home.nix file]:file:_files -g "home.nix *.nix"' \
        '--flake=+[flake URI]:str:' \
        '-b+[backup extension]:str:' \
        '--cores=+[cores]:n:' \
        '-c+[cores]:n:' \
        '--max-jobs=+[max jobs]:n:' \
        '-j+[max jobs]:n:' \
        '--option=+[Nix option]:str:' \
        '-A+[attribute]:str:' \
        '--show-trace[show trace]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--no-out-link[no out link]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '--print-build-logs[print build logs]' \
        '-L[print build logs]' \
        '--substituters=+[substituters]:list:' \
        '--update-input=+[update input]:list:' \
        '--override-input=+[override input]:str:' \
        '--switch[switch after build]' \
        '--ignore-link-conflicts[ignore link conflicts]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'home-manager subcommand' sub ;;
        args)
            case $words[1] in
                option) _arguments \
                    '--all[show all]' \
                    '--xml[xml output]' \
                    '--json[json output]' \
                    '*:option:' ;;
                init) _arguments \
                    '--switch[switch after init]' \
                    '*:dir:_files -/' ;;
                packages) _arguments '*:arg:' ;;
                remove-generations) _arguments '*:generation:' ;;
                expire-generations) _arguments '*:date:' ;;
            esac
            ;;
    esac
}

_home-manager "$@"
