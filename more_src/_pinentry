#compdef pinentry pinentry-curses pinentry-tty pinentry-mac pinentry-gnome3 pinentry-qt pinentry-gtk-2 pinentry-fltk
# Documentation: pinentry-curses --help on pinentry 1.3.2
# Source: pinentry (GnuPG) — ask securely for a secret and print it to stdout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --debug)'{-d,--debug}'[turn on debugging output]' \
    '(-D --display)'{-D,--display=}'[set the X display]:display:' \
    '(-T --ttyname)'{-T,--ttyname=}'[tty terminal node name]:file:_files' \
    '(-N --ttytype)'{-N,--ttytype=}'[tty terminal type]:name:_terminals' \
    '(-C --lc-ctype)'{-C,--lc-ctype=}'[tty LC_CTYPE value]:string:' \
    '(-M --lc-messages)'{-M,--lc-messages=}'[tty LC_MESSAGES value]:string:' \
    '(-o --timeout)'{-o,--timeout=}'[input timeout (seconds)]:secs:' \
    '(-g --no-global-grab)'{-g,--no-global-grab}'[grab keyboard only while window focused]' \
    '(-W --parent-wid)'{-W,--parent-wid=}'[parent window ID for positioning]:wid:' \
    '(-c --colors)'{-c,--colors=}'[custom ncurses colors]:string:' \
    '(-a --ttyalert)'{-a,--ttyalert=}'[alert mode]:mode:(none beep flash)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    && ret=0

return ret
