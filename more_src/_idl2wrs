#compdef idl2wrs
# _idl2wrs — Wireshark idl2wrs CLI converting CORBA IDL Interface Definition Language files to Wireshark dissector C source code generating skeleton .c files for proto_register and proto_reg_handoff (wireshark team, Perl); getopt
# upstream: https://gitlab.com/wireshark/wireshark

_idl2wrs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files -g "*.c *.h"' \
        '--output=+[output file]:file:_files -g "*.c *.h"' \
        '-O+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-d[debug]' \
        '--debug[debug]' \
        '-p+[prefix]:str:' \
        '--prefix=+[prefix]:str:' \
        '-n+[proto name]:str:' \
        '--proto-name=+[proto name]:str:' \
        '-s+[short name]:str:' \
        '--short-name=+[short name]:str:' \
        '-D+[macro]:str:' \
        '-I+[include dir]:dir:_files -/' \
        '--include=+[include dir]:dir:_files -/' \
        '-c[suppress comments]' \
        '--no-comments[suppress comments]' \
        '-r[register]' \
        '--register[register]' \
        '*:idl file:_files -g "*.idl *.IDL"'
}

_idl2wrs "$@"
