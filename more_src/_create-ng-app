#compdef create-ng-app
# Documentation: https://www.npmjs.com/package/create-ng-app
# Reference accessed: 2026-05-24
# Verified: npx create-ng-app --help.

# Zsh completion for create-ng-app - Angular workspace scaffolder (ng new)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--interactive[enable interactive prompts]' \
  '--no-interactive[disable interactive prompts]' \
  '(-d --dry-run)'{-d,--dry-run}'[report activity without writing files]' \
  '--defaults[use defaults without prompts]' \
  '--force[force overwrite existing files]' \
  '(-c --collection)'{-c,--collection=}'[schematics collection]:collection:' \
  '--ai-config=[AI tool config files]:tool:(agents claude copilot cursor gemini jetbrains none windsurf)' \
  '--commit[configure initial Git commit]' \
  '--no-commit[skip initial Git commit]' \
  '--create-application[create initial application project]' \
  '--no-create-application[create empty workspace only]' \
  '--directory=[target directory]:dir:_directories' \
  '--file-name-style-guide=[file naming convention]:style:(2016 2025)' \
  '(-s --inline-style)'{-s,--inline-style}'[inline root component styles]' \
  '(-t --inline-template)'{-t,--inline-template}'[inline root component template]' \
  '--minimal[minimal workspace without testing frameworks]' \
  '--new-project-root=[new project root path]:path:_directories' \
  '--package-manager=[package manager]:manager:(bun npm pnpm yarn)' \
  '(-p --prefix)'{-p,--prefix=}'[selector prefix]:prefix:' \
  '--routing[enable routing in initial app]' \
  '--no-routing[disable routing in initial app]' \
  '(-g --skip-git)'{-g,--skip-git}'[skip git initialization]' \
  '--skip-install[skip package installation]' \
  '(-S --skip-tests)'{-S,--skip-tests}'[skip unit test files]' \
  '--ssr[configure for SSR and SSG]' \
  '--standalone[use standalone API for root component]' \
  '--no-standalone[use NgModule for root component]' \
  '--style=[stylesheet format]:format:(css scss sass less)' \
  ':workspace name:' && ret=0

return ret
