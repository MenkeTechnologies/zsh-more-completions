#compdef docbook2dvi

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --backend)'{-b,--backend}'+[backend]:backend:(jade openjade)' \
  '(-c --cat)'{-c,--cat}'+[SGML catalog]:file:_files' \
  '(-d --dsl)'{-d,--dsl}'+[DSSSL stylesheet]:file:_files' \
  '(-e --encoding)'{-e,--encoding}'+[output encoding]:enc:' \
  '(-i --include)'{-i,--include}'+[include feature]:feature:' \
  '(-o --output)'{-o,--output}'+[output directory]:dir:_files -/' \
  '(-O --stdout)'{-O,--stdout}'[output to stdout]' \
  '(-p --pdf)'{-p,--pdf}'[generate PDF]' \
  '(-s --tomedia)'{-s,--tomedia}'+[media type]:media:(default print screen)' \
  '(-S --string-param)'{-S,--string-param}'+[XSL string param]:param:' \
  '(-t --to)'{-t,--to}'+[output format]:fmt:(dvi)' \
  '(-u --nochunks)'{-u,--nochunks}'[single file output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '*:file:_files -g "*.{xml,sgml}"' && ret=0

return ret
