#compdef lguest

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '--block=+[block device]:file:_files' \
  '--tunnet=+[tunnel network]:opts:' \
  '--initrd=+[initrd file]:file:_files' \
  '--rng[enable rng]' \
  '--username=+[username]:user:_users' \
  '--chroot=+[chroot dir]:dir:_files -/' \
  '1:memory:' \
  '2:kernel image:_files' \
  '*:kernel args:' && ret=0

return ret
