#compdef aprx
# _aprx — Matti Aarnio OH2MQK aprx multi-protocol APRS Internet System digipeater and igate (PertelusEMC team, C); getopt
# upstream: https://github.com/PertelusEMC/aprx

_aprx() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose debug]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "aprx.conf *.conf"' \
        '--config-file=+[config file]:file:_files -g "aprx.conf *.conf"' \
        '-d[daemon mode]' \
        '--daemon[daemon mode]' \
        '-i+[pid file]:file:_files' \
        '--pid-file=+[pid file]:file:_files' \
        '-e[show parsed config]' \
        '--show-config[show parsed config]' \
        '-l[no syslog]' \
        '--no-syslog[no syslog]' \
        '-L[default log]' \
        '--default-log[default log]' \
        '-u+[user]:user:_users' \
        '--user=+[user]:user:_users' \
        '-t+[test sec]:n:' \
        '--test=+[test sec]:n:'
}

_aprx "$@"
