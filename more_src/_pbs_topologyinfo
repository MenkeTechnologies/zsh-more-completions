#compdef pbs_topologyinfo
# Documentation: https://docs.open-mpi.org/en/main/
# PBS: report topology information for vnodes

local ret=1

_arguments -s \
  '(-a --all)'{-a,--all}'[report topology information for all vnodes]' \
  '(-h --help)'{-h,--help}'[print usage and exit]' \
  '(-l --license)'{-l,--license}'[report the number of node licenses required]' \
  '(-s --sockets)'{-s,--sockets}'[report derived socket counts]' \
  '*:vnode:_message "vnode"' && ret=0

return ret
