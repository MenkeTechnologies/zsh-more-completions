#compdef validns
# _validns — validns (DNS zone validator: parses a master zone file and produces RFC-violation reports including missing glue, broken DNSSEC chains, weak ciphers; -p policy file, -P print parse, -z root zone, -q quiet, -v verbose, -f no-NSEC3 checks, -s skip-large-zone heuristics, -t check trust anchors; positional zone file)
# upstream: https://github.com/akamai/validns
# Flags from akamai/validns validns.c on tip.

_validns() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-p+[policy file]:file:_files' \
        '-P[print parsed records]' \
        '-z+[root zone name]:name:' \
        '-q[quiet]' \
        '-f[no NSEC3 checks]' \
        '-s[skip large-zone heuristics]' \
        '-t[trust anchor checks]' \
        '1:zone file:_files'
}

_validns "$@"
