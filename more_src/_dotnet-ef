#compdef dotnet-ef

# Zsh completion for dotnet-ef - Entity Framework Core CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'database:commands to manage the database'
  'dbcontext:commands to manage DbContext types'
  'migrations:commands to manage migrations'
)

local -a database_sub=(
  'drop:drop the database'
  'update:update the database to a specified migration'
)

local -a dbcontext_sub=(
  'info:get information about a DbContext type'
  'list:list available DbContext types'
  'optimize:generate a compiled version of the model used by the DbContext'
  'scaffold:scaffold a DbContext and entity types for a database'
  'script:generate a SQL script from the DbContext'
)

local -a migrations_sub=(
  'add:add a new migration'
  'bundle:create an executable to update the database'
  'has-pending-model-changes:check if there are any pending changes in the model'
  'list:list available migrations'
  'remove:remove the last migration'
  'script:generate a SQL script from migrations'
)

local -a common=(
  '--project[relative path to the project folder]:project:_files -g "*.csproj"'
  '--startup-project[relative path to the startup project]:project:_files -g "*.csproj"'
  '--framework[target framework]:tfm:'
  '--configuration[build configuration]:config:(Debug Release)'
  '--runtime[target runtime]:runtime:'
  '--no-build[do not build the project before running]'
  '--msbuildprojectextensionspath[MSBuild project extensions path]:path:_files -/'
  '--verbose[show verbose output]'
  '--no-color[do not color output]'
  '--prefix-output[prefix output with level]'
  '(-h --help)'{-h,--help}'[show help information]'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show dotnet-ef version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dotnet-ef command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (database)
        _arguments \
          '1:subcommand:->db_sub' \
          '*::arg:->db_args' && ret=0
        case $state in
          (db_sub)
            _describe -t db_sub 'database subcommand' database_sub && ret=0
            ;;
          (db_args)
            case $line[2] in
              (update)
                _arguments $common \
                  '--connection[connection string]:conn:' \
                  '--context[DbContext to use]:context:' \
                  '1:target migration:' && ret=0
                ;;
              (drop)
                _arguments $common \
                  '(-f --force)'{-f,--force}'[do not confirm]' \
                  '--dry-run[show what would be dropped]' \
                  '--context[DbContext to use]:context:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (dbcontext)
        _arguments \
          '1:subcommand:->dbctx_sub' \
          '*::arg:->dbctx_args' && ret=0
        case $state in
          (dbctx_sub)
            _describe -t dbctx_sub 'dbcontext subcommand' dbcontext_sub && ret=0
            ;;
          (dbctx_args)
            case $line[2] in
              (scaffold)
                _arguments $common \
                  '(-d --data-annotations)'{-d,--data-annotations}'[use data annotations]' \
                  '(-c --context)'{-c,--context}'[DbContext name]:name:' \
                  '--context-dir[directory for DbContext file]:dir:_files -/' \
                  '--context-namespace[namespace for DbContext]:ns:' \
                  '(-f --force)'{-f,--force}'[overwrite existing files]' \
                  '(-o --output-dir)'{-o,--output-dir}'[directory for entity types]:dir:_files -/' \
                  '--namespace[namespace for entity types]:ns:' \
                  '--schema[schemas to include]:schema:' \
                  '(-t --table)'{-t,--table}'[tables to include]:table:' \
                  '--use-database-names[use database names as-is]' \
                  '--no-onconfiguring[do not generate OnConfiguring]' \
                  '--no-pluralize[do not pluralize collection names]' \
                  '1:connection string:' \
                  '2:provider:' && ret=0
                ;;
              (info|list)
                _arguments $common && ret=0
                ;;
              (optimize)
                _arguments $common \
                  '(-o --output-dir)'{-o,--output-dir}'[output directory]:dir:_files -/' \
                  '(-n --namespace)'{-n,--namespace}'[namespace]:ns:' \
                  '(-c --context)'{-c,--context}'[DbContext name]:name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (migrations)
        _arguments \
          '1:subcommand:->mig_sub' \
          '*::arg:->mig_args' && ret=0
        case $state in
          (mig_sub)
            _describe -t mig_sub 'migrations subcommand' migrations_sub && ret=0
            ;;
          (mig_args)
            case $line[2] in
              (add)
                _arguments $common \
                  '(-o --output-dir)'{-o,--output-dir}'[migrations directory]:dir:_files -/' \
                  '--namespace[namespace]:ns:' \
                  '(-c --context)'{-c,--context}'[DbContext]:ctx:' \
                  '1:migration name:' && ret=0
                ;;
              (remove)
                _arguments $common \
                  '(-f --force)'{-f,--force}'[revert applied migration]' \
                  '(-c --context)'{-c,--context}'[DbContext]:ctx:' && ret=0
                ;;
              (script)
                _arguments $common \
                  '(-o --output)'{-o,--output}'[output file]:file:_files' \
                  '(-i --idempotent)'{-i,--idempotent}'[generate idempotent script]' \
                  '--no-transactions[do not generate SQL transactions]' \
                  '(-c --context)'{-c,--context}'[DbContext]:ctx:' \
                  '1:from migration:' \
                  '2:to migration:' && ret=0
                ;;
              (bundle)
                _arguments $common \
                  '(-o --output)'{-o,--output}'[output path]:file:_files' \
                  '(-f --force)'{-f,--force}'[overwrite existing]' \
                  '--self-contained[bundle .NET runtime]' \
                  '-r[target runtime]:runtime:' \
                  '--target-runtime[target runtime]:runtime:' \
                  '(-c --context)'{-c,--context}'[DbContext]:ctx:' && ret=0
                ;;
              (list|has-pending-model-changes)
                _arguments $common \
                  '(-c --context)'{-c,--context}'[DbContext]:ctx:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
