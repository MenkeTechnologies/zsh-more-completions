#compdef paket

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add dependencies'
  'auto-restore:toggle automatic restore'
  'clear-cache:clear dependency cache'
  'config:configure paket settings'
  'convert-from-nuget:migrate from NuGet'
  'find-refs:find package references'
  'find-packages:search packages'
  'find-package-versions:locate specific versions'
  'generate-load-scripts:create load scripts'
  'info:show package info'
  'init:initialize paket in project'
  'install:install dependencies'
  'outdated:identify outdated packages'
  'pack:create NuGet packages'
  'push:publish packages'
  'remove:remove dependencies'
  'restore:restore dependencies'
  'simplify:simplify dependencies'
  'show-groups:display dependency groups'
  'show-installed-packages:list installed packages'
  'update:update dependencies'
  'why:explain why a package is referenced'
  'restriction:manage platform restrictions'
)

_arguments -C \
  '--silent[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--log-file=[log file]:file:_files' \
  '--from-bootstrapper[invoked from bootstrapper]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'paket subcommand' subcommands && ret=0
    ;;
esac

return ret
