#compdef protonup

# Zsh completion for protonup - Proton-GE installer/updater (protonup-qt CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d,--dir}'[set Steam compatibility tools directory]:directory:_directories' \
  '(-t --tag)'{-t,--tag}'[install a specific version tag]:tag' \
  '(-y --yes)'{-y,--yes}'[accept confirmation prompts automatically]' \
  '(-l --list)'{-l,--list}'[list installed versions]' \
  '(-r --releases)'{-r,--releases}'[list available releases]' \
  '--remove[remove a specific version]:version' \
  '--download[download only, do not install]' \
  '--output[output directory for downloads]:directory:_directories' \
  '--keep[keep downloaded archive after extraction]' \
  '--no-checksum[skip checksum verification]' && ret=0

return ret
