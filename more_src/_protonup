#compdef protonup
# Documentation: https://github.com/AUNaseef/protonup
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for protonup - Proton-GE installer/updater

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d,--dir}'[set installation directory]:directory:_directories' \
  '(-t --tag)'{-t,--tag}'[install a specific version tag]:tag' \
  '(-y --yes)'{-y,--yes}'[disable prompts and logs]' \
  '(-l --list)'{-l,--list}'[list installed versions]' \
  '(-r --remove)'{-r,--remove}'[remove an existing installation]:version' \
  '(-o --output)'{-o,--output}'[set download directory]:directory:_directories' \
  '--releases[list available versions]' \
  '--download[download only, do not install]' \
  '--dirs[list available install directories]' && ret=0

return ret
