#compdef autokeras-cli autokeras
# _autokeras-cli — Keras Team Auto-Keras autokeras-cli CLI command-line frontend wrapping the AutoKeras Python automated machine learning library built on Keras providing image classification regression text classification structured classification structured regression timeseries forecasting fit predict evaluate export-model AutoModel-Generator (Keras Team team, Python); click
# upstream: https://autokeras.com/

_autokeras-cli() {
    local -a sub=(
        'fit:train an AutoKeras model'
        'predict:run predictions'
        'evaluate:evaluate a model'
        'export-model:export the model'
        'image-classifier:image classifier shortcut'
        'image-regressor:image regressor shortcut'
        'text-classifier:text classifier shortcut'
        'text-regressor:text regressor shortcut'
        'structured-data-classifier:structured-data classifier'
        'structured-data-regressor:structured-data regressor'
        'time-series-forecaster:time-series forecaster'
        'auto-model:custom AutoModel'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--data=+[file]:file:_files' \
        '-d+[data]:file:_files' \
        '--test-data=+[file]:file:_files' \
        '--target=+[column]:str:' \
        '--y-column=+[column]:str:' \
        '--max-trials=+[N]:n:' \
        '--epochs=+[N]:n:' \
        '--batch-size=+[N]:n:' \
        '--objective=+[m]:m:(val_loss val_accuracy val_mean_squared_error val_mean_absolute_error)' \
        '--seed=+[N]:n:' \
        '--validation-split=+[N]:str:' \
        '--verbose-level=+[l]:l:(0 1 2)' \
        '--directory=+[dir]:dir:_files -/' \
        '--project-name=+[name]:str:' \
        '--overwrite[overwrite project]' \
        '--no-overwrite[no overwrite]' \
        '--num-classes=+[N]:n:' \
        '--multi-label[multi-label classification]' \
        '--loss=+[name]:str:' \
        '--metrics=+[list]:str:' \
        '--callbacks=+[list]:str:' \
        '--export-format=+[f]:f:(keras h5 savedmodel tflite onnx)' \
        '-o+[output]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'autokeras-cli subcommand' sub ;;
    esac
}

_autokeras-cli "$@"
