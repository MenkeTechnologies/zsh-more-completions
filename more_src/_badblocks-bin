#compdef badblocks
# _badblocks-bin — search for bad blocks on a device (e2fsprogs); read-only / write-mode block tester
# upstream: https://github.com/tytso/e2fsprogs

_badblocks-bin() {
    _arguments \
        '-b+[block size]:n:' \
        '-c+[blocks per check]:n:' \
        '-d+[read delay factor pct]:n:' \
        '-e+[max bad blocks before abort]:n:' \
        '-f[force]' \
        '-i+[input file with known bad blocks]:file:_files' \
        '-n[non-destructive read-write test]' \
        '-o+[output file]:file:_files' \
        '-p+[# of passes]:n:' \
        '-s[show progress]' \
        '-t+[test pattern]:pattern:' \
        '-v[verbose]' \
        '-w[destructive write-mode test]' \
        '-X[expert mode]' \
        '*:device:_files'
}

_badblocks-bin "$@"
