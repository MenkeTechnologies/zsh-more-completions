#compdef tnsping
# Documentation: https://docs.oracle.com/cd/B19306_01/network.102/b14212/connect.htm
# Reference accessed: 2026-05-17
# Verified: Oracle Net Services Admin Guide. Positional only; no flags.
# Syntax: tnsping net_service_name [count]
# Removed from prior file: bogus man.archlinux.org search URL.

# tnsping: Oracle Net listener reachability ping
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:net service name (from tnsnames.ora):' \
  '2:count (optional repeat):' && ret=0
return ret
