#compdef opensearch

_arguments -s \
  '(- *)'{-V,--version}'[print version and exit]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --daemonize)'{-d,--daemonize}'[start in background]' \
  '(-p --pidfile)'{-p,--pidfile=}'[create pid file at given path]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress stdout/stderr console logging]' \
  '(-s --silent)'{-s,--silent}'[show minimal output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*-E+[configure a setting key=value]:setting:'
