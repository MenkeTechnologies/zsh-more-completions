#compdef radmsg
# _radmsg — FreeRADIUS radmsg (low-level RADIUS packet generator used in tests; -s server, -p port, -S secret, -i id, -c code (1|4|11|12|40|43|44), -d dictionary, -F file with attributes, -x debug, -h help, -V version; positional argument is a list of Attr=Value lines)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Common flag shape from FreeRADIUS dev radmsg helper on tip.

_radmsg() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-s+[server]:host:_hosts' \
        '-p+[port]:port:' \
        '-S+[secret]:secret:' \
        '-i+[id]:id:' \
        '-c+[code]:code:(1 4 11 12 40 43 44)' \
        '-d+[dictionary dir]:dir:_files -/' \
        '-F+[attributes file]:file:_files' \
        '-x[debug]' \
        '*:Attr=Value:'
}

_radmsg "$@"
