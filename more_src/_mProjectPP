#compdef mProjectPP
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mProjectPP.html
# Fast plane-to-plane reprojection of a single FITS image

local ret=1

_arguments -s -S \
  '-z+[apply drizzle algorithm with factor]:factor' \
  '-d+[debugging level (1-5)]:level' \
  '-b+[exclude pixel-width border around edges]:border' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-i+[alternate input header for calculations]:altin.hdr:_files' \
  '-o+[alternate output header for calculations]:altout.hdr:_files' \
  '-h+[FITS extension (HDU) number]:hdu' \
  '-x+[pixel value scaling factor]:scale' \
  '-w+[weight map for input image]:weightfile:_files -g "*.fits"' \
  '-t+[minimum weight to include pixels]:threshold' \
  '-X[reproject entire image without cropping]' \
  '1:input FITS:_files -g "*.fits"' \
  '2:output FITS:_files -g "*.fits"' \
  '3:header template:_files' && ret=0

return ret
