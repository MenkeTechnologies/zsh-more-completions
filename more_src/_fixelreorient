#compdef fixelreorient
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixelreorient.html
# Source: MRtrix3/mrtrix3 cmd/fixelreorient.cpp — reorient fixel directions via warp field (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '1:fixel_in (input fixel directory):_files -/' \
    '2:warp (4D deformation field):_files -g "*.{nii,nii.gz,mif}"' \
    '3:fixel_out (output fixel directory):_files -/' \
    && ret=0

return ret
