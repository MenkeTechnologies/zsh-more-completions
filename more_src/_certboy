}
(( $+functions[_certboy__subcmd__help_commands] )) ||
_certboy__subcmd__help_commands() {
    local commands; commands=(
'check:Check certificates in the context' \
'import:Import a Root CA or ICA folder to create a new context' \
'export:Export server certificate and key to current directory' \
'completion:Generate shell completion scripts for bash, zsh, fish, or powershell' \
'revoke:Revoke (remove) certificates by domain name' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'certboy help commands' commands "$@"
}
(( $+functions[_certboy__subcmd__help__subcmd__check_commands] )) ||
_certboy__subcmd__help__subcmd__check_commands() {
    local commands; commands=()
    _describe -t commands 'certboy help check commands' commands "$@"
}
(( $+functions[_certboy__subcmd__help__subcmd__completion_commands] )) ||
_certboy__subcmd__help__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'certboy help completion commands' commands "$@"
}
(( $+functions[_certboy__subcmd__help__subcmd__export_commands] )) ||
_certboy__subcmd__help__subcmd__export_commands() {
    local commands; commands=()
    _describe -t commands 'certboy help export commands' commands "$@"
}
(( $+functions[_certboy__subcmd__help__subcmd__help_commands] )) ||
_certboy__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'certboy help help commands' commands "$@"
}
(( $+functions[_certboy__subcmd__help__subcmd__import_commands] )) ||
_certboy__subcmd__help__subcmd__import_commands() {
    local commands; commands=()
    _describe -t commands 'certboy help import commands' commands "$@"
}
(( $+functions[_certboy__subcmd__help__subcmd__revoke_commands] )) ||
_certboy__subcmd__help__subcmd__revoke_commands() {
    local commands; commands=()
    _describe -t commands 'certboy help revoke commands' commands "$@"
}
(( $+functions[_certboy__subcmd__import_commands] )) ||
_certboy__subcmd__import_commands() {
    local commands; commands=()
    _describe -t commands 'certboy import commands' commands "$@"
}
(( $+functions[_certboy__subcmd__revoke_commands] )) ||
_certboy__subcmd__revoke_commands() {
    local commands; commands=()
    _describe -t commands 'certboy revoke commands' commands "$@"
}

if [ "$funcstack[1]" = "_certboy" ]; then
    _certboy "$@"
else
    compdef _certboy certboy
fi
