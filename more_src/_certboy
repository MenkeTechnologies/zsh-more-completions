#compdef certboy
# Documentation: https://man.archlinux.org/search?q=certboy
# Reference accessed: 2026-05-16
# Source: cargo binstall certboy@2026.16.49
# Probed via: completion zsh
# Repository: https://github.com/audricsun/certboy

autoload -U is-at-least

_certboy() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-d+[Domain name for certificate/CA (can be specified multiple times for SAN)]:DOMAIN:_default' \
'*--domain=[Domain name for certificate/CA (can be specified multiple times for SAN)]:DOMAIN:_default' \
'--cn=[Common Name for certificate (required for Root CA and ICA)]:CN:_default' \
'--country=[Country code (default\: CN)]:COUNTRY:_default' \
'-c+[Parent CA to sign with (Root CA or ICA name)]:CA:_default' \
'--ca=[Parent CA to sign with (Root CA or ICA name)]:CA:_default' \
'--key-algorithm=[Key algorithm for Root CA (default\: ecdsa)]:KEY_ALGORITHM:(rsa ecdsa)' \
'-e+[Expiration in days. Common values\: 730 (2y), 1095 (3y), 1825 (5y), 3650 (10y), 7300 (20y)]:DAYS:_default' \
'--expiration=[Expiration in days. Common values\: 730 (2y), 1095 (3y), 1825 (5y), 3650 (10y), 7300 (20y)]:DAYS:_default' \
'-C+[Context path for certificates (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'--context=[Context path for certificates (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'-r[Create a Root CA instead of signing a certificate]' \
'--root-ca[Create a Root CA instead of signing a certificate]' \
'-f[Force re-sign existing certificate]' \
'--force[Force re-sign existing certificate]' \
'--encrypt-key[Encrypt generated TLS private key with a passphrase (stored in pass.key)]' \
'*-v[Verbose level (-v=info, -vv=debug, -vvv=trace)]' \
'*--verbose[Verbose level (-v=info, -vv=debug, -vvv=trace)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::domain_args -- Domain arguments (merged with -d/--domain):_default' \
":: :_certboy_commands" \
"*::: :->certboy" \
&& ret=0
    case $state in
    (certboy)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:certboy-command-$line[2]:"
        case $line[2] in
            (check)
_arguments "${_arguments_options[@]}" : \
'-E+[Expiration alert threshold in days (default\: 14 days / 2 weeks)]:DAYS:_default' \
'--expiration-alert=[Expiration alert threshold in days (default\: 14 days / 2 weeks)]:DAYS:_default' \
'-C+[Context path (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'--context=[Context path (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'-r[Check for certificates needing renewal]' \
'--renew[Check for certificates needing renewal]' \
'--detail[Show detailed information including DNS names and IP addresses for TLS certificates]' \
'--auto-fix[Automatically fix certificates with issues (duplicate serials, serial 0, wrong fullchain order)]' \
'-y[Skip confirmation prompts (use with auto-fix to apply fixes without prompting)]' \
'--yes[Skip confirmation prompts (use with auto-fix to apply fixes without prompting)]' \
'--verify-openssl[Verify that private key matches certificate for TLS certs using OpenSSL]' \
'-R[Check remote TLS certificate against local certificate for TLS certs only (not CA/ICA) Shows\: DNS resolution status, resolved IPs, and whether remote uses same TLS cert as local]' \
'--remote[Check remote TLS certificate against local certificate for TLS certs only (not CA/ICA) Shows\: DNS resolution status, resolved IPs, and whether remote uses same TLS cert as local]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
'-C+[Context path for the new certificate store]:PATH:_files' \
'--context=[Context path for the new certificate store]:PATH:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::source -- Paths to the Root CA or ICA folders to import (multiple allowed):_files' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'-C+[Context path (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'--context=[Context path (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':domain -- Domain of the server certificate to export:_default' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Shell to generate completion for:_default' \
&& ret=0
;;
(revoke)
_arguments "${_arguments_options[@]}" : \
'-C+[Context path (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'--context=[Context path (default\: \$XDG_STATE_HOME/certboy or ~/.local/state/certboy; env\: CERTBOY_CONTEXT)]:PATH:_files' \
'-y[Skip confirmation prompts (use with caution)]' \
'--yes[Skip confirmation prompts (use with caution)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::domains -- Domain names of certificates to revoke (can specify multiple):_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_certboy__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:certboy-help-command-$line[1]:"
        case $line[1] in
            (check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(revoke)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_certboy_commands] )) ||
_certboy_commands() {
    local commands; commands=(
'check:Check certificates in the context' \
'import:Import a Root CA or ICA folder to create a new context' \
'export:Export server certificate and key to current directory' \
'completion:Generate shell completion scripts for bash, zsh, fish, or powershell' \
'revoke:Revoke (remove) certificates by domain name' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'certboy commands' commands "$@"
}
(( $+functions[_certboy__subcmd__check_commands] )) ||
_certboy__subcmd__check_commands() {
    local commands; commands=()
    _describe -t commands 'certboy check commands' commands "$@"
}
(( $+functions[_certboy__subcmd__completion_commands] )) ||
_certboy__subcmd__completion_commands() {
