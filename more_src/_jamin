#compdef jamin

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --server)'{-s,--server}'+[jack server name]:srv:' \
  '(-n --no-connect)'{-n,--no-connect}'[do not auto connect]' \
  '*:session file:_files -g "*.jam"' && ret=0

return ret
