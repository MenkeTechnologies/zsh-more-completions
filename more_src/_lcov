#compdef lcov

# Zsh completion for lcov (code coverage)

_lcov() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-c --capture)'{-c,--capture}'[capture coverage data]' \
    '(-z --zerocounters)'{-z,--zerocounters}'[reset all execution counts to zero]' \
    '(-l --list)'{-l,--list}'[list the contents of a tracefile]:tracefile:_files' \
    '(-a --add-tracefile)'{-a,--add-tracefile}'[add contents of tracefile]:tracefile:_files' \
    '(-e --extract)'{-e,--extract}'[extract data from tracefile]:tracefile:_files' \
    '(-r --remove)'{-r,--remove}'[remove data from tracefile]:tracefile:_files' \
    '--diff=[diff two tracefiles]:tracefile:_files' \
    '--summary[show summary of tracefile]' \
    '(-o --output-file)'{-o,--output-file}'[output file]:output file:_files' \
    '(-d --directory)'{-d,--directory}'[use .da files in directory]:directory:_files -/' \
    '(-f --follow)'{-f,--follow}'[follow links when searching]' \
    '-k+[keep going on directory]:directory:_files -/' \
    '--keep=[keep going on directory]:directory:_files -/' \
    '(-b --base-directory)'{-b,--base-directory}'[base directory for relative paths]:directory:_files -/' \
    '--initial[capture initial zero coverage data]' \
    '-t+[test name]:test name:' \
    '--test-name=[test name]:test name:' \
    '--no-checksum[do not create checksums]' \
    '--checksum[create checksums]' \
    '--no-recursion[do not recurse into subdirectories]' \
    '--compat-libtool[enable libtool compatibility mode]' \
    '--no-compat-libtool[disable libtool compatibility mode]' \
    '--gcov-tool=[gcov tool]:tool:_command_names' \
    '--ignore-errors=[ignore errors]:error types:' \
    '--no-external[ignore data from external source files]' \
    '--external[include data from external source files]' \
    '--config-file=[config file]:config file:_files' \
    '--rc=[override configuration]:setting=value:' \
    '--include=[include files matching pattern]:pattern:' \
    '--exclude=[exclude files matching pattern]:pattern:' \
    '--erase-functions[reset function coverage data]' \
    '--from-package=[import coverage data from package]:package:_files' \
    '--to-package=[export coverage data to package]:package:_files' \
    '-q[quiet mode]' \
    '--quiet[quiet mode]' \
    '-v[verbose mode]' \
    '--verbose[verbose mode]' \
    '--version[display version]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '*:patterns:' \
    && ret=0

  return ret
}

_lcov "$@"
