#compdef f2mtz
# Documentation: https://www.ccp4.ac.uk/html/f2mtz.html
# CCP4: convert a formatted reflection file to MTZ format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN[input formatted reflection file]:reflections:_files' \
  'HKLOUT[output MTZ reflection file]:mtz:_files' \
  '*:keyword:(CELL CTYPOUT FILE FORMAT LABOUT NAME SCALE SKIP SYMMETRY TITLE END)' && ret=0

return ret
