#compdef asciidoctor-reducer
# Documentation: https://github.com/asciidoctor/asciidoctor-reducer
# Reduce an AsciiDoc document with include directives to a single document

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information and exit]' \
  '(-v --version)'{-v,--version}'[show version details and exit]' \
  '(-o --output)'{-o,--output}'[designate output filename or stream]:file:_files' \
  '*'{-a,--attribute}'[set document attribute (KEY[=VALUE])]:attribute' \
  '--preserve-conditionals[keep preprocessor conditional directives in reduced source]' \
  '--log-level[minimum logging level]:level:(debug info warn error fatal)' \
  '(-q --quiet)'{-q,--quiet}'[silence all application logging]' \
  '*'{-r,--require}'[load library before reducing]:library' \
  '(-S --safe-mode)'{-S,--safe-mode}'[set safety level]:mode:(unsafe safe server secure)' \
  '--trace[display error backtrace]' \
  '*:asciidoc file:_files -g "*.{adoc,asc,asciidoc}"' && ret=0

return ret
