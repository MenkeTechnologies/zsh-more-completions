#compdef osqueryd

# Zsh completion for osquery - system analytics and monitoring

_arguments -s -S \
  '--config_path[path to the configuration file]:file:_files' \
  '--database_path[path to the database]:directory:_directories' \
  '--extensions_socket[path to the extensions socket]:socket:_files' \
  '--extensions_timeout[timeout for extensions to register]:seconds' \
  '--flagfile[path to a flag file]:file:_files' \
  '--json[output results in JSON format]' \
  '--line[output results one value per line]' \
  '--csv[output results in CSV format]' \
  '--list[list all available tables]' \
  '--separator[set field separator character]:separator' \
  '--header[include column headers in output]' \
  '--verbose[enable verbose informational messages]' \
  '--disable_extensions[disable extension loading]' \
  '--pack[load a query pack by name]:pack name' \
  '--config_plugin[configuration plugin]:plugin' \
  '--logger_plugin[logger plugin]:plugin' \
  '--disable_logging[disable all logging]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon (osqueryd)]' \
  '--ephemeral[skip reading and writing the database]' \
  '--pidfile[path to the PID file]:file:_files' \
  '--config_check[check the configuration and exit]' \
  '--database_dump[dump the contents of the database]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
