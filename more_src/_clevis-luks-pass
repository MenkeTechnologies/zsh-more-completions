#compdef clevis-luks-pass
# Documentation: https://github.com/latchset/clevis/blob/master/src/luks/clevis-luks-pass
# Reference accessed: 2026-05-16
# Verified: upstream src/luks/clevis-luks-pass getopts ":d:s:".

# clevis-luks-pass: print the LUKS slot passphrase for a clevis binding
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[LUKS device]:device:_files -g "/dev/*"' \
  '-s[slot number]:slot:' && ret=0
return ret
