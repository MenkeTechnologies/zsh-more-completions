#compdef extract

# Zsh completion for extract - universal archive extraction tool

_arguments -s -S \
  '-r[remove archive after extraction]' \
  '-d+[extract to directory]:directory:_files -/' \
  '*:archive files:_files -g "*.{tar,tar.gz,tgz,tar.bz2,tbz2,tar.xz,txz,tar.zst,tar.lz,tar.lzma,gz,bz2,xz,zst,lz,lzma,zip,rar,7z,Z,deb,rpm,jar,war,ear,cab,iso,dmg,cpio,arj,lha,lzh,ace,zoo,arc,pax,a,ar}"'
