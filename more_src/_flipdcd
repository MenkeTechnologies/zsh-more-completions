#compdef flipdcd
# Documentation: https://www.ks.uiuc.edu/Development/MDTools/flipdcd/
# FlipDCD - convert the byte ordering (endianism) of NAMD/CHARMM DCD files

local ret=1

_arguments -s \
  '-s[report byte-order status of each file without changing it]' \
  '-B[make/keep each file big-endian]' \
  '-L[make/keep each file little-endian]' \
  '*:DCD file:_files -g "*.(dcd|DCD)"' && ret=0

return ret
