#compdef arangodb
# _arangodb — ArangoDB Starter: launch ArangoDB clusters / single servers (arangodb-helper/arangodb)
# upstream: https://github.com/arangodb-helper/arangodb
# Flags from main.go (cobra + spf13/pflag).

_arangodb() {
    local -a args
    args=(
        '--version[show version and exit]'
        '(-c --configuration)'{-c+,--configuration=}'[configuration file]:file:_files -g "*.(yaml|yml|conf|toml|cfg)"'
        '--log.verbose[turn on debug logging]'
        '--log.console=[send log output to console]:bool:(true false)'
        '--log.file=[send log output to file]:bool:(true false)'
        '--log.color=[colorize log output]:bool:(true false)'
        '--log.time-format=[log time format]:format:(local-datestring utc-datestring local-time utc-time)'
        '--log.dir=[custom log file directory]:dir:_files -/'
        '--log.rotate-files-to-keep=[number of rotated log files to keep]:n:'
        '--starter.mode=[mode of operation]:mode:(cluster single activefailover)'
        '--starter.local[start local slaves to create a machine-local test cluster]'
        '--starter.address=[address under which this server is reachable]:addr:'
        '--starter.host=[address used to bind the starter to]:addr:'
        '--starter.id=[unique identifier of this peer]:id:'
        '--starter.port=[port to listen on for other starters to join]:port:'
        '--starter.unique-port-offsets[give all peers a unique port offset]'
        '--starter.data-dir=[directory to store all data the starter generates]:dir:_files -/'
        '--starter.debug-cluster[log more information to debug a cluster]'
        '--starter.disable-ipv6[do not use IPv6 notation]'
        '--cluster.advertised-endpoint=[external endpoint for the servers]:endpoint:'
        '--cluster.agency-size=[number of agents in the cluster]:n:'
        '--server.use-local-bin[search for binaries in the local directory first]'
        '--server.arangod=[path of arangod]:file:_files'
        '--server.js-dir=[path of arango JS folder]:dir:_files -/'
        '--server.rr=[path of rr]:file:_files'
        '--server.threads=[server.threads of each server]:n:'
        '--server.storage-engine=[storage engine to use]:engine:(mmfiles rocksdb)'
        '--rocksdb.encryption-keyfile=[key file used for RocksDB encryption (EE)]:file:_files'
        '--rocksdb.encryption-key-generator=[program whose output is the RocksDB key (EE)]:file:_files'
        '--docker.endpoint=[endpoint used to reach the docker daemon]:endpoint:'
        '--docker.image=[Docker image used to launch arangod (empty = no docker)]:image:'
        '--docker.imagePullPolicy=[Docker image pull policy]:policy:(Always IfNotPresent Never)'
        '--docker.user=[user inside the Docker container]:user:'
        '--docker.container=[name of the docker container running this process]:name:'
        '--docker.net-host[run containers with --net=host]'
        '--docker.net-mode=[run containers with --net=<value>]:mode:'
        '--docker.privileged[run containers with --privileged]'
        '--docker.tty=[run containers with TTY enabled]:bool:(true false)'
        '--auth.jwt-secret=[plain-text file containing the JWT secret]:file:_files'
        '--ssl.keyfile=[PEM file containing server certificate + private key]:file:_files'
        '--ssl.cafile=[PEM file containing CA certificate for client auth]:file:_files'
        '--ssl.auto-key[create a self-signed certificate and use it as --ssl.keyfile]'
        '--ssl.auto-server-name=[server name in the self-signed certificate]:name:'
        '--ssl.auto-organization=[organization name in the self-signed certificate]:name:'
        '(- *)'{-h,--help}'[show help]'
        '1: :(version)'
    )
    _arguments -s -S $args
}

_arangodb "$@"
