#compdef sqlite-diffable

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'dump:dump SQLite database to diffable directory'
  'load:load diffable directory into SQLite database'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'sqlite-diffable subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (dump)
        _arguments -s -S \
          '1:database file:_files -g "*.db *.sqlite *.sqlite3"' \
          '2:output directory:_files -/' && ret=0
        ;;
      (load)
        _arguments -s -S \
          '1:input directory:_files -/' \
          '2:database file:_files -g "*.db *.sqlite *.sqlite3"' && ret=0
        ;;
    esac
    ;;
esac

return ret
