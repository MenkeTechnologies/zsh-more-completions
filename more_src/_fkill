#compdef fkill

_arguments -s -S \
  '(-f --force)'{-f,--force}'[force kill]' \
  '(-v --verbose)'{-v,--verbose}'[show process arguments]' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '(-t --force-after-timeout)'{-t,--force-after-timeout}'=[force after N seconds]:seconds:' \
  '--smart-case[smart case matching]' \
  '--case-sensitive[case-sensitive matching]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::pid name or :port: _default'
