#compdef fkill
# Documentation: https://github.com/sindresorhus/fkill-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-f --force)'{-f,--force}'[force kill processes]' \
  '(-v --verbose)'{-v,--verbose}'[show process arguments]' \
  '(-s --silent)'{-s,--silent}'[silently kill and always exit 0]' \
  '(-t --force-after-timeout)'{-t+,--force-after-timeout=}'[force kill after N seconds]:seconds:' \
  '--smart-case[case-insensitive matching unless pattern has uppercase]' \
  '--case-sensitive[force case-sensitive matching]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::pid, name or :port:_default'
