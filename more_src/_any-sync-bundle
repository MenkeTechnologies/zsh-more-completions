_any-sync-bundle() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version + exit]' \
        '--debug[enable debug mode with detailed logging]' \
        '--log-level=[log level]:level:(debug info warn error fatal)' \
        '--pprof[enable pprof HTTP server for profiling]' \
        '--pprof-addr=[pprof HTTP server address (default localhost:6060)]:addr:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _asb_cmds=(
                'start-all-in-one:start bundle with embedded MongoDB + Redis (requires Docker/Podman)'
                'start-bundle:start bundle services + use external MongoDB/Redis'
                'help:show help for command'
            )
            _describe -t commands 'any-sync-bundle command' _asb_cmds && ret=0
            ;;
        args)
            case $words[1] in
                start-all-in-one|start-bundle)
                    _arguments \
                        '(-c --bundle-config)'{-c,--bundle-config}'=[path to bundle YAML config]:path:_files -g "*.(yml|yaml)"' \
                        '(-cc --client-config)'{-cc,--client-config}'=[path to write Anytype client YAML]:path:_files -g "*.(yml|yaml)"' \
                        '--initial-storage=[initial bundle data directory]:dir:_files -/' \
                        '*--initial-external-addrs=[initial external addrs (StringSlice)]:addr:' \
                        '--initial-mongo-uri=[initial MongoDB URI]:uri:' \
                        '--initial-redis-uri=[initial Redis URI]:uri:' \
                        '--initial-s3-bucket=[S3 bucket name]:bucket:' \
                        '--initial-s3-endpoint=[S3 endpoint URL]:url:' \
                        '--initial-s3-region=[S3 region (default us-east-1)]:region:' \
                        '--initial-s3-force-path-style[use path-style S3 URLs (required for MinIO)]' \
                        '--initial-filenode-default-limit=[storage limit per space in bytes (default 1 TiB)]:bytes:' \
                        '--debug[enable debug mode]' \
                        '--log-level=[log level]:level:(debug info warn error fatal)' \
                        '--pprof[enable pprof HTTP server]' \
                        '--pprof-addr=[pprof HTTP server address]:addr:' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                help)
                    _arguments \
                        '1:command:(start-all-in-one start-bundle)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_any-sync-bundle "$@"
