#       → import "github.com/urfave/cli/v2"
#       → return &cli.App{ Name: "any-sync-bundle", ..., Flags:
#         buildGlobalFlags(), Commands: []*cli.Command{
#         cmdStartAllInOne(ctx), cmdStartBundle(ctx) } }
#       → flagDebug + flagLogLevel + flagPprof + flagPprofAddr
