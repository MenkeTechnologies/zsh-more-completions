#       → require github.com/libp2p/go-libp2p v0.47.0 (indirect
#                                                via any-sync)
#       → require github.com/libp2p/go-buffer-pool v0.1.0
#                                                  (indirect)
#     raw.githubusercontent.com grishy/any-sync-bundle main main.go
#       → import "github.com/grishy/any-sync-bundle/cmd"
#       → cliRoot := cmd.Root(ctx)
#     raw.githubusercontent.com grishy/any-sync-bundle main
