#compdef vkmark
# Documentation: https://github.com/vkmark/vkmark
# Reference accessed: 2026-05-21
# Verified: upstream source src/options.cpp.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --benchmark)'{-b,--benchmark}'+[benchmark spec]:spec:' \
  '(-s --size)'{-s,--size}'+[window size WxH]:WxH:' \
  '(-l --list-scenes)'{-l,--list-scenes}'[list scenes]' \
  '--show-all-options[show all scene options]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-L --list-devices)'{-L,--list-devices}'[list Vulkan devices]' \
  '(-D --use-device)'{-D,--use-device}'+[device UUID]:uuid:' \
  '--fullscreen[run fullscreen]' \
  '--run-forever[run benchmarks indefinitely]' \
  '(-p --present-mode)'{-p,--present-mode}'+[present mode]:mode:(immediate mailbox fifo fiforelaxed)' \
  '--pixel-format=[pixel format]:fmt:' \
  '--winsys=[window system]:ws:' \
  '--winsys-options=[window system options]:opts:' \
  '--winsys-dir=[window system plugins dir]:dir:_directories' \
  '--data-dir=[data directory]:dir:_directories' && ret=0

return ret
