#compdef vkmark
# Documentation: https://man.archlinux.org/search?q=vkmark
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --benchmark)'{-b,--benchmark}'+[benchmark spec]:spec:' \
  '(-s --size)'{-s,--size}'+[window size WxH]:WxH:' \
  '(-l --list-scenes)'{-l,--list-scenes}'[list scenes]' \
  '(--show-all-options)--show-all-options[show all scene options]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(--window-system)--window-system=+[window system]:ws:(xcb wayland kms direct)' \
  '(-p --present-mode)'{-p,--present-mode}'+[present mode]:mode:(fifo mailbox immediate)' \
  '(--pixel-format)--pixel-format=+[pixel format]:fmt:' \
  '(--device-uuid)--device-uuid=+[device UUID]:uuid:' \
  '(--fullscreen)--fullscreen[fullscreen]' \
  '(--data-dir)--data-dir=+[data dir]:dir:_files -/' \
  '(--use-device-with-uuid)--use-device-with-uuid=+[device UUID]:uuid:' && ret=0

return ret
