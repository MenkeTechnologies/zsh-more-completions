#compdef guix-cli
# _guix-cli — GNU Guix functional package manager CLI alias (GNU Project / Ludovic Courtès, Scheme); custom argparse
# upstream: https://git.savannah.gnu.org/cgit/guix.git

_guix-cli() {
    local -a sub=(
        'install:install packages'
        'remove:remove packages'
        'upgrade:upgrade packages'
        'package:manage user packages'
        'search:search for packages'
        'show:show package definition'
        'shell:start ephemeral environment'
        'environment:start a development environment (deprecated; use shell)'
        'pull:pull guix latest'
        'time-machine:run a guix command from past commit'
        'system:manage system configuration'
        'home:manage user home configuration'
        'gc:run garbage collection'
        'hash:compute hashes'
        'archive:export/import store items'
        'authenticate:check authenticity of commits'
        'build:build derivations'
        'challenge:challenge build results across substitutes'
        'container:run programs in containers'
        'copy:copy store items between machines'
        'cve:print known CVEs'
        'deploy:deploy operating systems'
        'describe:describe current guix revision'
        'docker:build docker images'
        'download:download a file'
        'edit:edit a package definition'
        'environment:manage build environments'
        'extension:Guix extension management'
        'graph:visualize dependency graph'
        'help:show help'
        'import:import package definitions'
        'lint:lint packages'
        'locate:locate file owners'
        'offload:offload computation'
        'pack:create reproducible bundles'
        'processes:list build processes'
        'publish:run substitute server'
        'pull:upgrade guix'
        'refresh:refresh package definitions'
        'repl:Guile REPL'
        'shepherd:Shepherd service manager helpers'
        'size:show closure size'
        'style:reformat package definitions'
        'substitute:internal substituter'
        'update:update guix metadata'
        'version:show version'
        'weather:check substitute availability'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--load-path=+[load path]:dir:_files -/' \
        '-L+[load path]:dir:_files -/' \
        '--no-substitutes[no substitutes]' \
        '--substitute-urls=+[substitute URLs]:list:_urls' \
        '--no-grafts[no grafts]' \
        '--no-offload[no offload]' \
        '--system=+[system type]:str:' \
        '-s+[system type]:str:' \
        '--cores=+[cores]:n:' \
        '-c+[cores]:n:' \
        '--max-jobs=+[max jobs]:n:' \
        '-M+[max jobs]:n:' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--keep-failed[keep failed]' \
        '-K[keep failed]' \
        '--verbosity=+[verbosity]:n:(0 1 2 3)' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--rounds=+[build rounds]:n:' \
        '--debug=+[debug level]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'guix subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|upgrade|show|search|edit|graph|size|weather) _arguments '*:package:' ;;
                package) _arguments \
                    '--install[install]' \
                    '-i[install]' \
                    '--remove[remove]' \
                    '-r[remove]' \
                    '--upgrade[upgrade]' \
                    '-u[upgrade]' \
                    '--profile=+[profile]:str:' \
                    '-p+[profile]:str:' \
                    '--manifest=+[manifest]:file:_files' \
                    '-m+[manifest]:file:_files' \
                    '--switch-generation=+[switch generation]:n:' \
                    '-S+[switch generation]:n:' \
                    '--roll-back[roll back]' \
                    '--list-installed[list installed]' \
                    '--list-generations[list generations]' \
                    '*:package:' ;;
                shell|environment) _arguments \
                    '--manifest=+[manifest]:file:_files' \
                    '-m+[manifest]:file:_files' \
                    '--pure[pure]' \
                    '--container[container]' \
                    '-C[container]' \
                    '--share=+[share host path]:dir:_files -/' \
                    '--expose=+[expose host path]:dir:_files -/' \
                    '*:package-or-command:' ;;
                system|home) _arguments \
                    '1:cmd:(reconfigure switch-generation roll-back build vm container search edit init describe)' \
                    '*:arg:' ;;
                pull|time-machine) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_guix-cli "$@"
