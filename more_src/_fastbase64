#compdef fastbase64

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-b+,--break=}'[break encoded output into lines of NUM]:n:' \
  {-w+,--wrap=}'[same as --break]:n:' \
  {-d,-D,--decode}'[decode input]' \
  {-e,--encode}'[encode input (default)]' \
  '--ignore-garbage[ignore non-alphabet characters when decoding]' \
  {-i+,--input=}'[input file]:file:_files' \
  {-o+,--output=}'[output file]:file:_files' \
  '*:input file:_files' && ret=0

return ret
