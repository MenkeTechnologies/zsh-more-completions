#compdef cntlm
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cntlm.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cntlm (NTLM/NTLMv2 authenticating HTTP proxy)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-A+[Allow ACL rule with IP/mask]:ip/mask' \
  '-a+[Authentication type]:type:(NTLMv2 NTLM2SR NT NTLM LM)' \
  '-B[Enable NTLM-to-basic authentication]' \
  '-c+[Configuration file]:config file:_files' \
  '-D+[Deny ACL rule with IP/mask]:ip/mask' \
  '-d+[Proxy domain/workgroup]:domain' \
  '-F+[Set NTLM authentication flags]:flags' \
  '-f[Run in foreground (do not daemonize)]' \
  '-G+[User-Agent matching for ISA plugin]:pattern' \
  '-g[Gateway mode (listen on all interfaces)]' \
  '-H[Generate password hashes for config file]' \
  '-h[Print help]' \
  '-I[Prompt for password interactively]' \
  '-L+[TCP/IP tunnel: local_port:host:port]:spec' \
  '-l+[Local proxy port]:port' \
  '-M+[Magic NTLM dialect detection on URL]:url' \
  '-N+[Hostnames to bypass parent proxy]:hosts' \
  '-O+[SOCKS5 proxy port]:port' \
  '-P+[PID file]:pid file:_files' \
  '-p+[Account password]:password' \
  '-R+[SOCKS5 proxy user accounts]:user:password' \
  '-r+[Additional header to send to parent proxy]:header:value' \
  '-S+[ISA scanner plugin size limit]:bytes' \
  '-s[Serialize requests (debug only)]' \
  '-T+[Save debug output to trace file]:log file:_files' \
  '-U+[Drop privileges to specified user]:user:_users' \
  '-u+[Proxy account username]:username' \
  '-v[Increase verbosity (debug)]' \
  '-w+[Workstation NetBIOS name]:workstation' \
  '*:proxy:' && ret=0

return ret
