#compdef cntlm

# Zsh completion for cntlm (NTLM / NTLM Session Response / NTLMv2 authenticating HTTP proxy)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-A+[Enable ACL policy file]:acl file:_files' \
  '-a+[Authentication type]:type:(NTLMv2 NTLM2SR NTLM LM)' \
  '-B[Enable NTLM-to-basic authentication]' \
  '-c+[Configuration file]:config file:_files' \
  '-d+[Proxy domain]:domain' \
  '-f[Run in foreground (do not daemonize)]' \
  '-g[Enable gateway mode (listen on all interfaces)]' \
  '-H[Print password hashes for config file]' \
  '-h+[Print help]' \
  '-I[Prompt for password interactively]' \
  '-L+[Set up port forwarding]:spec' \
  '-l+[Local proxy port]:port' \
  '-M+[Run magic NTLM dialect detection on URL]:url' \
  '-N[Do not use NTLM auth (basic/negotiate only)]' \
  '-O+[Set SOCKS5 proxy port]:port' \
  '-o+[Set PassNTLMv2 option]:option' \
  '-P+[PID file]:pid file:_files' \
  '-p+[Account password]:password' \
  '-r+[Additional header to send to parent proxy]:header:value' \
  '-S+[Set the maximum packet size]:bytes' \
  '-s+[Map to parent proxy via header]:header' \
  '-T+[Specify log file]:log file:_files' \
  '-U+[Run as specified user]:user:_users' \
  '-u+[Proxy account username]:username' \
  '-v[Increase verbosity (can repeat)]' \
  '-w+[Proxy account workstation]:workstation' \
  '*:proxy:' && ret=0

return ret
