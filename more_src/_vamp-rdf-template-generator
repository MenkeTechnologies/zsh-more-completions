#compdef vamp-rdf-template-generator
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/vamp-rdf-template-generator.1.html
# Generate a skeleton RDF description file for a Vamp plugin library

local ret=1

_arguments -s -S \
  '-i[run in interactive mode, prompting for PLUGIN_BASE_URI and YOUR_URI]' \
  '-m[set the plugin maker to YOUR_URI]:your uri' \
  '*:plugin:_default' && ret=0

return ret
