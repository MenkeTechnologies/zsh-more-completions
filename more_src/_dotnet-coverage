#compdef dotnet-coverage
# Documentation: https://learn.microsoft.com/en-us/dotnet/core/additional-tools/dotnet-coverage
# dotnet-coverage - collect and merge code coverage data

local ret=1
local -a commands

commands=(
  'merge:merge several code coverage reports into one'
  'collect:collect code coverage data for a .NET process'
  'connect:connect to an existing collection server'
  'snapshot:create a coverage file for an existing collection'
  'shutdown:close an existing code coverage collection'
  'instrument:instrument a binary on disk'
  'uninstrument:restore the original binary from an instrumented one'
)

_arguments -s -S \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--version[display the version of dotnet-coverage]' \
  '(-o --output)'{-o,--output}'=[set the code coverage report output file]:file:_files' \
  '(-f --output-format)'{-f,--output-format}'=[output file format]:format:(coverage xml cobertura)' \
  '(-s --settings)'{-s,--settings}'=[path to XML code coverage settings]:file:_files' \
  '(-id --session-id)'{-id,--session-id}'=[code coverage session id]:id:' \
  '(-if --include-files)'{-if,--include-files}'=[files to statically instrument]:files:_files' \
  '(-sv --server-mode)'{-sv,--server-mode}'[start the collector in server mode]' \
  '(-b --background)'{-b,--background}'[start collection in a new background process]' \
  '(-t --timeout)'{-t,--timeout}'=[interprocess communication timeout in ms]:ms:' \
  '--remove-input-files[remove all merged input coverage reports]' \
  '(-tn --tag-name)'{-tn,--tag-name}'=[snapshot tag name in the coverage file]:name:' \
  '(-tid --tag-identifier)'{-tid,--tag-identifier}'=[snapshot tag identifier]:id:' \
  '(-r --reset)'{-r,--reset}'[clear existing coverage after creating a file]' \
  '(-l --log-file)'{-l,--log-file}'=[set the log file path]:file:_files' \
  '(-ll --log-level)'{-ll,--log-level}'=[set the log level]:level:(Error Info Verbose)' \
  '(-dco --disable-console-output)'{-dco,--disable-console-output}'[disable console output]' \
  '--nologo[do not display the Code Coverage banner]' \
  '1:command:->cmds' \
  '*::arg:_files' && ret=0

case $state in
  cmds) _describe -t commands 'dotnet-coverage command' commands && ret=0 ;;
esac

return ret
