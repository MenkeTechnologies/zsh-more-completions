_berty() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'daemon:start a full Berty instance (Protocol + Messenger)'
        'account-daemon:start a full Berty instance (Berty Account)'
        'mini:start a terminal-based mini client (tcell)'
        'banner:print the Berty banner of the day'
        'version:print software version'
        'info:display system info'
        'groupinit:initialise a new multi-member group'
        'share-invite:share invite link on terminal or Discord dev channel'
        'token-server:token server (basic, no auth or logging)'
        'repl-server:replication server'
        'peers:list peers'
        'export:export messenger data from a berty node'
        'remote-logs:stream logs from a remote node'
        'service-key:generate keys for managed services'
        'push-server:push relay server'
        'p2p:libp2p identity helpers'
        'relay:libp2p circuit relay server'
        'vc-issuer:verifiable credentials issuer service'
        'directory-service:directory service'
        'gui:desktop GUI mode (requires fyne build tag)'
    )

    local -a p2p_subcmds
    p2p_subcmds=(
        'generate-id:generate a libp2p identity key (optional path)'
        'load-id:load an existing libp2p identity key (optional path)'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'berty subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                p2p)
                    _arguments -C \
                        '(-): :->p2psub' \
                        '*::p2parg:->p2parg' && ret=0
                    case $state in
                        p2psub)
                            _describe -t commands 'p2p subcommand' p2p_subcmds && ret=0
                            ;;
                        p2parg)
                            _arguments '1:identity file path:_files' && ret=0
                            ;;
                    esac
                    ;;
                daemon|account-daemon|mini|banner|version|info|groupinit|share-invite|token-server|repl-server|peers|export|remote-logs|service-key|push-server|relay|vc-issuer|directory-service|gui)
                    _message "$line[1] flags - run 'berty $line[1] -h' for the full list"
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_berty "$@"
