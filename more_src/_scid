#compdef scid scid_vs_pc
# Documentation: https://man.archlinux.org/search?q=scid
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-locale+[locale]:locale:' \
  '-encoding+[default encoding]:enc:' \
  '*:file:_files -g "*.{si4,pgn,pgn.gz}"' && ret=0

return ret
