#compdef scid scid_vs_pc
# Documentation: https://scid.sourceforge.net/
# Reference accessed: 2026-05-16
# Verified: SCID upstream (Shane's Chess Information Database). SCID
# accepts only positional database/PGN/EPD files; everything else is
# Tcl/Tk in-app menus. No documented CLI flag table.
# Removed from prior file: fabricated -help/-version/-locale/-encoding
# flags and bogus man.archlinux.org search URL.

# scid: chess database GUI (Tcl/Tk, positional args only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:chess database/PGN/EPD:_files -g "*.(si4|si3|pgn|pgn.gz|epd)(-.)"' && ret=0
return ret
