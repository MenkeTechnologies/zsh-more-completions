#compdef kysely-codegen
# Documentation: https://man.archlinux.org/search?q=kysely-codegen
# Reference accessed: 2026-05-16

_kysely-codegen() {
    _arguments \
        '--url[Database connection string]:url:' \
        '--dialect[SQL dialect]:dialect:(postgres mysql sqlite mssql libsql bun-sqlite)' \
        '--out-file[Output file path]:file:_files' \
        '--include-pattern[Glob pattern to filter tables]:pattern:' \
        '--exclude-pattern[Glob pattern to filter tables]:pattern:' \
        '--camel-case[Use CamelCasePlugin for column names]' \
        '--singularize[Singularize generated type aliases]' \
        '--runtime-enums[Generate runtime enums (PostgreSQL)]' \
        '--overrides[Specify type overrides]:json:' \
        '--custom-imports[Specify custom type imports]:json:' \
        '--env-file[Path to environment file]:file:_files' \
        '--print[Print output to terminal instead of file]' \
        '(-h --help)'{-h,--help}'[Display help]'
}

_kysely-codegen "$@"
