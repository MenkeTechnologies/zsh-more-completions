#compdef strip-nondeterminism
# Strip nondeterministic information from files

local ret=1

_arguments -s -S \
  '-t[specify file type]:type:(ar cpio gettext gzip jar javaproperties pearregistry png zip)' \
  '-T[specify timestamp]:timestamp:' \
  '-c[specify clamp timestamp]:timestamp:' \
  '--clamp-timestamp[clamp to timestamp]' \
  '-v[verbose output]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0

return ret
