#compdef funcen
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/funcen.1
# Iteratively compute the centroid within regions of a Funtools table

local ret=1

_arguments -s -S \
  '-i[use image filtering instead of event filtering]' \
  '-n+[maximum iterations (default 0)]:iter' \
  '-t+[pixel tolerance for convergence (default 1.0)]:tol' \
  '-v+[output verbosity]:level:(0 1 2 3)' \
  '1:input file:_files' \
  '2:region' && ret=0

return ret
