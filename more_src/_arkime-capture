#compdef arkime-capture arkime_capture
# _arkime-capture — Arkime capture-side daemon CLI capturing live pcap or offline-trace traffic indexing protocol metadata and PCAP segments into Elasticsearch/OpenSearch viewer cluster (arkime team, C); getopt
# upstream: https://github.com/arkime/arkime

_arkime-capture() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.ini config.ini arkime.ini"' \
        '--config=+[config file]:file:_files -g "*.ini config.ini arkime.ini"' \
        '-n+[node name]:str:' \
        '--node=+[node name]:str:' \
        '-r+[pcap file]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '--read=+[pcap file]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '-R+[pcap directory]:dir:_files -/' \
        '--recursive[recursive]' \
        '--copy[copy pcap]' \
        '--monitor[monitor dir]' \
        '--insecure[insecure]' \
        '--debug[debug]' \
        '-o+[opt=value]:str:' \
        '--option=+[opt=value]:str:' \
        '--tag=+[tag]:str:' \
        '--flush[flush after each pcap]' \
        '--scheme[scheme aware]' \
        '--skipUpgrade[skip upgrade]' \
        '--regressionTests[regression tests]' \
        '--dryrun[dry run]' \
        '--no-pcap-rate[no rate]' \
        '--tests[run unit tests]' \
        '*:command:'
}

_arkime-capture "$@"
