#compdef matrixClusterColumns
# UCSC kent: group the columns of a matrix into clusters

local ret=1

_arguments -s -S \
  '-makeIndex=[write index file with matrix column, file position, line length]:file:_files' \
  '-median[output median rather than mean cluster value]' \
  '-excludeZeros[exclude zeros when calculating mean/median]' \
  '1:input matrix tsv:_files -g "*.tsv"' \
  '2:meta tsv:_files -g "*.tsv"' \
  '3:cluster field:' \
  '4:output matrix tsv:_files -g "*.tsv"' \
  '5:output stats tsv:_files -g "*.tsv"' \
  '*:more cluster/outMatrix/outStats triples:_files' && ret=0

return ret
