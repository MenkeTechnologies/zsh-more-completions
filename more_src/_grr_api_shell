#compdef grr_api_shell
# Documentation: https://github.com/google/grr/blob/master/api_client/python/README.md
# GRR API interactive shell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--page_size=[page size for paging collections]:size' \
  '--basic_auth_username=[HTTP basic auth username]:user' \
  '--basic_auth_password=[HTTP basic auth password]:password' \
  '--debug[enable debug logging]' \
  '--exec_code=[run code instead of starting console]:code' \
  '--exec_file=[execute a file]:file:_files' \
  '*:api_endpoint:_hosts' && ret=0

return ret
