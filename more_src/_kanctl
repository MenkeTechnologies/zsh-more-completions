#compdef kanctl
# Kanister CLI: create and validate Kanister custom resources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'+[override namespace from kubectl context]:namespace' \
  '--dry-run[print resource YAML without creating it]' \
  '--skip-validation[skip validation before creation]' \
  '*:command:(create validate)' && ret=0

return ret
