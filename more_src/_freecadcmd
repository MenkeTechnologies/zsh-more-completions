#compdef freecadcmd
# Documentation: https://manpages.debian.org/unstable/freecad/freecadcmd.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --console)'{-c,--console}'[start an interactive console]' \
  '(-l --log-file)'{-l,--log-file}'+[log file]:file:_files' \
  '(-u --user-cfg)'{-u,--user-cfg}'+[user config file]:file:_files' \
  '(-s --system-cfg)'{-s,--system-cfg}'+[system config file]:file:_files' \
  '(-t --run-test)'{-t,--run-test}'+[run unit test]:test:' \
  '(-M --module-path)'{-M,--module-path}'+[additional module path]:dir:_files -/' \
  '(-P --python-path)'{-P,--python-path}'+[Python path]:dir:_files -/' \
  '(-d --disable-checking-for-3d-view)'{-d,--disable-checking-for-3d-view}'[disable 3D view checks]' \
  '*:file:_files -g "*.{FCStd,FCStd1,FCMacro,py,iges,igs,step,stp,stl,brep,obj,dxf,svg}"' && ret=0

return ret
