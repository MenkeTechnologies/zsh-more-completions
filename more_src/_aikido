#compdef aikido aikido-cli
# _aikido — Aikido Security all-in-one AppSec/CSPM CLI (Aikido, Go); spf13/cobra
# upstream: https://github.com/AikidoSec/aikido-cli

_aikido() {
    local -a sub=(
        'login:authenticate'
        'logout:logout'
        'whoami:show current user'
        'config:manage CLI config'
        'scan:run a security scan'
        'sbom:work with SBOM'
        'iac:scan IaC'
        'container:scan container image'
        'license:scan licenses'
        'secrets:scan for secrets'
        'malware:scan for malware'
        'workflow:manage workflows'
        'webhook:manage webhooks'
        'integration:manage integrations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[api token]:str:' \
        '--api-key=+[api key]:str:' \
        '--region=+[region]:r:(eu us)' \
        '--profile=+[profile]:str:' \
        '--output=+[output format]:fmt:(table json yaml sarif)' \
        '-o+[output format]:fmt:(table json yaml sarif)' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aikido subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '1:cmd:(repo dir image url ci)' \
                    '--repo=+[repo url]:url:_urls' \
                    '--branch=+[branch]:str:' \
                    '--severity=+[severity threshold]:t:(low medium high critical)' \
                    '--exit-on=+[exit policy]:p:(all fail)' \
                    '*:path:_files' ;;
                sbom) _arguments \
                    '1:cmd:(generate upload list)' \
                    '--format=+[format]:fmt:(cyclonedx spdx)' \
                    '--output=+[output file]:file:_files' \
                    '*:arg:' ;;
                iac|container|license|secrets|malware) _arguments \
                    '*:path:_files' ;;
                workflow|webhook|integration) _arguments \
                    '1:cmd:(list get create update delete)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_aikido "$@"
