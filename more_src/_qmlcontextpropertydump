#compdef qmlcontextpropertydump
# Documentation: https://doc.qt.io/qt-6/qtqml-tooling-qmllint.html
# Reference accessed: 2026-05-20
# Verified: local `qmlcontextpropertydump --help` (Qt 6 tool).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including generic Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --cpp-source-directory)'{-s,--cpp-source-directory}'+[C++ source folder to scan]:source dir:_files -/' \
  '(-b --build-directory)'{-b,--build-directory}'+[build folder for .qt/contextPropertyDump.ini]:build dir:_files -/' \
  '*:project directory:_files -/' && ret=0

return ret
