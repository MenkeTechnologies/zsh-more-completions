#compdef qmlcontextpropertydump
# Documentation: https://man.archlinux.org/search?q=qmlcontextpropertydump
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '*:project directory:_files -/' && ret=0

return ret
