#compdef fugue
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fugue.html
# FSL FUGUE: FMRIB's Utility for Geometrically Unwarping EPIs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[filename of input volume]:input:_files' \
  '-p[filename of unwrapped phase image]:phase:_files' \
  '--phasemap=[filename for input phase image]:phasemap:_files' \
  '--dwell=[EPI dwell time per phase-encode line (sec)]:dwell:' \
  '--asym=[fieldmap asymmetric spin echo time (sec)]:asym:' \
  '--dwelltoasym=[dwell to asym time ratio]:ratio:' \
  '-s[apply 2D Gaussian smoothing of sigma (in mm)]:sigma:' \
  '--smooth3=[apply 3D Gaussian smoothing of sigma (in mm)]:sigma:' \
  '-m[apply 2D median filtering]' \
  '--despike[apply a 2D de-spiking filter]' \
  '--poly=[apply polynomial fitting of order N]:order:' \
  '--fourier=[apply Fourier (sinusoidal) fitting of order N]:order:' \
  '--nokspace[do not use k-space forward warping]' \
  '-u[apply unwarping and save as filename]:unwarp:_files' \
  '-w[apply forward warping and save as filename]:warp:_files' \
  '--mask=[filename for loading valid mask]:mask:_files' \
  '--unwarpdir=[direction of unwarping]:dir:(x y z x- y- z-)' \
  '--phaseconj[apply phase conjugate method of unwarping]' \
  '--icorr[apply intensity correction to unwarping]' \
  '--icorronly[apply intensity correction only]' \
  '--saveshift=[filename for saving pixel shift volume]:file:_files' \
  '--loadshift=[filename for reading pixel shift volume]:file:_files' \
  '--savefmap=[filename for saving fieldmap (rad/s)]:file:_files' \
  '--loadfmap=[filename for loading fieldmap (rad/s)]:file:_files' \
  '--unmaskfmap[saved fieldmap is not masked]' \
  '--unmaskshift[saved shift volume is not masked]' \
  '--nofill[do not extrapolate fieldmap when calculating shifts]' \
  '--noextend[do not extend fieldmap]' \
  '-v[verbose output]' \
  '*:image:_files' && ret=0

return ret
