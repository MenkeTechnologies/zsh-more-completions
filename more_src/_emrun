#compdef emrun
# Documentation: https://emscripten.org/docs/compiling/Running-html-files-with-emrun.html
# emrun - run Emscripten-generated HTML pages via a local web server

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--browser=[browser alias or executable path to launch]:browser:' \
  '--list_browsers[enumerate browser aliases on the system]' \
  '--no_browser[run web server without spawning a browser]' \
  '--no_server[do not launch web server; run via file:// protocol]' \
  '--serve_after_close[keep server running after browser is closed]' \
  '--serve_after_exit[keep server running after page calls exit()]' \
  '--serve_root=[directory to use as web server root]:directory:_files -/' \
  '--port=[web server TCP port (default 6931)]:port:' \
  '--hostname=[web server TCP hostname (default localhost)]:hostname:' \
  '--silence_timeout=[seconds without output before page is hung]:seconds:' \
  '--timeout=[seconds before whole page run is hung]:seconds:' \
  '--timeout_returncode=[process return code on timeout]:code:' \
  '--verbose[print detailed information about emrun internal steps]' \
  '--log_stdout=[write application stdout to named file]:file:_files' \
  '--log_stderr=[write application stderr to named file]:file:_files' \
  '--system_info[print system information before launching]' \
  '--browser_info[print information about the browser to be launched]' \
  '--no_emrun_detect[hide warning if HTML was not built with --emrun]' \
  '--kill_start[terminate target browser processes before starting]' \
  '--kill_exit[terminate target browser processes when emrun quits]' \
  '--android[enable browser-based testing on Android devices]' \
  '*:html file:_files -g "*.html"' && ret=0

return ret
