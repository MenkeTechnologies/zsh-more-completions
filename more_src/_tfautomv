#compdef tfautomv
# Documentation: https://man.archlinux.org/search?q=tfautomv
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '--ignore=[regex to ignore resources]:pattern:' \
  '--preplanned=[path to plan file]:file:_files' \
  '*:directories:_directories'
