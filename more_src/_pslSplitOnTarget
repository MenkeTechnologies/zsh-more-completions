#compdef pslSplitOnTarget
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: split psl files into one per target

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-maxTargetCount=[maximum allowed targets]:n:' \
  '-lump[hash on target name to lump together]' \
  ':in psl:_files' \
  ':out dir:_files -/' && ret=0

return ret
