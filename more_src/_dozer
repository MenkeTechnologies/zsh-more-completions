#compdef dozer
# =============================================================================
# dozer — getdozer/dozer's "Dozer" — a Rust
#   REAL-TIME DATA MOVEMENT engine that
#   captures changes from operational
#   databases (Postgres logical replication,
#   MySQL CDC, Snowflake, Kafka) via CDC,
#   runs INCREMENTAL STREAMING SQL
#   transformations through an internal
#   dozer-sql / DataFusion-shaped query
#   engine, and sinks the results into ANY
#   of: ClickHouse, gRPC API server, REST
#   API server, Kafka, S3, SnowFlake.  Built
#   on direct `clickhouse-rs` (the canonical
#   Rust ClickHouse client) for the
#   ClickHouse sink path.  Rust=108 leader
#   bump opening Axis 53.
#
# AXIS 53 — CLICKHOUSE CLIENT LIBRARY — OPENS @ R801
# ===================================================
# Establishes the 53rd three-language axis in
# the corpus.  This axis covers CLI tools
# written in language X that ship a DIRECT
# library binding to ClickHouse's binary
# wire protocol (the native TCP+binary
# protocol, distinct from the HTTP+JSON
# interface).  Canonical implementations per
# language:
#   * Rust       : clickhouse-rs (this entry,
#                  via getdozer's fork)
#                  — the canonical pure-Rust
#                    ClickHouse client.
#                    Originally suharev7/
#                    clickhouse-rs, now also
#                    maintained at multiple
#                    forks (loyd/, getdozer/,
#                    ClickHouse-/, etc.) for
#                    different feature
#                    requirements.  Speaks
#                    the native TCP protocol
#                    + binary serialisation
#                    for max throughput
#                  — direct dep at
#                    `getdozer/dozer`
#                    Cargo.toml patch line:
#                    `clickhouse-rs = { git =
#                    "https://github.com/
#                    getdozer/clickhouse-rs" }`
#                    consumed by the
#                    `dozer-sink-clickhouse`
#                    workspace crate
#   * Go         : ClickHouse/clickhouse-go —
#                  the official Go driver
#                  from ClickHouse Inc.  R802
#                  will close the Go side
#   * TS-Node    : @clickhouse/client — the
#                  official TypeScript client.
#                  R803 will close the TS-
#                  Node side
#
# ClickHouse is a column-oriented analytics
# database (Apache 2.0, originally by
# Yandex, now ClickHouse Inc.).  All three
# clients above speak its NATIVE TCP
# protocol with binary block transmission —
# substantially faster than the HTTP+JSON
# interface that's also exposed.  ClickHouse
# protocol has revisioned bidirectional
# block streaming, server-side query
# rewriting, distributed query execution
# coordination, and binary type encoding
# that maps directly to columnar storage
# blocks — none of which the HTTP interface
# exposes
#
# Distinguishing dozer from sibling corpus
# data-movement tooling:
#   - VECTOR (`_vector`, vectordotdev): also
#     uses clickhouse-rs.  Vector's niche is
#     observability (logs/metrics/traces).
#     dozer's niche is database CDC
#   - BENTHOS / BENTO / REDPANDA-CONNECT
#     (`_benthos`, `_bento`, `_connect`,
#     `_rpk`): general-purpose stream
#     processors.  dozer is specifically
#     for OLTP-to-OLAP replication
#   - ARKFLOW (R781, `_arkflow`): general-
#     purpose Rust stream processor.  dozer
#     is verticalised for CDC + API serving
#   - KAFKA CONNECT (JVM): the canonical
#     Java CDC tool.  Heavy install,
#     JVM-bound, dozer is single-binary
#     Rust
#   - DEBEZIUM (JVM, Kafka Connect plugin):
#     CDC source for many databases. dozer
#     embeds its own CDC source layer in-
#     process, no Kafka Connect needed
#   - FLINK / KAFKA STREAMS / KSQLDB
#     (JVM-hosted): heavy operationally.
#     dozer is single-binary Rust
#   - MATERIALIZE / RISINGWAVE (Rust):
#     streaming-database angle (results
#     are queryable via SQL inside the
#     same process).  dozer's angle is
#     SINKING results out to OTHER systems
#     (ClickHouse, gRPC API, REST API)
#   - DOZER-CLI is the ORCHESTRATOR — it
#     reads dozer-config.yaml, builds the
#     pipeline DAG, runs all sources/
#     processors/sinks, and exposes a
#     management UI server via the `ui`
#     subcommand
#
# KEY DOZER FEATURES:
#   - YAML CONFIG-DRIVEN PIPELINES — the
#     `dozer-config.yaml` declares
#     `sources:` (Postgres CDC, MySQL CDC,
#     Snowflake, Kafka), `endpoints:`
#     (gRPC/REST API output), `sql:` (the
#     in-pipeline streaming SQL transform),
#     `sinks:` (ClickHouse, Kafka, Snowflake,
#     S3).  No code, no compile.  `dozer
#     run` parses + runs
#   - DOZER-SQL ENGINE — incremental
#     streaming SQL transformations
#     compiled from the YAML config.
#     Uses DataFusion-shaped query
#     planning.  Maintains stateful
#     window / aggregate / join state
#     in a local LMDB / sled-like
#     store
#   - GRPC + REST API GENERATION — for
#     every `endpoint:` in the config,
#     dozer emits a tonic-based gRPC
#     server PLUS an actix-web REST
#     server.  Schemas auto-generated
#     from the SQL output types.  No
#     manual codegen
#   - CLICKHOUSE SINK — `dozer-sink-
#     clickhouse` ingests SQL output
#     into ClickHouse via the native
#     binary protocol, with batching +
#     schema-on-write inference
#   - LIVE WEB UI — `dozer ui` starts an
#     embedded HTTP server that serves
#     the Dozer App UI (a React SPA
#     downloaded by `dozer ui update`).
#     Visualises the pipeline DAG,
#     shows source/sink status, exposes
#     live data preview
#   - CONFIG OVERRIDES VIA JSON POINTERS
#     — `--config-overrides /sources/0/
#     config/host=db.example.com` lets
#     CI pipelines override individual
#     YAML keys without templating
#   - BUILD ARTIFACT LOCK — `dozer build
#     --locked` requires `dozer-lock.
#     yaml` to be up-to-date (reproducible
#     CI builds)
#   - DEPLOY (HIDDEN) — `dozer-cli` has
#     a `Deploy` struct in types.rs for
#     pushing builds to a target URL,
#     though it's not currently exposed
#     as a top-level subcommand
#
# CLI ARGUMENT PARSER — clap 4.4 derive.
# Top-level `Cli` struct with five global
# flags + a `Commands` subcommand enum.
#
# CONFIG FILE LOOKUP:
# `-c/--config-path` defaults to a list of
# pattern strings from `dozer_types::
# constants::DEFAULT_CONFIG_PATH_PATTERNS`,
# typically `dozer-config.yaml`, `dozer.
# yaml`, etc.  Glob patterns supported.
# Multiple `-c` flags compose multiple
# config files into one pipeline
#
# CRITICAL DIRECT DEPENDENCIES (from
# dozer-cli/Cargo.toml):
#   - clickhouse-rs (git patch via
#     getdozer/clickhouse-rs)
#                              — ClickHouse
#                                native TCP
#                                client
#                                [AXIS 53 LIBRARY]
#                                consumed by
#                                `dozer-sink-
#                                clickhouse`
#   - tonic 0.11 (tls + tls-roots)
#                              — gRPC server
#                                for endpoints
#   - tonic-reflection 0.11    — gRPC
#                                reflection
#                                API
#   - tonic-web 0.11           — gRPC-web
#                                shim for
#                                browser
#                                clients
#   - actix-web 4.4            — REST API
#                                server for
#                                endpoints
#   - clap 4.4 (derive)        — CLI parser
#   - tokio 1.x (full)         — async runtime
#   - prost-reflect 0.12 (serde +
#     text-format)               — protobuf
#                                reflection
#                                for runtime
#                                schema
#                                discovery
#   - reqwest 0.11 (rustls-tls)
#                              — HTTP client
#                                for UI
#                                downloads
#   - rustyline 13.0           — CLI REPL
#                                editor
#                                primitives
#   - handlebars 4.4           — template
#                                engine for
#                                generated
#                                code
#   - tower 0.4 + tower-http   — middleware
#                                0.4          stack
#   - zip 0.6 (deflate)        — UI bundle
#                                extraction
#   - include_dir 0.7          — embed UI
#                                assets in
#                                the binary
#   - dozer-types / dozer-     — workspace
#     core / dozer-ingestion /   crates
#     dozer-sql / dozer-
#     tracing / dozer-sink-
#     clickhouse
#
# AGPL-3.0-or-later licensed (the cli crate;
# workspace mixed AGPL + Apache).  Rust
# 2021 edition.
#
# UPSTREAM:
#   * Source             : https://github.com/getdozer/dozer
#   * Site               : https://getdozer.io
#   * Docs               : https://getdozer.io/docs
#   * clickhouse-rs fork : https://github.com/getdozer/clickhouse-rs
#   * License            : AGPL-3.0-or-later (CLI crate)
#   * Maintainer         : getdozer team
#
# INSTALL:
#   # From source
#   git clone https://github.com/getdozer/dozer
#   cd dozer
#   cargo build --release
#   sudo install -m 0755 target/release/dozer /usr/local/bin/
#
#   # From release binary
#   # https://github.com/getdozer/dozer/releases
#
#   # Docker
#   docker pull getdozer/dozer:latest
#
# USAGE EXAMPLES:
#
#   # Build pipeline definitions from
#   # dozer-config.yaml in the current dir
#   dozer build
#
#   # Run the pipeline (uses cached build
#   # artifacts if available)
#   dozer run
#
#   # Build + run with an explicit config
#   # path
#   dozer -c /etc/dozer/prod-config.yaml run
#
#   # Multiple config files merged
#   dozer -c base.yaml \
#         -c clickhouse-sink.yaml \
#         -c grpc-api.yaml run
#
#   # Override individual config values
#   dozer --config-overrides /sources/0/config/host=prod-db.example.com \
#         --config-overrides /sinks/0/config/url=https://clickhouse.example.com \
#         run
#
#   # Force a fresh build (ignore lock file)
#   dozer build -f
#
#   # Locked build (CI-friendly; fails if
#   # dozer-lock.yaml is stale)
#   dozer build --locked
#
#   # Clean home directory (all data, schemas,
#   # cache)
#   dozer clean
#
#   # Run the web UI server
#   dozer ui
#
#   # Update the embedded UI code to the
#   # latest release
#   dozer ui update
#
#   # Show progress reporting
#   dozer --enable-progress run
#
#   # Don't read config from stdin (CI-friendly;
#   # disables piped-input config injection)
#   dozer --ignore-pipe run
#
#   # Help (clap default)
#   dozer --help
#   dozer build --help
#   dozer ui --help
#   dozer --version
#
# OPTIONS (sourced directly from
# https://github.com/getdozer/dozer/blob/main/dozer-cli/src/cli/types.rs Cli + Commands enums):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dozer_commands
_dozer_commands=(
    'clean:Remove all data, schemas, and cache from the home directory'
    'build:Build YAML definitions as a dozer pipeline'
    'run:Run a replication instance with the provided configuration'
    'ui:Run the web UI server (or update UI code)'
    'help:Print help for a subcommand'
)

local -a _dozer_ui_actions
_dozer_ui_actions=(
    'update:Download the latest UI code'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*'{-c+,--config-path=}'[YAML config file path (default dozer-config.yaml; glob patterns OK; repeatable)]:config:_files -g "*.(yaml|yml)"' \
    '--enable-progress[enable interactive progress reporting]' \
    '*--config-overrides=[override a single config key via JSON pointer (POINTER=JSON_VALUE; repeatable)]:override: ' \
    '--ignore-pipe[ignore piped stdin config input (CI-friendly)]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'dozer command' _dozer_commands && ret=0
        ;;
    args)
        case $line[1] in
            build)
                _arguments \
                    '(- *)'{-h,--help}'[show help for build]' \
                    '--locked[require dozer-lock.yaml is up-to-date (CI-friendly)]' \
                    '-f+[force a fresh build (optionally with a reason string)]:reason: ' \
                    && ret=0
                ;;
            ui)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for ui]' \
                    '1::action:->uiaction' \
                    && ret=0
                case $state in
                    uiaction)
                        _describe -t actions 'ui action' _dozer_ui_actions && ret=0 ;;
                esac
                ;;
            run|clean)
                _arguments \
                    '(- *)'{-h,--help}'[show help for this subcommand]' \
                    && ret=0
                ;;
            help)
                _arguments \
                    '1:subcommand:(clean build run ui)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
