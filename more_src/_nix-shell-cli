#compdef nix-shell
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-shell
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(--command --run)--command=[run command in shell]:c:' \
  '(--command --run)--run=[run non-interactive command]:c:' \
  '(-A --attr)'{-A+,--attr=}'[expression attr]:a:' \
  '-p[install packages]' \
  '--packages[install packages]' \
  '*-p+[package]:p:' \
  '--pure[pure environment]' \
  '--keep[keep env var]:var:' \
  '*-i+[interpreter]:s:' \
  '--exclude=[skip building dependencies matching regex]:regex:' \
  '--show-trace[show trace]' \
  '*-I+[search path]:p:' \
  '--option[k=v option]:v:' \
  '--arg[k=v arg]:v:' \
  '--argstr[k=v str arg]:v:' \
  '--no-build-output[no build output]' \
  '-Q[no build output]' \
  '--no-out-link[no out-link]' \
  '--builders=[builders]:b:' \
  '--cores=[cores]:n:' \
  '--max-jobs=[jobs]:n:' \
  '-j+[jobs]:n:' \
  '--max-silent-time=[s]:n:' \
  '--timeout=[s]:n:' \
  '--readonly-mode[readonly mode]' \
  '--repair[repair]' \
  '--keep-going[keep going]' \
  '-k[keep going]' \
  '--keep-failed[keep failed]' \
  '-K[keep failed]' \
  '--add-root[add root]:dir:_files -/' \
  '--check[check substituters]' \
  '*: :_files -g "*.nix shell.nix default.nix"' && ret=0

return ret
