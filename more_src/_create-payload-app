#compdef create-payload-app
# Documentation: https://www.npmjs.com/package/create-payload-app
# Reference accessed: 2026-05-23
# Verified: npx create-payload-app --help.

# Zsh completion for create-payload-app - Payload CMS project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-n[project name]:name:' \
  '-t[template name]:template:(blank website ecommerce with-cloudflare-d1 plugin)' \
  '-e[example name]:example:' \
  '-a[coding agent]:agent:(claude codex cursor)' \
  '--no-agent[skip agent skill installation]' \
  '--use-npm[use npm to install dependencies]' \
  '--use-yarn[use yarn to install dependencies]' \
  '--use-pnpm[use pnpm to install dependencies]' \
  '--use-bun[use bun to install dependencies]' \
  '--no-deps[do not install dependencies]' \
  '-h[show help]' \
  ':project name:' && ret=0

return ret
