#compdef upterm
# Documentation: https://github.com/owenthereal/upterm
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for upterm - secure terminal sharing

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'host:host a terminal session'
      'session:session subcommands'
      'proxy:WebSocket proxy for client connections'
      'completion:generate shell completion'
      'version:show version'
    )
    _describe -t commands 'upterm command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      host)
        _arguments -s \
          '--server=[upterm server URL (wss://...)]:url:' \
          '--force-command=[force a command that clients must join with]:command:' \
          '--authorized-keys=[public key file(s) for access control]:file:_files' \
          '--github-user=[authorized GitHub user]:user:' \
          '--gitlab-user=[authorized GitLab user]:user:' \
          '--srht-user=[authorized SourceHut user]:user:' \
          '--codeberg-user=[authorized Codeberg user]:user:' \
          '--allow-local-tcp-forwarding[enable SSH local forwarding]' \
          '--read-only[restrict SFTP to downloads only]' \
          '--no-sftp[disable file transfers]' \
          '--accept[auto-approve file operations]' \
          '*:command:_command_names' && ret=0
        ;;
      session)
        local -a session_cmds=(
          'current:display current session details'
        )
        _describe -t commands 'session command' session_cmds && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
