#compdef jfr

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'print:print events from a recording'
    'metadata:show event metadata'
    'summary:show recording summary'
    'assemble:assemble chunks into a recording'
    'disassemble:disassemble a recording into chunks'
    'view:show aggregated event data'
    'configure:configure flight recording'
    'scrub:remove events from a recording'
)

_arguments -s -S \
    '--help[show help]' \
    '-h[show help]' \
    '--version[show version]' \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'jfr subcommand' subcommands
        ;;
    args)
        case $words[1] in
            print)
                _arguments \
                    '--xml[print as XML]' \
                    '--json[print as JSON]' \
                    '--categories=[filter by category]:category' \
                    '--events=[filter by event type]:event type' \
                    '--stack-depth=[max stack depth]:depth' \
                    '*:JFR file:_files -g "*.jfr"'
                ;;
            summary)
                _arguments \
                    '*:JFR file:_files -g "*.jfr"'
                ;;
            metadata)
                _arguments \
                    '--categories=[filter by category]:category' \
                    '--events=[filter by event type]:event type' \
                    '*:JFR file:_files -g "*.jfr"'
                ;;
            assemble)
                _arguments \
                    '1:repository directory:_directories' \
                    '2:output file:_files -g "*.jfr"'
                ;;
            disassemble)
                _arguments \
                    '--max-chunks=[max chunks per file]:count' \
                    '--output=[output directory]:directory:_directories' \
                    '*:JFR file:_files -g "*.jfr"'
                ;;
            view)
                _arguments \
                    '--verbose[verbose output]' \
                    '--width=[table width]:columns' \
                    '--cell-height=[max cell height]:rows' \
                    '--truncate=[truncation mode]:(beginning end)' \
                    '1:view or event type:' \
                    '*:JFR file:_files -g "*.jfr"'
                ;;
            configure)
                _arguments \
                    '--input=[input JFC file]:file:_files -g "*.jfc"' \
                    '--output=[output JFC file]:file:_files -g "*.jfc"' \
                    '*:setting=value:'
                ;;
            scrub)
                _arguments \
                    '--include-events=[events to include]:events' \
                    '--exclude-events=[events to exclude]:events' \
                    '--include-categories=[categories to include]:categories' \
                    '--exclude-categories=[categories to exclude]:categories' \
                    '--output=[output file]:file:_files -g "*.jfr"' \
                    '*:JFR file:_files -g "*.jfr"'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
