#compdef for_each
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/for_each.html
# Source: MRtrix3/mrtrix3 bin/for_each — run a command for each of a set of inputs (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-exclude+[exclude string or regex from processing]:regex:_default' \
    '-test[print commands without executing them]' \
    '-nthreads+[number of parallel jobs]:n:_default' \
    '*:inputs and ":" and command:_default' \
    && ret=0

return ret
