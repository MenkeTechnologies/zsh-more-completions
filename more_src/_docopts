#compdef docopts
# Documentation: https://github.com/docopt/docopts
# Shell docopt parser

_arguments -s -S \
  '-h[show help message]' \
  '-V[show version]' \
  '-s[separator between option name and value]:separator:' \
  '-H[pass a help message string]:help message:' \
  '-A[name of associative array to fill]:array name:' \
  '-G[name of global prefix for variables]:prefix:' \
  '--version[show version]' \
  '--help[show help message]' \
  '*:argument:' \
  && return 0
