#compdef buildfea
# Documentation: https://fonttools.readthedocs.io/en/latest/feaLib/index.html
# Add features from a feature file (.fea) to a font (fontTools.feaLib)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-o --output)'{-o,--output}'=[path to the output font]:file:_files' \
  '(-t --tables)'{-t,--tables}'=[specify the table(s) to be built]:tables' \
  '(-d --debug)'{-d,--debug}'[add source-level debugging information to font]' \
  '*'{-v,--verbose}'[increase logger verbosity; repeat for more]' \
  '--traceback[show traceback for exceptions]' \
  '1:feature file:_files -g "*.(fea|FEA)"' \
  '2:input font:_files -g "*.(ttf|otf|TTF|OTF)"' && ret=0

return ret
