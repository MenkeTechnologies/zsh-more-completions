#compdef runsc

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'boot:boot a sandbox'
  'checkpoint:checkpoint a running container'
  'create:create a container'
  'debug:debug a running container'
  'delete:delete a container'
  'do:run a command in a new container'
  'events:display container events'
  'exec:execute a command in a running container'
  'gofer:start a gofer process'
  'help:show help'
  'install:install runsc as an OCI runtime'
  'kill:send a signal to a container'
  'list:list containers'
  'metric-server:start the metric server'
  'mitigate:mitigate CPU vulnerabilities'
  'pause:pause a container'
  'ps:list processes in a container'
  'restore:restore a container from checkpoint'
  'resume:resume a paused container'
  'run:create and run a container'
  'spec:create a new OCI runtime spec'
  'start:start a created container'
  'state:output the state of a container'
  'usage:show usage information'
  'wait:wait for a container'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '--root=[root directory for state]:directory:_directories' \
  '--log=[log file]:log file:_files' \
  '--log-format=[log format]:format:(text json json-k8s)' \
  '--debug[enable debug logging]' \
  '--debug-log=[debug log directory]:directory:_directories' \
  '--strace[enable strace logging]' \
  '--log-packets[enable packet logging]' \
  '--platform=[select platform]:platform:(ptrace kvm systrap)' \
  '--network=[set network type]:network:(none sandbox host)' \
  '--overlay[enable overlay filesystem]' \
  '--fsgofer-host-uds[enable host UDS in fsgofer]' \
  '--rootless[run as rootless]' \
  '--ref-dev-io[reference device I/O implementation]' \
  '--systemd-cgroup[use systemd cgroup driver]' \
  '--ignore-cgroups[ignore cgroup configuration]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'runsc command' commands && ret=0
    ;;
esac

return ret
