#compdef pbs_server
# Documentation: https://man.archlinux.org/search?q=pbs_server
# Reference accessed: 2026-05-16

# pbs_server: PBS/TORQUE batch server daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-A[acl file]:file:_files' \
  '-a[active scheduling]:val:(true false)' \
  '-d[home dir]:dir:_files -/' \
  '-D[run in foreground]' \
  '-e[disable jobs]' \
  '-f[force start]' \
  '-H[hot start (initial)]' \
  '-L[log file]:file:_files' \
  '-l[node spec]:spec:' \
  '-M[mom port]:port:' \
  '-n[node mom]' \
  '-p[port]:port:' \
  '-R[resource manager port]:port:' \
  '-S[scheduler port]:port:' \
  '-t[startup type]:type:(create cold warm hot)' \
  '*::pbs_server args:_files' && ret=0
return ret
