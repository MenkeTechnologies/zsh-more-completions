#compdef stman
# Documentation: https://github.com/classicsc/syncthingmanager
# stman: syncthingmanager, configure Syncthing from the CLI

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show the version and exit]' \
  '--device=[target a non-default device configuration]:device' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'configure:set up the connection to the Syncthing daemon'
      'daemon:control and query the Syncthing daemon'
      'device:add, remove, list and edit devices'
      'folder:add, remove, list and edit folders'
      'gui:configure the web GUI'
    )
    _describe -t commands 'stman command' cmds && ret=0
    ;;
esac

return ret
