#compdef pgloader

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '--client-min-messages[set client minimum message level]:level:(debug info notice warning error)' \
  '--log-min-messages[set log minimum message level]:level:(debug info notice warning error)' \
  '--summary[filename for summary]:summary file:_files' \
  '--root-dir[set root directory]:directory:_files -/' \
  '--logfile[log file path]:log file:_files' \
  '(-l --load-lisp-file)'{-l,--load-lisp-file}'[load lisp file]:lisp file:_files' \
  '--dry-run[perform dry run without changes]' \
  '--on-error-stop[stop on error]' \
  '--no-ssl-cert-verification[disable SSL certificate verification]' \
  '--context[set context]:context' \
  '--with[set option]:option' \
  '--set[set parameter]:parameter' \
  '--field[define a field]:field spec' \
  '--cast[define a cast rule]:cast rule' \
  '--type[set source type]:type' \
  '--encoding[set encoding]:encoding' \
  '--before[SQL to execute before load]:sql' \
  '--after[SQL to execute after load]:sql' \
  '--regress[regression testing mode]' \
  '*:command file:_files' && ret=0
return ret
