#compdef pidgin
# Documentation: https://man.archlinux.org/search?q=pidgin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[alternative config directory]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[verbose debug output]' \
  '(-D --debug-all)'{-D,--debug-all}'[exhaustive debug output]' \
  '(-n --nologin)'{-n,--nologin}'[do not auto-login to accounts]' \
  '(-l --login)'{-l+,--login=}'[auto-login to comma-separated accounts]:accounts:' \
  '(-f --force-online)'{-f,--force-online}'[force all accounts online]' \
  '(-m --multiple)'{-m,--multiple}'[allow multiple instances]' \
  '(-s --session)'{-s+,--session=}'[load specific X session]:id:' \
  '(-h --gtk-help)--gtk-help[show GTK+ help]' \
  '*::passthrough:_files' && ret=0

return ret
