#compdef ctracer
# Documentation: man ctracer(1)
# Source: acmel/dwarves ctracer.c (master) — DWARF-based class member tracer (C, argp).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --src_dir)'{-d+,--src_dir=}'[output source files directory]:dir:_files -/' \
    '(-C --cu_blacklist)'{-C+,--cu_blacklist=}'[CU blacklist file]:file:_files' \
    '(-D --dir)'{-D+,--dir=}'[load files in this directory]:dir:_files -/' \
    '(-g --glob)'{-g+,--glob=}'[file mask to load]:glob:_default' \
    '(-r --recursive)'{-r,--recursive}'[recursively load files]' \
    '1:file:_files' \
    '2:class name:_default' \
    && ret=0

return ret
