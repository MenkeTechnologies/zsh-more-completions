#compdef condor_vacate_job
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_vacate_job.html
# Reference accessed: 2026-05-17
# Verified: HTCondor condor_vacate_job upstream manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# duplicate -h/-help and missing -long/-totals/-addr.

# condor_vacate_job: gracefully vacate a running HTCondor job
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-long[long output]' \
  '-totals[totals only]' \
  '-fast[hard kill (no checkpoint)]' \
  '-pool[central manager host\:port]:host\:port:_hosts' \
  '-name[schedd name]:name:' \
  '-addr[<a.b.c.d\:port>]:addr:' \
  '-all[vacate all jobs]' \
  '-constraint[constraint expression]:expr:' \
  '-debug[debug output]' \
  '*:jobid (cluster | cluster.process | user):' && ret=0
return ret
