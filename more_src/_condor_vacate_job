#compdef condor_vacate_job

# condor_vacate_job: gracefully vacate a running job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-name[schedd]:name:' \
  '-pool[pool]:pool:' \
  '-fast[fast vacate (no checkpoint)]' \
  '-constraint[constraint expression]:expr:' \
  '-all[all jobs of user]' \
  '*:jobid:' && ret=0
return ret
