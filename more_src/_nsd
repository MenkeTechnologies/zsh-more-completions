#compdef nsd

# Zsh completion for nsd (NLnet Labs authoritative DNS nameserver)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-4[Only listen to IPv4 connections]' \
  '-6[Only listen to IPv6 connections]' \
  '-a+[Listen on the specified ip-address]:ip address' \
  '-c+[Read the specified config file]:config file:_files' \
  '-d[Do not fork, stay in the foreground]' \
  '-f+[Database file to use]:database file:_files' \
  '-h[Print help]' \
  '-i+[Identity when asked for CH TXT ID.SERVER]:identity' \
  '-I+[NSID customized string]:nsid' \
  '-l+[Specify a log file]:log file:_files' \
  '-N+[Number of server processes to fork]:count' \
  '-n+[Number of TCP connections per server]:number' \
  '-P+[Pid file to use]:pid file:_files' \
  '-p+[Port to answer queries on]:port' \
  '-s+[Number of statistics to keep]:number' \
  '-t+[Chroot to this directory on startup]:directory:_files -/' \
  '-u+[User name or ID to run as]:user:_users' \
  '-V+[Verbosity level]:level:(0 1 2 3 4 5)' \
  '-v[Print version]' && ret=0

return ret
