#compdef ave
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# compute average and basic stats

local ret=1

_arguments -s -S \
  '-col=[which column to use (default 1)]:n' \
  '-tableOut[output by columns (default output in rows)]' \
  '-noQuartiles[only calculate min, max, mean, standard deviation]' \
  '*:file:_files' && ret=0

return ret
