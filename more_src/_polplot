#compdef polplot
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss11.html
# POLPACK: plots a 2-dimensional vector map.

local ret=1

_arguments -s -S \
  'CAT=[input catalogue]:cat:_files' \
  'DEVICE=[plotting device]:device:' \
  'COLX=[column for positions along first axis]:col:' \
  'COLY=[column for positions along second axis]:col:' \
  'COLZ=[column for positions along third axis]:col:' \
  'COLMAG=[column holding vector magnitude]:col:' \
  'COLANG=[column holding vector orientation]:col:' \
  'VSCALE=[scale factor for vector lengths]:val:' \
  'ARROW=[arrow head size as fraction]:val:' \
  'ANGROT=[rotation angle added to orientation]:deg:' \
  'NEGATE=[negate angle before adding ANGROT]:flag:(TRUE FALSE)' \
  'JUST=[vector justification]:just:(CENTRE START END)' \
  'AXES=[display labelled axes]:flag:(TRUE FALSE)' \
  'CLEAR=[clear graphics device first]:flag:(TRUE FALSE)' \
  'FILL=[expand smaller dimension]:flag:(TRUE FALSE)' \
  'FRAME=[coordinate frame for axes]:frame:' \
  'EPOCH=[epoch for celestial coords]:epoch:' \
  'KEY=[display scale key]:flag:(TRUE FALSE)' \
  'KEYPOS=[key position]:pos:' \
  'KEYSTYLE=[plotting style for key]:style:' \
  'KEYVEC=[length of example vector in key]:val:' \
  'STYLE=[plotting style for vectors and axes]:style:' \
  'MARGIN=[widths of margins]:margin:' \
  'LBND=[lower left corner coordinates]:bounds:' \
  'UBND=[top right corner coordinates]:bounds:' \
  'ZAXVAL=[Z-axis value for displayed vectors]:val:' \
  'ZCOLVAL=[Z column value for displayed vectors]:val:' \
  '*:cat:_files' && ret=0

return ret
