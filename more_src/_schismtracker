#compdef schismtracker
# _schismtracker — Impulse Tracker clone with full editor (schismtracker/schismtracker)
# upstream: https://github.com/schismtracker/schismtracker
# Flags from schismtracker(1) man page.

_schismtracker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-a --audio-driver)'{-a+,--audio-driver=}'[SDL audio driver:device]:driver:' \
        '(-v --video-driver)'{-v+,--video-driver=}'[SDL video driver]:driver:(x11 dga fbcon)' \
        '--video-yuvlayout=[YUV layout]:layout:(YUY2 YV12 RGBA)' \
        '--video-size=[display size WIDTHxHEIGHT]:size:' \
        '--video-stretch=[fix aspect ratio]:value:' \
        '--video-gl-path=[OpenGL library path]:path:_files' \
        '--video-depth=[display depth in bits]:depth:(8 16 24 32)' \
        '--video-fb-device=[framebuffer device]:device:_files' \
        '(--network --no-network)--network[enable MIDI over IP networking]' \
        '(--network --no-network)--no-network[disable networking]' \
        '(--classic --no-classic)--classic[start in classic mode]' \
        '(--classic --no-classic)--no-classic[start in non-classic mode]' \
        '--display=[X11 display]:display:' \
        '(-f -F --fullscreen --no-fullscreen)'{-f,--fullscreen}'[fullscreen at startup]' \
        '(-f -F --fullscreen --no-fullscreen)'{-F,--no-fullscreen}'[windowed at startup]' \
        '(-p -P --play --no-play)'{-p,--play}'[start playing after loading song]' \
        '(-p -P --play --no-play)'{-P,--no-play}'[do not autoplay after loading]' \
        '--diskwrite=[render output to file then exit]:file:_files' \
        '(--font-editor --no-font-editor)--font-editor[run the font editor]' \
        '(--font-editor --no-font-editor)--no-font-editor[skip font editor]' \
        '(--hooks --no-hooks)--hooks[run hooks (default)]' \
        '(--hooks --no-hooks)--no-hooks[do not run hooks]' \
        '--debug=[debug flag list]:flags:' \
        '*:module / sample:_files -g "*.{it,xm,s3m,mod,mptm}"'
}

_schismtracker "$@"
