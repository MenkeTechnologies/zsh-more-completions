#compdef akamai-cli2 akamai2
# _akamai-cli2 — Akamai akamai-cli2 CLI command-line frontend wrapping the Akamai CLI a way to interact with Akamai products from the command line open-source written in Go a stand-alone application to install other Akamai CLI products manage installed packages and run installed CLI applications such as Akamai-property-manager Akamai-purge Akamai-EdgeWorkers Akamai-mPulse Akamai-CPS Akamai-Identity-Cloud Akamai-property image manager edge-dns edge-hostnames jwt-edge-grid auth-token netstorage Bot-Manager dns akamais access cache image-mgmt enterprise-app-access (Akamai team, Go); cobra
# upstream: https://github.com/akamai/cli

_akamai-cli2() {
    local -a sub=(
        'config:configure CLI'
        'help:show help'
        'install:install a CLI package'
        'list:list installed packages'
        'search:search for packages'
        'uninstall:uninstall a package'
        'update:update a package or itself'
        'upgrade:upgrade Akamai CLI itself'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--edgerc=+[file]:file:_files -g ".edgerc *.rc"' \
        '--section=+[name]:str:' \
        '--account-key=+[id]:str:' \
        '--accountkey=+[id]:str:' \
        '-a+[account]:str:' \
        '--account=+[id]:str:' \
        '--bash[install bash autocomplete]' \
        '--zsh[install zsh autocomplete]' \
        '--proxy=+[url]:str:' \
        '--no-color[no color]' \
        '-y[yes/skip prompts]' \
        '--yes[yes]' \
        '--profile=+[name]:str:' \
        '-p+[profile]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'akamai subcommand' sub ;;
        args)
            case $words[1] in
                install|update|uninstall) _arguments '*:package:(property-manager purge edge-dns edge-hostnames cps image-manager jsonnet adaptive-acceleration apps Identity-cloud edgeworkers visitor-prioritization netstorage cloudlets reporting securityCenter cloud-monitor api-gateway ksd diagnostics gtm appsec eaa-cli)' ;;
                config) _arguments '1:op:(get set unset list)' '*:key:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_akamai-cli2 "$@"
