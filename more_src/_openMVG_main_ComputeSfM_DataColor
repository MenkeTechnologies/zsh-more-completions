#compdef openMVG_main_ComputeSfM_DataColor
# Documentation: https://github.com/openMVG/openMVG/blob/develop/docs/sphinx/rst/software/SfM/SfM.rst
# openMVG: colorize SfM_Data point cloud and export PLY

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input_file)'{-i,--input_file}'[input SfM_Data scene]:file:_files' \
  '(-o --output_file)'{-o,--output_file}'[output PLY file]:file:_files' \
  '*:arg:_files' && ret=0

return ret
