#compdef gosmee
# Documentation: https://github.com/chmouel/gosmee
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Webhook relay/replay tool (smee.io-compatible).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    local -a commands
    commands=(
      'client:relay webhook payloads from smee.io or a gosmee server to a local service'
      'server:run a gosmee relay server'
      'replay:replay GitHub webhook deliveries via the API'
      'keygen:generate encryption keypairs for protected channels'
      'completion:generate shell completion scripts'
      'help:show help for a command'
    )
    _describe -t commands 'gosmee command' commands && ret=0
    ;;
  args)
    case $line[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
