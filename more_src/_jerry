#compdef jerry
# _jerry — shell script to watch anime from the terminal (justchokingaround/jerry)
# upstream: https://github.com/justchokingaround/jerry
# Flags from jerry.sh.

_jerry() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --continue)'{-c,--continue}'[continue from currently watching list]' \
        '--dub[watch in dub]' \
        '(-e --edit)'{-e,--edit}'[edit config file]' \
        '(-d --discord)'{-d,--discord}'[Discord Rich Presence]' \
        '(-i --image-preview)'{-i,--image-preview}'[image previews in fzf/rofi]' \
        '(-j --json)'{-j,--json}'[print video/subtitle JSON to stdout]' \
        '(-l --language)'{-l+,--language=}'[subtitle language]:lang:' \
        '(-n --number)'{-n+,--number=}'[episode number]:n:' \
        '(--rofi --dmenu --external-menu)--rofi[use rofi instead of fzf]' \
        '(--rofi --dmenu --external-menu)--dmenu[use dmenu instead of fzf]' \
        '(--rofi --dmenu --external-menu)--external-menu[use external menu]' \
        '(-q --quality)'{-q+,--quality=}'[video quality]:quality:(360 480 720 1080)' \
        '(-s --syncplay)'{-s,--syncplay}'[Syncplay with friends]' \
        '(-u --update)'{-u,--update}'[update the script]' \
        '--vlc[use VLC as the video player]' \
        '(-w --website)'{-w+,--website=}'[video source website]:website:(allanime aniwatch yugen hdrezka crunchyroll)' \
        '*:query:'
}

_jerry "$@"
