#compdef profanity
# Documentation: https://man.archlinux.org/search?q=profanity
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --account)'{-a+,--account=}'[account JID]:account:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-d --debug)'{-d+,--debug=}'[debug log file]:file:_files' \
  '(-l --log)'{-l+,--log=}'[log level]:l:(DEBUG INFO WARN ERROR)' \
  '(-t --theme)'{-t+,--theme=}'[theme]:t:' \
  '(-T --terminal-title)'{-T,--terminal-title}'[set terminal title]' \
  '(-x --status)'{-x+,--status=}'[set status]:s:(online chat away xa dnd)' \
  '(-V --vercheck)'{-V,--vercheck}'[check for new version]' \
  '*: :' && ret=0

return ret
