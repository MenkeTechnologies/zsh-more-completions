#compdef profanity-cli
# Documentation: https://manpages.debian.org/bookworm/profanity/profanity.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: alias completion for the profanity binary.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --account)'{-a+,--account=}'[auto-connect to account on startup]:account' \
  '(-c --config)'{-c+,--config=}'[use alternate config file]:file:_files' \
  '(-l --log)'{-l+,--log=}'[log level]:level:(DEBUG INFO WARN ERROR)' \
  '(-f --logfile)'{-f+,--logfile=}'[log file]:file:_files' \
  '(-t --theme)'{-t+,--theme=}'[load specified theme]:theme' && ret=0

return ret
