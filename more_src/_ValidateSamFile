#compdef ValidateSamFile
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/ValidateSamFile.java
# Picard: validate a SAM/BAM/CRAM file and report problems

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file to validate]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output file (defaults to stdout)]:file:_files' \
  '(-M --MODE)'{-M,--MODE}'=[output mode]:mode:(VERBOSE SUMMARY)' \
  '--IGNORE=[validation error types to exclude]:type:' \
  '--MAX_OUTPUT=[max lines output in verbose mode]:n:' \
  '--IGNORE_WARNINGS=[report only errors and suppress warnings]:b:(true false)' \
  '--VALIDATE_INDEX=[deprecated BAM index validation]:b:(true false)' \
  '--INDEX_VALIDATION_STRINGENCY=[BAM index validation stringency]:s:(EXHAUSTIVE LESS_EXHAUSTIVE NONE)' \
  '(-BISULFITE --IS_BISULFITE_SEQUENCED)'{-BISULFITE,--IS_BISULFITE_SEQUENCED}'=[reads are bisulfite-sequenced]:b:(true false)' \
  '--MAX_OPEN_TEMP_FILES=[max open file handles when spilling mate info]:n:' \
  '(-SMV --SKIP_MATE_VALIDATION)'{-SMV,--SKIP_MATE_VALIDATION}'=[disable mate pair validation]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
