#compdef clj-deps clojure-deps
# _clj-deps — Clojure deps.edn CLI / tools.deps CLI alias (clojure team, Clojure); custom argparse
# upstream: https://github.com/clojure/tools.deps

_clj-deps() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-Sdeps=+[deps.edn override]:str:' \
        '-Spath[print path]' \
        '-Stree[print dependency tree]' \
        '-Spom[generate pom]' \
        '-Sresolve-tags[resolve git tags]' \
        '-Sthreads=+[concurrent downloads]:n:' \
        '-Strace[print expansion trace]' \
        '-Sforce[force re-resolution]' \
        '-Srepro[repro mode (skip user deps)]' \
        '-Spro[do not include user deps]' \
        '-Sno-cp[no classpath]' \
        '-Scp=+[explicit classpath]:str:' \
        '-Sdeps-file=+[deps.edn file]:file:_files -g "deps.edn"' \
        '-Sverbose[verbose]' \
        '-Sdescribe[describe runtime]' \
        '-X[exec function]' \
        '-T[tool]' \
        '-M[main alias]' \
        '-A[deps aliases]' \
        '-P[prepare deps only]' \
        '-J+[jvm option]:str:' \
        '*:args:'
}

_clj-deps "$@"
