#compdef rogcat
# Documentation: https://man.archlinux.org/search?q=rogcat
# Reference accessed: 2026-05-16

# Zsh completion for rogcat Android log reader

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-s+[device serial]:serial' \
  '-c[clear log buffer]' \
  '-m[minitable format]' \
  '-S+[message substring filter]:filter' \
  '-T+[comma-separated tags]:tags' \
  '*::filters:{ _message "rogcat / logcat filters" }' && ret=0

return ret
