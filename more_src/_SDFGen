#compdef SDFGen
# Documentation: https://github.com/christopherbatty/SDFGen
# SDFGen - grid-based signed distance field generator from triangle meshes

local ret=1

_arguments -s -S \
  '1:obj file:_files -g "*.obj"' \
  '2:dx (grid cell length):' \
  '3:padding (cells, min 1):' && ret=0

return ret
