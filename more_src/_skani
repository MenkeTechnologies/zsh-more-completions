#compdef skani
# Documentation: https://github.com/bluenote-1577/skani
# skani - fast ANI and aligned fraction for genomes and MAGs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t)-t[number of threads]:threads' \
  '(-q)-q[query files]:file:_files' \
  '(-r)-r[reference files]:file:_files' \
  '(-o)-o[output file]:file:_files' \
  '(-d)-d[database directory]:dir:_files -/' \
  '--qi[compare individual query FASTA records]' \
  '--ri[compare individual reference FASTA records]' \
  '(-E)-E[output triangle as edge list]' \
  '1:subcommand:(dist triangle search sketch)' \
  '*::args:_files' && ret=0

return ret
