#compdef mujmap
# Documentation: https://github.com/elizagamedev/mujmap
# mujmap - synchronize mail between a JMAP server and notmuch

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-C)-C[use configuration directory]:dir:_files -/' \
  '--dry-run[do not apply changes]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mujmap command' \
      'sync[synchronize mail between notmuch and JMAP server]' \
      'push[push local changes without pulling remote changes]' \
      'send[send an email via a sendmail-like interface]' && ret=0
    ;;
  args)
    case $line[1] in
      send)
        _arguments -s \
          '(-t)-t[infer recipients from the message]' \
          '(-i -oi)-i[ignored for sendmail compatibility]' \
          '(-i -oi)-oi[ignored for sendmail compatibility]' \
          '(-f)-f[ignored for sendmail compatibility]' \
          '(-F)-F[ignored for sendmail compatibility]' && ret=0
        ;;
    esac
    ;;
esac

return ret
