#compdef storm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'jar:execute main class with storm classpath'
  'local:run topology in embedded local mode'
  'kill:terminate topology after deactivation'
  'activate:enable topology spouts'
  'deactivate:disable topology spouts'
  'rebalance:redistribute workers and adjust parallelism'
  'nimbus:launch nimbus master daemon'
  'supervisor:launch supervisor worker daemon'
  'ui:launch UI web daemon'
  'drpc:launch distributed RPC daemon'
  'logviewer:launch log viewing daemon'
  'pacemaker:launch pacemaker daemon'
  'dev-zookeeper:launch development Zookeeper'
  'list:display running topologies'
  'monitor:interactive throughput monitoring'
  'get-errors:retrieve latest topology errors'
  'heartbeats:list/get cluster state heartbeat nodes'
  'set_log_level:adjust logger level dynamically'
  'node-health-check:execute supervisor health check'
  'kill_workers:terminate supervisor workers'
  'sql:compile SQL as Trident topology'
  'blobstore:manage blob storage'
  'classpath:print client classpath'
  'server_classpath:print daemon classpath'
  'localconfvalue:print local config value'
  'remoteconfvalue:print cluster config value'
  'drpc-client:send DRPC request'
  'shell:run non-JVM language topology'
  'upload_credentials:update topology credentials'
  'admin:administrative operations'
  'version:show release version'
  'help:show command documentation'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'storm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (jar|local)
        _arguments \
          '1:topology jar:_files -g "*.jar"' \
          '*:class and args:' && ret=0
        ;;
      (kill)
        _arguments \
          '1:topology name:' \
          '-w+[wait time in seconds]:secs:' && ret=0
        ;;
      (rebalance)
        _arguments \
          '1:topology name:' \
          '-w+[wait time in seconds]:secs:' \
          '-n+[new number of workers]:n:' \
          '*-e+[component=parallelism]:component=n:' && ret=0
        ;;
      (monitor)
        _arguments \
          '1:topology name:' \
          '-i+[interval seconds]:secs:' \
          '-m+[component id]:id:' \
          '-s+[stream id]:id:' \
          '-w+[watch type]:type:(emitted transferred)' && ret=0
        ;;
      (set_log_level)
        _arguments \
          '*-l+[set logger level]:logger=level[:timeout]:' \
          '*-r+[reset logger]:logger:' \
          '*:topology name:' && ret=0
        ;;
      (blobstore)
        _arguments \
          '1:operation:(list cat create update delete set-acl replication)' \
          '*:blob key / file:_files' && ret=0
        ;;
      (admin)
        _arguments \
          '1:admin command:(remove_corrupt_topologies zk_cli creds)' \
          '*:options:' && ret=0
        ;;
      (sql)
        _arguments \
          '1:SQL file:_files -g "*.sql"' \
          '2:topology name:' && ret=0
        ;;
      (heartbeats)
        _arguments '*:command:' && ret=0
        ;;
      (drpc-client)
        _arguments \
          '*:function argument:' && ret=0
        ;;
      (shell)
        _arguments \
          '1:resources dir:_files -/' \
          '2:command:' \
          '*:args:' && ret=0
        ;;
      (upload_credentials)
        _arguments \
          '1:topology name:' \
          '*:credkey credvalue:' && ret=0
        ;;
    esac
    ;;
esac

return ret
