#compdef lto-dump-15

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '*--help=[show specific help]:topic:(common warnings target params optimizers)' \
  '(- *)--version[show version]' \
  '--list[list types of symbols]' \
  '--symbol=[show only the named symbol]:name:' \
  '--demangle[demangle C++ names]' \
  '--no-demangle[do not demangle]' \
  '--objects[print all objects]' \
  '--print-value[print symbol values]' \
  '*:LTO file:_files -g "*.(o|a|so)"' && ret=0

return ret
