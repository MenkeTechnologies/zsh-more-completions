#compdef lto-dump-15
# Documentation: https://gcc.gnu.org/onlinedocs/gcc/Overall-Options.html
# Reference accessed: 2026-05-19
# Verified: lto-dump(1) manpage at https://www.mankier.com/1/lto-dump.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show help]' \
  '-list[dump list of details of functions and variables]' \
  '-demangle[dump the demangled output]' \
  '-defined-only[dump only the defined symbols]' \
  '-print-value[dump initial values of variables]' \
  '-name-sort[sort the symbols alphabetically]' \
  '-size-sort[sort the symbols according to size]' \
  '-reverse-sort[dump the symbols in reverse order]' \
  '-no-sort[dump the symbols in order of occurrence]' \
  '-symbol=[dump the details of a specific symbol]:name:' \
  '-objects[dump the details of LTO objects]' \
  '-type-stats[dump statistics of tree types]' \
  '-tree-stats[dump statistics of trees]' \
  '-gimple-stats[dump statistics of gimple statements]' \
  '-dump-level=[set optimization level of body]:level:' \
  '-dump-body=[dump the specific gimple body]:body:' \
  '*:LTO file:_files -g "*.(o|a|so)"' && ret=0

return ret
