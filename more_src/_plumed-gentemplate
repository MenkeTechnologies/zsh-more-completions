#compdef plumed-gentemplate
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/gentemplate.html
# PLUMED gentemplate: build template inputs for PLUMED actions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--list[print a list of the available actions]' \
  '--include-optional[also print optional modifiers]' \
  '--action=[print the template for this particular action]:action' && ret=0

return ret
