#compdef isochore
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/isochore.html
# isochore - Plot isochores in DNA sequences

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input nucleotide sequence]:file:_files' \
  '-outfile[output file name]:file:_files' \
  '-graph[graph output type]:device:' \
  '-window[window size for GC content analysis]:size:' \
  '-shift[shift increment between windows]:shift:' \
  '-sbegin1[sequence start position]:pos:' \
  '-send1[sequence end position]:pos:' \
  '-sreverse1[reverse the sequence if DNA]' \
  '-sformat1[input sequence format]:format:' \
  '-snucleotide1[declare sequence as nucleotide]' \
  '-sprotein1[declare sequence as protein]' \
  '-odirectory2[output directory]:dir:_files -/' \
  '-gtitle[graph title]:title:' \
  '-gsubtitle[graph subtitle]:subtitle:' \
  '-gxtitle[graph x-axis title]:title:' \
  '-gytitle[graph y-axis title]:title:' \
  '-gdirectory[graph output directory]:dir:_files -/' \
  '-auto[turn off prompts]' \
  '-verbose[report command line options]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
