#compdef peaclock

# Zsh completion for peaclock - responsive terminal clock, timer, stopwatch

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show peaclock version]'
  '--config[path to a config file]:file:_files'
  '--config-base[base directory for configs]:directory:_files -/'
  '--no-config[do not load configuration file]'
  '--no-color[disable color output]'
  '--no-style[disable text styling]'
  '--no-input[ignore keyboard input]'
  '1:mode:(clock timer stopwatch)'
)

_arguments -s -S $arguments
