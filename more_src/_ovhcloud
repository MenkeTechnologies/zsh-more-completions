#compdef ovhcloud
# Documentation: https://man.archlinux.org/search?q=ovhcloud
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:account information'
  'baremetal:baremetal cloud'
  'cdn-dedicated:CDN dedicated'
  'cloud:public cloud projects'
  'completion:generate shell completion'
  'config:CLI configuration'
  'dedicated-cloud:dedicated cloud'
  'dedicated-server:dedicated server'
  'dedicated:alias for dedicated-server'
  'dns-anycast:Anycast DNS'
  'domain:domain management'
  'email-pro:email pro'
  'graph:show graphs'
  'help:show help'
  'horizon:Horizon UI'
  'hosted-private-cloud:hosted private cloud'
  'iam:identity and access management'
  'identity:user identity'
  'invoice:invoice operations'
  'ip:IP management'
  'ip-load-balancing:IP load balancing'
  'license-cpanel:cPanel license'
  'license-plesk:Plesk license'
  'license-windows:Windows license'
  'login:login to OVHcloud account'
  'logout:logout'
  'logs-data-platform:Logs Data Platform'
  'me:current account info'
  'order:order management'
  'pca:Public Cloud Archive'
  'price:pricing'
  'private-database:private database'
  'service:services'
  'sms:SMS service'
  'support-level:support level'
  'task:task management'
  'telephony:telephony service'
  'vps:Virtual Private Server'
  'vrack:vRack network'
  'web-cloud:web cloud'
  'web-paas:web platform-as-a-service'
  'whoami:show currently logged in user'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[debug mode]' \
  '--profile=[profile name]:profile:' \
  '--output=[output format]:fmt:(table json yaml gval custom)' \
  '--region=[OVHcloud region]:region:(europe canada us)' \
  '--no-color[disable colors]' \
  '--no-prompt[no interactive prompts]' \
  '--quiet[quiet output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ovhcloud command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (login) _arguments \
        '--profile=[profile name]:profile:' \
        '--region=[region]:region:(europe canada us)' && ret=0 ;;
      (config) _values 'subcommand' 'profile' 'show' 'set' 'unset' 'reset' && ret=0 ;;
      (cloud) _values 'subcommand' 'project' 'instance' 'image' 'volume' 'network' 'region' 'flavor' 'kube' 'storage' 'database' 'load-balancer' 'usage' && ret=0 ;;
      (iam) _values 'subcommand' 'group' 'permission' 'policy' 'user' && ret=0 ;;
    esac ;;
esac

return ret
