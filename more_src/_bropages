#compdef bro
# _bropages — bropages bro CLI (community examples-first manpage alternative; bro <command> fetches examples for a command, thanks/...no thanks vote, add submits a new example, lookup queries the API, list shows installed cmds, search runs term search)
# upstream: https://github.com/hubsmoke/bro
# Subcommands from bropages lib/bropages.rb on tip.

_bropages() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-v[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'bro command' '(lookup add thanks no-thanks list search login config update help version)' ;;
        args) _arguments '*:command-name:_command_names -e' ;;
    esac
}

_bropages "$@"
