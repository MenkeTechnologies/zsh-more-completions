#compdef rooch
# Documentation: https://github.com/rooch-network/rooch
# rooch - Rooch Network Move application/VM command-line interface

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'init:initialize the rooch configuration'
  'account:account management'
  'move:Move language integration (build/test/publish/run)'
  'server:start/stop the rooch server'
  'state:query global state'
  'statedb:state database operations'
  'object:object management'
  'resource:resource management'
  'event:event handling'
  'transaction:transaction handling'
  'rpc:JSON-RPC client requests'
  'env:environment configuration'
  'session-key:session key management'
  'db:database operations'
  'genesis:genesis block initialization'
  'abi:ABI operations'
  'dynamic-field:dynamic field management'
  'faucet:faucet operations'
  'indexer:indexing services'
  'oracle:oracle functionality'
  'did:decentralized identifier support'
  'bitcoin:Bitcoin integration'
  'payment-channel:payment channel operations'
  'da:data availability operations'
  'upgrade:upgrade operations'
  'util:utility functions'
  'version:print version'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'rooch command' sub && ret=0 ;;
  args)
    case $words[1] in
      account) _arguments '1:account cmd:(create import list switch nullify balance transfer sign verify)' && ret=0 ;;
      move) _arguments '1:move cmd:(build test new publish run view coverage prove)' && ret=0 ;;
      server) _arguments '1:server cmd:(start clean)' && ret=0 ;;
    esac
    ;;
esac

return ret
