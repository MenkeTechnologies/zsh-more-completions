#compdef snyk-auth
# _snyk-auth — Snyk CLI authentication subcommand alias (Snyk, TypeScript); commander
# upstream: https://github.com/snyk/cli

_snyk-auth() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--auth-type=+[auth type]:t:(oauth token)' \
        '--region=+[region]:r:(SNYK-US-01 SNYK-US-02 SNYK-EU-01 SNYK-AU-01)' \
        '*:api-token:'
}

_snyk-auth "$@"
