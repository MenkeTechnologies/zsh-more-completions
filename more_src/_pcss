#compdef pcss
# ============================================================================
# pcss - config.js-driven PostCSS build CLI
#         (TypeScript -> Node, MIT)
#
# Author : BriteSnow (Jeremy Chone)
# Upstream: https://github.com/BriteSnow/node-pcss-cli
# npm    : pcss-cli (binary: pcss)
#
# `pcss` is a minimal PostCSS-runner CLI that reads a
# JavaScript configuration file describing one or more
# (input -> output) entries with associated plugin
# arrays + applies the PostCSS pipeline to each entry.
# Compared with the canonical `postcss-cli` (which
# uses a flag-driven YAML/JSON config), `pcss` is
# config-as-code: the config file is a real
# JavaScript module that can import plugins
# directly, compute values dynamically, and share
# logic across entries.
#
# Usage:
#   pcss [-c pcss.config.js] [-w]
#
# Flags (minimist):
#   -c <file>          - config file path (default
#                         pcss.config.js)
#   -w                 - watch mode (re-runs on file
#                         change via chokidar)
#
# Configuration file structure (default-export an
# array of entries):
#   import autoprefixer from 'autoprefixer';
#   import postcssNested from 'postcss-nested';
#
#   export default [
#     {
#       input: ['src/css/main.scss',
#               'src/css/theme.scss'],
#       output: 'dist/style.css',
#       plugins: [
#         postcssNested(),
#         autoprefixer({ overrideBrowserslist: [
#           '> 0.5%' ] }),
#       ],
#       watchPath: ['src/css/**/*.scss'],
#     },
#     {
#       input: ['src/css/admin.scss'],
#       output: 'dist/admin.css',
#       plugins: [postcssNested()],
#     },
#   ];
#
# Per-entry fields:
#   - input: string OR string[]
#       source CSS file(s) to concatenate + process
#   - output: string
#       output CSS file path
#   - plugins: PostCSS plugin array
#       applied in declared order
#   - watchPath: string OR string[]
#       additional glob patterns to watch beyond
#       `input` (typically used when input gets
#       built from a tree of partials)
#
# Watch mode behaviour:
#   - chokidar-backed file watcher
#   - debounced 500ms after a change to coalesce
#     rapid edits
#   - listens for 'change' + 'add' + 'remove'
#     events
#
# The postcss lane is built on `postcss ^8.5.6`
# (declared at upstream package.json HEAD as a direct
# dep, used via the pipeline orchestrator in
# src/index.ts as `postcss(plugins).process(css,
# { from: input, to: output })`), the canonical
# Node CSS parser+transformer ecosystem by Andrey
# Sitnik (ai) - github.com/postcss/postcss, 28000+
# stars on the core repo.
#
# Sitnik created PostCSS in 2013 as a faster, more
# composable alternative to the older
# Stylus/Sass/Less preprocessor model. Rather than
# implementing a single monolithic transformer,
# PostCSS provides a *plugin-architecture parser +
# AST* that downstream plugins can compose:
#   - Autoprefixer (also Sitnik): adds vendor
#     prefixes per Can-I-Use data
#   - cssnano: minifier ecosystem with 30+ sub-
#     plugins (postcss-discard-empty, postcss-merge-
#     longhand, postcss-colormin, ...)
#   - cssnext / postcss-preset-env: future-CSS
#     transpilers
#   - Tailwind CSS: uses PostCSS as its
#     plugin-host
#   - Stylelint: CSS linter built on the PostCSS
#     parser
#
# This *plugin-as-platform* design made PostCSS the
# canonical Node CSS ecosystem for ~10 years -
# virtually every CSS-touching Node tool either uses
# PostCSS directly OR is compatible with PostCSS
# plugins via the standardized plugin contract.
#
# Sitnik's broader Node ecosystem footprint:
#   - PostCSS (core CSS pipeline)
#   - Autoprefixer (vendor prefix manager)
#   - browserslist (browser-targeting config used
#     by PostCSS + Babel + Webpack + ESLint + ...)
#   - Size Limit (npm package size measurement)
#   - Storeon (tiny Redux alternative)
#   - logux/core (CRDT-based collaborative editing)
#   - nanoid (small unique-ID library, ~20M weekly
#     downloads)
#
# Sitnik is one of the most-prolific multi-axis
# canonical-Node authors:
#   - Axis 258 (CSS, THIS AXIS): postcss + autoprefixer
#   - + browserslist (~38M weekly downloads, used by
#     Babel + Webpack + ESLint to determine target
#     browsers)
#   - + nanoid (~20M weekly downloads, used by
#     virtually every Node project that needs UUIDs)
#
# Joining the multi-axis canonical-author cohort:
#   - Andrew Gallant / BurntSushi (Rust)
#   - Armin Ronacher / mitsuhiko (Rust + Python)
#   - Vincent Prouillet / Keats (Rust)
#   - Daniel Lemire (Rust + Go + C + C++ + Java)
#   - Paul Miller / paulmillr (Node)
#   - Steven Fackler / sfackler (Rust)
#   - Devon Govett (Rust + Node)
#   - Brian Carlson / brianc (Node)
#   - Vladimir Mihailenco (Go)
#   - Matt Ranney + Redis Inc. team (Node)
#   - Andrey Sitnik / ai (Node, THIS AXIS)
#
# pcss-cli composes the PostCSS pipeline via the
# `postcss(plugins).process(css, options)` API +
# delegates to chokidar for watch mode + minimist
# for argv parsing.
#
# ----------------------------------------------------------------------------
# AXIS 258 :: CSS parser libraries (CSS Syntax L3 +
#              Selectors L4 + ~30 other CSS specs)
# Round 1474 :: TS-Node slot 3 of 4 :: CLOSES Axis 258
#                                       (251st axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : parcel-bundler/lightningcss  [R1472 _stencila]
#   Go      : tdewolff/parse/css           [R1473 _obelisk]
#   TS/Node : postcss                      [R1474 THIS FILE]
#             (Sitnik's plugin-platform)
#
# postcss closes Axis 258 with the *plugin-platform-
# ecosystem* pattern. The three lanes form a clean
# spectrum of CSS-library design philosophies:
#
#   - Rust (lightningcss): purpose-built single-
#     library Parcel-replacement; baked-in transforms
#     + minify; no plugin architecture
#   - Go (tdewolff/parse/css): shared-utility module
#     inside a multi-format parsing umbrella; pairs
#     with tdewolff/minify; no plugin architecture
#   - Node (postcss): plugin-platform ecosystem with
#     thousands of community plugins; the parser is
#     intentionally small + lets plugins do the
#     transformation
#
# The Node ecosystem's *plugin-platform-ecosystem*
# pattern is distinctive across the axis cluster.
# Compare:
#   - Axis 245 (BLAKE3) Node slot: dual-canonical
#     by deployment target (connor4312/blake3 +
#     @node-rs/blake3)
#   - Axis 254 (bcrypt) Node slot: dual-canonical by
#     deployment target (kelektiv native +
#     dcodeIO pure-JS)
#   - Axis 258 (CSS, THIS AXIS) Node slot: single
#     plugin-platform canonical (postcss) +
#     thousands of community plugins
#
# Cross-language interop at the CSS spec level - all
# three lanes parse the same W3C CSS specifications.
# Output differs based on the lane's transform
# philosophy.
#
# Use-case spectrum across the three lanes:
#   - stencila (Rust, lightningcss): scientific
#     document publishing platform's theme rendering
#     pipeline
#   - obelisk (Go, tdewolff/parse/css): web-page-to-
#     single-HTML archiver's CSS resource rewriting
#   - pcss (Node, postcss): config-as-code PostCSS
#     build runner for CSS preprocessing workflows
#
# Three lanes, three use-case shapes (scientific
# document theme / web archival rewriting / CSS
# build pipeline), three implementation strategies
# (specialized Rust replacement / Go multi-format
# umbrella / Node plugin platform), all converging
# on the same W3C CSS specifications.
#
# Axis 258 closes the round 1474 cycle - 251st axis
# closed total.
# ============================================================================

_pcss() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-c[config file (default pcss.config.js)]:file:_files -g "*.{js,mjs,cjs,ts}"' \
        '-w[watch mode (re-run on file change)]'
}

_pcss "$@"
