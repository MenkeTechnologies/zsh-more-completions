#compdef tartufo
# Documentation: https://github.com/godaddy/tartufo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'scan-local-repo:scan an already-cloned local git repo'
  'scan-remote-repo:clone and scan a remote git repository'
  'scan-folder:scan a folder (no git history)'
  'pre-commit:scan staged changes in a pre-commit hook'
  'update-signatures:update issue signatures'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--config=[tartufo config file]:file:_files -g "*.{toml,ini,cfg}"' \
  '--rules=[rules file]:file:_files -g "*.json"' \
  '--rule-patterns=[inline rule patterns]:json:' \
  '--default-regexes[use default regexes]' \
  '--no-default-regexes[disable default regexes]' \
  '--entropy[detect high-entropy strings]' \
  '--no-entropy[skip entropy checks]' \
  '--regex[detect via regexes]' \
  '--no-regex[skip regex detection]' \
  '--include-path-patterns=[paths to include]:patterns:' \
  '--exclude-path-patterns=[paths to exclude]:patterns:' \
  '--exclude-signatures=[signatures to exclude]:signatures:' \
  '--exclude-entropy-patterns=[entropy exclusion patterns]:patterns:' \
  '--cleanup[clean temp checkout dirs]' \
  '--no-cleanup[keep temp checkout dirs]' \
  '--json[JSON output]' \
  '--compact[compact output]' \
  '--output-format=[output format]:format:(text json compact)' \
  '--b64-entropy-score=[base64 entropy threshold]:score:' \
  '--hex-entropy-score=[hex entropy threshold]:score:' \
  '--repo-config=[repo config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tartufo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan-local-repo)
        _arguments \
          '--branch=[git branch]:branch:' \
          '--since-commit=[scan commits since SHA]:sha:' \
          '--max-depth=[max commit depth]:n:' \
          '--include-submodules[scan submodules]' \
          '*::repo_path:_files -/' && ret=0 ;;
      (scan-remote-repo)
        _arguments \
          '--branch=[git branch]:branch:' \
          '--since-commit=[scan commits since SHA]:sha:' \
          '--max-depth=[max commit depth]:n:' \
          '--work-dir=[clone target directory]:dir:_files -/' \
          '--key-path=[SSH key path]:file:_files' \
          '*::repo_url:' && ret=0 ;;
      (scan-folder)
        _arguments \
          '--recurse[recurse subfolders]' \
          '--no-recurse[do not recurse]' \
          '*::folder:_files -/' && ret=0 ;;
      (pre-commit)
        _arguments \
          '--staged-only[only scan staged]' && ret=0 ;;
      (update-signatures)
        _arguments \
          '*::repo_path:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
