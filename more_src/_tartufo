#compdef tartufo
# Documentation: https://github.com/godaddy/tartufo
# Reference accessed: 2026-05-21
# Verified: upstream source at tartufo/cli.py and tartufo/commands/*.py.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'scan-local-repo:scan a repository already cloned locally'
  'scan-remote-repo:automatically clone and scan a remote git repository'
  'scan-folder:scan a folder'
  'pre-commit:scan staged changes in a pre-commit hook'
  'update-signatures:update issue signatures in the config file'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet --no-quiet)'{-q,--quiet}'[quiet mode]' \
  '--no-quiet[disable quiet mode]' \
  '*--config=[tartufo config file]:file:_files' \
  '*--rule-patterns=[regex pattern to search for]:pattern:' \
  '--default-regexes[include default regex list]' \
  '--no-default-regexes[exclude default regex list]' \
  '--entropy[enable entropy checks]' \
  '--no-entropy[disable entropy checks]' \
  '--regex[enable regex checks]' \
  '--no-regex[disable regex checks]' \
  '--scan-filenames[scan filenames as well as contents]' \
  '--no-scan-filenames[do not scan filenames]' \
  '*'{-ip,--include-path-patterns}'=[paths to include]:pattern:' \
  '*'{-xp,--exclude-path-patterns}'=[paths to exclude]:pattern:' \
  '*'{-xe,--exclude-entropy-patterns}'=[entropy exclusion patterns]:pattern:' \
  '*'{-xr,--exclude-regex-patterns}'=[regex exclusion patterns]:pattern:' \
  '*'{-e,--exclude-signatures}'=[signatures to exclude]:signature:' \
  '('{-of,--output-format}')'{-of,--output-format}'=[output format]:format:(json compact text report)' \
  '('{-od,--output-dir}')'{-od,--output-dir}'=[output directory]:dir:_directories' \
  '('{-td,--temp-dir}')'{-td,--temp-dir}'=[temp directory]:dir:_directories' \
  '--buffer-size=[max in-memory issue buffer]:n:' \
  '--git-rules-repo=[git rules repo (path or URL)]:repo:' \
  '*--git-rules-files=[glob patterns for rule files]:pattern:' \
  '--log-timestamps[enable log timestamps]' \
  '--no-log-timestamps[disable log timestamps]' \
  '--entropy-sensitivity=[entropy sensitivity 0-100]:n:' \
  '--color[enable terminal color]' \
  '--no-color[disable terminal color]' \
  '--target-config[process repo config file]' \
  '--no-target-config[ignore repo config file]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tartufo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan-local-repo)
        _arguments \
          '--since-commit=[scan commits since SHA]:sha:' \
          '--max-depth=[max commit depth]:n:' \
          '--branch=[git branch]:branch:' \
          '--include-submodules[scan submodules]' \
          '--exclude-submodules[skip submodules]' \
          '(-p --progress)'{-p,--progress}'[display progress bar]' \
          '*::repo_path:_files -/' && ret=0 ;;
      (scan-remote-repo)
        _arguments \
          '--since-commit=[scan commits since SHA]:sha:' \
          '--max-depth=[max commit depth]:n:' \
          '--branch=[git branch]:branch:' \
          '('{-wd,--work-dir}')'{-wd,--work-dir}'=[clone target directory]:dir:_directories' \
          '--include-submodules[scan submodules]' \
          '--exclude-submodules[skip submodules]' \
          '(-p --progress)'{-p,--progress}'[display progress bar]' \
          '*::git_url:' && ret=0 ;;
      (scan-folder)
        _arguments \
          '--recurse[recurse subfolders]' \
          '--no-recurse[do not recurse]' \
          '--git-check[warn if folder is git repo]' \
          '--no-git-check[skip git repo check]' \
          '*::target:_files -/' && ret=0 ;;
      (pre-commit)
        _arguments \
          '--include-submodules[scan submodules]' \
          '--exclude-submodules[skip submodules]' && ret=0 ;;
      (update-signatures)
        _arguments \
          '--since-commit=[scan commits since SHA]:sha:' \
          '--max-depth=[max commit depth]:n:' \
          '--branch=[git branch]:branch:' \
          '--include-submodules[scan submodules]' \
          '--exclude-submodules[skip submodules]' \
          '*::repo_path:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
