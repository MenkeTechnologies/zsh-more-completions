#compdef cdm
# Documentation: https://man.archlinux.org/search?q=cdm
# Reference accessed: 2026-05-16

# cdm: console display manager (login + session switcher)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '*::cdm args:_files' && ret=0
return ret
