#compdef nqp nqp-m
# Documentation: https://github.com/Raku/nqp
# Reference accessed: 2026-05-19
# Verified: local nqp --help output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*-e+[evaluate expression]:expr:' \
  '--target=[compilation target]:target:' \
  {-t+,--trace=}'[trace flags]:flags:' \
  '--encoding=[input encoding]:encoding:' \
  {-o+,--output=}'[output file]:file:_files' \
  '--source-name=[source name]:name:' \
  '--combine[combine multiple sources]' \
  '--show-config[show config]' \
  '(-V --verbose-config)'{-V,--verbose-config}'[verbose config]' \
  '--stagestats=-[print stage statistics]::level:' \
  '--ll-exception[low-level exception]' \
  '--nqpevent=[NQP event]:event:' \
  '--profile=-[run profiler]::file:_files' \
  '--profile-compile=-[profile compile]::file:_files' \
  '--profile-filename=[profile output file]:file:_files' \
  '--profile-kind=[profile kind]:kind:(instrumented heap)' \
  '--profile-stage=[stage to profile]:stage:' \
  '--repl-mode=[REPL mode]:mode:' \
  '--rakudo-home[show Rakudo home]' \
  '--confprog=[configuration program]:file:_files' \
  '--full-cleanup[full cleanup on exit]' \
  '--debug-suspend[suspend for debugger]' \
  '--debug-port=[debug port]:port:' \
  '--tracing[enable tracing]' \
  '--setting=[setting]:setting:' \
  '--setting-path=[setting path]:dir:_files -/' \
  '--custom-regex-lib=[custom regex lib]:lib:' \
  '--module-path=[module path]:dir:_files -/' \
  '--no-regex-lib[no regex lib]' \
  '--stable-sc=[stable SC]:sc:' \
  '--optimize=[optimization level]:level:' \
  '--vmlibs=[VM libs]:libs:' \
  '--bootstrap[bootstrap]' \
  '*:NQP source file:_files -g "*.nqp"' && ret=0

return ret
