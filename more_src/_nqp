#compdef nqp nqp-m
# Documentation: https://man.archlinux.org/search?q=nqp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*-e+[evaluate expression]:expr:' \
  '--target=[compilation target]:target:(parse past qast mast jar moarvm js)' \
  {-t+,--trace=}'[trace flags]:flags:' \
  '--encoding=[input encoding]:encoding:' \
  {-o+,--output=}'[output file]:file:_files' \
  '*:NQP source file:_files -g "*.nqp"' && ret=0

return ret
