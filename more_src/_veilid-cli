#compdef veilid-cli
# Documentation: https://gitlab.com/veilid/veilid/-/tree/main/veilid-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Veilid P2P CLI client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --address)'{-a,--address=}'[network address to connect to]:addr:' \
  '(-p --ipc_path)'{-p,--ipc_path=}'[IPC socket path]:path:_files' \
  '(-n --subnode_index)'{-n,--subnode_index=}'[subnode index]:n:' \
  '--wait_for_debug[pause until debugger attaches]' \
  '(-c --config_file)'{-c,--config_file=}'[configuration file]:file:_files' \
  '--cli_log_level=[CLI log level]:level:(Error Warn Info Debug Trace)' \
  '(-i --interactive)'{-i,--interactive}'[enable interactive command mode]' \
  '(-e --evaluate)'{-e,--evaluate=}'[execute single CLI command]:cmd:' \
  '(-l --log)'{-l,--log}'[display logs only]' \
  '(-f --command_file)'{-f,--command_file=}'[read commands from file]:file:_files' \
  '*::file:_files' && ret=0

return ret
