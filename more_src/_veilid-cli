#compdef veilid-cli
# Documentation: https://man.archlinux.org/search?q=veilid-cli
# Reference accessed: 2026-05-16

# Zsh completion for Veilid P2P CLI client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--address[bootstrap node address]:addr' \
  '*::args:{ _message "veilid-cli control verbs" }' && ret=0

return ret
