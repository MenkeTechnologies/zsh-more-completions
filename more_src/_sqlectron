#compdef sqlectron
# Documentation: https://man.archlinux.org/search?q=sqlectron
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--disable-gpu[disable GPU acceleration]' \
  '--user-data-dir=[user data directory]:dir:_files -/' \
  '*:database_file:_files -g "*.{db,sqlite,sqlite3,db3}"' && ret=0

return ret
