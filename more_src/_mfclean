#compdef mfclean
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/mfclean.html
# Multi-frequency synthesis CLEAN

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'map=[map keyword]:map:' \
  'beam=[beam keyword]:beam:' \
  'model=[model keyword]:model:' \
  'out=[out keyword]:out:' \
  'gain=[gain keyword]:gain:' \
  'cutoff=[cutoff keyword]:cutoff:' \
  'niters=[niters keyword]:niters:' \
  'region=[region keyword]:region:' \
  'minpatch=[minpatch keyword]:minpatch:' \
  'speed=[speed keyword]:speed:' \
  'mode=[mode keyword]:mode:' \
  'log=[log keyword]:log:' \
  '*:visibility dataset:_files' && ret=0

return ret
