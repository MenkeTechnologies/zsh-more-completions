#compdef hipsparse-test hipsparse-bench
# _hipsparse — AMD ROCm hipSPARSE marshalling layer between HIP API and rocSPARSE or cuSPARSE sparse linear algebra library (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/hipSPARSE

_hipsparse() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_print_time=+[bool]:b:(0 1)' \
        '--gtest_output=+[format:file]:str:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '-r+[precision]:p:(s d c z)' \
        '--precision=+[precision]:p:(s d c z)' \
        '-f+[function]:str:' \
        '--function=+[function]:str:' \
        '-m+[rows]:n:' \
        '--sizem=+[rows]:n:' \
        '-n+[cols]:n:' \
        '--sizen=+[cols]:n:' \
        '-k+[nonzeros]:n:' \
        '--sizek=+[nonzeros]:n:' \
        '--nnz=+[nonzeros]:n:' \
        '--mb=+[block rows]:n:' \
        '--nb=+[block cols]:n:' \
        '--block-dim=+[block dim]:n:' \
        '--matrix=+[mtx file]:file:_files -g "*.mtx *.bin"' \
        '--matrix-type=+[type]:t:(general symmetric hermitian triangular)' \
        '--storage-format=+[format]:f:(csr coo ell hyb bsr)' \
        '--indextype=+[type]:t:(i32 i64 mixed)' \
        '--api=+[api]:a:(compat regular dispatch)' \
        '--devices=+[device id csv]:str:' \
        '--iters=+[iterations]:n:' \
        '--alpha=+[F]:f:' \
        '--beta=+[F]:f:' \
        '--base=+[index base]:b:(0 1)' \
        '--threads=+[N]:n:'
}

_hipsparse "$@"
