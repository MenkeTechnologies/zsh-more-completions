#compdef condor_drain
# _condor_drain — HTCondor condor_drain (gracefully drain or cancel-drain of a startd, dropping all running jobs once their JobLeaseDurations expire; -name startd name, -pool collector address, -graceful/-quick/-fast drain mode, -reason text, -cancel revert in-progress drain, -resume-on-completion or -check-expr boolean filter)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_drain on tip.

_condor_drain() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-name+[startd name]:name:' \
        '-pool+[collector address]:host:_hosts' \
        '-debug[debug]' \
        '-graceful[graceful drain]' \
        '-quick[quick drain]' \
        '-fast[fast drain]' \
        '-cancel[cancel drain]' \
        '-resume-on-completion[resume on completion]' \
        '-reason+[reason text]:reason:' \
        '-deadline+[seconds]:seconds:' \
        '-check-expr+[ClassAd boolean expr]:expr:' \
        '-start-expr+[start expression]:expr:'
}

_condor_drain "$@"
