#compdef primer3_masker

# primer3_masker: mask repetitive regions before primer design
local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-i --input)'{-i,--input}'=[input FASTA file]:file:_files' \
  '(-o --output)'{-o,--output}'=[output FASTA file]:file:_files' \
  '(-l --pwm_list)'{-l,--pwm_list}'=[comma-separated PWM list files]:pwm files:_files' \
  '(-m --masking_kmer_lists_dir)'{-m,--masking_kmer_lists_dir}'=[directory with k-mer lists]:dir:_files -/' \
  '(-p --pwm_threshold)'{-p,--pwm_threshold}'=[PWM score threshold]:threshold:' \
  '(-c --coverage_threshold)'{-c,--coverage_threshold}'=[coverage threshold]:threshold:' \
  '(-x --x_lowercase)'{-x,--x_lowercase}'[mask repeats in lowercase]' \
  '(-n --hard_masking)'{-n,--hard_masking}'[hard-mask repeats with N]' \
  '(-s --strict_tags)'{-s,--strict_tags}'[strict tag parsing]' \
  '*:input file:_files' && ret=0

return ret
