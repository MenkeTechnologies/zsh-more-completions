#compdef verilator_bin
# Documentation: https://verilator.org/guide/latest/
# Verilator HDL simulator binary (verilator front-end invokes this)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '--cc[create C++ output]' \
  '--sc[create SystemC output]' \
  '--binary[create a Verilated simulator binary]' \
  '--exe[generate an executable]' \
  '--build[invoke toolchain to build the model library]' \
  '--main[create a main wrapper]' \
  '--lint-only[check files for lint violations only]' \
  '--timing[enable timing support for delays and event controls]' \
  '--trace[enable VCD waveform creation]' \
  '--trace-vcd[enable VCD waveform creation]' \
  '--trace-fst[enable FST waveform tracing]' \
  '--trace-depth=[number of levels deep to trace]:levels' \
  '--top-module=[specify top-level module]:module' \
  '--Mdir=[name of output object directory]:dir:_files -/' \
  '-o+[specify final executable name]:exe:_files' \
  '-O0[disable optimization]' \
  '-O1[default optimization level]' \
  '-O2[stronger than default optimization]' \
  '-O3[enable slow optimizations]' \
  '--threads=[enable multithreading with N threads]:N' \
  '-j+[parallelism for build and verilation]:jobs' \
  '-CFLAGS+[add C++ compiler arguments]:flags' \
  '-LDFLAGS+[add C++ linker arguments]:flags' \
  '*-I-[directory to search for includes]:dir:_files -/' \
  '*-y+[directory to search for modules]:dir:_files -/' \
  '*-f+[parse arguments from a file]:file:_files' \
  '*:source file:_files -g "*.(v|sv|vh|svh)"' && ret=0

return ret
