#compdef mscgen

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-T+[output type]:type:(png eps svg ismap)' \
  '-i+[input file (- = stdin)]:file:_files' \
  '-o+[output file]:file:_files' \
  '-F+[font for PNG output]:font:' \
  '-p[print parsed msc to stdout]' \
  '-l[show license and exit]' \
  '*:input file:_files' && ret=0

return ret
