#compdef artemis

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:display available commands and usage'
  'pwd:show current folder and instance information'
  'shell:launch interactive JLine3 shell'
  'version:print version details'
  'completion:generate shell auto-completion script'
  'create:create a new broker instance'
  'upgrade:upgrade a broker instance'
  'connect:authenticate to broker with credentials'
  'disconnect:clear stored user credentials'
  'producer:send messages to a broker'
  'consumer:consume messages from a queue'
  'browser:browse messages on a queue'
  'transfer:move messages between destinations'
  'queue:queue tools'
  'address:address tools'
  'data:journal/data tools'
  'perf:performance testing'
  'check:system validation'
  'mask:encrypt and display passwords'
  'message:message tools'
  'broker:broker tools'
  'user:user tools'
  'activation:activation tools'
  'run:start broker instance'
  'stop:stop broker instance'
  'kill:kill broker process'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'artemis subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (queue)
        _values 'queue action' \
          'create' 'delete' 'update' 'stat' 'purge' && ret=0
        ;;
      (address)
        _values 'address action' \
          'create' 'delete' 'update' 'show' && ret=0
        ;;
      (data)
        _values 'data action' \
          'recover' 'print' 'exp' 'imp' 'decode' 'encode' 'compact' && ret=0
        ;;
      (perf)
        _values 'perf action' \
          'producer' 'client' 'journal' && ret=0
        ;;
      (check)
        _values 'check action' \
          'node' 'queue' 'topic' && ret=0
        ;;
      (user)
        _values 'user action' \
          'add' 'rm' 'list' 'reset' && ret=0
        ;;
      (activation)
        _values 'activation action' \
          'list' 'sequence-set' && ret=0
        ;;
      (broker)
        _values 'broker action' \
          'connection' && ret=0
        ;;
      (message)
        _values 'message action' \
          'browse' 'send' && ret=0
        ;;
      (create)
        _arguments \
          '--aio[use AIO journal type]' \
          '--nio[use NIO journal type]' \
          '--jdbc[use JDBC persistence]' \
          '--mapped[use mapped journal type]' \
          '--require-login[require user login]' \
          '--allow-anonymous[allow anonymous logins]' \
          '--use-client-auth[use client SSL auth]' \
          '--clustered[configure clustering]' \
          '--replicated[configure replication]' \
          '--backup[configure as backup]' \
          '--shared-store[use shared-store HA]' \
          '--host=[bind host]:host:_hosts' \
          '--port-offset=[port offset]:n:' \
          '--default-port=[default port]:port:' \
          '--no-amqp-acceptor[disable AMQP acceptor]' \
          '--no-mqtt-acceptor[disable MQTT acceptor]' \
          '--no-stomp-acceptor[disable STOMP acceptor]' \
          ':directory:_files -/' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
