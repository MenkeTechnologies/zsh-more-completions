#compdef cldrparser
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:collation file:_files -g "*.xml"' \
  '2::type name:' \
  '-a-[alt property to select specific type]:alt:' \
  '-d-[directory containing collation files]:dir:_files -/' \
  '-o-[directory for generated files]:dir:_files -/' \
  '-t-[execute test suite, halt on fail flag]:halt-on-fail:(y Y t T 1)' && ret=0

return ret
