  '-a[ASCII table]' \
  '-c[hex C-string from int]' \
  '-C[stdin to C array]' \
  '-d[decimal output]' \
  '-D[base64 decode]' \
  '-e[swap endian]' \
  '-E[base64 encode]' \
  '-f[IEEE 754 float]' \
  '-F[C strings to hexpairs]' \
  '-h[show help]' \
  '-H[string hash]' \
  '-i[long <-> IP]' \
  '-j[JSON output]' \
  '-k[keep base]' \
  '-K[randomart]' \
  '-n[append newline]' \
  '-o[octal to char]' \
  '-q[quiet]' \
  '-r[r2 ?-style output]' \
  '-s[hex pairs to char]' \
  '-S[char to hex]' \
  '-t[epoch to date]' \
  '-u[human-readable units]' \
  '-v[show version]' \
  '-w[16-bit signed]' \
  '-x[hexpairs from int]' \
  '-X[bit stream to hex]' \
  '-z[char string to bin]' \
  '-Z[bin string to string]' \
  '-b=[output base]:base:(f 2 3 8 10 16)' \
