#compdef wl-clip-persist
# Documentation: https://github.com/Linus789/wl-clip-persist
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--clipboard=[clipboard selection to persist]:type:(regular primary both)' \
  '--write-timeout=[write timeout in milliseconds]:ms:' \
  '--ignore-event-on-error[handle only error-free selection events]' \
  '--all-mime-type-regex=[regex for MIME types to persist]:regex:' \
  '--selection-size-limit=[max size of selection to persist (bytes)]:bytes:' \
  '--reconnect-tries=[reconnection attempt limit]:count:' \
  '--reconnect-delay=[reconnection delay in milliseconds]:ms:' \
  '--disable-timestamps[remove timestamps from log messages]' && ret=0

return ret
