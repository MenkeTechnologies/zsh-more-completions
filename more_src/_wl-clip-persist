#compdef wl-clip-persist

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[clipboard selection type]:type:(regular primary both)' \
  '-d[display name]:display:' \
  '--all-mime-type-regex[regex for MIME types to persist]:regex:' \
  '--selection-size-limit[max size of selection to persist]:bytes:' \
  '--timeout[connection timeout]:seconds:' && ret=0

return ret
