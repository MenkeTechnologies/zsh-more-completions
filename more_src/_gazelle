#compdef gazelle
# Documentation: https://man.archlinux.org/search?q=gazelle
# Reference accessed: 2026-05-16

_arguments -s -S \
  '-build_file_name=[Bazel build file name]:name:' \
  '-build_tags=[Go build tags]:tags:' \
  '-external=[external dependency mode]:mode:(external vendored)' \
  '-go_prefix=[import prefix for go_repository]:prefix:' \
  '-go_repository_mode[treat repo as external go_repository]' \
  '-known_import=[known import prefix]:import:' \
  '-mode=[fix mode]:mode:(fix diff print)' \
  '-proto=[proto mode]:mode:(default disable_global legacy global)' \
  '-repo_root=[repository root]:dir:_files -/' \
  '-r[process subdirectories recursively]' \
  '(-h -help)'{-h,-help}'[show help]' \
  '*:packages or dirs:_files -/'
