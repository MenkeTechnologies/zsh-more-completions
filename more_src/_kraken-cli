#compdef kraken-cli kraken
# _kraken-cli — Kraken kraken-cli CLI command-line frontend wrapping the Kraken Payward cryptocurrency exchange Spot Margin Futures REST WebSocket API managing accounts balances orders trades open-orders closed-orders OHLC ticker depth tradable-asset-pairs deposits withdrawals trade-history ledger-info account-balance staking earn (Kraken team, Go); cobra
# upstream: https://www.kraken.com/

_kraken-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'balance:balance operations'
        'order:order operations'
        'trade:trade operations'
        'history:trade history'
        'ledger:ledger operations'
        'ticker:ticker operations'
        'ohlc:OHLC candle data'
        'depth:order book depth'
        'asset:asset operations'
        'asset-pair:asset pair operations'
        'deposit:deposit operations'
        'withdrawal:withdrawal operations'
        'transfer:transfer operations'
        'staking:staking operations'
        'earn:earn operations'
        'futures:futures operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[e]:e:(spot futures testnet)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kraken-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list get place cancel cancel-all status)' \
                    '--pair=+[pair]:str:' \
                    '--type=+[t]:t:(buy sell)' \
                    '--ordertype=+[t]:t:(market limit stop-loss take-profit stop-loss-limit take-profit-limit settle-position)' \
                    '--volume=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '--price2=+[N]:str:' \
                    '*:order id:' ;;
                account|balance|trade|history|ledger|asset|asset-pair|deposit|withdrawal|transfer|staking|earn|futures) _arguments '1:op:(list get create cancel deposit withdraw transfer stake unstake)' '*:id:' ;;
                ticker|ohlc|depth) _arguments \
                    '--pair=+[pair]:str:' \
                    '--since=+[timestamp]:n:' \
                    '--interval=+[i]:i:(1 5 15 30 60 240 1440 10080 21600)' \
                    '--count=+[N]:n:' ;;
            esac
            ;;
    esac
}

_kraken-cli "$@"
