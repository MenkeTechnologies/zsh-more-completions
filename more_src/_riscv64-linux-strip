#compdef riscv64-linux-strip riscv64-linux-gnu-strip riscv64-unknown-linux-gnu-strip riscv64-unknown-elf-strip
# _riscv64-linux-strip — GNU binutils riscv64-linux-strip CLI cross-arch ELF64 symbol-stripping tool removing debug info DWARF symbol tables relocations notes from RV64GC RV64GCV Linux binaries shared libraries object files keeping specific symbols only-keep-debug discarding all unneeded keep-section-symbols (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_riscv64-linux-strip() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[strip all]' \
        '--strip-all[strip all]' \
        '-S[strip debug]' \
        '--strip-debug[strip debug]' \
        '-g[strip debug]' \
        '-d[strip debug]' \
        '--strip-unneeded[strip unneeded]' \
        '--strip-dwo[strip .dwo sections]' \
        '-K+[keep symbol]:str:' \
        '--keep-symbol=+[symbol]:str:' \
        '-N+[strip symbol]:str:' \
        '--strip-symbol=+[symbol]:str:' \
        '-w[wildcards]' \
        '--wildcard[wildcards]' \
        '-x[discard all]' \
        '--discard-all[discard all]' \
        '-X[discard locals]' \
        '--discard-locals[discard locals]' \
        '-R+[section]:str:' \
        '--remove-section=+[section]:str:' \
        '--keep-section=+[section]:str:' \
        '--only-keep-debug[only keep debug sections]' \
        '-o+[output]:file:_files' \
        '--output-file=+[file]:file:_files' \
        '-I+[input format]:str:' \
        '--input-target=+[fmt]:str:' \
        '-O+[output format]:str:' \
        '--output-target=+[fmt]:str:' \
        '-p[preserve dates]' \
        '--preserve-dates[preserve dates]' \
        '*:file:_files'
}

_riscv64-linux-strip "$@"
