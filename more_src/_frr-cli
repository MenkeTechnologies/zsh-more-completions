#compdef vtysh frr-cli
# _frr-cli — FRRouting frr-cli vtysh CLI integrated configuration shell unified interface to running zebra bgpd ospfd ospf6d ripd ripngd isisd ldpd pimd nhrpd vrrpd bfdd staticd fabricd babeld pathd watchfrr-managed routing daemons with cisco-style configuration mode (FRR team, C); getopt
# upstream: https://frrouting.org/

_frr-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-b[boot startup config]' \
        '--boot[boot startup config]' \
        '-c+[command]:str:' \
        '--command=+[command]:str:' \
        '-d+[daemon]:d:(zebra ripd ripngd ospfd ospf6d bgpd ldpd nhrpd pimd pim6d isisd babeld eigrpd sharpd staticd fabricd vrrpd pathd bfdd)' \
        '--daemon=+[name]:d:(zebra ripd ripngd ospfd ospf6d bgpd ldpd nhrpd pimd pim6d isisd babeld eigrpd sharpd staticd fabricd vrrpd pathd bfdd)' \
        '-E[echo input]' \
        '--echo[echo input]' \
        '-C[only check config]' \
        '--dryrun[only check config]' \
        '-m[markfile config style]' \
        '--markfile[markfile config style]' \
        '-n[no fork]' \
        '--noerror[exit nonzero on error]' \
        '-w[output writeconfig]' \
        '--writeconfig[output writeconfig]' \
        '-N+[pathspace]:str:' \
        '--pathspace=+[name]:str:' \
        '-H+[history file]:file:_files' \
        '--histfile=+[file]:file:_files' \
        '--user=+[user]:_users' \
        '--config_dir=+[dir]:dir:_files -/' \
        '--vty_socket=+[dir]:dir:_files -/' \
        '*::'
}

_frr-cli "$@"
