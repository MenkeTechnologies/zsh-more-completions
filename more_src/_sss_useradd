#compdef sss_useradd
# Documentation: https://man.archlinux.org/search?q=sss_useradd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '(-u --uid)'{-u,--uid}'+[user UID]:uid:' \
  '(-g --gid)'{-g,--gid}'+[primary GID]:gid:_groups' \
  '(-c --gecos)'{-c,--gecos}'+[GECOS info]:gecos:' \
  '(-h --home)'{-h,--home}'+[home directory]:dir:_files -/' \
  '(-k --skel)'{-k,--skel}'+[skel directory]:dir:_files -/' \
  '(-s --shell)'{-s,--shell}'+[login shell]:shell:_files -g "/usr/bin/*sh /bin/*sh"' \
  '(-m --create-home)'{-m,--create-home}'[create home directory]' \
  '(-M --no-create-home)'{-M,--no-create-home}'[do not create home]' \
  '(-G --groups)'{-G,--groups}'+[supplementary groups]:groups:_groups' \
  '(-N --no-user-group)'{-N,--no-user-group}'[do not create user group]' \
  '(-r --system)'{-r,--system}'[create system account]' \
  '(-Z --selinux-user)'{-Z,--selinux-user}'+[SELinux user]:user:' \
  '1:username:' && ret=0

return ret
