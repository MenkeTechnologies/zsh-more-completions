#compdef realesrgan-ncnn-vulkan-extra
# Documentation: https://github.com/xinntao/Real-ESRGAN-ncnn-vulkan
# Real-ESRGAN ncnn Vulkan image upscaler (extra-models fork)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-i+[input image path or directory]:input:_files' \
  '-o+[output image path or directory]:output:_files' \
  '-s+[upscale ratio (2/3/4, default=4)]:scale:(2 3 4)' \
  '-t+[tile size (>=32/0=auto)]:tile size' \
  '-m+[folder path to pre-trained models]:model dir:_files -/' \
  '-n+[model name]:model:(realesr-animevideov3 realesrgan-x4plus realesrgan-x4plus-anime realesrnet-x4plus)' \
  '-g+[gpu device to use (default=auto)]:gpu id' \
  '-j+[thread count for load:proc:save]:threads' \
  '-x[enable tta mode]' \
  '-f+[output image format]:format:(jpg png webp)' \
  '-v[verbose output]' && ret=0

return ret
