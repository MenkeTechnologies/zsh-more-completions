#compdef samtools-collate
# Documentation: http://www.htslib.org/doc/samtools-collate.html
# samtools collate: Shuffle and group alignments by name

local ret=1

_arguments -s -S \
  '(-O)'-O'[Output to stdout. This option cannot be used with -o .]' \
  '(-o)'-o'[Write output to FILE. This option cannot be used with -O . If unspecif]:FILE:_files' \
  '(-T)'-T'[Use PREFIX for temporary files. This is the same as specifying PREFIX]:PREFIX: ' \
  '(-u)'-u'[Write uncompressed BAM output]' \
  '(-l)'-l'[Compression level. \[1\]]:INT: ' \
  '(-n)'-n'[Number of temporary files to use. \[64\]]:INT: ' \
  '(-f)'-f'[Fast mode (primary alignments only).]' \
  '(-r)'-r'[Number of reads to store in memory (for use with -f). \[10000\]]:INT: ' \
  '(--no-PG)'--no-PG'[Do not add a @PG line to the header of the output file.]' \
  '(--threads)'--threads'[Number of input/output compression threads to use in addition to main]:INT: ' \
  '*:file:_files' && ret=0

return ret
