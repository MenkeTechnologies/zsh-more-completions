#compdef mariadbd

# mariadbd: MariaDB Server (mysqld successor)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-u[run as user]:user:_users' \
  '--user=[run as user]:user:_users' \
  '--defaults-file=[config file]:file:_files' \
  '--defaults-extra-file=[extra config file]:file:_files' \
  '--datadir=[data directory]:dir:_files -/' \
  '-h[data directory]:dir:_files -/' \
  '--socket=[unix socket file]:file:_files' \
  '--bind-address=[bind address]:host:' \
  '--port=[port]:port:' \
  '--log-error=[error log file]:file:_files' \
  '--log-bin=[binary log file]:file:_files' \
  '--log-slave-updates[log slave updates to binlog]' \
  '--general-log[general query log]' \
  '--slow-query-log[slow query log]' \
  '--pid-file=[PID file]:file:_files' \
  '--basedir=[base install dir]:dir:_files -/' \
  '--character-set-server=[server charset]:charset:' \
  '--collation-server=[server collation]:collation:' \
  '--default-storage-engine=[default engine]:engine:(InnoDB Aria MyISAM Memory CSV Archive MRG_MyISAM BLACKHOLE FEDERATED OQGraph)' \
  '--read-only[read-only mode]' \
  '--skip-grant-tables[skip grant tables (insecure)]' \
  '--skip-networking[disable networking]' \
  '--skip-name-resolve[disable DNS resolution]' \
  '--max-connections=[max connections]:n:' \
  '--memlock[lock mysqld in memory]' \
  '--log-warnings=[log warnings level]:level:' \
  '--bootstrap[bootstrap mode]' \
  '*::mariadbd args:_files' && ret=0
return ret
