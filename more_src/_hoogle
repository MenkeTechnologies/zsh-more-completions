#compdef hoogle

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:generate Hoogle databases'
      'search:search for functions by name or type'
      'server:start a web server'
      'data:show data directory'
    )
    _describe -t commands 'hoogle command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--local=[local packages directory]:directory:_directories' \
          '--database=[output database file]:file:_files' \
          '--download[download files from the web]' \
          '--insecure[allow insecure HTTPS connections]' \
          '*:packages:' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--database=[database file]:file:_files' \
          '--count=[number of results]:count:' \
          '--json[output as JSON]' \
          '--link[show links]' \
          '*:query:' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--database=[database file]:file:_files' \
          '-p+[port number]:port:' \
          '--port=[port number]:port:' \
          '--host=[host to bind to]:host:' \
          '--local[local mode]' \
          '--cdn=[CDN URL]:url:' \
          '--https[enable HTTPS]' \
          '--cert=[certificate file]:cert:_files' \
          '--key=[key file]:key:_files' \
          '--home=[home URL]:url:' \
          '--log=[log file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
