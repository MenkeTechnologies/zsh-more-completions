#compdef pslStats
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: collect statistics from a psl file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-queryStats[output per-query statistics]' \
  '-overallStats[output overall statistics]' \
  '-queries=[file of expected qNames and sizes]:file:_files' \
  '-warnOnConflicts[warn and ignore conflicting PSLs]' \
  '-tsv[write a TSV header instead of autoSql header]' \
  ':psl:_files' \
  ':stats out:_files' && ret=0

return ret
