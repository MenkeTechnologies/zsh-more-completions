#compdef opencv_version
# Documentation: https://github.com/opencv/opencv/blob/master/apps/version/opencv_version.cpp
# opencv_version — print OpenCV version and build configuration

local ret=1

_arguments -s -S \
  '(-h --help -usage -?)'{-h,--help}'[show this help message]' \
  '(-v --verbose)'{-v,--verbose}'[show build configuration log]' \
  '--opencl[show information about OpenCL platforms/devices]' \
  '--hw[show detected HW features]' \
  '--threads[show configured parallel framework and active threads]' && ret=0

return ret
