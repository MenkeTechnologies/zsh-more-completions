#compdef goleft
# Documentation: https://github.com/brentp/goleft
# kit of bioinformatics tools mostly for BAM/CRAM processing

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'covstats:estimate coverage and insert-size stats by sampling BAMs'
      'depth:parallelize calls to samtools in user-defined windows'
      'depthwed:matricize depth output to n-sites x n-samples'
      'indexcov:quick coverage estimate using only the BAM index'
      'indexsplit:generate regions of even data across a cohort'
      'samplename:report sample name(s) from a BAM SM tag'
    )
    _describe -t commands 'goleft command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      indexcov)
        _arguments -s -S \
          '(-d --directory)'{-d,--directory}'=[output directory]:dir:_files -/' \
          '--fai=[path to FASTA index]:file:_files' \
          '--excludepatt=[pattern to exclude chromosomes]:pattern' \
          '--extranormalize[extra normalization, improves CRAM results]' \
          '--sex=[chromosomes to use for inferring sex]:chroms' \
          '*:bam file:_files' && ret=0
        ;;
      *)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
