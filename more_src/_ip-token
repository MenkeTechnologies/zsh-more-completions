#compdef ip-token
# Documentation: https://man.archlinux.org/man/ip-token.8.en
# ip token - manage tokenized interface identifiers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip token command' \
      'set[assign interface token]' 'del[remove interface token]' \
      'get[retrieve tokenized identifier]' 'list[display all tokenized identifiers]' \
      'dev[networking interface]' && ret=0
    ;;
esac

return ret
