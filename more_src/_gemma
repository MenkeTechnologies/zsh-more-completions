#compdef gemma
# Documentation: https://github.com/genetics-statistics/GEMMA
# GEMMA: genome-wide efficient mixed-model association (LMM, BSLMM, kinship)

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-g+[genotype file input]:file:_files' \
  '-p+[phenotype file input]:file:_files' \
  '-bfile+[PLINK binary format file prefix]:prefix:_files' \
  '-o+[output file prefix]:prefix' \
  '-k+[kinship matrix file input]:file:_files' \
  '-a+[annotation file input]:file:_files' \
  '-gk+[compute kinship matrix]:type' \
  '-lmm+[run univariate linear mixed model]:type' \
  '-mvlmm[run multivariate linear mixed model]' \
  '-bslmm+[run Bayesian sparse linear mixed model]:type' \
  '-n+[select phenotype number]:int' \
  '-maf+[minor allele frequency threshold]:float' \
  '-nind+[read up to specified number of individuals]:int' \
  '-check[enable checks (slower processing)]' \
  '-no-fpe-check[disable floating point exception checking]' \
  '-strict[stop execution when problems occur]' \
  '-silence[suppress terminal output]' \
  '-debug[enable debug output]' \
  '-debug-data[debug data output mode]' \
  '-debug-dump[debug data stored to files]' \
  '-legacy[run in legacy mode]' && ret=0

return ret
