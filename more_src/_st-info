#compdef st-info
# Documentation: https://github.com/stlink-org/stlink/blob/develop/doc/man/st-info.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--version[print version information]'
  '--probe[display info about connected programmers and devices]'
  '--serial[display device serial number]'
  '--flash[display amount of flash memory]'
  '--pagesize[display flash page size]'
  '--sram[display amount of SRAM]'
  '--chipid[display chip ID]'
  '--descr[display device description]'
  '--connect-under-reset[connect under reset]'
  '--hot-plug[connect without halting target]'
  '--freq=[SWD frequency in kHz]:freq:'
)

_arguments -s -S $arguments
