#compdef st-info

local -a arguments

arguments=(
  '--probe[display information about connected programmers and devices]'
  '--serial=[select device by serial number]:serial:'
  '--connect-under-reset[connect under reset]'
  '--hot-plug[connect without halting the target]'
  '--freq=[set SWD frequency in KHz]:freq:'
  '--flash[display amount of flash memory]'
  '--sram[display amount of SRAM]'
  '--pagesize[display flash page size]'
  '--chipid[display chip ID]'
  '--descr[display device description]'
  '--hla-serial=[use specified HLA serial]:serial:'
  '--version[show version information]'
)

_arguments -s -S $arguments
