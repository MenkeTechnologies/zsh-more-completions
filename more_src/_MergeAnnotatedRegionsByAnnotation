#compdef MergeAnnotatedRegionsByAnnotation
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/utils/MergeAnnotatedRegionsByAnnotation.java
# Merge annotated genomic regions within specified distance if annotation values are exactly the same

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'=[output file]:value:_files' \
  '--segments=[input segment file]:value:_files' \
  '*--annotations-to-match=[annotation column to match on]:value:' \
  '--max-merge-distance=[maximum distance to merge regions]:value:' \
  '--output-contig-column=[output contig column name]:value:' \
  '--output-start-column=[output start column name]:value:' \
  '--output-end-column=[output end column name]:value:' \
  '*:argument:_files' && ret=0

return ret
