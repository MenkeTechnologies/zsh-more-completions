#compdef auto-changelog

# Zsh completion for auto-changelog - Auto-generate changelog from git history

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-o,--output}'=[output file]:file:_files' \
  {-c,--config}'=[config file]:file:_files' \
  {-t,--template}'=[template file]:file:_files' \
  {-r,--remote}'=[remote URL]:url' \
  {-p,--package}'[use version from package.json]' \
  '--tag-prefix=[tag prefix]:prefix' \
  '--tag-pattern=[tag pattern]:pattern' \
  '--starting-version=[starting version]:version' \
  '--starting-date=[starting date]:date' \
  '--ending-version=[ending version]:version' \
  '--sort-commits=[sort commits]:sort order:(date date-desc relevance)' \
  '--commit-limit=[max commits per release]:int' \
  '--backfill-limit=[max commits for backfilled releases]:int' \
  '--commit-url=[custom commit URL format]:url' \
  '--issue-url=[custom issue URL format]:url' \
  '--merge-url=[custom merge URL format]:url' \
  '--compare-url=[custom compare URL format]:url' \
  '--issue-pattern=[issue pattern regex]:pattern' \
  '--breaking-pattern=[breaking change pattern regex]:pattern' \
  '--ignore-commit-pattern=[pattern for commits to ignore]:pattern' \
  '--hide-credit[hide auto-changelog credit]' \
  '--handlebars-setup=[handlebars setup file]:file:_files' \
  '--append-git-log=[append string to git log command]:string' \
  '--append-git-tag=[append string to git tag command]:string' \
  '--prepend[prepend to existing changelog]' \
  '--stdout[output to stdout]' \
  '--unreleased[include unreleased changes]' \
  '--unreleased-only[only output unreleased changes]' \
  '--latest-version=[override latest version]:version' \
  {-l,--latestVersion}'=[override latest version]:version'
