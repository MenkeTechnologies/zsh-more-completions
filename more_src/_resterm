#compdef resterm
# Documentation: https://github.com/unkn0wn-root/resterm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for resterm — .http/.rest client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '*:request:_files -g "*.(http|rest)"' && ret=0

return ret
