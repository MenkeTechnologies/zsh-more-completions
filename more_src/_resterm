#compdef resterm
# Documentation: https://man.archlinux.org/search?q=resterm
# Reference accessed: 2026-05-16

# Zsh completion for resterm — .http/.rest client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '*:request:_files -g "*.(http|rest)"' && ret=0

return ret
