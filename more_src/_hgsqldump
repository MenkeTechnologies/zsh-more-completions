#compdef hgsqldump
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: execute mysqldump using passwords from .hg.conf

local ret=1

_arguments -s -S \
  '--databases[dump several databases]' \
  '--all-databases[dump all databases]' \
  '*::mysqldump args and database:_default' && ret=0

return ret
