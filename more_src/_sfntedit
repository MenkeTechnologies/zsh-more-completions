#compdef sfntedit
# Documentation: https://adobe-type-tools.github.io/afdko/AFDKO-Overview.html
# AFDKO: edit tables within an sfnt-formatted font (OTF/TTF)

local ret=1

_arguments -s -S \
  '-x[extract table to file]:tag spec:' \
  '-d[delete table]:tag spec:' \
  '-a[add (or replace) table]:tag=file spec:' \
  '-l[list sfnt directory (default)]' \
  '-c[check checksums]' \
  '-f[fix checksums (implies -c)]' \
  '-X[execute command-lines from scriptfile]:scriptfile:_files' \
  '-u[print usage]' \
  '-h[print help]' \
  '*:font:_files' && ret=0

return ret
