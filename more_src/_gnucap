#compdef gnucap

# GNUCAP: GNU Circuit Analysis Package
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[verbose / show version]' \
  '-b[batch mode (no prompt)]' \
  '-i[run commands from file]:file:_files' \
  '-q[quiet (no banner)]' \
  '*:GNUCAP netlist file:_files' && ret=0
return ret
