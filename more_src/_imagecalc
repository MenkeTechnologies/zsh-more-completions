#compdef imagecalc
# Documentation: https://casacore.github.io/casacore/
# casacore: evaluate a casacore image expression

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage]' \
  'in=[input image or image expression]:image:_files' \
  'out=[output image name (optional)]:image:_files' \
  'hdf5=[output image in HDF5 format?]:bool:(T F)' \
  'debug=[debug level]:level' \
  '*:argument: ' && ret=0

return ret
