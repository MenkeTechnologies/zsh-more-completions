#compdef otbcli_LargeScaleMeanShift
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_LargeScaleMeanShift.html
# Orfeo ToolBox: chained Large-Scale Mean-Shift segmentation pipeline

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input single or multiband image]:image:_files' \
  '-spatialr[radius of spatial neighborhood for averaging]:value:' \
  '-ranger[threshold on spectral euclidean distance]:value:' \
  '-minsize[minimum segment size for merging]:value:' \
  '-tilesizex[size of tiles along X-axis]:value:' \
  '-tilesizey[size of tiles along Y-axis]:value:' \
  '-mode[type of segmented output]:mode:(vector raster)' \
  '-mode.vector.imfield[support image for field value computation]:image:_files' \
  '-mode.vector.out[output GIS vector file]:output:_files' \
  '-mode.raster.out[output raster image]:output:_files' \
  '-cleanup[clean all temporary files created]:bool:(true false)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
