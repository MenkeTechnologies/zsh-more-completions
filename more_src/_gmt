#compdef gmt
# Documentation: https://man.archlinux.org/search?q=gmt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a modules

modules=(
  'begin:start session'
  'end:end session'
  'figure:specify figure'
  'subplot:create matrix of panels'
  'inset:place inset'
  'clear:delete defaults/cache'
  'basemap:plot basemap'
  'coast:plot coastlines'
  'plot:plot data 2D'
  'plot3d:plot data 3D'
  'colorbar:plot colorbar'
  'contour:plot contours'
  'image:plot image'
  'text:plot text'
  'legend:plot legend'
  'logo:GMT logo'
  'histogram:histogram'
  'rose:rose plot'
  'wiggle:wiggle plot'
  'mask:plot mask'
  'clip:clip area'
  'solar:solar terminator'
  'ternary:ternary plot'
  'vector:plot vectors'
  'events:event plot'
  'movie:make movie'
  'batch:batch processing'
  'connect:connect points'
  'convert:convert tables'
  'defaults:show defaults'
  'set:set defaults'
  'get:get defaults'
  'gmt2kml:GMT to KML'
  'grd2cpt:grid to CPT'
  'grd2kml:grid to KML'
  'grd2xyz:grid to xyz'
  'grdblend:blend grids'
  'grdclip:clip grid'
  'grdcontour:grid contours'
  'grdconvert:convert grid'
  'grdcut:cut grid'
  'grdedit:edit grid'
  'grdfft:FFT on grid'
  'grdfill:fill NaNs'
  'grdfilter:filter grid'
  'grdgdal:GDAL on grid'
  'grdgradient:grid gradient'
  'grdhisteq:grid histogram equalize'
  'grdimage:plot grid as image'
  'grdinfo:grid info'
  'grdinterpolate:interpolate'
  'grdlandmask:land mask'
  'grdmask:grid mask'
  'grdmath:grid math'
  'grdmix:mix grids'
  'grdpaste:paste grids'
  'grdproject:project grid'
  'grdsample:resample grid'
  'grdselect:select grids'
  'grdtrack:sample grid'
  'grdtrend:fit trend'
  'grdvector:plot vectors'
  'grdview:plot 3D grid'
  'grdvolume:grid volume'
  'greenspline:Greens spline'
  'info:dataset info'
  'kml2gmt:KML to GMT'
  'makecpt:make CPT'
  'mapproject:projections'
  'math:table math'
  'nearneighbor:nearest neighbor'
  'project:project'
  'psconvert:PS to other'
  'regress:regression'
  'sample1d:sample 1D'
  'select:select records'
  'simplify:simplify lines'
  'spatial:spatial ops'
  'spectrum1d:1D spectrum'
  'sph2grd:sphere to grid'
  'sphdistance:sphere distance'
  'sphinterpolate:sphere interp'
  'sphtriangulate:sphere triangulate'
  'split:split tables'
  'surface:surface fit'
  'trend1d:1D trend'
  'trend2d:2D trend'
  'triangulate:triangulate'
  'which:locate file'
  'xyz2grd:xyz to grid'
  'docs:open module docs'
  'binstats:bin stats'
  'blockmean:block mean'
  'blockmedian:block median'
  'blockmode:block mode'
  'dimfilter:dim filter'
  'filter1d:1D filter'
  'fitcircle:fit circle'
  'pscoast:classic coast'
  'psxy:classic plot'
  'psbasemap:classic basemap'
  'gmtinfo:classic info'
  'gmtmath:classic math'
  'gmtset:classic set'
  'gmtselect:classic select'
)

_arguments -C \
  '--help[list modules]' \
  '--new-script=[script template]:lang:' \
  '--new-glue=[glue file]:name:' \
  '--show-bindir[show bin dir]' \
  '--show-citation[show citation]' \
  '--show-classic[list classic names]' \
  '--show-classic-core[list classic core]' \
  '--show-cores[show CPUs]' \
  '--show-date[show build date]' \
  '--show-datadir[show data dirs]' \
  '--show-dataserver[show data server URL]' \
  '--show-dcw[DCW version]' \
  '--show-doi[show DOI]' \
  '--show-gshhg[GSHHG version]' \
  '--show-modules[list modules]' \
  '--show-modules-core[list core modules]' \
  '--show-library[library path]' \
  '--show-plugindir[plugin dir]' \
  '--show-sharedir[share dir]' \
  '--show-userdir[user dir]' \
  '--version[show version]' \
  '1: :->module' \
  '*::arg:->args' && ret=0

case $state in
  (module) _describe -t modules 'gmt module' modules && ret=0 ;;
  (args) _arguments '*:arg:_files' && ret=0 ;;
esac

return ret
