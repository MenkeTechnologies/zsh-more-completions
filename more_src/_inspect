#compdef inspect
# Documentation: https://github.com/UKGovernmentBEIS/inspect_ai
# Reference accessed: 2026-05-22
# Verified: inspect --help (inspect-ai PyPI package).

# Zsh completion for inspect - UK AI Safety Institute Inspect eval CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show Inspect version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'inspect command' \
      'eval[evaluate tasks]' \
      'eval-set[evaluate a set of tasks with retries]' \
      'eval-retry[retry failed evaluations]' \
      'list[list tasks on filesystem]' \
      'view[open Inspect log viewer]' \
      'log[query read and convert logs]' \
      'score[score a previous evaluation run]' \
      'trace[list and read execution traces]' \
      'cache[manage model output cache]' \
      'sandbox[manage sandbox environments]' \
      'info[read configuration and log info]' && ret=0
    ;;
esac

return ret
