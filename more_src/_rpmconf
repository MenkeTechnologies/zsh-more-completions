#compdef rpmconf
# Documentation: https://github.com/xsuchy/rpmconf/blob/master/bin/rpmconf
# Reference accessed: 2026-05-21
# Verified: upstream argparse source in xsuchy/rpmconf bin/rpmconf.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-a --all)'{-a,--all}'[check configuration files of all packages]' \
  '(-c --clean)'{-c,--clean}'[find and delete orphaned .rpmnew/.rpmsave files]' \
  '(-d --debug)'{-d,--debug}'[dry run; show which file will be deleted]' \
  '(-D --diff)'{-D,--diff}'[non-interactive diff mode (use with -a or -o)]' \
  '(-f --frontend)'{-f+,--frontend=}'[merge frontend editor]:editor:(vimdiff gvimdiff diffuse kdiff3 meld sdiff env)' \
  '--root=[alternative installroot]:dir:_files -/' \
  '(-t --test)'{-t,--test}'[test if any merge files exist; exit 0 if none]' \
  '-Z[display SELinux context of old and new file]' \
  '(-o --owner)'{-o,--owner}'[check only configuration files of given package(s)]:*:package:' \
  '(-u --unattended)'{-u,--unattended=}'[unattended mode]:mode:(use_maintainer use_your default)' \
  '(-V --version)'{-V,--version}'[display rpmconf version]' \
  '(-x --exclude)'{-x,--exclude}'[exclude directory (applies only with -c)]:*:dir:_files -/' && ret=0

return ret
