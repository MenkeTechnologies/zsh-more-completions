#compdef rpmconf
# Documentation: https://man.archlinux.org/search?q=rpmconf
# Reference accessed: 2026-05-16

_arguments -s \
  '(-a --all)'{-a,--all}'[check all packages]' \
  '(-o --owner)'{-o,--owner=}'[examine one package]:package:' \
  '(-f --frontend)'{-f,--frontend=}'[merge frontend]:type:(vimdiff gvimdiff diffuse kdiff3 meld sdiff env)' \
  '(-c --clean)'{-c,--clean}'[find rpmnew/rpmsave]' \
  '(-d --debug)'{-d,--debug}'[dry run]' \
  '(-D --diff)'{-D,--diff}'[diff mode]' \
  '--root=[install root]:dir:_files -/' \
  '(-t --test)'{-t,--test}'[test only]' \
  '(-u --unattended)'{-u,--unattended=}'[unattended mode]:mode:' \
  '(- *)'{-V,--version}'[show version]' \
  '(-x --exclude)'{-x,--exclude=}'[exclude directory]:dir:_files -/' \
  '-Z[show SELinux contexts]'
