#compdef mergiraf

_mergiraf_commands() {
  local -a commands=(
    'merge:Merge three files using structured merge'
    'resolve:Attempt to resolve conflicts'
    'diff:Structured diff between two files'
    'languages:List supported languages'
    'install:Install as Git merge driver'
    'completions:Generate shell completions'
    'help:Show help'
  )
  _describe -t commands 'mergiraf command' commands
}

_mergiraf() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-V --version)'{-V,--version}'[Print version]' \
    '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
    '1:command:_mergiraf_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        merge)
          _arguments \
            '(-s --style)'{-s,--style}'[Conflict marker style]:style:(diff3 merge)' \
            '(-x --compact)'{-x,--compact}'[Compact output]' \
            '1:base file:_files' \
            '2:left file:_files' \
            '3:right file:_files' \
            '4:merged output:_files'
          ;;
        resolve)
          _arguments \
            '(-s --style)'{-s,--style}'[Conflict marker style]:style:(diff3 merge)' \
            '1:file with conflicts:_files'
          ;;
        diff)
          _arguments \
            '1:file A:_files' \
            '2:file B:_files'
          ;;
        install)
          _arguments \
            '--global[Install globally]'
          ;;
        completions)
          _arguments '1:shell:(bash zsh fish elvish powershell)'
          ;;
      esac
      ;;
  esac
}

_mergiraf "$@"
