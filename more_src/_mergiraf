#compdef mergiraf
# Documentation: https://mergiraf.org/usage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_mergiraf_commands() {
  local -a commands=(
    'merge:Merge three files using structured merge'
    'solve:Attempt to solve conflicts in a conflicted file'
    'review:Review a previous mergiraf merge by id'
    'report:Generate a diagnostic archive for bug reporting'
    'languages:List supported languages'
    'completions:Generate shell completions'
    'help:Show help'
  )
  _describe -t commands 'mergiraf command' commands
}

_mergiraf() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-V --version)'{-V,--version}'[Print version]' \
    '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
    '1:command:_mergiraf_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        merge)
          _arguments \
            '--git[Git merge driver mode]' \
            '(-L --language)'{-L,--language}'[Specify file language]:lang:' \
            '--allow-parse-errors[merge despite syntax errors]' \
            '(-c --compact)'{-c,--compact}'[compact conflict presentation]' \
            '1:base file:_files' \
            '2:left file:_files' \
            '3:right file:_files' \
            '4:merged output:_files'
          ;;
        solve)
          _arguments \
            '(-s --style)'{-s,--style}'[Conflict marker style]:style:(diff3 merge)' \
            '1:file with conflicts:_files'
          ;;
        review)
          _arguments '1:merge id:'
          ;;
        report)
          _arguments '*:: :_files'
          ;;
        languages)
          _arguments '--gitattributes[output in gitattributes format]'
          ;;
        diff)
          _arguments \
            '1:file A:_files' \
            '2:file B:_files'
          ;;
        completions)
          _arguments '1:shell:(bash zsh fish elvish powershell)'
          ;;
      esac
      ;;
  esac
}

_mergiraf "$@"
