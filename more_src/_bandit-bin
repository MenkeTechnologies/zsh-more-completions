#compdef bandit
# _bandit-bin — Bandit Python security linter (PyCQA, Python); scan Python source for common security issues
# upstream: https://github.com/PyCQA/bandit

_bandit-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-r --recursive)'{-r,--recursive}'[recursive]' \
        '(-a --aggregate)'{-a,--aggregate}'+[aggregate]:agg:(file vuln)' \
        '(-n --number)'{-n,--number}'+[context lines]:n:' \
        '(-c --configfile)'{-c,--configfile}'+[config file]:file:_files' \
        '(-p --profile)'{-p,--profile}'+[profile]:profile:' \
        '(-t --tests)'{-t,--tests}'+[tests to run]:tests:' \
        '(-s --skip)'{-s,--skip}'+[tests to skip]:tests:' \
        '(-l --level)'{-l,--level}'+[severity threshold]:level:(low medium high)' \
        '-ll[shorthand for --level medium]' \
        '-lll[shorthand for --level high]' \
        '(-i --confidence)'{-i,--confidence}'+[confidence threshold]:level:(low medium high)' \
        '-ii[shorthand --confidence medium]' \
        '-iii[shorthand --confidence high]' \
        '(-f --format)'{-f,--format}'+[output format]:fmt:(csv custom html json screen txt xml yaml)' \
        '--msg-template+[message template]:str:' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '(-q --quiet --silent)'{-q,--quiet,--silent}'[quiet]' \
        '--ignore-nosec[ignore nosec comments]' \
        '(-x --exclude)'{-x,--exclude}'+[exclude paths]:paths:' \
        '-b+[baseline file]:file:_files' \
        '--baseline+[baseline file]:file:_files' \
        '--ini+[ini file]:file:_files' \
        '--exit-zero[exit zero even on findings]' \
        '*:target:_files'
}

_bandit-bin "$@"
