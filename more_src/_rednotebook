#compdef rednotebook
# Documentation: https://manpages.debian.org/bookworm/rednotebook/rednotebook.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm rednotebook(1) manpage OPTIONS.
# Removed from prior file: fabricated -V flag (uses --version only) and
# bogus man.archlinux.org search URL.

# rednotebook: Python-based personal journal
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--date=[open on specified date (YYYY-MM-DD)]:date:' \
  '*:journal path:_files -/' && ret=0
return ret
