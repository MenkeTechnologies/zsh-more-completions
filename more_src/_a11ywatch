#compdef a11ywatch
# Documentation: https://github.com/a11ywatch/a11ywatch
# Reference accessed: 2026-05-23
# Verified: upstream cli/README.md (a11ywatch_cli / a11ywatch-cli npm).

# Zsh completion for a11ywatch - web accessibility automation CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build A11yWatch Lite locally'
  'crawl:site-wide scan a website for issues'
  'extract:extract results for platforms'
  'scan:single-page scan a website for issues'
  'start:start A11yWatch Lite locally'
  'stop:stop A11yWatch Lite locally'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --clear-token)'{-c,--clear-token}'[clear API token]' \
  '--clear-cv-token[clear Computer Vision API token]' \
  '--clear-recording[clear recording directory setting]' \
  '(-f --find-results)'{-f,--find-results}'[log file results path]:path:_files' \
  '--find-tmp-dir[get tmp directory location]' \
  '(-g --github-api-url)'{-g,--github-api-url=}'[GitHub API endpoint]:url:' \
  '--github-results-path=[GitHub results path]:path:_files' \
  '(-r --results-parsed-list)'{-r,--results-parsed-list}'[parsed report list]' \
  '(-R --results-parsed)'{-R,--results-parsed}'[parsed results JSON]' \
  '--results-issues[total issue counts]' \
  '--results-issues-errors[error issue count]' \
  '--results-issues-warnings[warning issue count]' \
  '--results-parsed-github[GitHub HTML message results]' \
  '(-s --set-token)'{-s+,--set-token=}'[set API token]:token:' \
  '--set-cv-token=[set Computer Vision API token]:token:' \
  '--set-cv-url=[set Computer Vision API URL]:url:' \
  '--set-recording=[enable recordings directory]:dir:_directories' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'a11ywatch command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan|crawl)
        _arguments \
          '--url=[URL to scan]:url:' \
          '--fix[attempt to fix code from recommendations]' \
          '--save[save results to disk]' \
          '--csv[save results as CSV]' \
          '-S[include subdomains]' \
          '-t[include all TLD extensions]' \
          '-d[detailed output]' \
          '-n[no color]' \
          '-s[summary output]' && ret=0 ;;
      (start)
        _arguments \
          '(-f)'{-f}'[start with front-end client]' \
          '--local[start via nodejs monolith]' \
          '--standalone[use monolith in docker]' \
          '--upgrade[upgrade instance images]' && ret=0 ;;
      (build|stop|extract)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
