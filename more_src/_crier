#compdef crier
# _crier — Prow component that reports ProwJob status to GitHub/Slack/Gerrit/etc (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/crier/main.go (flag).

_crier() {
    _arguments \
        '-cookiefile=[git http.cookiefile path]:file:_files' \
        '-gerrit-workers=[number of Gerrit report workers]:n:' \
        '-pubsub-workers=[number of pubsub report workers]:n:' \
        '-github-workers=[number of GitHub report workers]:n:' \
        '-slack-workers=[number of Slack report workers]:n:' \
        '*-additional-slack-token-files=[additional Slack token file (key=path)]:kv:' \
        '-blob-storage-workers=[number of blob-storage report workers]:n:' \
        '-kubernetes-blob-storage-workers=[k8s blob-storage report workers]:n:' \
        '-kubernetes-report-fraction=[fraction of jobs to report pod info]:f:' \
        '-slack-token-file=[Slack token file]:file:_files' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files'
}

_crier "$@"
