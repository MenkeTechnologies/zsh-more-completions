#compdef olm-cli olmctl
# _olm-cli — Operator Framework olm-cli olmctl CLI command-line frontend wrapping the Operator Lifecycle Manager OLM Kubernetes-native operator-package-installation-upgrade-management providing operatorgroup catalogsource subscription installplan clusterserviceversion-CSV-bundle-channel-policy-dependency-resolver-stable-fast-alpha installation (Operator Framework team, Go); cobra
# upstream: https://olm.operatorframework.io/

_olm-cli() {
    local -a sub=(
        'install:install OLM into cluster'
        'uninstall:uninstall OLM'
        'list:list installed operators'
        'install-operator:install operator from a CatalogSource'
        'uninstall-operator:uninstall an installed operator'
        'subscriptions:subscription management'
        'catalogsources:CatalogSource management'
        'operatorgroups:OperatorGroup management'
        'installplans:InstallPlan management'
        'csv:ClusterServiceVersion management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--channel=+[name]:str:' \
        '--catalog=+[name]:str:' \
        '--source-namespace=+[ns]:str:' \
        '--install-mode=+[m]:m:(OwnNamespace SingleNamespace MultiNamespace AllNamespaces)' \
        '--approval=+[a]:a:(Automatic Manual)' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'olm-cli subcommand' sub ;;
        args)
            case $words[1] in
                install-operator|uninstall-operator) _arguments '*:package name:' ;;
                subscriptions|catalogsources|operatorgroups|installplans|csv) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_olm-cli "$@"
