#compdef catdcd
# Documentation: https://www.ks.uiuc.edu/Development/MDTools/catdcd/
# CatDCD - concatenate, slice and convert molecular-dynamics trajectory files

local ret=1

_arguments -s -S \
  '-o[output file]:output file:_files' \
  '-otype[output file type]:type:(pdb dcd trr crd crdbox namdbin binpos rst7 xyz pqr)' \
  '-s[structure file]:structure file:_files' \
  '-stype[structure file type]:type:(pdb dcd trr crd crdbox namdbin binpos rst7 xyz pqr psf)' \
  '-i[index file of zero-based atom indices]:index file:_files' \
  '-first[first frame to write]:first frame:' \
  '-last[last frame to write]:last frame:' \
  '-stride[number of frames to skip]:stride:' \
  '-num[print frame counts only, write no output]' \
  '*:input trajectory:_files' && ret=0

return ret
