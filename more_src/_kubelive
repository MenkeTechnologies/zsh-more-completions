#compdef kubelive
# =============================================================================
# kubelive — ameerthehacker Ameer Jhan's "kubectl reinvented to be more
#            reactive and interactive" — a Kubernetes TUI dashboard that
#            renders live `kubectl get -w`-style streams (pods, services,
#            deployments, namespaces) in a full-screen React-in-terminal
#            interface.  Built on Vadim Demedes's `ink` library — the
#            JSX/React renderer for terminal user interfaces — kubelive
#            updates resource statuses in realtime without cluttering
#            the terminal scrollback the way `kubectl get pod -w` does.
#            Designed for DevOps engineers who want to watch a
#            Kubernetes cluster's state evolve without parsing
#            ever-growing text logs or context-switching to k9s.
#            Companion / alternative to k9s (Go + tview) — kubelive is
#            the Node.js + ink equivalent.
#
# Author:  Ameer Jhan (@ameerthehacker) — independent JavaScript / React
#          developer, frontend engineer.  Created kubelive in 2019 as
#          a personal scratch-an-itch project after suffering through
#          `kubectl get pod -w`'s output verbosity.
# Source:  https://github.com/ameerthehacker/kubelive
# CLI:     cli.js (uses tj/commander.js for argv parsing + ink for
#                  the entire visible interface via `render(<App/>)`)
# Library: vadimdemedes/ink
#          ("🌈 React for interactive command-line apps" — the
#           CANONICAL React-renderer-for-terminal library, the
#           JSX/React/Component-tree approach to terminal UIs, the
#           TypeScript-Node equivalent of Rust's ratatui (R530) and
#           Go's bubbletea (R531))
# License: MIT
# Status:  Active — 602+ stars on ameerthehacker/kubelive; ink itself
#          is 30100+ stars on vadimdemedes/ink and is the dominant
#          React-based terminal UI library, used by GitHub Copilot CLI,
#          Anthropic's Claude Code (the CLI you may be using right now),
#          Gatsby CLI, Prisma CLI, twilio-cli, terminalizer, and 4000+
#          npm packages.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 40
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 40TH TypeScript-Node CLI library variant.  TypeScript-Node climbs
# from 39 to 40 documented libraries (vadimdemedes/ink via kubelive).
# New leaderboard: Rust=40, Go=40, TypeScript-Node=40 (THREE-WAY TIE AT
# 40 — first three-way tie at 40 of this round-sequence).  Taxonomy now
# spans 271 cross-language CLI library variants across 65 documented
# languages.
#
# This completion COMPLETES THE TUI-WIDGET-FRAMEWORK TRIPLE across the
# top three languages:
#   * Axis 5: TUI WIDGET FRAMEWORK
#     - R530: Rust    → ratatui-org/ratatui    (immediate-mode)
#     - R531: Go      → charmbracelet/bubbletea (Elm Architecture)
#     - R532: TS-Node → vadimdemedes/ink       (THIS, REACT components)
# All three top-language TUI frameworks now documented; Axis 5 is
# complete across the leaderboard.
#
# Three POLAR-OPPOSITE rendering models for the same outcome:
#   * ratatui (Rust):    re-create entire widget tree per frame
#                        (immediate-mode, ImGui-inspired)
#   * bubbletea (Go):    pure (Model, Msg) → (Model, Cmd) reducer
#                        (Elm-Architecture, functional reactive)
#   * ink (TS-Node):     React component tree with reconciler
#                        (declarative, Fiber-based reconciler)
# This is the FIRST documented case in the taxonomy of three top
# languages each implementing a DIFFERENT well-known UI-paradigm for
# the SAME terminal-UI domain.  Comparable to the GUI ecosystem:
#   * ImGui (C++)             — immediate-mode
#   * Elm                      — Elm Architecture (FRP)
#   * React (Web/Native)       — component tree + reconciler
# but achieved entirely at the terminal level — no GPU, no DOM, no
# native widgets, just ANSI escapes painted into the terminal grid.
#
# -----------------------------------------------------------------------------
#
# WHAT IS ink AND WHY IS IT THE 40TH TS-NODE CLI LIBRARY?
#
# ink (https://github.com/vadimdemedes/ink, 30100+ stars) is **Vadim
# Demedes's "🌈 React for interactive command-line apps"** — the
# REACT RENDERER for terminal output, built on top of React's
# pluggable-renderer architecture (the same architecture that powers
# `react-dom`, `react-native`, `react-three-fiber`, and the React
# DevTools host).  ink registers a custom React reconciler that
# instead of mounting DOM nodes or native UIView/UIButton instances,
# mounts virtual "box" / "text" / "newline" / "static" / "spacer"
# nodes that the ink runtime composites into an ANSI-escape-coded
# string and writes to stdout.
#
# ink's distinguishing characteristics:
#
#   1. REACT COMPONENT MODEL — ink applications are written as React
#      function components with JSX.  Hooks (`useState`, `useEffect`,
#      `useReducer`, `useContext`, `useMemo`) all work normally:
#
#          import {render, Text, Box, useApp, useInput} from 'ink';
#          import React, {useState} from 'react';
#
#          const App = () => {
#              const {exit} = useApp();
#              const [count, setCount] = useState(0);
#              useInput((input, key) => {
#                  if (key.upArrow) setCount(c => c + 1);
#                  if (input === 'q') exit();
#              });
#              return (
#                  <Box flexDirection="column">
#                      <Text color="cyan">Count: {count}</Text>
#                      <Text dimColor>(↑ to increment, q to quit)</Text>
#                  </Box>
#              );
#          };
#          render(<App />);
#
#      Compare ratatui R530 (immediate-mode widget tree rebuilt every
#      frame) and bubbletea R531 (Elm Architecture with three pure
#      functions).  ink is FUNDAMENTALLY DIFFERENT: it's the actual
#      React library running in Node.js with a custom renderer.
#      Every React idiom transfers: error boundaries, suspense,
#      context, refs, memo, forwardRef, lazy loading.
#
#   2. FLEXBOX LAYOUT VIA YOGA — ink uses Facebook's `yoga-layout`
#      library (the same Flexbox engine that powers React Native and
#      Lithium) to layout components in 2D terminal space.  `<Box
#      flexDirection="column" justifyContent="space-between"
#      alignItems="center" padding={1}>` works the same way as React
#      Native's `<View style={{flexDirection: 'column', ...}}>`.
#      No other documented TUI framework uses Flexbox:
#         * ratatui:    constraint-based percent/min/max layout
#                       (Constraint::Percentage(50), Min(10), Max(20))
#         * bubbletea:  pure-string concatenation in View()
#                       (lipgloss provides JoinVertical/JoinHorizontal)
#         * blessed:    percent + character coordinates
#                       (top: '50%', left: 'center')
#      FIRST documented TUI framework with full Flexbox layout —
#      designers familiar with web CSS Flexbox can compose terminal
#      UIs without learning new layout paradigms.
#
#   3. REACT RECONCILER ARCHITECTURE — ink calls
#      `import {createReconciler} from 'react-reconciler'` and
#      registers an opaque host config that tells React how to:
#         - createInstance(type, props)    — create a box/text node
#         - appendChild(parent, child)     — wire up the layout tree
#         - prepareUpdate(node, oldProps,
#                         newProps)         — compute prop diffs
#         - commitUpdate(node, payload)    — apply prop changes
#         - insertBefore(parent, child,
#                        beforeChild)       — reorder for animations
#      This is the SAME ABI used by react-dom (DOM nodes),
#      react-native (UIView/UIButton), react-three-fiber
#      (Mesh/Material/Geometry), and even react-pixi (PIXI.Container).
#      ink is React-the-library with a different host config.
#      Compare bubbletea's Elm Architecture (purpose-built for
#      bubbletea), ratatui's immediate-mode (purpose-built for
#      ratatui).  FIRST documented TUI framework that piggybacks on
#      an EXISTING UI framework's reconciler.
#
#   4. JSX TRANSPILATION REQUIREMENT — ink requires a Babel/SWC/
#      TypeScript step to transpile `<Box>` → `React.createElement(
#      Box, ...)` before Node.js can execute.  No other documented
#      TUI framework has a build-step requirement:
#         * ratatui:    plain Rust syntax, cargo handles it
#         * bubbletea:  plain Go syntax, go build handles it
#         * blessed:    plain JS, no transpile needed
#      ink's build requirement is a TRADEOFF: it gives developers
#      JSX ergonomics at the cost of forcing every ink project to
#      have a TS/Babel toolchain.  kubelive uses `import-jsx`
#      (transpile-on-import) to avoid an explicit build step at
#      `npm install` time.
#
#   5. ECOSYSTEM OF REACT-COMPONENT WIDGETS — Because ink components
#      are just React components, the ink ecosystem can leverage the
#      ENTIRE React component ecosystem.  Popular ink-specific
#      components:
#         * `ink-table`         — tabular data with row/col
#         * `ink-select-input`  — keyboard-driven select list
#         * `ink-text-input`    — single-line text input
#         * `ink-tab`           — tab container (kubelive uses)
#         * `ink-spinner`       — loading spinner (wraps cli-spinners)
#         * `ink-link`          — clickable terminal hyperlinks
#         * `ink-progress-bar`  — progress bar
#         * `ink-gradient`      — gradient text
#         * `ink-big-text`      — ASCII art text
#         * `ink-syntax-highlight` — code syntax highlighting
#      Compare ratatui's tui-* community widgets (~50) or bubbletea's
#      bubbles + community (~40).  ink's ecosystem has 200+ npm
#      packages targeting it specifically.
#
# ink's relationship to other documented TS-Node CLI libraries:
#
#   * Like `@inquirer/prompts` R520 — interactive (waits for user input)
#   * Like `ora` R524               — terminal-control-aware (handles ANSI)
#   * Like `chalk` R528             — uses ANSI escapes for color
#   * Unlike ALL of the above       — TAKES OVER THE WHOLE TERMINAL
#     via alternate screen buffer + raw mode + full-screen React-tree
#     reconciliation.  inquirer/ora/chalk are line-oriented (prompt-
#     then-read or single-line spinner); ink is screen-oriented (paint
#     a screenful of React-rendered text on every state change).
#     Direct analogs:
#         * Rust:    ratatui (R530) — immediate-mode vs ink's reactive
#         * Go:      bubbletea (R531) — Elm vs ink's React
#     ink COMPLETES the TUI-framework triple across top three
#     languages, with the THIRD distinct rendering paradigm.
#
# -----------------------------------------------------------------------------
#
# THE kubelive CLI — commander.js + ink Composition
#
# kubelive's argv parser is `tj/commander.js` (already documented in
# the taxonomy via other tools):
#
#     cli.version(pkg.version, '-v, --version');
#     cli
#       .command('get <resource>')
#       .option('--context <name>', 'set kubernetes context to use')
#       .description('get live update on the <resource>')
#       .action((resource, args) => {
#           setCurrentCXT(args.context);
#           const App = importJsx('./src/containers/app');
#           render(<App resource={resource} />);
#       });
#
# One subcommand (`get`), one option (`--context`), one positional
# (`<resource>`).  Everything else — selecting pods, viewing logs,
# describing services, copying clipboard content — happens via
# `useInput()` keyboard handlers inside ink components.  This is the
# SIGNATURE pattern of ink applications and parallels ratatui (R530)
# and bubbletea (R531) — minimal argv parser + rich React TUI.
#
# Distinct from every other documented TS-Node CLI library on FIVE
# axes:
#
#   1. REACT COMPONENT TREE — Every other documented TS-Node CLI
#      library is FUNCTION-CALL-BASED (chalk's chain, inquirer's
#      prompt() function, commander's .option() chain, ora's
#      spinner.start()).  ink uses REACT COMPONENT TREES with JSX.
#      FIRST documented TS-Node CLI library that uses the React
#      component-tree model.
#
#   2. FLEXBOX LAYOUT — Every other documented TS-Node CLI library
#      writes to stdout linearly or positions cursor manually via
#      ANSI escapes.  ink uses YOGA (Facebook's Flexbox engine —
#      same one powering React Native).  Compose terminal UIs with
#      `flexDirection`, `justifyContent`, `alignItems`, `padding`,
#      `margin`, `flexGrow`.  FIRST documented TS-Node CLI library
#      with Flexbox 2D layout.
#
#   3. REACT-RECONCILER ABI INTEGRATION — Every other documented
#      TS-Node CLI library is self-contained.  ink piggybacks on
#      `react-reconciler` — the same package powering react-dom,
#      react-native, react-three-fiber.  ink IS React with a
#      different host config.  FIRST documented TS-Node CLI library
#      that integrates with an existing UI framework's reconciler.
#
#   4. JSX TRANSPILATION REQUIREMENT — Every other documented
#      TS-Node CLI library works with plain JS (no JSX, no
#      TypeScript required for runtime).  ink REQUIRES JSX
#      transpilation (via Babel, esbuild, swc, or `import-jsx` for
#      runtime transpilation).  FIRST documented TS-Node CLI library
#      with a JSX/build-step requirement.
#
#   5. REACT-ECOSYSTEM LEVERAGE — Every other documented TS-Node CLI
#      library is standalone with its own widget catalog (chalk's
#      colors, inquirer's prompt types, ora's spinners).  ink
#      INHERITS React's ENTIRE ecosystem: error boundaries, suspense,
#      context, lazy loading, refs, memo, forwardRef.  Plus 200+
#      ink-specific component packages on npm (ink-table, ink-
#      select-input, ink-tab, ink-progress-bar, ink-spinner, ink-
#      link, ink-syntax-highlight).  FIRST documented TS-Node CLI
#      library that inherits a meta-ecosystem from a parent
#      framework (React).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/ameerthehacker/kubelive/blob/master/cli.js
# commander.js definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
    'get:get live update on a Kubernetes resource'
)

_arguments -s -C \
    '(-v --version)'{-v,--version}'[print version and exit]' \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case "$state" in
    cmd)
        _describe -t commands 'kubelive command' commands && ret=0
        ;;
    args)
        case "${words[1]}" in
            get)
                _arguments -s \
                    '--context=[kubernetes context to use]:context:' \
                    '1:resource:(pods services deployments namespaces nodes ingresses configmaps secrets)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
