#compdef process_climate_indices
# Documentation: https://github.com/monocongo/climate_indices/blob/master/src/climate_indices/__main__.py
# climate-indices: compute SPI, SPEI, PNP, PET and Palmer drought indices

local ret=1

_arguments -s -S \
  '--index[climate index to compute]:index:(spi spei pnp scaled pet palmers all)' \
  '--periodicity[periodicity of input dataset]:periodicity:(monthly daily)' \
  '*--scales[timestep scales to compute]:scale:' \
  '--calibration_start_year[calibration period start year]:year:' \
  '--calibration_end_year[calibration period end year]:year:' \
  '--netcdf_precip[input precipitation NetCDF file]:file:_files' \
  '--var_name_precip[precipitation variable name]:varname:' \
  '--netcdf_temp[input temperature NetCDF file]:file:_files' \
  '--var_name_temp[temperature variable name]:varname:' \
  '--netcdf_pet[input PET NetCDF file]:file:_files' \
  '--var_name_pet[PET variable name]:varname:' \
  '--netcdf_awc[input available water capacity NetCDF file]:file:_files' \
  '--var_name_awc[AWC variable name]:varname:' \
  '--output_file_base[base file path for outputs]:file:_files' \
  '--multiprocessing[number of worker processes]:mode:(single all_but_one all)' \
  '--chunksizes[output NetCDF chunk sizing]:chunks:(none input)' \
  '*:file:_files' && ret=0

return ret
