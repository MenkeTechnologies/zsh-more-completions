#compdef FileConverter
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: convert between MS file formats

local ret=1

_arguments -s -S \
  '-in[input file]:input file:_files' \
  '-in_type[input file type]:type:' \
  '-out[output file]:output file:_files' \
  '-out_type[output file type]:type:' \
  '-UID_postprocessing[unique ID handling]:mode:(none ensure reassign)' \
  '-TIC_DTA2D[export TIC instead of full experiment for DTA2D]' \
  '-MGF_compact[use compact MGF format without zero-intensity peaks]' \
  '-force_MaxQuant_compatibility[ensure MaxQuant compatibility in mzXML output]' \
  '-force_TPP_compatibility[ensure TPP parser compatibility in mzML output]' \
  '-convert_to_chromatograms[transform spectra to chromatogram data]' \
  '-write_scan_index[append index when writing mzML/mzXML]' \
  '-lossy_compression[apply numpress compression for smaller files]' \
  '-lossy_mass_accuracy[desired m/z accuracy for lossy compression]:accuracy:' \
  '-process_lowmemory[process without loading entire dataset into memory]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
