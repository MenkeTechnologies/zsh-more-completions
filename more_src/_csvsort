#compdef csvsort

# Zsh completion for csvsort (csvkit)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiting character]:delimiter:' \
  '(-t --tabs)'{-t,--tabs}'[specify that input is tab-delimited]' \
  '(-q --quotechar)'{-q,--quotechar}'[character for quoting]:char:' \
  '(-u --quoting)'{-u,--quoting}'[quoting style]:style:(0 1 2 3)' \
  '(-e --encoding)'{-e,--encoding}'[input encoding]:encoding:' \
  '(-H --no-header-row)'{-H,--no-header-row}'[no header row in input]' \
  '(-K --no-inference)'{-K,--no-inference}'[disable type inference]' \
  '(-n --names)'{-n,--names}'[print column names]' \
  '(-c --columns)'{-c,--columns}'[columns to sort by]:columns:' \
  '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
  '--no-locale[do not use locale-aware sorting]' \
  '(-y --snifflimit)'{-y,--snifflimit}'[limit CSV dialect sniffing]:bytes:' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:csv file:_files -g "*.csv *.tsv"' && return 0
