#compdef pamtilt
# Documentation: man pamtilt (Netpbm)
# Source: Netpbm pamtilt — print the tilt angle of a PGM file (for de-skewing).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-angle=[max angle to search (deg)]:maxangle:' \
    '-fast[use fast (lower-quality) search]' \
    '-quality=[search quality level]:q:' \
    '-hstep=[horizontal step]:n:' \
    '-vstep=[vertical step]:n:' \
    '-dstep=[depth step]:n:' \
    '-astep=[angle step]:n:' \
    '-verbose[print iteration progress]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:PGM file:_files -g "*.{pgm,pam,pnm}"' \
    && ret=0

return ret
