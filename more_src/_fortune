#compdef fortune

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-a[choose from all lists, including offensive]' \
  '-f[print list of files used]' \
  '-i[ignore case for -m pattern]' \
  '-l[long quotations only]' \
  '-o[choose offensive fortunes only]' \
  '-s[short quotations only]' \
  '-w[wait, scaled by length, before exit]' \
  '-m+[print fortunes matching regex pattern]:pattern:' \
  '-n+[max length to consider short]:n:' \
  '*:file/directory/all:_files' && ret=0

return ret
