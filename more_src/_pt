#compdef pt

local -a arguments

arguments=(
  '--after=[show NUM lines after match]:lines:'
  '--before=[show NUM lines before match]:lines:'
  '--context=[show NUM lines before and after match]:lines:'
  '--color[colorize output]'
  '--nocolor[disable colorized output]'
  '--color-line-number=[color for line numbers]:color:'
  '--color-match=[color for matches]:color:'
  '--color-path=[color for paths]:color:'
  '--column[show column numbers]'
  '(-c --count)'{-c,--count}'[only print count of matching lines per file]'
  '(-e --regexp)'{-e,--regexp}'=[pattern to match]:pattern:'
  '--depth=[max directory depth to search]:depth:'
  '(-f --file-search-regexp)'{-f,--file-search-regexp}'=[only search files matching pattern]:pattern:'
  '(-l --files-with-matches)'{-l,--files-with-matches}'[only print filenames containing matches]'
  '--follow[follow symlinks]'
  '(-g --file-search-regexp)'{-g,--file-search-regexp}'=[only search files matching pattern]:pattern:'
  '--global-gitignore[use global .gitignore]'
  '--group[group matches by file]'
  '--nogroup[do not group matches by file]'
  '--hidden[search hidden files and directories]'
  '--home-ptignore[use ~/.ptignore]'
  '--ignore=[ignore files/directories matching pattern]:pattern:'
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive search]'
  '(-S --smart-case)'{-S,--smart-case}'[smart case search]'
  '--numbers[show line numbers]'
  '--nonumbers[do not show line numbers]'
  '(-o --output-encode)'{-o,--output-encode}'=[output encoding]:encoding:'
  '--skip-vcs-ignores[do not skip VCS ignore files]'
  '(-w --word-regexp)'{-w,--word-regexp}'[match whole words only]'
  '(-h --help)'{-h,--help}'[show help message]'
  '--version[show version information]'
  '1:pattern:'
  '*:path:_files'
)

_arguments -s -S $arguments
