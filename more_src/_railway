#compdef railway

# Zsh completion for Railway CLI

_railway() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'add:add a service to your project'
    'completion:generate shell completion'
    'connect:connect to a service database'
    'deploy:deploy a template into your project'
    'domain:add a custom domain or generate a Railway domain'
    'docs:open Railway documentation'
    'down:remove the most recent deployment'
    'environment:change which environment you are using'
    'init:create a new Railway project'
    'link:associate existing project with current directory'
    'list:list all projects'
    'login:login to Railway'
    'logout:logout of Railway'
    'logs:view logs for a deployment'
    'open:open your project dashboard'
    'redeploy:redeploy the latest deployment'
    'run:run a local command using variables from the active environment'
    'service:link to an existing service'
    'shell:open a local subshell with Railway variables'
    'status:show information about the current project'
    'unlink:disassociate project from current directory'
    'up:deploy the current directory'
    'variables:show or manage environment variables'
    'volume:manage volumes'
    'whoami:get current user info'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'railway command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        up)
          _arguments -s -S \
            '-d[detach after deploying]' \
            '--detach[detach after deploying]' \
            '-e+[environment to deploy to]:environment:' \
            '--environment=[environment to deploy to]:environment:' \
            '-s+[service to deploy]:service:' \
            '--service=[service to deploy]:service:' \
            && ret=0
          ;;
        run)
          _arguments -s -S \
            '-e+[environment]:environment:' \
            '--environment=[environment]:environment:' \
            '-s+[service]:service:' \
            '--service=[service]:service:' \
            '*:command:' \
            && ret=0
          ;;
        logs)
          _arguments -s -S \
            '-d+[deployment ID]:deployment:' \
            '--deployment=[deployment ID]:deployment:' \
            '-n+[number of lines]:lines:' \
            '--lines=[number of lines]:lines:' \
            '-f[follow logs]' \
            '--follow[follow logs]' \
            '-s+[service]:service:' \
            '--service=[service]:service:' \
            '-e+[environment]:environment:' \
            '--environment=[environment]:environment:' \
            && ret=0
          ;;
        variables)
          _arguments -s -S \
            '1:subcommand:(set get delete)' \
            '-s+[service]:service:' \
            '--service=[service]:service:' \
            '-e+[environment]:environment:' \
            '--environment=[environment]:environment:' \
            '--json[output as JSON]' \
            && ret=0
          ;;
        environment)
          _arguments -s -S \
            '1:environment name:' \
            && ret=0
          ;;
        domain)
          _arguments -s -S \
            '-s+[service]:service:' \
            '--service=[service]:service:' \
            '-e+[environment]:environment:' \
            '--environment=[environment]:environment:' \
            && ret=0
          ;;
        volume)
          _arguments -s -S \
            '1:subcommand:(add list detach delete)' \
            '-s+[service]:service:' \
            '--service=[service]:service:' \
            && ret=0
          ;;
        connect)
          _arguments -s -S \
            '-e+[environment]:environment:' \
            '--environment=[environment]:environment:' \
            '1:service name:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            '--json[output as JSON]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_railway "$@"
