#compdef q-cli
# _q-cli — Harel Ben-Attia q text-as-SQL CLI alias (harelba team, Python); argparse
# upstream: https://github.com/harelba/q

_q-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--query=+[query]:str:' \
        '-q+[query]:str:' \
        '--query-filename=+[query file]:file:_files' \
        '-Q+[query file]:file:_files' \
        '--query-encoding=+[query encoding]:e:(utf-8 iso-8859-1)' \
        '--version-check-mode=+[mode]:m:(check ignore)' \
        '--save-default-rc[save default rc]' \
        '--max-attached-sqlite-database-files=+[n]:n:' \
        '-d+[delimiter]:str:' \
        '--delimiter=+[delimiter]:str:' \
        '-p[input has header]' \
        '--pipe-delimited[pipe delim]' \
        '-t[tab delimited]' \
        '--tab-delimited[tab delimited]' \
        '-T[tab delimited output]' \
        '--output-delimiter=+[delimiter]:str:' \
        '-D+[delimiter]:str:' \
        '-O[output header]' \
        '--output-header[output header]' \
        '-H[skip header]' \
        '--skip-header[skip header]' \
        '-r+[output record separator]:str:' \
        '--output-record-separator=+[record separator]:str:' \
        '-w+[input file encoding]:e:(utf-8 iso-8859-1)' \
        '--input-encoding=+[input encoding]:e:(utf-8 iso-8859-1)' \
        '--output-encoding=+[output encoding]:e:(utf-8 iso-8859-1)' \
        '-W+[output encoding]:e:(utf-8 iso-8859-1)' \
        '-z+[compression]:c:(none gzip auto)' \
        '--gzipped[input is gzipped]' \
        '--with-universal-newlines[universal newlines]' \
        '--keep-leading-whitespace-in-values[keep leading ws]' \
        '-A[analyze input]' \
        '--analyze-only[analyze only]' \
        '-m+[mode]:m:(relaxed strict fluffy)' \
        '--mode=+[mode]:m:(relaxed strict fluffy)' \
        '-c+[column count]:n:' \
        '--column-count=+[column count]:n:' \
        '--input-quoting-mode=+[mode]:m:(none minimal nonnumeric all)' \
        '--output-quoting-mode=+[mode]:m:(none minimal nonnumeric all)' \
        '--max-column-length-limit=+[length]:n:' \
        '--disable-double-double-quoting[no double quoting]' \
        '--disable-escaped-double-quoting[no escaped double quoting]' \
        '-b[beautify output]' \
        '--beautify[beautify output]' \
        '-f+[formatting]:str:' \
        '--formatting=+[formatting]:str:' \
        '-E+[encoding]:e:(utf-8 iso-8859-1)' \
        '--encoding=+[encoding]:e:(utf-8 iso-8859-1)' \
        '-C+[caching mode]:m:(none read readwrite)' \
        '--caching-mode=+[mode]:m:(none read readwrite)' \
        '--dump-defaults[dump defaults]' \
        '--save-db-to-disk=+[file]:file:_files' \
        '-S+[file]:file:_files' \
        '*:query:'
}

_q-cli "$@"
