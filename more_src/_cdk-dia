#compdef cdk-dia
# Documentation: https://github.com/pistazie/cdk-dia
# cdk-dia - diagram AWS CDK provisioned infrastructure

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--cdk-tree-path --tree)'{--cdk-tree-path=,--tree=}'[path of synthesized CDK cloud assembly]:tree json:_files' \
  '(--target-path --target)'{--target-path=,--target=}'[target path for rendered PNG]:target:_files' \
  '--collapse[collapse CDK constructs]' \
  '--no-collapse[do not collapse CDK constructs]' \
  '--collapse-double-clusters[collapse CDK constructs with one child that is a cluster itself]' \
  '--no-collapse-double-clusters[do not collapse double clusters]' \
  '(--include --stacks)'{--include=,--stacks=}'[stacks to include]:stacks:' \
  '--exclude=[stacks to exclude]:stacks:' \
  '--rendering=[rendering engine to use]:engine:(graphviz cytoscape-html)' \
  '*::arg:_files' && ret=0

return ret
