#compdef boilr
# _boilr — boilerplate template manager (tmrts/boilr)
# upstream: https://github.com/tmrts/boilr
# Subcommands + flags from pkg/cmd/root.go (cobra).

_boilr() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_boilr_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                template)
                    _arguments \
                        '1: :_boilr_template_commands' \
                        '*::template arg:->targs' && ret=0
                    case $state in
                        targs)
                            case $words[1] in
                                download)
                                    _arguments \
                                        '(-f --force)'{-f,--force}'[overwrite an existing template with the same name]' \
                                        '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info warn error)' \
                                        '1:git URL or shorthand:' \
                                        '2:template name:' && ret=0 ;;
                                use)
                                    _arguments \
                                        '(-f --use-defaults)'{-f,--use-defaults}'[use default values from project.json instead of prompting]' \
                                        '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info warn error)' \
                                        '1:template name:' \
                                        '2:target directory:_files -/' && ret=0 ;;
                                save)
                                    _arguments \
                                        '(-f --force)'{-f,--force}'[overwrite an existing template with the same name]' \
                                        '1:source directory:_files -/' \
                                        '2:template name:' && ret=0 ;;
                                list)
                                    _arguments '--dont-prettify[print only the template names]' && ret=0 ;;
                                delete|rename)
                                    _arguments '1:template name:' '2:new name (rename):' && ret=0 ;;
                                validate)
                                    _arguments '1:template name:' && ret=0 ;;
                            esac ;;
                    esac ;;
                init)
                    _arguments \
                        '(-f --force)'{-f,--force}'[recreate directories if they exist]' && ret=0 ;;
                version)
                    _arguments '--dont-prettify[print just the version]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_boilr_commands] )) ||
_boilr_commands() {
    local -a commands
    commands=(
        'template:manage templates (download / use / save / list / delete / rename / validate)'
        'init:initialise the boilr template directory'
        'version:print boilr version'
    )
    _describe -t commands 'boilr command' commands
}

(( $+functions[_boilr_template_commands] )) ||
_boilr_template_commands() {
    local -a commands
    commands=(
        'download:download a template from a git repository'
        'use:apply a saved template into a target directory'
        'save:save a directory as a template'
        'list:list the saved templates'
        'delete:delete a saved template'
        'rename:rename a saved template'
        'validate:validate a template definition'
    )
    _describe -t commands 'boilr template command' commands
}

_boilr "$@"
