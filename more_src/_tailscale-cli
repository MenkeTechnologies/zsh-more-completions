#compdef tailscale-cli
# _tailscale-cli — Tailscale zero-config WireGuard mesh VPN CLI alias (Tailscale Inc., Go); custom argparse
# upstream: https://github.com/tailscale/tailscale

_tailscale-cli() {
    local -a sub=(
        'up:connect to tailscale'
        'down:disconnect tailscale'
        'logout:logout of tailscale'
        'set:set tailscale settings'
        'login:login to tailscale'
        'switch:switch tailnet'
        'configure:configure machine'
        'syspolicy:show effective MDM policy'
        'lock:tailnet lock commands'
        'serve:start serve on tailnet'
        'funnel:expose service to internet'
        'webclient:web client commands'
        'status:show tailnet status'
        'metrics:show metrics'
        'netcheck:check network conditions'
        'ip:show tailscale IP addresses'
        'dns:show tailscale dns config'
        'ping:ping tailnet peer'
        'nc:netcat to a tailnet peer port'
        'ssh:ssh to a tailnet peer'
        'file:transfer files via Taildrop'
        'bugreport:print bug report'
        'cert:get TLS cert from tailnet'
        'completion:generate shell completion'
        'console:open admin console'
        'gui:open status GUI'
        'help:show help'
        'version:show version'
        'whois:show owner of a tailnet ip'
        'update:update tailscale version'
        'exit-node:exit node commands'
        'share:share a tailnet device'
        'idtoken:fetch oidc id token'
        'debug:debug subcommands'
        'drive:Taildrive subcommands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--socket=+[unix socket]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tailscale subcommand' sub ;;
        args)
            case $words[1] in
                up) _arguments \
                    '--reset[reset settings]' \
                    '--qr[print qr code]' \
                    '--login-server=+[login server]:url:_urls' \
                    '--accept-routes[accept advertised routes]' \
                    '--accept-dns[accept dns]' \
                    '--exit-node=+[exit node]:str:' \
                    '--exit-node-allow-lan-access[exit node allow lan access]' \
                    '--advertise-routes=+[advertise routes]:list:' \
                    '--advertise-exit-node[advertise as exit node]' \
                    '--advertise-tags=+[advertise tags]:list:' \
                    '--hostname=+[hostname]:str:_hosts' \
                    '--ssh[enable tailnet ssh server]' \
                    '--shields-up[shields up]' \
                    '--snat-subnet-routes=+[snat subnet routes]:b:(true false)' \
                    '--stateful-filtering=+[stateful filtering]:b:(true false)' \
                    '--auth-key=+[auth key]:str:' \
                    '--operator=+[operator]:str:_users' \
                    '--timeout=+[timeout]:dur:' \
                    '--accept-risk=+[accept risk types]:list:' \
                    '--force-reauth[force reauth]' \
                    '--json[json output]' \
                    '--unattended[unattended]' ;;
                set) _arguments \
                    '--accept-routes=+[accept routes]:b:(true false)' \
                    '--accept-dns=+[accept dns]:b:(true false)' \
                    '--auto-update=+[auto update]:b:(true false)' \
                    '--exit-node=+[exit node]:str:' \
                    '--exit-node-allow-lan-access=+[lan access]:b:(true false)' \
                    '--advertise-routes=+[advertise routes]:list:' \
                    '--advertise-exit-node=+[advertise exit node]:b:(true false)' \
                    '--advertise-tags=+[advertise tags]:list:' \
                    '--hostname=+[hostname]:str:_hosts' \
                    '--ssh=+[ssh]:b:(true false)' \
                    '--operator=+[operator]:str:_users' \
                    '--shields-up=+[shields up]:b:(true false)' \
                    '--stateful-filtering=+[stateful filtering]:b:(true false)' \
                    '--snat-subnet-routes=+[snat subnet routes]:b:(true false)' ;;
                status) _arguments \
                    '--json[json output]' \
                    '--peers=+[show peers]:b:(true false)' \
                    '--active[only active]' \
                    '--self=+[show self]:b:(true false)' \
                    '--listen=+[listen]:str:' ;;
                ping) _arguments \
                    '1:peer:' \
                    '--c=+[count]:n:' \
                    '--tsmp[use tsmp]' \
                    '--icmp[use icmp]' \
                    '--peerapi[peerapi]' \
                    '--until-direct[until direct]' \
                    '--verbose[verbose]' \
                    '--timeout=+[timeout]:dur:' \
                    '--size=+[size]:n:' ;;
                file) _arguments \
                    '1:cmd:(cp get)' \
                    '*:arg:' ;;
                ssh) _arguments \
                    '*:peer-cmd:' ;;
                serve|funnel) _arguments \
                    '1:cmd:(status set on off)' \
                    '*:arg:' ;;
                exit-node) _arguments \
                    '1:cmd:(list suggest)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                lock) _arguments \
                    '1:cmd:(init status sign log node remove revoke-keys)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_tailscale-cli "$@"
