#compdef exim_tidydb
# Documentation: https://manpages.debian.org/bookworm/exim4-base/exim_tidydb.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm exim_tidydb(8) manpage OPTIONS. Only two flags
# exist: -f (no prompt) and -t (cutoff time).
# Removed from prior file: fabricated --help/--version long flags and bogus
# man.archlinux.org search URL.

# exim_tidydb: remove obsolete data from Exim hints databases
local curcontext="$curcontext" ret=1
_arguments -C \
  '-f[do not prompt for each record]' \
  '-t[cutoff time (e.g. 7d 6h 90m)]:time:' \
  '1:spool directory:_files -/' \
  '2:database name:(retry wait-remote_smtp wait-lmtp callout ratelimit misc tls seen)' && ret=0
return ret
