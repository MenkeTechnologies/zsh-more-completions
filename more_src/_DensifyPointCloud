#compdef DensifyPointCloud
# Documentation: https://github.com/cdcseacave/openMVS/wiki/Usage
# OpenMVS: densify a sparse point-cloud via patch-match stereo

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --working-folder)'{-w,--working-folder}'=[working directory]:dir:_files -/' \
  '(-c --config-file)'{-c,--config-file}'=[config file]:file:_files' \
  '--archive-type=[project archive type]:type:(-1 0 1 2)' \
  '--process-priority=[process priority]:prio' \
  '--max-threads=[max worker threads]:n' \
  '(-v --verbosity)'{-v,--verbosity}'=[verbosity level]:level' \
  '--cuda-device=[CUDA device]:dev' \
  '(-i --input-file)'{-i,--input-file}'=[input scene file]:file:_files' \
  '(-p --pointcloud-file)'{-p,--pointcloud-file}'=[sparse point-cloud file]:file:_files' \
  '(-m --mask-path)'{-m,--mask-path}'=[mask images folder]:dir:_files -/' \
  '(-o --output-file)'{-o,--output-file}'=[output dense point-cloud]:file:_files' \
  '--view-neighbors-file=[input view neighbors file]:file:_files' \
  '--output-view-neighbors-file=[output view neighbors file]:file:_files' \
  '--resolution-level=[image downscale factor]:n' \
  '--max-resolution=[maximum image resolution]:n' \
  '--min-resolution=[minimum image resolution]:n' \
  '--sub-resolution-levels=[patch-match sub-resolution iterations]:n' \
  '--number-views=[views used for depth estimation]:n' \
  '--number-views-fuse=[min agreeing images for fusion]:n' \
  '--ignore-mask-label=[mask label to exclude]:n' \
  '--iters=[patch-match iterations]:n' \
  '--geometric-iters=[geometric consistency iterations]:n' \
  '--estimate-colors=[color estimation]:n:(0 1 2)' \
  '--estimate-normals=[normal estimation]:n:(0 1 2)' \
  '--estimate-scale=[point-scale multiplier]:n' \
  '--sub-scene-area=[split scene by max surface area]:n' \
  '--sample-mesh=[uniformly sample mesh points]:n' \
  '--fusion-mode=[depth fusion method]:n:(-2 -1 0 1)' \
  '(-t --fusion-depth-diff-threshold)'{-t,--fusion-depth-diff-threshold}'=[max depth variance during fusion]:n' \
  '(-d --fusion-reprojection-threshold)'{-d,--fusion-reprojection-threshold}'=[max reprojection distance]:n' \
  '--postprocess-dmaps=[depth-map filtering flags]:n' \
  '--filter-point-cloud=[filter by visibility]:n' \
  '--roi-border=[region-of-interest border]:n' \
  '--estimate-roi=[enable ROI estimation]:n' \
  '--crop-to-roi=[crop scene to ROI]:n' \
  '--remove-dmaps=[delete depth-maps after fusion]:n' \
  '--up-axis=[ROI up-axis]:n:(0 1 2)' \
  '*:scene:_files' && ret=0

return ret
