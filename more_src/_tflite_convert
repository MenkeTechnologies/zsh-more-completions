#compdef tflite_convert
# Documentation: https://man.archlinux.org/search?q=tflite_convert
# Reference accessed: 2026-05-16

# tflite_convert: convert TensorFlow models to TFLite format
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--output_file=[output .tflite file]:file:_files -g "*.tflite"' \
  '--graph_def_file=[input GraphDef .pb file]:file:_files -g "*.pb"' \
  '--saved_model_dir=[saved model directory]:dir:_files -/' \
  '--keras_model_file=[input Keras .h5]:file:_files -g "*.(h5|keras)"' \
  '--input_arrays=[input tensors comma list]:arrays:' \
  '--output_arrays=[output tensors comma list]:arrays:' \
  '--input_shapes=[input tensor shapes]:shapes:' \
  '--inference_type=[output type]:type:(FLOAT QUANTIZED_UINT8 INT8 INT16)' \
  '--inference_input_type=[input type]:type:(FLOAT QUANTIZED_UINT8 INT8 INT16)' \
  '--quantize_to_float16[force float16 quantization]' \
  '--post_training_quantize[post-training quantize]' \
  '--allow_custom_ops[allow custom ops]' \
  '--saved_model_signature_key=[signature key]:key:' \
  '--saved_model_tag_set=[tag set]:tags:' \
  '--target_ops=[target ops set]:ops:(TFLITE_BUILTINS SELECT_TF_OPS TFLITE_BUILTINS_INT8)' \
  '--enable_v1_converter[use TOCO V1 converter]' \
  '--enable_select_tf_ops[enable select TF ops]' \
  '*::tflite_convert args:_files' && ret=0
return ret
