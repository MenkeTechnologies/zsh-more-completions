#compdef pdfpc
# Documentation: https://manpages.debian.org/testing/pdf-presenter-console/pdfpc.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-B --list-bindings)'{-B,--list-bindings}'[display action bindings]' \
  '(-c --cfg-statement)'{-c+,--cfg-statement=}'[interpret string as pdfpcrc statement]:statement:' \
  '(-C --time-of-day)'{-C,--time-of-day}'[show current clock time]' \
  '(-d --duration)'{-d+,--duration=}'[presentation duration (minutes)]:n:' \
  '(-e --end-time)'{-e+,--end-time=}'[end time HH:MM]:time:' \
  '(-f --note-format)'{-f+,--note-format=}'[note format]:format:(plain markdown)' \
  '(-g --disable-auto-grouping)'{-g,--disable-auto-grouping}'[disable overlay group detection]' \
  '(-l --last-minutes)'{-l+,--last-minutes=}'[last-minutes warning threshold]:n:' \
  '(-L --list-actions)'{-L,--list-actions}'[list supported actions]' \
  '(-M --list-monitors)'{-M,--list-monitors}'[list system monitors]' \
  '(-n --notes)'{-n+,--notes=}'[beamer notes position]:position:(left right top bottom none)' \
  '(-N --no-install)'{-N,--no-install}'[allow testing without proper installation]' \
  '(-p --rest-port)'{-p+,--rest-port=}'[REST server port]:port:' \
  '(-P --page)'{-P+,--page=}'[start on page]:n:' \
  '(-r --page-transition)'{-r+,--page-transition=}'[default page transition]:type:(replace split blinds box wipe dissolve glitter fly push cover uncover fade)' \
  '(-R --pdfpc-location)'{-R+,--pdfpc-location=}'[use custom pdfpc file]:file:_files' \
  '(-s --switch-screens)'{-s,--switch-screens}'[swap presenter/presentation screens]' \
  '(-S --single-screen)'{-S,--single-screen}'[use only one screen]' \
  '(-t --start-time)'{-t+,--start-time=}'[countdown start time HH:MM]:time:' \
  '(-T --enable-auto-srt-load)'{-T,--enable-auto-srt-load}'[auto-load video subtitles]' \
  '(-V --enable-rest-server)'{-V+,--enable-rest-server=}'[enable REST server]:cidr:' \
  '(-W --wayland-workaround)'{-W,--wayland-workaround}'[Wayland HiDPI workaround]' \
  '(-w --windowed)'{-w+,--windowed=}'[windowed mode]:mode:(presenter presentation both none)' \
  '(-X --external-script)'{-X+,--external-script=}'[external script for X key]:file:_files' \
  '(-Z --size)'{-Z+,--size=}'[window size WxH]:size:' \
  '-1+[presenter screen monitor]:monitor:' \
  '--presenter-screen=[presenter screen monitor]:monitor:' \
  '-2+[presentation screen monitor]:monitor:' \
  '--presentation-screen=[presentation screen monitor]:monitor:' \
  '*:pdf_file:_files -g "*.pdf"' && ret=0

return ret
