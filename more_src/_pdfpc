#compdef pdfpc

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --duration)'{-p+,--duration=}'[presentation duration (minutes)]:n:' \
  '(-d --start-time)'{-d+,--start-time=}'[start time (HH:MM)]:time:' \
  '(-e --end-time)'{-e+,--end-time=}'[end time (HH:MM)]:time:' \
  '(-l --last-minutes)'{-l+,--last-minutes=}'[last-minutes warning threshold]:n:' \
  '(-c --current-size)'{-c+,--current-size=}'[current slide size]:n:' \
  '(-r --rotate)'{-r+,--rotate=}'[rotate display N degrees]:n:(0 90 180 270)' \
  '(-s --switch-screens)'{-s,--switch-screens}'[switch presenter/presentation screens]' \
  '(-S --single-screen)'{-S,--single-screen}'[force single-screen mode]' \
  '(-u --windowed)'{-u+,--windowed=}'[windowed mode]:mode:(presenter presentation both none)' \
  '(-w --notes)'{-w,--notes}'[disable caching of slides with notes]' \
  '(-z --windowed)'{-z+,--windowed=}'[windowed flag (alt)]:mode:(presenter presentation both none)' \
  '(-A --persist-cache)'{-A+,--persist-cache=}'[cache file path]:file:_files' \
  '(-B --black-on-end)'{-B,--black-on-end}'[show black slide at end]' \
  '(-C --disable-cache-cleanup)'{-C,--disable-cache-cleanup}'[disable cache cleanup]' \
  '(-D --disable-cache)'{-D,--disable-cache}'[disable cache rendering]' \
  '(-F --disable-compression)'{-F,--disable-compression}'[disable cache compression]' \
  '(-g --disable-tooltips)'{-g,--disable-tooltips}'[disable tooltips]' \
  '(-Q --disable-input-autodetection)'{-Q,--disable-input-autodetection}'[disable autodetection]' \
  '(-t --time-of-day)'{-t,--time-of-day}'[show current clock time]' \
  '(-T --enable-auto-srt-load)'{-T,--enable-auto-srt-load}'[auto-load .srt subtitles]' \
  '(-V --enable-rest-server)'{-V+,--enable-rest-server=}'[enable REST server]:cidr:' \
  '--rest-port=[REST server port]:port:' \
  '--rest-static-root=[REST static files dir]:dir:_files -/' \
  '--rest-https=[HTTPS cert]:cert_key:' \
  '(-W --wayland-workaround)'{-W,--wayland-workaround}'[Wayland HiDPI workaround]' \
  '(-X --external-script)'{-X+,--external-script=}'[external script (X key)]:file:_files' \
  '--page=[start on this page]:n:' \
  '--transition=[default page transition]:type:(replace split blinds box wipe dissolve glitter fly push cover uncover fade)' \
  '*:pdf_file:_files -g "*.pdf"' && ret=0

return ret
