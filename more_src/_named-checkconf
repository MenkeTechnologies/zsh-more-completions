#compdef named-checkconf
# Documentation: https://manpages.debian.org/trixie/bind9-utils/named-checkconf.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-h[show help]' \
  '-a[skip DNSSEC algorithm crypto-provider check]' \
  '-c[check core configuration only]' \
  '-i[ignore deprecated warnings]' \
  '-j[read journal when loading zonefile]' \
  '-k[validate DNSSEC keys against key-directory]' \
  '-l[list configured zones]' \
  '-p[print canonical config]' \
  '-t=[chroot directory]:dir:_files -/' \
  '-v[show version]' \
  '-x[mask shared secrets (use with -p)]' \
  '-z[test load all primary zones]' \
  ':config:_files -g "*.conf"'
