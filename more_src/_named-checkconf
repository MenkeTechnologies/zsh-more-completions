#compdef named-checkconf

_arguments -s \
  '(- *)-h[show help]' \
  '-c[check core only]' \
  '-i[ignore deprecated warnings]' \
  '-j[read JSON serialized format]' \
  '-l[list zones]' \
  '-p[print canonical config]' \
  '-t=[chroot directory]:dir:_files -/' \
  '-v[show version]' \
  '-x[mask shared secrets (use with -p)]' \
  '-z[test load all primary zones]' \
  ':config:_files -g "*.conf"'
