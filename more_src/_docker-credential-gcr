#compdef docker-credential-gcr
# _docker-credential-gcr — Docker credential helper for GCR/Artifact Registry (GoogleCloudPlatform/docker-credential-gcr)
# upstream: https://github.com/GoogleCloudPlatform/docker-credential-gcr
# Subcommands from main.go (subcommands.Register).

_docker-credential-gcr() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                store:'docker credential store: store credentials'
                get:'docker credential store: retrieve credentials'
                erase:'docker credential store: erase credentials'
                list:'docker credential store: list registered hosts'
                gcr-login:'log into GCR using OAuth'
                gcr-logout:'log out from GCR'
                docker-config:'configure docker to use this helper'
                config:'configure token sources and behavior'
                version:'show version'
                clear:'clear stored credentials'
                help:'show help'
                commands:'list registered subcommands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                config)
                    _arguments \
                        '--token-source=[comma-separated token sources]:sources:(store env gcloud)' \
                        '--unset-token-source[clear token source configuration]' ;;
                docker-config)
                    _arguments \
                        '--overwrite[overwrite existing credential helper entries]' \
                        '--unset[remove credential helper entries]' ;;
            esac
            ;;
    esac
}

_docker-credential-gcr "$@"
