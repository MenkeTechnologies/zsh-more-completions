#compdef otelcol otelcol-contrib

# Zsh completion for OpenTelemetry Collector

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'completion:generate shell completions'
      'components:list available components'
      'validate:validate configuration'
    )
    _describe -t commands 'otelcol command' commands && ret=0
    ;;
  args)
    case $line[1] in
      validate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file or URI]:config:_files -g "*.{yaml,yml}"' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

# Default run mode (no subcommand)
_arguments -s -S \
  '--config=[config source URIs]:config:_files -g "*.{yaml,yml}"' \
  '--feature-gates=[feature gate IDs]:gates' \
  '--set=[set config value]:key=value' && ret=0

return ret
