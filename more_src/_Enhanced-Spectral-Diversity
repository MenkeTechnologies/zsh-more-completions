#compdef Enhanced-Spectral-Diversity
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/s1tbx-op-sentinel1/src/main/java/org/esa/s1tbx/sentinel1/gpf/SpectralDiversityOp.java
# ESA SNAP gpt Enhanced-Spectral-Diversity operator - estimate range/azimuth shifts for S-1 TOPS

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PfineWinWidthStr=[registration window width]:width:(32 64 128 256 512 1024 2048)' \
  '-PfineWinHeightStr=[registration window height]:height:(32 64 128 256 512 1024 2048)' \
  '-PfineWinAccAzimuth=[search accuracy in azimuth]:acc:(2 4 8 16 32 64)' \
  '-PfineWinAccRange=[search accuracy in range]:acc:(2 4 8 16 32 64)' \
  '-PfineWinOversampling=[window oversampling factor]:factor:(32 64 128 256)' \
  '-PxCorrThreshold=[peak cross-correlation threshold]:threshold' \
  '-PcohThreshold=[coherence threshold for outlier removal]:threshold' \
  '-PnumBlocksPerOverlap=[number of windows per overlap for ESD]:num' \
  '-PesdEstimator=[ESD estimator for azimuth shift]:estimator:(Average Periodogram)' \
  '-PweightFunc=[coherence weight function]:func:(None Linear Quadratic Inv\ Quadratic)' \
  '-PtemporalBaselineType=[baseline type for integration network]:type' \
  '-PmaxTemporalBaseline=[maximum temporal baseline]:baseline' \
  '-PintegrationMethod=[shift network integration method]:method:(L1 L2 L1\ and\ L2)' \
  '-PdoNotWriteTargetBands=[do not write target bands]:flag:(true false)' \
  '-PuseSuppliedRangeShift=[use user supplied range shift]:flag:(true false)' \
  '-PoverallRangeShift=[the overall range shift]:shift' \
  '-PuseSuppliedAzimuthShift=[use user supplied azimuth shift]:flag:(true false)' \
  '-PoverallAzimuthShift=[the overall azimuth shift]:shift' \
  '*:graph xml:_files' && ret=0

return ret
