#compdef cvs-debi cvs-debc
# Documentation: https://manpages.debian.org/cvs-debi
# Source: debian/devscripts scripts/cvs-debi.sh — install / list contents of CVS-built debs (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '-M+[CVS module name]:module:_default' \
    '-P+[package name]:package:_default' \
    '-V+[package version]:version:_default' \
    '-T+[CVS tag]:tag:_default' \
    '-R+[root directory]:dir:_files -/' \
    '-W+[working directory]:dir:_files -/' \
    '-x+[CVS default module prefix]:prefix:_default' \
    '-a+[Debian build architecture]:arch:_default' \
    '-t+[GNU target architecture]:target:_default' \
    '*:package:_default' \
    && ret=0

return ret
