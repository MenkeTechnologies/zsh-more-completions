#compdef create-backend-service
# Documentation: https://www.npmjs.com/package/create-backend-service
# Reference accessed: 2026-05-23
# Verified: npm view create-backend-service bin; npm readme CLI flags section.

# Zsh completion for create-backend-service - modular backend service scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--template=[service template]:template:(basic full minimal)' \
  '--database=[database engine]:database:(mysql postgresql sqlite)' \
  '--no-git[skip git initialization]' \
  '--no-install[skip dependency installation]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  ':project name:' && ret=0

return ret
