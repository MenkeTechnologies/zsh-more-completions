# Zsh completion for create-kurdemy-app - NestJS/React fullstack Kurdemy scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--frontend=[frontend framework]:frontend:(nextjs react)' \
  '--database=[database type]:database:(postgresql mysql sqlite sqlserver)' \
  '--orm=[ORM choice]:orm:(prisma drizzle)' \
  '--trpc=[include tRPC]:bool:(true false)' \
  '--auth=[include authentication]:bool:(true false)' \
  '--tailwind=[include Tailwind CSS]:bool:(true false)' \
  '--package-manager=[package manager]:manager:(npm yarn pnpm)' \
  '--template=[starter template]:template:(blog ecommerce saas)' \
  ':project name:' && ret=0

return ret
