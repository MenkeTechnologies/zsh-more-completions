#compdef gnutls-cli-debug gnutls-serv certtool ocsptool psktool srptool
# _libgnutls-tools — GnuTLS auxiliary utility family (gnutls-cli-debug iterates TLS extensions for capability discovery, gnutls-serv runs a tiny TLS server, certtool generates / inspects X.509 certs, ocsptool runs OCSP queries, psktool manages PSK files, srptool manages SRP verifier files; common flags --help, --version, --debug, --priority, --port, --x509cafile)
# upstream: https://gitlab.com/gnutls/gnutls
# Common flag shape from gnutls src/* on tip.

_libgnutls-tools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[debug]:level:' \
        '--debug+[debug]:level:' \
        '--priority+[priority string]:priority:' \
        '-p+[port]:port:' \
        '--port+[port]:port:' \
        '--x509cafile+[CA file]:file:_files' \
        '--load-pubkey+[pubkey file]:file:_files' \
        '--load-privkey+[privkey file]:file:_files' \
        '--outfile+[output file]:file:_files' \
        '--infile+[input file]:file:_files'
}

_libgnutls-tools "$@"
