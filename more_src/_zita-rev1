#compdef zita-rev1
# _zita-rev1 — stereo and ambisonic reverb (Fons Adriaensen)
# upstream: https://kokkinizita.linuxaudio.org/linuxaudio/index.html
# Flags from zita-rev1(1) man page.

_zita-rev1() {
    _arguments \
        '(- *)-h[show help]' \
        '-B[Ambisonic mode]' \
        '-name[JACK client name]:name:' \
        '-s[JACK server name]:server:' \
        '-g[window geometry / position]:geometry:'
}

_zita-rev1 "$@"
