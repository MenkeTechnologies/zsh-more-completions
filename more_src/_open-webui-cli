#compdef open-webui-cli

# Zsh completion for open-webui-cli
# https://github.com/open-webui/open-webui

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:List resources (models, etc.)'
  'chat:Start a chat session'
  'upload:Upload files for RAG'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'open-webui-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (list)
        _arguments -s -S '1:resource:(models)' && ret=0
        ;;
      (chat)
        _arguments -s -S \
          '--model=[model name]:model:' \
          '--prompt=[initial prompt]:prompt:' && ret=0
        ;;
      (upload)
        _arguments -s -S '1:type:(file)' '2:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
