#compdef midicopy
# Documentation: https://manpages.debian.org/testing/abcmidi/midicopy.1.en.html
# extract tracks, channels or time intervals from a MIDI file into a new MIDI file

local ret=1

_arguments -s -S \
  '-ver[print version number and exit]' \
  '-trks+[copy only the specified tracks (numbered from 1)]:tracks' \
  '-xtrks+[exclude the specified tracks from copying]:tracks' \
  '-chns+[copy only the specified MIDI channels]:channels' \
  '-xchns+[exclude the specified channels from copying]:channels' \
  '-from+[begin copying from MIDI pulse position n]:pulse' \
  '-to+[stop copying after MIDI pulse position n]:pulse' \
  '-frombeat+[begin copying from quarter beat number n]:beat' \
  '-tobeat+[stop copying after quarter beat number n]:beat' \
  '-fromsec+[begin copying from time n in seconds]:seconds' \
  '-tosec+[stop copying after time n in seconds]:seconds' \
  '-replace+[replace byte value at track,loc,val]:replacement' \
  '-tempo+[replace all tempo markings with the given value]:tempo' \
  '-speed+[multiply all tempo values by a floating-point factor]:factor' \
  '-drumfocus[highlight drum line by reducing other drums loudness]' \
  '-mutenodrum+[attenuate non-drum channels to the given level]:level' \
  '-setdrumloudness+[change loudness of drum code n to value m]:n m' \
  '-focusontrack+[reduce velocities in non-specified tracks]:tracks' \
  '-focusonchannel+[reduce velocities in non-specified channels]:channels' \
  '-attenuation+[velocity reduction amount (default 70)]:amount' \
  '-nobends[remove all pitch bend commands]' \
  '-indrums+[include only the specified percussion codes]:codes' \
  '-xdrums+[exclude the specified percussion codes]:codes' \
  '-onlydrums[copy the percussion channel exclusively]' \
  '-nodrums[copy all channels except percussion]' \
  '-transpose+[shift pitch by n semitones (non-percussion only)]:semitones' \
  '*:midi file:_files -g "*.(mid|midi)"' && ret=0

return ret
