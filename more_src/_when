#compdef when
# Documentation: https://manpages.debian.org/bookworm/when/when.1.en.html
# Reference accessed: 2026-05-30
# when — Leon Brocard's tiny personal calendar utility. Single-file calendar
# in ~/.when/calendar (one line per event); long-form-only flags drive
# rendering. Positional accepts single-letter command codes that can be
# combined (`when cw` = calendars then weekly items).

local curcontext="$curcontext" state line ret=1

local -a _verbs
_verbs=(
  'i:upcoming items (default)'
  'c:calendar grids for last/this/next month (no items)'
  'e:invoke $EDITOR on the calendar file'
  'w:items for the coming week'
  'm:items for the coming month'
  'y:items for the coming year'
  'j:modified Julian day (for date arithmetic)'
  'd:current date only'
)

_arguments -s -S \
  '(- *)--help[show brief help]' \
  '(- *)--version[show version + a-line description]' \
  '--language=[output language]:lang:' \
  '--future=[days into the future to report (default 14)]:days:' \
  '--past=[days into the past to report (default -1)]:days:' \
  '--calendar=[calendar file path]:file:_files' \
  '--editor=[editor command (default `emacs -nw`)]:cmd:_command_names -e' \
  '--wrap=[output column width (default 80)]:cols:' \
  '(--wrap_auto --noowrap_auto)--wrap_auto[auto-detect terminal width]' \
  '(--wrap_auto --noowrap_auto)--noowrap_auto[disable auto width detection]' \
  '--wrap_max=[maximum column width (default -1)]:cols:' \
  '--rows=[terminal row count (default 40)]:rows:' \
  '(--rows_auto --norows_auto)--rows_auto[auto-detect terminal height]' \
  '(--rows_auto --norows_auto)--norows_auto[disable auto height detection]' \
  '(--header --noheader)--header[show output headers]' \
  '(--header --noheader)--noheader[suppress output headers]' \
  '(--paging --nopaging)--paging[pipe through pager]' \
  '(--paging --nopaging)--nopaging[no pager]' \
  '--paging_less_options=[extra less options]:opts:' \
  '--filter_accents_on_output[strip accents from output]' \
  '--styled_output[use ANSI styling]' \
  '--styled_output_if_not_tty[style output even when not a TTY]' \
  '--calendar_today_style=[ANSI style for today in calendar view]:style:' \
  '--items_today_style=[ANSI style for today in items view]:style:' \
  '--prefilter=[pipe calendar through PROGRAM before parsing]:program:_command_names -e' \
  '--now=[override current date (Y M D)]:date:' \
  '(--neighboring_months --noneighboring_months)--neighboring_months[include adjacent months]' \
  '(--neighboring_months --noneighboring_months)--noneighboring_months[exclude adjacent months]' \
  '(--monday_first --nomonday_first)--monday_first[week starts on Monday]' \
  '(--monday_first --nomonday_first)--nomonday_first[week starts on Sunday]' \
  '--orthodox_easter[use Orthodox Easter calculation]' \
  '(--ampm --noampm)--ampm[12-hour time]' \
  '(--ampm --noampm)--noampm[24-hour time]' \
  '--auto_pm=[assume PM for hours below X]:hour:' \
  '(--literal_only --noliteral_only)--literal_only[show only explicitly-dated entries]' \
  '(--literal_only --noliteral_only)--noliteral_only[also expand recurring entries (default)]' \
  '1:command code (can be combined, e.g. `cw`):->verb' \
  && ret=0

case $state in
  verb)
    _describe -t commands 'when command code' _verbs && ret=0
    ;;
esac

return ret
