#compdef grdgdal
# Documentation: https://docs.generic-mapping-tools.org/latest/grdgdal.html
# Source: GenericMappingTools/gmt classic-mode grdgdal — dispatch GDAL utilities (info/dem/grid/rasterize/translate/warp).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[GDAL program + modifiers (+m method +c cpt)]:prog:(info dem grid rasterize translate warp)' \
    '-G+[output grid file]:file:_files' \
    '-F+[GDAL options string]:opts:_default' \
    '-M+[read/write via GDAL (+r read, +w write)]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-r[pixel registration (default gridline)]' \
    '*:input file:_files' \
    && ret=0

return ret
