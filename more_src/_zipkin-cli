#compdef zipkin-cli zipkincli
# _zipkin-cli — OpenZipkin zipkin-cli CLI command-line frontend to the Zipkin distributed tracing system REST API querying services spans operations dependencies traces by trace-id service-name span-name time-range duration tag with per-trace details detailed-spans-export Zipkin-Brave-Cobra Cobra-CLI-style scripting (OpenZipkin team, Go); cobra
# upstream: https://zipkin.io/

_zipkin-cli() {
    local -a sub=(
        'services:list services'
        'spans:list span names for a service'
        'operations:list operations'
        'traces:list traces by query'
        'trace:show a single trace'
        'dependencies:show service dependencies'
        'health:show server health'
        'config:configuration'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '--api-version=+[v]:v:(v1 v2)' \
        '--insecure[skip TLS verify]' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zipkin-cli subcommand' sub ;;
        args)
            case $words[1] in
                services|dependencies|health) ;;
                spans|operations) _arguments '1:service:' ;;
                trace) _arguments '1:trace id:' ;;
                traces) _arguments \
                    '--service=+[name]:str:' \
                    '--span=+[name]:str:' \
                    '--limit=+[N]:n:' \
                    '--lookback=+[duration]:str:' \
                    '--end-ts=+[ms]:str:' \
                    '--min-duration=+[us]:n:' \
                    '--max-duration=+[us]:n:' \
                    '--annotation-query=+[k=v]:str:' ;;
            esac
            ;;
    esac
}

_zipkin-cli "$@"
