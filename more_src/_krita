#compdef krita

# Zsh completion for krita - Krita digital painting application

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nosplash[do not show splash screen]' \
  '--canvasonly[start in canvas-only mode]' \
  '--fullscreen[start in fullscreen mode]' \
  '--workspace=[start with given workspace]:workspace' \
  '--windowlayout=[start with given window layout]:layout' \
  '--new-image=[create a new image]:colormodel,bitdepth,width,height' \
  '--template=[open template]:file:_files -g "*.kra"' \
  '--dpi=[set display DPI]:dpi' \
  '--export[export file and exit]' \
  '--export-sequence[export animation sequence]' \
  '--export-filename=[export to filename]:file:_files' \
  '--file-layer=[file layer to use]:file:_files' \
  '--batch[batch mode, no GUI]' \
  '*:file:_files -g "*.{kra,ora,psd,png,jpg,jpeg,tiff,tif,gif,bmp,xcf,svg,webp,exr}"' && ret=0

return ret
