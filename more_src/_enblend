#compdef enblend
# Documentation: https://man.archlinux.org/search?q=enblend
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'+[verbosity level]:level:' \
  '(-w --wrap)'{-w,--wrap}'+[wrap mode]:mode:(NONE HORIZONTAL VERTICAL BOTH)' \
  '(-l --levels)'{-l,--levels}'+[pyramid levels]:n:' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-a --pre-assemble)'{-a,--pre-assemble}'[pre-assemble images]' \
  '(-b --blocksize)'{-b,--blocksize}'+[block size KB]:kb:' \
  '(-c --ciecam)'{-c,--ciecam}'[CIECAM02 colorspace]' \
  '(-d --depth)'{-d,--depth}'+[output bit depth]:depth:(8 16 32 r32 r64 sint8 sint16 sint32 uint8 uint16 uint32 float double)' \
  '(-f --size)'{-f,--size}'+[output canvas size]:WxH+X+Y:' \
  '(-g --gpu)'{-g,--gpu}'[use GPU acceleration]' \
  '(-m --image-cache-block-size)'{-m,--image-cache-block-size}'+[image cache block]:kb:' \
  '(-x --primary-seam-generator)'{-x,--primary-seam-generator}'+[seam generator]:gen:(graph-cut nft)' \
  '(--mask-vectorize)--mask-vectorize=+[mask vectorize tolerance]:n:' \
  '(--mask-buffer-size)--mask-buffer-size=+[mask buffer]:kb:' \
  '(--mask-vectorize)--mask-vectorize=+[vectorize tolerance]:n:' \
  '(--load-masks)--load-masks=+[load masks]:files:' \
  '(--save-masks)--save-masks=+[save masks]:template:' \
  '(--visualize)--visualize=+[visualize seam]:file:_files' \
  '(--smooth-difference)--smooth-difference=+[difference smoothing]:radius:' \
  '(--anneal)--anneal=+[anneal seam params]:params:' \
  '(--blend-colorspace)--blend-colorspace=+[blend colorspace]:cs:(identity lab luv ciecam)' \
  '(--coarse-mask)--coarse-mask=+[coarse mask scale]:scale:' \
  '(--fine-mask)--fine-mask[fine mask mode]' \
  '(--optimizer-weights)--optimizer-weights=+[optimizer weights]:weights:' \
  '*:input_files:_files -g "*.{tif,tiff,jpg,jpeg,png}"' && ret=0

return ret
