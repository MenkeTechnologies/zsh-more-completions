#compdef impacket-mimikatz

# Impacket mimikatz.py: minimal MimiKatz over DCSync RPC
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-target-ip[target IP]:ip:' \
  '-port[connection port]:port:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-codec[encoding]:codec:' \
  '*:target user[:password]@host [command]:' && ret=0
return ret
