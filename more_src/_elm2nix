#compdef elm2nix

# Zsh completion for elm2nix - convert Elm dependencies to Nix

_elm2nix() {
  local curcontext="$curcontext" state line ret=1

  local -a subcommands=(
    'init:initialize elm-srcs.nix'
    'convert:convert elm.json to Nix'
    'snapshot:create snapshot of Elm packages'
  )

  _arguments -s -S -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:->subcmd' \
    '*::args:->args' && ret=0

  case $state in
    subcmd)
      _describe -t subcommands 'elm2nix command' subcommands && ret=0
      ;;
  esac

  return ret
}

_elm2nix "$@"
