#compdef veryl

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'new:create a new project'
      'init:initialize a project in current directory'
      'build:build the project'
      'check:check syntax and semantics'
      'fmt:format source code'
      'lint:lint source code'
      'test:run tests'
      'doc:generate documentation'
      'publish:publish to registry'
      'update:update dependencies'
      'metadata:show metadata'
      'completion:generate shell completions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments '1:project name:' && ret=0
        ;;
      (build|check)
        _arguments \
          '--release[build in release mode]' \
          '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:' && ret=0
        ;;
      (fmt)
        _arguments \
          '--check[check formatting without making changes]' \
          '*:files:_files -g "*.veryl"' && ret=0
        ;;
      (lint)
        _arguments '*:files:_files -g "*.veryl"' && ret=0
        ;;
      (test)
        _arguments \
          '--sim=[simulator]:simulator:(verilator vcs vivado)' \
          '--wave[dump waveform]' && ret=0
        ;;
      (doc)
        _arguments '--open[open documentation in browser]' && ret=0
        ;;
      (publish)
        _arguments \
          '--bump=[version bump]:bump:(major minor patch)' \
          '--dry-run[perform dry run]' && ret=0
        ;;
    esac
    ;;
esac

return ret
