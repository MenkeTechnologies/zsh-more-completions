#compdef goverter
# Documentation: https://goverter.jmattheis.de/reference/cli
# goverter: generate type-safe Go converters from interface definitions

local ret=1
local -a commands

commands=(
  'gen:generate converters from the given packages'
  'help:show help'
  'version:print the version'
)

_arguments -C \
  '(-h -help)'{-h,-help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'goverter command' commands && ret=0
    ;;
  args)
    case $line[1] in
      gen)
        _arguments -s \
          '-build-tags=[comma separated build tags to consider during interface loading]:tags' \
          '-cwd=[set the working directory]:dir:_files -/' \
          '*'{-g,-global}'=[apply a setting globally to all converters]:setting' \
          '-output-constraint=[build constraint for generated files]:constraint' \
          '*:package:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
