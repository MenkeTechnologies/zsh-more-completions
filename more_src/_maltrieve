#compdef maltrieve
# _maltrieve — Kyle Maxwell maltrieve CLI for downloading recent malware samples from public-feed sources MalwareBlackList MalcOde Malware Domain Lists VirusShare KrakenLabs storing into local archives or VxCage Cuckoo MIIIDIDE Viper (kylemaxwell team, Python); argparse
# upstream: https://github.com/krmaxwell/maltrieve

_maltrieve() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.cfg maltrieve.cfg"' \
        '--config=+[config file]:file:_files -g "*.cfg maltrieve.cfg"' \
        '-d+[directory]:dir:_files -/' \
        '--dumpdir=+[directory]:dir:_files -/' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-i+[input urls file]:file:_files' \
        '--inputfile=+[input urls file]:file:_files' \
        '-p+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '-s+[sort by]:s:(date hash size source)' \
        '--sort=+[sort by]:s:(date hash size source)' \
        '-x[crawl]' \
        '--crawl[crawl]' \
        '-N+[concurrent N]:n:' \
        '--concurrent=+[N]:n:' \
        '-S+[sources csv]:str:' \
        '--sources=+[sources csv]:str:' \
        '--viper=+[uri]:str:' \
        '--vxcage=+[uri]:str:' \
        '--cuckoo=+[uri]:str:' \
        '--logheaders[log headers]' \
        '--unique[unique]' \
        '--no-clean[no clean]'
}

_maltrieve "$@"
