#compdef riff
# Documentation: https://github.com/walles/riff
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# riff: a diff filter that highlights intra-line changes. Configuration
# also via the RIFF environment variable; full flag list deferred to
# `riff --help`.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--color=[control color output]:when:(on off auto always never)' \
  '--unchanged-style=[style for unchanged portions of changed lines]:style:' \
  '-b[ignore whitespace when diffing]' \
  '*:file:_files' && ret=0

return ret
