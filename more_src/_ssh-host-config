#compdef ssh-host-config

# ssh-host-config: cygwin/MSYS2 helper to configure sshd service
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-y[respond yes to all prompts]' \
  '-n[respond no to all prompts]' \
  '-d[enable debug]' \
  '-c[explicit cygwin contact addr]:str:' \
  '--cygwin=[cygwin contact addr]:str:' \
  '-p[explicit port number]:port:' \
  '--port=[explicit port number]:port:' \
  '-u[username for service]:user:_users' \
  '--user=[username for service]:user:_users' \
  '-w[password for service account]:pass:' \
  '--pwd=[password for service account]:pass:' \
  '--privileged[run as privileged user]' \
  '*::ssh-host-config args:' && ret=0
return ret
