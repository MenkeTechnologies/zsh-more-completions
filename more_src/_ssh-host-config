#compdef ssh-host-config

# ssh-host-config: configure sshd as a Windows service (Cygwin / Git-Bash)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '-h[show help]' \
  '--port=[sshd port]:port:' \
  '-p[sshd port]:port:' \
  '--yes[answer yes to prompts]' \
  '-y[answer yes to prompts]' \
  '--no[answer no to prompts]' \
  '-n[answer no to prompts]' \
  '--privileged[run as privileged Cygwin user]' \
  '--user[run as named user]:user:_users' \
  '-c[cygwin env passthrough]:val:' \
  '-w[password for privileged user]:pwd:' \
  '*::ssh-host-config args:_files' && ret=0
return ret
