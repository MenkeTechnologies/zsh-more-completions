#compdef pkl
# Documentation: https://pkl-lang.org/main/current/pkl-cli/index.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pkl (Apple Pkl configuration language CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'eval:Evaluate Pkl module(s) and produce output'
      'test:Run tests in Pkl module(s)'
      'repl:Start a REPL session'
      'server:Run as a server communicating over stdin/stdout'
      'run:Execute commands defined in modules extending pkl:Command'
      'project:Manage Pkl projects'
      'download-package:Download packages to the cache directory'
      'analyze:Analyze Pkl modules'
      'format:Format or check formatting of Pkl files'
      'shell-completion:Generate shell completion scripts'
    )
    _describe -t commands 'pkl command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '--allowed-modules=[URI patterns for allowed modules]:patterns'
      '--allowed-resources=[URI patterns for allowed resources]:patterns'
      '--no-cache[Disable module caching]'
      '--cache-dir=[Module cache directory]:dir:_directories'
      '--root-dir=[Root directory for file-based module imports]:dir:_directories'
      '*--property=[Set an external property]:key=value'
      '*-p+[Set an external property]:key=value'
      '*--env-var=[Set an environment variable]:key=value'
      '*-e+[Set an environment variable]:key=value'
      '--settings=[Path to Pkl settings file]:file:_files'
      '--no-project[Disable loading PklProject files]'
      '--project-dir=[Path to the project directory]:dir:_directories'
      '--omit-project-settings[Ignore project evaluator settings]'
      '--module-path=[Search path for modulepath: URIs]:path'
      '-w+[Working directory for relative modules]:dir:_directories'
      '--working-dir=[Working directory for relative modules]:dir:_directories'
      '-t+[Evaluation timeout in seconds]:seconds'
      '--timeout=[Evaluation timeout in seconds]:seconds'
      '--trace-mode=[Trace output format]:mode:(compact pretty)'
      '--color=[ANSI color formatting]:mode:(never auto always)'
      '--ca-certificates=[TLS certificate file path]:file:_files'
      '--http-proxy=[HTTP proxy address]:url'
      '--http-no-proxy=[Hosts bypassing proxy]:hosts'
      '-h[Print help]'
      '--help[Print help]'
    )

    case ${words[1]} in
      eval)
        _arguments -s -S \
          $common_flags \
          '-f+[Output format]:format:(json jsonnet pcf plist properties text textproto xml yaml)' \
          '--format=[Output format]:format:(json jsonnet pcf plist properties text textproto xml yaml)' \
          '-o+[Output file path]:file:_files' \
          '--output-path=[Output file path]:file:_files' \
          '-m+[Output directory for multiple file output]:dir:_directories' \
          '--multiple-file-output-path=[Output directory for multiple file output]:dir:_directories' \
          '-x+[Expression to evaluate within the module]:expression' \
          '--expression=[Expression to evaluate within the module]:expression' \
          '--module-output-separator=[Separator for concatenated outputs]:sep' \
          '*:module:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          $common_flags \
          '--overwrite[Overwrite expected output files]' \
          '--junit-reports=[Directory for JUnit reports]:dir:_directories' \
          '--junit-aggregate-reports[Combine reports into a single file]' \
          '--junit-aggregate-suite-name=[Root suite name]:name' \
          '--power-assertions[Enable detailed assertion messages]' \
          '--no-power-assertions[Disable detailed assertion messages]' \
          '*:module:_files' && ret=0
        ;;
      repl)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      server)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      run)
        _arguments -s -S \
          $common_flags \
          '*:module:_files' && ret=0
        ;;
      project)
        local -a subcmds=(
          'package:Prepare project for publication as a package'
          'resolve:Resolve project dependencies'
        )
        _describe -t subcmds 'project subcommand' subcmds && ret=0
        ;;
      download-package)
        _arguments -s -S \
          '--no-cache[Disable caching]' \
          '--cache-dir=[Cache directory]:dir:_directories' \
          '--no-transitive[Do not download transitive dependencies]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package URI' && ret=0
        ;;
      analyze)
        local -a subcmds=(
          'imports:Build import dependency graph'
        )
        _describe -t subcmds 'analyze subcommand' subcmds && ret=0
        ;;
      format)
        _arguments -s -S \
          '--grammar-version=[Grammar compatibility version]:version' \
          '-s[Skip stdout writing]' \
          '--silent[Skip stdout writing]' \
          '-w[Format files in-place]' \
          '--write[Format files in-place]' \
          '--diff-name-only[List files with violations]' \
          '*:file:_files' && ret=0
        ;;
      shell-completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
