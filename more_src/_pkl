#compdef pkl

# Zsh completion for pkl (Apple Pkl configuration language CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'eval:Evaluate Pkl module(s) and produce output'
      'test:Run tests in Pkl module(s)'
      'repl:Start a REPL session'
      'server:Run as a language server'
      'project:Manage Pkl projects'
      'download-package:Download packages'
    )
    _describe -t commands 'pkl command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '--allowed-modules=[URI patterns for allowed modules]:patterns'
      '--allowed-resources=[URI patterns for allowed resources]:patterns'
      '--no-cache[Disable module caching]'
      '--cache-dir=[Module cache directory]:dir:_directories'
      '--root-dir=[Root directory for file-based module imports]:dir:_directories'
      '--property=[Set an external property]:key=value'
      '-p+[Set an external property]:key=value'
      '--env-var=[Set an environment variable]:key=value'
      '--settings=[Path to Pkl settings file]:file:_files'
      '--no-project[Disable loading PklProject files]'
      '--project-dir=[Path to the project directory]:dir:_directories'
      '-h[Print help]'
      '--help[Print help]'
    )

    case ${words[1]} in
      eval)
        _arguments -s -S \
          $common_flags \
          '-f+[Output format]:format:(json jsonnet pcf plist properties text xml yaml)' \
          '--format=[Output format]:format:(json jsonnet pcf plist properties text xml yaml)' \
          '-o+[Output file path]:file:_files' \
          '--output-path=[Output file path]:file:_files' \
          '-m+[Output directory for multiple file output]:dir:_directories' \
          '--multiple-file-output-path=[Output directory for multiple file output]:dir:_directories' \
          '-x+[Expression to evaluate within the module]:expression' \
          '--expression=[Expression to evaluate within the module]:expression' \
          '*:module:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          $common_flags \
          '--overwrite[Overwrite expected output files]' \
          '*:module:_files' && ret=0
        ;;
      repl)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      server)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      project)
        local -a subcmds=(
          'package:Package a project'
          'resolve:Resolve project dependencies'
        )
        _describe -t subcmds 'project subcommand' subcmds && ret=0
        ;;
      download-package)
        _arguments -s -S \
          '--no-cache[Disable caching]' \
          '--cache-dir=[Cache directory]:dir:_directories' \
          '--no-transitive[Do not download transitive dependencies]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package URI' && ret=0
        ;;
    esac
    ;;
esac

return ret
