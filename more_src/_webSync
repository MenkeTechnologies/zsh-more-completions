#compdef webSync
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/utils/webSync
# download from https server, using files.txt on their end to get the list of files

local ret=1

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-x --connections)'{-x,--connections}'=[max parallel connections to the server, default 10]:n:' \
  '(-s --skipScan)'{-s,--skipScan}'[do not scan local file sizes again]' \
  '*:url:_urls' && ret=0

return ret
