#compdef taskwarrior-tui

_taskwarrior-tui() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '--config=[path to taskwarrior config]:file:_files' \
        '--report=[default report to show]:report:(next list all completed waiting recurring)' \
        '--task-data=[path to task data directory]:dir:_directories' \
        '--task-command=[path to task binary]:file:_files'
}

_taskwarrior-tui "$@"
