#compdef gow

# Zsh completion for gow - Go file watcher

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-e+[file extensions to watch]:extensions' \
  '-w[working directory]:directory:_directories' \
  '-c[clear terminal on restart]' \
  '-s[use polling instead of OS events]' \
  '-g[enable goroutine tracking]' \
  '*:go command and arguments' && ret=0

return ret
