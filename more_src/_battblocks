#compdef battblocks
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/battblocks.html
# Find Bayesian blocks / burst durations (T90, T50) in BAT light curves or events

local ret=1

_arguments -s -S \
  'infile=[input event or light curve data]:infile:_files' \
  'outfile=[output good time interval file]:outfile:_files' \
  'durfile=[output duration measures file T90 T50]:durfile:_files' \
  'nspill=[events to skip per analysis cell]:nspill:' \
  'gaussian=[use Gaussian statistics]:gaussian:(yes no INDEF)' \
  'txx=[burst fluence percentage for duration]:txx:' \
  'tpeak=[sliding window size for peak rate, sec]:tpeak:' \
  'tlookback=[local Bayesian block window, sec]:tlookback:' \
  'burst_tstart=[manual burst start time MET]:burst_tstart:' \
  'burst_tstop=[manual burst stop time MET]:burst_tstop:' \
  'timedel=[internal time quantization size]:timedel:' \
  'ncp_prior=[log prior controlling block sensitivity]:ncp_prior:' \
  'bkgsub=[enable background subtraction]:bkgsub:(yes no)' \
  'breakfile=[GTI file with explicit breakpoints]:breakfile:_files' \
  'timecol=[light curve time column name]:timecol:' \
  'countscol=[light curve rate/counts column name]:countscol:' \
  'errcol=[light curve error column name]:errcol:' \
  'expocol=[per-bin exposure column name]:expocol:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
