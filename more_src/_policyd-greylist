#compdef policyd-greylist
# Documentation: https://man.archlinux.org/search?q=policyd-greylist
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '-d[daemon mode]' \
  '-f[foreground]' \
  '-p+[port]:port:' \
  '-l+[listen address]:addr:' \
  '-v[verbose]' && ret=0

return ret
