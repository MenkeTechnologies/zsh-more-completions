#compdef create-fresh
# Documentation: https://www.npmjs.com/package/create-fresh
# Reference accessed: 2026-05-24
# Verified: npx create-fresh --help.

# Zsh completion for create-fresh - Fresh project scaffolding CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-r --recipe)'{-r,--recipe=}'[recipe name]:recipe:(honeybun tiramisu)' \
  ':directory:_directories' && ret=0

return ret
