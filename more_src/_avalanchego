#compdef avalanchego
# _avalanchego — Ava Labs avalanchego node implementation for the Avalanche network running P-chain X-chain C-chain consensus and Snowman/Avalanche protocol (ava-labs team, Go); cobra
# upstream: https://github.com/ava-labs/avalanchego

_avalanchego() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--config-file=+[file]:file:_files -g "*.json *.yaml *.yml"' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--db-dir=+[dir]:dir:_files -/' \
        '--db-type=+[type]:t:(leveldb pebble memdb)' \
        '--log-dir=+[dir]:dir:_files -/' \
        '--log-level=+[level]:l:(off fatal error warn info debug trace verbo)' \
        '--log-display-level=+[level]:l:(off fatal error warn info debug trace verbo)' \
        '--log-format=+[fmt]:f:(auto plain colors json)' \
        '--http-host=+[host]:str:' \
        '--http-port=+[port]:n:' \
        '--http-tls-enabled[enable TLS]' \
        '--http-tls-cert-file=+[file]:file:_files' \
        '--http-tls-key-file=+[file]:file:_files' \
        '--http-allowed-origins=+[csv]:str:' \
        '--http-allowed-hosts=+[csv]:str:' \
        '--api-admin-enabled[enable admin API]' \
        '--api-info-enabled[enable info API]' \
        '--api-keystore-enabled[enable keystore API]' \
        '--api-metrics-enabled[enable metrics API]' \
        '--api-health-enabled[enable health API]' \
        '--api-ipcs-enabled[enable IPCS API]' \
        '--bootstrap-ips=+[csv]:str:' \
        '--bootstrap-ids=+[csv]:str:' \
        '--network-id=+[id]:i:(mainnet fuji local 5 4 3 2 1)' \
        '--public-ip=+[ip]:str:' \
        '--public-ip-resolution-service=+[svc]:s:(ifconfigCo opendns)' \
        '--public-ip-resolution-frequency=+[d]:str:' \
        '--staking-port=+[port]:n:' \
        '--staking-tls-cert-file=+[file]:file:_files' \
        '--staking-tls-key-file=+[file]:file:_files' \
        '--staking-signer-key-file=+[file]:file:_files' \
        '--staking-enabled[enable staking]' \
        '--snow-sample-size=+[N]:n:' \
        '--snow-quorum-size=+[N]:n:' \
        '--snow-virtuous-commit-threshold=+[N]:n:' \
        '--snow-rogue-commit-threshold=+[N]:n:' \
        '--snow-concurrent-repolls=+[N]:n:' \
        '--snow-optimal-processing=+[N]:n:' \
        '--snow-max-processing=+[N]:n:' \
        '--snow-max-time-processing=+[d]:str:' \
        '--track-subnets=+[csv]:str:' \
        '--plugin-dir=+[dir]:dir:_files -/' \
        '--vm-aliases-file=+[file]:file:_files -g "*.json"' \
        '--chain-aliases-file=+[file]:file:_files -g "*.json"' \
        '--chain-config-dir=+[dir]:dir:_files -/' \
        '--subnet-config-dir=+[dir]:dir:_files -/'
}

_avalanchego "$@"
