#compdef eww

# Zsh completion for eww (ElKowar's Wacky Widgets)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'daemon:Start the eww daemon'
  'open:Open a window'
  'open-many:Open multiple windows'
  'close:Close a window'
  'close-all:Close all windows'
  'reload:Reload the configuration'
  'kill:Kill the eww daemon'
  'state:Print the current state'
  'get:Get the value of a variable'
  'update:Update the value of a variable'
  'inspect:Open the GTK inspector'
  'ping:Ping the eww daemon'
  'logs:Print and watch the logs'
  'shell-completions:Generate shell completions'
  'windows:List all window names'
  'active-windows:List all currently active windows'
)

local -a global_flags=(
  '--config=[Specify the configuration directory]:config dir:_files -/'
  '--debug[Enable debug logging]'
  '--restart[Restart the daemon if it is already running]'
  '--no-daemonize[Do not daemonize the process]'
  '--force-wayland[Force wayland usage]'
  '-h[Print help]'
  '--help[Print help]'
  '-V[Print version]'
  '--version[Print version]'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'eww command' commands && ret=0
    ;;
  args)
    case $words[1] in
      open)
        _arguments -s -S \
          $global_flags \
          '--id=[Set the window ID]:id' \
          '--screen=[Monitor index to open on]:monitor' \
          '--pos=[Position (x,y)]:position' \
          '--size=[Size (width,height)]:size' \
          '--anchor=[Anchor point]:anchor' \
          '--duration=[Auto-close after duration]:duration' \
          '--arg=[Set a window argument (key=value)]:arg' \
          ':window name' && ret=0
        ;;
      close)
        _arguments -s -S \
          $global_flags \
          '*:window name' && ret=0
        ;;
      get)
        _arguments -s -S \
          $global_flags \
          ':variable name' && ret=0
        ;;
      update)
        _arguments -s -S \
          $global_flags \
          '*:variable=value' && ret=0
        ;;
      shell-completions)
        _arguments -s -S \
          $global_flags \
          '--shell=[Shell to generate completions for]:shell:(bash zsh fish)' && ret=0
        ;;
      *)
        _arguments -s -S \
          $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
