#compdef 3dANOVA3
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dANOVA3.html
# AFNI three-factor analysis of variance on datasets

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-type[ANOVA model type 1-5]:k' \
  '-alevels[number of levels for factor A]:a' \
  '-blevels[number of levels for factor B]:b' \
  '-clevels[number of levels for factor C]:c' \
  '*-dset[input dataset for factor level combination]:i' \
  '-voxel[screen output for a specific voxel]:num' \
  '-diskspace[calculate disk space requirements]' \
  '-mask[apply mask using sub-brick 0]:dataset:_files' \
  '-fa[F-statistic for factor A]:prefix' \
  '-fb[F-statistic for factor B]:prefix' \
  '-fc[F-statistic for factor C]:prefix' \
  '-fab[F-statistic for A*B interaction]:prefix' \
  '-fac[F-statistic for A*C interaction]:prefix' \
  '-fbc[F-statistic for B*C interaction]:prefix' \
  '-fabc[F-statistic for A*B*C interaction]:prefix' \
  '*-amean[factor A level mean]:i' \
  '*-bmean[factor B level mean]:i' \
  '*-cmean[factor C level mean]:i' \
  '*-xmean[cell mean at specified factor levels]:i' \
  '*-adiff[pairwise factor A difference]:i' \
  '*-bdiff[pairwise factor B difference]:i' \
  '*-cdiff[pairwise factor C difference]:i' \
  '*-xdiff[difference between two cells]:i' \
  '*-acontr[custom contrast for factor A]:coef' \
  '*-bcontr[custom contrast for factor B]:coef' \
  '*-ccontr[custom contrast for factor C]:coef' \
  '*-abmean[mean at factor A and B levels]:i' \
  '-old_method[use previous computation method]' \
  '-OK[confirmation flag for previous method]' \
  '-assume_sph[assume sphericity for zero-sum contrasts]' \
  '-bucket[create combined bucket dataset]:prefix' \
  '*:dataset:_files' && ret=0

return ret
