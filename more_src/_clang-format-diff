#compdef clang-format-diff clang-format-diff.py

# Zsh completion for clang-format-diff (format changed lines with clang-format)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-i[apply changes in-place]' \
  '-p[strip path prefix]:num' \
  '-regex[custom pattern to filter files]:regex' \
  '-iregex[case-insensitive pattern to filter files]:regex' \
  '-sort-includes[sort include directives]' \
  '-v[verbose output]' \
  '-style[code style]:style:(LLVM GNU Google Chromium Microsoft Mozilla WebKit file)' \
  '-fallback-style[fallback style]:style:(none LLVM GNU Google Chromium Microsoft Mozilla WebKit)' \
  '-binary[path to clang-format]:binary:_files' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
