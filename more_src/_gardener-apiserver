#compdef gardener-apiserver
# _gardener-apiserver — Gardener aggregated API server (garden core APIs)
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-apiserver/app on tip.

_gardener-apiserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--secure-port=[secure-serving bind port]:port:' \
        '--bind-address=[secure-serving bind address]:host:' \
        '--cert-dir=[secure-serving cert directory]:dir:_files -/' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--client-ca-file=[client cert CA file]:file:_files' \
        '--etcd-servers=[csv of etcd servers]:csv:' \
        '--etcd-cafile=[etcd CA cert file]:file:_files' \
        '--etcd-certfile=[etcd client cert file]:file:_files' \
        '--etcd-keyfile=[etcd client key file]:file:_files' \
        '--etcd-prefix=[etcd key prefix]:prefix:' \
        '--authentication-kubeconfig=[delegated authn kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authz kubeconfig]:file:_files' \
        '--kubeconfig=[Gardener kubeconfig file]:file:_files' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '--audit-log-path=[audit log file path]:file:_files' \
        '--audit-policy-file=[audit policy file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_gardener-apiserver "$@"
