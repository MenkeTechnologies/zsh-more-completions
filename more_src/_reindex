#compdef reindex
# Documentation: https://www.ccp4.ac.uk/html/reindex.html
# CCP4: reindex reflections in an MTZ file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN[input MTZ reflection file]:mtz:_files -g "*.mtz"' \
  'HKLOUT[output reindexed MTZ reflection file]:mtz:_files' \
  '*:keyword:(REINDEX SYMMETRY MATCH LEFTHAND NOREDUCE END)' && ret=0

return ret
