#compdef flatpak-cli
# _flatpak-cli — Flatpak desktop application sandbox/distribution CLI alias (Flathub / Alexander Larsson, C); custom argparse
# upstream: https://github.com/flatpak/flatpak

_flatpak-cli() {
    local -a sub=(
        'install:install applications/runtimes'
        'update:update applications/runtimes'
        'uninstall:uninstall applications/runtimes'
        'mask:mask installations from updates'
        'pin:pin runtimes'
        'list:list installed apps and/or runtimes'
        'info:show application/runtime information'
        'history:show history of installations'
        'config:manage flatpak configuration'
        'repair:repair flatpak installation'
        'create-usb:copy installed apps to USB'
        'search:search for apps'
        'run:run an application'
        'override:override permissions'
        'make-current:specify default branch'
        'enter:enter app sandbox'
        'ps:list running apps'
        'kill:stop a running app'
        'document-export:share file with apps'
        'document-unexport:unshare file'
        'document-info:show file info'
        'documents:list shared files'
        'permissions:list permissions'
        'permission-remove:remove permissions'
        'permission-reset:reset permissions'
        'permission-set:set permissions'
        'permission-show:show permissions'
        'remotes:list remote repos'
        'remote-add:add remote repo'
        'remote-delete:delete remote repo'
        'remote-modify:modify remote repo'
        'remote-list:list remote refs'
        'remote-info:show information about a remote ref'
        'build:build dir'
        'build-init:initialize build dir'
        'build-finish:finalize build dir'
        'build-export:export build dir'
        'build-bundle:create OSTree bundle'
        'build-import-bundle:import OSTree bundle'
        'build-sign:sign an application or runtime'
        'build-update-repo:update repo metadata'
        'build-commit-from:create new commit'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ostree-verbose[ostree verbose]' \
        '--user[user installation]' \
        '--system[system installation]' \
        '--installation=+[installation]:str:' \
        '--default-arch[default arch]' \
        '--supported-arches[supported arches]' \
        '--gl-drivers[gl drivers]' \
        '--gpg-import=+[gpg import file]:file:_files' \
        '--no-aliases[no aliases]' \
        '--print-system-only[print system only]' \
        '--print-updated-env[print updated env]' \
        '--columns=+[columns]:str:' \
        '--no-deps[no deps]' \
        '--no-related[no related]' \
        '--no-pull[no pull]' \
        '--no-deploy[no deploy]' \
        '--no-static-deltas[no static deltas]' \
        '--reinstall[reinstall]' \
        '--noninteractive[non interactive]' \
        '-y[assume yes]' \
        '--assumeyes[assume yes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flatpak subcommand' sub ;;
        args)
            case $words[1] in
                install|update|uninstall|info|run|enter|kill|mask|pin|search|history|list|override) _arguments '*:app:' ;;
                remote-add) _arguments \
                    '--if-not-exists[if not exists]' \
                    '--no-gpg-verify[no gpg verify]' \
                    '--prio=+[priority]:n:' \
                    '--title=+[title]:str:' \
                    '--default-branch=+[default branch]:str:' \
                    '*:name-and-url:_urls' ;;
                remote-delete|remote-modify|remote-info|remote-list) _arguments '*:remote:' ;;
                build) _arguments \
                    '--share=+[share]:list:(network ipc)' \
                    '--bind-mount=+[bind mount]:str:' \
                    '--talk-name=+[talk name]:str:' \
                    '--own-name=+[own name]:str:' \
                    '--system-talk-name=+[system talk name]:str:' \
                    '--system-own-name=+[system own name]:str:' \
                    '*:dir:_files -/' ;;
            esac
            ;;
    esac
}

_flatpak-cli "$@"
