#compdef minijail0
# Documentation: https://google.github.io/minijail/minijail0.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-H[print supported syscall names for seccomp]' \
  '-a+[alternate syscall table]:table:' \
  '-b+[bind-mount src,dest[,writable]]:mount spec:' \
  '-B+[skip setting securebits in mask]:bitmask:' \
  '-c+[restrict capabilities (bitmask)]:caps:' \
  '-C+[change root directory]:dir:_files -/' \
  '-d[create new /dev mount]' \
  '-e[enter new network namespace]' \
  '-f+[write jailed process PID to file]:file:_files' \
  '-g+[change group]:group:_groups' \
  '-G[inherit supplementary groups]' \
  '-i[exit immediately after fork]' \
  '-I[run program as init (pid 1)]' \
  '-k+[mount filesystem]:mount spec:' \
  '-K[do not mark mounts as MS_SLAVE]' \
  '-l[run in new IPC namespace]' \
  '-L[report blocked syscalls]' \
  '-m+[uid mapping for user namespace]:map:' \
  '-M+[gid mapping for user namespace]:map:' \
  '-n[set no_new_privs bit]' \
  '-N[run in new cgroup namespace]' \
  '-p[run in new PID namespace]' \
  '-P+[set root filesystem using pivot_root]:dir:_files -/' \
  '-r[remount /proc readonly]' \
  '-R+[set rlimit]:rlimit spec:' \
  '-s[enable seccomp mode 1 (strict)]' \
  '-S+[seccomp filter policy file]:filter:_files' \
  '-t+[mount tmpfs on /tmp]:size:' \
  '-T+[assume binary ELF linkage type]:type:(static dynamic)' \
  '-u+[change user]:user:_users' \
  '-U[enter new user namespace]' \
  '-v[run in new VFS namespace]' \
  '-V+[enter existing VFS namespace]:ns file:_files' \
  '-w[create and join anonymous session keyring]' \
  '-y[keep current user supplementary groups]' \
  '-Y[synchronize seccomp filters across thread group]' \
  '-z[do not forward signals to jailed process]' \
  '--ambient[raise ambient capabilities]' \
  '*--add-suppl-group=[add supplementary group]:group:_groups' \
  '--allow-speculative-execution[allow speculative execution features]' \
  '*--bind-mount=[bind-mount path]:mount spec:' \
  '--config=[use configuration file]:config:_files' \
  '*--env-add=[add env variable]:var=value:' \
  '--env-reset[clear environment]' \
  '--logging=[log destination]:dest:(auto syslog stderr)' \
  '*--mount=[mount filesystem]:mount spec:' \
  '--mount-dev[create new /dev mount]' \
  '--ns-mount=[enter existing VFS namespace]:ns file:_files' \
  '--preload-library=[override preload library path]:lib:_files' \
  '--profile=[choose sandboxing profile]:profile:(minimalistic-mountns)' \
  '--seccomp-bpf-binary=[use pre-compiled seccomp BPF binary]:file:_files' \
  '--uts=[create new UTS/hostname namespace]:hostname:' \
  '*:command:_command_names' && ret=0

return ret
