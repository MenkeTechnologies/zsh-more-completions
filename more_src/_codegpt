# ============================================================================
# _codegpt — zsh completion for appleboy/CodeGPT, "a CLI in Go that
#             writes git commit messages or does code review using ChatGPT"
#             — Go=151 leader bump continuing Axis 96 OpenAI/async-openai
#             via the canonical Go OpenAI SDK sashabaranov/go-openai
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/appleboy/CodeGPT
#   Maintainer : Bo-Yi Wu (appleboy)
#   License    : MIT
#   Stars      : 1498
#   Language   : Go
#   Module     : github.com/appleboy/CodeGPT
#   Binary     : codegpt  (cmd/codegpt/main.go;
#                           rootCmd.Use = "codegpt" inferred
#                           from cmd/cmd.go RootCmd)
#   Last push  : 2026-05-31
#
# WHAT IT IS
#   CodeGPT is "a CLI written in Go that writes git commit
#   messages or does code review using ChatGPT" (or any
#   OpenAI-compatible LLM endpoint).  It can be invoked
#   manually (`codegpt commit`), wired into git via the
#   `prepare-commit-msg` hook (`codegpt hook install`), or run
#   as part of a CI step to auto-review every PR (`codegpt
#   review`).  Config is layered:  a YAML file at
#   `~/.config/codegpt/.codegpt.yaml` for non-secret defaults
#   plus the OS keychain (Keychain on macOS, Secret Service on
#   Linux, Credential Manager on Windows) for the OpenAI API
#   key (migrated automatically from any plaintext value found
#   in the YAML).  Supports OpenAI, Gemini, and any
#   OpenAI-compatible provider via the typed `provider`
#   config.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/cmd.go RootCmd +
#                       per-subcommand cmd/<name>.go —
#                       spf13/cobra v1.10.2)
#   codegpt [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global persistent flags:
#     --config <PATH>                Path to config YAML
#                                    [default: $HOME/.config/
#                                              codegpt/
#                                              .codegpt.yaml]
#     --prompt_folder <DIR>          Prompt folder
#                                    [default: $HOME/.config/
#                                              codegpt/prompt]
#
#   Subcommands:
#     commit                         Automatically generate a
#                                    commit message
#       --preview                      Preview before committing
#       --diff_unified <N>             Unified-diff context
#                                      [default: 3]
#       --model <MODEL>                OpenAI model
#                                      [default: gpt-4o]
#       --lang <CODE>                  Output language
#                                      [default: en]
#       --proxy <URL>                  HTTPS proxy URL
#       --socks <URL>                  SOCKS proxy URL
#       --template_file <PATH>         Template file
#       --template_string <STR>        Inline template string
#       --template_vars_file <PATH>    Template variables file
#       --amend                        Run as `git commit --amend`
#       --prompt_only                  Print the assembled prompt
#                                      and exit (do not call the
#                                      LLM)
#       --no_confirm                   Skip the confirmation
#                                      prompt
#       --file <PATH> / -f <PATH>      Use a diff file instead of
#                                      live git
#       --exclude_list <CSV>           Comma-separated diff
#                                      exclude patterns
#       --stream                       Stream tokens to stdout
#                                      while generating
#
#     review                         Auto-review code changes
#       --diff_unified <N>             Unified-diff context
#                                      [default: 3]
#       --max_tokens <N>               Max completion tokens
#                                      [default: 300]
#       --model <MODEL>                OpenAI model
#                                      [default: gpt-4o]
#       --lang <CODE>                  Summarization language
#       --amend                        Operate on
#                                      `git commit --amend`
#                                      diff range
#       --prompt_only                  Print prompt, do not call
#                                      LLM
#
#     hook <SUBCOMMAND>              Manage the git
#                                    `prepare-commit-msg` hook
#       install                        Install the hook
#       uninstall                      Remove the hook
#
#     config <SUBCOMMAND>            Manage config values
#       list                           List all config values
#       set <key> <value>              Set a config value
#                                      (sensitive keys like
#                                      `openai.api_key` are
#                                      stored in the OS keychain)
#
#     prompt                         Manage prompt templates
#
#     version                        Show version
#
#     completion                     Generate shell completion
#                                    (hidden in `--help` —
#                                    `HiddenDefaultCmd`)
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/sashabaranov/go-openai
#   v1.41.2` declared in go.mod — `go-openai` is THE canonical
#   Go OpenAI SDK maintained by Alexander Baranov (sashabaranov/
#   go-openai, 10K+ stars, ~5M Go module downloads/month;
#   the predominant typed OpenAI client in the Go ecosystem,
#   used by Plandex, Aichat, SGPT, ChatGPT-CLI, and dozens of
#   other Go LLM tools).  go-openai exposes the typed
#   `openai.NewClient(apiKey)` / `openai.NewClientWithConfig(
#   cfg)` constructors, `openai.DefaultAzureConfig` /
#   `openai.DefaultConfig` for Azure / OpenAI / proxy
#   configurations, every Chat Completion / Completion /
#   Embedding / Image / Audio / Moderation / FineTuning /
#   Files / Assistants / Threads / Messages / Runs API as
#   typed `client.<Resource>` namespaces, the typed
#   `ChatCompletionRequest` / `ChatCompletionResponse` /
#   `ChatCompletionStreamResponse` / `Message` / `Function`
#   / `Tool` / `ToolCall` / `ResponseFormat` / `Image*` /
#   `Audio*` / `Embedding*` payloads, server-sent-events
#   streaming via `CreateChatCompletionStream`, automatic
#   retries on rate-limit responses, and the
#   `responses.NewService(...)` v2 Responses-API binding.
#   CodeGPT's `internal/openai/openai.go` uses
#   `client.CreateChatCompletion(ctx, ChatCompletionRequest{
#   Model, Messages, Temperature, MaxTokens, Stream, ...})`
#   to drive every commit-message / code-review generation,
#   piping the streaming response through the cobra TUI.
#   Verified via:
#     gh api repos/appleboy/CodeGPT/contents/go.mod
#       → github.com/sashabaranov/go-openai v1.41.2
#       → github.com/spf13/cobra v1.10.2
#       → module github.com/appleboy/CodeGPT
#     gh api repos/appleboy/CodeGPT/contents/cmd/cmd.go
#       → rootCmd.AddCommand(versionCmd, configCmd, commitCmd,
#           hookCmd, reviewCmd, CompletionCmd, promptCmd)
#       → PersistentFlags --config, --prompt_folder
#     gh api repos/appleboy/CodeGPT/contents/cmd/commit.go
#       → commitCmd.PersistentFlags --preview, --diff_unified,
#           --model, --lang, --proxy, --socks, --template_file,
#           --template_string, --template_vars_file, --amend,
#           --prompt_only, --no_confirm, --file, --exclude_list,
#           --stream
#   This entry is the Go=151 leader bump that continues Axis
#   96 (OpenAI / async-openai SDK) opened at R973 with
#   Rust=async-openai via emk/subtitles-rs (substudy).
#
#   No completion for `codegpt` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_codegpt() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[path to config YAML]:file:_files -g "*.yaml"' \
        '--prompt_folder=[prompt folder]:dir:_files -/' \
        '1: :_codegpt_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                commit)
                    _arguments \
                        '--preview[preview commit message before committing]' \
                        '--diff_unified=[unified-diff context lines (default 3)]:n:' \
                        '--model=[OpenAI model (default gpt-4o)]:model:' \
                        '--lang=[output language (default en)]:lang:(en zh es fr de ja ko ru pt)' \
                        '--proxy=[HTTPS proxy URL]:url:' \
                        '--socks=[SOCKS proxy URL]:url:' \
                        '--template_file=[template file]:file:_files' \
                        '--template_string=[inline template string]:tmpl:' \
                        '--template_vars_file=[template variables file]:file:_files' \
                        '--amend[run as git commit --amend]' \
                        '--prompt_only[print prompt; do not call LLM]' \
                        '--no_confirm[skip confirmation prompt]' \
                        '(-f --file)'{-f,--file}'=[use diff file instead of live git]:file:_files' \
                        '--exclude_list=[CSV of diff exclude patterns]:csv:' \
                        '--stream[stream tokens to stdout]' && ret=0 ;;
                review)
                    _arguments \
                        '--diff_unified=[unified-diff context lines (default 3)]:n:' \
                        '--max_tokens=[max completion tokens (default 300)]:n:' \
                        '--model=[OpenAI model (default gpt-4o)]:model:' \
                        '--lang=[summarization language]:lang:(en zh es fr de ja ko ru pt)' \
                        '--amend[operate on amend diff range]' \
                        '--prompt_only[print prompt; do not call LLM]' && ret=0 ;;
                hook)
                    _arguments \
                        '1:hook subcommand:(install uninstall)' \
                        '*::arg:' && ret=0 ;;
                config)
                    _arguments \
                        '1:config subcommand:(list set)' \
                        '*::arg:' && ret=0 ;;
                prompt|version|completion)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_codegpt_commands] )) ||
_codegpt_commands() {
    local -a commands
    commands=(
        'commit:automatically generate a commit message'
        'review:auto-review code changes'
        'hook:manage the git prepare-commit-msg hook'
        'config:manage config values (list/set)'
        'prompt:manage prompt templates'
        'version:show version'
        'completion:generate shell completion'
    )
    _describe -t commands 'codegpt command' commands
}

_codegpt "$@"
