#compdef akash
# Documentation: https://man.archlinux.org/search?q=akash
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--home=[Akash home directory]:directory:_directories' \
  '--chain-id=[Tendermint chain id]:id:' \
  '--node=[Tendermint RPC endpoint]:url:' \
  '--keyring-backend=[Keyring backend]:backend:(os file test)' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'keys:Manage keys'
      'tx:Build or broadcast transactions'
      'query:Query chain state'
      'debug:Debug helpers'
      'tendermint:Tendermint helpers'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
