#compdef phantom
# Documentation: https://man.archlinux.org/search?q=phantom
# Reference accessed: 2026-05-16

# Zsh completion for phantom (git worktrees; phantompane/phantom)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _values -s 'phantom subcommand' \
      create attach list where delete exec edit ai shell serve preferences version completion mcp github gh && ret=0
    ;;
  rest)
    case $line[1] in
      preferences)
        _values 'preferences' get set remove && ret=0
        ;;
      github|gh)
        _values 'github' checkout && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
