#compdef phantom
# Documentation: https://github.com/aku11i/phantom/blob/main/docs/commands.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for phantom (git worktree manager)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _values -s 'phantom subcommand' \
      create attach list where delete shell exec edit ai preferences project github gh mcp version completion && ret=0
    ;;
  rest)
    case $line[1] in
      preferences)
        _values 'preferences' get set remove && ret=0
        ;;
      project)
        _values 'project' list add remove && ret=0
        ;;
      github|gh)
        _values 'github' checkout && ret=0
        ;;
      mcp)
        _values 'mcp' serve && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
