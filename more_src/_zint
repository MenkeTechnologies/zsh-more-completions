#compdef zint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b[barcode type]:type' \
  '--barcode=[barcode type]:type' \
  '-d[data to encode]:data' \
  '--data=[data to encode]:data' \
  '-i[input file]:file:_files' \
  '--input=[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '--height=[barcode height]:height' \
  '--heightperrow[height per row]' \
  '-w[module width]:width' \
  '--whitesp=[whitespace width]:width' \
  '--border=[border width]:width' \
  '--box[add box around barcode]' \
  '--bind[add boundary bars]' \
  '--mirror[mirror image]' \
  '--rotate=[rotate]:angle:(0 90 180 270)' \
  '--cols=[columns]:columns' \
  '--rows=[rows]:rows' \
  '--vers=[symbol version]:version' \
  '--secure=[error correction level]:level' \
  '--primary=[primary message]:message' \
  '--mode=[encoding mode]:mode' \
  '--eci=[ECI code]:code' \
  '--gs1[use GS1 mode]' \
  '--gssep[use GS separator]' \
  '--binary[binary mode]' \
  '--fg=[foreground color]:color' \
  '--bg=[background color]:color' \
  '--notext[suppress human readable text]' \
  '--bold[use bold text]' \
  '--cmyk[use CMYK colors]' \
  '--dotty[use dots instead of squares]' \
  '--dotsize=[dot size]:size' \
  '--scale=[scale factor]:scale' \
  '--filetype=[output file type]:type:(png gif bmp tif eps svg emf)' \
  '--batch[batch mode]' \
  '--dump[dump hexdump]' \
  '-e[display table of encodings]' \
  '-t[display table of barcodes]' && ret=0

return ret
