#compdef zint
# Documentation: https://man.archlinux.org/man/zint.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (zint.1 manpage).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print usage information]' \
  '(- *)'{-v,--version}'[display zint version]' \
  '(-b --barcode)'{-b+,--barcode=}'[set the barcode symbology]:type:' \
  '--addongap=[EAN/UPC gap between main data and add-on]:n:' \
  '--batch[treat each input file line as separate dataset]' \
  '--bg=[background colour (hex or CMYK)]:colour:' \
  '--binary[treat input as raw 8-bit binary data]' \
  '--bind[add horizontal boundary bars]' \
  '--bindtop[add boundary bar to top only]' \
  '--bold[use bold font for Human Readable Text]' \
  '--border=[width of boundary bars or box borders]:n:' \
  '--box[add box around symbol]' \
  '--cmyk[use CMYK colour space for EPS/TIF output]' \
  '--cols=[number of data columns]:n:' \
  '--compliantheight[warn if height non-compliant]' \
  '(-d --data)'{-d+,--data=}'[input data to encode]:data:' \
  '--direct[send output to stdout]' \
  '--dmiso144[Data Matrix: ISO/IEC standard 144x144 placement]' \
  '--dmre[Data Matrix: allow DMRE sizes]' \
  '--dotsize=[radius of dots in dotty mode]:n:' \
  '--dotty[use dots instead of squares]' \
  '--dump[dump hexadecimal representation]' \
  '(-e --ecinos)'{-e,--ecinos}'[display table of ECIs]' \
  '--eci=[ECI code for input data]:n:' \
  '--embedfont[embed font in vector output]' \
  '--esc[process escape characters in input]' \
  '--extraesc[Code 128: process special escape sequences]' \
  '--fast[use faster encodation]' \
  '--fg=[foreground colour]:colour:' \
  '--filetype=[output file type]:type:(BMP EMF EPS GIF PCX PNG SVG TIF TXT)' \
  '--fullmultibyte[use multibyte modes for non-ASCII data]' \
  '--gs1[treat input as GS1 compatible]' \
  '--gs1nocheck[do not check GS1 validity]' \
  '--gs1parens[treat parentheses as GS1 AI delimiters]' \
  '--gssep[Data Matrix GS1: use GS separator]' \
  '--guarddescent=[EAN/UPC guard bar descent height]:n:' \
  '--guardwhitespace[EAN/UPC: add quiet zone indicators to HRT]' \
  '--height=[symbol height in X-dimensions]:n:' \
  '--heightperrow[treat height as per-row for stacked symbologies]' \
  '(-i --input)'{-i+,--input=}'[read input data from file]:file:_files' \
  '--init[create Reader Initialisation symbol]' \
  '--mask=[masking pattern (DotCode/Han Xin/QR)]:n:' \
  '--mirror[use batch data to determine filename in batch mode]' \
  '--mode=[encoding mode for MaxiCode/GS1 Composite]:n:' \
  '--nobackground[remove background colour]' \
  '--noquietzones[disable quiet zones]' \
  '--notext[remove Human Readable Text]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--primary=[primary content for MaxiCode/GS1 Composite]:message:' \
  '--quietzones[add compliant quiet zones]' \
  '(-r --reverse)'{-r,--reverse}'[reverse foreground and background colours]' \
  '--rotate=[rotate symbol by degrees]:deg:(0 90 180 270)' \
  '--rows=[number of rows for stacked symbologies]:n:' \
  '--scale=[adjust X-dimension size]:n:' \
  '--scalexdimdp=[scale by X-dimension and resolution]:spec:' \
  '--scmvv=[MaxiCode: prefix SCM with vv identifier]:n:' \
  '--secure=[error correction level]:n:' \
  '*--seg1=[set segment 1 ECI and data]:eci,data:' \
  '*--seg2=[set segment 2 ECI and data]:eci,data:' \
  '*--seg3=[set segment 3 ECI and data]:eci,data:' \
  '--separator=[height of row separator bars]:n:' \
  '--small[use smaller font for HRT]' \
  '--square[Data Matrix: exclude rectangular sizes]' \
  '--structapp=[Structured Append info I,C[,ID]]:spec:' \
  '(-t --types)'{-t,--types}'[display table of barcode types]' \
  '--textgap=[gap between barcode and HRT]:n:' \
  '--vers=[symbol version/size]:n:' \
  '--vwhitesp=[vertical whitespace height]:n:' \
  '(-w --whitesp)'{-w+,--whitesp=}'[horizontal whitespace width]:n:' \
  '--werror[convert all warnings into errors]' && ret=0

return ret
