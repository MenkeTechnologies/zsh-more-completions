#compdef fido2-token

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-C[change PIN]' \
  '-D[delete blob, credential, or template]' \
  '-G[get blob or PUAT]' \
  '-I[get info about device or credentials]' \
  '-L[list information]' \
  '-R[reset device]' \
  '-S[set or store data]' \
  '-V[print version]' \
  '-a[verbose listing]' \
  '-b[blob operation]' \
  '-c[show credential]' \
  '-d[debug]' \
  '-e[entry/template]' \
  '-f[force]' \
  '-i+[credential ID or template ID]:id:' \
  '-k+[key path or rpId]:key/rp:' \
  '-l+[pin length]:n:' \
  '-m[memory or migration mode]' \
  '-n+[rp_id, name, or display name]:value:' \
  '-p+[display name]:value:' \
  '-r[show resident credentials]' \
  '-t+[ppuat path]:file:_files' \
  '-u[user]' \
  '*:device / blob / template:_files' && ret=0

return ret
