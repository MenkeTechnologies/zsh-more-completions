#compdef nextflow

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-C[use specified config file]:config file:_files' \
  '-D[set JVM property]:property=value' \
  '-bg[run in background]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '-log[set log file]:log file:_files' \
  '-syslog[send logs to syslog]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'clean:clean project cache and work directories'
      'clone:clone a pipeline repository'
      'config:print resolved pipeline configuration'
      'console:launch Nextflow interactive console'
      'drop:delete a cached pipeline'
      'help:show help for a command'
      'info:show pipeline execution information'
      'inspect:inspect process settings in a pipeline'
      'kuberun:run a pipeline on Kubernetes'
      'list:list cached pipelines'
      'log:show execution log'
      'pull:download or update a pipeline'
      'run:run a pipeline'
      'self-update:update Nextflow'
      'view:view a pipeline script'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '--name=[run name]:name' \
          '-w[work directory]:directory:_directories' \
          '--work-dir=[work directory]:directory:_directories' \
          '-resume[resume last run]' \
          '-profile[configuration profile]:profile' \
          '-params-file=[parameters file]:file:_files -g "*.{json,yaml,yml}"' \
          '-entry=[entry workflow]:workflow' \
          '-r[revision]:revision' \
          '--revision=[revision]:revision' \
          '-latest[pull latest before run]' \
          '-with-report=[HTML report file]:file:_files' \
          '-with-timeline=[timeline report file]:file:_files' \
          '-with-trace=[trace report file]:file:_files' \
          '-with-dag=[DAG file]:file:_files' \
          '-with-docker=[Docker image]:image' \
          '-with-singularity=[Singularity image]:image' \
          '-with-conda=[Conda environment]:env' \
          '-with-tower=[Tower URL]:url' \
          '-bucket-dir=[remote bucket directory]:directory' \
          '-cache=[enable/disable cache]:cache:(true false deep lenient)' \
          '-process.[set process directive]:directive' \
          '-N[send notification email]:email' \
          '--dsl1[enable DSL1 mode]' \
          '--dsl2[enable DSL2 mode]' \
          '--stub[execute in stub mode]' \
          '--stub-run[execute in stub mode]' \
          '-qs[queue size]:size' \
          '-ps[pool size]:size' \
          '(- *)'{-h,--help}'[show help]' \
          '1:pipeline:_files' && ret=0
        ;;
      log)
        _arguments -s -S \
          '-after=[show entries after date]:date' \
          '-before=[show entries before date]:date' \
          '-but=[show all except matching]:filter' \
          '-filter=[filter entries]:filter' \
          '-f[list fields]:fields' \
          '-quiet[only show names]' \
          '-s[list entries by specific field]:field' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '-after=[remove entries after date]:date' \
          '-before=[remove entries before date]:date' \
          '-but=[keep matching entries]:count' \
          '-f[force removal]' \
          '-n[dry run]' \
          '-k[remove only entries in cache]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      pull|clone)
        _arguments -s -S \
          '-r[revision]:revision' \
          '-hub=[repository hub]:hub:(github bitbucket gitlab)' \
          '-user=[hub user name]:user' \
          '(- *)'{-h,--help}'[show help]' \
          '1:pipeline' && ret=0
        ;;
    esac
    ;;
esac

return ret
