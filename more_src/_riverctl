#compdef riverctl
# Documentation: https://man.archlinux.org/man/riverctl.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'close:close the focused view'
  'exit:exit the compositor'
  'focus-output:focus an output'
  'focus-view:focus a view'
  'move:move focused view'
  'resize:resize focused view'
  'snap:snap focused view to edge'
  'send-to-output:move view to output'
  'spawn:run an external command'
  'swap:swap focused view in stack'
  'toggle-float:toggle float for focused view'
  'toggle-fullscreen:toggle fullscreen'
  'zoom:zoom focused view'
  'default-layout:set default layout namespace'
  'output-layout:set output layout namespace'
  'send-layout-cmd:send command to current layout'
  'set-focused-tags:set focused tags'
  'set-view-tags:set tags for focused view'
  'toggle-focused-tags:toggle focused tags'
  'toggle-view-tags:toggle view tags'
  'spawn-tagmask:set spawn tagmask'
  'focus-previous-tags:focus previously focused tags'
  'send-to-previous-tags:send view to previously focused tags'
  'declare-mode:declare a new mode'
  'enter-mode:switch to a mode'
  'map:bind a normal-mode shortcut'
  'map-pointer:bind a pointer button'
  'map-switch:bind a switch shortcut'
  'unmap:remove a normal-mode shortcut'
  'unmap-pointer:remove a pointer binding'
  'unmap-switch:remove a switch shortcut'
  'rule-add:add a rule'
  'rule-del:delete a rule'
  'list-rules:list rules'
  'default-attach-mode:set default attach mode'
  'output-attach-mode:set per-output attach mode'
  'allow-tearing:allow tearing for matching views'
  'background-color:set background color'
  'border-color-focused:set focused border color'
  'border-color-unfocused:set unfocused border color'
  'border-color-urgent:set urgent border color'
  'border-width:set border width'
  'focus-follows-cursor:set focus follows cursor'
  'hide-cursor:configure cursor hiding'
  'set-cursor-warp:set cursor warp mode'
  'set-repeat:set keyboard repeat'
  'xcursor-theme:set XCursor theme'
  'list-inputs:list input devices'
  'list-input-configs:list input configs'
  'keyboard-layout:set keyboard layout'
  'keyboard-layout-file:set keyboard layout file'
  'input:configure input devices'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'riverctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (map|unmap)
        _arguments \
          '-release[on release]' \
          '-repeat[repeat while held]' \
          '-layout=[layout id]:n:' \
          '*::mode_modifiers_key_command:' && ret=0 ;;
      (default-attach-mode|output-attach-mode)
        _arguments '*::mode:(top bottom above below after)' && ret=0 ;;
      (set-cursor-warp)
        _arguments '*::mode:(disabled on-output-change on-focus-change)' && ret=0 ;;
      (rule-add|rule-del)
        _arguments \
          '-app-id=[app id]:id:' \
          '-title=[window title]:title:' \
          '*::action:' && ret=0 ;;
    esac ;;
esac

return ret
