#compdef cockroach

# Zsh completion for CockroachDB CLI

local curcontext="$curcontext" state line ret=1

local -a cockroach_commands
cockroach_commands=(
  'auth-session:log in and out of HTTP sessions'
  'cert:create CA, node, and client certificates'
  'connect:connect and configure the cluster'
  'debug:debugging commands'
  'demo:open a demo SQL shell'
  'dump:dump SQL tables'
  'gen:generate auxiliary files'
  'import:import a db or table from dump files'
  'init:initialize a cluster'
  'login:create a HTTP session and token'
  'logout:invalidate a HTTP session'
  'mt:multi-tenant commands'
  'node:list, inspect, drain, or remove nodes'
  'nodelocal:upload and delete nodelocal files'
  'quit:drain and shut down a node'
  'sql:open a SQL shell'
  'sqlfmt:reformat SQL queries'
  'start:start a node'
  'start-single-node:start a single-node cluster'
  'statement-diag:manage statement diagnostics'
  'userfile:upload, list, and delete user-scoped files'
  'version:print the CockroachDB version'
  'workload:generators for data and query loads'
  'zip:gather cluster debug data'
)

local -a cockroach_global_flags
cockroach_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--log=[logging configuration]:config:'
  '--log-config-file=[log config file]:file:_files'
  '--log-dir=[directory for log files]:directory:_directories'
)

_arguments -s -S \
  $cockroach_global_flags \
  '--version[print version]' \
  '1:command:_describe -t commands command cockroach_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      start)
        _arguments -s -S \
          $cockroach_global_flags \
          '--accept-sql-without-tls[accept SQL connections without TLS]' \
          '--advertise-addr=[address to advertise to other nodes]:address:' \
          '--attrs=[node attributes]:attrs:' \
          '--background[run in the background]' \
          '--cache=[total size for caches]:size:' \
          '--certs-dir=[path to certificate directory]:directory:_directories' \
          '--cluster-name=[cluster name]:name:' \
          '--disable-cluster-name-verification[disable cluster name verification]' \
          '--external-io-dir=[external IO directory]:directory:_directories' \
          '--http-addr=[address for the Admin UI]:address:' \
          '--insecure[run in insecure mode]' \
          '--join=[addresses to join]:addresses:' \
          '--listen-addr=[address/port to listen on]:address:' \
          '--locality=[locality info]:locality:' \
          '--locality-advertise-addr=[advertised address by locality]:locality=addr:' \
          '--max-disk-temp-storage=[max disk temp storage]:size:' \
          '--max-go-memory=[max Go runtime memory]:size:' \
          '--max-offset=[max allowed clock offset]:duration:' \
          '--max-sql-memory=[max memory for SQL layer]:size:' \
          '--pid-file=[PID file]:file:_files' \
          '--sql-addr=[address for SQL connections]:address:' \
          '--store=[path and attributes for a store]:store spec:' \
          '-s=[path and attributes for a store]:store spec:' \
          '--temp-dir=[directory for temporary files]:directory:_directories' \
          '--wal-failover=[WAL failover configuration]:config:' && ret=0
        ;;
      start-single-node)
        _arguments -s -S \
          $cockroach_global_flags \
          '--accept-sql-without-tls[accept SQL connections without TLS]' \
          '--advertise-addr=[address to advertise]:address:' \
          '--background[run in the background]' \
          '--cache=[total size for caches]:size:' \
          '--certs-dir=[certificate directory]:directory:_directories' \
          '--external-io-dir=[external IO directory]:directory:_directories' \
          '--http-addr=[Admin UI address]:address:' \
          '--insecure[run in insecure mode]' \
          '--listen-addr=[address/port to listen on]:address:' \
          '--max-disk-temp-storage=[max disk temp storage]:size:' \
          '--max-sql-memory=[max memory for SQL]:size:' \
          '--pid-file=[PID file]:file:_files' \
          '--sql-addr=[address for SQL connections]:address:' \
          '--store=[store path and attributes]:store spec:' \
          '-s=[store path and attributes]:store spec:' \
          '--temp-dir=[temp directory]:directory:_directories' && ret=0
        ;;
      sql)
        _arguments -s -S \
          $cockroach_global_flags \
          '--certs-dir=[certificate directory]:directory:_directories' \
          '-d=[database name]:database:' \
          '--database=[database name]:database:' \
          '-e=[execute SQL and exit]:SQL statement:' \
          '--execute=[execute SQL and exit]:SQL statement:' \
          '-f=[read SQL from file]:file:_files' \
          '--file=[read SQL from file]:file:_files' \
          '--format=[output format]:format:(tsv csv table records sql html raw)' \
          '--host=[database server host]:host:' \
          '--insecure[use insecure connection]' \
          '-p=[database server port]:port:' \
          '--port=[database server port]:port:' \
          '--safe-updates[restrict SQL for safer operations]' \
          '--set=[set client-side option]:option=value:' \
          '--url=[connection URL]:url:' \
          '-u=[database user name]:user:' \
          '--user=[database user name]:user:' \
          '--watch=[repeat SQL at interval]:duration:' && ret=0
        ;;
      demo)
        _arguments -s -S \
          $cockroach_global_flags \
          '--auto-demo-stats[inject stats automatically]' \
          '--cache=[total size for caches]:size:' \
          '--demo-locality=[locality per node]:locality:' \
          '--disable-demo-license[disable trial license]' \
          '-e=[execute SQL and exit]:SQL statement:' \
          '--execute=[execute SQL and exit]:SQL statement:' \
          '--geo-partitioned-replicas[simulate geo-partitioned replicas]' \
          '--global[simulate global cluster]' \
          '--http-port=[port for UI per node]:port:' \
          '--insecure[run in insecure mode]' \
          '--max-sql-memory=[max SQL memory]:size:' \
          '--multitenant[run in multi-tenant mode]' \
          '--nodes=[number of demo nodes]:count:' \
          '--no-example-database[do not create example databases]' \
          '--sql-port=[port for SQL per node]:port:' \
          '--with-load[run a demo workload]' \
          '1:dataset:(movr startrek intro tpcc)' && ret=0
        ;;
      init)
        _arguments -s -S \
          $cockroach_global_flags \
          '--certs-dir=[certificate directory]:directory:_directories' \
          '--host=[node address]:host:' \
          '--insecure[use insecure connection]' \
          '--port=[node port]:port:' && ret=0
        ;;
      cert)
        local -a cert_commands
        cert_commands=(
          'create-ca:create the CA certificate and key'
          'create-client:create a client certificate and key'
          'create-node:create a node certificate and key'
          'list:list certificates in the cert directory'
        )
        _arguments -s -S \
          $cockroach_global_flags \
          '1:cert command:_describe -t commands command cert_commands' \
          '*::cert args:->cert_args' && ret=0
        case "$state" in
          cert_args)
            case "${line[1]}" in
              create-ca)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--allow-ca-key-reuse[allow reuse of CA key]' \
                  '--ca-key=[path to CA key]:key:_files' \
                  '--certs-dir=[certificate directory]:directory:_directories' \
                  '--lifetime=[certificate lifetime]:duration:' \
                  '--overwrite[overwrite existing files]' && ret=0
                ;;
              create-node)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--ca-key=[path to CA key]:key:_files' \
                  '--certs-dir=[certificate directory]:directory:_directories' \
                  '--lifetime=[certificate lifetime]:duration:' \
                  '--overwrite[overwrite existing files]' \
                  '*:host or IP:' && ret=0
                ;;
              create-client)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--also-generate-pkcs8-key[generate PKCS8 key too]' \
                  '--ca-key=[path to CA key]:key:_files' \
                  '--certs-dir=[certificate directory]:directory:_directories' \
                  '--lifetime=[certificate lifetime]:duration:' \
                  '--overwrite[overwrite existing files]' \
                  '1:username:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--certs-dir=[certificate directory]:directory:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      node)
        local -a node_commands
        node_commands=(
          'decommission:decommission nodes'
          'drain:drain a node'
          'ls:list nodes'
          'recommission:recommission decommissioned nodes'
          'status:show the status of nodes'
        )
        _arguments -s -S \
          $cockroach_global_flags \
          '1:node command:_describe -t commands command node_commands' \
          '*::node args:->node_args' && ret=0
        case "$state" in
          node_args)
            case "${line[1]}" in
              ls|status)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--all[show all node details]' \
                  '--certs-dir=[certificate directory]:directory:_directories' \
                  '--decommission[show decommission status]' \
                  '--format=[output format]:format:(tsv csv table records sql html raw)' \
                  '--host=[node address]:host:' \
                  '--insecure[use insecure connection]' \
                  '--port=[node port]:port:' \
                  '--ranges[show range/replica information]' \
                  '--stats[show stats information]' && ret=0
                ;;
              decommission|recommission)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--certs-dir=[certificate directory]:directory:_directories' \
                  '--host=[node address]:host:' \
                  '--insecure[use insecure connection]' \
                  '--port=[node port]:port:' \
                  '--self[target the node connected to]' \
                  '--wait=[when to return]:wait:(all none)' \
                  '*:node ID:' && ret=0
                ;;
              drain)
                _arguments -s -S \
                  $cockroach_global_flags \
                  '--certs-dir=[certificate directory]:directory:_directories' \
                  '--drain-wait=[max time to wait for drain]:duration:' \
                  '--host=[node address]:host:' \
                  '--insecure[use insecure connection]' \
                  '--port=[node port]:port:' \
                  '--self[drain the node connected to]' && ret=0
                ;;
              *)
                _arguments -s -S $cockroach_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      zip)
        _arguments -s -S \
          $cockroach_global_flags \
          '--certs-dir=[certificate directory]:directory:_directories' \
          '--host=[node address]:host:' \
          '--insecure[use insecure connection]' \
          '--nodes=[nodes to collect from]:node ids:' \
          '--port=[node port]:port:' \
          '--redact-logs[redact sensitive data from logs]' \
          '--cpu-profile-duration=[CPU profile duration]:duration:' \
          '1:output file:_files' && ret=0
        ;;
      workload)
        local -a workload_commands
        workload_commands=(
          'check:check consistency of a workload'
          'fixtures:fixtures for workloads'
          'init:initialize a workload'
          'run:run a workload'
        )
        _arguments -s -S \
          $cockroach_global_flags \
          '1:workload command:_describe -t commands command workload_commands' \
          '*::workload args:' && ret=0
        ;;
      sqlfmt)
        _arguments -s -S \
          $cockroach_global_flags \
          '-e=[SQL statement to format]:SQL:' \
          '--execute=[SQL statement to format]:SQL:' \
          '--len=[desired column line length]:length:' \
          '--no-simplify[do not simplify output]' \
          '--print-width=[desired line width]:width:' \
          '--tab-width=[tab width]:width:' \
          '--use-spaces[use spaces instead of tabs]' && ret=0
        ;;
      import)
        local -a import_commands
        import_commands=(
          'db:import a database from dump files'
          'table:import a table from dump files'
        )
        _arguments -s -S \
          $cockroach_global_flags \
          '1:import command:_describe -t commands command import_commands' \
          '*::import args:' && ret=0
        ;;
      *)
        _arguments -s -S $cockroach_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
