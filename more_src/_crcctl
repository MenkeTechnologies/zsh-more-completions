#compdef crc
# _crcctl — RedHat OpenShift Local crc (single-node OpenShift / podman-machine on a laptop; subcommands: setup, start, stop, status, delete, ip, ssh, console, oc-env, podman-env, config, version, bundle, cluster, telemetry; common flags --memory, --cpus, --disk-size, --pull-secret-file, --preset)
# upstream: https://github.com/crc-org/crc
# Subcommands from crc cmd/crc on tip.

_crcctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--log-level+[log level]:level:(trace debug info warn error fatal)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'crc command' '(setup start stop delete cleanup status ip ssh console config oc-env podman-env version bundle telemetry update web-console openshift-oc admin)' ;;
        args)
            case $line[1] in
                start) _arguments \
                    '--memory+[memory MiB]:mb:' \
                    '-m+[memory MiB]:mb:' \
                    '--cpus+[cpu count]:n:' \
                    '-c+[cpu count]:n:' \
                    '--disk-size+[disk GiB]:gb:' \
                    '-d+[disk GiB]:gb:' \
                    '--pull-secret-file+[pull secret file]:file:_files' \
                    '-p+[pull secret file]:file:_files' \
                    '-b+[bundle path]:file:_files' \
                    '--bundle+[bundle path]:file:_files' \
                    '--preset+[preset]:preset:(microshift okd openshift)' \
                    '--nameserver+[nameserver]:ns:' \
                    '-n+[nameserver]:ns:' ;;
                config) _describe -t commands 'config subcommand' '(get set unset view)' ;;
                bundle) _describe -t commands 'bundle subcommand' '(list use generate)' ;;
                cluster) _describe -t commands 'cluster subcommand' '(monitoring status)' ;;
                admin) _describe -t commands 'admin subcommand' '(replicas validate)' ;;
            esac
            ;;
    esac
}

_crcctl "$@"
