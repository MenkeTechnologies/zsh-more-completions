#compdef roc-cli2 roc2
# _roc-cli2 — Richard Feldman Roc Lang roc-cli2 CLI command-line frontend wrapping the Roc fast friendly functional language open-source written in Rust originally Richard Feldman heavily inspired by Elm pure functional statically typed compiled to LLVM no-runtime-errors-by-design with platforms applications optimal mode dev mode incremental build run test check repl docs format glue build dev edit fmt help main app platform CommandLine TCP HTTP webserver-effect cliplatform Web Effect Module-System (Richard Feldman Roc Lang team, Rust); clap
# upstream: https://www.roc-lang.org/

_roc-cli2() {
    local -a sub=(
        'build:Build a binary from given file'
        'check:Check the code for problems'
        'dev:Combine the run and check commands'
        'docs:Generate documentation'
        'edit:Open the file in your editor'
        'format:Format a file or directory'
        'fmt:Format a file or directory'
        'glue:Generate platform glue code'
        'help:Print help'
        'preprocess-host:Preprocess a host module'
        'repl:Launch the REPL'
        'run:Compile and run a program'
        'test:Run all tests in the file'
        'version:Print version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--target=+[t]:t:(system linux-x86_64 linux-x32 macos-x86_64 macos-arm64 windows-x86_64 wasm32)' \
        '--lib[build a lib]' \
        '--no-link[skip linking]' \
        '--prebuilt-platform[prebuilt platform]' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--optimize[optimize]' \
        '--dev[dev mode]' \
        '--linker=+[l]:l:(legacy surgical)' \
        '--profile[profile]' \
        '--time[show time]' \
        '--max-threads=+[N]:n:' \
        '--check[check only]' \
        '--build-host[build host]' \
        '--suppress-build-host-warning[suppress build host warning]' \
        '--threading=+[m]:m:(single multi)' \
        '--main=+[name]:str:' \
        '--watch[watch mode]' \
        '-w[watch]' \
        '--bundle[bundle]' \
        '--emit-llvm-ir[emit LLVM IR]' \
        '--no-fmt-check[no format check]' \
        '--fuzz[fuzz mode]' \
        '--check-tag-stack[check tag stack]' \
        '--unstable=+[features]:str:' \
        '*--unstable=+[features]:str:' \
        '--standalone[standalone]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'roc subcommand' sub ;;
        args)
            case $words[1] in
                build|check|run|test|dev|format|fmt|docs|edit|preprocess-host|glue) _arguments '*:roc file:_files -g "*.roc"' ;;
                repl) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_roc-cli2 "$@"
