#compdef blkcat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/blkcat.html
# Source: sleuthkit/sleuthkit man/blkcat.1 — display the contents of file system data units (formerly dcat).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a -h -w)-a[display contents in ASCII]' \
    '(-a -h -w)-h[display contents in hexdump]' \
    '(-a -h -w)-w[display contents in HTML table format]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 raw blkls swap list)' \
    '-s[display statistics (unit size, file block size, fragment count)]' \
    '-u[size of default data unit for raw/blkls/swap images]:unit size:' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-v[verbose output to stderr]' \
    '-V[display version]' \
    '*:image file or block addr:_files' \
    && ret=0

return ret
