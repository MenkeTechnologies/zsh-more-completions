#compdef lxd-cli2 lxd2
# _lxd-cli2 — Canonical LXD lxd-cli2 CLI command-line frontend wrapping the LXD container hypervisor and system manager daemon next-generation system container manager open-source written in Go originally Canonical now Linux Containers project LXC powered single binary daemon REST-API networking storage live-migration sock client-server lxd-init activateifneeded callhook cluster forkconsole forkdns forkexec forkfile forkgetfile forkmigrate forkmount forknetns forkproxy forkstart forkuevent forkstats forklimits forkzfs migratedumpsuccess waitready init startup recover shutdown daemon import sql cluster sql sqltool (Canonical Linux Containers team Stéphane Graber, Go); cobra
# upstream: https://linuxcontainers.org/lxd/

_lxd-cli2() {
    local -a sub=(
        'activateifneeded:activate the daemon if needed'
        'callhook:hook called by containers'
        'cluster:cluster operations'
        'completion:generate shell completion'
        'daemon:run as daemon'
        'forkconsole:forked console'
        'forkdns:forked DNS server'
        'forkexec:forked exec'
        'forkfile:forked file'
        'forkmigrate:forked migrate'
        'forknet:forked netns'
        'forkmount:forked mount'
        'forkproxy:forked proxy'
        'forkstart:forked start'
        'forkuevent:forked uevent'
        'forkzfs:forked ZFS'
        'help:show help'
        'import:import a backup tarball'
        'init:initialize LXD'
        'manpage:generate man pages'
        'netcat:netcat-like tool'
        'recover:recover daemon state'
        'shutdown:shutdown the daemon'
        'sql:run SQL on local DB'
        'sqltool:open SQL tool'
        'version:show version'
        'waitready:wait until daemon is ready'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--logfile=+[file]:file:_files' \
        '--syslog[log to syslog]' \
        '--trace=+[component]:str:' \
        '*--trace=+[component]:str:' \
        '--cpuprofile=+[file]:file:_files' \
        '--memprofile=+[file]:file:_files' \
        '--auto[automated init]' \
        '--minimal[minimal init]' \
        '--network-address=+[host]:_hosts' \
        '--network-port=+[port]:n:' \
        '--storage-backend=+[name]:n:(dir zfs btrfs lvm ceph cephfs cephobject)' \
        '--storage-create-device=+[path]:_files' \
        '--storage-create-loop=+[size]:n:' \
        '--storage-pool=+[name]:str:' \
        '--trust-password=+[password]:str:' \
        '--dump[dump preseed]' \
        '--group=+[name]:_groups' \
        '--preseed[read preseed from stdin]' \
        '--target=+[node]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--description=+[text]:str:' \
        '--cluster-token=+[token]:str:' \
        '--cluster-address=+[host:port]:_hosts' \
        '--enable-ipv4[enable IPv4]' \
        '--enable-ipv6[enable IPv6]' \
        '--all[all instances]' \
        '--force[force]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--timeout=+[sec]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lxd subcommand' sub ;;
        args)
            case $words[1] in
                cluster) _arguments '1:op:(list show list-database revoke-token enable add-token remove evacuate restore set-state edit get-current-leader rebuild)' '*:arg:' ;;
                sql) _arguments '1:db:(local global)' '*:query:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                manpage) _arguments '*:dir:_files -/' ;;
            esac
            ;;
    esac
}

_lxd-cli2 "$@"
