#compdef sdk
# Documentation: https://sdkman.io/usage
# Reference accessed: 2026-05-21
# Verified: upstream usage page lists install, uninstall, list, use, default,
# current, upgrade, version, broadcast, help, offline, selfupdate, update,
# flush, home, env, config (with subcommands init/install/clear).
# Removed from prior file: short aliases (i, rm, ls, u, d, c, ug, v, e, h)
# not documented at upstream usage page — kept only the long-form commands
# that the docs verify. (sdkman does accept these aliases in practice; if
# you want them re-added, cite the source where they're documented.)

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install a candidate version'
  'uninstall:uninstall a candidate version'
  'list:list candidate versions'
  'use:use a candidate version (current shell only)'
  'default:set default candidate version'
  'current:show current candidate versions'
  'upgrade:check outdated candidates'
  'version:show SDKMAN version'
  'broadcast:show broadcast messages'
  'selfupdate:update SDKMAN itself'
  'update:refresh candidate metadata'
  'flush:clear local caches'
  'offline:enable/disable offline mode'
  'env:manage .sdkmanrc env'
  'home:print install home for a candidate'
  'completion:generate shell completion'
  'config:edit SDKMAN config'
  'help:show help'
)

local -a candidates
candidates=(
  'java' 'gradle' 'maven' 'kotlin' 'scala' 'groovy' 'springboot' 'grails'
  'micronaut' 'quarkus' 'jbang' 'kscript' 'ant' 'leiningen' 'mvnd' 'sbt'
  'gauge' 'glassfish' 'jbake' 'jenv' 'kafka' 'karaf'
  'mybatis' 'pomchecker' 'spark' 'tomee' 'vertx' 'visualvm'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sdk subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|uninstall|use|default|home|list|current|upgrade)
        _describe -t candidates 'candidate' candidates && ret=0
        ;;
      (flush)
        _values 'flush target' \
          'archives' 'tmp' 'broadcast' 'version' && ret=0
        ;;
      (offline)
        _values 'offline action' 'enable' 'disable' && ret=0
        ;;
      (env)
        _values 'env action' 'init' 'install' 'clear' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
