#compdef sdk

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install a candidate version'
  'i:install a candidate version'
  'uninstall:uninstall a candidate version'
  'rm:uninstall a candidate version'
  'list:list candidate versions'
  'ls:list candidate versions'
  'use:use a candidate version (current shell)'
  'u:use a candidate version (current shell)'
  'default:set default candidate version'
  'd:set default candidate version'
  'current:show current candidate versions'
  'c:show current candidate versions'
  'upgrade:upgrade installed candidates'
  'ug:upgrade installed candidates'
  'version:show SDKMAN! version'
  'v:show SDKMAN! version'
  'selfupdate:update SDKMAN! itself'
  'update:update candidate metadata'
  'flush:clear caches'
  'offline:enable/disable offline mode'
  'env:manage .sdkmanrc env'
  'e:manage .sdkmanrc env'
  'home:print install home for a candidate'
  'h:print install home for a candidate'
  'completion:generate shell completion'
  'config:edit SDKMAN config'
  'help:show help'
)

local -a candidates
candidates=(
  'java' 'gradle' 'maven' 'kotlin' 'scala' 'groovy' 'springboot' 'grails'
  'micronaut' 'quarkus' 'jbang' 'kscript' 'ant' 'leiningen' 'mvnd' 'sbt'
  'cuba' 'gauge' 'glassfish' 'java' 'jbake' 'jenv' 'kafka-tools' 'karaf'
  'mybatis' 'pomchecker' 'spark' 'tomee' 'vertx' 'visualvm'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sdk subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|i|uninstall|rm|use|u|default|d|home|h|list|ls|current|c|upgrade|ug)
        _describe -t candidates 'candidate' candidates && ret=0
        ;;
      (flush)
        _values 'flush target' \
          'archives' 'tmp' 'broadcast' 'version' 'candidates' && ret=0
        ;;
      (offline)
        _values 'offline action' 'enable' 'disable' && ret=0
        ;;
      (env|e)
        _values 'env action' 'init' 'install' 'clear' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
