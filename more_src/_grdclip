#compdef grdclip
# Documentation: https://docs.generic-mapping-tools.org/latest/grdclip.html
# Source: GenericMappingTools/gmt src/grdclip.c — clip grid values to specified bounds (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files -g "*.{grd,nc}"' \
    '-R+[region]:region:_default' \
    '-Sa+[set values above to new value]:value:_default' \
    '-Sb+[set values below to new value]:value:_default' \
    '-Si+[set values inside range to new value]:range:_default' \
    '-Sr+[replace specific value with another]:from/to:_default' \
    '*-V[verbose (stackable)]' \
    '1:input grid:_files -g "*.{grd,nc}"' \
    && ret=0

return ret
