#compdef druid-tools druidctl
# _druid-tools — Apache Druid druid-tools druidctl CLI command-line frontend wrapping the Apache Druid real-time analytics database internal-tools providing coordinator overlord broker historical middlemanager indexer router CLI subcommands for running services dump-segment hash-by-segment-id pull-deps validate-druid-config print-events index data-loader (Apache Druid team, Java); custom argparse
# upstream: https://druid.apache.org/

_druid-tools() {
    local -a sub=(
        'coordinator:run coordinator'
        'overlord:run overlord'
        'historical:run historical'
        'broker:run broker'
        'router:run router'
        'middleManager:run middle manager'
        'indexer:run indexer'
        'tools:tools'
        'dump-segment:dump segment'
        'hash-by-segment-id:hash by segment id'
        'pull-deps:pull dependencies'
        'reset-cluster:reset cluster'
        'insert-segment-to-db:insert segment metadata'
        'export-metadata:export metadata'
        'validate-druid-config:validate config'
        'index:run an index task'
        'data-loader:data loader'
        'print-events:print events'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--config-overrides-file=+[file]:file:_files' \
        '--log-level=+[l]:l:(TRACE DEBUG INFO WARN ERROR FATAL)' \
        '--no-progress[disable progress]' \
        '--jvm-config=+[file]:file:_files' \
        '--server-config=+[file]:file:_files -g "*.properties"' \
        '--coordinator-url=+[url]:str:' \
        '--broker-url=+[url]:str:' \
        '--overlord-url=+[url]:str:' \
        '--router-url=+[url]:str:' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'druid-tools subcommand' sub ;;
    esac
}

_druid-tools "$@"
