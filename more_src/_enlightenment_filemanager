#compdef enlightenment_filemanager
# Documentation: https://man.archlinux.org/search?q=enlightenment_filemanager
# Reference accessed: 2026-05-16

# enlightenment_filemanager: stand-alone E file manager (efm)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:dir:_files -/' && ret=0
return ret
