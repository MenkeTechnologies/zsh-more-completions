#compdef enlightenment_filemanager
# Documentation: https://www.enlightenment.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# enlightenment_filemanager: stand-alone E file manager (efm)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:dir:_files -/' && ret=0
return ret
