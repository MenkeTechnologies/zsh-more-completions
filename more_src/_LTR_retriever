#compdef LTR_retriever
# Documentation: https://github.com/oushujun/LTR_retriever
# Accurate identification of LTR retrotransposons and library construction

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-genome=[genome sequence file (FASTA)]:file:_files' \
  '-inharvest=[LTR-RT candidates from LTRharvest]:file:_files' \
  '-infinder=[LTR-RT candidates from LTR_FINDER]:file:_files' \
  '-inmgescan=[LTR-RT candidates from MGEScan_LTR]:file:_files' \
  '-nonTGCA=[non-canonical LTR-RT candidates from LTRharvest]:file:_files' \
  '(-v -verbose)'{-v,-verbose}'[retain intermediate outputs]' \
  '-noanno[disable whole genome LTR-RT annotation]' \
  '-wholeelement[keep LTR-RTs as whole elements in library]' \
  '-misschar=[ambiguous character]:char:' \
  '-Nscreen[disable filtering ambiguous sequence in candidates]' \
  '-missmax=[maximum number of ambiguous bp allowed]:int:' \
  '-missrate=[maximum percentage of ambiguous bp allowed]:rate:' \
  '-minlen=[minimum bp of the LTR region]:int:' \
  '-max_ratio=[maximum length ratio of internal/LTR region]:float:' \
  '-minscore=[minimum alignment length for tandem repeats]:int:' \
  '-flankmiss=[maximum ambiguous length in 60bp flanking sequences]:int:' \
  '-flanksim=[minimum percentage identity for flanking alignment]:int:' \
  '-flankaln=[maximum alignment portion for flanking sequences]:float:' \
  '-motif=[non-canonical motifs to search for]:motif:' \
  '-notrunc[discard truncated and nested LTR-RTs]' \
  '-procovTE=[maximum portion for DNA TE/LINE alignments]:float:' \
  '-procovPL=[maximum portion for plant protein alignments]:float:' \
  '-prolensig=[minimum alignment length for protein matches]:int:' \
  '-blastclust=[use blastclust with optional custom parameters]:params:' \
  '-cdhit=[use cd-hit-est with optional custom parameters]:params:' \
  '-linelib=[LINE transposase database (FASTA)]:file:_files' \
  '-dnalib=[DNA TE transposase database (FASTA)]:file:_files' \
  '-plantprolib=[plant protein database (FASTA)]:file:_files' \
  '-TEhmm=[Pfam database for TE identification]:file:_files' \
  '-repeatmasker=[path to RepeatMasker program]:dir:_files -/' \
  '-blastplus=[path to BLAST+ program]:dir:_files -/' \
  '-blast=[path to BLAST program]:dir:_files -/' \
  '-cdhit_path=[path to CD-HIT program]:dir:_files -/' \
  '-hmmer=[path to HMMER program]:dir:_files -/' \
  '-trf_path=[path to trf program]:dir:_files -/' \
  '-tesorter=[path to TEsorter program]:dir:_files -/' \
  '-u=[neutral mutation rate per bp per year]:rate:' \
  '(-m -model)'{-m,-model}'=[gap-compressed distance model]:model:(K2P JC69 pdist)' \
  '-step=[restart from particular step]:step:(Init Major Trunc Promask Library Next)' \
  '-stop=[stop after specified step]:step:(Init Major Trunc Promask Library Next)' \
  '-salvage=[recycle TEsorter and HMM classification files]:flag:(0 1)' \
  '-convert_seq_name=[convert sequence names/encode IDs]:flag:(0 1)' \
  '-threads=[number of threads]:int:' && ret=0

return ret
