#compdef paleofetch
# Documentation: https://github.com/ss7m/paleofetch
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above. Only --recache is documented;
# previous file invented -c/-r/-h/-v flags not present in the upstream source.

# Zsh completion for paleofetch - neofetch written in C

local curcontext="$curcontext" ret=1

_arguments -s \
  '--recache[ignore cache and repopulate it]' && ret=0

return ret
