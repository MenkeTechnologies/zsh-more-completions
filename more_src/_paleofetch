#compdef paleofetch
# Documentation: https://man.archlinux.org/search?q=paleofetch
# Reference accessed: 2026-05-16

# Zsh completion for paleofetch - fast system fetch written in C

local -a arguments

arguments=(
  '-c[clear the cache before running]'
  '-r[ignore the cache for this run]'
  '-h[show help information]'
  '-v[show paleofetch version]'
)

_arguments -s $arguments
