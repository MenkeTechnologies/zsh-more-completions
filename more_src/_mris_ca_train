#compdef mris_ca_train
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_ca_train
# FreeSurfer: train a surface classifier array (GCS) from labeled subjects

local ret=1

_arguments -s -S \
  '(- *)--help[print help info]' \
  '(- *)--version[print version info]' \
  '-sdir[subjects directory]:dir:_files -/' \
  '-nbrs[neighborhood size (default 2)]:number' \
  '-orig[original surface filename (default smoothwm)]:filename' \
  '-norm1[GCSA normalize input #1 after reading]' \
  '-norm2[GCSA normalize input #2 after reading]' \
  '-norm3[GCSA normalize input #3 after reading]' \
  '-ic[priors and classifiers params (default 7 4)]:number_priors:number_classifiers' \
  '-sulc[use sulc as only input]' \
  '-sulconly[use sulc as only input]' \
  '-a[number of averages (default 5)]:number' \
  '-t[parcellation table input file]:filename:_files' \
  '-v[diagnostic level]:number' \
  '-n[number of inputs (default 1)]:number' \
  '*:argument:_files' && ret=0

return ret
