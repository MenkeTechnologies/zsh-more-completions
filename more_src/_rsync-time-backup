#compdef rsync-time-backup rsync_tmbackup.sh
# Documentation: https://github.com/laurent22/rsync-time-backup
# Reference accessed: 2026-05-17
# Verified: laurent22/rsync-time-backup upstream rsync_tmbackup.sh
# flag surface (-p/--port, -i/--id_rsa, --rsync-get-flags,
# --rsync-set-flags, --rsync-append-flags, --log-dir,
# --log-to-destination, --strategy, --no-auto-expire, -h/--help).
# Removed from prior file: bogus man.archlinux.org search URL.

_arguments -s \
  '(-p --port)'{-p,--port}'=[SSH port]:port:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --id_rsa)'{-i,--id_rsa}'=[SSH key]:file:_files' \
  '--rsync-get-flags[print default flags]' \
  '--rsync-set-flags=[replace flags]:flags:' \
  '--rsync-append-flags=[append flags]:flags:' \
  '--log-dir=[log dir]:dir:_files -/' \
  '--log-to-destination[log to dest]' \
  '--strategy=[expiration strategy]:strategy:' \
  '--no-auto-expire[no auto expire]' \
  '1:source:_files' \
  '2:destination:_files' \
  '3:exclude file:_files'
