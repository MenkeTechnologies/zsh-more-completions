#compdef beagle
# Documentation: https://faculty.washington.edu/browning/beagle/beagle_5.4_18Mar22.pdf
# Beagle: genotype phasing and imputation (key=value arguments)

local ret=1

_arguments -s -S \
  '*gt=[input genotype file (VCF)]:file:_files -g "*.vcf*"' \
  '*ref=[reference panel for imputation]:file:_files' \
  '*out=[output file prefix]:prefix' \
  '*map=[genetic map file]:file:_files' \
  '*chrom=[chromosome(s) to analyze]:chrom' \
  '*impute=[enable/disable imputation]:bool:(true false)' \
  '*gp=[output genotype probabilities]:bool:(true false)' \
  '*ne=[effective population size]:int' \
  '*err=[error rate]:float' \
  '*window=[analysis window size in cM]:cm' \
  '*overlap=[overlap between analysis windows in cM]:cm' \
  '*seed=[random seed]:int' \
  '*nthreads=[number of processor threads]:int' \
  '*burnin=[maximum burn-in iterations]:int' \
  '*iterations=[number of phasing iterations]:int' \
  '*phase-states=[number of model states for phasing]:int' \
  '*imp-states=[number of model states for imputation]:int' && ret=0

return ret
