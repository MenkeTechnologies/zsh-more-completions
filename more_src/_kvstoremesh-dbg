#compdef kvstoremesh-dbg
# _kvstoremesh-dbg — Cilium KVStoreMesh debug CLI
# upstream: https://github.com/cilium/cilium
# Subcommands + flags from clustermesh-apiserver/kvstoremesh-dbg/root.go on tip.

_kvstoremesh-dbg() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-H --host)'{-H,--host=}'[KVStoreMesh server-side API URI]:uri:_urls' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'status:show KVStoreMesh sync status'
                'troubleshoot:run guided KVStoreMesh diagnostic flows'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_kvstoremesh-dbg "$@"
