#compdef argocd-image-updater

# Zsh completion for argocd-image-updater (ArgoCD image auto-updater)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'help:show help'
      'run:run the image updater'
      'test:test image update configuration'
      'version:show version'
    )
    _describe -t commands 'argocd-image-updater command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (run)
        _arguments \
          '--argocd-server-addr[ArgoCD server address]:address' \
          '--argocd-auth-token[ArgoCD auth token]:token' \
          '--argocd-insecure[use insecure connection]' \
          '--argocd-plaintext[use plaintext connection]' \
          '--argocd-namespace[ArgoCD namespace]:namespace' \
          '--applications-api[applications API]:api:(argocd kubernetes)' \
          '--check-interval[check interval]:duration' \
          '--dry-run[dry run]' \
          '--health-port[health check port]:port' \
          '--kubeconfig[path to kubeconfig]:file:_files' \
          '--loglevel[log level]:level:(trace debug info warn error)' \
          '--max-concurrency[max concurrent updates]:count' \
          '--metrics-port[metrics port]:port' \
          '--once[run once and exit]' \
          '--registries-conf-path[registries config]:file:_files' \
          '--warmup-time[warmup time]:duration' && ret=0
        ;;
      (test)
        _arguments \
          '--image[image to test]:image' \
          '--update-strategy[update strategy]:strategy:(semver latest name digest)' \
          '--allow-tags[allow tags matching regex]:regex' \
          '--ignore-tags[ignore tags matching regex]:regex' \
          '--credentials[credentials]:user\:password' \
          '--registries-conf-path[registries config]:file:_files' \
          '--loglevel[log level]:level:(trace debug info warn error)' && ret=0
        ;;
    esac
    ;;
esac

return ret
