#compdef nbdev_test
# Documentation: https://nbdev.fast.ai/api/test.html
# nbdev_test: test notebooks in an nbdev project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--path=[notebook name or glob to test]:path:_files' \
  '--flags=[space separated list of test flags to run that are normally ignored]:flags:' \
  '--n_workers=[number of workers]:n:' \
  '--timing[time each notebook to see which are slow]' \
  '--do_print[print start and end of each notebook]' \
  '--pause=[pause time in seconds between notebooks]:seconds:' \
  '--ignore_fname=[filename that will result in siblings being ignored]:fname:' \
  '--verbose[print stdout/stderr from notebook cells]' \
  '--save[write outputs back to notebooks on success]' \
  '--symlinks[follow symlinks]' \
  '--file_glob=[only include files matching glob]:glob:' \
  '--file_re=[only include files matching regex]:regex:' \
  '--folder_re=[only enter folders matching regex]:regex:' \
  '--skip_file_glob=[skip files matching glob]:glob:' \
  '--skip_file_re=[skip files matching regex]:regex:' \
  '--skip_folder_re=[skip folders matching regex]:regex:' && ret=0

return ret
