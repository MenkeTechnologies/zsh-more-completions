#compdef addlicense
# Documentation: https://github.com/google/addlicense
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# addlicense — https://github.com/google/addlicense — flags documented in README (-c -check -f -ignore -l -s -v -y).

local ret=1

_arguments -s -S \
  '-check[verify headers only; nonzero if missing]' \
  '-c+[copyright holder]:holder' \
  '-f+[path to license text file]:file:_files' \
  '-ignore+[doublestar ignore pattern]:pattern' \
  '-l+[license type]:type:(apache bsd mit mpl)' \
  '-s+[SPDX in header; use -s=only for SPDX-only]' \
  '-v[verbose: print modified files]' \
  '-y+[copyright year(s)]:year' \
  '*:path pattern:_files' && ret=0

return ret
