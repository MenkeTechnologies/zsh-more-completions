#compdef efivar-tools efivar
# Documentation: https://man.archlinux.org/search?q=efivar-tools
# Reference accessed: 2026-05-16

# efivar(-tools): EFI variable manipulation
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-l[list variables]' \
  '--list[list variables]' \
  '-p[print a specific variable]' \
  '--print[print a specific variable]' \
  '-A[print attributes only]' \
  '--print-attributes[print attributes only]' \
  '-D[delete variable]' \
  '--delete[delete variable]' \
  '-n[variable name]:name:' \
  '--name=[variable name]:name:' \
  '-w[write variable]' \
  '--write[write variable]' \
  '-a[append to variable]' \
  '--append[append to variable]' \
  '-L[list-guids]' \
  '--list-guids[list-guids]' \
  '-t[attributes (e.g. 7)]:attr:' \
  '--attributes=[attributes (e.g. 7)]:attr:' \
  '-f[file with variable value]:file:_files' \
  '--fromfile=[file with variable value]:file:_files' \
  '*::efivar args:_files' && ret=0
return ret
