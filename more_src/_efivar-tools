#compdef efivar-tools efivar efisecdb
# Documentation: https://manpages.debian.org/experimental/efivar/efivar.1
# Reference accessed: 2026-05-17
# Verified: Debian efivar package manpages — UEFI variable
# manipulation flags (-l/--list, -p/--print, -n/--name, -A/--append,
# -L/--list-guids, -w/--write, -f/--datafile (real flag, not
# --fromfile), -t/--attributes, -d/--print-decimal, -D/--delete,
# -e/--export, -i/--import). efisecdb has its own flag set.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --fromfile (real is --datafile), --print-attributes
# (no such flag on efivar).

# efivar(-tools): EFI variable manipulation
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-l[list variables]' \
  '--list[list variables]' \
  '-p[print a specific variable]' \
  '--print[print a specific variable]' \
  '-d[print decimal]' \
  '--print-decimal[print decimal]' \
  '-e[export raw to file]:file:_files' \
  '--export=[export raw to file]:file:_files' \
  '-i[import raw from file]:file:_files' \
  '--import=[import raw from file]:file:_files' \
  '-D[delete variable]' \
  '--delete[delete variable]' \
  '-n[variable name]:name:' \
  '--name=[variable name]:name:' \
  '-w[write variable]' \
  '--write[write variable]' \
  '-a[append to variable]' \
  '--append[append to variable]' \
  '-L[list-guids]' \
  '--list-guids[list-guids]' \
  '-t[attributes (e.g. 7)]:attr:' \
  '--attributes=[attributes (e.g. 7)]:attr:' \
  '-f[file with variable value]:file:_files' \
  '--datafile=[file with variable value]:file:_files' \
  '*::efivar args:_files' && ret=0
return ret
