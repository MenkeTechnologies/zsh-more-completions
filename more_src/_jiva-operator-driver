#compdef jiva-operator-driver
# _jiva-operator-driver — OpenEBS Jiva CSI driver (one binary, runs as controller or node plugin per --plugin)
# upstream: https://github.com/openebs/jiva-operator
# Flags from cmd/csi/main.go on tip (cobra).

_jiva-operator-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--nodeid=[NodeID identifying the node running this driver]:id:' \
        '--version=[display driver version]:ver:' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--name=[name of this driver]:name:' \
        '--plugin=[driver mode]:mode:(controller node)' \
        '--enableiscsidebug[enable iscsi debug logs]' \
        '--retrycount=[max retries while waiting for volume to become ready]:n:' \
        '--metricsBindAddress=[TCP address for Prometheus metrics]:addr:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_jiva-operator-driver "$@"
