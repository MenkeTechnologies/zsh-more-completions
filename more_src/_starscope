#compdef starscope
# Documentation: https://github.com/eapache/starscope/blob/main/doc/USER_GUIDE.md
# Code indexer and query tool (cscope/ctags export)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show available options]' \
  '(-v --version)'{-v,--version}'[display version number]' \
  '(-q --query)'{-q,--query}'+[query database: [FILTERS,]TABLE,QUERY]:query:' \
  '(-e --export)'{-e,--export}'+[export to format]:format:(ctags cscope)' \
  '--export-path=[custom export file location]:path:_files' \
  '(-d --dump)'{-d,--dump}'+[dump tables to raw text]:table:' \
  '(-f --file)'{-f,--file}'+[database file (default .starscope.db)]:db:_files' \
  '*'{-x,--exclude}'+[exclude paths matching pattern]:pattern:' \
  '(-s --summary)'{-s,--summary}'[show current database contents summary]' \
  '--no-read[skip reading existing database]' \
  '--no-write[skip writing database file]' \
  '--no-update[skip updating database]' \
  '--force-update[re-scan all files and directories]' \
  '(-l --line-mode)'{-l,--line-mode}'[enter interactive query mode]' \
  '--quiet[suppress non-critical output]' \
  '--verbose[provide detailed processing output]' \
  '*:file:_files' && ret=0

return ret
