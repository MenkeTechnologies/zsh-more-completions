#compdef jack-scope
# Documentation: https://github.com/jackaudio/jack-example-tools
# an oscilloscope for JACK

local ret=1

_arguments -s -S \
  '-b+[frame size of the displayed data]:frames' \
  '-d+[delay interval in milliseconds between updates]:ms' \
  '-f+[store a still image of each frame to directory]:directory:_files -/' \
  '-m+[scope operating mode]:mode:(signal embed)' \
  '-n+[number of channels / JACK input ports]:count' \
  '-p+[pattern of JACK ports to connect to]:pattern' \
  '-u+[UDP port to listen for OSC packets on]:port' \
  '-w+[scope size in pixels]:pixels' && ret=0

return ret
