#compdef jxl_from_tree
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/jxl_from_tree.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input tree text:_files -g "*.txt"' \
  '2:output JXL:_files -g "*.jxl"' \
  '3::tree drawing:_files' && ret=0

return ret
