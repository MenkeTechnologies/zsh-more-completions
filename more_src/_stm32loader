#compdef stm32loader
# Documentation: https://github.com/florisla/stm32loader
# Flash firmware to STM32 microcontrollers over serial using Python

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --port)'{-p,--port}'=[serial port]:port:_files' \
  '(-b --baud)'{-b,--baud}'=[baud rate]:baud' \
  '(-f --family)'{-f,--family}'=[device family]:family:(F0 F1 F3 F4 F7 H7 L4 L0 G0 NRG)' \
  '(-e --erase)'{-e,--erase}'[erase before writing]' \
  '(-w --write)'{-w,--write}'[write file content to flash]' \
  '(-v --verify)'{-v,--verify}'[verify flash content versus local file]' \
  '(-r --read)'{-r,--read}'[read from flash into local file]' \
  '(-l --length)'{-l,--length}'=[length of read or erase]:length' \
  '(-a --address)'{-a,--address}'=[target address]:address' \
  '(-g --go-address)'{-g,--go-address}'=[start executing at address]:address' \
  '(-V --verbose)'{-V,--verbose}'[verbose mode]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-s --swap-rts-dtr)'{-s,--swap-rts-dtr}'[swap RTS and DTR signals]' \
  '(-R --reset-active-high)'{-R,--reset-active-high}'[make RESET active high]' \
  '(-B --boot0-active-low)'{-B,--boot0-active-low}'[make BOOT0 active low]' \
  '*:file:_files' && ret=0

return ret
