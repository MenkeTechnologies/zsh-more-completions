#compdef miri

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run the main binary of the local package'
      'test:run the tests of the local package'
      'setup:set up Miri for the current toolchain'
    )
    _describe -t commands 'cargo miri command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run|test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[package to run]:package:' \
          '--package=[package to run]:package:' \
          '--lib[run lib target]' \
          '--bin=[run specified binary]:binary:' \
          '--example=[run specified example]:example:' \
          '--test=[run specified test]:test:' \
          '--features=[features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' \
          '--release[run in release mode]' \
          '--target=[target triple]:target:' \
          '-j+[number of parallel jobs]:jobs:' \
          '--jobs=[number of parallel jobs]:jobs:' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '-Zmiri-disable-validation[disable memory validity checks]' \
          '-Zmiri-disable-stacked-borrows[disable Stacked Borrows checks]' \
          '-Zmiri-disable-data-race-detector[disable data race detection]' \
          '-Zmiri-disable-alignment-check[disable alignment checks]' \
          '-Zmiri-disable-abi-check[disable ABI compatibility checks]' \
          '-Zmiri-isolation-error=[isolation error behavior]:behavior:(abort warn warn-nobacktrace hide)' \
          '-Zmiri-seed=[random seed]:seed:' \
          '-Zmiri-symbolic-alignment-check[enable symbolic alignment checking]' \
          '-Zmiri-tag-gc=[garbage collect tags]:interval:' \
          '-Zmiri-track-alloc-id=[track allocation ID]:id:' \
          '-Zmiri-track-pointer-tag=[track pointer tag]:tag:' \
          '-Zmiri-tree-borrows[use Tree Borrows instead of Stacked Borrows]' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
