#compdef filegone filegone-bpfcc
# _filegone — trace file deletions / renames (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/filegone.py (argparse).

_filegone() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
    )
    _arguments $args
}

_filegone "$@"
