#compdef difx2fits
# Documentation: https://difx.readthedocs.io/en/latest/sources/difx_programs.html
# DiFX: convert DiFX correlator output to FITS-IDI format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information and exit]' \
  '(-n --no-model)'{-n,--no-model}'[do not write model (ML) table]' \
  '(-s --scale)'{-s,--scale}'[scale visibility data by scale]:scale' \
  '(-t --deltat)'{-t,--deltat}'[generate .jobmatrix file with time intervals]:interval' \
  '--difx-tsys-interval[DiFX-derived tsys interval (sec)]:interval' \
  '--difx-pcal-interval[DiFX-derived pcal interval (sec)]:interval' \
  '(-S --sniff-all)'{-S,--sniff-all}'[sniff all bins and phase centers]' \
  '(-T --sniff-time)'{-T,--sniff-time}'[use interval as sniffer time resolution]:interval' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-d --difx)'{-d,--difx}'[run on all .difx files in directory]' \
  '(-k --keep-order)'{-k,--keep-order}'[do not sort the antennas by name]' \
  '(-1 --dont-combine)'{-1,--dont-combine}'[make separate FITS file for each input job]' \
  '(-x --dont-sniff)'{-x,--dont-sniff}'[do not generate sniffer output files]' \
  '(-0 --zero)'{-0,--zero}'[do not put visibility data in FITS file]' \
  '--bin[select on this pulsar bin number]:bin' \
  '--phasecentre[create FITS file for pth phase centers]:p' \
  '--override-version[ignore difx version clashes]' \
  '--bandpass[write the .bandpass file]' \
  '(-m --max-jobs)'{-m,--max-jobs}'[split into more FITS files after nJob input files]:nJob' \
  '--eop-merge-mode[conditions for merging jobs with different EOPs]:mode' \
  '--clock-merge-mode[conditions for merging jobs with different clock models]:mode' \
  '--antpol[use antenna-based polarization labels as in VEX]' \
  '--polxy2hv[re-label all polarizations XY to HV]' \
  '*:base filename:_files' && ret=0

return ret
