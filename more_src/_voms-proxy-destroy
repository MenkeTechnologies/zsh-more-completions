#compdef voms-proxy-destroy
# Documentation: https://manpages.debian.org/testing/voms-clients-java/voms-proxy-destroy.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# voms-proxy-destroy: delete a VOMS proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,-help}'[display usage]' \
  '(- *)'{-v,-version}'[display version]' \
  '-debug[enable extra debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, minimal output]' \
  '(-f -file)'{-f,-file}'+[proxy file in non-standard place]:file:_files' \
  '-dry[do not actually destroy the proxy]' \
  '(-c -conf)'{-c,-conf}'+[read options from file]:file:_files' \
  '*::voms-proxy-destroy args:_files' && ret=0
return ret
