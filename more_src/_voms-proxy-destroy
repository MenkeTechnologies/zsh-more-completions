#compdef voms-proxy-destroy
# Documentation: https://man.archlinux.org/search?q=voms-proxy-destroy
# Reference accessed: 2026-05-16

# voms-proxy-destroy: delete a VOMS proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-q[quiet]' \
  '-file[proxy file]:file:_files' \
  '-conf[config file]:file:_files' \
  '-dry[dry-run]' \
  '*::voms-proxy-destroy args:_files' && ret=0
return ret
