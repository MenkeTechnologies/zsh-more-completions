#compdef pay-respects

# Zsh completion for pay-respects (iffse/pay-respects, core/src/args.rs). Wrapper / init mode uses shell name; bare invocation continues to interactive modes.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --alias)'{-a,--alias}'::alias name for generated function (default f):' \
  '--nocnf[disable command-not-found integration]' \
  '1::shell:(bash zsh fish nu xonsh pwsh)'
