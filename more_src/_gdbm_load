#compdef gdbm_load
# Documentation: gdbm_load --help (GNU GDBM)
# Source: load a GDBM database from a dump file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--usage[short usage]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-M --mmap)'{-M,--mmap}'[use memory mapping]' \
    '(-U --update)'{-U,--update}'[update existing database]' \
    '(-b --block-size)'{-b+,--block-size=}'[block size]:bytes:' \
    '(-c --cache-size)'{-c+,--cache-size=}'[cache size]:n:' \
    '(-m --mode)'{-m+,--mode=}'[file mode]:mode:' \
    '(-n --no-meta)'{-n,--no-meta}'[do not set file metadata]' \
    '(-r --replace)'{-r,--replace}'[replace existing records (with -U)]' \
    '(-u --user)'{-u+,--user=}'[file owner NAME|UID[:NAME|GID]]:user:_users' \
    '1:dump file:_files' \
    '2:gdbm file:_files' \
    && ret=0

return ret
