#compdef dcd-client dcd-server
# Documentation: https://github.com/dlang-community/DCD
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dlang-community/DCD ships both dcd-client and dcd-server.

local prog="${words[1]:t}"

case "$prog" in
  dcd-server)
    _arguments -s -S \
      '*-I+[add import search path]:path:_files -/' \
      '(-p --port)'{-p+,--port=}'[port to listen on (default 9166)]:port:' \
      '--tcp[use TCP sockets instead of UNIX domain sockets]' \
      '--socketFile=[override default socket file path]:file:_files' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '*:args:_files'
    ;;
  *)
    # dcd-client
    _arguments -s -S \
      '-c+[byte position of cursor for autocomplete]:byte:' \
      '--extended[extended output]' \
      '(-d --doc)'{-d,--doc}'[print ddoc for symbol at cursor]' \
      '--clearCache[clear server autocomplete cache]' \
      '*-I+[add import search path]:path:_files -/' \
      '*-R+[remove import search path]:path:_files -/' \
      '(-l --symbolLocation)'{-l,--symbolLocation}'[find declaration of symbol]' \
      '(-s --search)'{-s,--search}'[search for symbols by name]:name:' \
      '(-u --localUse)'{-u,--localUse}'[find uses of symbol in current module]' \
      '--inlayHints[emit inlay hints]' \
      '--shutdown[shut down server]' \
      '--tcp[use TCP sockets]' \
      '(-p --port)'{-p+,--port=}'[port]:port:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '*:source file:_files -g "*.(d|di)"'
    ;;
esac
