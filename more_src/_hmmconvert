#compdef hmmconvert
# HMMER: convert profile file to various HMMER formats

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-a -b -2)-a[output profiles in ASCII text format (default)]' \
  '(-a -b -2)-b[output profiles in binary format]' \
  '(-a -b -2)-2[output in legacy HMMER2 ASCII text format]' \
  '--outfmt=[output HMMER3 ASCII format: 3/a through 3/f]:format:(3/a 3/b 3/c 3/d 3/e 3/f)' \
  '*:hmm file:_files' && ret=0

return ret
