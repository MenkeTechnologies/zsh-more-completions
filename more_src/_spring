#compdef spring

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run a Spring Boot Groovy script'
  'jar:package an application as an executable jar'
  'init:initialize a new project from start.spring.io'
  'shell:start the embedded shell'
  'install:install Spring Boot CLI extensions'
  'uninstall:uninstall extensions'
  'encodepassword:encode a password for Spring Security'
  'help:show help for a command'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'spring subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--autoconfigure=[autoconfigure]:flag:(true false)' \
          '(--classpath -cp)'{--classpath=,-cp=}'[classpath]:cp:' \
          '--no-guess-dependencies[do not guess dependencies]' \
          '--no-guess-imports[do not guess imports]' \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '--watch[watch for file changes]' \
          '*:script:_files -g "*.groovy"' && ret=0
        ;;
      (init)
        _arguments \
          '(-a --artifact-id)'{-a,--artifact-id=}'[artifact id]:id:' \
          '(-b --boot-version)'{-b,--boot-version=}'[Spring Boot version]:version:' \
          '--build=[build system]:system:(maven gradle)' \
          '(-d --dependencies)'{-d,--dependencies=}'[dependencies]:deps:' \
          '(-g --group-id)'{-g,--group-id=}'[group id]:id:' \
          '(-j --java-version)'{-j,--java-version=}'[Java version]:version:' \
          '(-l --language)'{-l,--language=}'[language]:lang:(java groovy kotlin)' \
          '--list[list available metadata]' \
          '(-p --packaging)'{-p,--packaging=}'[packaging]:packaging:(jar war)' \
          '(-x --extract)'{-x,--extract=}'[extract location]:dir:_files -/' && ret=0
        ;;
      (uninstall)
        _arguments \
          '--all[uninstall all extensions]' && ret=0
        ;;
    esac
    ;;
esac

return ret
