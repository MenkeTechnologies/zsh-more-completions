#compdef dsconf
# Documentation: https://github.com/389ds/389-ds-base/blob/main/src/lib389/cli/dsconf
# Reference accessed: 2026-05-16
# Verified: upstream src/lib389/cli/dsconf.

# dsconf: 389-DS configuration CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'backend:backend management'
  'backup:backup operations'
  'chaining:chaining configuration'
  'config:server configuration'
  'directory_manager:Directory Manager password'
  'logging:log configuration'
  'monitor:monitoring'
  'plugin:plugin management'
  'pwpolicy:password policy'
  'replication:replication'
  'conflicts:replication conflicts'
  'saslmappings:SASL mappings'
  'security:security configuration'
  'schema:schema management'
)
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose tracing]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(-D --binddn)'{-D,--binddn=}'[bind DN]:dn:' \
  '(-w --bindpw)'{-w,--bindpw=}'[bind password]:password:' \
  '(-W --prompt)'{-W,--prompt}'[prompt for bind password]' \
  '(-y --pwdfile)'{-y,--pwdfile=}'[bind password file]:file:_files' \
  '(-b --basedn)'{-b,--basedn=}'[base DN]:dn:' \
  '(-Z --starttls)'{-Z,--starttls}'[connect with StartTLS]' \
  '1:instance:' \
  '2: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'dsconf command' commands && ret=0 ;;
esac
return ret
