#compdef crwl
# Documentation: https://github.com/unclecode/crawl4ai
# Reference accessed: 2026-05-23
# Verified: crwl --help (crawl4ai PyPI console script).

# Zsh completion for crwl - Crawl4AI web crawling CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-B --browser-config)'{-B+,--browser-config=}'[browser config YAML/JSON]:file:_files' \
  '(-C --crawler-config)'{-C+,--crawler-config=}'[crawler config YAML/JSON]:file:_files' \
  '(-f --filter-config)'{-f+,--filter-config=}'[content filter config]:file:_files' \
  '(-e --extraction-config)'{-e+,--extraction-config=}'[extraction strategy config]:file:_files' \
  '(-j --json-extract)'{-j+,--json-extract=}'[LLM structured extraction prompt]:prompt:' \
  '(-s --schema)'{-s+,--schema=}'[JSON schema for extraction]:file:_files' \
  '(-b --browser)'{-b+,--browser=}'[browser params key=value,...]:params:' \
  '(-c --crawler)'{-c+,--crawler=}'[crawler params key=value,...]:params:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(all json markdown md markdown-fit md-fit)' \
  '(-O --output-file)'{-O+,--output-file=}'[write output to file]:file:_files' \
  '(-bc --bypass-cache)'{-bc,--bypass-cache}'[bypass crawl cache]' \
  '(-q --question)'{-q+,--question=}'[ask about crawled content]:question:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-p --profile)'{-p+,--profile=}'[browser profile name]:profile:' \
  '--deep-crawl[deep crawl strategy]:strategy:(bfs dfs best-first)' \
  '--max-pages[max pages in deep crawl]:n:' \
  '--json-ensure-ascii[escape non-ASCII in JSON]' \
  '--no-json-ensure-ascii[do not escape non-ASCII in JSON]' \
  ':URL:_urls' && ret=0

return ret
