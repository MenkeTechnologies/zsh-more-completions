#compdef digger

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-p,--project}'[project name]:project' \
  '--config[config file path]:file:_files' \
  '--no-backend[disable backend]' \
  '--no-init[skip terraform init]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'plan:run terraform plan'
      'apply:run terraform apply'
      'destroy:run terraform destroy'
      'unlock:unlock terraform state'
      'run:run arbitrary terraform command'
      'drift:detect infrastructure drift'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      plan|apply|destroy|unlock|run|drift)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-p,--project}'[project name]:project' && ret=0
        ;;
    esac
    ;;
esac

return ret
