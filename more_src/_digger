#compdef digger
# Documentation: https://github.com/diggerhq/digger
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# diggerhq/digger CLI orchestrates Terraform/OpenTofu in CI. Subcommands per
# docs: plan (lock + terraform plan), apply (terraform apply + unlock),
# unlock (release PR locks).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --project)'{-p,--project}'=[project name]:project' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'plan:lock PR and run terraform plan on affected projects'
      'apply:run terraform apply on affected projects and unlock'
      'unlock:unlock projects in current PR'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      plan|apply|unlock)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --project)'{-p,--project}'=[project name]:project' && ret=0
        ;;
    esac
    ;;
esac

return ret
