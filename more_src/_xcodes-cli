#compdef xcodes-cli
# _xcodes-cli — Robotsandpencils xcodes Xcode version manager CLI alias (Robots & Pencils, Swift); custom argparse
# upstream: https://github.com/RobotsAndPencils/xcodes

_xcodes-cli() {
    local -a sub=(
        'download:download specific Xcode'
        'install:install specific Xcode'
        'installed:list installed Xcodes'
        'list:list available Xcodes'
        'runtimes:simulator runtimes commands'
        'select:select active Xcode'
        'signout:sign out from Apple'
        'update:fetch latest available Xcode list'
        'uninstall:uninstall an Xcode'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-aria2[do not use aria2]' \
        '--no-color[no color]' \
        '--data-source=+[data source]:s:(apple xcodeReleases)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xcodes subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--latest[install latest]' \
                    '--latest-prerelease[install latest prerelease]' \
                    '--directory=+[install dir]:dir:_files -/' \
                    '-d+[install dir]:dir:_files -/' \
                    '--path=+[install xip path]:file:_files -g "*.xip *.dmg"' \
                    '-p+[install xip path]:file:_files -g "*.xip *.dmg"' \
                    '--experimental-unxip[experimental unxip]' \
                    '--no-color[no color]' \
                    '--update[update list before install]' \
                    '--empty-trash[empty trash after install]' \
                    '--select[select after install]' \
                    '*:version:' ;;
                download) _arguments \
                    '--latest[download latest]' \
                    '--latest-prerelease[download latest prerelease]' \
                    '--directory=+[download dir]:dir:_files -/' \
                    '-d+[download dir]:dir:_files -/' \
                    '--no-color[no color]' \
                    '*:version:' ;;
                uninstall|select) _arguments \
                    '*:version-or-path:' ;;
                runtimes) _arguments \
                    '1:cmd:(install download)' \
                    '--latest[latest]' \
                    '--include-betas[include betas]' \
                    '*:runtime:' ;;
                signout) _arguments '*:arg:' ;;
                installed|list|update) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_xcodes-cli "$@"
