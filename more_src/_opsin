#compdef opsin
# Documentation: https://github.com/dan2097/opsin
# OPSIN - Open Parser for Systematic IUPAC Nomenclature (name to structure)

local ret=1

_arguments -s -S \
  '-h[show help dialog]' \
  '(-osmi -ocml -oinchi -ostdinchi -ostdinchikey)-osmi[output SMILES]' \
  '(-osmi -ocml -oinchi -ostdinchi -ostdinchikey)-ocml[output CML]' \
  '(-osmi -ocml -oinchi -ostdinchi -ostdinchikey)-oinchi[output InChI with FixedH layer]' \
  '(-osmi -ocml -oinchi -ostdinchi -ostdinchikey)-ostdinchi[output StdInChI]' \
  '(-osmi -ocml -oinchi -ostdinchi -ostdinchikey)-ostdinchikey[output StdInChIKey]' \
  '*:name file:_files' && ret=0

return ret
