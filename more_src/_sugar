# -----------------------------------------------------------------------------
#
# WHY dialoguer IS THE 73RD RUST CLI LIBRARY
#
# dialoguer is the canonical Rust interactive-prompt library.
# Built on Armin Ronacher's `console` crate (low-level terminal
# manipulation), dialoguer provides high-level prompt widgets
# that handle keyboard events, validation, themes, and history
# — abstracting away the imperative cursor-positioning + ANSI-
# escape work that raw `console` requires.
#
# Five distinguishing characteristics:
#
#   1. WIDGET-FIRST DESIGN — each prompt type is a Rust struct
#      with chainable setters + interact()-style terminal
#      methods.  Distinct from a single-function readline
#      API (Rust's std::io::stdin().read_line()) or a multi-
#      function API (rustyline's editor + helper + completer).
#
#   2. BUILDER PATTERN — Input::new() → with_prompt() →
#      default() → with_initial_text() → validate_with() →
#      history_with() → interact_text() returns Result<String>.
#      Distinct from inquire's static-method API.
#
#   3. CONSOLE-RS ECOSYSTEM INTEGRATION — pairs naturally with
#      `indicatif` (progress bars) + `console` (terminal
#      manipulation).  Together they cover the entire TUI
#      input/output story.
#
#   4. THEME SYSTEM via Theme trait — dialoguer::theme::Theme
#      is a trait; built-in implementations include
#      ColorfulTheme + SimpleTheme; custom themes implement
#      Theme to control how prompts render.  Distinct from
#      inquire's RenderConfig struct.
#
#   5. ARMIN-RONACHER / MITSUHIKO / CONSOLE-RS ECOSYSTEM
#      PROVENANCE — distinct from Sean McArthur (Hyperium),
#      Tolnay (serde), Sorhus (Node CLI), Mockers (notify-rs).
#      Armin Ronacher's console-rs is the canonical Rust
#      terminal-UI stack.
#
# -----------------------------------------------------------------------------
#
# THE sugar CLI — clap derive + dialoguer + tracing + anchor + bundlr
#
# sugar's CLI is in src/cli/mod.rs + src/main.rs.  Uses clap
# v3 derive with #[derive(Parser)] Cli + #[derive(Subcommand)]
# Commands.
#
# Global flags:
#   -l, --log-level LEVEL   trace|debug|info|warn|error|off
#   -h, --help              show help
#   -V, --version           show version
#
# Subcommands (17):
#   airdrop                 airdrop NFTs to a list
#   bundlr balance|withdraw bundlr storage ops
#   collection set|withdraw candy machine collection mgmt
#   config create|update|set candy machine config mgmt
#   deploy                  deploy cache items on-chain
#   freeze initialize|thaw|unlock-funds freeze guard ops
#   guard add|remove|show|update|withdraw guard mgmt
#   hash                    hash cache for hidden settings
#   launch                  full deploy workflow (validate +
#                           upload + deploy + sign + verify)
#   mint                    mint one or more NFTs
#   reveal                  reveal hidden settings NFTs
#   show                    display on-chain config
#   sign                    sign NFT(s) (authority)
#   upload                  upload assets to storage
#   validate                validate asset directory
#   verify                  verify uploads
#   withdraw                withdraw rent from closed CM
#
# dialoguer is used throughout for Confirm prompts (destructive
# ops like `sugar withdraw` ask "Are you sure? [y/N]"), Input
# prompts (config wizard during `sugar config create`), Select
# prompts (storage backend selection: Bundlr / NFTStorage / AWS),
# MultiSelect prompts (guard chain composition during
# `sugar guard add`).
#
# Five-axis distinctness from all previously-documented Rust
# libraries:
#
#   1. INTERACTIVE PROMPT WIDGETS — Input / Password / Confirm /
#      Select / MultiSelect / Sort / FuzzySelect / Editor.
#      Distinct abstraction from progress bars, logging, etc.
#
#   2. WIDGET-FIRST DESIGN — each prompt is a typed struct.
#
#   3. THEME TRAIT — pluggable styling.
#
#   4. VALIDATOR + HISTORY TRAITS — prompt re-display on
#      validation failure; up-arrow recall of previous inputs.
#
#   5. ARMIN-RONACHER / CONSOLE-RS ECOSYSTEM PROVENANCE —
#      distinct maintainer ecosystem.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/metaplex-foundation/sugar/blob/main/src/cli/mod.rs
# clap v3 derive #[clap] attributes.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _sugar_cmds _sugar_log_levels _sugar_bundlr _sugar_collection
local -a _sugar_config_cmds _sugar_freeze _sugar_guard
_sugar_cmds=(
    'airdrop:airdrop NFTs to a list'
    'bundlr:Bundlr storage operations'
    'collection:Candy Machine collection management'
    'config:candy machine configuration management'
    'deploy:deploy cache items into candy machine on-chain'
    'freeze:freeze guard operations'
    'guard:manage guards on the candy machine'
    'hash:hash cache for hidden settings'
    'launch:full deploy workflow (validate + upload + deploy + sign + verify)'
    'mint:mint one or more NFTs'
    'reveal:reveal the NFTs from a hidden settings candy machine'
    'show:show on-chain config of an existing candy machine'
    'sign:sign one or all NFTs from candy machine'
    'upload:upload assets to storage and create cache config'
    'validate:validate asset directory'
    'verify:verify uploads'
    'withdraw:withdraw rent from a closed candy machine'
    'help:show help for a subcommand'
)
_sugar_log_levels=(
    'trace:trace-level logging'
    'debug:debug-level logging'
    'info:info-level logging'
    'warn:warn-level logging'
    'error:error-level logging'
    'off:disable logging'
)
_sugar_bundlr=('balance:show Bundlr balance' 'withdraw:withdraw from Bundlr')
_sugar_collection=('set:set collection' 'withdraw:withdraw collection')
_sugar_config_cmds=('create:create config interactively' 'update:update config field' 'set:set config field')
_sugar_freeze=('initialize:initialize freeze guard' 'thaw:thaw frozen NFTs' 'unlock-funds:unlock funds from freeze guard')
_sugar_guard=(
    'add:add a guard to the candy machine'
    'remove:remove a guard from the candy machine'
    'show:show current guards'
    'update:update an existing guard'
    'withdraw:withdraw funds collected by guards'
)

local common_flags
common_flags=(
    '(-k --keypair)'{-k+,--keypair=}'[keypair file path]:keypair:_files'
    '(-r --rpc-url)'{-r+,--rpc-url=}'[Solana RPC URL]:url:_default'
    '(-c --config)'{-c+,--config=}'[config file path (default config.json)]:config:_files -g "*.json"'
    '--cache=[cache file path (default cache.json)]:cache:_files'
    '(-p --priority-fee)'{-p+,--priority-fee=}'[Solana priority fee value]:fee:_default'
)

_arguments -C \
    '(-l --log-level)'{-l+,--log-level=}'[log level]:level:->log_level' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    log_level)
        _describe -t levels 'log level' _sugar_log_levels && ret=0
        ;;
    cmd)
        _describe -t commands 'sugar subcommand' _sugar_cmds && ret=0
        ;;
    args)
        case $words[1] in
            bundlr)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'bundlr action' _sugar_bundlr && ret=0
                fi
                ;;
            collection)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'collection action' _sugar_collection && ret=0
                fi
                ;;
            config)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'config action' _sugar_config_cmds && ret=0
                fi
                ;;
            freeze)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'freeze action' _sugar_freeze && ret=0
                fi
                ;;
            guard)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'guard action' _sugar_guard && ret=0
                fi
                ;;
            deploy|mint|airdrop|reveal|show|sign|upload|validate|verify|withdraw|launch|hash)
                _arguments $common_flags && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _sugar_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
