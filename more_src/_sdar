#compdef sdar
# Documentation: https://sourceware.org/binutils/docs/binutils/ar.html and https://sourceforge.net/p/sdcc/code/HEAD/tree/trunk/sdcc/support/sdbinutils/binutils/ar.c
# Reference accessed: 2026-05-21
# Verified: SDCC's sdar is a port of GNU binutils ar (support/sdbinutils/
# binutils/ar.c synced from upstream binutils). Operations and modifiers
# match GNU ar(1).

# sdar: SDCC archive (GNU ar port)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--plugin=[load the specified plugin]:plugin:' \
  '--target=[specify bfd target name]:target:' \
  '--output=[directory for extracted files]:dir:_files -/' \
  '--record-libdeps=[record library deps for static lib]:libdeps:' \
  '-M[script mode for ar]' \
  '*:archive/object files:_files -g "*.(a|lib|rel|o)"' && ret=0
return ret
