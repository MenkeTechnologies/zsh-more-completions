#compdef dscextract
# Documentation: https://manpages.debian.org/dscextract
# Source: debian/devscripts scripts/dscextract.sh — extract a single file from a Debian .dsc (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:dsc file:_files -g "*.dsc"' \
    '2:file path inside source:_default' \
    && ret=0

return ret
