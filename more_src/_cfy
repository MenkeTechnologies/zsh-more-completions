#compdef cfy
# Documentation: https://docs.cloudify.co/latest/cli/
# Cloudify CLI for managing blueprints, deployments and the Cloudify Manager

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display the version and exit]' \
  '(-q --quiet)'{-q,--quiet}'[show critical logs only]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '--json[force JSON output]' \
  '--format=[output format]:format:(plain json)' \
  '--manager=[specify target manager]:manager' \
  '(-t --tenant-name)'{-t,--tenant-name}'=[specify tenant]:tenant' \
  '(-o --pagination-offset)'{-o,--pagination-offset}'=[skip resources]:offset' \
  '(-s --pagination-size)'{-s,--pagination-size}'=[results per page]:size' \
  '*:command:((agents\:"handle a deployment agents" apply\:"apply configuration" blueprints\:"handle blueprints" deployments\:"handle deployments" events\:"show events from executions" executions\:"handle workflow executions" plugins\:"handle plugins" secrets\:"handle secret store" workflows\:"handle workflows" init\:"initialize a working env" profiles\:"handle CLI profiles" config\:"configuration management" cluster\:"cluster operations" snapshots\:"backup and restore snapshots" tenants\:"multi-tenancy" users\:"user management" user-groups\:"user group management" certificates\:"manage TLS certificates" ldap\:"LDAP integration" license\:"license management" sites\:"site management" ssh\:"SSH access"))' && ret=0

return ret
