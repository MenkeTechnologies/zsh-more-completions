#compdef hugin_lensdb
# Documentation: https://man.archlinux.org/man/hugin_lensdb.1.en
# hugin_lensdb: maintain the Hugin lens and camera database

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '--recursive[search all subfolders (with --populate)]' \
  '--populate=[populate database from all pto files in BASEPATH]:basepath:_files -/' \
  '--compress[compress database by averaging single values]' \
  '--remove-lens=[remove the specified lens]:lens:' \
  '--remove-camera=[remove the specified camera MAKER|MODEL]:camera:' \
  '--export-database=[export database to external file]:file:_files' \
  '--import-from-file=[import data from external file]:file:_files' && ret=0

return ret
