#compdef csvquote
# _csvquote — Dan Brown csvquote tool to escape commas/newlines inside CSV quoted fields CLI alias (dbro team, C); custom argparse
# upstream: https://github.com/dbro/csvquote

_csvquote() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-u[restore (un-quote)]' \
        '-q+[quote char]:str:' \
        '-d+[delimiter]:str:' \
        '-r+[record separator]:str:' \
        '-t[detect terminal mode]' \
        '*:files:_files -g "*.csv"'
}

_csvquote "$@"
