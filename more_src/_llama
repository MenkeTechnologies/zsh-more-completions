#compdef llama
# Documentation: https://www.npmjs.com/package/llama-cli
# Reference accessed: 2026-05-23
# Verified: npx llama-cli --help.

# Zsh completion for llama - deploy Chaos Llama to AWS (llama-cli npm package)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:deploy Chaos Llama to AWS'
)

_arguments -C \
  '--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'llama command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
