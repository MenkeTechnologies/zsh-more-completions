#compdef contour

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to config file]:config file:_files' \
  '--profile=[terminal profile to use]:profile' \
  '--working-directory=[start in specified directory]:directory:_directories' \
  '--class=[override the class WM_CLASS property]:class' \
  '--platform-plugin=[override the Qt platform plugin]:plugin' \
  '--session=[session ID]:session id' \
  '--debug=[debug category]:category' \
  '--live-config[enable live config reload]' \
  '--dump-state-at-exit=[dump state at exit to file]:file:_files' \
  '(-e --execute)'{-e,--execute}'[execute command]:command:_command_names -e' \
  '*:program and arguments:_command_names -e' && ret=0

return ret
