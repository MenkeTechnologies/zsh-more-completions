#compdef tweak

# tweak: simple binary file editor for terminal
# Documentation: http://www.chiark.greenend.org.uk/~sgtatham/tweak/
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-r[read-only]' \
  '-l[load line settings]:file:_files' \
  '-s[no swap file]' \
  '-i[insert mode]' \
  '*:file:_files' && ret=0
return ret
