#compdef ukify
# Documentation: https://github.com/systemd/systemd/blob/main/src/ukify/ukify.py
# Reference accessed: 2026-05-21
# Verified: upstream systemd ukify.py CONFIG_ITEMS argparse definitions.
# Removed from prior file: --sections (real: --section singular).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a Unified Kernel Image'
  'genkey:generate signing keys'
  'inspect:inspect a UKI or PE binary'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ukify command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (build)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--linux[linux kernel image]:kernel:_files' \
          '--initrd[initrd image]:initrd:_files' \
          '--cmdline[kernel command line]:cmdline:' \
          '--os-release[os-release file]:file:_files' \
          '--devicetree[device tree]:dtb:_files' \
          '--splash[splash screen BMP image]:bmp:_files' \
          '--pcrpkey[PCR signing public key]:key:_files' \
          '*--section=[section as NAME:TEXT|@PATH]:section:' \
          '--tools=[directories to search for tools]:dir:_files -/' \
          '--stub=[path to sd-stub file]:stub:_files' \
          '(-o --output)'{-o,--output}'=[output file path]:output:_files' \
          '--measure[print systemd-measure output for the UKI]' \
          '--policy-digest[print systemd-measure policy digests]' \
          '--pcr-banks=[PCR banks]:banks:' \
          '--pcr-private-key=[PCR signing private key]:key:_files' \
          '--pcr-public-key=[PCR signing public key]:key:_files' \
          '--pcr-certificate=[PCR signing certificate]:cert:_files' \
          '--sign-kernel[sign the embedded kernel]' \
          '--no-sign-kernel[do not sign the embedded kernel]' \
          '--signtool=[signing tool]:tool:(sbsign pesign systemd-sbsign)' \
          '--secureboot-private-key=[secure boot key]:key:_files' \
          '--secureboot-certificate=[secure boot cert]:cert:_files' \
          '--secureboot-certificate-dir=[NSS cert db dir]:dir:_files -/' \
          '--secureboot-certificate-name=[NSS cert entry name]:name:' \
          '--secureboot-certificate-validity=[certificate validity days]:days:' \
          '--signing-engine=[OpenSSL engine]:engine:' \
          '--signing-provider=[OpenSSL provider]:provider:' \
          '--certificate-provider=[OpenSSL cert provider]:provider:' \
          '(-c --config)'{-c,--config}'=[configuration file]:file:_files' \
          '--summary[print parsed config and exit]' \
          '--microcode=[microcode file]:file:_files' \
          '--uname=[kernel version string]:version:' \
          '--sbat=[SBAT policy]:sbat:' \
          '--profile=[profile information]:profile:_files' \
          '--join-profile=[join profile from PE binary]:file:_files' \
          '--sign-profile=[which profiles to sign]:profile:' \
          '--pcrsig=[signed PCR policy JSON]:file:_files' \
          '--join-pcrsig=[PE binary to join with --pcrsig]:file:_files' \
          '--efi-arch=[target EFI architecture]:arch:' \
          '--devicetree-auto=[DeviceTree for automatic selection]:dtb:_files' \
          '--hwids=[directory with HWID text files]:dir:_files -/' \
          '--efifw=[directory with efi firmware binary]:dir:_files -/' \
          '--phases=[phase paths]:phases:' && ret=0
        ;;
      (genkey)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--secureboot-private-key=[secure boot private key path]:key:_files' \
          '--secureboot-certificate=[secure boot certificate path]:cert:_files' \
          '--pcr-private-key=[PCR private key]:key:_files' \
          '--pcr-public-key=[PCR public key]:key:_files' \
          '--pcr-certificate=[PCR certificate]:cert:_files' \
          '--secureboot-certificate-validity=[certificate validity days]:days:' && ret=0
        ;;
      (inspect)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--json=[JSON output]:format:(pretty short off)' \
          '-j[equivalent to --json=pretty]' \
          '--all[print all sections]' \
          '*--section=[section to print]:section:' \
          '*:file:_files' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
