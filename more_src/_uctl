#compdef uctl
# Documentation: https://www.union.ai/docs/serverless/api-reference/uctl-cli/
# Union.ai uctl command line interface for Flyte/Union resources

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--admin.endpoint=[admin endpoint]:endpoint:' \
  '(-p --project)'{-p,--project}'=[project name]:project:' \
  '(-d --domain)'{-d,--domain}'=[domain name]:domain:' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'get:retrieve resources'
      'create:create resources'
      'update:modify resources'
      'delete:delete resources'
      'apply:apply configurations'
      'append:append operations'
      'register:register entities'
      'config:manage configuration'
      'demo:manage the local demo cluster'
      'version:display version information'
    )
    _describe -t commands 'uctl command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      get)
        local -a sub
        sub=(
          'app:get apps'
          'cluster:get clusters'
          'clusterconfig:get cluster configs'
          'clusterpool:get cluster pools'
          'execution:get executions'
          'launchplan:get launch plans'
          'policy:get policies'
          'project:get projects'
          'role:get roles'
          'task:get tasks'
          'workflow:get workflows'
        )
        _describe -t subcommands 'get subcommand' sub && ret=0
        ;;
      create)
        local -a sub
        sub=(
          'app:create an app'
          'clusterpool:create a cluster pool'
          'clusterpoolassignment:create a cluster pool assignment'
          'execution:create an execution'
          'policy:create a policy'
          'project:create a project'
          'role:create a role'
        )
        _describe -t subcommands 'create subcommand' sub && ret=0
        ;;
      update)
        local -a sub
        sub=(
          'cluster-resource-attribute:update cluster resource attributes'
          'execution:update an execution'
          'launchplan:update a launch plan'
          'plugin-override:update a plugin override'
          'project:update a project'
          'task-resource-attribute:update task resource attributes'
        )
        _describe -t subcommands 'update subcommand' sub && ret=0
        ;;
      delete)
        local -a sub
        sub=(
          'app:delete an app'
          'cluster:delete a cluster'
          'clusterconfig:delete a cluster config'
          'clusterpool:delete a cluster pool'
          'execution:delete an execution'
          'policy:delete a policy'
          'role:delete a role'
        )
        _describe -t subcommands 'delete subcommand' sub && ret=0
        ;;
      apply)
        local -a sub
        sub=(
          'app:apply an app config'
          'clusterconfig:apply a cluster config'
          'clusterconfigid:apply a cluster config by id'
          'clusterpoolconfig:apply a cluster pool config'
        )
        _describe -t subcommands 'apply subcommand' sub && ret=0
        ;;
      register)
        local -a sub
        sub=('examples:register examples' 'files:register serialized files')
        _describe -t subcommands 'register subcommand' sub && ret=0
        ;;
      config)
        local -a sub
        sub=(
          'discover:discover configuration'
          'docs:show configuration docs'
          'init:initialize configuration'
          'validate:validate configuration'
        )
        _describe -t subcommands 'config subcommand' sub && ret=0
        ;;
      demo)
        local -a sub
        sub=(
          'start:start the demo cluster'
          'status:show demo cluster status'
          'exec:exec into the demo cluster'
          'reload:reload the demo cluster'
          'teardown:teardown the demo cluster'
        )
        _describe -t subcommands 'demo subcommand' sub && ret=0
        ;;
      *)
        ret=0
        ;;
    esac
    ;;
esac

return ret
