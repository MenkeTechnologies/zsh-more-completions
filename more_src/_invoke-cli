#compdef invoke-cli inv
# _invoke-cli — Jeff Forcier Invoke Python task execution CLI alias (Jeff Forcier / Pyinvoke, Python); custom argparse
# upstream: https://github.com/pyinvoke/invoke

_invoke-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--complete[print completion candidates]' \
        '--config=+[config file]:file:_files' \
        '-f+[config file]:file:_files' \
        '--collection=+[collection name]:str:' \
        '-c+[collection name]:str:' \
        '--list[list tasks]' \
        '-l[list tasks]' \
        '--list-depth=+[list depth]:n:' \
        '--list-format=+[list format]:fmt:(flat nested json)' \
        '-F+[list format]:fmt:(flat nested json)' \
        '--no-dedupe[no dedupe]' \
        '--print-completion-script=+[print completion]:shell:(bash zsh fish)' \
        '--prompt-for-sudo-password[prompt for sudo password]' \
        '-p[prompt for sudo password]' \
        '--prompt-for-login-password[prompt for login password]' \
        '-P[prompt for login password]' \
        '--echo[echo commands]' \
        '-e[echo commands]' \
        '--hide=+[hide output]:o:(out err both none)' \
        '-H+[hide output]:o:(out err both none)' \
        '--no-pty[no pty]' \
        '--pty[force pty]' \
        '--in-stream=+[input stream]:str:' \
        '-i+[input stream]:str:' \
        '--out-stream=+[output stream]:str:' \
        '-o+[output stream]:str:' \
        '--err-stream=+[error stream]:str:' \
        '-r+[error stream]:str:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--warn-only[warn on error instead of stop]' \
        '-w[warn on error instead of stop]' \
        '--dry[dry run]' \
        '-R[dry run]' \
        '--echo-format=+[echo format]:str:' \
        '--echo-stdin=+[echo stdin]:b:(true false)' \
        '--write-pyc[write pyc files]' \
        '--no-color[no color]' \
        '*:task:'
}

_invoke-cli "$@"
