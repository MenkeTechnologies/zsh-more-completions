#compdef wordlist2dawg
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wordlist2dawg.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wordlist2dawg: tesseract-ocr utility to convert a wordlist to a DAWG.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-t[verify equivalence between dawg and wordlist]' \
  '-r+[reverse policy: 1=reverse RTL, 2=reverse all]:policy:(1 2)' \
  '-l+[multi-length: <short> <long>]:short length:' \
  '1:wordlist file:_files' \
  '2:DAWG output file:_files' \
  '3:unicharset file:_files' && ret=0

return ret
