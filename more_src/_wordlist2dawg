#compdef wordlist2dawg
# Documentation: https://man.archlinux.org/search?q=wordlist2dawg
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-v,--version}'[show version]' \
  '-t[type-mode (trie)]' \
  '-r+[reverse policy]:policy:' \
  '1:wordlist file:_files' \
  '2:dawg output file:_files' \
  '3:unicharset file:_files' && ret=0

return ret
