#compdef btkey
# Documentation: man btkey(1)
# Source: netbsd/src usr.bin/btkey — Bluetooth link key storage management (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[clear key from device]' \
    '-c[clear key from file]' \
    '-k+[link key (hex digits, padded to 16 octets)]:key:_default' \
    '-L[list keys stored in device]' \
    '-l[list keys stored in file]' \
    '-R[read key from device]' \
    '-r[read key from file]' \
    '-W[write key to device]' \
    '-w[write key to file]' \
    '-a+[remote device address (BDADDR or name)]:address:_default' \
    '-d+[local device address (BDADDR or name)]:device:_default' \
    && ret=0

return ret
