#compdef impacket-lookupsid

# Impacket lookupsid.py: SAM-R RID brute force / SID enumeration
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-domain-sids[lookup domain SIDs only]' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '*:domain/user[:password]@host [max_rid]:' && ret=0
return ret
