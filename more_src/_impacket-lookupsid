#compdef impacket-lookupsid
# Documentation: https://github.com/fortra/impacket/blob/master/examples/lookupsid.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-lookupsid: enumerate Windows SIDs / RIDs via SAMR brute force.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-target-ip[target machine IP]:ip:' \
  '-port[destination port]:port:(139 445)' \
  '-domain-sids[enumerate domain SIDs (forwarded to DC)]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '*::positional:_files' && ret=0
return ret
