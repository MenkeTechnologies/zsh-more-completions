#compdef argo

# Zsh completion for Argo Workflows CLI

local curcontext="$curcontext" state line ret=1

local -a argo_commands
argo_commands=(
  'archive:manage the workflow archive'
  'auth:manage authentication'
  'cluster-template:manage cluster workflow templates'
  'completion:output shell completion code'
  'cp:copy artifacts from a workflow'
  'cron:manage cron workflows'
  'delete:delete workflows'
  'executor-plugin:manage executor plugins'
  'get:display details about a workflow'
  'lint:validate files or directories'
  'list:list workflows'
  'logs:view logs of a workflow'
  'node:perform action on a node in a workflow'
  'resubmit:resubmit completed workflows'
  'resume:resume suspended workflows'
  'retry:retry failed workflows'
  'server:start the Argo Server'
  'stop:stop zero or more workflows'
  'submit:submit a workflow'
  'suspend:suspend zero or more workflows'
  'template:manage workflow templates'
  'terminate:terminate zero or more workflows'
  'version:print version information'
  'wait:wait for workflows to complete'
  'watch:watch a workflow until it completes'
)

local -a argo_global_flags
argo_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--argo-base-href=[base href for Argo UI]:href:'
  '--argo-server=[Argo Server address]:address:'
  '-s=[Argo Server address]:address:'
  '--as=[username to impersonate]:user:'
  '--as-group=[group to impersonate]:group:'
  '--as-uid=[UID to impersonate]:uid:'
  '--certificate-authority=[path to CA cert]:cert:_files'
  '--client-certificate=[path to client cert]:cert:_files'
  '--client-key=[path to client key]:key:_files'
  '--cluster=[name of kubeconfig cluster]:cluster:'
  '--context=[name of kubeconfig context]:context:'
  '--gloglevel=[log level for glog]:level:'
  '-e[send GRPC requests without TLS]'
  '--insecure-skip-tls-verify[skip TLS verification]'
  '-k[turn on TLS verification]'
  '--kubeconfig=[path to kubeconfig]:kubeconfig:_files'
  '--loglevel=[log level]:level:(debug info warn error)'
  '-n=[namespace]:namespace:'
  '--namespace=[namespace]:namespace:'
  '--request-timeout=[request timeout]:duration:'
  '--secure[use secure connection]'
  '--server=[address of the Kubernetes API server]:server:'
  '--token=[bearer token for authentication]:token:'
  '--user=[name of kubeconfig user]:user:'
  '-v=[log level verbosity]:level:'
  '--verbose[enable verbose logging]'
)

_arguments -s -S \
  $argo_global_flags \
  '1:command:_describe -t commands command argo_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      submit)
        _arguments -s -S \
          $argo_global_flags \
          '--dry-run[print the workflow without creating it]' \
          '--entrypoint=[override the entrypoint]:entrypoint:' \
          '--from=[submit from an existing resource]:resource:' \
          '--generate-name=[override metadata.generateName]:name:' \
          '--labels=[add labels]:labels:' \
          '--log[follow the workflow logs]' \
          '--name=[override metadata.name]:name:' \
          '--node-field-selector=[selector for node fields]:selector:' \
          '-o=[output format]:format:(name json yaml wide)' \
          '--output=[output format]:format:(name json yaml wide)' \
          '-p=[set parameter]:key=value:' \
          '--parameter=[set parameter]:key=value:' \
          '-f=[parameter file]:param file:_files' \
          '--parameter-file=[parameter file]:param file:_files' \
          '--priority=[workflow priority]:priority:' \
          '--scheduled-time=[override scheduled time]:time:' \
          '--server-dry-run[send to server for validation without creating]' \
          '--serviceaccount=[service account]:sa:' \
          '--status=[set workflow status after submission]:status:(Succeeded Failed Error)' \
          '--strict[perform strict validation]' \
          '-w[wait for the workflow to complete]' \
          '--wait[wait for the workflow to complete]' \
          '--watch[watch the workflow until it completes]' \
          '*:workflow file:_files' && ret=0
        ;;
      list)
        _arguments -s -S \
          $argo_global_flags \
          '-A[list workflows from all namespaces]' \
          '--all-namespaces[list workflows from all namespaces]' \
          '--chunk-size=[return large lists in chunks]:size:' \
          '--completed[show completed workflows]' \
          '--field-selector=[filter by field selector]:selector:' \
          '-l=[filter by label selector]:selector:' \
          '--label-selector=[filter by label selector]:selector:' \
          '--no-headers[do not print headers]' \
          '-o=[output format]:format:(name json yaml wide)' \
          '--output=[output format]:format:(name json yaml wide)' \
          '--prefix=[filter by name prefix]:prefix:' \
          '--resubmitted[show resubmitted workflows]' \
          '--running[show running workflows]' \
          '--since=[only show workflows newer than]:duration:' \
          '--status=[filter by status]:status:(Pending Running Succeeded Failed Error)' && ret=0
        ;;
      get)
        _arguments -s -S \
          $argo_global_flags \
          '--node-field-selector=[selector for node fields]:selector:' \
          '-o=[output format]:format:(name json yaml wide)' \
          '--output=[output format]:format:(name json yaml wide)' \
          '--status=[filter node status]:status:' \
          '1:workflow name:' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $argo_global_flags \
          '-c=[container name]:container:' \
          '--container=[container name]:container:' \
          '-f[follow the log stream]' \
          '--follow[follow the log stream]' \
          '--grep=[filter log lines]:pattern:' \
          '--no-color[disable colorized output]' \
          '-p[print log lines only]' \
          '--previous[print logs for previously completed pods]' \
          '--since=[show logs newer than duration]:duration:' \
          '--since-time=[show logs since time]:timestamp:' \
          '--tail=[number of lines to show]:lines:' \
          '--timestamps[show timestamps]' \
          '1:workflow name:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $argo_global_flags \
          '-A[delete workflows from all namespaces]' \
          '--all[delete all workflows]' \
          '--all-namespaces[delete from all namespaces]' \
          '--completed[delete completed workflows]' \
          '--dry-run[print which workflows would be deleted]' \
          '--field-selector=[filter by field selector]:selector:' \
          '-l=[filter by label selector]:selector:' \
          '--label-selector=[filter by label selector]:selector:' \
          '--older=[delete workflows older than]:duration:' \
          '--prefix=[delete by name prefix]:prefix:' \
          '--resubmitted[delete resubmitted workflows]' \
          '--status=[filter by status]:status:(Pending Running Succeeded Failed Error)' \
          '*:workflow name:' && ret=0
        ;;
      watch)
        _arguments -s -S \
          $argo_global_flags \
          '--node-field-selector=[selector for node fields]:selector:' \
          '--status=[filter node status]:status:' \
          '1:workflow name:' && ret=0
        ;;
      wait)
        _arguments -s -S \
          $argo_global_flags \
          '*:workflow name:' && ret=0
        ;;
      suspend)
        _arguments -s -S \
          $argo_global_flags \
          '*:workflow name:' && ret=0
        ;;
      resume)
        _arguments -s -S \
          $argo_global_flags \
          '--node-field-selector=[selector for node fields]:selector:' \
          '*:workflow name:' && ret=0
        ;;
      retry)
        _arguments -s -S \
          $argo_global_flags \
          '--node-field-selector=[selector for node fields]:selector:' \
          '--restart-successful[restart successful nodes too]' \
          '-w[wait for the workflow to complete]' \
          '--wait[wait for the workflow to complete]' \
          '--watch[watch the workflow until it completes]' \
          '-o=[output format]:format:(name json yaml wide)' \
          '--output=[output format]:format:(name json yaml wide)' \
          '*:workflow name:' && ret=0
        ;;
      resubmit)
        _arguments -s -S \
          $argo_global_flags \
          '--memoized[re-use memoized steps]' \
          '--priority=[workflow priority]:priority:' \
          '-w[wait for the workflow to complete]' \
          '--wait[wait for the workflow to complete]' \
          '--watch[watch the workflow until it completes]' \
          '-o=[output format]:format:(name json yaml wide)' \
          '--output=[output format]:format:(name json yaml wide)' \
          '*:workflow name:' && ret=0
        ;;
      terminate|stop)
        _arguments -s -S \
          $argo_global_flags \
          '--message=[termination message]:message:' \
          '--node-field-selector=[selector for node fields]:selector:' \
          '*:workflow name:' && ret=0
        ;;
      lint)
        _arguments -s -S \
          $argo_global_flags \
          '--kinds=[which kinds to lint]:kinds:(Workflow CronWorkflow WorkflowTemplate ClusterWorkflowTemplate)' \
          '--offline[perform offline linting]' \
          '--strict[strict validation]' \
          '-o=[output format]:format:(simple json)' \
          '--output=[output format]:format:(simple json)' \
          '*:file:_files' && ret=0
        ;;
      template)
        local -a template_commands
        template_commands=(
          'create:create a workflow template'
          'delete:delete a workflow template'
          'get:display details about a workflow template'
          'lint:validate a workflow template'
          'list:list workflow templates'
        )
        _arguments -s -S \
          $argo_global_flags \
          '1:template command:_describe -t commands command template_commands' \
          '*::template args:' && ret=0
        ;;
      cron)
        local -a cron_commands
        cron_commands=(
          'create:create a cron workflow'
          'delete:delete a cron workflow'
          'get:display details about a cron workflow'
          'lint:validate a cron workflow'
          'list:list cron workflows'
          'resume:resume a cron workflow'
          'suspend:suspend a cron workflow'
        )
        _arguments -s -S \
          $argo_global_flags \
          '1:cron command:_describe -t commands command cron_commands' \
          '*::cron args:' && ret=0
        ;;
      archive)
        local -a archive_commands
        archive_commands=(
          'delete:delete a workflow from the archive'
          'get:get a workflow from the archive'
          'list:list workflows in the archive'
          'list-label-keys:list label keys in the archive'
          'list-label-values:list label values in the archive'
          'resubmit:resubmit an archived workflow'
          'retry:retry an archived workflow'
        )
        _arguments -s -S \
          $argo_global_flags \
          '1:archive command:_describe -t commands command archive_commands' \
          '*::archive args:' && ret=0
        ;;
      auth)
        local -a auth_commands
        auth_commands=(
          'token:print the auth token'
        )
        _arguments -s -S \
          $argo_global_flags \
          '1:auth command:_describe -t commands command auth_commands' \
          '*::auth args:' && ret=0
        ;;
      server)
        _arguments -s -S \
          $argo_global_flags \
          '--access-control-allow-origin=[CORS allow origin]:origin:' \
          '--auth-mode=[authentication mode]:mode:(server client sso)' \
          '--basehref=[base href]:href:' \
          '--browser-open[open browser on startup]' \
          '--configmap=[configmap name]:name:' \
          '--event-async-dispatch[dispatch events async]' \
          '--event-operation-queue-size=[event operation queue size]:size:' \
          '--event-worker-count=[event worker count]:count:' \
          '--hsts[add HSTS header]' \
          '--log-format=[log format]:format:(text json)' \
          '--managed-namespace=[managed namespace]:namespace:' \
          '--namespaced[run in namespace mode]' \
          '-p=[port to listen on]:port:' \
          '--port=[port to listen on]:port:' \
          '--secure[use TLS]' \
          '--tls-certificate=[TLS certificate]:cert:_files' \
          '--tls-key=[TLS key]:key:_files' \
          '--x-frame-options=[X-Frame-Options header]:value:(DENY SAMEORIGIN)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $argo_global_flags \
          '1:shell:(bash zsh)' && ret=0
        ;;
      cp)
        _arguments -s -S \
          $argo_global_flags \
          '1:source (workflow/node-id/artifact-name):' \
          '2:destination:_files' && ret=0
        ;;
      *)
        _arguments -s -S $argo_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
