#compdef skupper

local -a _skupper_commands
_skupper_commands=(
  'completion:generate shell completion'
  'debug:debug commands'
  'delete:delete skupper installation'
  'expose:expose a workload'
  'gateway:manage gateways'
  'help:help about any command'
  'init:initialize skupper'
  'link:manage site links'
  'network:show network status'
  'revoke-access:revoke access'
  'service:manage services'
  'site:manage site'
  'status:show skupper status'
  'token:manage tokens'
  'unexpose:unexpose a workload'
  'update:update skupper'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig[kubeconfig file]:file:_files' \
  '--context[kubeconfig context]:context' \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace' \
  '--platform[platform]:platform:(kubernetes podman)' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'skupper commands' _skupper_commands
    ;;
  args)
    case "$words[1]" in
      init)
        _arguments \
          '--site-name[site name]:name' \
          '--ingress[ingress mode]:mode:(route loadbalancer nodeport none)' \
          '--router-mode[router mode]:mode:(interior edge)' \
          '--enable-console[enable console]' \
          '--console-auth[console auth]:auth:(internal openshift unsecured)' \
          '--console-user[console user]:user' \
          '--console-password[console password]:password' \
          '--ingress-host[ingress host]:host' \
          '--create-network-policy[create network policy]' \
          '--timeout[timeout]:duration' \
          '--router-cpu[router CPU]:cpu' \
          '--router-memory[router memory]:memory' \
          '--controller-cpu[controller CPU]:cpu' \
          '--controller-memory[controller memory]:memory' \
          '--routers[number of routers]:count'
        ;;
      expose)
        _arguments \
          '--address[service address]:address' \
          '--port[port]:port' \
          '--target-port[target port]:port' \
          '--protocol[protocol]:protocol:(tcp http http2)' \
          '--headless[headless service]' \
          '--proxy[proxy type]:type' \
          '1:resource type:(deployment statefulset service deploymentconfig)' \
          '2:resource name'
        ;;
      unexpose)
        _arguments \
          '--address[service address]:address' \
          '1:resource type:(deployment statefulset service deploymentconfig)' \
          '2:resource name'
        ;;
      service)
        _arguments '1:subcommand:(create delete bind unbind status label)' '*:args'
        ;;
      link)
        _arguments '1:subcommand:(create delete status)' '*:args'
        ;;
      token)
        _arguments '1:subcommand:(create)' '*:file:_files'
        ;;
      gateway)
        _arguments '1:subcommand:(init delete expose unexpose bind unbind forward unforward status)' '*:args'
        ;;
      debug)
        _arguments '1:subcommand:(dump events service)' '*:args'
        ;;
      delete)
        _arguments '--timeout[timeout]:duration'
        ;;
      status)
        _arguments '--timeout[timeout]:duration'
        ;;
      update)
        _arguments '--timeout[timeout]:duration'
        ;;
    esac
    ;;
esac
