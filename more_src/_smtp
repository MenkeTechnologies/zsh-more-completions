#compdef smtp
# _smtp — OpenSMTPD smtp(1) (standalone SMTP client; pipes stdin to a remote SMTP server with optional TLS/STARTTLS and AUTH; used for quick MTA tests)
# upstream: https://github.com/OpenSMTPD/OpenSMTPD
# Flags from usr.sbin/smtpd/smtp.1 on tip.

_smtp() {
    _arguments \
        '-h[show usage]' \
        '-a+[authfile (line 1 = user, line 2 = password) — requires TLS]:file:_files' \
        '-C[do not require valid server cert (deprecated; use -T noverify)]' \
        '-F+[envelope MAIL FROM]:from:_email_addresses' \
        '-H+[HELO name]:host:_hosts' \
        '-n[just open SMTP session and quit (do not read stdin)]' \
        '-s+[server (proto://[user:pass@]host[:port])]:server:' \
        '*-T+[TLS parameter]:param:(noverify cafile= servername= ciphers= protocols=)' \
        '*-v[verbose]' \
        '*:recipient:_email_addresses'
}

_smtp "$@"
