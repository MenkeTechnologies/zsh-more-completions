#compdef cfdisk-cli
# _cfdisk-cli — util-linux cfdisk curses-based partition manipulator CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_cfdisk-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-L+[color mode]:c:(auto never always)' \
        '--color=+[color mode]:c:(auto never always)' \
        '--lock=+[mode]:m:(yes no nonblock)' \
        '-r+[chs option]:str:' \
        '--read-only[read only mode]' \
        '-z[no partition table]' \
        '--zero[no partition table]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_cfdisk-cli "$@"
