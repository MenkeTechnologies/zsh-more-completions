#compdef clickhouse-static-files-disk-uploader

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--metadata-path=[ClickHouse metadata path]:dir:_files -/' \
  '--test-mode[run in test mode]' \
  '--link[create hard links instead of copies]' \
  '--url=[upload URL]:url:' \
  '--output-dir=[output directory]:dir:_files -/' && ret=0

return ret
