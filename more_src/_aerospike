#compdef asd aerospike
# _aerospike — Aerospike server (asd) launcher (Aerospike key-value database engine; --config-file path, --pidfile path, --instance N for multi-instance hosts, --foreground, --reload-config send SIGHUP, --warm-restart drain and restart, --cold-start clear durable indexes; -v print version; positional argument none beyond flags)
# upstream: https://github.com/aerospike/aerospike-server
# Flags from aerospike/aerospike-server as/src/main on tip.

_aerospike() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config-file+[config file]:file:_files -g "*.conf"' \
        '--pidfile+[pid file]:file:_files' \
        '--instance+[instance N]:n:' \
        '--foreground[stay foreground]' \
        '--reload-config[send SIGHUP to running asd]' \
        '--warm-restart[warm restart]' \
        '--cold-start[cold start]' \
        '--no-detach[do not detach]'
}

_aerospike "$@"
