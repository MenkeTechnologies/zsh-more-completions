#compdef moonc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'=[output file or directory]:output:_files' \
  '(-p --print)'{-p,--print}'[print compiled Lua to stdout]' \
  '(-t --tree)'{-t,--tree}'[print parse tree]' \
  '(-T --transform)'{-T,--transform}'[print transform tree]' \
  '(-b --dump)'{-b,--dump}'[dump compile state]' \
  '(-l --lint)'{-l,--lint}'[perform lint checks]' \
  '(-X --extended)'{-X,--extended}'[enable extended MoonScript features]' \
  '(-w --watch)'{-w,--watch}'[watch for file changes and recompile]' \
  '--version[show version]' \
  '--help[show help]' \
  '*:moonscript file:_files -g "*.moon"' && ret=0

return ret
