#compdef iotop-c

# iotop-c (iotop in C) completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-H,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-o,--only}'[show only processes with I/O activity]' \
  {-b,--batch}'[batch mode (non-interactive)]' \
  {-n,--iter}'=[number of iterations]:iterations' \
  {-d,--delay}'=[delay between updates in seconds]:delay' \
  {-p,--pid}'=[monitor specific PID]:PID:_pids' \
  {-u,--user}'=[monitor specific user]:user:_users' \
  {-P,--processes}'[show only processes, not threads]' \
  {-a,--accumulated}'[show accumulated I/O]' \
  {-k,--kilobytes}'[show I/O in kilobytes]' \
  {-t,--time}'[add timestamp to each line in batch mode]' \
  {-q,--quiet}'[suppress header in batch mode]' \
  && ret=0

return ret
