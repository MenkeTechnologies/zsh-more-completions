#compdef pyprojectsort
# Documentation: https://pypi.org/project/pyprojectsort/
# formatter that sorts pyproject.toml files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--check[check whether the file would be reformatted, exit non-zero if so]' \
  '--diff[show the changes that would be made without writing them]' \
  '*:file:_files -g "*.toml"' && ret=0

return ret
