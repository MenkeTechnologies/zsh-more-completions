#compdef abc-bsv abc

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[verbose]' \
  '-V[version]' \
  '-q[quiet]' \
  '-c+[execute command]:cmd:' \
  '-f+[script file]:file:_files' \
  '-F+[script string]:script:' \
  '-T+[time limit s]:s:' \
  '-x[exit on error]' \
  '-a[batch mode]' \
  '-b[batch mode no header]' \
  '-l+[log file]:file:_files' \
  '-w+[wirelist]:file:_files' \
  '-s+[stdout-redirect]:file:_files' \
  '-e+[error redirect]:file:_files' \
  '-X+[no header]:n:' \
  '-o+[output]:file:_files' \
  '-O+[no read history]:n:' \
  '-p[batch script]' \
  '-d+[debug level]:n:' \
  '*: :_files -g "*.aig *.aag *.blif *.bench *.cnf *.dimacs *.eqn *.gml *.pla *.smv *.v"' && ret=0

return ret
