#compdef tnote
# Documentation: https://pkg.go.dev/github.com/jemmyh/tnote
# tnote - terminal notebook CLI implemented in Go

local ret=1
local line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[help for this command]' \
  '(-o --owner)'{-o,--owner}'=[owner of notebook]:owner:' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'add:add a note to your notebook'
      'create:create a notebook'
      'delete:delete notes prefixed with id'
      'help:help about any command'
      'print:print notes in your notebook'
      'version:show version'
    )
    _describe -t commands 'tnote command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -s \
          '(-o --owner)'{-o,--owner}'=[owner of notebook]:owner:' \
          '--content=[note content]:content:' && ret=0
        ;;
      create)
        _arguments -s '(-o --owner)'{-o,--owner}'=[owner of notebook]:owner:' && ret=0
        ;;
      delete)
        _arguments -s \
          '(-o --owner)'{-o,--owner}'=[owner of notebook]:owner:' \
          '--id=[id prefix of notes to delete]:id:' && ret=0
        ;;
      print)
        _arguments -s \
          '(-o --owner)'{-o,--owner}'=[owner of notebook]:owner:' \
          '-v[verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
