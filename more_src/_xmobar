#compdef xmobar

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose output]' \
  '(-r --recompile)'{-r,--recompile}'[force recompilation]' \
  '-B[set background color]:color' \
  '-F[set foreground color]:color' \
  '-o[position at top of screen]' \
  '-b[position at bottom of screen]' \
  '-d[override redirect]' \
  '-a[set text alignment]:alignment:(l c r)' \
  '-f[set font]:font' \
  '-N[add additional font]:font' \
  '-t[set output template]:template' \
  '-c[set list of commands]:commands' \
  '-C[add additional command]:command' \
  '-p[set position]:position' \
  '-A[set alpha transparency]:alpha' \
  '-T[set text offset]:offset' \
  '-i[set icon root directory]:directory:_directories' \
  '-x[set screen number]:screen number' \
  '*:config file:_files'
