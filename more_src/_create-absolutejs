#compdef create-absolutejs
# Documentation: https://www.npmjs.com/package/create-absolutejs
# Reference accessed: 2026-05-24
# Verified: npm view create-absolutejs bin; npm readme Options section.

# Zsh completion for create-absolutejs - AbsoluteJS multi-framework project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--angular[scaffold Angular frontend]' \
  '--angular-dir=[Angular output directory]:directory:_directories' \
  '--assets=[static assets directory]:directory:_directories' \
  '--auth=[auth plugin or none]:auth:(plugin none)' \
  '--biome[enable Biome tooling]' \
  '--build=[build output directory]:directory:_directories' \
  '--db=[database engine or none]:db:(engine none)' \
  '--db-dir=[database files directory]:directory:_directories' \
  '--db-host=[database host provider or none]:provider:(provider none)' \
  '--directory=[project layout mode]:directory:(custom default)' \
  '--eslint+prettier[enable ESLint and Prettier]' \
  '--git[initialize git repository]' \
  '--html[enable HTML frontend]' \
  '--html-dir=[HTML output directory]:directory:_directories' \
  '--html-scripts[include HTML scripts setup]' \
  '--htmx[enable HTMX frontend]' \
  '--htmx-dir=[HTMX output directory]:directory:_directories' \
  '--install[install dependencies after scaffold]' \
  '--lts[pin latest published dependency versions]' \
  '--orm=[ORM choice]:orm:(drizzle prisma none)' \
  '--plugin=[AbsoluteJS plugin]:plugin:' \
  '--react[enable React frontend]' \
  '--react-dir=[React output directory]:directory:_directories' \
  '--skip[skip interactive prompts where possible]' \
  '--svelte[enable Svelte frontend]' \
  '--svelte-dir=[Svelte output directory]:directory:_directories' \
  '--tailwind[enable Tailwind CSS]' \
  '--tailwind-input=[Tailwind input file]:file:_files' \
  '--tailwind-output=[Tailwind output file]:file:_files' \
  '--vue[enable Vue frontend]' \
  '--vue-dir=[Vue output directory]:directory:_directories' \
  '(-h --help)'{-h,--help}'[display help]' \
  ':project name:' && ret=0

return ret
