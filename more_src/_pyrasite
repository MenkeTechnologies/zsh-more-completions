#compdef pyrasite
# _pyrasite — inject code into a running Python process (lmacken/pyrasite)
# upstream: https://github.com/lmacken/pyrasite
# Flags from pyrasite/main.py (argparse).

_pyrasite() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-l --list-payloads)'{-l,--list-payloads}'[list standard payloads]' \
        '--gdb-prefix=[command prefix for gdb (e.g. sudo)]:prefix:' \
        '--verbose[verbose mode]' \
        '--output=[output stream type]:type:(procstreams direct ignore)' \
        '--ipc-timeout=[IPC timeout (seconds)]:seconds:' \
        '1:target PID:_pids' \
        '2:payload script:_files -g "*.py"'
}

_pyrasite "$@"
