#compdef countryfetch
# Documentation: https://github.com/nik-rev/countryfetch
# countryfetch - a CLI tool similar to neofetch but for countries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--list-countries[list all countries]' \
  '--all-countries[show information about all countries]' \
  '*:country:' && ret=0

return ret
