#compdef cyclonedx-conan
# Documentation: https://github.com/CycloneDX/cyclonedx-conan
# cyclonedx-conan: generate CycloneDX SBOM from Conan C/C++ projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-if --install-folder)'{-if,--install-folder}'[folder with conaninfo.txt and conanbuildinfo.txt]:dir:_files -/' \
  '--output=[output SBOM file path (- for STDOUT)]:file:_files' \
  '--exclude-dev[exclude development dependencies]' \
  '(-b --build)'{-b,--build}'[build policy for packages]:policy:' \
  '(-r --remote)'{-r,--remote}'[specify remote server]:remote:' \
  '(-u --update)'{-u,--update}'[check for dependency updates]' \
  '(-l --lockfile)'{-l,--lockfile}'[path to lockfile]:file:_files' \
  '--lockfile-out=[filename of updated lockfile]:file:_files' \
  '(-db --dry-build)'{-db,--dry-build}'[apply build argument as install would]' \
  '*'{-e,--env}'[environment variables for build]:env:' \
  '*'{-o,--options}'[define option values]:option:' \
  '*'{-pr,--profile}'[apply profile to machine]:profile:' \
  '*'{-s,--settings}'[settings overwriting defaults]:setting:' \
  '*'{-c,--conf}'[configuration overwriting defaults]:conf:' \
  '*:path or reference:_files' && ret=0

return ret
