#compdef ettercap
# Documentation: https://man.archlinux.org/man/ettercap.8.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-T --text)'{-T,--text}'[text-only UI]' \
  '(-G --gtk)'{-G,--gtk}'[GTK UI]' \
  '(-C --curses)'{-C,--curses}'[curses UI]' \
  '(-D --daemon)'{-D,--daemon}'[daemon mode]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-Q --superquiet)'{-Q,--superquiet}'[super quiet]' \
  '(-r --read)'{-r+,--read=}'[read pcap]:file:_files -g "*.pcap *.cap"' \
  '(-w --write)'{-w+,--write=}'[write pcap]:file:_files' \
  '(-s --script)'{-s+,--script=}'[script]:file:_files' \
  '(-d --dns)'{-d,--dns}'[resolve DNS]' \
  '(-i --iface)'{-i+,--iface=}'[interface]:if:_net_interfaces' \
  '(-I --liface)'{-I+,--liface=}'[lookback iface]:if:_net_interfaces' \
  '(-Y --secondary)*'{-Y+,--secondary=}'[secondary iface]:if:_net_interfaces' \
  '(-n --netmask)'{-n+,--netmask=}'[netmask]:n:' \
  '(-A --address)'{-A+,--address=}'[address]:addr:' \
  '(-P --plugin)*'{-P+,--plugin=}'[plugin]:p:' \
  '(-F --filter)*'{-F+,--filter=}'[filter file]:file:_files -g "*.ef"' \
  '(-z --silent)'{-z,--silent}'[silent mode (no ARP)]' \
  '(-Z --packet-sources)'{-Z,--packet-sources}'[packet sources]' \
  '(-j --load-hosts)'{-j+,--load-hosts=}'[load hosts file]:file:_files' \
  '(-k --save-hosts)'{-k+,--save-hosts=}'[save hosts file]:file:_files' \
  '(-W --wifi-key)'{-W+,--wifi-key=}'[WiFi key]:k:' \
  '(-a --config)'{-a+,--config=}'[config file]:file:_files' \
  '(-e --regex)'{-e+,--regex=}'[regex filter]:re:' \
  '(-E --external)'{-E,--external}'[external mode]' \
  '(-y --bittest)'{-y,--bittest}'[bit test]' \
  '(-L --logfile)'{-L+,--logfile=}'[log file]:file:_files' \
  '(-l --logfile-info)'{-l+,--logfile-info=}'[info log]:file:_files' \
  '(-m --logfile-msg)'{-m+,--logfile-msg=}'[msg log]:file:_files' \
  '(-c --compress)'{-c,--compress}'[compress logs]' \
  '(-o --only-mitm)'{-o,--only-mitm}'[only MitM]' \
  '(-B --bridge)'{-B+,--bridge=}'[bridge iface]:if:_net_interfaces' \
  '(-S --nosslmitm)'{-S,--nosslmitm}'[no SSL MitM]' \
  '(-M --mitm)*'{-M+,--mitm=}'[MitM method]:m:(arp ndp icmp dhcp port pptp dns)' \
  '(-R --reversed)'{-R,--reversed}'[reverse target list]' \
  '(-t --proto)'{-t+,--proto=}'[proto]:p:(tcp udp all)' \
  '(-V --visual)'{-V+,--visual=}'[visual format]:f:(hex ascii text ebcdic html utf8)' \
  '(-x --ext-headers)'{-x,--ext-headers}'[ext headers]' \
  '(-X --hex)'{-X,--hex}'[hex output]' \
  '(-u --unoffensive)'{-u,--unoffensive}'[unoffensive mode]' \
  '(--no-iface --no-promisc)--no-promisc[no promisc]' \
  '(-p --nopromisc)'{-p,--nopromisc}'[no promisc]' \
  '*: :' && ret=0

return ret
