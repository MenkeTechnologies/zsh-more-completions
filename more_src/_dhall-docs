#compdef dhall-docs
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-docs
# Source: dhall-lang/dhall-haskell dhall-docs/src/Dhall/Docs.hs — generate HTML docs from a Dhall package.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--input=[directory of the dhall package]:directory:_files -/' \
    '--output-link=[path to the link targeting the directory with generated docs]:directory:_files -/' \
    '--package-name=[override the package name shown on HTML navbars]:name:_default' \
    '--ascii[format rendered source code using only ASCII syntax]' \
    '--base-import-url=[base URL used by the copy-path-to-clipboard feature]:url:_default' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
