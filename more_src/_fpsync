#compdef fpsync
# Documentation: https://github.com/martymac/fpart/blob/master/man/fpsync.1
# fpsync - synchronize directories in parallel using fpart and rsync/cpio/tar

local ret=1

_arguments -s -S \
  '-h[print help]' \
  '-V[print version]' \
  '-v[verbose mode (repeatable)]' \
  '-n[number of concurrent sync jobs]:jobs:' \
  '-f[maximum files per sync job]:files:' \
  '-s[maximum bytes per sync job]:size:' \
  '-m[external copy tool]:tool:(rsync cpio pax tar tarify)' \
  '-T[absolute path of copy tool]:path:_files' \
  '-o[override default tool options]:toolopts:' \
  '-O[override default fpart options]:fpartopts:' \
  '-E[work on a per-directory basis (repeat for aggressive)]' \
  '-w[use remote SSH workers]:workers:' \
  '-d[shared directory for SSH worker communications]:shdir:_files -/' \
  '-t[fpsync temporary directory]:tmpdir:_files -/' \
  '-M[send e-mail to address after a run]:mailaddr:' \
  '-Z[prefix logs with human-readable dates]' \
  '-S[sudo mode for crawling and synchronizations]' \
  '-p[prepare mode: set up but do not start transfers]' \
  '-l[list previous runs and their status]' \
  '-r[resume a previous run]:runid:' \
  '-R[replay mode: re-sync all partitions with -r]' \
  '-a[archive a run to tmpdir]:runid:' \
  '-D[delete a run and associated files]:runid:' \
  '*:directory:_files -/' && ret=0

return ret
