#compdef flyte-cli
# Documentation: https://github.com/flyteorg/flyte
# Reference accessed: 2026-05-23
# Verified: flyte-cli --help (legacy Flyte platform CLI).

# Zsh completion for flyte-cli - Flyte platform command-line interface (deprecated)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--insecure[do not use SSL]' \
  '--cacert[certificate file for SSL]:file:_files' \
  '(-n --name)'{-n+,--name=}'[name for sub-command]:name:' \
  '(-d --domain)'{-d+,--domain=}'[domain for sub-command]:domain:' \
  '(-p --project)'{-p+,--project=}'[project for sub-command]:project:' \
  '(-h --host)'{-h+,--host=}'[host for sub-command]:host:' \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'flyte-cli command' \
      'activate-project[activate a project]' \
      'archive-project[archive a project]' \
      'fast-register-files[fast register files]' \
      'get-active-launch-plan[get active launch plan]' \
      'get-child-executions[get child executions]' \
      'get-execution[get execution details]' \
      'get-launch-plan[get launch plan details]' \
      'get-matching-attributes[get matchable resource]' \
      'get-task[get task details]' \
      'get-workflow[get workflow details]' \
      'list-active-launch-plans[list active launch plans]' \
      'list-executions[list executions]' \
      'list-launch-plan-names[list launch plan names]' \
      'list-launch-plan-versions[list launch plan versions]' \
      'list-matching-attributes[list matchable resources]' \
      'list-projects[list projects]' \
      'list-task-names[list task names]' \
      'list-task-versions[list task versions]' \
      'list-workflow-names[list workflow names]' \
      'list-workflow-versions[list workflow versions]' \
      'parse-proto[parse proto]' \
      'recover-execution[recover execution]' \
      'register-files[register files]' \
      'register-project[register project]' \
      'setup-config[set up default config file]' \
      'terminate-execution[terminate execution]' \
      'update-cluster-resource-attributes[update cluster resource attributes]' \
      'update-execution-cluster-label[update execution cluster label]' \
      'update-execution-queue-attributes[update execution queue attributes]' \
      'update-launch-plan[update launch plan]' \
      'update-launch-plan-meta[update launch plan metadata]' \
      'update-plugin-override[update plugin override]' \
      'update-task-meta[update task metadata]' \
      'update-workflow-meta[update workflow metadata]' && ret=0
    ;;
esac

return ret
