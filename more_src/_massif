#compdef massif-bin ms_print
# _massif — Valgrind massif heap profiler driver (Nicholas Nethercote, C); records heap snapshots and ms_print renders text report
# upstream: https://valgrind.org

_massif() {
    _arguments \
        '--massif-out-file+[output file]:file:_files' \
        '--heap+[heap profiling]:bool:(yes no)' \
        '--heap-admin+[admin bytes per block]:n:' \
        '--stacks+[stack profiling]:bool:(yes no)' \
        '--pages-as-heap+[pages as heap]:bool:(yes no)' \
        '--depth+[stack depth]:n:' \
        '--alloc-fn+[treat fn as alloc]:fn:' \
        '--ignore-fn+[ignore fn]:fn:' \
        '--threshold+[threshold pct]:f:' \
        '--peak-inaccuracy+[peak inaccuracy pct]:f:' \
        '--time-unit+[time unit]:unit:(i ms B)' \
        '--detailed-freq+[detailed freq]:n:' \
        '--max-snapshots+[max snapshots]:n:' \
        '--threshold-pages+[threshold pages]:n:' \
        '*:file:_files'
}

_massif "$@"
