#compdef samplv1_jack
# _samplv1_jack — samplv1 polyphonic sampler synth, JACK client (rncbc/samplv1)
# upstream: https://github.com/rncbc/samplv1
# Flags from src/samplv1_jack.cpp (QCommandLineParser).

_samplv1_jack() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-g --no-gui)'{-g,--no-gui}'[disable the GUI]' \
        '(-n --client-name)'{-n+,--client-name=}'[JACK client name]:name:' \
        '*:preset file:_files -g "*.{samplv1,xml}"'
}

_samplv1_jack "$@"
