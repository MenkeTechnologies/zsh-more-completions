#compdef nginx
# _nginx — nginx HTTP/proxy server (-t tests config, -T also dumps it, -q suppresses non-error msgs during test, -s sends a signal (stop|quit|reload|reopen), -p prefix path, -c config file, -e error log, -g sets global directives)
# upstream: https://github.com/nginx/nginx
# Flags from nginx src/core/nginx.c (ngx_get_options) on tip.

_nginx() {
    _arguments \
        '-?[show usage]' \
        '-h[show usage]' \
        '-v[show version]' \
        '-V[show version + config args]' \
        '-t[test config + exit]' \
        '-T[test config and print effective config]' \
        '-q[quiet during config test]' \
        '-s+[send signal to master]:signal:(stop quit reopen reload)' \
        '-p+[prefix path]:dir:_files -/' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-e+[error log file]:file:_files' \
        '-g+[set global directives]:directives:'
}

_nginx "$@"
