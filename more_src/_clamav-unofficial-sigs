#compdef clamav-unofficial-sigs
# Documentation: https://man.archlinux.org/search?q=clamav-unofficial-sigs
# Reference accessed: 2026-05-16

# clamav-unofficial-sigs: update third-party ClamAV signature databases
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-f[force]' \
  '--force[force]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[decode third-party DB]:file:_files' \
  '--decode-third-party=[decode third-party DB]:file:_files' \
  '-e[remove signature]:name:' \
  '--remove-script-signature=[remove signature]:name:' \
  '-g[gpg verify on-only]' \
  '-i[install cron]' \
  '-l[list versions]' \
  '-w[whitelist signature]:sig:' \
  '--whitelist=[whitelist signature]:sig:' \
  '-t[test]' \
  '*::clamav-unofficial-sigs args:_files' && ret=0
return ret
