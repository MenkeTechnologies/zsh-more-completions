#compdef FieldConvert
# Documentation: https://doc.nektar.info/userguide/latest/user-guidese24.html
# Nektar++ FieldConvert post-processing utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '*'{-m,--module}'=[apply processing module (e.g. -m C0Projection)]:module' \
  '(-l --modules-list)'{-l,--modules-list}'[list available modules]' \
  '(-p --modules-opt)'{-p,--modules-opt}'=[print options for a given module]:module' \
  '(-r --range)'{-r,--range}'=[output range xmin,xmax,ymin,ymax,zmin,zmax]:range' \
  '(-n --output-points)'{-n,--output-points}'=[number of equispaced output points]:int' \
  '--output-points-hom-z=[output points in homogeneous z-direction]:int' \
  '--noequispaced[do not use equispaced output (use Gaussian points)]' \
  '(-e --error)'{-e,--error}'[write error of fields for regression testing]' \
  '(-f --force-output)'{-f,--force-output}'[force output, disable backup file creation]' \
  '--nparts=[number of partitions for parallel processing]:int' \
  '--part-only=[partition mesh into N partitions and exit]:int' \
  '--part-only-overlapping=[partition into N overlapping partitions and exit]:int' \
  '(-p --procid)'{-p,--procid}'=[process id for parallel input/output]:int' \
  '--onlyshape=[only process elements of a given shape]:shape' \
  '*:file:_files' && ret=0

return ret
