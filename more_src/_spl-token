#compdef spl-token
# _spl-token — Solana Program Library spl-token CLI for SPL Token program management create/mint/transfer/burn/freeze/thaw of fungible and non-fungible tokens on Solana (solana-labs team, Rust); clap
# upstream: https://github.com/solana-labs/solana-program-library

_spl-token() {
    local -a sub=(
        'create-token:create new token'
        'create-multisig:create multisig'
        'create-account:create token account'
        'authorize:authorize account or token'
        'transfer:transfer tokens'
        'burn:burn tokens'
        'mint:mint tokens'
        'freeze:freeze account'
        'thaw:thaw account'
        'wrap:wrap SOL'
        'unwrap:unwrap SOL'
        'approve:approve delegate'
        'revoke:revoke delegate'
        'close:close account'
        'close-mint:close mint'
        'bench:benchmark'
        'balance:show balance'
        'supply:show supply'
        'accounts:list accounts'
        'address:show wallet address'
        'account-info:show account info'
        'multisig-info:show multisig info'
        'cleanup:cleanup'
        'sync-native:sync native account'
        'enable-required-transfer-memos:enable required transfer memos'
        'disable-required-transfer-memos:disable required transfer memos'
        'enable-cpi-guard:enable CPI guard'
        'disable-cpi-guard:disable CPI guard'
        'update-default-account-state:update default account state'
        'set-transfer-fee:set transfer fee'
        'set-interest-rate:set interest rate'
        'set-transfer-hook:set transfer hook'
        'initialize-metadata:init metadata'
        'update-metadata:update metadata'
        'initialize-group:init group'
        'update-group-max-size:update group max size'
        'initialize-member:init member'
        'withdraw-withheld-tokens:withdraw withheld tokens'
        'update-confidential-transfer-settings:update confidential transfer'
        'configure-confidential-transfer-account:configure confidential transfer'
        'enable-confidential-credits:enable confidential credits'
        'disable-confidential-credits:disable confidential credits'
        'deposit-confidential-tokens:deposit confidential tokens'
        'withdraw-confidential-tokens:withdraw confidential tokens'
        'apply-pending-balance:apply pending balance'
        'gc:garbage-collect'
        'display:display'
        'completion:generate shell completions'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "*.yml *.yaml"' \
        '-C+[file]:file:_files -g "*.yml *.yaml"' \
        '--url=+[url]:str:' \
        '-u+[url]:str:' \
        '--keypair=+[file]:file:_files -g "*.json"' \
        '-k+[file]:file:_files -g "*.json"' \
        '--fee-payer=+[file]:file:_files -g "*.json"' \
        '--blockhash=+[blockhash]:str:' \
        '--nonce=+[pubkey]:str:' \
        '--nonce-authority=+[pubkey]:str:' \
        '--with-memo=+[memo]:str:' \
        '--with-compute-unit-price=+[microlamports]:n:' \
        '--with-compute-unit-limit=+[CU]:n:' \
        '--output=+[fmt]:f:(json json-compact)' \
        '--program-id=+[pubkey]:str:' \
        '--program-2022[use Token 2022]' \
        '--sign-only[sign only]' \
        '--dump-transaction-message[dump tx message]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spl-token subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_spl-token "$@"
