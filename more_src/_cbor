_cbor() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    case $service in
        cbor)
            _arguments \
                '(-c --color)'{-c,--color}'[force color output]' \
                '(-t --type)'{-t,--type}'=[output type]:type:(javascript js j diagnose diag d comment c)' \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
            && ret=0
            ;;
        cbor2comment)
            _arguments \
                '(-x --hex)'{-x,--hex}'=[hex string input]:hex:' \
                '(-t --tabsize)'{-t,--tabsize}'=[indent amount]:spaces:' \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*:file:_files' \
            && ret=0
            ;;
        cbor2diag|cbor2json)
            _arguments \
                '(-x --hex)'{-x,--hex}'=[hex string input]:hex:' \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*:file:_files' \
            && ret=0
            ;;
        cbor2js)
            _arguments \
                '(-x --hex)'{-x,--hex}'=[hex string input]:hex:' \
                '(-e --exports)'{-e,--exports}'[add module.exports= to output beginning]' \
                '(-H --hidden)'{-H,--hidden}'[include non-enumerable symbols]' \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*:file:_files' \
            && ret=0
            ;;
        js2cbor|json2cbor)
            _arguments \
                '(-x --hex)'{-x,--hex}'[hex string output]' \
                '(-c --canonical)'{-c,--canonical}'[canonical RFC 8949 deterministic encoding]' \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*:file:_files' \
            && ret=0
            ;;
    esac

    return ret
}

_cbor "$@"
