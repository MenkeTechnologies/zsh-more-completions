#
# Spec authorship distribution for CBOR
# (Axis 280):
#   - Spec authors: Carsten Bormann (TZI)
#     + Paul Hoffman (ICANN) - the original
#     RFC 7049 + RFC 8949 authors
#   - Rust canonical: McCallum (Enarx;
