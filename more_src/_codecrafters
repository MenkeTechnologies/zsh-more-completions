#compdef codecrafters
# Documentation: https://man.archlinux.org/search?q=codecrafters
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'test:test your changes against the official test suite'
  'submit:submit your solution'
  'help:show help for a command'
  'completion:generate shell completion scripts'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'codecrafters command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
