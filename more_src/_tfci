#compdef tfci
# Documentation: https://github.com/hashicorp/tfc-workflows-tooling/blob/main/docs/USAGE.md
# tfci - CLI to interact with HCP Terraform and Terraform Enterprise in CI/CD

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-hostname=[hostname of a Terraform Enterprise installation]:hostname' \
  '-token=[API token to authenticate with HCP Terraform]:token' \
  '-organization=[name of the organization in HCP Terraform]:org' \
  '1:command:(upload run plan workspace)' \
  '*::arg:_default' && ret=0

return ret
