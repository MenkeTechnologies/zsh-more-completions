#compdef smauvspec
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/smauvspec.html
# Plot averaged spectra of a visibility dataset

local ret=1

_arguments -s \
  'vis=[input UV data sets]:dataset:_files' \
  'select=[standard UV selection commands]:select' \
  'line=[UV linetype: line,nchan,start,width,step]:line' \
  'stokes=[polarization types to plot]:stokes' \
  'interval=[time averaging interval in minutes (default 0)]:interval' \
  'hann=[Hanning smoothing width (odd, default 1)]:hann' \
  'offset=[position shift in arcsec (RA,DEC)]:offset' \
  'catpath=[path to JPL catalog]:dir:_files -/' \
  'vsource=[source radial velocity in km/s]:vsource' \
  'veltype=[reference frame (LSR or BARY)]:veltype' \
  'veldef=[velocity definition (radio, optic, relat)]:veldef' \
  'strngl=[minimum catalog line strength (log scale)]:strngl' \
  'axis=[x and y axes (default channel,amplitude)]:axis' \
  'xlabel=[custom x-axis label]:xlabel' \
  'ylabel=[custom y-axis label]:ylabel' \
  'yrange=[y-axis min/max range]:yrange' \
  'dotsize=[symbol size 1-201]:dotsize' \
  'title=[title content (BL, PO, TI, IN)]:title' \
  'device=[PGPLOT device/type]:device' \
  'nxy=[plot grid dimensions (x,y)]:nxy' \
  'log=[log file for spectrum output]:logfile:_files' \
  'options=[nocal,nopass,nopol,ampscalar,rms,nobase,avall,dots,...]:options' \
  '*:dataset:_files' && ret=0

return ret
