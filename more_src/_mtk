#compdef mtk mtk.py
# Documentation: https://github.com/bkerler/mtkclient/blob/main/README-USAGE.md
# MediaTek flash and repair utility (BROM/DA exploitation)

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--loader=[set DA loader file]:file:_files' \
  '--preloader=[set preloader file]:file:_files' \
  '--vid=[set USB vendor id]:vid' \
  '--pid=[set USB product id]:pid' \
  '--serialport=[use serial port]:port:_files' \
  '--debugmode[enable debug mode]' \
  '--ptype=[set payload type]:ptype' \
  '--mode=[connection mode]:mode' \
  '--wdt=[watchdog address]:addr' \
  '--var1=[set var1]:var1' \
  '--uart_addr=[uart address]:addr' \
  '--da_addr=[DA address]:addr' \
  '--brom_addr=[BROM address]:addr' \
  '--sectorsize=[sector size in bytes]:bytes' \
  '--gpt-num-part-entries=[GPT partition entry count]:num' \
  '--gpt-part-entry-size=[GPT partition entry size]:bytes' \
  '--gpt-part-entry-start-lba=[GPT partition entry start LBA]:lba' \
  '--parttype=[partition type]:type' \
  '--skip=[skip partitions]:partitions' \
  '--socid[read SoC id]' \
  '--loglevel=[set log level]:level' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'printgpt[print GPT partition table]' \
      'gpt[dump GPT to file]' \
      'r[read partition to file]' \
      'rl[read all partitions to directory]' \
      'rf[read full flash to file]' \
      'rs[read sectors to file]' \
      'ro[read partition with offset]' \
      'w[write partition from file]' \
      'wf[write full flash from file]' \
      'wl[write partitions from directory]' \
      'wo[write with offset]' \
      'e[erase partition]' \
      'es[erase sectors]' \
      'ess[erase sectors safe]' \
      'fs[filesystem operations]' \
      'footer[dump crypto footer]' \
      'reset[reset device]' \
      'meta[enter meta mode]' \
      'da[download agent commands]' \
      'payload[run payload]' \
      'crash[crash into BROM]' \
      'brute[bruteforce]' \
      'gettargetconfig[read target config]' \
      'peek[read memory]' \
      'stage[run stage]' \
      'plstage[run preloader stage]' \
      'script[run command script]' \
      'dumpbrom[dump BROM]' \
      'dumpsram[dump SRAM]' \
      'dumppreloader[dump preloader]' \
      'logs[show logs]' \
      'devices[list devices]' && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
