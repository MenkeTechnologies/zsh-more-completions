#compdef kafy
# ============================================================================
# _kafy — zsh completion for KLogicHQ's kafy, a kubectl-style Kafka CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/KLogicHQ/kafy
#   Author     : KLogicHQ
#   License    : MIT
#   Language   : Go
#   Module     : kafy
#   Binary     : kafy  (built from root main.go calling cmd.Execute)
#   Version    : 0.0.8  (cmd/root.go const version)
#   Last push  : 2025-12-10
#
# WHAT IT IS
#   kafy is "a comprehensive Kafka productivity CLI tool that
#   simplifies Kafka operations with a kubectl-inspired interface"
#   — verb-noun subcommand structure over topics, consumer groups,
#   produce/consume streams, brokers, offsets, cluster health, and
#   live tailing.  Cluster connection details live in a per-user
#   config (added with `kafy config add <cluster> --bootstrap …`)
#   and `kafy config use <cluster>` switches the active context,
#   exactly like `kubectl config use-context`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/root.go + cmd/*.go
#                       spf13/cobra Command tree)
#   kafy <command> <subcommand> [flags]
#
#   Global flags (inherited by every subcommand):
#     -o, --output <FORMAT>          Output format (table, json, yaml)
#                                      [default: table]
#     -c, --cluster <NAME>           Use specified cluster instead of
#                                    the current context (override)
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help
#         --version                  Show version (from cmd/root.go
#                                                 const version)
#
#   Subcommands:
#     config                         Manage Kafka cluster configurations
#       list                           List all configured clusters
#       current                        Show current active cluster
#       use <cluster>                  Switch to a different cluster
#       add <cluster>                  Add a new cluster
#         --bootstrap <ADDR>           Bootstrap broker(s) addr
#         --zookeeper <ADDR>           Zookeeper addr (optional)
#         --broker-metrics-port <PORT> Broker metrics JMX port
#       delete <cluster>
#         --force                      Skip confirmation
#       rename <old> <new>
#       update <cluster>
#         --name <NEW>                 Rename
#         --bootstrap <ADDR>
#         --zookeeper <ADDR>
#         --broker-metrics-port <PORT>
#       export                         Export config to YAML / JSON
#       import <file>                  Import config from YAML / JSON
#
#     topics                         Manage Kafka topics
#       list                           List all topics
#       describe <topic>               Show topic details
#       create <topic>                 Create a topic
#       delete <topic>                 Delete (with safety confirm)
#       alter <topic>                  Alter partitions or configs
#       partitions [topic]             Show partition details
#       configs                        Manage topic configurations
#         list                           List configs for all topics
#         get <topic>                    Show topic-level configs
#         set <topic> <key>=<value>      Set topic-level config
#         delete <topic> <key>           Remove a config override
#       set-partitions <topic>         Change number of partitions
#       move-partition <topic>         Move data between partitions
#
#     groups                         Manage consumer groups
#       list                           List all consumer groups
#       describe <group>               Show group members + offsets
#       lag <group>                    Show lag per partition
#       reset <group>
#         --to-earliest                  Reset to earliest offset
#         --to-latest                    Reset to latest offset
#         --to-timestamp <TS>            Reset to timestamp
#       delete <group> [--force]
#
#     produce <topic>                Produce messages to a topic
#         --key <KEY>                    Message key
#         --header <K:V>                 Message header (repeatable)
#         --file <PATH>                  Produce messages from file
#         --format <FMT>                 Format: text / json / yaml
#         --count <N>                    Send N random test messages
#         --size <BYTES>                 Size of each generated msg
#
#     consume <topic...>             Consume messages from topic(s)
#         --group <ID>                   Consumer group (auto-gen if unset)
#         --from-beginning               Start from beginning
#         --from-latest                  Start from latest
#         --limit <N>                    Limit number of messages
#                                        (0 = unlimited)
#         --output <FMT>                 Output: table / json / yaml / hex
#         --key-filter <PAT>             Filter by key (wildcards *)
#         --no-value                     Hide message values
#
#     brokers                        Inspect and manage Kafka brokers
#       list                           List all brokers
#       describe <broker-id>           Show broker metadata
#       metrics <broker-id>            Show broker metrics
#         -a, --analyze                  Enable AI-powered analysis
#         -p, --provider <P>             AI provider
#                                          (openai / claude / grok / gemini)
#         -m, --model <MODEL>            AI model name
#       configs
#         list                           List all broker configs
#         get <broker-id>                Show config for broker
#         set <broker-id> <k>=<v>        Update broker config
#
#     offsets                        Manage topic offsets
#       show <topic>                   Show offsets per partition
#       reset <topic>                  Reset to earliest (default)
#         --to-earliest
#         --to-latest
#         --to-timestamp <TS>
#
#     health                         Health checks and monitoring
#       check                          Run all health checks
#       brokers                        Check broker connectivity
#       topics                         Check topic health
#       groups                         Check consumer group health
#
#     tail <topic...>                Tail messages in real-time (-f)
#         --output <FMT>                 table / json / yaml / hex
#         --key-filter <PAT>             Wildcard key filter
#         --no-value                     Hide message values
#
#     cp <source-topic> <dest-topic> Copy messages between topics
#         --from-beginning
#         --limit <N>
#         --begin-offset <N>
#         --end-offset <N>
#
#     util                           Utility commands
#       random-key                     Generate random Kafka key
#         --length <N>                   Key length
#       dump-metadata                  Dump cluster metadata
#
#     version                        Show version information
#     completion <shell>             Generate shell completion script
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/confluentinc/confluent-kafka-go/v2
#   v2.11.1` declared in go.mod — the canonical Go Apache Kafka
#   client maintained by Confluent (confluentinc/confluent-kafka-go),
#   a Go wrapper over Magnus Edenhill's librdkafka C library
#   (the same upstream that powers the Rust `rdkafka` crate used by
#   _openwecd at R877).  confluent-kafka-go provides typed Producer,
#   Consumer, AdminClient, and SchemaRegistry APIs over the full
#   Kafka 0-9-1+ protocol with idempotent producers, transactional
#   producers, SASL/GSSAPI/PLAIN/SCRAM auth, OAuth bearer tokens,
#   and rebalance callbacks.  kafy's `internal/` clients call into
#   the AdminClient for topic / config / partition operations,
#   Producer for `kafy produce`, and Consumer for `kafy consume` /
#   `kafy tail`.  Verified via:
#     gh api repos/KLogicHQ/kafy/contents/go.mod
#       → github.com/confluentinc/confluent-kafka-go/v2 v2.11.1
#       → github.com/spf13/cobra v1.10.1
#   This entry is the Go=127 leader bump that continues Axis 72
#   (Apache Kafka Client Library) opened at R877 with Rust=
#   rdkafka 0.37.0 (cea-sec/openwec daemon).
#
#   No completion for `kafy` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_kafy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-o --output)'{-o+,--output=}'[output format (table/json/yaml)]:format:(table json yaml)' \
        '(-c --cluster)'{-c+,--cluster=}'[use specified cluster (override current context)]:cluster:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_kafy_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                config)    _kafy_config    && ret=0 ;;
                topics)    _kafy_topics    && ret=0 ;;
                groups)    _kafy_groups    && ret=0 ;;
                produce)   _kafy_produce   && ret=0 ;;
                consume)   _kafy_consume   && ret=0 ;;
                brokers)   _kafy_brokers   && ret=0 ;;
                offsets)   _kafy_offsets   && ret=0 ;;
                health)    _kafy_health    && ret=0 ;;
                tail)      _kafy_tail      && ret=0 ;;
                cp)        _kafy_cp        && ret=0 ;;
                util)      _kafy_util      && ret=0 ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
                version)   _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kafy_commands] )) ||
_kafy_commands() {
    local -a commands
    commands=(
        'config:manage Kafka cluster configurations and contexts'
        'topics:manage Kafka topics (create/list/describe/delete/alter/partitions/configs)'
        'groups:manage consumer groups and offsets'
        'produce:produce messages to a topic'
        'consume:consume messages from one or more topics'
        'brokers:inspect and manage Kafka brokers'
        'offsets:manage topic offsets'
        'health:health checks and monitoring'
        'tail:tail messages in real-time (like tail -f)'
        'cp:copy messages between topics'
        'util:utility commands (random-key, dump-metadata)'
        'completion:generate shell completion script'
        'version:show version information'
    )
    _describe -t commands 'kafy command' commands
}

(( $+functions[_kafy_config] )) ||
_kafy_config() {
    local -a sub
    sub=(
        'list:list all configured clusters'
        'current:show the current active cluster'
        'use:switch to a different cluster'
        'add:add a new cluster'
        'delete:remove a cluster'
        'rename:rename a cluster context'
        'update:update cluster configuration'
        'export:export config to YAML/JSON'
        'import:import config from YAML/JSON'
    )
    _arguments \
        '--bootstrap=[bootstrap broker address(es)]:address:' \
        '--zookeeper=[Zookeeper address (optional)]:address:' \
        '--broker-metrics-port=[broker metrics JMX port]:port:' \
        '--name=[new name for update]:name:' \
        '--force[skip confirmation]' \
        '1: : _describe -t commands "config subcommand" sub'
}

(( $+functions[_kafy_topics] )) ||
_kafy_topics() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_kafy_topics_commands' \
        '*::arg:->targs' && ret=0

    case $state in
        targs)
            case $words[1] in
                configs)
                    _arguments \
                        '1:configs subcommand:(list get set delete)' \
                        '*: :_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kafy_topics_commands] )) ||
_kafy_topics_commands() {
    local -a sub
    sub=(
        'list:list all topics'
        'describe:show details of a topic'
        'create:create a topic'
        'delete:delete a topic (with safety confirmation)'
        'alter:alter partitions or configs'
        'partitions:show partition details for all topics or a specific topic'
        'configs:manage topic configurations'
        'set-partitions:change the number of partitions for a topic'
        'move-partition:move data between partitions within the same topic'
    )
    _describe -t commands 'topics subcommand' sub
}

(( $+functions[_kafy_groups] )) ||
_kafy_groups() {
    _arguments \
        '--to-earliest[reset to earliest offset]' \
        '--to-latest[reset to latest offset]' \
        '--to-timestamp=[reset to timestamp]:timestamp:' \
        '--force[skip confirmation]' \
        '1:groups subcommand:(list describe lag reset delete)' \
        '*: :_files'
}

(( $+functions[_kafy_produce] )) ||
_kafy_produce() {
    _arguments \
        ':topic:' \
        '--key=[message key]:key:' \
        '*--header=[message header (repeatable, k:v or k=v)]:header:' \
        '--file=[produce messages from file]:file:_files' \
        '--format=[message format]:format:(text json yaml)' \
        '--count=[send N random test messages]:count:' \
        '--size=[size in bytes for each generated test message]:size:'
}

(( $+functions[_kafy_consume] )) ||
_kafy_consume() {
    _arguments \
        '*:topic:' \
        '--group=[consumer group ID (auto-generated if not provided)]:group:' \
        '--from-beginning[start from beginning]' \
        '--from-latest[start from latest messages]' \
        '--limit=[max messages (0 = unlimited)]:limit:' \
        '--output=[output format]:format:(table json yaml hex)' \
        '--key-filter=[filter messages by key (wildcards: * prefix* *suffix *contains*)]:pattern:' \
        '--no-value[hide message values from output]'
}

(( $+functions[_kafy_brokers] )) ||
_kafy_brokers() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_kafy_brokers_commands' \
        '*::arg:->bargs' && ret=0

    case $state in
        bargs)
            case $words[1] in
                metrics)
                    _arguments \
                        '(-a --analyze)'{-a,--analyze}'[enable AI-powered analysis]' \
                        '(-p --provider)'{-p+,--provider=}'[AI provider]:provider:(openai claude grok gemini)' \
                        '(-m --model)'{-m+,--model=}'[AI model name]:model:' \
                        ':broker id:' && ret=0 ;;
                configs)
                    _arguments \
                        '1:configs subcommand:(list get set)' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kafy_brokers_commands] )) ||
_kafy_brokers_commands() {
    local -a sub
    sub=(
        'list:list all brokers'
        'describe:show broker metadata'
        'metrics:show broker metrics (disk, CPU, requests)'
        'configs:manage broker configurations'
    )
    _describe -t commands 'brokers subcommand' sub
}

(( $+functions[_kafy_offsets] )) ||
_kafy_offsets() {
    _arguments \
        '--to-earliest[reset to earliest offset]' \
        '--to-latest[reset to latest offset]' \
        '--to-timestamp=[reset to timestamp]:timestamp:' \
        '1:offsets subcommand:(show reset)' \
        ':topic:'
}

(( $+functions[_kafy_health] )) ||
_kafy_health() {
    _arguments \
        '1:health subcommand:(check brokers topics groups)'
}

(( $+functions[_kafy_tail] )) ||
_kafy_tail() {
    _arguments \
        '*:topic:' \
        '--output=[output format]:format:(table json yaml hex)' \
        '--key-filter=[filter by key (wildcards)]:pattern:' \
        '--no-value[hide message values]'
}

(( $+functions[_kafy_cp] )) ||
_kafy_cp() {
    _arguments \
        ':source topic:' \
        ':destination topic:' \
        '--from-beginning[start copying from the beginning]' \
        '--limit=[max number of messages to copy]:limit:' \
        '--begin-offset=[begin copying from this offset]:offset:' \
        '--end-offset=[stop copying at this offset]:offset:'
}

(( $+functions[_kafy_util] )) ||
_kafy_util() {
    _arguments \
        '--length=[length of random key]:length:' \
        '1:util subcommand:(random-key dump-metadata)'
}

_kafy "$@"
