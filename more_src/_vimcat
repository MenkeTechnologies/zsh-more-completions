#compdef vimcat
# Documentation: https://github.com/rkitover/vimpager (vimcat script)
# Reference accessed: 2026-05-21
# Verified: upstream vimcat script option parsing.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help,-help,--usage,-usage}'[display help screen]' \
  '(- *)'{-v,--version,-version}'[show version information]' \
  '-n[print with line numbers]' \
  '-s[squeeze multiple blank lines into one]' \
  '-o+[output ANSI highlighted text to file or stdout]:file:_files' \
  '-t+[set scroll time in seconds]:seconds:' \
  '*--cmd+[run vim command before initialization]:cmd:' \
  '*-c+[run vim command after initialization]:cmd:' \
  '-u+[specify vimrc file to use]:file:_files' \
  '-x[enable debugging output on stderr]' \
  '*:file:_files' && ret=0

return ret
