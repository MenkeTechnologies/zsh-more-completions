#compdef vimcat
# Documentation: https://man.archlinux.org/man/extra/vimpager/vimcat.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[debug]' \
  '--debug-vim[vim debug]' \
  '-c+[ANSI columns]:n:' \
  '*:file:_files' && ret=0

return ret
