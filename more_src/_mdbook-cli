#compdef mdbook-cli
# _mdbook-cli — Rust mdBook documentation generator CLI alias (rust-lang team, Rust); clap-rs
# upstream: https://github.com/rust-lang/mdBook

_mdbook-cli() {
    local -a sub=(
        'init:create new mdbook'
        'build:build the book'
        'test:test code samples'
        'clean:clean output dir'
        'watch:watch and rebuild'
        'serve:serve with live reload'
        'completions:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mdbook subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '1:dir:_files -/' \
                    '--title=+[title]:str:' \
                    '--theme[copy default theme]' \
                    '--ignore=+[ignore]:str:(git none)' \
                    '--force[force]' ;;
                build) _arguments \
                    '1:dir:_files -/' \
                    '--dest-dir=+[output dir]:dir:_files -/' \
                    '-d+[output dir]:dir:_files -/' \
                    '--open[open in browser]' \
                    '-o[open in browser]' ;;
                serve) _arguments \
                    '1:dir:_files -/' \
                    '--dest-dir=+[output dir]:dir:_files -/' \
                    '-d+[output dir]:dir:_files -/' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--hostname=+[hostname]:host:_hosts' \
                    '-n+[hostname]:host:_hosts' \
                    '--open[open in browser]' \
                    '-o[open in browser]' ;;
                watch) _arguments \
                    '1:dir:_files -/' \
                    '--dest-dir=+[output dir]:dir:_files -/' \
                    '-d+[output dir]:dir:_files -/' \
                    '--open[open in browser]' \
                    '-o[open in browser]' ;;
                test) _arguments \
                    '1:dir:_files -/' \
                    '--library-path=+[lib path]:dir:_files -/' \
                    '-L+[lib path]:dir:_files -/' \
                    '--dest-dir=+[output dir]:dir:_files -/' \
                    '-d+[output dir]:dir:_files -/' \
                    '--chapter=+[chapter]:str:' \
                    '-c+[chapter]:str:' ;;
                clean) _arguments \
                    '1:dir:_files -/' \
                    '--dest-dir=+[output dir]:dir:_files -/' \
                    '-d+[output dir]:dir:_files -/' ;;
                completions) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_mdbook-cli "$@"
