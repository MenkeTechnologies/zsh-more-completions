#compdef javacc jjtree jjdoc
# Documentation: https://javacc.github.io/javacc/documentation/cli.html
# Reference accessed: 2026-05-19
# Verified: javacc.github.io CLI options reference. Removed invented
# -OUTPUT_LANGUAGE option (not in upstream option list).

local curcontext="$curcontext" ret=1

case $service in
  (javacc)
    _arguments \
      '-OUTPUT_DIRECTORY=[output directory]:dir:_files -/' \
      '-GRAMMAR_ENCODING=[grammar file encoding]:enc:' \
      '-JDK_VERSION=[target Java version]:ver:' \
      '-STATIC=[static methods]:flag:(true false)' \
      '-DEBUG_PARSER=[debug parser]:flag:(true false)' \
      '-DEBUG_LOOKAHEAD=[debug lookahead]:flag:(true false)' \
      '-DEBUG_TOKEN_MANAGER=[debug token manager]:flag:(true false)' \
      '-IGNORE_CASE=[ignore case]:flag:(true false)' \
      '-CACHE_TOKENS=[cache tokens]:flag:(true false)' \
      '-CHOICE_AMBIGUITY_CHECK=[choice ambiguity check depth]:n:' \
      '-OTHER_AMBIGUITY_CHECK=[other ambiguity check depth]:n:' \
      '-USER_TOKEN_MANAGER=[user token manager]:flag:(true false)' \
      '-USER_CHAR_STREAM=[user char stream]:flag:(true false)' \
      '-BUILD_PARSER=[build parser]:flag:(true false)' \
      '-BUILD_TOKEN_MANAGER=[build token manager]:flag:(true false)' \
      '-TOKEN_MANAGER_USES_PARSER=[token mgr uses parser]:flag:(true false)' \
      '-SANITY_CHECK=[sanity check]:flag:(true false)' \
      '-FORCE_LA_CHECK=[force lookahead check]:flag:(true false)' \
      '-COMMON_TOKEN_ACTION=[common token action]:flag:(true false)' \
      '-UNICODE_INPUT=[unicode input]:flag:(true false)' \
      '-KEEP_LINE_COLUMN=[keep line/column]:flag:(true false)' \
      '-JAVA_UNICODE_ESCAPE=[Java unicode escape]:flag:(true false)' \
      '-ERROR_REPORTING=[error reporting]:flag:(true false)' \
      '*:grammar:_files -g "*.jj"' && ret=0 ;;
  (jjtree)
    _arguments \
      '-OUTPUT_DIRECTORY=[output directory]:dir:_files -/' \
      '-MULTI=[multi mode]:flag:(true false)' \
      '-NODE_DEFAULT_VOID=[node default void]:flag:(true false)' \
      '-NODE_CLASS=[node class]:class:' \
      '-NODE_FACTORY=[node factory]:flag:(true false)' \
      '-NODE_PACKAGE=[node package]:pkg:' \
      '-NODE_PREFIX=[node prefix]:prefix:' \
      '-NODE_SCOPE_HOOK=[node scope hook]:flag:(true false)' \
      '-NODE_USES_PARSER=[node uses parser]:flag:(true false)' \
      '-BUILD_NODE_FILES=[build node files]:flag:(true false)' \
      '-VISITOR=[visitor]:flag:(true false)' \
      '-VISITOR_DATA_TYPE=[visitor data type]:type:' \
      '-VISITOR_RETURN_TYPE=[visitor return type]:type:' \
      '-VISITOR_EXCEPTION=[visitor exception]:exception:' \
      '-STATIC=[static]:flag:(true false)' \
      '-OUTPUT_FILE=[output file]:file:_files' \
      '-TRACK_TOKENS=[track tokens]:flag:(true false)' \
      '*:jj:_files -g "*.jjt"' && ret=0 ;;
  (jjdoc)
    _arguments \
      '-TEXT=[text output]:flag:(true false)' \
      '-BNF=[BNF output]:flag:(true false)' \
      '-OUTPUT_FILE=[output file]:file:_files' \
      '-CSS=[CSS file]:file:_files' \
      '*:grammar:_files -g "*.jj"' && ret=0 ;;
esac

return ret
