#compdef termshark

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-i+[interface to capture from]:interface:_net_interfaces' \
  '-r+[read packet data from file]:capture file:_files' \
  '-w+[write raw packet data to file]:output file:_files' \
  '-f+[capture filter expression]:filter' \
  '-Y+[display filter expression]:display filter' \
  '-d+[decode as]:decode specification' \
  '-D[list available interfaces]' \
  '-T+[output format]:format:(json jsonraw ek tabs text pdml ps psml)' \
  '-c+[stop after n packets]:packet count' \
  '--pass-thru=[control pass-thru mode]:mode:(auto true false)' \
  '--log-tty[log to terminal]' \
  '--debug[enable debug logging]' \
  '--tshark-args=[extra tshark arguments]:args' \
  '*:capture filter' && ret=0

return ret
