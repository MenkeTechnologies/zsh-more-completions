#compdef algod
# _algod — Algorand algod node daemon running consensus REST API gossip and ledger storage for Algorand mainnet testnet betanet and devnet (algorand team, Go); cobra
# upstream: https://github.com/algorand/go-algorand

_algod() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d+[data dir]:dir:_files -/' \
        '--data=+[data dir]:dir:_files -/' \
        '-g+[genesis file]:file:_files -g "*.json"' \
        '--genesis=+[genesis file]:file:_files -g "*.json"' \
        '-G+[genesis ID]:str:' \
        '--genesis-id=+[genesis ID]:str:' \
        '-l+[listen addr]:str:' \
        '--listen=+[listen addr]:str:' \
        '-p+[peer ip:port]:str:' \
        '--peer=+[peer ip:port]:str:' \
        '-P+[phonebook file]:file:_files' \
        '--phonebook=+[phonebook file]:file:_files' \
        '-x+[seed]:str:' \
        '--seed=+[seed]:str:' \
        '-s[install profiler]' \
        '--profile[install profiler]' \
        '-t+[telemetry override]:str:' \
        '--telemetry-override=+[telemetry override]:str:' \
        '--telemetryURI=+[uri]:str:' \
        '--logname=+[name]:str:' \
        '--logTag=+[tag]:str:' \
        '--logHost=+[host]:h:_hosts' \
        '-n[no override profiler]' \
        '--no-profiler-override[no override profiler]' \
        '-T+[cpu profile file]:file:_files' \
        '--cpuprofile=+[cpu profile file]:file:_files' \
        '--memprofile=+[mem profile file]:file:_files' \
        '--blockProfile=+[block profile file]:file:_files' \
        '--mutexProfile=+[mutex profile file]:file:_files' \
        '--traceFile=+[trace file]:file:_files' \
        '--hostedIPC=+[path]:file:_files' \
        '--listenNotify=+[count]:n:' \
        '--init-and-exit[init and exit]' \
        '--validate-with-tools[validate with tools]'
}

_algod "$@"
