#compdef afcclient
# _afcclient — interactive AFC (Apple File Conduit) shell for iOS devices (libimobiledevice/libimobiledevice)
# upstream: https://github.com/libimobiledevice/libimobiledevice
# Flags + REPL commands from tools/afcclient.c.

_afcclient() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-u --udid)'{-u+,--udid=}'[target the specific device by UDID]:udid:' \
        '(-n --network)'{-n,--network}'[connect to a network-attached device (not recommended)]' \
        '(-d --debug)'{-d,--debug}'[enable communication debugging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_afcclient_commands' \
        '*::arg:' && ret=0

    return ret
}

(( $+functions[_afcclient_commands] )) ||
_afcclient_commands() {
    local -a commands
    commands=(
        'ls:list directory contents (use -l for long form)'
        'pwd:print the working directory on the device'
        'cd:change directory on the device'
        'mkdir:create a directory on the device'
        'rm:remove a file or directory (-r recursive, -f force)'
        'ln:create a hard / symbolic link (-s for symbolic)'
        'mv:move / rename a file on the device'
        'get:download a file from the device (-r recursive, -f overwrite)'
        'put:upload a file to the device (-r recursive, -f overwrite)'
        'info:show AFC connection info'
        'devinfo:print device file-system info'
        'stat:print stat() for a file on the device'
        'help:show interactive help'
        'quit:exit the AFC shell'
    )
    _describe -t commands 'afcclient command' commands
}

_afcclient "$@"
