#compdef genomeCoverageBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/genomecov.html
# compute genome-wide coverage of features (bedtools genomecov)

local ret=1

_arguments -s -S \
  '-ibam[BAM file as input for coverage]:file:_files' \
  '-i[input file (BED/GFF/VCF)]:file:_files' \
  '-g[genome file to define chromosome lengths]:file:_files' \
  '-d[report depth at each genome position (1-based)]' \
  '-dz[report depth at each non-zero position (0-based)]' \
  '-bg[report depth in BedGraph format]' \
  '-bga[BedGraph output including zero-coverage regions]' \
  '-split[treat split BAM/BED12 entries as distinct intervals]' \
  '-strand[calculate coverage on a specific strand]:strand:(+ -)' \
  '-pc[coverage from left to right point of paired reads]' \
  '-fs[force fragment size instead of read length]:size' \
  '-5[calculate coverage of 5-prime positions]' \
  '-3[calculate coverage of 3-prime positions]' \
  '-max[combine positions with depth >= max into one bin]:max' \
  '-scale[scale coverage by a constant factor]:factor' \
  '-trackline[add UCSC Genome Browser track line]' \
  '-trackopts[additional track line definition parameters]:opts' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
