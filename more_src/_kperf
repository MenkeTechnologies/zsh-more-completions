#compdef kperf
# Documentation: https://github.com/knative-extensions/kperf
# Knative performance benchmarking and load-testing tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--namespace=[target namespace]:namespace' \
  '--namespace-prefix=[prefix for multiple namespaces]:prefix' \
  '--namespace-range=[namespace index range e.g. 1,3]:range' \
  '--svc-prefix=[service name prefix]:prefix' \
  '(-n --number)'{-n,--number}'+[total count of services to create]:number' \
  '(-b --batch)'{-b,--batch}'+[services created per interval]:batch' \
  '(-c --concurrency)'{-c,--concurrency}'+[concurrent creation workers]:concurrency' \
  '(-i --interval)'{-i,--interval}'+[time between batch creations]:interval' \
  '--range=[service index range]:range' \
  '--output=[result file destination]:file:_files' \
  '--verbose[detailed output]' \
  '*:command:(service eventing)' && ret=0

return ret
