#compdef checkly-cli checkly
# _checkly-cli — Checkly checkly-cli CLI command-line frontend wrapping the Checkly synthetic monitoring API monitoring uptime browser checks platform monitoring-as-code MaaC providing login logout deploy destroy test trigger import switch runtimes private-locations account whoami sync record-replay snapshot Playwright-based-Browser-checks Multi-step-API-Checks Heartbeat status-page-incidents (Checkly team, TypeScript); commander
# upstream: https://www.checklyhq.com/

_checkly-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'deploy:deploy resources'
        'destroy:destroy resources'
        'test:run tests'
        'trigger:trigger checks'
        'import:import existing resources'
        'sync:sync with Checkly'
        'switch:switch account'
        'runtimes:list runtimes'
        'pwt:run a Playwright command'
        'record-replay:record/replay session'
        'snapshot:snapshot operations'
        'private-locations:private location ops'
        'account:account operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--account-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "checkly.config.*"' \
        '--config=+[file]:file:_files -g "checkly.config.*"' \
        '-l+[locations]:str:' \
        '--locations=+[locs]:str:' \
        '--private-locations=+[locs]:str:' \
        '-g+[grep]:str:' \
        '--grep=+[pattern]:str:' \
        '-t+[tags]:str:' \
        '--tags=+[tags]:str:' \
        '-r+[reporter]:r:(list ci dot json github)' \
        '--reporter=+[r]:r:(list ci dot json github)' \
        '--record[record results]' \
        '--update-snapshots[update snapshots]' \
        '-n+[N]:n:' \
        '--n-replicas=+[N]:n:' \
        '--force[force]' \
        '--preview[preview]' \
        '--retries=+[N]:n:' \
        '--schedule-on-deploy[schedule on deploy]' \
        '--parallel[parallel]' \
        '--timeout=+[sec]:n:' \
        '--env=+[k=v]:str:' \
        '-e+[k=v]:str:' \
        '--env-file=+[file]:file:_files -g ".env*"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'checkly subcommand' sub ;;
        args)
            case $words[1] in
                runtimes|private-locations|account) _arguments '1:op:(list get use)' '*:name:' ;;
            esac
            ;;
    esac
}

_checkly-cli "$@"
