#compdef rpmdev-newspec
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-newspec.in
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools rpmdev-newspec.in source.
# Removed from prior file: fabricated -r/--rpm-version flag (does not exist).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-o --output)'{-o+,--output=}'[output spec file (- for stdout)]:file:_files' \
  '(-t --type)'{-t+,--type=}'[template type]:type:(minimal lib python perl R php-pear ruby ocaml dummy)' \
  '(-m --macros)'{-m,--macros}'[emit templates using macros instead of shell variables]' \
  '(- *)'{-h,--help}'[show usage]' \
  '(- *)'{-v,--version}'[print version]' \
  ':app name:' && ret=0
return ret
