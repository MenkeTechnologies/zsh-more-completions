#compdef mBgModel
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mBgModel.html
# Compute a global background correction model from overlap difference fits

local ret=1

_arguments -s -S \
  '-i+[number of iterations (1-32767, default 5000)]:niter' \
  '-l[calculate level adjustments only]' \
  '-d+[debugging level (1-3)]:level' \
  '-r+[extra debugging for nth image]:refimg' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '1:images table:_files -g "*.tbl"' \
  '2:fits table:_files -g "*.tbl"' \
  '3:corrections table:_files -g "*.tbl"' && ret=0

return ret
