#compdef acra-rollback
# _acra-rollback — decrypt and re-insert Acra-encrypted DB data (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Flags from cmd/acra-rollback/acra-rollback.go (flag).

_acra-rollback() {
    _arguments \
        '(- *)-h[show help]' \
        '-keys_dir=[folder containing keys]:dir:_files -/' \
        '-client_id=[client ID / private key file name]:id:' \
        '-connection_string=[DB connection string]:dsn:' \
        '-select=[SELECT query to fetch data for decryption]:sql:' \
        '-insert=[INSERT query template for decrypted rows]:sql:' \
        '-output_file=[file to store generated INSERTs]:file:_files -g "*.sql"' \
        '-execute[execute generated INSERTs against DB]' \
        '-escape[escape bytea format]' \
        '-mysql_enable[handle MySQL connections]' \
        '-postgresql_enable[handle PostgreSQL connections]' \
        '-tls_database_enabled[enable TLS for DB connection]'
}

_acra-rollback "$@"
