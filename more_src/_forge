#compdef forge

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'bind:generate Rust bindings for smart contracts'
  'bind-json:generate bindings for project struct (de)serialization'
  'build:build the project smart contracts'
  'cache:manage the Foundry cache'
  'clean:remove build artifacts and cache'
  'clone:clone a contract from Etherscan'
  'compiler:compiler utilities'
  'completions:generate shell completions'
  'config:display the current config'
  'coverage:generate coverage reports'
  'create:deploy a smart contract'
  'doc:generate documentation for the project'
  'eip712:generate EIP-712 struct encodings'
  'flatten:flatten a source file and imports'
  'fmt:format Solidity source files'
  'geiger:detect usage of unsafe cheat codes (deprecated)'
  'help:show help'
  'init:create a new Forge project'
  'inspect:get specialized information about a contract'
  'install:install one or multiple dependencies'
  'lint:lint Solidity source files'
  'remappings:get inferred remappings'
  'remove:remove one or multiple dependencies'
  'script:run a smart contract as a script'
  'selectors:function selector utilities'
  'snapshot:create a gas snapshot of test gas usage'
  'soldeer:Soldeer dependency manager'
  'test:run the project tests'
  'tree:display project dependency tree'
  'update:update dependencies'
  'verify-bytecode:verify deployed bytecode against source'
  'verify-check:check verification status on Etherscan'
  'verify-contract:verify smart contracts on Etherscan'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'forge subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (test)
        _arguments \
          '(-mt --match-test)'{-mt,--match-test=}'[run tests matching regex]:regex:' \
          '(-nmt --no-match-test)'{-nmt,--no-match-test=}'[skip tests matching regex]:regex:' \
          '(-mc --match-contract)'{-mc,--match-contract=}'[run contracts matching regex]:regex:' \
          '(-nmc --no-match-contract)'{-nmc,--no-match-contract=}'[skip contracts matching regex]:regex:' \
          '(-mp --match-path)'{-mp,--match-path=}'[run files matching glob]:glob:' \
          '(-nmp --no-match-path)'{-nmp,--no-match-path=}'[skip files matching glob]:glob:' \
          '*-v[increase verbosity (repeat)]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '--json[JSON output]' \
          '--md[markdown output]' \
          '--junit[JUnit XML output]' \
          '(-l --list)'{-l,--list}'[list tests]' \
          '--summary[print test summary]' \
          '--detailed[detailed test summary]' \
          '(-r --rpc-url)'{-r,--rpc-url=}'[RPC URL]:url:' \
          '--fork-block-number=[fork block number]:n:' \
          '--gas-report[generate gas report]' \
          '--debug[debug a single test]' \
          '--fail-fast[stop on first test failure]' \
          '(-j --threads)'{-j,--threads=}'[number of threads]:n:' \
          '--fuzz-seed=[fuzz seed]:seed:' \
          '--fuzz-runs=[fuzz runs]:n:' \
          '--rerun[rerun failed tests]' \
          '(-w --watch)'{-w,--watch}'[watch mode]' && ret=0
        ;;
      (build|create|script|coverage|inspect|fmt|lint|doc|flatten|snapshot)
        _files
        ret=0
        ;;
      (completions)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' 'elvish' && ret=0
        ;;
      (cache)
        _values 'cache action' 'ls' 'clean' && ret=0
        ;;
      (compiler)
        _values 'compiler action' 'resolve' 'list' && ret=0
        ;;
      (selectors)
        _values 'selectors action' 'collision' 'find' 'list' 'cache' 'upload' && ret=0
        ;;
      (soldeer)
        _values 'soldeer action' \
          'init' 'install' 'login' 'push' 'update' 'version' && ret=0
        ;;
    esac
    ;;
esac

return ret
