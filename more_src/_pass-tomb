#compdef pass-tomb

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'open:open the password tomb'
      'close:close the password tomb'
      'create:create a new password tomb'
      'resize:resize the password tomb'
      'timer:set auto-close timer'
    )
    _describe -t commands 'pass tomb command' commands && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '-n[do not use GPG agent]' \
          '-t[tomb size in MB]:size' \
          '-f[force creation]' \
          '-p[path to tomb file]:file:_files' && ret=0
        ;;
      open)
        _arguments \
          '-n[do not use GPG agent]' \
          '-t[set auto-close timer in seconds]:seconds' \
          '-f[force open]' \
          '-p[path to tomb file]:file:_files' && ret=0
        ;;
      close)
        _arguments '-f[force close]' && ret=0
        ;;
      resize)
        _arguments '-s[new size in MB]:size' && ret=0
        ;;
      timer)
        _arguments '1:seconds' && ret=0
        ;;
    esac
    ;;
esac

return ret
