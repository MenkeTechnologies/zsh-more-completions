#compdef ios-sim
# _ios-sim — iOS Simulator command-line driver (Node.js); launches/installs/uninstalls apps on iOS simulators
# upstream: https://github.com/phonegap/ios-sim

_ios-sim() {
    local -a sub=(
        'showsdks:list installed simulator SDKs'
        'showdevicetypes:list available device types'
        'launch:launch app bundle on simulator'
        'install:install app bundle on simulator'
        'start:start simulator'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--devicetypeid+[device type id]:type:' \
        '--sdk+[SDK version]:ver:' \
        '--family+[family]:family:(iphone ipad)' \
        '--retina[retina simulator]' \
        '--tall[4-inch retina]' \
        '--64bit[64-bit simulator]' \
        '--log+[log file]:file:_files' \
        '--stdout+[stdout file]:file:_files' \
        '--stderr+[stderr file]:file:_files' \
        '--timeout+[launch timeout]:sec:' \
        '--exit[exit when app exits]' \
        '--setenv+[env var]:KEY=VAL:' \
        '--args+[app args]:args:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ios-sim subcommand' sub ;;
        args)
            case $words[1] in
                launch|install) _arguments '*:app bundle:_files -g "*.app"' ;;
            esac
            ;;
    esac
}

_ios-sim "$@"
