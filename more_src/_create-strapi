#compdef create-strapi
# Documentation: https://docs.strapi.io/cms/installation/cli
# create-strapi - scaffold a new Strapi 5 application

local ret=1

_arguments -s -S \
  '--no-run[do not start the application after creation]' \
  '(--ts --typescript)'{--ts,--typescript}'[set up the project with TypeScript]' \
  '(--js --javascript)'{--js,--javascript}'[set up the project with JavaScript]' \
  '--use-npm[use npm as the package manager]' \
  '--use-pnpm[use pnpm as the package manager]' \
  '--install[install dependencies, skip prompt]' \
  '--no-install[skip dependency installation]' \
  '--git-init[initialize a git repository, skip prompt]' \
  '--no-git-init[do not initialize a git repository]' \
  '--example[include example data, skip prompt]' \
  '--no-example[exclude example data]' \
  '--skip-cloud[skip Strapi Cloud login/signup step]' \
  '--non-interactive[skip all prompts and use defaults]' \
  '--skip-db[skip database prompts, use default SQLite]' \
  '--template=[create from the specified template]:template:' \
  '--dbclient=[set database type]:client:(sqlite postgres mysql)' \
  '--dbhost=[database host address]:host:' \
  '--dbport=[database port]:port:' \
  '--dbname=[database name]:name:' \
  '--dbusername=[database admin username]:user:' \
  '--dbpassword=[database admin password]:password:' \
  '--dbssl=[enable or disable SSL connection]:ssl:(true false)' \
  '--dbfile=[SQLite database file path]:file:_files' \
  '1:project-directory:_files -/' && ret=0

return ret
