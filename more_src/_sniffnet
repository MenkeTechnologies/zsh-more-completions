#compdef sniffnet
# Documentation: https://man.archlinux.org/search?q=sniffnet
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-a --adapter)'{-a,--adapter}'[network adapter to inspect]:adapter' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
