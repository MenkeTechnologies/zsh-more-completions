#compdef xfce4-orage orage
# Documentation: https://manpages.debian.org/buster/orage/orage.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian buster orage(1) manpage. Binary is `orage`.

# Orage: XFCE calendar/appointment manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-? --help)'{-?,--help}'[show help]' \
  '(-p --preferences)'{-p,--preferences}'[open preferences window]' \
  '(-t --toggle)'{-t,--toggle}'[toggle Orage visibility]' \
  '(-a --add-foreign)'{-a,--add-foreign=}'[add foreign file (read-only by default; suffix RW for read-write)]:file:_files -g "*.ics"' \
  '(-r --remove-foreign)'{-r,--remove-foreign=}'[remove foreign file]:file:_files -g "*.ics"' && ret=0
return ret
