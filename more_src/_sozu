#compdef sozu
# Documentation: https://man.archlinux.org/search?q=sozu
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '-c+[Path to sozu TOML config]:file:_files -g "*.toml(-.)"' \
  '-p+[PID file path]:file:_files' \
  '--help[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'start:Launch the sozu process manager'
      'worker:Run a proxy worker'
      'reload:Reload configuration without downtime'
      'quit:Stop the proxy gracefully'
      'shutdown:Hard-stop all listeners'
      'status:Dump current proxy status'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
