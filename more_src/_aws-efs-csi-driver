#compdef aws-efs-csi-driver
# _aws-efs-csi-driver — AWS EFS CSI driver
# upstream: https://github.com/kubernetes-sigs/aws-efs-csi-driver
# Flags from cmd/main.go + pkg/driver/options.go on tip.

_aws-efs-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--efs-utils-config-dir-path=[preferred efs-utils config dir]:dir:_files -/' \
        '--efs-utils-config-legacy-dir-path=[legacy efs-utils config dir]:dir:_files -/' \
        '--efs-utils-static-files-path=[efs-utils static files dir]:dir:_files -/' \
        '--vol-metrics-opt-in[emit volume metrics]' \
        '--vol-metrics-refresh-period=[volume metrics refresh period (minutes)]:n:' \
        '--vol-metrics-fs-rate-limit=[volume metrics routines rate limit per filesystem]:n:' \
        '--delete-access-point-root-dir[delete access-point root dir on DeleteVolume]' \
        '--adaptive-retry-mode=[use AWS adaptive retry mode]:bool:(true false)' \
        '--tags=[space-separated key:value tags for EFS resources]:tags:' \
        '--max-inflight-mount-calls-opt-in[opt in to max-inflight-mount-calls]' \
        '--max-inflight-mount-calls=[block NodePublishVolume when this many calls are inflight]:n:' \
        '--volume-attach-limit-opt-in[opt in to volume-attach-limit]' \
        '--volume-attach-limit=[max volumes per node]:n:' \
        '--force-unmount-after-timeout[force-unmount if normal unmount times out]' \
        '--unmount-timeout=[timeout before force unmount]:duration:' \
        '--debug-logs[set klog verbosity to 5 + enable efs-utils debug logging]' \
        '--efs-cloudwatch-log-enabled[enable CloudWatch logging for EFS]' \
        '--s3files-cloudwatch-log-enabled=[enable CloudWatch logging for S3Files]:bool:(true false)' \
        '--s3files-cloudwatch-metrics-enabled=[enable CloudWatch metrics for S3Files]:bool:(true false)' \
        '--efs-utils-conf-overrides=[csv section:key=value overrides for efs-utils.conf]:overrides:' \
        '--s3files-utils-conf-overrides=[csv section:key=value overrides for s3files-utils.conf]:overrides:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_aws-efs-csi-driver "$@"
