#compdef nfs-subdir-external-provisioner
# _nfs-subdir-external-provisioner — NFS subdir external dynamic-PV provisioner
# upstream: https://github.com/kubernetes-sigs/nfs-subdir-external-provisioner
# Configuration via env (NFS_SERVER, NFS_PATH, etc.); flags from cmd/nfs-subdir-external-provisioner/provisioner.go on tip.

_nfs-subdir-external-provisioner() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[Kubernetes API server URL]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--logtostderr=[log to stderr]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_nfs-subdir-external-provisioner "$@"
