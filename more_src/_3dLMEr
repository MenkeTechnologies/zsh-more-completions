#compdef 3dLMEr
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLMEr.html
# AFNI: voxel-wise linear mixed-effects modeling via lme4

local ret=1

_arguments -s -S \
  '-bounds[lower/upper bounds for outlier removal]:lower:' \
  '-cio[use AFNI C IO functions (default)]' \
  '-dataTable[data structure with header; last option]:table:' \
  '-dbgArgs[save parameters for debugging]' \
  '-glfCode[general linear F-test code]:code:' \
  '-gltCode[general linear t-test code]:code:' \
  '-help[display help]' \
  '-IF[column name for input files (default InputFile)]:name:' \
  '-jobs[number of parallel processors]:n:' \
  '-mask[process voxels within mask only]:mask:_files' \
  '-model[model with fixed and random effects (R formula)]:formula:' \
  '-prefix[output filename]:prefix:' \
  '-qVarCenters[centering values for quantitative vars]:values:' \
  '-qVars[quantitative variables/covariates]:vars:' \
  '-R2[output conditional and marginal R-squared]' \
  '-resid[output filename for residuals]:prefix:' \
  '-Rio[use R IO functions]' \
  '-show_allowed_options[list all allowed options]' \
  '-SS_type[sum of squares type]:type:(1 2 3)' \
  '-TRR[test-retest reliability analysis]' \
  '-vVarCenters[centering values for voxel-wise covariates]:values:' \
  '-vVars[voxel-wise covariates]:vars:' \
  '*:dataset:_files' && ret=0

return ret
