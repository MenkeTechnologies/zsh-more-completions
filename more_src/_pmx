#compdef pmx
# Documentation: https://github.com/deGrootLab/pmx
# pmx command line tool for alchemical free energy calculations

local ret=1
local curcontext="$curcontext" state line

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show installed pmx version]' \
  '1:command:(mutate gentop analyse gmxlib)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      mutate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-f[input structure file (pdb or gro)]:file:_files' \
          '-fB[input structure file for B state]:file:_files' \
          '-o[output structure file]:file:_files' \
          '-ff[path to mutation forcefield directory]:ff' \
          '-script[text file with mutations to apply]:file:_files' \
          '-resinfo[display 3-letter to 1-letter residue code map]' \
          '-dna[generate hybrid residues for DNA nucleotides]' \
          '-rna[generate hybrid residues for RNA nucleotides]' && ret=0
        ;;
      gentop)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-p[input topology file (.top)]:file:_files' \
          '-itp[optional input ITP file]:file:_files' \
          '-o[output topology or ITP file]:file:_files' \
          '-ff[directory containing the mutation force field]:ff' \
          '-log[log output file]:file:_files' \
          '-split[write split topologies for vdw and q morphs]' \
          '-scale_mass[scale dummy atom masses to 1.0]' \
          '-dna[generate hybrid residue for DNA nucleotides]' \
          '-rna[generate hybrid residue for RNA nucleotides]' && ret=0
        ;;
      analyse)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*-fA[input dgdl.xvg files for A to B]:file:_files' \
          '*-fB[input dgdl.xvg files for B to A]:file:_files' \
          '-m[estimators: CGI BAR JARZ]:estimator:(CGI BAR JARZ)' \
          '-t[temperature in Kelvin]:temperature' \
          '-o[output results filename]:file:_files' \
          '-b[bootstrap samples for standard error]:bootstrap' \
          '-n[number of blocks for dividing data]:blocks' \
          '-iA[two-column file with integrated work values A to B]:file:_files' \
          '-iB[two-column file with integrated work values B to A]:file:_files' \
          '-oA[output file for integrated work values A to B]:file:_files' \
          '-oB[output file for integrated work values B to A]:file:_files' \
          '--reverseB[reverse sign of backward work values]' \
          '--integ_only[only integrate, skip analysis]' \
          '--skip[select every nth work value]:skip' \
          '--rand[random subset size of trajectories]:rand' \
          '--prec[decimal precision for output]:prec' \
          '--units[output units]:units:(kj kcal kt)' \
          '--pickle[save estimator results to pickled files]' \
          '--no_ks[disable Kolmogorov-Smirnov normality test]' \
          '--work_plot[output plot filename]:file:_files' \
          '--nbins[histogram bins for plot]:nbins' \
          '--dpi[plot resolution]:dpi' && ret=0
        ;;
      gmxlib)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
