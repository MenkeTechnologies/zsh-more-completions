#compdef vkrunner
# Documentation: https://github.com/Igalia/vkrunner
# Reference accessed: 2026-05-21
# Verified: upstream source src/main.c options table.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --image)'{-i,--image}'+[write final rendering to IMG as PPM]:file:_files -g "*.ppm"' \
  '(-b --buffer)'{-b,--buffer}'+[dump UBO/SSBO contents to BUF]:file:_files' \
  '(-B --binding)'{-B,--binding}'+[select binding to dump]:binding:' \
  '(-d --disasm)'{-d,--disasm}'[show SPIR-V disassembly]' \
  '(-D --replace)'{-D,--replace}'+[replace TOK with REPL in scripts]:TOK=REPL:' \
  '(-q --quiet)'{-q,--quiet}'[do not print non-error info]' \
  '--device-id=[select Vulkan device]:devid:' \
  '*:test_script:_files -g "*.shader_test"' && ret=0

return ret
