#compdef vkrunner
# Documentation: https://man.archlinux.org/search?q=vkrunner
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --image-file)'{-i,--image-file}'+[output image file]:file:_files -g "*.{ppm,png}"' \
  '(-d --dump-disasm)'{-d,--dump-disasm}'[dump shader disasm]' \
  '(--verbose)--verbose[verbose]' \
  '(-D --define)'{-D,--define}'+[define preprocessor variable]:var:' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-V --vk-validation)'{-V,--vk-validation}'+[validation layer]:val:(true false)' \
  '(--device-id)--device-id=+[Vulkan device id]:id:' \
  '*:test_script:_files -g "*.shader_test"' && ret=0

return ret
