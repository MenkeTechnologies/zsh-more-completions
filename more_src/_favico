# Source: cargo binstall favico@0.1.12
# Probed via: --generate-completion zsh
# Repository: https://github.com/sorairolake/favico
#compdef favico

autoload -U is-at-least

_favico() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-o+[Directory to output generated files]:PATH:_files -/' \
'--output=[Directory to output generated files]:PATH:_files -/' \
'--name=[Set the name member of the web app manifest]:NAME:_default' \
'--short-name=[Set the short_name member of the web app manifest]:NAME:_default' \
'--theme-color=[Set the theme_color member of the web app manifest]:COLOR:_default' \
'--background-color=[Set the background_color member of the web app manifest]:COLOR:_default' \
'--filter=[Sampling filter used to resize the input image]:FILTER:((nearest\:"Nearest Neighbor"
triangle\:"Linear Filter"
catmullrom\:"Cubic Filter"
gaussian\:"Gaussian Filter"
lanczos3\:"Lanczos with window 3"))' \
'-f+[The format of the input]:FORMAT:((bmp\:"Windows Bitmap"
dds\:"DirectDraw Surface"
farbfeld\:"Farbfeld"
gif\:"Graphics Interchange Format"
hdr\:"Radiance RGBE"
ico\:"ICO file format"
jpeg\:"JPEG"
openexr\:"OpenEXR"
png\:"Portable Network Graphics"
pnm\:"Portable Anymap Format"
qoi\:"Quite OK Image Format"
tga\:"Truevision TGA"
tiff\:"Tag Image File Format"
webp\:"WebP"
xbm\:"X BitMap"))' \
'--format=[The format of the input]:FORMAT:((bmp\:"Windows Bitmap"
dds\:"DirectDraw Surface"
farbfeld\:"Farbfeld"
gif\:"Graphics Interchange Format"
hdr\:"Radiance RGBE"
ico\:"ICO file format"
jpeg\:"JPEG"
openexr\:"OpenEXR"
png\:"Portable Network Graphics"
pnm\:"Portable Anymap Format"
qoi\:"Quite OK Image Format"
tga\:"Truevision TGA"
tiff\:"Tag Image File Format"
webp\:"WebP"
xbm\:"X BitMap"))' \
'--generate-completion=[Generate shell completion]:SHELL:((bash\:"Bash"
elvish\:"Elvish"
fish\:"fish"
nushell\:"Nushell"
powershell\:"PowerShell"
zsh\:"Zsh"))' \
'--png[Store PNG images instead of BMP images to an ICO image]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input image file:_files' \
&& ret=0
}

(( $+functions[_favico_commands] )) ||
_favico_commands() {
    local commands; commands=()
    _describe -t commands 'favico commands' commands "$@"
}

if [ "$funcstack[1]" = "_favico" ]; then
    _favico "$@"
else
    compdef _favico favico
fi
