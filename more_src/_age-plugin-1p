#compdef age-plugin-1p
# Documentation: https://github.com/Enzime/age-plugin-1p
# use SSH keys stored in 1Password with age

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--print-recipients[print public keys of 1Password SSH keys in authorized_keys format]' && ret=0

return ret
