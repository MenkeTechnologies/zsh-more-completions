#compdef tetragon tetra
# _tetragon-cli — Cilium Tetragon eBPF runtime security CLI (Isovalent/Cilium, Go); manage Tetragon agent and tracing policies
# upstream: https://github.com/cilium/tetragon

_tetragon-cli() {
    local -a sub=(
        'getevents:print Tetragon events'
        'tracingpolicy:manage tracing policies'
        'completion:print shell completion'
        'debug:debug commands'
        'metrics:show metrics'
        'rthooks:list runtime hooks'
        'stacktrace:show stack trace'
        'status:show Tetragon status'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '-s+[server addr]:addr:' \
        '--server-address+[server addr]:addr:' \
        '--retries+[retries]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tetragon subcommand' sub ;;
        args)
            case $words[1] in
                getevents) _arguments \
                    '--event-fields+[fields]:fields:' \
                    '--namespaces+[ns filter]:ns:' \
                    '-n+[ns filter]:ns:' \
                    '--pods+[pods filter]:pods:' \
                    '--processes+[process regex]:regex:' \
                    '-p+[process regex]:regex:' \
                    '--types+[event types]:types:' \
                    '-t+[event types]:types:' \
                    '--exclude-fields+[exclude fields]:fields:' \
                    '--exclude-namespaces+[exclude namespaces]:ns:' \
                    '--exclude-pods+[exclude pods]:pods:' \
                    '-o+[output format]:fmt:(compact json)' \
                    '--output+[output format]:fmt:' ;;
                tracingpolicy) _arguments '1:tp cmd:(list add delete)' '*:args:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_tetragon-cli "$@"
