#compdef deno

# Zsh completion for deno (JavaScript/TypeScript runtime)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-q[Suppress diagnostic output]' \
  '--quiet[Suppress diagnostic output]' \
  '--unstable[Enable unstable features and APIs]' \
  '--unstable-bare-node-builtins[Enable unstable bare node builtins]' \
  '--unstable-byonm[Enable unstable bring your own node_modules]' \
  '--unstable-sloppy-imports[Enable unstable sloppy imports]' \
  '--unstable-webgpu[Enable unstable WebGPU API]' \
  '--unstable-broadcast-channel[Enable unstable BroadcastChannel API]' \
  '--unstable-ffi[Enable unstable FFI APIs]' \
  '--unstable-fs[Enable unstable file system APIs]' \
  '--unstable-kv[Enable unstable Key-Value store APIs]' \
  '--unstable-net[Enable unstable net APIs]' \
  '--unstable-http[Enable unstable HTTP APIs]' \
  '--unstable-worker-options[Enable unstable Web Worker APIs]' \
  '--unstable-cron[Enable unstable Deno.cron API]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bench:Run benchmarks'
      'bundle:Bundle module and dependencies into single file (deprecated)'
      'cache:Cache the dependencies'
      'check:Type-check the dependencies'
      'clean:Remove the cache directory'
      'compile:Compile the script into a self contained executable'
      'completions:Generate shell completions'
      'coverage:Print coverage reports'
      'doc:Show documentation for a module'
      'eval:Eval script'
      'fmt:Format source files'
      'info:Show info about cache or related source file'
      'init:Initialize a new project'
      'install:Install script as an executable'
      'add:Add dependencies to the configuration file'
      'remove:Remove dependencies from the configuration file'
      'jupyter:Deno kernel for Jupyter notebooks'
      'uninstall:Uninstall a script previously installed with deno install'
      'lsp:Start the language server'
      'lint:Lint source files'
      'publish:Publish the current working directory to JSR'
      'repl:Read Eval Print Loop'
      'run:Run a JavaScript or TypeScript program'
      'serve:Run a server'
      'task:Run a task defined in the configuration file'
      'test:Run tests'
      'types:Print runtime TypeScript declarations'
      'upgrade:Upgrade deno executable to given version'
      'vendor:Vendor remote modules into a local directory'
    )
    _describe -t commands 'deno command' commands && ret=0
    ;;
  args)
    local -a permission_flags=(
      '--allow-all[Allow all permissions]'
      '-A[Allow all permissions]'
      '--allow-env=[Allow environment access]:vars'
      '--deny-env=[Deny environment access]:vars'
      '--allow-ffi=[Allow loading dynamic libraries]:paths:_files'
      '--deny-ffi=[Deny loading dynamic libraries]:paths:_files'
      '--allow-hrtime[Allow high resolution time measurement]'
      '--deny-hrtime[Deny high resolution time measurement]'
      '--allow-net=[Allow network access]:hosts'
      '--deny-net=[Deny network access]:hosts'
      '--allow-read=[Allow file system read access]:paths:_files'
      '--deny-read=[Deny file system read access]:paths:_files'
      '--allow-run=[Allow running subprocesses]:programs'
      '--deny-run=[Deny running subprocesses]:programs'
      '--allow-sys=[Allow access to OS info]:apis'
      '--deny-sys=[Deny access to OS info]:apis'
      '--allow-write=[Allow file system write access]:paths:_files'
      '--deny-write=[Deny file system write access]:paths:_files'
      '--no-prompt[Always throw if not allowed]'
    )

    local -a common_flags=(
      '--config=[The configuration file]:file:_files'
      '-c+[The configuration file]:file:_files'
      '--no-config[Disable automatic loading of the config file]'
      '--import-map=[Load import map file]:file:_files'
      '--no-remote[Do not resolve remote modules]'
      '--no-npm[Do not resolve npm modules]'
      '--node-modules-dir=[Set node modules directory management mode]:mode:(auto manual none)'
      '--vendor=[Toggle vendoring]'
      '--lock=[Check the specified lock file]:file:_files'
      '--no-lock[Disable auto discovery of the lock file]'
      '--frozen=[Error out if lockfile is out of date]:bool:(true false)'
      '--cert=[Load certificate authority from PEM encoded file]:file:_files'
      '--cached-only[Require that remote dependencies are already cached]'
      '--reload=[Reload source code cache]:modules'
      '-r=[Reload source code cache]:modules'
      '--inspect=[Activate inspector]:host_port'
      '--inspect-brk=[Activate inspector and break at start]:host_port'
      '--inspect-wait=[Activate inspector and wait for debugger]:host_port'
      '--seed=[Seed Math.random()]:number'
      '--v8-flags=[Set V8 command line options]:flags'
      '--check=[Type check modules]:mode:(all local)'
      '--no-check[Skip type-checking modules]'
      '--watch=[Watch for file changes and restart]:paths:_files'
      '--no-clear-screen[Do not clear terminal screen on reload]'
      '--ext=[Set content type of supplied file]:ext:(ts tsx js jsx)'
      '--env-file=[Load env variables from specified file]:file:_files'
      '-h[Print help]'
      '--help[Print help]'
    )

    case ${words[1]} in
      run)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '--location=[Value of globalThis.location]:href' \
          '--strace-ops=[Trace low-level ops]::ops' \
          '1:script:_files' \
          '*:args' && ret=0
        ;;
      serve)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '--port=[Port to listen on]:port' \
          '--host=[Hostname to listen on]:host' \
          '--parallel[Run multiple server workers in parallel]' \
          '1:script:_files' \
          '*:args' && ret=0
        ;;
      test)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '--ignore=[Ignore files]:patterns' \
          '--no-run[Cache test modules without running tests]' \
          '--doc[Type-check code blocks in JSDoc and Markdown]' \
          '--fail-fast=[Stop after N failures]:count' \
          '--filter=[Run tests with this string or pattern in the test name]:filter' \
          '--shuffle=[Shuffle the order that the tests are run in]:seed' \
          '--coverage=[Collect coverage profile data into DIR]:dir:_directories' \
          '--clean[Empty the temporary coverage profile data before running tests]' \
          '--parallel[Run test modules in parallel]' \
          '--trace-leaks[Enable tracing of leaks]' \
          '--reporter=[Select reporter]:reporter:(pretty dot junit tap)' \
          '--junit-path=[Write JUnit XML report to this file]:file:_files' \
          '--hide-stacktraces[Hide stack traces for errors in failure test results]' \
          '*:files or directories:_files' && ret=0
        ;;
      bench)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '--ignore=[Ignore files]:patterns' \
          '--no-run[Cache bench modules without running benchmarks]' \
          '--filter=[Run benchmarks matching string or pattern]:filter' \
          '--json[Output benchmark result in JSON format]' \
          '*:files or directories:_files' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '--check[Check if the source files are formatted]' \
          '--ext=[Set content type of supplied file]:ext:(ts tsx js jsx md json jsonc)' \
          '--ignore=[Ignore files]:patterns' \
          '--options-indent-width=[Define indentation width]:width' \
          '--options-line-width=[Define maximum line width]:width' \
          '--options-prose-wrap=[Define how prose is wrapped]:wrap:(always never preserve)' \
          '--options-single-quote[Use single quotes]' \
          '--options-use-tabs[Use tabs for indentation]' \
          '--options-no-semicolons[Do not use semicolons except where necessary]' \
          '--config=[The configuration file]:file:_files' \
          '-c+[The configuration file]:file:_files' \
          '--no-config[Disable automatic loading of the config file]' \
          '--watch=[Watch for file changes and restart]:paths:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:files or directories:_files' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '--fix[Fix any lintable errors]' \
          '--rules[List available rules]' \
          '--rules-tags=[Use rules from specified tags]:tags' \
          '--rules-include=[Include specified rules]:rules' \
          '--rules-exclude=[Exclude specified rules]:rules' \
          '--ignore=[Ignore files]:patterns' \
          '--json[Output lint result in JSON format]' \
          '--compact[Output lint result in compact format]' \
          '--config=[The configuration file]:file:_files' \
          '-c+[The configuration file]:file:_files' \
          '--no-config[Disable automatic loading of the config file]' \
          '--watch=[Watch for file changes and restart]:paths:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:files or directories:_files' && ret=0
        ;;
      compile)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '-o+[Output file]:file:_files' \
          '--output=[Output file]:file:_files' \
          '--target=[Target OS architecture]:target:(x86_64-unknown-linux-gnu aarch64-unknown-linux-gnu x86_64-pc-windows-msvc x86_64-apple-darwin aarch64-apple-darwin)' \
          '--include=[Additional module to include]:path:_files' \
          '--no-terminal[Hide the terminal/console window on Windows]' \
          '--icon=[Set the application icon]:file:_files' \
          '1:script:_files' && ret=0
        ;;
      install)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '-n+[Executable file name]:name' \
          '--name=[Executable file name]:name' \
          '--root=[Installation root]:dir:_directories' \
          '-f[Forcefully overwrite existing installation]' \
          '--force[Forcefully overwrite existing installation]' \
          '-g[Install a package or script as a globally available executable]' \
          '--global[Install a package or script as a globally available executable]' \
          '-e+[Install from a code string]:code' \
          '--entrypoint=[Entrypoint to install]:entrypoint' \
          '1:module:_files' && ret=0
        ;;
      add)
        _arguments -s -S \
          '--dev[Add as a development dependency]' \
          '-D[Add as a development dependency]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      doc)
        _arguments -s -S \
          '--json[Output documentation in JSON format]' \
          '--html[Output documentation as static site in HTML]' \
          '--name=[Name used in the docs]:name' \
          '--category-docs=[Path to a JSON file]:file:_files' \
          '--symbol-redirect-map=[Path to a JSON file]:file:_files' \
          '--strip-trailing-html[Strip .html from the URLs]' \
          '--default-symbol-map=[Path to a JSON file]:file:_files' \
          '--output=[Output directory]:dir:_directories' \
          '--private[Show private items in output]' \
          '--filter=[Dot separated path to symbol]:filter' \
          '--lint[Lint documentation diagnostics]' \
          '-r=[Reload source code cache]:modules' \
          '--reload=[Reload source code cache]:modules' \
          '--lock=[Check the specified lock file]:file:_files' \
          '--no-lock[Disable auto discovery of the lock file]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:source files:_files' && ret=0
        ;;
      info)
        _arguments -s -S \
          '--json[Output in JSON format]' \
          '-r=[Reload source code cache]:modules' \
          '--reload=[Reload source code cache]:modules' \
          '--cert=[Load certificate authority from PEM encoded file]:file:_files' \
          '--location=[Show files used for origin bound APIs]:href' \
          '--no-config[Disable automatic loading of the config file]' \
          '--no-remote[Do not resolve remote modules]' \
          '--no-npm[Do not resolve npm modules]' \
          '--lock=[Check the specified lock file]:file:_files' \
          '--no-lock[Disable auto discovery of the lock file]' \
          '--config=[The configuration file]:file:_files' \
          '-c+[The configuration file]:file:_files' \
          '--import-map=[Load import map file]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:source file:_files' && ret=0
        ;;
      eval)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '--print[Print result to stdout]' \
          '-p[Print result to stdout]' \
          '1:code' && ret=0
        ;;
      cache)
        _arguments -s -S \
          $common_flags \
          '*:source files:_files' && ret=0
        ;;
      check)
        _arguments -s -S \
          '--all[Type-check all code including remote modules]' \
          '-r=[Reload source code cache]:modules' \
          '--reload=[Reload source code cache]:modules' \
          '--lock=[Check the specified lock file]:file:_files' \
          '--no-lock[Disable auto discovery of the lock file]' \
          '--config=[The configuration file]:file:_files' \
          '-c+[The configuration file]:file:_files' \
          '--no-config[Disable automatic loading of the config file]' \
          '--import-map=[Load import map file]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:source files:_files' && ret=0
        ;;
      coverage)
        _arguments -s -S \
          '--ignore=[Ignore files]:patterns' \
          '--include=[Include files matching regex]:regex' \
          '--exclude=[Exclude files matching regex]:regex' \
          '--lcov[Output coverage report in lcov format]' \
          '--output=[Output file for lcov]:file:_files' \
          '--html[Output coverage report as HTML]' \
          '--detailed[Output detailed coverage information for each file]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:coverage directory:_directories' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(zsh bash fish powershell elvish fig)' && ret=0
        ;;
      init)
        _arguments -s -S \
          '--lib[Generate project for a library]' \
          '--serve[Generate project for deno serve]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:directory:_directories' && ret=0
        ;;
      task)
        _arguments -s -S \
          '--config=[The configuration file]:file:_files' \
          '-c+[The configuration file]:file:_files' \
          '--cwd=[Specify the directory to run the task in]:dir:_directories' \
          '--filter=[Filter by workspace member]:filter' \
          '--eval[Evaluate provided task as a script]' \
          '--recursive[Run the task in all workspace members]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:task name' \
          '*:args' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '--version=[The version to upgrade to]:version' \
          '--output=[The path to output the updated version to]:file:_files' \
          '--dry-run[Perform all checks without replacing old version]' \
          '--force[Replace current exe even if not out-of-date]' \
          '--canary[Upgrade to canary channel]' \
          '--rc[Upgrade to release candidate]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '--token=[Authentication token]:token' \
          '--config=[The configuration file]:file:_files' \
          '-c+[The configuration file]:file:_files' \
          '--no-config[Disable automatic loading of the config file]' \
          '--dry-run[Perform all checks without actually publishing]' \
          '--allow-slow-types[Allow publishing with slow types]' \
          '--allow-dirty[Allow publishing if the repository has uncommitted changes]' \
          '--no-provenance[Disable provenance attestation]' \
          '--check[Type-check modules before publishing]' \
          '--no-check[Skip type-checking]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      vendor)
        _arguments -s -S \
          '-o+[Output directory]:dir:_directories' \
          '--output=[Output directory]:dir:_directories' \
          '-f[Forcefully overwrite existing files]' \
          '--force[Forcefully overwrite existing files]' \
          '-c+[The configuration file]:file:_files' \
          '--config=[The configuration file]:file:_files' \
          '--no-config[Disable automatic loading of the config file]' \
          '--import-map=[Load import map file]:file:_files' \
          '--lock=[Check the specified lock file]:file:_files' \
          '--no-lock[Disable auto discovery of the lock file]' \
          '-r=[Reload source code cache]:modules' \
          '--reload=[Reload source code cache]:modules' \
          '--cert=[Load certificate authority from PEM encoded file]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:source files:_files' && ret=0
        ;;
      jupyter)
        _arguments -s -S \
          '--install[Install Deno kernel for Jupyter]' \
          '--kernel[Run Deno kernel]' \
          '--conn=[Connection file]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      repl)
        _arguments -s -S \
          $permission_flags \
          $common_flags \
          '--eval-file=[Evaluate the given file(s)]:files:_files' \
          '--eval=[Evaluate provided code]:code' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
