#compdef puppet-catalog
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/catalog.md
# puppet catalog - compile, apply, download and inspect Puppet catalogs

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console dot)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '--terminus=[backend for retrieving or altering catalog data]:terminus:(compiler json rest yaml)' \
  '1:action:(apply compile download find info save select)' \
  '*::arg:' && ret=0

return ret
