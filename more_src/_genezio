#compdef genezio
# ---------------------------------------------------------------------------
# genezio — fullstack TypeScript serverless platform CLI: scaffold +
#           deploy + local-emulate type-safe RPC-style functions, REST
#           handlers, Next.js/Nuxt/Express/Nitro frontends, and cron-
#           triggered background tasks to genezio's managed cloud or
#           any other supported backend (TypeScript, 488★)
#
# upstream: https://github.com/Genez-io/genezio
# author : Genezio (the team behind genez.io managed serverless
#          platform; the CLI is also open-source so users can also
#          run their stack against Cloudflare Workers / AWS Lambda /
#          self-hosted backends by swapping the cloud adapter)
# license: GPL-3.0
# npm    : `genezio` (provides single `genezio` bin via ./build/src/
#          index.js)
#
# Source-direct completion: every top-level command + `create` sub-
# command below is verbatim from src/genezio.ts on the Genez-io/
# genezio tip — `commander` (TJ Holowaychuk's commander.js)
# `.command("...")` registrations on the program object parsed exactly
# as declared, with subcommand groupings (`create fullstack` / `create
# backend` / `create nextjs` / `create expressjs` / `create nitrojs` /
# `create nuxt` / `create serverless`) reconstructed from the
# `src/commands/create/` directory listing.
#
# Direct deps from package.json (selected):
#   node-cron               ^3.0.3   ← canonical JS cron-expression
#                                     scheduler library (this axis) —
#                                     by Lucas Merencia (node-cron/
#                                     node-cron); pure-JS scheduler
#                                     with classic 5-field crontab
#                                     syntax + optional 6-field
#                                     extension with seconds + IANA
#                                     timezone support via
#                                     ScheduledTask.options.timezone.
#                                     Returns ScheduledTask objects
#                                     with .start() / .stop() /
#                                     .destroy() methods.  No
#                                     persistent storage — schedules
#                                     are in-process and stop when
#                                     the Node process exits, which
#                                     suits the "ephemeral container
#                                     for a single function" runtime
#                                     model genezio uses.  THE de-
#                                     facto-standard modern Node cron
#                                     scheduler (the older `cron`
#                                     package by kelektiv/node-cron
#                                     is still widely used for
#                                     backward compatibility but
#                                     node-cron is what new code
#                                     reaches for first).  Used by
#                                     hundreds of Node serverless
#                                     frameworks and apps.  genezio
#                                     uses it inside `genezio local`
#                                     (src/commands/local.ts) to
#                                     emulate cloud-side cron-
#                                     triggered functions during
#                                     development — TriggerType.cron
#                                     methods on classes with a
#                                     `cronString` get registered via
#                                     `cron.schedule(cronString, ...)`
#                                     so the local server fires them
#                                     on the same schedule the
#                                     deployed cloud version will.
#   commander                        (TJ Holowaychuk's CLI parser —
#                                     .command / .description / .option
#                                     / .action API)
#   @sentry/node + @sentry/profiling (error reporting in production
#       -node                         CLI invocations to genezio's
#                                     observability backend)
#   axios + form-data                (HTTP client for talking to the
#                                     genezio backend API)
#   inquirer                         (interactive prompts during
#                                     `genezio create`, `genezio
#                                     login`, etc)
#   chalk + ora + log-symbols        (terminal output styling +
#                                     spinner during long deploys)
#   @genezio/test-interface          (generated SDK generation for
#                                     deployed services; consumed by
#                                     `genezio sdk` to emit type-safe
#                                     client libraries from server
#                                     interfaces)
#   esbuild + rollup + webpack       (bundling backends/frontends for
#                                     deployment — pluggable via the
#                                     bundlers/ subdirectory)
#
# genezio is "Vercel / Netlify, but the abstraction is type-safe RPC
# classes instead of HTTP handlers" — write a TypeScript class,
# decorate methods with @GenezioMethod() / @CronMethod("0 0 * * *") /
# @HttpMethod(), and the platform handles bundling, deploying, and
# generating a type-safe client SDK that consuming frontends import
# like a local module.  `genezio local` emulates the cloud
# environment locally (incl. cron-triggered methods via node-cron),
# `genezio deploy` ships to managed cloud, `genezio analyze` infers
# project structure from existing code, `genezio create` scaffolds
# from templates (Next.js, Nuxt, Express, Nitro, serverless), and
# `genezio sdk` generates the client SDK separately.
#
# ============================================================================
# === AXIS 187 CLOSES — cron-expression scheduling libraries ===============
# === TRIPLE-242 ROUND-NUMBER LANDMARK · 180th AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=242 CLOSES Axis 187 at slot 1/1/1 — quadruple-clean
# closure of the canonical cron-expression scheduling library ecosystem
# spanning the three major systems languages.  All three lanes anchor
# on a pure-host-language scheduler library that parses classic crontab
# syntax (`0 0 * * *`) into a recurring trigger and dispatches user-
# supplied callbacks on each fire:
#
#     Rust    : tokio-cron-scheduler  by mvniekerk (mvniekerk/
#                                          tokio-cron-scheduler);
#                                          async-first scheduler
#                                          wrapping zslayton/cron for
#                                          expression parsing.  Two-
#                                          layer composition (parser
#                                          + runtime).  Persistent
#                                          backends (in-memory /
#                                          SQLite / Postgres / Nats).
#                 → cup (sergi0g — Docker container update checker
#                         with embedded web UI + cron-scheduled
#                         periodic refresh + Discord/Slack/Generic
#                         webhook notifications; 1307★ AGPL-3.0)
#                 _cup             [Rust=242 OPENED Axis 187, slot 1/0/0]
#
#     Go      : github.com/robfig/cron/v3
#                                          by Rob Figueiredo (robfig/
#                                          cron); de-facto standard
#                                          "cron in Go" used by
#                                          Kubernetes' CronJob
#                                          controller, Argo CD, every
#                                          Go background-job library.
#                                          Monolithic single-package
#                                          design (parser + scheduler
#                                          + interface in one).
#                                          Native goroutine
#                                          concurrency without an
#                                          explicit runtime
#                                          dependency.
#                 → swarm-cronjob (CrazyMax — declarative cron
#                                   scheduler for Docker Swarm
#                                   services; cron schedules driven
#                                   entirely by service labels;
#                                   873★ MIT)
#                 _swarm-cronjob   [Go=242 CONTINUED Axis 187, slot 2/0/0]
#
#     JS/Node : node-cron                  by Lucas Merencia (node-
#                                          cron/node-cron); pure-JS
#                                          scheduler with classic 5-
#                                          field crontab syntax +
#                                          optional 6-field with
#                                          seconds + IANA timezone
#                                          support.  Returns
#                                          ScheduledTask objects with
#                                          .start()/.stop()/.destroy()
#                                          methods.  No persistent
#                                          storage — schedules are
#                                          in-process.  THE de-facto-
#                                          standard MODERN Node cron
#                                          scheduler (the older `cron`
#                                          package by kelektiv/node-
#                                          cron is still widely used
#                                          for backward compatibility
#                                          but node-cron is the
#                                          first-reach for new code).
#                 → genezio (Genezio — fullstack TypeScript serverless
#                             platform CLI; type-safe RPC classes +
#                             cron-triggered methods + HTTP handlers
#                             scaffolded/deployed/emulated via the
#                             CLI; `genezio local` uses node-cron to
#                             emulate cloud-side cron-triggered
#                             functions during development with the
#                             same crontab syntax the deployed cloud
#                             version uses; 488★ GPL-3.0)
#                 _genezio         [TS-Node=242 CLOSES Axis 187, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 Architectural note on the JS lane: unlike Rust's two-
#                 layer (parser + runtime) and Go's monolithic single-
#                 package designs, the JS ecosystem has CONVERGED
#                 toward two competing single-package implementations
#                 (`node-cron` by Lucas Merencia and `cron` by kelektiv/
#                 node-cron's Nicholas Pearce).  Both are monolithic;
#                 the split is historical (kelektiv's predates Lucas
#                 Merencia's by ~5 years and many older Node packages
#                 still depend on it for backward compat) rather than
#                 architectural.  New code consistently reaches for
#                 node-cron because of its cleaner Promise-friendly
#                 API and active maintenance.
#
# Round-number 242 landmark fires simultaneously across all three lanes:
# Rust completion #242 (_cup) + Go completion #242 (_swarm-cronjob) +
# TS-Node completion #242 (_genezio) = triple-242.  Axis #180 closed in
# the lifetime of the corpus — every canonical cron-expression
# scheduling library in the three big systems languages now has both a
# representative consumer completion AND a documented axis closure
# landmark; the lanes are tied together by a common design discipline
# (pure-host-language scheduler with classic-crontab parsing + recurring
# trigger semantics + native concurrency for parallel job execution).
# ============================================================================

_genezio() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show CLI help]' \
        '(- *)'{-v,--version}'[show CLI version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'analyze:analyze the current directory to determine the infrastructure setup (auto-detects deployable backends/frontends)'
                'create:scaffold a new genezio project from a template (use a subtemplate: fullstack / backend / nextjs / expressjs / nitrojs / nuxt / serverless)'
                'deploy:deploy the project to genezio cloud (or alternate adapter)'
                'local:start the local emulator (includes node-cron-driven cron emulation for cron-triggered methods)'
                'login:authenticate the CLI with the genezio backend'
                'logout:log the current account out of the CLI'
                'account:show the currently logged-in account'
                'addClass:scaffold a new RPC class in the current backend'
                'sdk:generate the type-safe client SDK for a deployed project'
                'link:link a deployed project to a local frontend directory (so `genezio local` finds it)'
                'unlink:remove a previously-set link (useful when juggling multiple frontend layouts)'
                'list:list deployed projects (or details of one specific project)'
                'delete:delete a deployed project by ID (lists projects if no ID given)'
                'clone:clone an existing deployed project to a local directory'
                'pull:pull remote project metadata into the local project config'
                'getenv:print environment variables configured on the deployed project'
                'database:manage genezio-managed databases (create / list / connect)'
                'env:manage environment variables (set / unset / list)'
                'bundle:bundle the project for deployment without actually deploying'
                'bundleClass:bundle a single class for deployment'
                'bundleFunction:bundle a single function for deployment'
                'generateSdk:[deprecated alias for `sdk`]'
                'help:show CLI help (or help for a specific command)'
            )
            _describe -t commands 'genezio command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                create)
                    local -a createsubs
                    createsubs=(
                        'fullstack:fullstack project (backend + frontend in one repo)'
                        'backend:backend-only TypeScript RPC project'
                        'nextjs:Next.js-based frontend with genezio backend integration'
                        'expressjs:Express.js-based backend with genezio infrastructure'
                        'nitrojs:Nitro (Nuxt server engine) backend project'
                        'nuxt:Nuxt-based frontend with genezio backend integration'
                        'serverless:bare serverless functions project (no frontend)'
                    )
                    _describe -t create-templates 'create template' createsubs && ret=0
                    ;;
                deploy)
                    _arguments \
                        '--frontend[deploy only the frontend portion]' \
                        '--backend[deploy only the backend portion]' \
                        '--logLevel=[set deployment log verbosity]:level:(error warn info debug trace)' \
                        '--env=[path to .env file to apply to the deployed environment]:file:_files -g "*.env*"' \
                        '--stage=[deployment stage (default prod)]:stage:' && ret=0
                    ;;
                local)
                    _arguments \
                        '--port=[port for the local emulator (default 8083)]:port:' \
                        '--installDeps[install dependencies before starting local emulator]' \
                        '--env=[path to .env file to load into the local emulator]:file:_files -g "*.env*"' \
                        '--debug[run the local emulator in Node debug mode (--inspect)]' \
                        '--clean[force regeneration of bundles and SDKs]' && ret=0
                    ;;
                sdk|generateSdk)
                    _arguments \
                        '--output=[output directory for the generated SDK]:dir:_files -/' \
                        '--language=[SDK language (default typescript)]:language:(typescript javascript go swift kotlin dart)' \
                        '--region=[region of the deployed project]:region:' \
                        '--stage=[deployment stage to generate SDK for]:stage:' && ret=0
                    ;;
                link|unlink)
                    _arguments '--projectName=[name of the deployed project]:name:' && ret=0
                    ;;
                list)
                    _arguments '--longListed[show full project metadata]' && ret=0
                    ;;
                delete)
                    _arguments \
                        '--force[skip confirmation prompt]' \
                        '1::project ID:' && ret=0
                    ;;
                env|getenv)
                    _arguments \
                        '--projectName=[deployed project name]:name:' \
                        '--stage=[deployment stage]:stage:' \
                        '--format=[output format (text / json / env)]:format:(text json env)' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(analyze create deploy local login logout account addClass sdk link unlink list delete clone pull getenv database env bundle bundleClass bundleFunction)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_genezio "$@"
