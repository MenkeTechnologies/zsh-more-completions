#compdef sort-bed
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/sorting/sort-bed.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/sort-bed/src/Sort.cpp
# Reference accessed: 2026-05-27
# Verified: upstream Sort.cpp argument parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--help[show help message and exit]' \
  '--version[show program version and citation info]' \
  '--check-sort[validate that input is properly sorted, exit non-zero otherwise]' \
  '--max-mem=[memory limit (e.g. 8G, 8000M, 8000000000)]:size:' \
  '--tmpdir=[temporary directory for intermediate sort files]:directory:_files -/' \
  '(-u --unique -d --duplicates)'{-u,--unique}'[output only unique BED elements]' \
  '(-u --unique -d --duplicates)'{-d,--duplicates}'[output only duplicate BED elements]' \
  '*:bed file:_files -g "*.(bed|bed.gz)(-.)"' && ret=0

return ret
