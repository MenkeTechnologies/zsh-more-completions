#compdef age age-keygen
# Documentation: https://man.archlinux.org/search?q=age
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (age)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-e --encrypt)'{-e,--encrypt}'[encrypt input]' \
      '(-d --decrypt)'{-d,--decrypt}'[decrypt input]' \
      '(-p --passphrase)'{-p,--passphrase}'[encrypt with passphrase]' \
      '(-a --armor)'{-a,--armor}'[ASCII armor]' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '*'{-r+,--recipient=}'[recipient]:r:' \
      '*'{-R+,--recipients-file=}'[recipients file]:file:_files' \
      '*'{-i+,--identity=}'[identity file]:file:_files' \
      '(-j --plugin-name)'{-j+,--plugin-name=}'[plugin name]:n:' \
      '*: :_files' && ret=0 ;;
  (age-keygen)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '(-y --convert)'{-y,--convert}'[convert priv to pub]' \
      '*: :_files' && ret=0 ;;
esac

return ret
