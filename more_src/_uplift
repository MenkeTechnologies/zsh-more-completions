#compdef uplift
# Documentation: https://upliftci.dev/reference/cli/root/
# Semantic versioning the easy way, powered by Conventional Commits for CI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config-dir=[custom path to uplift config directory]:dir:_files -/' \
  '--debug[display detailed operation information]' \
  '--dry-run[execute without making actual changes]' \
  '--ignore-detached[bypass git detached HEAD errors]' \
  '--ignore-existing-prerelease[exclude existing prerelease versions from calculations]' \
  '--ignore-shallow[bypass git shallow clone errors]' \
  '--no-push[prevent pushing changes to remote repository]' \
  '--no-stage[skip git staging of modifications]' \
  '--silent[suppress all logging output]' \
  '*:command:((
    bump\:"bump the semantic version within files"
    changelog\:"create or update a changelog with the latest semantic release"
    release\:"release the next semantic version of a repository"
    tag\:"tag a git repository with the next semantic version"
    completion\:"generate shell completion scripts"
    version\:"print build time version information"
    help\:"help about any command"
  ))' && ret=0

return ret
