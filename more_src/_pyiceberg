#compdef pyiceberg

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'list:list tables or namespaces'
  'describe:describe a namespace or table'
  'schema:get table schema'
  'files:list all files of the table'
  'location:return location of the table'
  'properties:manage table/namespace properties'
  'drop:drop a namespace or table'
  'rename:rename a table'
  'create:create a namespace'
  'spec:return partition spec of table'
  'uuid:return UUID of table'
  'list-refs:list all refs (branches/tags) in table'
  'version:show pyiceberg version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '*--catalog=[catalog name]:catalog:' \
  '--output=[output format]:format:(text json)' \
  '--uri=[catalog URI]:uri:' \
  '--credential=[authentication credential]:cred:' \
  '--verbose[enable verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pyiceberg subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (properties)
        _values 'properties action' \
          'get' 'set' 'remove' && ret=0
        ;;
      (drop)
        _values 'drop target' 'namespace' 'table' && ret=0
        ;;
      (create)
        _values 'create target' 'namespace' && ret=0
        ;;
    esac
    ;;
esac

return ret
