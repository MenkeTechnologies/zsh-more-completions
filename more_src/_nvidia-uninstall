#compdef nvidia-uninstall
# Documentation: https://man.archlinux.org/search?q=nvidia-uninstall
# Reference accessed: 2026-05-16

# nvidia-uninstall: uninstall NVIDIA proprietary driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-q[query running install]' \
  '--query[query running install]' \
  '-s[silent]' \
  '--silent[silent]' \
  '-n[no questions]' \
  '--no-questions[no questions]' \
  '--log-file=[log file]:file:_files' \
  '--installer-prefix=[install prefix]:dir:_files -/' \
  '*::nvidia-uninstall args:_files' && ret=0
return ret
