#compdef nvidia-uninstall
# Documentation: https://github.com/NVIDIA/nvidia-installer/blob/main/option_table.h
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvidia-uninstall: uninstall NVIDIA proprietary driver
# (subset of nvidia-installer options marked OPTION_APPLIES_TO_NVIDIA_UNINSTALL)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[print usage information and exit]' \
  '(- *)'{-v,--version}'[print version and exit]' \
  '(- *)'{-A,--advanced-options}'[print common and advanced options and exit]' \
  '(-q --no-questions)'{-q,--no-questions}'[assume default answer to all questions]' \
  '(-s --silent)'{-s,--silent}'[run silently; no output except errors]' \
  '(-e --expert)'{-e,--expert}'[enable expert installation mode]' \
  '(-c --no-ncurses-color)'{-c,--no-ncurses-color}'[disable color in ncurses interface]' \
  '--log-file-name=[log file]:file:_files' \
  '--installer-prefix=[install prefix]:dir:_files -/' \
  '--tmpdir=[directory for temporary files]:dir:_files -/' \
  '--ui=[user interface to use]:ui:(ncurses none)' \
  '--skip-module-unload[skip unloading the NVIDIA kernel module]' \
  '*::nvidia-uninstall args:_files' && ret=0
return ret
