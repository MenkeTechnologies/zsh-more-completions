#compdef blc broken-link-checker

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-e[exclude external links]' \
  '--exclude-external[exclude external links]' \
  '-f[filter by HTML tag]:tag' \
  '--filter-level=[filter level]:level:(0 1 2 3)' \
  '-g[get only]' \
  '--get[get only]' \
  '-i+[include keyword filter]:keyword' \
  '--include=[include keyword filter]:keyword' \
  '-o[ordered]' \
  '--ordered[ordered]' \
  '-r[recursive]' \
  '--recursive[recursive]' \
  '--exclude=[exclude pattern]:pattern' \
  '--host-requests=[max requests per host]:count' \
  '--requests=[max total requests]:count' \
  '--user-agent=[custom user agent]:user agent' \
  '1:URL:' && return 0
