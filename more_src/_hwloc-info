#compdef hwloc-info
# Documentation: hwloc-info --help (Portable Hardware Locality)
# Source: report information about hwloc topology and objects.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(--topology --support)--objects[report info about specific objects]' \
    '(--objects --support)--topology[report info about the topology]' \
    '(--objects --topology)--support[report info about supported features]' \
    {-v,--verbose}'[additional details]' \
    {-q,--quiet,-s}'[reduce detail]' \
    '--get-attr=[only show named attribute line]:name:' \
    '--ancestors[chain of ancestors up to root]' \
    '--ancestor=[only show ancestor of given type]:type:' \
    '--children[show all children]' \
    '--descendants=[only show descendants of given type]:type:' \
    '--local-memory[only local memory nodes]' \
    '--local-memory-flags=[flags for local memory selection]:x:' \
    '--best-memattr=[best target among local nodes]:attr:' \
    '--default-nodes[default local nodes only]' \
    '--first[only first matching object]' \
    '-n[prefix lines with object index]' \
    '--restrict=[restrict topology bitmap]:bitmap:' \
    '--restrict-flags=[restrict flags]:n:' \
    '--filter=[filter objects type:knd]:filter:' \
    '--no-icaches[do not show instruction caches]' \
    '--no-io[do not show I/O devices or bridges]' \
    '--no-bridges[do not show I/O bridges except hostbridges]' \
    '--whole-io[show all I/O devices and bridges]' \
    {-i+,--input=}'[input XML/synthetic topology]:topology:_files' \
    '--input-format=[input format]:fmt:(xml fsroot synthetic cpuid)' \
    '--pid=[query process pid topology]:pid:_pids' \
    '*:object or keyword:(root levels topology support)' \
    && ret=0

return ret
