#compdef fscrypt

# Zsh completion for fscrypt (Linux filesystem encryption tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:Configure fscrypt for the system or a filesystem'
  'encrypt:Encrypt a directory'
  'unlock:Unlock an encrypted directory'
  'lock:Lock an encrypted directory'
  'purge:Remove all protectors for a filesystem from the kernel'
  'status:Print fscrypt status of a file or directory'
  'metadata:Manipulate fscrypt metadata directly'
)

_arguments -s -S -C \
  '--verbose[Print additional debug info]' \
  '--quiet[Print only error messages]' \
  '--help[Print help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'fscrypt command' commands && ret=0
    ;;
  args)
    case $words[1] in
      setup)
        _arguments -s -S \
          '--all-users[Configure all users on the system]' \
          '--force[Force setup even if already configured]' \
          '--time=[Target time for passphrase hashing]:time' \
          ':filesystem mountpoint:_files -/' && ret=0
        ;;
      encrypt)
        _arguments -s -S \
          '--policy=[Use an existing policy]:policy' \
          '--protector=[Use an existing protector]:protector' \
          '--source=[Protector source type]:source:(pam_passphrase custom_passphrase raw_key)' \
          '--name=[Protector name]:name' \
          '--user=[User for the protector]:user:_users' \
          '--no-recovery[Do not create a recovery protector]' \
          '--skip-unlock[Skip unlocking after encryption]' \
          ':directory:_files -/' && ret=0
        ;;
      unlock)
        _arguments -s -S \
          '--user=[User for the protector]:user:_users' \
          ':directory:_files -/' && ret=0
        ;;
      lock)
        _arguments -s -S \
          '--all-users[Lock for all users]' \
          '--user=[User for the protector]:user:_users' \
          ':directory:_files -/' && ret=0
        ;;
      purge)
        _arguments -s -S \
          '--force[Do not ask for confirmation]' \
          '--user=[User whose keys to purge]:user:_users' \
          ':filesystem mountpoint:_files -/' && ret=0
        ;;
      status)
        _arguments -s -S \
          ':file or directory:_files' && ret=0
        ;;
      metadata)
        local -a subcmds=(
          'create:Create new metadata'
          'destroy:Destroy existing metadata'
          'dump:Dump metadata contents'
          'add-protector-to-policy:Add a protector to a policy'
          'remove-protector-from-policy:Remove a protector from a policy'
          'change-passphrase:Change protector passphrase'
        )
        _describe -t subcmds 'metadata subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
