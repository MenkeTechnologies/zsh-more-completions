#compdef which-cli
# _which-cli — Carlo Wood gnu which locate a command CLI alias (GNU team, C); custom argparse
# upstream: https://carlowood.github.io/which/

_which-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[show all matches]' \
        '--all[show all matches]' \
        '-i[parse interactive]' \
        '--read-alias[parse interactive]' \
        '-i+[interactive alias]:str:' \
        '--show-dot[expand . in path]' \
        '--show-tilde[show ~ for HOME]' \
        '--tty-only[stop processing options on right]' \
        '--skip-alias[skip alias]' \
        '--skip-functions[skip functions]' \
        '--skip-dot[skip directories starting with dot]' \
        '--skip-tilde[skip ~ directories]' \
        '*:commands:_command_names'
}

_which-cli "$@"
