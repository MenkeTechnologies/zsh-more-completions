#compdef nucBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/nuc.html
# profile nucleotide content of intervals (bedtools nuc)

local ret=1

_arguments -s -S \
  '-fi[input FASTA file]:file:_files' \
  '-bed[input BED/GFF/VCF file]:file:_files' \
  '-s[profile sequence according to strand]' \
  '-seq[print extracted sequence as an extra column]' \
  '-pattern[report the number of times a pattern appears]:pattern' \
  '-C[ignore case when matching -pattern]' \
  '-fullHeader[use full FASTA header]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
