#compdef age-keygen

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '-y[convert identity file to recipients]:identity file:_files' && ret=0

return ret
