#compdef moveoutletstostrm moveoutletstostreams MoveOutletsToStreams
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/MoveOutletsToStreams.html
# TauDEM: move outlet points onto the stream raster

local ret=1

_arguments -s -S \
  '-p[input D8 flow directions grid]:pfile:_files' \
  '-src[input stream raster grid]:srcfile:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-om[output moved-outlets file]:movedoutletsfile:_files' \
  '-omlyr[layer name in moved-outlets file]:om layer name:' \
  '-md[maximum grid cells to traverse (default 50)]:maxdist:' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
