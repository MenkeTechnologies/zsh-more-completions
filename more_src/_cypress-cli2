#compdef cypress-cli2 cypress2
# _cypress-cli2 — Cypress.io cypress-cli2 CLI command-line frontend wrapping the Cypress fast easy and reliable testing for anything that runs in a browser open-source written in JavaScript Node TypeScript Cypress is a next generation front end testing tool built for the modern web run open install verify info cache cache-clear cache-prune cache-list cache-path component-testing e2e Studio dashboard Cloud open-ct run-ct headless headed browser project record key parallel group ci-build-id config-file env e2e-spec env-vars (Cypress.io team Brian Mann, JavaScript/TypeScript); commander
# upstream: https://www.cypress.io/

_cypress-cli2() {
    local -a sub=(
        'cache:cache operations'
        'completion:generate shell completion'
        'help:show help'
        'info:show env info'
        'install:install Cypress binary'
        'open:open Cypress GUI'
        'open-ct:open component testing GUI'
        'run:run tests headlessly'
        'run-ct:run component tests'
        'verify:verify Cypress installation'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[no color]' \
        '--browser=+[name]:n:(chrome chromium edge electron firefox)' \
        '-b+[browser]:n:(chrome chromium edge electron firefox)' \
        '--ci-build-id=+[id]:str:' \
        '--component[component testing]' \
        '--config=+[json]:str:' \
        '-c+[config]:str:' \
        '--config-file=+[file]:file:_files -g "cypress.config.* *.ts *.js *.json"' \
        '-C+[config file]:file:_files -g "cypress.config.* *.ts *.js *.json"' \
        '--cwd=+[dir]:dir:_files -/' \
        '--e2e[e2e mode]' \
        '--env=+[k=v]:str:' \
        '*--env=+[k=v]:str:' \
        '-e+[env]:str:' \
        '--global[global mode]' \
        '--group=+[name]:str:' \
        '--headed[headed mode]' \
        '--headless[headless mode]' \
        '--inspect[inspect]' \
        '--inspect-brk[inspect break]' \
        '--key=+[key]:str:' \
        '--no-exit[no exit]' \
        '--no-runner-ui[no runner UI]' \
        '--parallel[parallel]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--project=+[dir]:dir:_files -/' \
        '-P+[project]:dir:_files -/' \
        '--record[record to Cypress Cloud]' \
        '-r[record]' \
        '--reporter=+[r]:n:(spec mochawesome teamcity junit nyc)' \
        '-R+[reporter]:n:(spec mochawesome teamcity junit nyc)' \
        '--reporter-options=+[opts]:str:' \
        '-o+[reporter opts]:str:' \
        '--runner-ui[runner UI]' \
        '--spec=+[file]:file:_files' \
        '*--spec=+[file]:file:_files' \
        '-s+[spec]:file:_files' \
        '--tag=+[name]:str:' \
        '-t+[tag]:str:' \
        '--auto-cancel-after-failures=+[N]:n:' \
        '--force[force]' \
        '-f[force]' \
        '--testing-type=+[t]:t:(e2e component)' \
        '--detached[run detached]' \
        '*:args:'
}

_cypress-cli2 "$@"
