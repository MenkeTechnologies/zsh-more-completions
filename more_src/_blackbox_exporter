#compdef blackbox_exporter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config.file=[configuration file]:config file:_files' \
  '--config.check[check configuration and exit]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.route-prefix=[prefix for web routes]:prefix:' \
  '--web.external-url=[external URL]:url:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--history.limit=[max historical results]:count:' \
  '--timeout-offset=[offset to subtract from timeout]:seconds:' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
