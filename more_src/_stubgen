#compdef stubgen
# mypy stub file generator

local ret=1

_arguments -s -S \
  '-m[generate stubs for module]:module name:' \
  '-p[generate stubs for package]:package name:' \
  '-o[output directory]:directory:_files -/' \
  '--ignore-errors[ignore errors during generation]' \
  '--no-import[do not import modules]' \
  '--parse-only[only parse source files]' \
  '--include-private[include private symbols]' \
  '--export-less[generate fewer exports]' \
  '--doc-dir=[directory with .rst docs]:directory:_files -/' \
  '--search-path=[module search path]:path:_files -/' \
  '--python-executable=[Python executable]:executable:_files' \
  '--verbose[verbose output]' \
  '-q[quiet mode]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:source files:_files -g "*.py"' && ret=0

return ret
