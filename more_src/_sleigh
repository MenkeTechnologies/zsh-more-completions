#compdef sleigh
# _sleigh — Ghidra Sleigh language compiler (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra
# Flags from SleighCompileOptions.java.

_sleigh() {
    _arguments \
        '-x[turn on parser debugging]' \
        '-y[write .sla using XML debug format]' \
        '-u[print warnings for unnecessary pcode instructions]' \
        '-l[report pattern conflicts]' \
        '-n[print warnings for all NOP constructors]' \
        '-t[print warnings for dead temporaries]' \
        '-e[enforce use of local keyword for temporaries]' \
        '-c[print warnings for colliding-operand constructors]' \
        '-f[print warnings for unused token fields]' \
        '-s[treat register names as case sensitive]' \
        '*-D+[define preprocessor macro NAME=VALUE]:macro:' \
        '*-d+[define preprocessor module macro MODULE]:module:' \
        '-i+[inject options from file]:file:_files' \
        '-a+[compile all .slaspec files in directory]:dir:_files -/' \
        '1:input .slaspec or -a directory:_files -g "*.slaspec"' \
        '2:output .sla file:_files -g "*.sla"'
}

_sleigh "$@"
