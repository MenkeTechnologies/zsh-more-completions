#compdef cq-cli
# Documentation: https://github.com/CadQuery/cq-cli
# CadQuery command-line interface: convert CadQuery scripts to CAD/mesh formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--codec=[conversion codec e.g. step stl svg dxf glb gltf threejs]:codec:(step stl svg dxf glb gltf threejs)' \
  '--infile=[input CadQuery script (.py) or FreeCAD (.fcstd); stdin if omitted]:infile:_files' \
  '--outfile=[output file; stdout if omitted; semicolon-separated for multiple]:outfile:_files' \
  '--errfile=[error output file; stderr if omitted]:errfile:_files' \
  '--params=[script parameters as JSON file, JSON string, or colon/semicolon delimited]:params:' \
  '--outputopts=[codec-specific options as colon/semicolon delimited string]:opts:' \
  '--getparams=[extract parameter metadata as JSON; file path or true for stdout]:getparams:' \
  '--validate=[verify script validity without generating output]:validate:(true false)' \
  '--expression=[Python expression to evaluate and render]:expression:' \
  '*:script:_files' && ret=0

return ret
