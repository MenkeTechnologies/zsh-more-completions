#compdef seq24
# Documentation: https://man.archlinux.org/search?q=seq24
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --manual-alsa-ports)'{-m,--manual-alsa-ports}'[manual alsa ports]' \
  '(-s --showmidi)'{-s,--showmidi}'[show midi events]' \
  '(-p --priority)'{-p,--priority}'[realtime priority]' \
  '(-P --pass-sysex)'{-P,--pass-sysex}'[pass sysex]' \
  '(-k --show-keys)'{-k,--show-keys}'[show keyboard]' \
  '(-S --stats)'{-S,--stats}'[print stats]' \
  '(-J --jack-transport)'{-J,--jack-transport}'[JACK transport]' \
  '(-M --jack-master)'{-M,--jack-master}'[JACK master]' \
  '(-C --jack-master-cond)'{-C,--jack-master-cond}'[conditional jack master]' \
  '(-Z --jack-start-mode)'{-Z,--jack-start-mode}'+[jack start mode]:mode:(live song)' \
  '(-i --interaction-method)'{-i,--interaction-method}'+[mouse method]:m:(seq24 fruity)' \
  '(-x --options)'{-x,--options}'+[user options]:opts:' \
  '*:midi file:_files -g "*.midi" -g "*.mid"' && ret=0

return ret
