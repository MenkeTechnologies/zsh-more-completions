#compdef containerlab clab
# Documentation: https://containerlab.dev/cmd/deploy/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for containerlab - container-based networking lab tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:deploy a lab'
  'destroy:destroy a lab'
  'redeploy:destroy and redeploy lab'
  'start:start stopped lab nodes'
  'stop:stop running lab nodes'
  'inspect:inspect a lab'
  'save:save running lab configuration'
  'generate:generate various artifacts'
  'graph:generate lab topology graph'
  'tools:various tools'
  'events:stream container events'
  'version:show version'
  'completion:generate shell completion'
  'config:configure lab elements'
  'exec:execute a command on lab nodes'
)

_arguments -s -S \
  '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
  '--name=[lab name]:name:' \
  '--runtime=[container runtime]:runtime:(docker podman)' \
  '--timeout=[operation timeout]:duration:' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'containerlab command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      deploy)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '(-n --name)'{-n+,--name=}'[override lab name]:name:' \
          '(-c --reconfigure)'{-c,--reconfigure}'[destroy and redeploy lab]' \
          '--max-workers=[max workers for parallel node deployment]:workers:' \
          '(-r --runtime)'{-r+,--runtime=}'[container runtime]:runtime:(docker podman)' \
          '--timeout=[API request timeout]:duration:' \
          '--vars=[template variables file]:file:_files -g "*.{json,yaml,yml}"' \
          '--export-template=[template for topology export]:template file:_files' \
          '--export-rendered=[write rendered topology to file]:file:_files' \
          '--log-level=[log level]:level:(trace debug info warn error)' \
          '--node-filter=[deploy only filtered nodes]:filter:' \
          '--skip-post-deploy[skip post-deploy phase]' \
          '--skip-labdir-acl[skip lab directory ACL setup]' \
          '--owner=[lab owner (multi-user)]:owner:'
        ;;
      destroy)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--cleanup[remove lab directory]' \
          '--graceful[attempt graceful shutdown]' \
          '--all[destroy all labs]' \
          '--node-filter=[destroy only filtered nodes]:filter:'
        ;;
      inspect)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--all[inspect all labs]' \
          '--format=[output format]:format:(table json)' \
          '--details[show detailed info]'
        ;;
      graph)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--srv=[HTTP server address]:address:' \
          '--dot[generate dot file instead of HTML]'
        ;;
    esac
    ;;
esac

return ret
