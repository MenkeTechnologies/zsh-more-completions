#compdef containerlab clab

# Zsh completion for containerlab - container-based networking lab tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:deploy a lab'
  'destroy:destroy a lab'
  'inspect:inspect a lab'
  'save:save running lab configuration'
  'generate:generate various artifacts'
  'graph:generate lab topology graph'
  'tools:various tools'
  'version:show version'
  'completion:generate shell completion'
  'config:configure lab elements'
  'exec:execute a command on lab nodes'
)

_arguments -s -S \
  '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
  '--name=[lab name]:name:' \
  '--runtime=[container runtime]:runtime:(docker podman)' \
  '--timeout=[operation timeout]:duration:' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'containerlab command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      deploy)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--reconfigure[destroy and redeploy lab]' \
          '--max-workers=[max workers for parallel node deployment]:workers:' \
          '--export-template=[template for topology export]:template file:_files' \
          '--node-filter=[deploy only filtered nodes]:filter:'
        ;;
      destroy)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--cleanup[remove lab directory]' \
          '--graceful[attempt graceful shutdown]' \
          '--all[destroy all labs]' \
          '--node-filter=[destroy only filtered nodes]:filter:'
        ;;
      inspect)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--all[inspect all labs]' \
          '--format=[output format]:format:(table json)' \
          '--details[show detailed info]'
        ;;
      graph)
        _arguments \
          '(-t --topo)'{-t+,--topo=}'[topology file]:topology file:_files -g "*.{yaml,yml}"' \
          '--srv=[HTTP server address]:address:' \
          '--dot[generate dot file instead of HTML]'
        ;;
    esac
    ;;
esac

return ret
