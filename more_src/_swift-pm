#compdef swift-package swift-package-collection
# _swift-pm — Swift Package Manager (Apple Swift project, Swift); manage SwiftPM packages and dependencies
# upstream: https://github.com/apple/swift-package-manager

_swift-pm() {
    local -a sub=(
        'add-dependency:add a package dependency'
        'add-product:add a product'
        'add-target:add a target'
        'add-target-dependency:add a target dependency'
        'archive-source:archive source'
        'clean:clean build dir'
        'compute-checksum:compute checksum'
        'completion-tool:print shell completion'
        'config:configure swift package'
        'describe:describe package'
        'diagnose-api-breaking-changes:diagnose API breaking changes'
        'dump-package:dump package as JSON'
        'dump-pif:dump pif'
        'dump-symbol-graph:dump symbol graph'
        'edit:put dependency in edit mode'
        'experimental-install:experimental install'
        'experimental-prebuilts:prebuilts'
        'fetch:fetch sources'
        'generate-documentation:DocC docs'
        'generate-xcodeproj:generate Xcode project (deprecated)'
        'help:show help'
        'init:initialize package'
        'install-completion-script:install completion'
        'learn:open learn link'
        'plugin:plugin commands'
        'purge-cache:purge cache'
        'reset:reset state'
        'resolve:resolve deps'
        'show-dependencies:show deps'
        'show-executables:show executables'
        'tools-version:print tools version'
        'unedit:end edit mode'
        'update:update deps'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-c+[build configuration]:cfg:(debug release)' \
        '--configuration+[build configuration]:cfg:(debug release)' \
        '--package-path+[package path]:dir:_files -/' \
        '--cache-path+[cache path]:dir:_files -/' \
        '--config-path+[config path]:dir:_files -/' \
        '--security-path+[security path]:dir:_files -/' \
        '--scratch-path+[scratch path]:dir:_files -/' \
        '-Xcc+[clang flag]:flag:' \
        '-Xswiftc+[swiftc flag]:flag:' \
        '-Xlinker+[linker flag]:flag:' \
        '-Xcxx+[clang++ flag]:flag:' \
        '-Xmanifest+[manifest flag]:flag:' \
        '--triple+[triple]:str:' \
        '--sdk+[SDK]:path:_files' \
        '--toolchain+[toolchain]:path:_files' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--disable-sandbox[disable sandbox]' \
        '--disable-prefetching[disable prefetching]' \
        '--enable-prefetching[enable prefetching]' \
        '--offline[offline]' \
        '--jobs+[jobs]:n:' \
        '-j+[jobs]:n:' \
        '--use-integrated-swift-driver[integrated driver]' \
        '--disable-sandbox[disable sandbox]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swift-package subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--type+[type]:type:(empty library executable system-module manifest macro tool-build-plugin command-plugin extension)' \
                    '--name+[name]:str:' ;;
                completion-tool) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_swift-pm "$@"
