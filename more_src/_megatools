#compdef megatools
# megatools — command-line client for the MEGA.nz cloud storage

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'dl:download files and folders from MEGA.nz'
  'get:download files from your MEGA account'
  'ls:list files in your MEGA account'
  'put:upload files to MEGA'
  'copy:sync local and remote directories'
  'df:show MEGA storage usage'
  'mkdir:create directories in MEGA'
  'rm:remove files or directories from MEGA'
  'reg:register a new MEGA account'
  'login:log in to your MEGA account'
  'export:export files from your MEGA account'
)

_arguments -s -S \
  '1:subcommand:->subcommand' \
  '*::subcommand arguments:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'megatools subcommand' subcommands && ret=0
    ;;
  (args)
    local subcmd=$line[1]
    case $subcmd in
      (dl)      _dispatch megadl megadl ;;
      (get)     _dispatch megaget megaget ;;
      (ls)      _dispatch megals megals ;;
      (put)     _dispatch megaput megaput ;;
      (copy)    _dispatch megacopy megacopy ;;
      (df)      _dispatch megadf megadf ;;
      (mkdir)   _dispatch megamkdir megamkdir ;;
      (rm)      _dispatch megarm megarm ;;
      (reg)     _dispatch megareg megareg ;;
      (login)   _dispatch megalogin megalogin ;;
      (export)  _dispatch megaexport megaexport ;;
    esac
    ;;
esac

return ret
