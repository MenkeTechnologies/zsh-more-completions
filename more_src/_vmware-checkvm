#compdef vmware-checkvm
# _vmware-checkvm — VMware open-vm-tools vmware-checkvm (probe whether the running OS is inside a VMware hypervisor and print the hypervisor identifier; takes no arguments — exits 0 if VMware is detected, 1 otherwise, and prints a single descriptive line to stdout)
# upstream: https://github.com/vmware/open-vm-tools
# Behaviour from vmware/open-vm-tools open-vm-tools/checkvm/checkvm.c on tip.

_vmware-checkvm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]'
}

_vmware-checkvm "$@"
