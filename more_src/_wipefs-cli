#compdef wipefs-cli
# _wipefs-cli — util-linux wipefs wipe filesystem/RAID/partition signatures CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_wipefs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[wipe all signatures]' \
        '--all[wipe all signatures]' \
        '-b[backup signature]' \
        '--backup[backup signature]' \
        '-f[force]' \
        '--force[force]' \
        '-i[do not erase nested partitions]' \
        '--no-act[do not erase, only display]' \
        '-n[do not erase, only display]' \
        '--lock=+[mode]:m:(yes no nonblock)' \
        '-O+[output cols]:str:' \
        '--output=+[output cols]:str:' \
        '-J[json output]' \
        '--json[json output]' \
        '--noheadings[no headings]' \
        '-p[parsable output]' \
        '--parsable[parsable output]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t+[fstype]:str:' \
        '--types=+[fstype]:str:' \
        '-o+[offset]:n:' \
        '--offset=+[offset]:n:' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper,loop}*"'
}

_wipefs-cli "$@"
