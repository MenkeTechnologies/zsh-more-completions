#compdef jupyter-nbconvert nbconvert

# Zsh completion for jupyter nbconvert

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--to=[output format]:format:(html latex pdf slides markdown rst script notebook asciidoc)' \
  '--template=[template name or path]:template' \
  '--output=[output filename]:filename:_files' \
  '--output-dir=[output directory]:directory:_directories' \
  '--execute[execute the notebook prior to export]' \
  '--no-input[exclude input cells from output]' \
  '--no-prompt[exclude input and output prompts]' \
  '--allow-errors[continue on errors during execution]' \
  '--stdin[read notebook from stdin]' \
  '--stdout[write output to stdout]' \
  '--inplace[overwrite the input notebook]' \
  '--clear-output[clear output of notebooks]' \
  '--ExecutePreprocessor.timeout=[execution timeout in seconds]:timeout' \
  '--ExecutePreprocessor.kernel_name=[kernel to use]:kernel' \
  '--TagRemovePreprocessor.enabled=[enable tag-based cell removal]:bool:(True False)' \
  '--TagRemovePreprocessor.remove_cell_tags=[tags marking cells for removal]:tags' \
  '--TemplateExporter.exclude_input=[exclude input cells]:bool:(True False)' \
  '--TemplateExporter.exclude_output=[exclude output cells]:bool:(True False)' \
  '--HTMLExporter.theme=[HTML theme]:theme:(dark light)' \
  '--embed-images[embed images as base64 in HTML]' \
  '--log-level=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--config=[config file]:config file:_files -g "*.py"' \
  '--reveal-prefix=[URL prefix for reveal.js]:url' \
  '--SlidesExporter.reveal_theme=[reveal.js theme]:theme' \
  '*:notebook:_files -g "*.ipynb"' && ret=0

return ret
