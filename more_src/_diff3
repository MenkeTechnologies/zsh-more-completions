#compdef diff3

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-A,--show-all}'[output all changes, bracketing conflicts]' \
  {-e,--ed}'[output ed script incorporating changes]' \
  {-E,--show-overlap}'[like -e, but bracket conflicts]' \
  {-3,--easy-only}'[like -e, only nonoverlapping changes]' \
  {-x,--overlap-only}'[like -e, only overlapping changes]' \
  '-X[like -x, but bracket conflicts]' \
  "-i[append 'w' and 'q' commands to ed scripts]" \
  {-m,--merge}'[output actual merged file]' \
  {-a,--text}'[treat all files as text]' \
  '--strip-trailing-cr[strip trailing carriage return on input]' \
  {-T,--initial-tab}'[make tabs line up by prepending a tab]' \
  '--diff-program=[program to compare files]:program:_command_names -e' \
  '*'{-L+,--label=}'[label instead of file name]:label:' \
  '1:my file:_files' \
  '2:old file:_files' \
  '3:your file:_files' && ret=0

return ret
