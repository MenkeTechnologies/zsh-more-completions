#compdef makeflat
# Documentation: http://www.starlink.ac.uk/docs/sun139.htx/sun139.html
# CCDPACK: Produce a flatfield calibration image

local ret=1

_arguments -s -S \
  'IN=[input flatfield frames]:in:_files' \
  'OUT=[output master flatfield image]:out:_files' \
  'METHOD=[image combination method]:method:' \
  'ALPHA=[trimming fraction for TRIMMED method]:alpha:' \
  'BOXSIZE=[smoothing box size]:boxsize:' \
  'CLEAN=[clean defective pixels]:clean:(TRUE FALSE)' \
  'GAMMA=[outlier rejection threshold for cleaning]:gamma:' \
  'GENVAR=[generate variances]:genvar:(TRUE FALSE)' \
  'ITER=[number of cleaning iterations]:iter:' \
  'KEEPIN=[retain input NDFs]:keepin:(TRUE FALSE)' \
  'LOGFILE=[log file name]:logfile:_files' \
  'LOGTO=[where to write log information]:logto:(TERMINAL LOGFILE BOTH NEITHER)' \
  'MAX=[upper limit for THRESHOLD/MINMAX]:max:' \
  'MIN=[lower limit for THRESHOLD/MINMAX]:min:' \
  'MINPIX=[minimum contributing pixels]:minpix:' \
  'NITER=[number of clipping iterations]:niter:' \
  'NORM=[normalise output flatfield]:norm:(TRUE FALSE)' \
  'SIGMAS=[sigma clipping level]:sigmas:' \
  'TITLE=[output NDF title]:title:' \
  'USESET=[use Set header grouping]:useset:(TRUE FALSE)' \
  'USEVAR=[use input variances]:usevar:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
