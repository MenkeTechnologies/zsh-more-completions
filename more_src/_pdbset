#compdef pdbset
# Documentation: https://www.ccp4.ac.uk/html/pdbset.html
# CCP4: various useful manipulations on coordinate files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate file]:output:_files' \
  '*:keyword:(CELL SPACEGROUP ORTHOGONALIZATION SYMGEN REORTHOGONALIZE ROTATE SHIFT TRANSFORM CHAIN RENUMBER BFACTOR OCCUPANCY ELEMENT REPLACE SELECT PICK EXCLUDE SEQUENCE OUTPUT XPLOR UTOB ATRENUMBER REMARK COM NOISE END)' && ret=0

return ret
