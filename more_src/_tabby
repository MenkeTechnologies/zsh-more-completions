#compdef tabby
# Documentation: https://github.com/TabbyML/tabby
# Reference accessed: 2026-05-21
# Verified: upstream crates/tabby/src/main.rs Commands enum.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--otlp-endpoint=[OpenTelemetry endpoint]:url:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'serve:start the api endpoint for IDE/Editor extensions'
      'download:download the language model for serving'
    )
    _describe -t commands 'tabby command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model=[completion model ID to serve]:model:' \
          '--chat-model=[chat model ID to serve]:model:' \
          '--device=[device to use]:device:(cpu cuda rocm metal vulkan)' \
          '--port=[port to listen on]:port:' && ret=0
        ;;
      download)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model=[model ID to download]:model:' && ret=0
        ;;
    esac
    ;;
esac

return ret
