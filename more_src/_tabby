#compdef tabby

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'serve:start the Tabby server'
      'download:download model'
      'worker:start a worker'
    )
    _describe -t commands 'tabby command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model[model ID to serve]:model:' \
          '--chat-model[chat model ID to serve]:model:' \
          '--device[device to use]:device:(cpu cuda rocm metal)' \
          '--port[port to listen on]:port:' \
          '--host[host to bind to]:host:' \
          '--parallelism[number of parallel requests]:num:' \
          '--no-webserver[disable the web server UI]' && ret=0
        ;;
      download)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model[model ID to download]:model:' && ret=0
        ;;
      worker)
        local -a worker_commands
        worker_commands=(
          'completion:start a completion worker'
          'chat:start a chat worker'
        )
        _describe -t commands 'worker command' worker_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
