#compdef envelope

# mattrighetti/envelope src/command/client.rs (clap); Homebrew: Formula/e/envelope.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'envelope command' compadd -- \
    add check delete drop duplicate diff edit history init import list lock revert run unlock
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
