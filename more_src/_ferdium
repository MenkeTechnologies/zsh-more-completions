#compdef ferdium
# _ferdium — Ferdium (Electron-based all-in-one messaging client; fork of Ferdi/Franz with multi-service tabs; flags inherit Electron's --user-data-dir, --proxy-server, --enable-features, plus app-specific --testing-services and --dev for devtools)
# upstream: https://github.com/ferdium/ferdium-app
# Flags from ferdium-app src/electron/main.ts on tip.

_ferdium() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--dev[open devtools]' \
        '--testing[testing mode]' \
        '--testing-services[bundle test services]' \
        '--user-data-dir=*[user data dir]:dir:_files -/' \
        '--no-sandbox[disable sandbox]' \
        '--disable-gpu[disable GPU]' \
        '--proxy-server=*[proxy server]:proxy:' \
        '--enable-features=*[Chromium features]:features:' \
        '--ozone-platform=*[ozone backend]:platform:(x11 wayland)' \
        '*::url:'
}

_ferdium "$@"
