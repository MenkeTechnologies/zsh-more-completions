#compdef mapmask
# mapmask — manipulate CCP4 maps and masks: extent, mask, combine (CCP4)

local ret=1

_arguments -s -S \
  'MAPIN[first input map]:file:_files -g "*.(map|ccp4)"' \
  'MSKIN[first input mask]:file:_files -g "*.(msk|mask)"' \
  'MAPIN2[second input map]:file:_files -g "*.(map|ccp4)"' \
  'MSKIN2[second input mask]:file:_files -g "*.(msk|mask)"' \
  'XYZIN[input coordinates]:file:_files -g "*.(pdb|ent)"' \
  'MAPLIM[reference map for extent matching]:file:_files -g "*.(map|ccp4)"' \
  'MAPOUT[output map]:file:_files -g "*.(map|ccp4)"' \
  'MSKOUT[output mask]:file:_files -g "*.(msk|mask)"' \
  'XYZLIM[output map extent]:opt:(ASU CELL MATCH)' \
  'BORDER[extend map around model]:n:' \
  'EXTEND[extension method]:m:(COPY XTAL OVERLAP)' \
  'PAD[density for unmapped regions]:val:' \
  'SYMMETRY[override spacegroup]:sg:' \
  'AXIS[output axis order]:axes:' \
  'MASK[mask threshold]:opt:(CUT FRAC VOLUME)' \
  'MODE[logical file assignments]:opt:' \
  'PRINT[output sections]:opt:(MAP MASK)' \
  'SCALE[scale map values]:opt:(FACTOR SIGMA MEAN RATIO)' \
  'SOLV[solvent flattening/flipping]:opt:(FLIP ATTN)' \
  'MAPS[combine maps]:opt:(ADD MULT)' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
