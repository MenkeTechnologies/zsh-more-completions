#compdef MetFragCommandLine
# Documentation: https://ipb-halle.github.io/MetFrag/projects/metfragcl/
# MetFrag command line: in silico fragmentation for metabolite identification

local ret=1

_arguments -s \
  '*:parameter file or KEY=VALUE:_alternative
    "files:parameter file:_files"
    "params:parameter:(
      PeakListPath
      MetFragDatabaseType
      LocalDatabasePath
      ChemSpiderToken
      NeutralPrecursorMass
      DatabaseSearchRelativeMassDeviation
      NeutralPrecursorMolecularFormula
      PrecursorCompoundIDs
      IonizedPrecursorMass
      FragmentPeakMatchAbsoluteMassDeviation
      FragmentPeakMatchRelativeMassDeviation
      PrecursorIonMode
      IsPositiveIonMode
      MetFragScoreTypes
      MetFragScoreWeights
      OfflineSpectralDatabaseFile
      MaximumTreeDepth
      MetFragPreProcessingCandidateFilter
      MetFragPostProcessingCandidateFilter
      NumberThreads
      UseSmiles
      MetFragCandidateWriter
      SampleName
      ResultsPath
    )"' && ret=0

return ret
