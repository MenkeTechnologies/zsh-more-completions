#compdef dhcping

# dhcping: send DHCP request to detect server reachability
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-s[DHCP server]:host:_hosts' \
  '-c[client IP]:ip:' \
  '-t[timeout]:seconds:' \
  '-r[DHCPRELEASE]' \
  '-i[client id]:cid:' \
  '-h[chaddr]:mac:' \
  '-g[giaddr]:ip:' \
  '*::dhcping args:_files' && ret=0
return ret
