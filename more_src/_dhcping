#compdef dhcping
# Documentation: https://manpages.debian.org/bookworm/dhcping/dhcping.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcping: send DHCP request to detect server reachability.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose, print some information]' \
  '-V[very verbose, print a lot of information]' \
  '-i[use DHCPINFORM packets]' \
  '-r[use DHCPREQUEST packets (default)]' \
  '-q[quiet, print nothing]' \
  '-t+[maximum time to wait (seconds, default 3)]:seconds' \
  '-c+[request this client IP address]:ip' \
  '-s+[send DHCP packet to this server IP]:server:_hosts' \
  '-h+[client hardware address (colon-hex)]:mac' \
  '-g+[gateway IP address]:ip' && ret=0
return ret
