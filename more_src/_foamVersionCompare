#compdef foamVersionCompare
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/tools/foamVersionCompare — compare two dotted version strings, exit code matches the relation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-h -help)'{-h,-help}'[print usage]' \
    '1: :->verA' \
    '2: :->op' \
    '3: :->verB' \
    && ret=0

case $state in
    op)
        local -a ops=(
            'eq:equal to'
            'lt:less than'
            'gt:greater than'
            'le:less than or equal to'
            'ge:greater than or equal to'
        )
        _describe -t ops 'operator' ops && ret=0
        ;;
    verA|verB)
        _message 'version string (e.g. 11 or 11.0.1)'
        ;;
esac

return ret
