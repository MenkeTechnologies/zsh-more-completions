#compdef crew

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a package from source'
  'const:display build environment constants'
  'deps:display package dependencies'
  'download:download a package without installing'
  'files:list files installed by a package'
  'help:display help information'
  'install:install a package'
  'list:list available or installed packages'
  'postinstall:run post-install steps for a package'
  'reinstall:reinstall a package'
  'remove:remove an installed package'
  'search:search for a package'
  'update:update package lists'
  'upgrade:upgrade installed packages'
  'whatprovides:find which package provides a file'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'crew command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|build|download|reinstall|deps|files|postinstall)
        _arguments '*:package name:' && ret=0
        ;;
      (remove)
        _arguments '*:installed package:' && ret=0
        ;;
      (search)
        _arguments '1:search term:' && ret=0
        ;;
      (list)
        _arguments \
          '--available[list available packages]' \
          '--installed[list installed packages]' \
          && ret=0
        ;;
      (whatprovides)
        _arguments '1:filename:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
