#compdef amneziawg-go
# Documentation: https://github.com/amnezia-vpn/amneziawg-go
# Documentation: https://github.com/amnezia-vpn/amneziawg-go/blob/master/main.go
# Reference accessed: 2026-05-27
# Verified: upstream amnezia-vpn/amneziawg-go main.go argv switch (case "-f", "--foreground" and "--version").

# amneziawg-go is a userspace AmneziaWG daemon. main.go only inspects:
#   amneziawg-go --version
#   amneziawg-go [-f|--foreground] INTERFACE-NAME
# Behavior is otherwise controlled via environment variables (not CLI flags):
#   WG_TUN_FD, WG_UAPI_FD, WG_PROCESS_FOREGROUND, LOG_LEVEL.

_arguments -s -S \
  '(-f --foreground)'{-f,--foreground}'[run daemon in foreground instead of daemonizing]' \
  '--version[print version information and exit]' \
  '1:interface-name:'
