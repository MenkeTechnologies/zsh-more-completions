#compdef openbox-xdg-autostart
# Documentation: https://github.com/danakj/openbox/blob/master/data/autostart/openbox-xdg-autostart
# Reference accessed: 2026-05-16
# Verified: upstream openbox-xdg-autostart Python script.
# Removed from prior file: fabricated single-dash -h/-V flags and bogus
# man.archlinux.org search URL.

# openbox-xdg-autostart: run XDG autostart entries for Openbox
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show usage info]' \
  '--version[show version and copyright]' \
  '--list[list autostart entries (\\[*\\] indicates runnable)]' \
  '*:environment:(GNOME KDE ROX XFCE Old)' && ret=0
return ret
