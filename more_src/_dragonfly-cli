#compdef dragonfly-cli dragonfly

# Dragonfly: modern in-memory data store CLI/server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--port=[bind port]:port:' \
  '--bind=[bind address]:host:_hosts' \
  '--maxmemory=[max memory bytes]:bytes:' \
  '--proactor_threads=[proactor threads]:n:' \
  '--dbnum=[number of databases]:n:' \
  '--keys_output_limit=[max keys returned by KEYS]:n:' \
  '--dir=[data directory]:dir:_files -/' \
  '--dbfilename=[snapshot filename]:name:' \
  '--logtostderr[log to stderr]' \
  '--alsologtostderr[also log to stderr]' \
  '--logbuflevel=[log buffer level]:n:' \
  '--logbufsecs=[log buffer secs]:n:' \
  '--max_log_size=[max log size MB]:mb:' \
  '--minloglevel=[min log level]:level:(0 1 2 3)' \
  '--cluster_mode=[cluster mode]:mode:(emulated default)' \
  '--enable_multi_shard_sync[enable multi-shard sync]' \
  '--epoll=[use epoll]:bool:(true false)' \
  '--io_uring=[use io_uring]:bool:(true false)' \
  '*::dragonfly args:_files' && ret=0
return ret
