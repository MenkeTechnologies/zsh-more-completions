#compdef gl gitless

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'track:start tracking changes to files'
  'untrack:stop tracking changes to files'
  'status:show status of the repo'
  'diff:show changes in files'
  'commit:record changes in the local repo'
  'branch:list, create, delete, or switch branches'
  'checkout:checkout committed versions of files'
  'merge:merge divergent branches'
  'resolve:mark files with conflicts as resolved'
  'fuse:fuse changes from a branch'
  'remote:list, create, delete, or edit remotes'
  'publish:publish commits upstream'
  'switch:switch branches'
  'tag:list, create, or delete tags'
  'history:show commit history'
  'init:initialize an empty repository'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gl command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (track)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      (untrack)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      (status)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-e[show only files with extensions]:extension:' && ret=0
        ;;
      (diff)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      (commit)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-m[commit message]:message:' \
          '-p[partial commit of files]' \
          '--include[include only these files]:file:_files' \
          '--exclude[exclude these files]:file:_files' && ret=0
        ;;
      (branch)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-c[create a new branch]:branch name:' \
          '-d[delete a branch]:branch name:' \
          '-dp[delete a branch from a remote]:branch name:' \
          '-su[set upstream]:upstream:' \
          '-uu[unset upstream]' \
          '1:branch name:' && ret=0
        ;;
      (checkout)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-cp[commit point]:commit:' \
          '*:file:_files' && ret=0
        ;;
      (merge)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--abort[abort the merge]' \
          '1:branch:' && ret=0
        ;;
      (fuse)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-e[exclude commits]:commits:' \
          '-o[only include commits]:commits:' \
          '--abort[abort the fuse]' \
          '1:branch:' && ret=0
        ;;
      (remote)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-c[create a new remote]:name url:' \
          '-d[delete a remote]:name:' \
          '1:remote name:' && ret=0
        ;;
      (publish)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (history)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-v[verbose output]' \
          '*:file:_files' && ret=0
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
