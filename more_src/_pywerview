#compdef pywerview
# _pywerview — pywerview CLI Python port of PowerView the PowerShell Active Directory enumeration toolkit performing get-netdomain get-netuser get-netcomputer get-netshare get-netsite get-netou get-netgroup get-netloggedon get-netsession get-localgroup get-domaintrust-mapping queries via LDAP SAMR for authorized AD pentest enumeration (Yannick Méheut team, Python); argparse
# upstream: https://github.com/the-useless-one/pywerview

_pywerview() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '--hashes=+[lmhash:nthash]:str:' \
        '-k[use kerberos]' \
        '--kerberos[use kerberos]' \
        '--aes-key=+[key]:str:' \
        '--dc-ip=+[ip]:_hosts' \
        '--ssl[use SSL]' \
        '-t+[target]:_hosts' \
        '--target=+[ip]:_hosts' \
        '--use-ldaps[force LDAPS]' \
        '--debug[debug]' \
        '*:subcommand:(get-adobject get-aduser get-adcomputer get-adgroup get-adgroupmember get-netdomain get-netdomaincontroller get-netuser get-netcomputer get-netgroup get-netgroupmember get-netou get-netsite get-netshare get-netloggedon get-netsession get-localgroup get-localgroupmember get-domainsid get-domaintrust get-domaintrust-mapping get-objectacl find-userfield find-computerfield invoke-userhunter get-domainpolicy get-domainforest get-netforest get-netforestcatalog get-netforesttrust)'
}

_pywerview "$@"
