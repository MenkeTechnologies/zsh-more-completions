#compdef octanol
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/octanol.html
# octanol - Draw a White-Wimley protein hydropathy plot

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input protein sequence]:file:_files' \
  '-graph[output graph type]:device:' \
  '-datafile[White-Wimley free energy data file]:file:_files' \
  '-width[window size for analysis]:width:' \
  '-plotoctanol[display the octanol plot]' \
  '-plotinterface[display the interface plot]' \
  '-plotdifference[display the difference plot]' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for all available options]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
