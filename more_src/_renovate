#compdef renovate

# Zsh completion for Renovate - dependency update tool

_arguments -s -S \
  '--autodiscover[autodiscover all repositories]' \
  '--autodiscover-filter=[filter autodiscovered repos]:pattern:' \
  '--base-dir=[base directory for Renovate operations]:directory:_files -/' \
  '--binary-source=[source for third-party binaries]:source:(global docker install)' \
  '--config-file=[config file]:file:_files -g "*.{json,json5,js}"' \
  '--detect-host-rules-from-env[detect host rules from env vars]' \
  '--dry-run=[dry run mode]:mode:(full lookup extract)' \
  '--force-cli[use CLI config even if config file exists]' \
  '--git-author=[git commit author]:author:' \
  '--git-private-key=[git private key]:key:' \
  '--log-file=[log file]:file:_files' \
  '--log-file-level=[log file level]:level:(debug info warn error fatal)' \
  '--log-level=[log level]:level:(debug info warn error fatal)' \
  '--onboarding=[create onboarding PR]:mode:(true false)' \
  '--platform=[platform type]:platform:(azure bitbucket bitbucket-server codecommit gitea github gitlab local)' \
  '--print-config[print resolved config and exit]' \
  '--redis-url=[Redis URL for caching]:url:' \
  '--require-config=[require config]:mode:(required optional ignored)' \
  '--schedule=[cron schedule]:schedule:' \
  '--token=[platform token]:token:' \
  '--endpoint=[platform API endpoint]:url:' \
  '--use-base-branch-config=[use base branch config]:mode:(merge none)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:repositories:'
