#compdef usage

# Zsh completion for usage - CLI usage specification tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:Generate completions or documentation from a usage spec'
      'complete:Run completions for a usage spec'
      'exec:Execute a command using a usage spec'
      'bash:Generate bash completions'
      'fish:Generate fish completions'
      'zsh:Generate zsh completions'
      'schema:Print the JSON schema for usage specs'
      'version:Print version information'
      'help:Print help for a command'
    )
    _describe -t commands 'usage command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      generate)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[specify usage spec file]:file:_files' \
          '(-o --out)'{-o,--out}'[specify output file]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      complete)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[specify usage spec file]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:words' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:command' && ret=0
        ;;
      help)
        local -a commands=(
          'generate:Generate completions or documentation'
          'complete:Run completions'
          'exec:Execute a command'
          'bash:Generate bash completions'
          'fish:Generate fish completions'
          'zsh:Generate zsh completions'
          'schema:Print JSON schema'
          'version:Print version'
        )
        _describe -t commands 'usage command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
