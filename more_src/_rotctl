#compdef rotctl
# Documentation: https://hamlib.sourceforge.net/manuals/4.5/rotctl.html
# Reference accessed: 2026-05-21
# Verified: upstream Hamlib rotctl(1) manpage at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[set rotator model number]:model number' \
  '(-r --rot-file)'{-r,--rot-file}'[set device of the rotator]:device:_files' \
  '(-R --rot-file2)'{-R,--rot-file2}'[set device of the 2nd rotator]:device:_files' \
  '(-s --serial-speed)'{-s,--serial-speed}'[set serial port speed]:baud rate:(300 1200 2400 4800 9600 19200 38400 57600 115200)' \
  '(-t --send-cmd-term)'{-t,--send-cmd-term}'[set send command terminator]:terminator' \
  '(-o --set-azoffset)'{-o,--set-azoffset}'[azimuth correction (added to set values)]:offset' \
  '(-O --set-eloffset)'{-O,--set-eloffset}'[elevation correction (added to set values)]:offset' \
  '(-C --set-conf)'{-C,--set-conf}'[set configuration parameter]:key=value' \
  '(-l --list)'{-l,--list}'[list all rotator model numbers]' \
  '(-u --dump-caps)'{-u,--dump-caps}'[dump rotator capabilities]' \
  '(-L --show-conf)'{-L,--show-conf}'[show configuration parameters]' \
  '(-i --read-history)'{-i,--read-history}'[load command history from file]' \
  '(-I --save-history)'{-I,--save-history}'[save command history to file]' \
  '(-v --verbose)'{-v,--verbose}'[set verbose mode (cumulative)]' \
  '(-Z --debug-time-stamps)'{-Z,--debug-time-stamps}'[enable timestamps for debug messages]'
