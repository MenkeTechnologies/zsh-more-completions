#compdef x11vnc-cli
# _x11vnc-cli — Karl Runge x11vnc VNC server for real X11 displays CLI alias (LibVNC team, C); custom argparse
# upstream: https://github.com/LibVNC/x11vnc

_x11vnc-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-display=+[X display]:str:' \
        '-auth=+[xauthority file]:file:_files' \
        '-N[multi-display]' \
        '-id=+[window id]:str:' \
        '-sid=+[shared id]:str:' \
        '-clip=+[clip geometry]:str:' \
        '-flashcmap[flash colormap]' \
        '-shiftcmap=+[n]:n:' \
        '-notruecolor[no true color]' \
        '-visual=+[visual]:str:' \
        '-overlay[use overlay]' \
        '-overlay_nocursor[overlay no cursor]' \
        '-scale=+[fraction]:str:' \
        '-scale_cursor=+[fraction]:str:' \
        '-viewonly[view only]' \
        '-shared[allow shared]' \
        '-once[exit after disconnect]' \
        '-many[many connections]' \
        '-forever[never exit]' \
        '-loop[loop forever]' \
        '-timeout=+[seconds]:n:' \
        '-inetd[start by inetd]' \
        '-http[http server]' \
        '-https[https server]' \
        '-httpdir=+[http dir]:dir:_files -/' \
        '-httpport=+[port]:port:' \
        '-rfbport=+[port]:port:' \
        '-port=+[port]:port:' \
        '-noxdamage[no xdamage]' \
        '-xdamage[xdamage]' \
        '-noxfixes[no xfixes]' \
        '-xfixes[xfixes]' \
        '-noxrandr[no xrandr]' \
        '-xrandr[xrandr]' \
        '-noxrecord[no xrecord]' \
        '-xrecord[xrecord]' \
        '-rotate=+[mode]:m:(x y xy yx +90 -90 +180)' \
        '-padgeom=+[WxH]:str:' \
        '-quiet[quiet]' \
        '-q[quiet]' \
        '-bg[background]' \
        '-output=+[log file]:file:_files' \
        '-o+[log file]:file:_files' \
        '-logfile=+[log file]:file:_files' \
        '-rfbauth=+[passwd file]:file:_files' \
        '-passwdfile=+[passwd file]:file:_files' \
        '-storepasswd=+[pass file]:str:' \
        '-passwd=+[plain text password]:str:' \
        '-viewpasswd=+[view password]:str:' \
        '-deny=+[deny hosts]:str:' \
        '-allow=+[allow hosts]:str:' \
        '-localhost[only localhost]' \
        '-input=+[input perms]:str:' \
        '-grabkbd[grab kbd]' \
        '-grabptr[grab pointer]' \
        '-grabalways[grab always]' \
        '-ungrabboth[ungrab both]' \
        '-noxkb[no xkb]' \
        '-xkb[use xkb]' \
        '-skip_keycodes=+[codes]:str:' \
        '-add_keysyms[add keysyms]' \
        '-clear_mods[clear mods]' \
        '-clear_keys[clear keys]' \
        '-cursor=+[mode]:str:' \
        '-nocursor[no cursor]' \
        '-cursorpos[cursor pos updates]' \
        '-nocursorpos[no cursor pos updates]' \
        '-arrow=+[number]:n:' \
        '-noxinerama[no xinerama]' \
        '-xinerama[xinerama]' \
        '-norepeat[no repeat]' \
        '-ssl=+[cert path]:file:_files' \
        '-stunnel[use stunnel]' \
        '-no6[no IPv6]' \
        '-listen=+[interface]:str:' \
        '-noipv4[no IPv4]' \
        '-noipv6[no IPv6]' \
        '-tightfilexfer[tight file transfer]' \
        '-ultrafilexfer[ultra file transfer]' \
        '-rfbversion=+[version]:str:' \
        '-permitfiletransfer[permit file transfer]' \
        '-norc[no rc file]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '*:arg:'
}

_x11vnc-cli "$@"
