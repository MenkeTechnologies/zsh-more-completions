#compdef ttfcomponentizer
# Documentation: https://adobe-type-tools.github.io/afdko/AFDKO-Overview.html
# AFDKO: componentize a TTF using a companion UFO's component data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '-o[path to output the componentized TTF]:output path:_files' \
  '*:font:_files -g "*.ttf"' && ret=0

return ret
