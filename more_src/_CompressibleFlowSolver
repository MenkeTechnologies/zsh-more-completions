#compdef CompressibleFlowSolver
# Documentation: https://doc.nektar.info/userguide/latest/user-guidech17.html
# Nektar++ CompressibleFlowSolver solver: shared command-line options

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[display extra information]' \
  '--version[display software version and source control info]' \
  '(-f --force-output)'{-f,--force-output}'[force field/checkpoint files, disable backup]' \
  '*'{-I,--solverinfo}'=[override or define solverinfo key=value]:keyvalue' \
  '*'{-P,--parameter}'=[override or define parameter key=value]:keyvalue' \
  '(-i --io-format)'{-i,--io-format}'=[set field file output format]:format:(Xml Hdf5)' \
  '--no-exp-opt[disable expansion list ordering optimization]' \
  '--npx=[number of processes in x-direction (Fourier)]:int' \
  '--npy=[number of processes in y-direction (Fourier)]:int' \
  '--npz=[number of processes in z-direction (Fourier)]:int' \
  '--npt=[number of chunks for parallel-in-time integration]:int' \
  '--part-info[print detailed partitioning information]' \
  '--part-only=[partition mesh into N partitions and exit]:int' \
  '--write-opt-file[force generation of new optimisation file]' \
  '--use-opt-file=[use specified collection optimisation file]:file:_files' \
  '--use-hdf5-node-comm[enable parallel HDF5 mesh partitioning]' \
  '--use-metis[force METIS for mesh partitioning]' \
  '--use-scotch[force Scotch for mesh partitioning]' \
  '--set-start-chknumber=[set starting checkpoint file number]:int' \
  '--set-start-time=[set simulation start time]:float' \
  '*:session file:_files -g "*.xml"' && ret=0

return ret
