#compdef direnv

# Zsh completion for direnv - environment switcher for the shell

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'allow:Grants direnv permission to load the .envrc'
  'deny:Revokes direnv permission to load the .envrc'
  'edit:Opens PATH_TO_RC or the current .envrc in your editor'
  'exec:Execute CMD with DIRENV_DIR set to PATH'
  'export:Print the bash export/unset commands for the environment'
  'fetchurl:Fetch a given URL into a fixed path'
  'hook:Output shell code needed to hook direnv into the shell'
  'prune:Remove old allowed/denied .envrc files'
  'reload:Trigger a reload'
  'revoke:Revoke the authorization of a .envrc file'
  'show_dump:Show the dump of environment variables'
  'status:Print some debug status information'
  'stdlib:Display the stdlib available in the .envrc execution context'
  'version:Print the version number'
  'help:Show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      allow|deny|edit|revoke)
        _arguments ':envrc file:_files -g ".envrc"' && ret=0
        ;;
      hook)
        _arguments ':shell:(bash fish tcsh zsh elvish)' && ret=0
        ;;
      exec)
        _arguments \
          ':dir:_files -/' \
          ':command:_command_names' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
