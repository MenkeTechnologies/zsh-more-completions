#compdef intrctl
# Documentation: man intrctl(8)
# Source: netbsd/src usr.sbin/intrctl — interrupt control and inspection (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:command:(affinity intr list nointr)' \
    '-c+[CPU index (affinity/intr/nointr) or compact list]:cpu_index:_default' \
    '-i+[interrupt ID to modify]:intrid:_default' \
    '-w+[continuous display delay in seconds]:wait:_default' \
    '-z[skip rows with all-zero interrupt counts]' \
    && ret=0

return ret
