#compdef sbom2dot
# Documentation: https://pypi.org/project/sbom2dot/
# create a GraphViz DOT dependency graph from an SBOM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input-file)'{-i,--input-file}'=[SBOM file to process]:file:_files' \
  '--debug[include debug information]' \
  '(-o --output-file)'{-o,--output-file}'=[output filename]:file:_files' \
  '(-V --version)'{-V,--version}'[display version]' && ret=0

return ret
