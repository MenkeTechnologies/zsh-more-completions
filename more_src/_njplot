#compdef njplot newicktops
# Documentation: http://doua.prabi.fr/software/njplot
# njplot: phylogenetic tree drawing program (PHYLIP/Newick format)

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-us[PostScript tree prepared for US Letter paper size]' \
  '-psonly[no window interface, just write the PostScript tree file]' \
  '-size[font size used for taxon names]:size:' \
  '-pc[number of pages for PostScript output]:n:' \
  '-psize[size of PostScript page as WIDTHxHEIGHT]:dimensions:' \
  '-lengths[show branch lengths if present in the tree file]' \
  '-boot[show bootstrap values if present in the tree file]' \
  '-notitle[do not include title in PostScript output]' \
  '*:tree file:_files' && ret=0

return ret
