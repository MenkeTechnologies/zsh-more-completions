#compdef permify
# Documentation: https://man.archlinux.org/search?q=permify
# Reference accessed: 2026-05-16

# Permify — open-source authorization service; CLI (`permify --help`) covers serve/migrate/version/etc.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'serve:run API server'
  'migrate:database migrations'
  'version:print build info'
  'validate:validate schema bundle'
  'coverage:test coverage helpers'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'permify' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
