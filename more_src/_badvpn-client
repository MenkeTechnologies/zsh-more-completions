#compdef badvpn-client
# Documentation: https://github.com/ambrop72/badvpn/blob/master/client/client.c
# badvpn peer-to-peer VPN client

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--logger[logging destination]:dest:(stdout syslog)' \
  '--syslog-facility[set syslog facility]:facility:' \
  '--syslog-ident[set syslog identity]:ident:' \
  '--loglevel[logging verbosity level]:level:(0 1 2 3 4 5 none error warning notice info debug)' \
  '--channel-loglevel[per-channel loglevel]:channel:' \
  '--threads[number of threads]:number:' \
  '--use-threads-for-ssl-handshake[offload SSL handshake to threads]' \
  '--use-threads-for-ssl-data[offload SSL data to threads]' \
  '--ssl[enable SSL]' \
  '--nssdb[NSS database string]:nssdb:' \
  '--client-cert-name[client certificate name]:name:' \
  '--server-name[server name]:name:' \
  '--server-addr[server address]:addr:' \
  '--tapdev[TAP device name]:device:' \
  '--scope[scope name]:scope:' \
  '--bind-addr[bind address]:addr:' \
  '--num-ports[number of ports]:number:' \
  '--ext-addr[external address and scope]:addr:' \
  '--transport-mode[transport mode]:mode:(udp tcp)' \
  '--encryption-mode[encryption mode]:mode:(blowfish aes none)' \
  '--hash-mode[hash mode]:mode:(md5 sha1 none)' \
  '--otp[one-time-password mode]:otp:' \
  '--fragmentation-latency[fragmentation latency ms]:ms:' \
  '--peer-ssl[use SSL with peers]' \
  '--peer-tcp-socket-sndbuf[peer TCP send buffer bytes]:bytes:' \
  '--send-buffer-size[send buffer in packets]:packets:' \
  '--send-buffer-relay-size[relay send buffer in packets]:packets:' \
  '--max-macs[max MAC addresses]:number:' \
  '--max-groups[max multicast groups]:number:' \
  '--igmp-group-membership-interval[IGMP group membership interval ms]:ms:' \
  '--igmp-last-member-query-time[IGMP last member query time ms]:ms:' \
  '--max-peers[max number of peers]:number:' \
  '--allow-peer-talk-without-ssl[allow peer comms without SSL]' && ret=0

return ret
