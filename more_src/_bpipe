#compdef bpipe
# ============================================================================
#  _bpipe — Bpipe: bioinformatics pipeline tool (Simon Sadedin, MCRI Australia)
#
#  Source-direct extraction from
#    https://github.com/ssadedin/bpipe/blob/master/src/main/groovy/bpipe/Runner.groovy
#    https://github.com/ssadedin/bpipe/blob/master/src/main/groovy/bpipe/cmd/BpipeCommand.groovy
#    https://docs.groovy-lang.org/latest/html/gapi/groovy/cli/commons/CliBuilder.html
#    (Groovy CliBuilder DSL)
#
#  Maintained by Simon Sadedin (ssadedin/bpipe), Murdoch Children's
#  Research Institute (MCRI), Melbourne, Australia.  242 GH stars.
#  Bpipe is a domain-specific language and toolkit for running and
#  managing bioinformatics pipelines (DNA/RNA sequencing, alignment,
#  variant calling, transcriptomics).  Pipelines are written in a
#  Groovy-based DSL with `produce`/`transform`/`exec` operations.
#  Bpipe schedules pipeline stages across compute clusters (SGE,
#  Torque, SLURM, LSF) and handles dependency tracking, restart-on-
#  failure, parallel execution, and reproducible runs.  Sister tools:
#  nextflow (also Groovy-based pipeline tool, IN CORPUS via
#  _nextflow), snakemake (Python-based, IN CORPUS), Nextflow's nf-core
#  community pipelines (IN CORPUS via _nf-core), WDL/Cromwell (Broad
#  Institute, in corpus), Galaxy Project (in corpus).
#
#  CLI library taxonomy update: 1st Groovy entry — Apache Groovy's
#  built-in **CliBuilder** DSL (groovy.cli.commons.CliBuilder).
#  Groovy is a FIRST-TIME addition to the cross-language CLI library
#  taxonomy.
#
#  CliBuilder is Apache Groovy's idiomatic Groovy DSL for CLI parsing
#  — wraps Apache Commons CLI (R371) under the hood but provides a
#  much more Groovy-idiomatic interface via `with` blocks + method-
#  call-as-option syntax + property-style result access.  Distinct
#  language and CLI pattern despite the Commons CLI backend.  Used by
#  Bpipe, Crafter CMS startup scripts, the doop pointer-analysis
#  framework, CCU-Historian (Homematic CCU data recorder), Bluesoft
#  Bee (database tool), Membrane SOA Model creator, Rundeck build
#  tooling, Debezium build scripts, Membrane Service Proxy, and most
#  Groovy CLI tools that prefer Groovy idioms over Java commons-cli
#  verbosity.
#
#  CliBuilder Groovy API:
#    import groovy.cli.commons.CliBuilder
#    import groovy.cli.commons.OptionAccessor
#
#    CliBuilder cli = new CliBuilder(usage: 'mytool [options] file...',
#                                    posix: true,
#                                    width: 100)
#    cli.with {
#      h longOpt: 'help', 'show help'
#      d longOpt: 'dir', 'output directory', args: 1
#      v longOpt: 'verbose', 'verbose output'
#      n longOpt: 'count', 'count', args: 1, argName: 'N'
#      p longOpt: 'param', 'pipeline parameter', args: 1,
#        argName: 'name=value', valueSeparator: ',' as char
#      'R' longOpt: 'report', 'generate report with template',
#                   args: 1
#      nochecks longOpt: 'no-checks', 'skip checks'
#    }
#
#    OptionAccessor opt = cli.parse(args)
#    if (!opt || opt.h) {
#      cli.usage()
#      System.exit(0)
#    }
#    def dir = opt.dir ?: '.'
#    def count = opt.count ? opt.count as int : 1
#    def remaining = opt.arguments()  // positional args
#
#  Groovy CliBuilder distinctive features:
#    - GROOVY DSL via `with` BLOCK — `cli.with { ... }` opens a builder
#      block where each method call inside defines one option
#    - METHOD-CALL-AS-OPTION syntax — short letter `h` becomes the
#      method name; `h longOpt: 'help', 'description'` defines the
#      `-h, --help` option via Groovy's named-argument method-call
#      syntax: `h(longOpt: 'help', args: 1, 'description')`
#    - SHORT NAMES as Groovy IDENTIFIERS — lowercase short opts are
#      bare identifiers (`h`, `d`, `v`); UPPERCASE short opts must be
#      QUOTED STRINGS (`'R'`, `'L'`) because of Groovy's variable
#      naming rules
#    - LONG-ONLY OPTIONS — when no short letter exists, use the LONG
#      name itself as the method name: `nochecks longOpt: 'no-checks',
#      'description'`
#    - `args: 1` parameter — option takes ONE value argument
#    - `args: N` parameter — option takes N values
#    - `argName: 'foo'` parameter — value placeholder in help output
#    - `valueSeparator: ',' as char` — multi-value separator (must be
#      cast to char in Groovy)
#    - `required: true` parameter — required option
#    - `defaultValue: 'X'` parameter — default value
#    - `type: Integer.class` parameter — type coercion class
#    - `convert: { ... }` parameter — Groovy closure for value conversion
#    - `CliBuilder(usage: '...', posix: true, width: 100)` constructor
#      with named-arg pairs for usage line + POSIX-mode toggle + help
#      width
#    - `cli.parse(args)` returns `OptionAccessor` or `null` on parse
#      error (PRINTS error message to stderr automatically)
#    - PROPERTY-STYLE RESULT ACCESS — `opt.h`, `opt.dir`, `opt.verbose`
#      — Groovy property access maps to commons-cli's `hasOption`/
#      `getOptionValue`
#    - `opt.dirs` (PLURAL) — list-style access for multi-value options
#    - `opt.arguments()` — list of remaining positional args
#    - `cli.usage()` — prints help text to stderr
#    - `cli.width = 100` — set formatter width
#    - `@DelegatesTo(CliBuilder)` annotation — for type-safe closure
#      delegate in Groovy scripts
#    - INTERNALLY WRAPS Apache Commons CLI (R371) — but caller sees only
#      Groovy idioms; commons-cli types `Option`, `Options`, `CommandLine`
#      are HIDDEN behind `OptionAccessor`
#    - LIVES IN `groovy.cli.commons` PACKAGE (since Groovy 2.5) —
#      previously at `groovy.util.CliBuilder` (legacy package, removed
#      in Groovy 3.0)
#    - ALTERNATIVE BACKEND `groovy.cli.picocli.CliBuilder` — same DSL
#      but backed by picocli (R277) instead of commons-cli — for
#      colored output + automatic --help generation
#  Distinct from R371 Apache Commons CLI (Java imperative `Options
#  options = new Options(); options.addOption(SHORT, LONG, HAS_ARG,
#  DESC)` builder — same backend, DIFFERENT FRONTEND/language),
#  R277 picocli (Java annotation-driven `@Command`/`@Option`/
#  `@Parameters` with auto-color help), R322 JCommander (Java
#  annotation-driven `@Parameter` with reflection), R370 Scala
#  case-app (Scala case class + `@HelpMessage`/`@ExtraName`
#  annotations), R343 commander.js (JS fluent builder), R275 Rust
#  clap-derive (Rust struct + clap-derive macro).  Groovy CliBuilder's
#  approach: GROOVY DSL with `with` BLOCK + METHOD-CALL-AS-OPTION
#  syntax + SHORT-NAMES-AS-GROOVY-IDENTIFIERS + UPPERCASE/LONG-ONLY
#  as QUOTED STRINGS + PROPERTY-STYLE RESULT ACCESS via `OptionAccessor`
#  + INTERNALLY WRAPS Apache Commons CLI but HIDES Java types — corpus's
#  **first documented Groovy-DSL-wrapping-commons-cli CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 115;
#  Groovy added to the documented-CLI-language set.
#
#  Surface (verbatim from Runner.groovy `configureRunCli` block):
#
#  Options:
#    -h, --help                   Usage information
#    -d, --dir DIR                Output directory
#        --delay SECONDS          Delay in seconds before starting
#                                 pipeline
#    -a, --autoarchive PATH       Clean up internal files after run
#                                 into given archive
#    -t, --test                   Test mode
#    -f, --filename FILE          Output file name of report
#    -r, --report                 Generate HTML report / documentation
#                                 for pipeline
#    -R, --report TEMPLATE        Generate report using named template
#                                 (uppercase short form, quoted in DSL)
#    -n, --threads N              Maximum threads
#    -m, --memory MEM             Maximum memory in MB, or specified as
#                                 <n>GB or <n>MB
#    -l, --resource RES=VAL       Place limit on named resource
#    -v, --verbose                Print internal logging to stderr
#    -y, --yes                    Answer yes to any prompts
#    -u, --until STAGE            Run until stage given
#    -p, --param K=V[,K=V,...]    Define pipeline parameter, or @<file>
#                                 (valueSeparator: ',' as char)
#    -b, --branch B1,B2,...       Comma-separated list of branches to
#                                 limit execution to
#    -s, --source FILE            Load pipeline file(s) before running
#    -e, --env ENV                Environment to select from alternate
#                                 configs in bpipe.config
#    -L, --interval INTERVAL      Default genomic interval (samtools
#                                 format)
#        --no-checks              Skip execution of all pipeline checks
#
#  Subcommands (dispatched via positional argv[0]):
#    run PIPELINE [FILES...]      Run a pipeline
#    test PIPELINE                Test mode (alias for `-t`)
#    log [JOBID]                  Tail bpipe log
#    status                       Show pipeline status
#    cleanup [-v] FILES...        Clean up dependency outputs
#    stopcommands                 Stop all running commands
#    diagram PIPELINE             Generate pipeline DAG diagram
#    documentation PIPELINE       Generate HTML documentation
#    install PIPELINE             Install pipeline dependencies
#    agent [-v] [-n CONCURRENCY]  Run as bpipe agent
#    archive ARCHIVE.zip          Archive pipeline outputs
#    history                      Show pipeline run history
#    jobs                         Show active jobs
#    register PIPELINE            Register pipeline with system
#    preallocate                  Preallocate resources
#    query                        Query pipeline state
#    retry                        Retry failed pipeline stages
#
#  Positional:
#    PIPELINE.groovy              Pipeline definition file (Groovy DSL)
#    DATA_FILES...                Input data files (FASTQ, BAM, VCF, etc.)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base):
#    - nextflow (IN CORPUS via _nextflow — Seqera Labs nf-core pipelines)
#    - nf-core (IN CORPUS via _nf-core)
#    - grails (IN CORPUS — Grails web framework)
#    - sdk / sdkman (IN CORPUS — SDKMAN! sdk command)
#    - jbang (IN CORPUS — Java/Groovy single-file script runner)
#    - liquibase (IN CORPUS + STOCK — database schema migration)
#    - groovysh / groovyConsole (IN CORPUS — Groovy REPL/IDE; no
#      CliBuilder usage in their own CLI dispatch)
#    - rundeck (6131 stars but `_rd` already covers main Rundeck CLI;
#      Rundeck's Groovy testbuild.groovy uses CliBuilder but is just
#      a build script, not the user-facing rundeck binary)
#    - doop (plast-lab/doop — 214 stars academic pointer analysis,
#      smaller user base; FUTURE round candidate)
#    - craftercms (335 stars — CMS, mostly Spring Boot Java with
#      Groovy startup helper, less pure-Groovy showcase)
#    - ccu-historian (131 stars — Homematic CCU data recorder,
#      smaller user base)
# ============================================================================

_bpipe() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show usage information]' \
    '(-d --dir)'{-d,--dir}'=[output directory]:dir:_directories' \
    '--delay=[delay seconds before pipeline start]:seconds' \
    '(-a --autoarchive)'{-a,--autoarchive}'=[clean up internal files into archive]:path' \
    '(-t --test)'{-t,--test}'[test mode]' \
    '(-f --filename)'{-f,--filename}'=[report output file name]:file:_files' \
    '(-r --report)'{-r,--report}'[generate HTML report for pipeline]' \
    '-R[generate report using named template]:template' \
    '(-n --threads)'{-n,--threads}'=[maximum threads]:n' \
    '(-m --memory)'{-m,--memory}'=[max memory (MB or <n>GB / <n>MB)]:memory' \
    '*'{-l,--resource}'=[limit on named resource (resource=value)]:limit' \
    '(-v --verbose)'{-v,--verbose}'[print internal logging to stderr]' \
    '(-y --yes)'{-y,--yes}'[answer yes to any prompts]' \
    '(-u --until)'{-u,--until}'=[run until stage given]:stage' \
    '*'{-p,--param}'=[pipeline parameter (name=value or @file)]:param' \
    '*'{-b,--branch}'=[comma-separated branches to limit execution to]:branches' \
    '*'{-s,--source}'=[load pipeline file before running]:file:_files -g "*.groovy"' \
    '(-e --env)'{-e,--env}'=[environment from bpipe.config]:env' \
    '-L[default genomic interval (samtools format)]:interval' \
    '--no-checks[skip execution of all pipeline checks]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'run:run a pipeline'
        'test:test mode'
        'log:tail bpipe log'
        'status:show pipeline status'
        'cleanup:clean up dependency outputs'
        'stopcommands:stop all running commands'
        'diagram:generate pipeline DAG diagram'
        'documentation:generate HTML documentation'
        'install:install pipeline dependencies'
        'agent:run as bpipe agent'
        'archive:archive pipeline outputs'
        'history:show pipeline run history'
        'jobs:show active jobs'
        'register:register pipeline with system'
        'preallocate:preallocate resources'
        'query:query pipeline state'
        'retry:retry failed pipeline stages'
      )
      _alternative \
        'commands:bpipe subcommand:(($verbs))' \
        'pipelines:pipeline file:_files -g "*.groovy"'
      ;;
    subargs)
      case $line[1] in
        run|test|install|register|preallocate|diagram|documentation|retry)
          _files -g "*.groovy"
          ;;
        log)
          _arguments \
            ':job id'
          ;;
        agent)
          _arguments \
            '-v[verbose]' \
            '-n=[concurrency]:n'
          ;;
        archive)
          _files -g "*.zip"
          ;;
        cleanup)
          _arguments \
            '-v[verbose]' \
            '*:file:_files'
          ;;
      esac
      ;;
  esac
}

_bpipe "$@"
