#compdef uuagc
# Documentation: https://hackage.haskell.org/package/uuagc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Hackage README and project GitHub do not document CLI flags;
# upstream docs only describe uuagc as a Haskell attribute-grammar
# compiler. Per-flag verification (-m/--module, -d/--data, etc.) was
# not achievable from public docs, so flags cannot be asserted.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:ag file:_files -g "*.ag"' && ret=0
return ret
