#compdef dart
# _dart-cli — Dart language tool (Google, Dart); compile/run/test/format Dart code and packages
# upstream: https://github.com/dart-lang/sdk

_dart-cli() {
    local -a sub=(
        'analyze:analyze project'
        'build:run build_runner'
        'compile:compile Dart to native/snap/js'
        'create:create new project'
        'devtools:open DevTools'
        'doc:generate dartdoc'
        'fix:apply automated fixes'
        'format:format source files'
        'help:show help'
        'info:print platform info'
        'language-server:run analyzer LSP'
        'mcp-server:run MCP server'
        'pub:pub package manager'
        'run:run a script'
        'test:run tests'
        'tooling-daemon:run tooling daemon'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--enable-analytics[enable analytics]' \
        '--disable-analytics[disable analytics]' \
        '--enable-experiment+[experiments]:str:' \
        '--no-analytics[no analytics]' \
        '--sound-null-safety[sound null safety]' \
        '--no-sound-null-safety[no sound null safety]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dart subcommand' sub ;;
        args)
            case $words[1] in
                pub) _arguments '1:pub cmd:(add cache deps downgrade get global login logout outdated publish remove run token unpack upgrade)' '*:args:' ;;
                compile) _arguments \
                    '1:type:(aot-snapshot exe jit-snapshot js kernel)' \
                    '-o+[output]:file:_files' \
                    '--output+[output]:file:_files' \
                    '*:file:_files' ;;
                create) _arguments \
                    '-t+[template]:template:(console package server-shelf web cli web-server-shelf)' \
                    '--template+[template]:template:' \
                    '--force[force]' \
                    '--no-pub[no pub get]' \
                    '*:dir:_files -/' ;;
                test) _arguments \
                    '-r+[reporter]:reporter:(compact expanded failures-only github json silent)' \
                    '--reporter+[reporter]:reporter:' \
                    '-j+[concurrency]:n:' \
                    '--concurrency+[concurrency]:n:' \
                    '-p+[platform]:platform:(chrome firefox safari vm node)' \
                    '--platform+[platform]:platform:' \
                    '--coverage+[coverage dir]:dir:_files -/' \
                    '--name+[name regex]:regex:' \
                    '*:test file:_files -g "*.dart"' ;;
                format) _arguments \
                    '--output+[output]:type:(write show)' \
                    '-o+[output]:type:(write show)' \
                    '--line-length+[line length]:n:' \
                    '-l+[line length]:n:' \
                    '--show+[show what]:val:(all changed none)' \
                    '--set-exit-if-changed[set exit if changed]' \
                    '*:path:_files' ;;
            esac
            ;;
    esac
}

_dart-cli "$@"
