#compdef ruplacer
# Documentation: https://github.com/your-tools/ruplacer
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# ruplacer - find and replace text in source files.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--go[actually perform replacements (default is preview only)]' \
  '(-t --type)'{-t,--type=}'[only process files matching type]:file type:' \
  '--type-not=[exclude file types]:file type:' \
  '--type-list[show all available file types]' \
  '--hidden[search hidden files and directories]' \
  '(-w --word-regex)'{-w,--word-regex}'[match whole words only]' \
  '--no-regex[treat pattern as literal string]' \
  '--preserve-case[preserve case style when replacing]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--ignored[search ignored files]' \
  '--color=[color output]:when:(auto always never)' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:pattern:' \
  '2:replacement:' \
  '3:path:_files' && ret=0

return ret
