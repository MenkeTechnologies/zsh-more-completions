#compdef ruplacer

# Zsh completion for ruplacer - find and replace in files

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--go[actually perform replacements]' \
  '(-t --type)'{-t,--type}'[only search files matching type]:file type:' \
  '--hidden[search hidden files and directories]' \
  '(-w --word-regex)'{-w,--word-regex}'[match whole words only]' \
  '--no-regex[treat pattern as literal string]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--ignored[search ignored files]' \
  '--color[color output]:when:(auto always never)' \
  '--help[show help]' \
  '--version[show version]' \
  '1:pattern:' \
  '2:replacement:' \
  '3:path:_files' && ret=0

return ret
