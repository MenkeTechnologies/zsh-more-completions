#compdef extractfeat
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/extractfeat.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS extractfeat: extract features from a sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence with features]:sequence USA:_files' \
  '-before=[bases to extract upstream of each feature]:n:' \
  '-after=[bases to extract downstream of each feature]:n:' \
  '-source=[feature source filter]:source:' \
  '-type=[feature type filter]:type:' \
  '-sense=[strand sense filter]:sense:(0 1 -1)' \
  '-minscore=[minimum feature score]:score:' \
  '-maxscore=[maximum feature score]:score:' \
  '-tag=[feature tag filter]:tag:' \
  '-value=[feature tag value filter]:value:' \
  '-join[join multi-segment features into one output]' \
  '-featinname[include feature type in output ID]' \
  '-describe=[tags to add to description]:tags:' \
  '-outseq=[output sequence file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
