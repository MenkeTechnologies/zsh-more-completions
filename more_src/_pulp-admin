#compdef pulp-admin

# pulp-admin: Pulp 2.x administration CLI (Pulp 3 uses pulp-cli / pulpcore-manager)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'auth:manage authentication'
  'consumer:manage consumers'
  'event:manage event listeners'
  'login:authenticate against the Pulp server'
  'logout:remove cached credentials'
  'orphan:manage orphaned content'
  'puppet:Puppet plugin commands'
  'python:Python plugin commands'
  'repo:manage repositories'
  'rpm:manage RPM repositories'
  'server:server administration'
  'sync:manage sync schedules'
  'tasks:show tasks'
  'user:manage users'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --username)'{-u,--username=}'[Pulp user]:user:' \
  '(-p --password)'{-p,--password=}'[Pulp password]:pwd:' \
  '--cert-file=[client cert file]:file:_files' \
  '--key-file=[client key file]:file:_files' \
  '--verify-ssl=[verify SSL]:bool:(true false)' \
  '--config=[config file]:file:_files' \
  '--debug[debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pulp-admin subcommand' commands && ret=0 ;;
esac
return ret
