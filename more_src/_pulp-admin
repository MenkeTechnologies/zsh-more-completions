#compdef pulp-admin

# pulp-admin: Pulp v2 administrative CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'rpm:RPM repositories'
  'puppet:Puppet repositories'
  'iso:ISO repositories'
  'docker:Docker registries'
  'ostree:OSTree repositories'
  'python:Python repositories'
  'deb:Debian repositories'
  'auth:auth (user/role/permission)'
  'consumer:consumer management'
  'consumer-group:consumer group management'
  'event:event listener management'
  'login:log into the Pulp server'
  'logout:log out of the Pulp server'
  'orphan:orphan content management'
  'permission:permission management'
  'repo:repository management (cross-type)'
  'role:role management'
  'server:server configuration'
  'tasks:server task management'
  'user:user management'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-u[username]:user:' \
  '--username=[username]:user:' \
  '-p[password]:pass:' \
  '--password=[password]:pass:' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-s[server hostname]:host:' \
  '--server=[server hostname]:host:' \
  '--cert-file=[client cert]:file:_files' \
  '--key-file=[client key]:file:_files' \
  '--ca-path=[ca cert path]:path:_files' \
  '--map[show command map]' \
  '--debug[debug client output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pulp-admin command' commands && ret=0 ;;
esac
return ret
