#compdef capacitor-cli
# _capacitor-cli — Ionic Capacitor cross-platform native runtime CLI alias (ionic-team team, TypeScript); commander
# upstream: https://github.com/ionic-team/capacitor

_capacitor-cli() {
    local -a sub=(
        'init:initialize Capacitor project'
        'add:add a new platform'
        'sync:copy + update native code'
        'copy:copy web assets to native projects'
        'update:update native plugins/dependencies'
        'open:open native IDE'
        'run:run app on device/simulator'
        'build:run build steps'
        'serve:serve app and open native browser'
        'doctor:check installation'
        'ls:list installed plugins'
        'plugin:generate:generate plugin scaffold'
        'config:get/set config'
        'telemetry:enable/disable telemetry'
        'migrate:migrate to latest Capacitor'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'capacitor subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '1:app name:' \
                    '2:app id:' \
                    '--web-dir=+[dir]:dir:_files -/' \
                    '--npm-client=+[client]:c:(npm pnpm yarn bun)' ;;
                add|sync|copy|update|open|run|build) _arguments \
                    '1:platform:(ios android)' \
                    '--deployment[deployment mode]' \
                    '--inline[inline source maps]' \
                    '--target=+[target device]:str:' \
                    '--no-sync[no sync]' \
                    '--prod[production]' \
                    '--list[list devices]' \
                    '--keystorepath=+[keystore]:file:_files' \
                    '--keystorepass=+[pass]:str:' \
                    '--keystorealias=+[alias]:str:' \
                    '--keystorealiaspass=+[alias pass]:str:' \
                    '--androidreleasetype=+[type]:t:(APK AAB)' ;;
                plugin:generate) _arguments \
                    '1:name:' \
                    '2:dir:_files -/' \
                    '--package=+[package]:str:' ;;
                config) _arguments '1:get/set:' '*:args:' ;;
                migrate) _arguments '--no-confirm[no confirm]' ;;
            esac
            ;;
    esac
}

_capacitor-cli "$@"
