#compdef dialign2-2
# Documentation: https://dialign.gobics.de/
# DIALIGN 2: segment-to-segment multiple sequence alignment

local ret=1

_arguments -s -S \
  '-afc[output file *.afc with all considered fragments]' \
  '-afc_v[like -afc but verbose, fragments printed explicitly]' \
  '-anc[anchored alignment using seq_file.anc anchor points]' \
  '-cs[examine both Watson and Crick strands of translated segments]' \
  '-cw[additional output file in CLUSTAL W format]' \
  '-ds[DNA alignment speed up; require two matches at fragment start]' \
  '-fa[additional output file in FASTA format]' \
  '-ff[file *.frg with fragment info from pairwise alignments]' \
  '-fn[name output files as out_file.extension]:out_file:_files' \
  '-fop[file *.fop with fragment coordinates in pairwise alignments]' \
  '-fsm[file *.fsm with fragment coordinates in final alignment]' \
  '-iw[disable overlap weights]' \
  '-lgs[long genomic sequences mode]' \
  '-lgs_t[like -lgs but assess all segment pairs at peptide level]' \
  '-lmax[maximum fragment length]:length:' \
  '-lo[long output; generate *.log file]' \
  '-ma[mixed alignments of P-fragments and N-fragments]' \
  '-mask[replace non-selected residues with *]' \
  '-mat[file *mat with substitution counts]' \
  '-mat_thr[like -mat but only fragments with weight score > t]:t:' \
  '-max_link[maximum linkage clustering for sequence tree]' \
  '-min_link[minimum linkage clustering for sequence tree]' \
  '-mot[motif option]' \
  '-msf[additional output file in MSF format]' \
  '-n[nucleic acid sequences without fragment translation]' \
  '-nt[nucleic acid sequences, translate segments to peptides]' \
  '-nta[suppress textual alignment]' \
  '-o[fast version (alignments may differ slightly)]' \
  '-ow[enforce overlap weights]' \
  '-pst[print status; create *.sta file]' \
  '-smin[minimum similarity for first residue/codon pair]:x:' \
  '-stars[limit * characters indicating local similarity]:x:' \
  '-stdo[write results to standard output]' \
  '-ta[print standard textual alignment]' \
  '-thr[set threshold T]:x:' \
  '-xfr[exclude specified fragments from pairwise alignment]' \
  '*:sequence file:_files' && ret=0

return ret
