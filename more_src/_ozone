#compdef ozone

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'sh:client commands (volumes/buckets/keys/snapshots)'
  'fs:filesystem commands (similar to hdfs dfs)'
  'admin:admin and developer commands'
  'debug:debug tools'
  'freon:load generator (stress test)'
  'classpath:print Hadoop class path'
  'dtutil:delegation token operations'
  'envvars:display Hadoop environment variables'
  'getconf:read ozone config values'
  'genconf:generate minimal ozone-site.xml'
  'ratislogparser:print Ratis log in human-readable form'
  'om:start Ozone Manager'
  'scm:start Storage Container Manager'
  'datanode:start datanode'
  's3g:start S3 Gateway'
  'recon:start Recon service'
  'httpfs:start HttpFS gateway'
  'insight:diagnostic insight tool'
  'csi:start CSI server'
  'auditparser:Ozone audit log parser'
  'repair:repair tool'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--config=[Hadoop config dir]:dir:_files -/' \
  '--debug[enable debug output]' \
  '--daemon=[daemon mode]:mode:(start status stop)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ozone subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (sh)
        _values 'sh action' \
          'volume' 'bucket' 'key' 'token' 'snapshot' 'tenant' 'prefix' && ret=0
        ;;
      (admin)
        _values 'admin action' \
          'containerbalancer' 'replicationmanager' 'safemode' 'printTopology' \
          'cert' 'container' 'datanode' 'pipeline' 'namespace' 'om' 'reconfig' \
          'scm' 'cluster' 'service' 'tenant' 'reconcile' 'transfer' 'decommission' \
          'maintenance' && ret=0
        ;;
      (debug)
        _values 'debug action' \
          'chunkinfo' 'print-log-dag' 'pld' 'find-missing-padding' 'fmp' \
          'recover' 'prefix' 'ldb' 'read-replicas' 'container' 'ratislogparser' \
          'replicas' 'om' 'scm' && ret=0
        ;;
      (freon)
        _values 'freon test' \
          'rk' 'randomkey' 'ockg' 'omkg' 'omcg' 'leaderelection' 'rcoc' \
          'cg' 'omdb' 'okga' 'ockg' 'ompg' 'okr' 'oksrc' 'osc' 'ompc' \
          'rsk' 'omdg' 'okmd' 'sk' 'csg' 'oksv' 'ocac' && ret=0
        ;;
      (fs)
        _values 'fs operation' \
          '-ls' '-mkdir' '-rm' '-rmr' '-mv' '-cp' '-put' '-get' '-cat' \
          '-text' '-chmod' '-chown' '-chgrp' '-touchz' '-du' '-df' '-dus' \
          '-stat' '-tail' '-test' '-find' '-getmerge' '-copyToLocal' \
          '-copyFromLocal' '-moveFromLocal' '-moveToLocal' '-checksum' \
          '-getfattr' '-setfattr' '-truncate' '-help' && ret=0
        ;;
    esac
    ;;
esac

return ret
