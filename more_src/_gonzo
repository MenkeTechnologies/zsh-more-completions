#compdef gonzo
# Documentation: https://github.com/control-theory/gonzo
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gonzo — real-time log analysis terminal UI.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*'{-f,--file}'=[files or globs to read logs from]:file:_files' \
  '--follow[monitor log files in real time]' \
  '--format=[log format (auto, json, logfmt, plain, custom)]:format:(auto json logfmt plain custom)' \
  '(-u --update-interval)'{-u,--update-interval}'=[dashboard refresh rate]:duration:' \
  '(-b --log-buffer)'{-b,--log-buffer}'=[max log entries retained]:count:' \
  '(-m --memory-size)'{-m,--memory-size}'=[max frequency entries]:count:' \
  '--ai-provider=[AI provider]:provider:(openai claude-code)' \
  '--ai-model=[AI model name]:model:' \
  '(-s --skin)'{-s,--skin}'=[color scheme/theme]:skin:' \
  '*--stop-words=[additional words to filter from analysis]:word:' \
  '--k8s-enabled[enable Kubernetes log streaming]' \
  '*--k8s-namespaces=[target Kubernetes namespaces]:namespace:' \
  '--k8s-selector=[filter pods by labels]:selector:' \
  '--k8s-kubeconfig=[path to kubeconfig]:file:_files' \
  '--web-port=[port for web dashboard]:port:' \
  '--web-disabled[disable web dashboard]' \
  '--config=[configuration file path]:file:_files' \
  '(-t --test-mode)'{-t,--test-mode}'[run without TTY]' && ret=0

return ret
