#compdef roo-cli roo

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authentication commands (login/logout/status)'
  'task:task subcommands'
  'config:print or edit configuration'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --print)'{-p,--print}'[print final response to stdout and exit]' \
  '--output-format=[output format]:format:(text json stream-json)' \
  '--input-format=[input format]:format:(text json)' \
  '--ephemeral[purge global/workspace state on exit]' \
  '--require-approval[require manual approval for tools]' \
  '--terminal-shell=[shell for tool execution]:shell:(bash zsh fish sh dash)' \
  '--stdin-prompt-stream[read NDJSON prompts from stdin]' \
  '--mistake-limit=[consecutive mistake limit]:n:' \
  '--create-with-session-id=[create new task with session UUID]:uuid:' \
  '--resume=[resume existing session]:uuid:' \
  '--mode=[Roo mode]:mode:(code architect ask debug orchestrator custom)' \
  '--provider=[LLM provider]:provider:(openai anthropic openrouter ollama vertex bedrock azure roo)' \
  '--model=[LLM model id]:model:' \
  '--workspace=[workspace path]:dir:_files -/' \
  '--profile=[configuration profile]:profile:' \
  '--temperature=[sampling temperature]:f:' \
  '--max-tokens=[max output tokens]:n:' \
  '--max-cost=[max cost in dollars]:f:' \
  '--max-turns=[max conversational turns]:n:' \
  '--auto-approve[auto-approve all actions]' \
  '--no-checkpoints[disable workspace checkpoints]' \
  '--quiet[suppress informational output]' \
  '--debug[debug logging]' \
  '*--include=[include file pattern]:glob:' \
  '*--exclude=[exclude file pattern]:glob:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'roo-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments '*::sub:(login logout status)' && ret=0 ;;
      (task)
        _arguments '*::sub:(list new resume delete)' && ret=0 ;;
      (config)
        _arguments \
          '--edit[open in editor]' \
          '--print[print effective config]' && ret=0 ;;
    esac ;;
esac

return ret
