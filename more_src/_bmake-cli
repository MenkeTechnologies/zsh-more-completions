#compdef bmake-cli
# _bmake-cli — Simon J Gerraty bmake portable BSD make CLI alias (NetBSD/sjg team, C); custom argparse
# upstream: https://www.crufty.net/help/sjg/bmake.html

_bmake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-B[backward compatible single-shell-per-command mode]' \
        '-C+[chdir]:dir:_files -/' \
        '-D+[macro define]:str:' \
        '-d+[debug flags]:str:' \
        '-e[env overrides]' \
        '-f+[makefile]:file:_files' \
        '-I+[include dir]:dir:_files -/' \
        '-i[ignore errors]' \
        '-J+[fd_in,fd_out]:str:' \
        '-j+[jobs]:n:' \
        '-k[keep going]' \
        '-m+[lookup dir]:dir:_files -/' \
        '-N[print what would be executed]' \
        '-n[print but do not exec]' \
        '-q[query]' \
        '-r[no built-in rules]' \
        '-S[stop on error]' \
        '-s[silent]' \
        '-T+[trace file]:file:_files' \
        '-t[touch]' \
        '-V+[variable to print]:str:' \
        '-v[verbose]' \
        '-W+[treat as warning]:str:' \
        '-w[print directory]' \
        '-X[no export]' \
        '*:targets vars:'
}

_bmake-cli "$@"
