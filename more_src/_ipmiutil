#compdef ipmiutil
# _ipmiutil — Andy Cress ipmiutil server-management utility for IPMI Intelligent Platform Management Interface (ipmiutil team, C); custom argparse
# upstream: https://github.com/atcress/ipmiutil

_ipmiutil() {
    local -a sub=(
        'getevt:get IPMI events'
        'sel:show System Event Log'
        'health:show basic health'
        'sensor:show sensors'
        'sensors:show sensors'
        'user:show or set users'
        'lan:show or set LAN config'
        'serial:show or set serial config'
        'config:save or restore configuration'
        'cmd:send IPMI raw command'
        'reset:reset BMC'
        'getevent:get event'
        'getstatus:get status'
        'getsdr:get SDR'
        'getsel:get SEL'
        'leds:control LEDs'
        'fwum:firmware update'
        'fru:show FRU info'
        'mc:show MC info'
        'reset_bmc:reset BMC'
        'discover:discover IPMI hosts'
        'set_pef:set platform event filter'
        'sol:serial over LAN'
        'tsol:terminal SOL'
        'snmp_alert:snmp alert config'
        'wdt:watchdog'
        'fan:show fans'
        'tmconf:set timezone'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-N+[ip address]:host:_hosts' \
        '--node=+[ip address]:host:_hosts' \
        '-U+[user]:user:_users' \
        '--user=+[user]:user:_users' \
        '-P+[password]:str:' \
        '--password=+[password]:str:' \
        '-R+[reuse]:str:' \
        '-J+[cipher suite]:n:' \
        '-T+[transport]:t:(LAN LAN+ KCS SMB OPENIPMI)' \
        '-Y+[ipmi version]:v:(1.5 2.0)' \
        '-E[use IPMI_PASSWORD env]' \
        '-F+[driver]:d:(lan lan_2_0 kcs smb openipmi)' \
        '-L+[priv level]:p:(USER OPERATOR ADMIN CALLBACK)' \
        '-o+[output csv]:str:' \
        '-O+[output file]:file:_files' \
        '-x[debug]' \
        '-v+[verbose]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ipmiutil subcommand' sub ;;
    esac
}

_ipmiutil "$@"
