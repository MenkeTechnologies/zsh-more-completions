#compdef cgspec
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/cgspec.html
# MIRIAD: overlay spectra on displayed images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[up to 10 input images]:in:_files' \
  'type=[image type]:type:(contour pixel spectrum dspectrum mask)' \
  'region=[region of interest]:region:' \
  'xybin=[spatial increment and binning]:xybin:' \
  'slev=[contour level scale factor pairs]:slev:' \
  'levs1=[contour levels image 1]:levs1:' \
  'levs2=[contour levels image 2]:levs2:' \
  'levs3=[contour levels image 3]:levs3:' \
  'grange=[pixel map range and lookup table]:grange:' \
  'vrange=[spectral range to plot]:vrange:' \
  'irange=[intensity range for spectra]:irange:' \
  'iscale=[per-spectrum scaling factor]:iscale:' \
  'spsize=[spectrum sizes as viewport fractions]:spsize:' \
  'stick=[major tick increments]:stick:' \
  'device=[PGPLOT device]:device:' \
  'labtyp=[spatial label types]:labtyp:' \
  'options=[display customization options]:options:' \
  'clines=[contour line widths]:clines:' \
  'slines=[spectrum line widths and types]:slines:' \
  'blines=[border and label line widths]:blines:' \
  'break=[solid/dashed contour transitions]:break:' \
  'csize=[character sizes]:csize:' \
  'olay=[overlay spectrum location file]:olay:_files' \
  '*:image:_files' && ret=0

return ret
