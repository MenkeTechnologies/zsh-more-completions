#compdef usacloud

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:manage Sakura Cloud CLI configuration'
  'auth-status:show authentication status'
  'server:manage virtual servers'
  'disk:manage disks'
  'archive:manage archives'
  'cdrom:manage CD-ROMs'
  'auto-backup:manage automatic backups'
  'private-host:manage private hosts'
  'bridge:manage bridges'
  'internet:manage internet routers'
  'local-router:manage local routers'
  'packet-filter:manage packet filters'
  'switch:manage switches'
  'interface:manage interfaces'
  'ipaddress:manage IPv4 addresses'
  'ipv6addr:manage IPv6 addresses'
  'ipv6net:manage IPv6 networks'
  'subnet:manage subnets'
  'database:manage database appliances'
  'load-balancer:manage load balancers'
  'nfs:manage NFS appliances'
  'vpc-router:manage VPC routers'
  'mobile-gateway:manage mobile gateways'
  'sim:manage SIM cards'
  'dns:manage DNS zones'
  'gslb:manage GSLBs'
  'proxy-lb:manage Proxy LBs'
  'simple-monitor:manage simple monitors'
  'bill:list billing'
  'coupon:list coupons'
  'container-registry:manage container registries'
  'esme:manage SMS service'
  'web-accelerator:manage web accelerator'
  'icon:manage icons'
  'license:manage licenses'
  'note:manage startup scripts/notes'
  'ssh-key:manage SSH keys'
  'region:list regions'
  'zone:list zones'
  'disk-plan:list disk plans'
  'internet-plan:list internet plans'
  'license-info:list license types'
  'private-host-plan:list private host plans'
  'server-plan:list server plans'
  'service-class:list service classes'
  'rest:call the API directly'
  'self:show calling user info'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

local -a global_zones=(is1a is1b tk1a tk1b tk1v)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[profile name]:profile:' \
  '*--zone=[zone]:zone:($global_zones)' \
  '--no-color[disable color output]' \
  '--output-type=[output format]:format:(table json yaml csv tsv)' \
  '--token=[API token]:token:' \
  '--secret=[API secret]:secret:' \
  '--debug[debug logging]' \
  '--trace[trace logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'usacloud command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server|disk|archive|cdrom|switch|database|load-balancer|nfs|vpc-router|mobile-gateway|sim|dns|gslb|proxy-lb|simple-monitor|container-registry|note|ssh-key|icon|license|esme)
        _arguments \
          '*::sub:(list ls find create read update delete shutdown reset boot power-on power-off ssh scp wait-until clone snapshot)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
      (region|zone|disk-plan|internet-plan|license-info|private-host-plan|server-plan|service-class)
        _arguments \
          '*::sub:(list ls)' && ret=0 ;;
    esac ;;
esac

return ret
