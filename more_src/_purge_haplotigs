#compdef purge_haplotigs
# Documentation: https://github.com/skingan/purge_haplotigs_multiBAM
# purge_haplotigs: identify and reassign allelic contigs in heterozygous assemblies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'purge_haplotigs subcommand' \
      'readhist[generate a read-depth histogram for the genome]' \
      'contigcov[get contig coverage stats and flag suspect contigs]' \
      'purge[identify and reassign haplotigs]' \
      'ncbiplace[generate a placement file for NCBI submission]' && ret=0
    _files
    ;;
esac

return ret
