#compdef rsgiscmprefimgs
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# A utility which checks an image against a reference image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --ref)'{-r,--ref}'[Input file search path for reference images (i.e., '\''/path/to/*.tif'\'')]:value:_files' \
  '(-i --input)'{-i,--input}'[Input path to images which are being checked.]:value:_files' \
  '(-e --ext)'{-e,--ext}'[Input image file extension (pairs with --input).]:value:_files' \
  '(-o --output)'{-o,--output}'[Optional output JSON file with list of files checked,]:value:_files' \
  '--rmerr[Delete error files from system.]' \
  '*:file:_files' && ret=0

return ret
