#compdef stalin
# Documentation: https://man.archlinux.org/search?q=stalin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c[generate C code only]' \
  '-d[debug mode]' \
  '-I+[include path]:dir:_files -/' \
  '-O+[opt level]:n:(0 1 2 3 4 5)' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-o+[output file]:file:_files' \
  '-On[no optimization]' \
  '-clean[delete intermediates]' \
  '-no-clean[keep intermediates]' \
  '-T+[type inference timeout]:sec:' \
  '-L+[library path]:dir:_files -/' \
  '*:scheme file:_files -g "*.{scm,sc,ss}"' && ret=0

return ret
