#compdef stalin
# Documentation: https://github.com/barak/stalin/blob/master/stalin.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-version[print version and exit]' \
  '*-I+[scheme include directory]:dir:_files -/' \
  '-s[include Scheme->C compatibility macros (WHEN, UNLESS)]' \
  '-x[include Xlib/GL macros (FOREIGN-FUNCTION, FOREIGN-DEFINE; implies -s)]' \
  '-q[include QobiScheme macros (DEFINE-STRUCTURE; implies -x)]' \
  '-t[include macros for self-compiling Stalin (implies -q)]' \
  '-treat-all-symbols-as-external[share one abstract external symbol across all]' \
  '-do-not-treat-all-symbols-as-external[generate distinct abstract symbol per constant (default)]' \
  '-no-clone-size-limit[do not limit clone size]' \
  '-clone-size-limit+[limit clone size]:expressions:' \
  '-split-even-if-no-widening[split even when no widening occurs]' \
  '-fully-convert-to-CPS[fully CPS-convert]' \
  '-no-escaping-continuations[no escaping continuations]' \
  '-du[dump usage statistics]' \
  '-Ob[optimization: baseline]' \
  '-Om[optimization: medium]' \
  '-On[optimization: none]' \
  '-Or[optimization: representation]' \
  '-Ot[eliminate type checking]' \
  '-d0[debugging level 0]' \
  '-d1[debugging level 1]' \
  '-d2[debugging level 2]' \
  '-d3[debugging level 3]' \
  '-d4[debugging level 4]' \
  '-d5[debugging level 5]' \
  '-d6[debugging level 6]' \
  '-d7[debugging level 7]' \
  '-closure-conversion-statistics[print closure conversion statistics]' \
  '-dc[debug: closure conversion]' \
  '-dC[debug: closure conversion (verbose)]' \
  '-dH[debug: heap]' \
  '-dg[debug: graph]' \
  '-dh[debug: heap]' \
  '-d[generic debug]' \
  '-architecture+[target architecture]:name:' \
  '-baseline[baseline closure conversion]' \
  '-conventional[conventional closure conversion]' \
  '-lightweight[lightweight closure conversion]' \
  '-immediate-flat[immediate flat closures]' \
  '-indirect-flat[indirect flat closures]' \
  '-immediate-display[immediate display closures]' \
  '-indirect-display[indirect display closures]' \
  '-linked[linked closures]' \
  '-align-strings[align strings]' \
  '-do-not-align-strings[do not align strings]' \
  '-de[debug e]' \
  '-df[debug f]' \
  '-dG[debug G]' \
  '-di[debug i]' \
  '-dI[debug I]' \
  '-dp[debug p]' \
  '-dP[debug P]' \
  '-ds[debug s]' \
  '-dS[debug S]' \
  '-Tmk[Tmk mode]' \
  '-no-tail-call-optimization[disable tail-call optimization]' \
  '-db[debug b]' \
  '-c[stop after generating C code]' \
  '-k[keep intermediate files]' \
  '-cc+[C compiler to use]:cc:_command_names -e' \
  '*-copt+[option to pass to the C compiler]:opt:' \
  '*:pathname:_files -g "*.sc"' && ret=0

return ret
