#compdef msgpack msgpack-cli
# _msgpack — MessagePack format reference CLI alias (MessagePack project, multiple); custom argparse
# upstream: https://github.com/msgpack/msgpack

_msgpack() {
    local -a sub=(
        'encode:encode JSON to msgpack'
        'decode:decode msgpack to JSON'
        'convert:convert between formats'
        'lint:validate msgpack file'
        'inspect:inspect bytes/structure'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--input=+[input file]:file:_files' \
        '-i+[input file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--format=+[format]:fmt:(json msgpack hex)' \
        '-f+[format]:fmt:(json msgpack hex)' \
        '--pretty[pretty print]' \
        '--no-pretty[no pretty print]' \
        '--ext=+[register extension types]:list:' \
        '--strict[strict]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'msgpack subcommand' sub ;;
        args)
            case $words[1] in
                encode|decode|convert|lint|inspect) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_msgpack "$@"
