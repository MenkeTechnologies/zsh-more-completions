#compdef lvm_dump lvmdump
# Documentation: https://man.archlinux.org/search?q=lvm_dump
# Reference accessed: 2026-05-16

# lvmdump: collect LVM debug info into a tarball for support
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-a[advanced collection (include lvmetad/lvmlockd cache)]' \
  '-c[clean dmsetup info from device list]' \
  '-d[output directory]:dir:_files -/' \
  '-l[also dump lvmlockd info]' \
  '-m[gather metadata only]' \
  '-p[do not collect dm/lvm reports]' \
  '-s[also gather sysreport]' \
  '-u[don'\''t udevadm info]' \
  '*::lvmdump args:_files' && ret=0
return ret
