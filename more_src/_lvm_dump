#compdef lvm_dump

# lvm_dump: collect diagnostic LVM/system information
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a[advanced - collect lvmetad/lvmpolld dumps]' \
  '-c[clustered - run dlm_tool ls and friends]' \
  '-d[output directory]:dir:_files -/' \
  '-l[verbose lvmetad/lvmpolld info]' \
  '-m[gather metadata only]' \
  '-p[pvs / vgs / lvs verbose tables]' \
  '-s[gather system info]' \
  '-u[gather udev info]' \
  '*::lvm_dump args:_files' && ret=0
return ret
