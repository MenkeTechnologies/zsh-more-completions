#compdef lvm_dump lvmdump
# Documentation: https://github.com/lvmteam/lvm2/blob/main/scripts/lvmdump.sh.in
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lvmdump: collect LVM debug info into a tarball for support
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print help]' \
  '-a[advanced collection]' \
  '-c[if running clvmd, gather cluster data]' \
  '-d+[dump into a directory instead of tarball]:dir:_files -/' \
  '-l[gather lvmetad state if running]' \
  '-p[gather lvmpolld state if running]' \
  '-m[gather LVM metadata from the PVs]' \
  '-s[gather system info and context]' \
  '-u[gather udev info and context]' \
  '*::lvmdump args:_files' && ret=0
return ret
