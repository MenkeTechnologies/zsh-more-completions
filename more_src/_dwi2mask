#compdef dwi2mask
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwi2mask.html
# Generate a whole-brain mask from DWI data

local ret=1

_arguments -s -S \
  '(-h -help)-help[display help page and exit]' \
  '-version[display version information and exit]' \
  '-clean_scale[maximum scale used to cut bridges]:value' \
  '-grad[provide DW gradient scheme in a text file]:file:_files' \
  '-fslgrad[provide DW gradient scheme in FSL bvecs/bvals format]:bvecs:_files:bvals:_files' \
  '-info[display information messages]' \
  '-quiet[do not display information messages or progress status]' \
  '-debug[display debugging messages]' \
  '-force[force overwrite of output files]' \
  '-nthreads[use specified number of threads]:number' \
  '*-config[temporarily set the value of an MRtrix config file entry]:key:value' \
  '*:image:_files' && ret=0

return ret
