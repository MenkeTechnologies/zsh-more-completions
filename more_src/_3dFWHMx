#compdef 3dFWHMx
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dFWHMx.html
# AFNI estimate smoothness (FWHM / ACF) of a dataset

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-mask[use only voxels nonzero in dataset]:dataset:_files' \
  '-automask[compute a mask from this dataset]' \
  '(-input -dset)'{-input,-dset}'[input dataset to analyze]:dataset:_files' \
  '-demed[subtract median of each voxel time series]' \
  '-unif[normalize each voxel time series to same MAD]' \
  '-detrend[polynomial detrending to order q]:q' \
  '-detprefix[save detrended dataset with prefix]:prefix' \
  '-geom[final estimate as geometric mean]' \
  '-arith[final estimate as arithmetic mean]' \
  '-combine[combine measurements along each axis]' \
  '-out[write output to file (3 columns)]:file:_files' \
  '-compat[older 3dFWHM compatibility mode]' \
  '(-ACF -acf)'{-ACF,-acf}'[compute spatial autocorrelation function]:anam' \
  '-2difMAD[first/second-neighbor differences with MAD]' \
  '-ShowMeClassicFWHM[output classic FWHM values]' \
  '*:dataset:_files' && ret=0

return ret
