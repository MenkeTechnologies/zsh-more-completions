#compdef gurobi_cl
# Documentation: https://docs.gurobi.com/projects/optimizer/en/current/reference/misc/commandline.html
# Gurobi command-line optimization tool

local ret=1

_arguments -s \
  '--help[display help information]' \
  '--version[show version details]' \
  '--license[display current license file location]' \
  '--tokens[show whether the token server is serving tokens]' \
  '--printquality[output solution quality statistics]' \
  '--server=[specify a Compute Server machine for remote solving]:server' \
  '--password=[provide access password for Compute Server]:password' \
  '--accessid=[cloud credential for Instant Cloud]:accessid' \
  '--secretkey=[cloud credential for Instant Cloud]:secretkey' \
  '--pool=[specify cloud pool name for Instant Cloud]:pool' \
  '*:argument:_files' && ret=0

return ret
