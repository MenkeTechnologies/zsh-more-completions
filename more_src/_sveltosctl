#compdef sveltosctl
# Documentation: https://man.archlinux.org/search?q=sveltosctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'show:dry-run cluster profiles / resources'
      'deploy:deploy add-ons via Sveltos'
      'snapshot:manage cluster configuration snapshots'
      'register:register managed clusters'
      'log:tail Sveltos manager logs'
      'version:print version'
    )
    _describe -t commands 'sveltosctl command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
