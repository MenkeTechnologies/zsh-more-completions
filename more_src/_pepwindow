#compdef pepwindow
# Documentation: https://man.archlinux.org/search?q=pepwindow
# Reference accessed: 2026-05-16

# EMBOSS pepwindow: plot hydropathy profile of a protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-length=[window size for averaging (residues)]:size:' \
  '-aadata=[AA properties data file]:file:_files' \
  '-normalize[normalize values from 0 to 1]' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:protein USA:_files' && ret=0
return ret
