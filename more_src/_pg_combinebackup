#compdef pg_combinebackup

# pg_combinebackup: combine PostgreSQL incremental backups (PG 17+)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-d[debug output]' \
  '--debug[debug output]' \
  '-n[dry-run]' \
  '--dry-run[dry-run]' \
  '-N[no-sync]' \
  '--no-sync[no-sync]' \
  '-o[output directory]:dir:_files -/' \
  '--output=[output directory]:dir:_files -/' \
  '-T[tablespace mapping]:OLDDIR=NEWDIR:' \
  '--tablespace-mapping=[tablespace mapping]:OLDDIR=NEWDIR:' \
  '--clone[clone files instead of copy]' \
  '--copy[force copy of files (default)]' \
  '--copy-file-range[use copy_file_range]' \
  '--link[link files instead of copy]' \
  '--manifest-checksums=[manifest checksums]:algo:(NONE SHA224 SHA256 SHA384 SHA512 CRC32C)' \
  '--no-manifest[do not write backup_manifest]' \
  '--sync-method=[sync method]:method:(fsync syncfs)' \
  '*:backup directories:_files -/' && ret=0
return ret
