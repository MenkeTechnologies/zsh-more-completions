#compdef pg_combinebackup
# Documentation: https://www.postgresql.org/docs/current/app-pgcombinebackup.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pg_combinebackup: combine PostgreSQL incremental backups (PG 17+)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry-run]' \
  '(-N --no-sync)'{-N,--no-sync}'[no sync]' \
  '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
  '*'{-T+,--tablespace-mapping=}'[tablespace mapping]:OLDDIR=NEWDIR:' \
  '(-k --link)'{-k,--link}'[link files instead of copy]' \
  '--clone[clone files instead of copy]' \
  '--copy[force copy of files (default)]' \
  '--copy-file-range[use copy_file_range]' \
  '--manifest-checksums=[manifest checksums]:algo:(NONE CRC32C SHA224 SHA256 SHA384 SHA512)' \
  '--no-manifest[do not write backup_manifest]' \
  '--sync-method=[sync method]:method:(fsync syncfs)' \
  '*:backup directories:_files -/' && ret=0
return ret
