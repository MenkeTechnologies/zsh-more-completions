#compdef edgedb
# Documentation: https://docs.geldata.com/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for EdgeDB / Gel CLI (the edgedb binary; project rebranded to Gel)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'database:manage databases'
  'branch:manage branches'
  'describe:describe database objects'
  'dump:create a database backup'
  'restore:restore a database backup'
  'configure:modify server configuration'
  'info:show information about an EdgeDB installation'
  'project:manage project'
  'instance:manage instances'
  'query:execute EdgeQL queries'
  'analyze:analyze query performance'
  'list:list database objects'
  'migrate:run migrations'
  'migration:manage migrations'
  'watch:watch for schema changes and apply migrations'
  'ui:open the web UI'
  'cloud:manage EdgeDB Cloud'
  'cli:manage the CLI'
  'server:install or list server versions'
)

_arguments -s -S \
  '(-I --instance)'{-I,--instance}'[instance name]:instance:' \
  '(-d --database)'{-d,--database}'[database name]:database:' \
  '--dsn[DSN for connection]:dsn:' \
  '--host[host]:host:_hosts' \
  '--port[port]:port:' \
  '--user[user]:user:' \
  '--password[prompt for password]' \
  '--password-from-stdin[read password from stdin]' \
  '--tls-ca-file[TLS CA certificate]:file:_files' \
  '--tls-security[TLS security mode]:mode:(default insecure no_host_verification strict)' \
  '--wait-until-available[wait for connection]:timeout:' \
  '--connect-timeout[connection timeout]:timeout:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'edgedb command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (query)
        _arguments \
          '--output-format[output format]:format:(json json-pretty tab-separated)' \
          '--file[read query from file]:file:_files' \
          '*:query:' && ret=0
        ;;
      (migrate|migration)
        local -a mig_cmds=(
          'apply:apply migrations'
          'create:create a migration'
          'edit:edit a migration'
          'log:show migration history'
          'status:show migration status'
        )
        _describe -t commands 'migration command' mig_cmds && ret=0
        ;;
      (instance)
        local -a inst_cmds=(
          'create:create an instance'
          'destroy:destroy an instance'
          'link:link a remote instance'
          'list:list instances'
          'logs:show instance logs'
          'restart:restart an instance'
          'revert:revert to a previous version'
          'start:start an instance'
          'status:show instance status'
          'stop:stop an instance'
          'unlink:unlink a remote instance'
          'upgrade:upgrade an instance'
          'credentials:show instance credentials'
        )
        _describe -t commands 'instance command' inst_cmds && ret=0
        ;;
      (project)
        local -a proj_cmds=(
          'info:show project info'
          'init:initialize a project'
          'unlink:unlink project'
          'upgrade:upgrade project'
        )
        _describe -t commands 'project command' proj_cmds && ret=0
        ;;
      (branch)
        local -a br_cmds=(
          'create:create a branch'
          'drop:drop a branch'
          'list:list branches'
          'switch:switch current branch'
          'merge:merge a branch'
          'rebase:rebase a branch'
          'wipe:wipe a branch'
          'current:show current branch'
        )
        _describe -t commands 'branch command' br_cmds && ret=0
        ;;
      (cloud)
        local -a cloud_cmds=(
          'login:log in to EdgeDB Cloud'
          'logout:log out of EdgeDB Cloud'
          'secretkey:manage secret keys'
        )
        _describe -t commands 'cloud command' cloud_cmds && ret=0
        ;;
      (dump)
        _arguments \
          '--all[dump all databases]' \
          '--format[dump format]:format:(dir)' \
          '1:output file:_files' && ret=0
        ;;
      (restore)
        _arguments \
          '--all[restore all databases]' \
          '1:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
