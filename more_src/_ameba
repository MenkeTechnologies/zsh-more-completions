#compdef ameba
# Documentation: https://github.com/crystal-ameba/ameba/blob/master/src/ameba/cli/cmd.cr
# Ameba code style linter for Crystal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-r --rules)'{-r,--rules}'[show all available rules]' \
  '(-R --rule-versions)'{-R,--rule-versions}'[show all available rule versions]' \
  '(-s --silent)'{-s,--silent}'[disable output]' \
  '(-c --config)'{-c,--config}'[specify a configuration file]:config:_files' \
  '(-u --up-to-version)'{-u,--up-to-version}'[choose a version]:version:' \
  '(-f --format)'{-f,--format}'[choose an output formatter]:formatter:(progress dot flycheck json todo)' \
  '--only[run only given rules or groups]:rules:' \
  '--except[disable the given rules or groups]:rules:' \
  '--all[enable all available rules]' \
  '--fix[autocorrect issues]' \
  '--gen-config[generate a configuration file acting as a TODO list]' \
  '--min-severity[minimum severity of issues to report]:severity:(error warning convention)' \
  '(-e --explain)'{-e,--explain}'[explain an issue at a specified location]:location:' \
  '(-d --describe)'{-d,--describe}'[describe a rule with specified name]:rule:' \
  '--without-affected-code[stop showing affected code in default formatter]' \
  '--ignore-unmatched-paths[do not report unmatched path patterns]' \
  '--ignore-config[ignore the config file]' \
  '--no-color[disable colors]' \
  '--stdin-filename[read source from STDIN]:filename:_files' \
  '*:file:_files' && ret=0

return ret
