#compdef nri-flex
# Documentation: https://man.archlinux.org/search?q=nri-flex
# Reference accessed: 2026-05-16

# nri-flex: New Relic flex integration (config-driven)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-config_file=[config file]:file:_files' \
  '--config_file=[config file]:file:_files' \
  '-verbose[verbose]' \
  '--verbose[verbose]' \
  '-pretty[pretty output]' \
  '-show_version[show version]' \
  '*::nri-flex args:_files' && ret=0
return ret
