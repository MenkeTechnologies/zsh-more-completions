#compdef nri-flex
# Documentation: https://github.com/newrelic/nri-flex
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above (internal/load/load.go
# ArgumentList struct). Struct tags map to lowercase snake_case flags.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-verbose[print more information to logs]' \
  '-pretty[print pretty formatted JSON]' \
  '-metrics[publish metrics data]' \
  '-inventory[publish inventory data]' \
  '-events[publish events data]' \
  '-metadata[add customer-defined key-value attributes]' \
  '-nri_add_hostname[add hostname attribute to the samples]' \
  '-nri_cluster=[cluster name]:cluster:' \
  '-nri_service=[service name]:service:' \
  '-temp_dir=[temporal data dir]:dir:_files -/' \
  '-config_path=[Flex configuration path]:path:_files -/' \
  '-config_file=[Flex configuration file]:file:_files' \
  '-local[run locally rather than infra-agent]' \
  '-force_log_event[force log event creation]' \
  '-container_discovery[enable container discovery]' \
  '-event_limit=[event limit]:n:' \
  '*::nri-flex args:_files' && ret=0
return ret
