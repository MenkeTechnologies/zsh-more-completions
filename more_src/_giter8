#compdef giter8 g8
# _giter8 — Eugene Yokota giter8 Scala/Java project template CLI alias (foundweekends team, Scala); custom argparse
# upstream: https://github.com/foundweekends/giter8

_giter8() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--list[list templates]' \
        '-l[list templates]' \
        '--force[force overwrite]' \
        '-f[force overwrite]' \
        '--branch=+[branch or tag]:str:' \
        '-b+[branch or tag]:str:' \
        '--tag=+[tag]:str:' \
        '-t+[tag]:str:' \
        '--directory=+[target dir]:dir:_files -/' \
        '-d+[target dir]:dir:_files -/' \
        '-o+[target dir]:dir:_files -/' \
        '--out=+[target dir]:dir:_files -/' \
        '--clean[run with clean cache]' \
        '-c[run with clean cache]' \
        '--no-interaction[non interactive]' \
        '-n[non interactive]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--name=+[project name]:str:' \
        '--organization=+[organization]:str:' \
        '--package=+[package]:str:' \
        '--scala-version=+[scala version]:str:' \
        '--sbt-version=+[sbt version]:str:' \
        '*:template:'
}

_giter8 "$@"
