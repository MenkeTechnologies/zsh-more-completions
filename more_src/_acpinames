#compdef acpinames
# Documentation: acpinames
# Source: acpica/acpica source/tools/acpinames/anmain.c — load and display ACPI namespace (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-\?[show help]' \
    '-l[load namespace only, no display]' \
    '-v[show version]' \
    '-x+[debug output level]:level:_default' \
    '*:ACPI table file:_files -g "*.{aml,dat}"' \
    && ret=0

return ret
