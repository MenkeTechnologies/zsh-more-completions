#   Binary     : devalang  (Cargo.toml [[bin]] required-features=["cli"])
#   Last push  : 2026-05-27
#
# WHAT IT IS
#   Devalang is "a domain-specific language (DSL) for sound designers and
#   music hackers — compose, automate, and control sound in plain text"
#   — Labscend Studios's text-first music programming language and the
#   `devalang` CLI tool that builds `.deva` source files into audio assets
#   (wav / mp3 / mid) using a `rodio`-backed audio engine, drives the
#   audio engine in live-mode with `notify`-based file watching + crossfade,
#   manages reusable banks/plugins/presets/templates through a remote
#   addon registry, captures live MIDI input via `midir` and `midly` into
#   `.deva` source, and embeds `wasmtime` for sandboxed plugin execution.
#   The toolchain doubles as a WASM-compiled npm-distributable package so
#   the same `.deva` files can be played from the browser.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/rust/tools/cli/mod.rs Cli/Commands
#                       clap-derive enum + each commands/*/mod.rs struct)
#   devalang <command> [subcommand] [options]
#
#   Commands:
#     play        Build and play .deva file(s)
#       --input <FILE>                 entry track or project file
#       --output <DIR>                 output directory for assets
#       --format <FMT>                 wav | mp3 | mid (AudioFormat enum)
#       --bit-depth <BITS>             PCM bit depth (AudioBitDepth enum)
#       --channels <CH>                mono | stereo (AudioChannels enum)
#       --sample-rate <HZ>             override sample rate
#       --resample-quality <Q>         resampling strategy (ResampleQuality)
#       --live                         live mode with watch + crossfade
#       --crossfade-ms <MS>            crossfade duration in ms
#       --quiet                        mute audio output
#       --volume <0..1>                volume level
#       --no-rule                      disable rule checking during playback
#
#     init        Initialize a new project
#       -n, --name <NAME>              project name (or use cwd if absent)
#       -t, --template <T>             template: default | basic | advanced
#                                                       [default: default]
#
#     build       Builds .deva file(s)
#       --path <PATH>                  path to .deva file       [default ./]
#       --formats <FMT>...             output formats; space-delim list
#                                      (overrides config: e.g. wav mid mp3)
#       --no-rule                      disable rule checking during build
#
#     check       Check syntax without building
#       -e, --entry <FILE|DIR>         entry file or directory
#                                                       [default ./examples]
#       -w, --watch                    watch & re-check on changes
#       -d, --debug                    enable debug output (lexer/parser)
#       --no-rule                      disable rule checking
#
#     addon       Manages addons (install/update/remove/list/discover)
#       install <NAME>                 install named addon
#         -l, --local                  install from local .deva dir
#       remove <NAME>                  remove named addon
#       list                           list installed addons
#       discover [SEARCH]              search the addon registry
#         -t, --addon-type <TYPE>      bank | plugin | preset | template
#         -a, --author <AUTHOR>        filter by author
#         -l, --local                  discover local .deva addons
#         -i, --install                prompt to install discovered addons
#       update <NAME>                  update named addon
#       metadata <NAME>                show addon metadata
#
#     login [TOKEN]   Authenticate with Devalang token (prompts if absent)
#     logout          Log out from Devalang
#     me              Check authentication status
#     telemetry { enable | disable | status }
#                     Manage telemetry settings
#
#     devices     Manage MIDI devices
#       list                           list available MIDI devices
#       preview [--port <N>]           preview incoming/outgoing notes
#       write --out <FILE> [OPTS...]   record incoming notes to .deva
#         --mode <synth|pattern>       recording mode      [default: synth]
#         --synth-name <NAME>          variable name       [default: mySynth]
#         --waveform <WF>              synth waveform      [default: saw]
#         --pattern-name <NAME>        pattern var name    [default: myPattern]
#         --port <N>                   MIDI port index (default all)
#         --step <FRAC>                step duration       [default: 1/16]
#         --bpm <BPM>                  tempo               [default: 120.0]
#         --group <GROUP>              insert into named group (synth mode)
#         --trigger <TRIG>             trigger name (pattern mode)
#         --live                       update file during recording
#         --debug                      enable debug output
#         --rewrite                    rewrite file from scratch (live)
#         --velocity-zero-as-rest      treat velocity 0 as rest [default true]
#
# AXIS / CORPUS POSITION
#   Direct dependency on `midir = "..."` declared as a `[features].cli` dep
#   in Cargo.toml — the canonical Rust cross-platform MIDI I/O library
#   (Boddlnagg/midir).  midir wraps platform MIDI APIs (ALSA RawMidi on
#   Linux, CoreMIDI on macOS, WinMM/WinRT MIDI on Windows) behind a
#   unified Rust API.  Devalang's `devices` subcommand opens MIDI input
#   ports via midir to capture played notes and rewrite them into `.deva`
#   source.  Verified via:
#     gh api repos/devaloop-labs/devalang/contents/Cargo.toml
#       → [features] cli = ["...", "dep:midir", ...]
#       → src/rust/tools/cli/commands/devices.rs uses midir::MidiInput
#   This entry is the Rust=118 leader bump that OPENS Axis 63
#   (MIDI I/O Library), pairing with future Go=gomidi/midi and
#   TS-Node=jzz poles to close the axis at 1/1/1.
#
#   No completion for `devalang` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_devalang() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_devalang_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                play)         _devalang_play       && ret=0 ;;
                init)         _devalang_init       && ret=0 ;;
                build)        _devalang_build      && ret=0 ;;
                check)        _devalang_check      && ret=0 ;;
                addon)        _devalang_addon      && ret=0 ;;
                login)        _arguments '(- *)'{-h,--help}'[help for login]' ':token:' && ret=0 ;;
                logout)       _arguments '(- *)'{-h,--help}'[help for logout]' && ret=0 ;;
                me)           _arguments '(- *)'{-h,--help}'[help for me]' && ret=0 ;;
                telemetry)    _devalang_telemetry  && ret=0 ;;
                devices)      _devalang_devices    && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_devalang_commands] )) ||
_devalang_commands() {
    local -a commands
    commands=(
        'play:build and play .deva file(s)'
        'init:initialize a new Devalang project'
        'build:build .deva file(s) to audio assets'
        'check:check syntax without building'
        'addon:manage addons (install/update/remove/list/discover)'
        'login:authenticate with Devalang token'
        'logout:log out from Devalang'
        'me:check authentication status'
        'telemetry:manage telemetry settings'
        'devices:manage MIDI devices (list/preview/write)'
    )
    _describe -t commands 'devalang command' commands
}

(( $+functions[_devalang_play] )) ||
_devalang_play() {
    _arguments \
        '--input=[entry track or project file]:file:_files -g "*.(deva|toml)"' \
        '--output=[output directory for generated assets]:dir:_files -/' \
        '--format=[preferred output format]:format:(wav mp3 mid)' \
        '--bit-depth=[PCM bit depth]:bits:(16 24 32)' \
        '--channels=[channel count]:channels:(mono stereo)' \
        '--sample-rate=[override sample rate]:hz:' \
        '--resample-quality=[resampling quality]:quality:(low medium high)' \
        '--live[live mode with watch + crossfade]' \
        '--crossfade-ms=[crossfade duration (ms)]:ms:' \
        '--quiet[mute the audio output]' \
        '--volume=[volume level (0.0 to 1.0)]:volume:' \
        '--no-rule[disable rule checking during playback]' \
        '(- *)'{-h,--help}'[help for play]'
}

(( $+functions[_devalang_init] )) ||
_devalang_init() {
    _arguments \
        '(-n --name)'{-n+,--name=}'[project name (or use cwd if absent)]:name:' \
        '(-t --template)'{-t+,--template=}'[project template (default: default)]:template:(default basic advanced)' \
        '(- *)'{-h,--help}'[help for init]'
}

(( $+functions[_devalang_build] )) ||
_devalang_build() {
    _arguments \
        '--path=[path to .deva file (default ./)]:path:_files -g "*.deva"' \
        '*--formats=[output formats (space-delim list)]:formats:(wav mid mp3)' \
        '--no-rule[disable rule checking during build]' \
        '(- *)'{-h,--help}'[help for build]'
}

(( $+functions[_devalang_check] )) ||
_devalang_check() {
    _arguments \
        '(-e --entry)'{-e+,--entry=}'[entry file or directory to check (default ./examples)]:file or dir:_files' \
        '(-w --watch)'{-w,--watch}'[watch for changes and re-check]' \
        '(-d --debug)'{-d,--debug}'[enable debug output (lexer, parser logs)]' \
        '--no-rule[disable rule checking during validation]' \
        '(- *)'{-h,--help}'[help for check]'
}

(( $+functions[_devalang_addon] )) ||
_devalang_addon() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_devalang_addon_commands' \
        '*::arg:->aargs' && ret=0

    case $state in
        aargs)
            case $words[1] in
                install)
                    _arguments \
                        '(-l --local)'{-l,--local}'[install from local .deva directory]' \
                        ':addon name:' && ret=0 ;;
                remove|update|metadata)
                    _arguments ':addon name:' && ret=0 ;;
                list)
                    _arguments '(- *)'{-h,--help}'[help for list]' && ret=0 ;;
                discover)
                    _arguments \
                        '(-t --addon-type)'{-t+,--addon-type=}'[filter by addon type]:type:(bank plugin preset template)' \
                        '(-a --author)'{-a+,--author=}'[filter by author]:author:' \
                        '(-l --local)'{-l,--local}'[discover local addons in .deva directory]' \
                        '(-i --install)'{-i,--install}'[prompt to install discovered addons]' \
                        ':search term:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_devalang_addon_commands] )) ||
_devalang_addon_commands() {
    local -a commands
    commands=(
        'install:install an addon (use -l for local)'
        'remove:remove an installed addon'
        'list:list installed addons'
        'discover:search the addon registry'
        'update:update an installed addon'
        'metadata:show metadata for an addon'
    )
    _describe -t commands 'devalang addon command' commands
}

(( $+functions[_devalang_telemetry] )) ||
_devalang_telemetry() {
    _arguments \
        '1: :((enable\:enable\ telemetry disable\:disable\ telemetry status\:show\ telemetry\ status))'
}

(( $+functions[_devalang_devices] )) ||
_devalang_devices() {
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
        '1: :_devalang_devices_commands' \
        '*::arg:->dargs' && ret=0

    case $state in
        dargs)
            case $words[1] in
                list)
                    _arguments '(- *)'{-h,--help}'[help for list]' && ret=0 ;;
                preview)
                    _arguments \
                        '--port=[MIDI port index]:port:' \
                        '(- *)'{-h,--help}'[help for preview]' && ret=0 ;;
                write)
                    _arguments \
                        '--out=[output file path (REQUIRED)]:output file:_files -g "*.deva"' \
                        '--mode=[recording mode (default synth)]:mode:(synth pattern)' \
                        '--synth-name=[synth variable name (default mySynth)]:name:' \
                        '--waveform=[synth waveform (default saw)]:waveform:(saw square sine triangle)' \
                        '--pattern-name=[pattern variable name (default myPattern)]:name:' \
                        '--port=[MIDI port index (default all)]:port:' \
                        '--step=[step duration fraction (default 1/16)]:step:(1/4 1/8 1/16 1/32)' \
                        '--bpm=[tempo in BPM (default 120.0)]:bpm:' \
                        '--group=[group name to insert notes into (synth mode)]:group:' \
                        '--trigger=[trigger name (pattern mode, e.g. myBank.kick)]:trigger:' \
                        '--live[update file during recording (live writing)]' \
                        '--debug[enable debug output]' \
                        '--rewrite[rewrite file from scratch (live mode)]' \
                        '--velocity-zero-as-rest=[treat velocity 0 as rest (default true)]:flag:(true false)' \
                        '(- *)'{-h,--help}'[help for write]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_devalang_devices_commands] )) ||
_devalang_devices_commands() {
    local -a commands
    commands=(
        'list:list available MIDI devices'
        'preview:preview incoming/outgoing notes (non-writing)'
        'write:record incoming notes and write to a .deva file'
    )
    _describe -t commands 'devalang devices command' commands
}

_devalang "$@"
