#compdef xmonad

# Zsh completion for xmonad - tiling window manager

_arguments -s -S \
  '--help[show help]' \
  '--version[show version information]' \
  '--verbose-version[show detailed build information]' \
  '--recompile[recompile xmonad configuration]' \
  '--restart[restart a running xmonad]' \
  '--replace[replace the currently running window manager]'
