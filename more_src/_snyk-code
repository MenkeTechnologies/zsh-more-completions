#compdef snyk-code
# _snyk-code — Snyk static code analysis (SAST) subcommand alias (Snyk, TypeScript); commander
# upstream: https://github.com/snyk/cli

_snyk-code() {
    local -a sub=(
        'test:run code analysis'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '--json-file-output=+[json file output]:file:_files' \
        '--sarif[sarif output]' \
        '--sarif-file-output=+[sarif file output]:file:_files' \
        '--severity-threshold=+[severity threshold]:t:(low medium high critical)' \
        '--fail-on=+[fail on]:t:(all upgradable patchable)' \
        '--org=+[organization]:org:' \
        '--report[report results]' \
        '--target-name=+[target name]:str:' \
        '--target-reference=+[target reference]:str:' \
        '--remote-repo-url=+[remote repo url]:url:_urls' \
        '--project-name=+[project name]:str:' \
        '--exclude=+[exclude]:list:' \
        '--include=+[include]:list:' \
        '--legacy[use legacy engine]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snyk code subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '*:path:_files' ;;
            esac
            ;;
    esac
}

_snyk-code "$@"
