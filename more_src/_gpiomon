#compdef gpiomon
# _gpiomon — Bartosz Golaszewski libgpiod gpiomon CLI for watching GPIO lines for edge events rising falling both with optional bias active-low bias pull-up pull-down event-count output JSON format (linux team, C); getopt
# upstream: https://git.kernel.org/pub/scm/libs/libgpiod/libgpiod.git

_gpiomon() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-l[active low]' \
        '--active-low[active low]' \
        '-B+[bias]:b:(as-is disable pull-down pull-up)' \
        '--bias=+[bias]:b:(as-is disable pull-down pull-up)' \
        '-n+[num-events]:n:' \
        '--num-events=+[num-events]:n:' \
        '-s[silent]' \
        '--silent[silent]' \
        '-r[rising edge]' \
        '--rising-edge[rising edge]' \
        '-f[falling edge]' \
        '--falling-edge[falling edge]' \
        '-F+[format]:f:(default json csv)' \
        '--format=+[format]:f:(default json csv)' \
        '*:chip line:'
}

_gpiomon "$@"
