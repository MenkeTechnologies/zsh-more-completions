#compdef clippy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-W+[set lint level to warn]:lint:' \
  '-A+[set lint level to allow]:lint:' \
  '-D+[set lint level to deny]:lint:' \
  '-F+[set lint level to forbid]:lint:' \
  '--fix[automatically apply suggestions]' \
  '--allow-dirty[allow dirty working directory with --fix]' \
  '--allow-staged[allow staged changes with --fix]' \
  '--allow-no-vcs[allow no VCS with --fix]' \
  '--no-deps[do not lint dependencies]' \
  '-p+[package to check]:package:' \
  '--package=[package to check]:package:' \
  '--all[check all packages in workspace]' \
  '--workspace[check all packages in workspace]' \
  '--lib[check only the library target]' \
  '--bins[check all binary targets]' \
  '--bin=[check specified binary]:binary:' \
  '--examples[check all example targets]' \
  '--example=[check specified example]:example:' \
  '--tests[check all test targets]' \
  '--test=[check specified test]:test:' \
  '--benches[check all bench targets]' \
  '--bench=[check specified bench]:bench:' \
  '--all-targets[check all targets]' \
  '--features=[space or comma separated features]:features:' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '--target=[target triple]:target:' \
  '--release[check in release mode]' \
  '--profile=[check with specified profile]:profile:(dev release test bench)' \
  '-j+[number of parallel jobs]:jobs:' \
  '--jobs=[number of parallel jobs]:jobs:' \
  '--message-format=[message format]:format:(human-readable short json)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '--color=[coloring]:when:(auto always never)' \
  '*:path:_files' && ret=0

return ret
