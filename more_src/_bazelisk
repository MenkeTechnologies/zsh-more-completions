#compdef bazelisk

# Zsh completion for bazelisk - a user-friendly launcher for Bazel

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build targets'
  'test:build and run tests'
  'run:run a binary target'
  'clean:remove build outputs'
  'query:query the build graph'
  'cquery:configured query'
  'aquery:action query'
  'info:show info about bazel and workspace'
  'version:show bazel version'
  'shutdown:stop the Bazel server'
  'fetch:fetch external dependencies'
  'sync:synchronize the workspace'
  'mod:Bzlmod operations'
  'coverage:generate code coverage reports'
  'dump:dump internal state of bazel'
  'help:show help'
  'analyze-profile:analyze a build profile'
  'config:view configuration fragments'
  'canonicalize-flags:canonicalize flags'
  'print_action:print action graph info'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show version]' \
  '--strict[exit with error if USE_BAZEL_VERSION is not set]' \
  '--migrate[migrate to a new version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'bazel command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (build|test|run|query|cquery|aquery|coverage)
        _arguments \
          '--config=[build config]:config:' \
          '--keep_going[keep going after errors]' \
          '--jobs=[number of parallel jobs]:n:' \
          '--verbose_failures[show full command lines]' \
          '--sandbox_debug[keep sandbox around on failure]' \
          '--compilation_mode=[compilation mode]:mode:(fastbuild opt dbg)' \
          '*:target:' && ret=0
        ;;
      (clean)
        _arguments '--expunge[remove the entire working tree]' && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
