#compdef validator

# Boeing/config-file-validator/v2 cmd/validator/validator.go (flag); Homebrew: Formula/c/config-file-validator.rb

local ret=1
_arguments -s \
  '-depth=[recursion depth (0 disables recurse)]:depth:' \
  '-exclude-dirs=[comma-separated dirs to skip]:dirs:' \
  '-exclude-file-types=[comma-separated types to ignore]:types:' \
  '-file-types=[comma-separated types to validate]:types:' \
  '-globbing[enable glob patterns in search paths]' \
  '-reporter=[reporter format:path]:reporter:(standard json junit sarif)' \
  '-version[print version]' \
  '-group-output=[grouping mode]:mode:' \
  '-quiet[quiet output]' \
  '-require-schema[require JSON/YAML schema]' \
  '-no-schema[skip schema validation]' \
  '-type-map=[override file type mapping]:map:' \
  '-schema-map=[path to schema map]:map:' \
  '-schema-store[use schemastore.org]' \
  '-schema-store-path=[path to schema store]:path:_files -/' \
  '-config=[validator config file]:config:_files' \
  '-no-config[ignore config file]' \
  '-gitignore[honor .gitignore]' \
  '*::search path:_files -/' && ret=0
return ret
