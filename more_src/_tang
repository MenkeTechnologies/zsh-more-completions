#compdef tang tangd

# Tang: HTTP-based key escrow server (clevis tang pin endpoint)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-l[listen address]:address:' \
  '-p[listen port]:port:' \
  '-D[directory of advertisement keys]:dir:_files -/' \
  '-d[directory of advertisement keys]:dir:_files -/' \
  '*::extra args:_files' && ret=0
return ret
