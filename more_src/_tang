#compdef tang tangd
# Documentation: https://github.com/latchset/tang/blob/master/src/tangd.c
# Reference accessed: 2026-05-21
# Verified: upstream src/tangd.c getopt_long "lp:e:vh".

# tang/tangd: HTTP-based key escrow server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-p --port)'{-p,--port}'=[listening port (default 9090)]:port:' \
  '(-e --endpoint)'{-e,--endpoint}'=[endpoint to listen on]:endpoint:' \
  '(-l --listen)'{-l,--listen}'[run as standalone service]' \
  '*:JWK directory:_files -/' && ret=0
return ret
