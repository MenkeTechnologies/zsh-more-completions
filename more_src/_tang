#compdef tang

# tang: server-side daemon for the Network-Bound Disk Encryption (NBDE) protocol
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[server keys directory (default /var/db/tang)]:dir:_files -/' \
  '-l[only listen on localhost]' \
  '-p[TCP port to listen on]:port:' \
  '*::tang args (typically launched by tangd-update / tangd@.service):_files' && ret=0
return ret
