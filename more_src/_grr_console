#compdef grr_console
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/grr_console.1.html
# GRR Rapid Response server console

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '--verbose[turn on verbose logging]' \
  '--debug[break in debugger on unhandled exception]' \
  '--config=[primary configuration file]:file:_files' \
  '--secondary_configs=[secondary config files]:files:_files' \
  '--config_help[print config help]' \
  '--context=[config contexts]:context' \
  '--plugins=[additional plugin files]:files:_files' \
  '--disallow_missing_config_definitions[error on undefined config options]' \
  '(-p --parameter)'{-p,--parameter}'=[global config override]:param' \
  '--list_storage[list storage subsystems]' \
  '--local_client[target clients run locally]' \
  '--local_worker[run with a local worker]' \
  '--client_ids=[client IDs for testing]:ids' \
  '--hostnames=[client hostnames for testing]:hostnames' \
  '--testnames=[which tests to run]:tests' \
  '--client=[initialise console with client id]:client id' \
  '--reason=[access reason for default token]:reason' \
  '--code_to_execute=[execute code non-interactively]:code' \
  '--command_file=[supply code from file]:file:_files' \
  '--exit_on_complete[exit after code execution]' && ret=0

return ret
