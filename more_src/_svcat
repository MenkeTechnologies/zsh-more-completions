#compdef svcat
# Documentation: https://github.com/kubernetes-sigs/service-catalog/blob/master/docs/cli.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: kubernetes-sigs/service-catalog was archived on 2022-05-06. The
# completion reflects the last-documented svcat command surface.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
  'register:register a broker'
  'deregister:remove a broker from the cluster'
  'get:list resources (brokers, classes, instances, bindings, plans)'
  'describe:describe a resource'
  'provision:provision a new instance'
  'deprovision:delete an instance'
  'bind:create a binding to an instance'
  'unbind:remove binding(s) from an instance'
  'sync:trigger a catalog resync'
  'marketplace:view services offered'
  'install:install svcat as a kubectl plugin'
  'touch:force update of a resource'
  'version:print version'
  'completion:generate shell completion script'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--v=[log level]:level:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds) _describe -t commands 'svcat command' cmds && ret=0 ;;
  args) _default && ret=0 ;;
esac

return ret
