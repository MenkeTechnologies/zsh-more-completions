#compdef svcat

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'get:list brokers, classes, instances, bindings'
      'describe:describe a resources'
      'provision:provision a new instance'
      'bind:create binding credentials'
      'unbind:delete binding'
      'deprovision:delete instance'
      'sync:relist broker catalog'
      'version:print version'
    )
    _describe -t commands 'svcat command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
