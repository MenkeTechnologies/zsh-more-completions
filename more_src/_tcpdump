#compdef tcpdump
# Documentation: man 8 tcpdump (man7.org)
# Reference accessed: 2026-05-29
# Network packet analyzer.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-i+[network interface to listen on]:iface:_net_interfaces' \
  '-c+[exit after capturing N packets]:count:' \
  '-w+[write raw packets to file]:file:_files' \
  '-r+[read packets from saved capture file]:file:_files -g "*.(pcap|pcapng|cap)"' \
  '-n[do not resolve addresses to names]' \
  '-nn[do not resolve addresses or service names]' \
  '*-v[verbose output]' \
  '-e[display link-level header on each line]' \
  '-x[print packet data in hex]' \
  '-xx[print packet data in hex including link layer]' \
  '-X[print packet data in hex and ASCII]' \
  '-XX[print hex+ASCII including link layer]' \
  '-A[display packets in ASCII]' \
  '-s+[snapshot length (bytes; 0 = full packet)]:bytes:' \
  '-t[suppress timestamp]' \
  '-tt[timestamps as seconds since epoch]' \
  '-ttt[time delta between current and previous packet]' \
  '-tttt[full timestamp with date]' \
  '-ttttt[delta from first packet]' \
  '-S[show absolute TCP sequence numbers]' \
  '-q[quick output with less info]' \
  '(- *)-D[list available network interfaces]' \
  '--list-interfaces[list available network interfaces]' \
  '-L[display known data link types for interface]' \
  '--list-time-stamp-types[list time-stamp types]' \
  '-K[skip checksum verification (IP/TCP/UDP)]' \
  '-p[disable promiscuous mode]' \
  '-l[line-buffer stdout]' \
  '-U[packet-buffer output]' \
  '-F+[read filter expression from file]:file:_files' \
  '-d[dump compiled packet-matching code]' \
  '-dd[dump as C program fragment]' \
  '-ddd[dump as decimal numbers]' \
  '-G+[rotate dump file at interval (seconds)]:seconds:' \
  '-C+[rotate savefile at size (millions of bytes)]:MB:' \
  '-W+[max number of savefiles]:n:' \
  '-z+[run command after file rotation]:command:_command_names -e' \
  '-Z+[change user ID after opening capture device]:user:_users' \
  '-j+[timestamp type]:type:(host host_lowprec host_hiprec adapter adapter_unsynced)' \
  '-I[enable monitor mode (Wi-Fi)]' \
  '-B+[OS capture buffer size (KiB)]:kib:' \
  '-T+[force packet interpretation as type]:type:(aodv carp cnfp domain lmp pgm pgm_zmtp1 ptp radius resp rpc rtcp rtp snmp someip tftp vat vxlan vxlan-gpe wb zmtp1)' \
  '-Q+[direction]:direction:(in out inout)' \
  '-M+[validate TCP-MD5 signatures via shared secret]:secret:' \
  '-y+[data link type]:dlt:' \
  '--immediate-mode[deliver packets as they arrive]' \
  '--time-stamp-precision=[time stamp precision]:precision:(micro nano)' \
  '--micro[short for --time-stamp-precision=micro]' \
  '--nano[short for --time-stamp-precision=nano]' \
  '--print[print parsed packet even with -w]' \
  '--no-promiscuous-mode[disable promiscuous mode]' \
  '*:expression:' && ret=0

return ret
