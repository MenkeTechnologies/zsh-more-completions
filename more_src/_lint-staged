#compdef lint-staged

# Zsh completion for lint-staged - Run linters on staged git files

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--allow-empty[allow empty commits]' \
  '--concurrent=[number of concurrent tasks]:concurrency:(true false 1 2 3 4 5 6 7 8)' \
  '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
  '--cwd=[working directory]:directory:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '--diff=[override diff used to detect staged files]:diff' \
  '--diff-filter=[override diff filter]:filter' \
  '--max-arg-length=[maximum argument string length]:length' \
  '--no-stash[disable stashing of unstaged files]' \
  '(-q --quiet)'{-q,--quiet}'[suppress lint-staged output]' \
  '--relative[pass relative file paths]' \
  '(-x --shell)'{-x,--shell}'[shell to use for scripts]:shell path:_files' \
  '(-v --verbose)'{-v,--verbose}'[show task output]'
