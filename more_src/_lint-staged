#compdef lint-staged
# Documentation: https://github.com/lint-staged/lint-staged
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: prior file had `--concurrent` without short form (real short is `-p`),
# `(-x --shell)` (not in upstream README), and missed --continue-on-error,
# --fail-on-changes, --no-hide-partially-staged, --hide-unstaged, --hide-all,
# --no-revert.

# Zsh completion for lint-staged - Run linters on staged git files

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--allow-empty[allow empty commits when tasks revert all staged changes]' \
  '(-p --concurrent)'{-p,--concurrent}'=[number of concurrent tasks or false for serial]:concurrency:(true false 1 2 3 4 5 6 7 8)' \
  '(-c --config)'{-c,--config}'=[path to config file or - for stdin]:config file:_files' \
  '--continue-on-error[run all tasks to completion even if one fails]' \
  '--cwd=[run all tasks in a specific directory]:directory:_directories' \
  '(-d --debug)'{-d,--debug}'[print additional debug information]' \
  '--diff=[override default --staged flag of git diff]:diff' \
  '--diff-filter=[override default --diff-filter=ACMR flag]:filter' \
  '--fail-on-changes[fail with exit code 1 when tasks modify tracked files]' \
  '--no-hide-partially-staged[show unstaged changes from partially staged files]' \
  '--hide-unstaged[hide all unstaged changes in tracked files]' \
  '--hide-all[hide all unstaged changes and untracked files]' \
  '--max-arg-length=[maximum length of command-line argument string]:length' \
  '--no-revert[do not revert to original state on errors]' \
  '--no-stash[disable the backup stash]' \
  '(-q --quiet)'{-q,--quiet}'[disable lint-staged console output]' \
  '(-r --relative)'{-r,--relative}'[pass relative file paths to tasks]' \
  '(-v --verbose)'{-v,--verbose}'[show task output even when tasks succeed]'
