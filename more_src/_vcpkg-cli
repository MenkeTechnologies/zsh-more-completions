#compdef vcpkg-cli
# _vcpkg-cli — Microsoft vcpkg C++ library manager CLI alias (Microsoft, C++); custom argparse
# upstream: https://github.com/microsoft/vcpkg

_vcpkg-cli() {
    local -a sub=(
        'autocomplete:generate completion'
        'install:install packages'
        'remove:remove installed packages'
        'list:list installed packages'
        'search:search for packages'
        'integrate:user-wide integration'
        'depend-info:print package deps'
        'env:print environment for given triplet'
        'export:export installed packages'
        'fetch:fetch a tool'
        'hash:compute file hash'
        'help:show help'
        'owns:locate which port owns a file'
        'portsdiff:diff ports baseline'
        'update:list outdated packages'
        'upgrade:upgrade installed packages'
        'version:show version'
        'x-add-version:add new version to baseline'
        'x-build-external:build external port'
        'x-history:show port history'
        'x-init-registry:init custom registry'
        'x-package-info:show package info'
        'x-vsinstances:list VS instances'
        'z-applocal:fix DLL deps for app local deployment'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--triplet=+[triplet]:str:' \
        '--host-triplet=+[host triplet]:str:' \
        '--vcpkg-root=+[vcpkg root]:dir:_files -/' \
        '--x-buildtrees-root=+[buildtrees root]:dir:_files -/' \
        '--x-downloads-root=+[downloads root]:dir:_files -/' \
        '--x-install-root=+[install root]:dir:_files -/' \
        '--x-packages-root=+[packages root]:dir:_files -/' \
        '--feature-flags=+[feature flags]:list:' \
        '--overlay-ports=+[overlay ports]:list:_files -/' \
        '--overlay-triplets=+[overlay triplets]:list:_files -/' \
        '--binarysource=+[binary source]:list:' \
        '--clean-after-build[clean after build]' \
        '--clean-buildtrees-after-build[clean buildtrees after build]' \
        '--clean-downloads-after-build[clean downloads after build]' \
        '--clean-packages-after-build[clean packages after build]' \
        '--no-print-usage[no print usage]' \
        '--keep-going[keep going]' \
        '--x-no-default-features[no default features]' \
        '--allow-unsupported[allow unsupported]' \
        '--no-dry-run[no dry run]' \
        '--dry-run[dry run]' \
        '--recurse[recurse]' \
        '--debug[debug]' \
        '--debug-env[debug env]' \
        '--disable-metrics[disable metrics]' \
        '--printmetrics[print metrics]' \
        '--sendmetrics[send metrics]' \
        '--editable[editable]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vcpkg subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|upgrade|search|depend-info|owns) _arguments '*:package:' ;;
                integrate) _arguments \
                    '1:cmd:(install remove project bash zsh fish powershell powershell6 x-fish)' \
                    '*:arg:' ;;
                export) _arguments \
                    '--7zip[7zip archive]' \
                    '--nuget[nuget package]' \
                    '--nuget-id=+[nuget id]:str:' \
                    '--nuget-version=+[nuget version]:str:' \
                    '--zip[zip archive]' \
                    '--raw[raw export]' \
                    '--ifw[ifw export]' \
                    '--chocolatey[chocolatey]' \
                    '--prefab[prefab]' \
                    '--output=+[output dir]:dir:_files -/' \
                    '*:package:' ;;
                autocomplete) _arguments '1:shell:(bash zsh fish powershell)' ;;
                list|update|env|version|help) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_vcpkg-cli "$@"
