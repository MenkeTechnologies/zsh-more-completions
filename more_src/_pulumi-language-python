#compdef pulumi-language-python
# _pulumi-language-python — Pulumi language plugin for Python (pulumi/pulumi)
# upstream: https://github.com/pulumi/pulumi
# Flags from sdk/python/cmd/pulumi-language-python/main.go (flag).

_pulumi-language-python() {
    _arguments \
        '-version[print plugin version and exit]' \
        '-tracing=[Zipkin tracing endpoint]:endpoint:' \
        '-use-executor=[explicit Python executor command]:cmd:' \
        '1:engine address:'
}

_pulumi-language-python "$@"
