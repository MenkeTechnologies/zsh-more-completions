#compdef jfrog-cli artifactory-cli xray-cli

local curcontext="$curcontext" state line ret=1

(( $+functions[_jf] )) || autoload -Uz _jf 2>/dev/null
if (( $+functions[_jf] )); then
  _jf "$@"
  return
fi

local -a subcommands

subcommands=(
  'rt:Artifactory commands'
  'mc:Mission Control commands'
  'ds:Distribution commands'
  'xr:Xray commands'
  'pl:Pipelines commands'
  'config:configure JFrog platform connection'
  'login:authenticate'
  'logout:log out'
  'project:project commands'
  'audit:audit dependencies for vulnerabilities'
  'scan:scan local files/directories'
  'docker scan:scan a Docker image'
  'build-scan:scan a build'
  'curation-audit:curation audit'
  'dependency-tree:dependency tree'
  'enrich:enrich SBOM'
  'go:Go package management'
  'gradle:Gradle commands'
  'mvn:Maven commands'
  'npm:npm commands'
  'pip:pip commands'
  'pipenv:pipenv commands'
  'poetry:Poetry commands'
  'nuget:NuGet commands'
  'dotnet:.NET commands'
  'yarn:Yarn commands'
  'docker:Docker commands'
  'helm:Helm commands'
  'helm-chart:Helm chart commands'
  'rb:release bundle commands'
  'evd:evidence commands'
  'ci-setup:CI setup wizard'
  'completion:generate shell completion'
  'options:CLI options'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*--server-id=[server ID from config]:id:' \
  '*--user=[username]:user:_users' \
  '*--password=[password]:password:' \
  '*--access-token=[access token]:token:' \
  '*--insecure-tls[skip TLS verification]' \
  '*--ssh-key-path=[SSH key path]:file:_files' \
  '*--ssh-passphrase=[SSH passphrase]:passphrase:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'jfrog subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (rt)
        _values 'rt action' \
          'upload' 'download' 'copy' 'move' 'delete' 'search' 'set-props' \
          'delete-props' 'build-publish' 'build-collect-env' 'build-add-git' \
          'build-add-dependencies' 'build-promote' 'build-distribute' \
          'build-discard' 'build-scan' 'build-clean' 'build-status' \
          'config' 'use' 'ping' 'curl' 'access-token-create' \
          'docker-promote' 'go' 'go-publish' 'gradle' 'mvn' 'npm' 'nuget' \
          'pip' 'replication-create' 'replication-delete' 'replication-list' \
          'group-create' 'group-add-users' 'group-remove-users' 'group-delete' \
          'user-create' 'user-delete' 'permission-target-create' \
          'permission-target-delete' 'permission-target-list' \
          'permission-target-update' 'transfer-config' 'transfer-files' \
          'release-bundle-create' 'release-bundle-update' 'release-bundle-sign' \
          'release-bundle-distribute' 'release-bundle-delete' \
          'repository-create' 'repository-update' 'repository-delete' \
          'repository-list' 'repository-config' 'remote-repos-list' \
          'access-bundle-create' 'access-token-revoke' 'wb' 'gc' 'gpg' && ret=0
        ;;
      (xr)
        _values 'xr action' \
          'audit' 'audit-mvn' 'audit-gradle' 'audit-npm' 'audit-pip' \
          'audit-pipenv' 'audit-go' 'audit-nuget' 'audit-yarn' \
          'scan' 'docker-scan' 'build-scan' 'curl' 'offline-update' \
          'enable-watch' 'export-watches' 'import-watches' && ret=0
        ;;
      (config)
        _values 'config action' 'add' 'edit' 'show' 'remove' 'use' 'export' 'import' && ret=0
        ;;
      (rb)
        _values 'rb action' \
          'create' 'update' 'distribute' 'sign' 'delete' 'list' 'list-distributions' \
          'export' && ret=0
        ;;
      (project)
        _values 'project action' 'init' 'enrich' 'docker' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'fish' 'zsh' && ret=0
        ;;
    esac
    ;;
esac

return ret
