#compdef prow-checkconfig
# _prow-checkconfig — Prow validator for prow + .prow.yaml configuration (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/checkconfig/main.go (flag).

_prow-checkconfig() {
    _arguments \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-plugin-config=[plugin config file]:file:_files' \
        '-prow-yaml-repo-name=[name of repo whose .prow.yaml should be checked]:repo:' \
        '-prow-yaml-path=[path to the .prow.yaml file]:file:_files' \
        '*-warnings=[warning to validate (repeat)]:warning:' \
        '*-exclude-warning=[warning to exclude (repeat)]:warning:' \
        '*-required-job-annotations=[required job annotation (repeat)]:annotation:' \
        '-expensive-checks[enable expensive warnings]' \
        '-strict[treat all warnings as errors]' \
        '-include-default-warnings[force inclusion of default warning set]'
}

_prow-checkconfig "$@"
