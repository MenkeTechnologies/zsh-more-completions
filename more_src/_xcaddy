#compdef xcaddy

_xcaddy_cmds() {
    local -a commands=(
        'build:compile custom Caddy binary'
        'run:build and run Caddy'
        'adapt:adapt Caddy config to JSON'
        'list-modules:list available Caddy modules'
        'environ:print environment'
        'version:print version'
        'help:print help information'
    )
    _describe -t commands 'xcaddy command' commands
}

_xcaddy() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '1:command:_xcaddy_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                build)
                    _arguments \
                        '--output=[output file path]:file:_files' \
                        '*--with=[add module]:module-spec' \
                        '*--replace=[replace module]:replace-spec' \
                        '--debug[enable debug build]' \
                        '1:caddy-version'
                    ;;
                run)
                    _arguments \
                        '*--with=[add module]:module-spec' \
                        '*--replace=[replace module]:replace-spec' \
                        '--debug[enable debug build]' \
                        '*:caddy-args'
                    ;;
            esac
            ;;
    esac
}

_xcaddy "$@"
