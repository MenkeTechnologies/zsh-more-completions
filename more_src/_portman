# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/apideck-libraries/portman
#   Maintainer : Apideck Libraries
#   License    : Apache-2.0
#   Stars      : 681
#   Language   : TypeScript (Node.js)
#   Package    : @apideck/portman
#   Binary     : portman  (package.json bin: {"portman":
#                          "bin/portman"})
#   Last push  : 2026-05-23
#
# WHAT IT IS
#   Portman is "an OpenAPI-to-Postman converter that injects a
#   contract-/integration-test suite and runs it via Newman"
#   maintained by Apideck.  Point it at an OpenAPI 3.x spec (URL
#   or local file), and it parses the spec via
#   `@apidevtools/swagger-parser`, converts every operation into
#   a Postman request via `openapi-to-postmanv2`, layers
#   Portman's typed assertion DSL on top (variable assignments,
#   contract tests, integration tests, custom request/response
#   overrides), optionally syncs the generated collection to a
#   Postman workspace via the Postman API, and shells out to
#   Newman to actually execute the collection — yielding a full
#   spec-driven CI test pipeline from a single command.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/index.ts top-level
#                       `yargs.option(...)` chain — yargs 17.7;
#                       most flags have a single-char alias)
#   portman [OPTIONS]
#
#   Source-spec inputs:
#     -u, --url <URL>                URL of OpenAPI spec to port
#     -l, --local <PATH>             Local OpenAPI spec to port
#     -b, --baseUrl <URL>            Override spec baseUrl in
#                                    Postman
#     --localPostman <PATH>          Use a local Postman
#                                    collection (skips OpenAPI
#                                    conversion)
#
#   Output:
#     -o, --output <FILE>            Write the Postman
#                                    collection to file
#     --oaOutput <FILE>              Write the post-processed
#                                    OpenAPI spec to file
#     --collectionName <NAME>        Override Postman collection
#                                    name
#
#   Postman sync:
#     --syncPostman                  Upload collection to Postman
#                                    after conversion
#     --postmanFastSync              Create a new collection
#                                    (new UID) instead of update
#     --postmanRefreshCache          Refresh all cached Postman
#                                    API data
#     -p, --postmanUid <UID>         Postman collection UID for
#                                    upload
#     --postmanWorkspaceName <NAME>  Target Postman workspace
#                                    name
#     --uploadOnly                   Upload only (skip
#                                    conversion)
#     --syncPostmanCollectionIds     Sync collection IDs
#
#   Newman runner:
#     -n, --runNewman                Run Newman on the generated
#                                    collection
#     --newmanRunOptions <JSON>      JSON-stringified Newman
#                                    options
#     --newmanOptionsFile <PATH>     Path/URL to Newman options
#                                    file
#     -d, --newmanIterationData <PATH>
#                                    Iteration data file for
#                                    Newman
#
#   Test injection:
#     -t, --includeTests             Inject Portman test suite
#                                    [default: true]
#     --bundleContractTests          Bundle contract tests in a
#                                    separate Postman folder
#     --logAssignVariables           Log assigned variables
#                                    during conversion
#
#   Configuration:
#     -c, --portmanConfigFile <PATH> Portman config file
#                                    (portman-config.json)
#     -s, --postmanConfigFile <PATH> Postman config file
#     --filterFile <PATH>            OpenAPI filter file
#     --envFile <PATH>               .env file with secrets
#     --cliOptionsFile <PATH>        File with CLI options
#                                    (replaces command-line
#                                    args)
#
#   Diagnostics / flags:
#     --ignoreCircularRefs           Ignore circular refs in
#                                    OpenAPI spec [default: false]
#     --warn                         Print warnings to stdout
#     --init                         Initialize a new
#                                    portman-config.json
#     --extraUnknownFormats <CSV>    Treat additional OpenAPI
#                                    `format` values as known
#
#   Standard yargs auto-flags:
#     --help                         Show help
#     --version                      Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `@apidevtools/swagger-parser ^10.1.1`
#   declared in package.json (with companion `openapi-format
#   ^1.32.1`, `openapi-to-postmanv2 ^6.0.1`, and `openapi-types
#   9.1.0`) — `@apidevtools/swagger-parser` is THE canonical
#   Node.js OpenAPI / Swagger schema library maintained by James
#   Messinger / APIDevTools (APIDevTools/swagger-parser, 1.2K+
#   stars, ~10M npm downloads/week; the predominant typed
#   OpenAPI 2.0 / 3.0.x / 3.1.x parser + validator + bundler +
#   dereferencer for the entire JavaScript ecosystem).
#   swagger-parser exposes the typed `SwaggerParser.parse()` /
#   `validate()` / `dereference()` / `bundle()` / `resolve()`
#   methods returning a fully-typed `OpenAPI.Document` (from
#   `openapi-types`), the `$RefParser` low-level reference
#   resolver with file / HTTP(S) / inline-anchor / circular
#   handling, complete `$ref` cycle detection with
#   configurable continueOnError, JSON-Schema-style format
#   validation, and the same `parse`/`validate` API for both
#   Swagger 2.0 and OpenAPI 3.x.  Portman's `src/oas/
#   OpenApiParser.ts` calls
#   `SwaggerParser.bundle(specPathOrUrl)` to fully resolve all
#   external $refs into a single in-memory document, then
#   walks `Paths.iter()` to convert every operation into a
#   typed Postman request.  Verified via:
#     gh api repos/apideck-libraries/portman/contents/
#         package.json
#       → "@apidevtools/swagger-parser": "^10.1.1"
#       → "openapi-format": "^1.32.1"
#       → "openapi-to-postmanv2": "^6.0.1"
#       → "openapi-types": "9.1.0"
#       → "yargs": "^17.7.2"
#       → "bin": {"portman": "bin/portman"}
#     gh api repos/apideck-libraries/portman/contents/src/
#         index.ts
#       → yargs.option('u'|'l'|'b'|'o'|'n'|'d'|'p'|'t'|'c'|'s'
#         + 30+ long-form Postman/Newman options)
#   This entry is the TS-Node=148 leader bump that CLOSES Axis
#   93 (OpenAPI / openapiv3 schema library) at 1/1/1 three-
#   language symmetry — pairing Rust=openapiv3 via holon-run/
#   uxc (R961 _uxc), Go=getkin/kin-openapi via httprunner/
#   httprunner (R962 _hrp), and TS-Node=@apidevtools/swagger-
#   parser via apideck-libraries/portman (this entry).
#   Triple-148 landmark on commit.  Axis 93 = 86th axis closed.
#
#   No completion for `portman` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_portman() {
    _arguments -s \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-u --url)'{-u,--url}'=[URL of OpenAPI spec to port]:url:' \
        '(-l --local)'{-l,--local}'=[local OpenAPI spec to port]:file:_files -g "*.{yml,yaml,json}"' \
        '(-b --baseUrl)'{-b,--baseUrl}'=[override spec baseUrl in Postman]:url:' \
        '--localPostman=[use a local Postman collection (skip conversion)]:file:_files -g "*.json"' \
        '(-o --output)'{-o,--output}'=[write Postman collection to file]:file:_files -g "*.json"' \
        '--oaOutput=[write post-processed OpenAPI spec to file]:file:_files' \
        '--collectionName=[override Postman collection name]:name:' \
        '--syncPostman[upload collection to Postman]' \
        '--postmanFastSync[create new collection (new UID)]' \
        '--postmanRefreshCache[refresh cached Postman API data]' \
        '(-p --postmanUid)'{-p,--postmanUid}'=[Postman collection UID for upload]:uid:' \
        '--postmanWorkspaceName=[target Postman workspace name]:name:' \
        '--uploadOnly[upload only (skip conversion)]' \
        '--syncPostmanCollectionIds[sync collection IDs]' \
        '(-n --runNewman)'{-n,--runNewman}'[run Newman on generated collection]' \
        '--newmanRunOptions=[JSON-stringified Newman options]:json:' \
        '--newmanOptionsFile=[Newman options file path/URL]:file:_files' \
        '(-d --newmanIterationData)'{-d,--newmanIterationData}'=[Newman iteration data file]:file:_files' \
        '(-t --includeTests)'{-t,--includeTests}'[inject Portman test suite]' \
        '--bundleContractTests[bundle contract tests in separate Postman folder]' \
        '--logAssignVariables[log assigned variables during conversion]' \
        '(-c --portmanConfigFile)'{-c,--portmanConfigFile}'=[Portman config file path]:file:_files -g "*.json"' \
        '(-s --postmanConfigFile)'{-s,--postmanConfigFile}'=[Postman config file path]:file:_files -g "*.json"' \
        '--filterFile=[OpenAPI filter file]:file:_files' \
        '--envFile=[.env file with secrets]:file:_files -g ".env*"' \
        '--cliOptionsFile=[file with CLI options]:file:_files' \
        '--ignoreCircularRefs[ignore circular refs in OpenAPI spec]' \
        '--warn[print warnings to stdout]' \
        '--init[initialize a new portman-config.json]' \
        '--extraUnknownFormats=[CSV of extra known OpenAPI formats]:csv:'
}

_portman "$@"
