#compdef aulast
# _aulast — Linux audit aulast (last(1)-like view built from audit log records: per-session login/logout history with tty, host, duration and event id; -f input file, --bad show failed logins, --proof show proof events, --extract dump matching records, --user filter, --tty filter, --stdin read from stdin, --version, --help)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/aulast.c on tip.

_aulast() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-f+[input file]:file:_files' \
        '--bad[failed logins]' \
        '--proof[show proof events]' \
        '--extract[dump records]' \
        '--user+[user]:user:_users' \
        '--tty+[tty]:tty:' \
        '--stdin[stdin]'
}

_aulast "$@"
