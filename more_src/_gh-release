#compdef gh-release
# _gh-release — GitHub gh release subcommand alias (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-release() {
    local -a sub=(
        'create:create a release'
        'delete:delete a release'
        'delete-asset:delete a release asset'
        'download:download release assets'
        'edit:edit a release'
        'list:list releases'
        'upload:upload assets to a release'
        'view:view a release'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--repo=+[owner/name]:str:' \
        '-R+[owner/name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh-release subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--draft[draft]' \
                    '-d[draft]' \
                    '--prerelease[prerelease]' \
                    '-p[prerelease]' \
                    '--latest[latest release]' \
                    '--notes=+[notes]:str:' \
                    '-n+[notes]:str:' \
                    '--notes-file=+[notes file]:file:_files' \
                    '-F+[notes file]:file:_files' \
                    '--notes-from-tag[notes from tag]' \
                    '--notes-start-tag=+[notes start tag]:str:' \
                    '--target=+[target commitish]:str:' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--verify-tag[verify tag exists]' \
                    '--generate-notes[generate notes]' \
                    '--discussion-category=+[discussion category]:str:' \
                    '*:tag-and-files:_files' ;;
                list) _arguments \
                    '--exclude-drafts[exclude drafts]' \
                    '--exclude-pre-releases[exclude pre-releases]' \
                    '--json=+[json fields]:list:' \
                    '--limit=+[max items]:n:' \
                    '-L+[max items]:n:' \
                    '--order=+[order]:o:(asc desc)' \
                    '-O+[order]:o:(asc desc)' ;;
                view|edit|delete) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '*:tag:' ;;
                upload) _arguments \
                    '--clobber[overwrite]' \
                    '*:tag-and-files:_files' ;;
                download) _arguments \
                    '--archive=+[archive]:t:(tar.gz zip)' \
                    '--clobber[overwrite]' \
                    '--dir=+[output dir]:dir:_files -/' \
                    '-D+[output dir]:dir:_files -/' \
                    '--output=+[output file]:file:_files' \
                    '-O+[output file]:file:_files' \
                    '--pattern=+[asset pattern]:list:' \
                    '-p+[asset pattern]:list:' \
                    '--skip-existing[skip existing]' \
                    '*:tag:' ;;
                delete-asset) _arguments \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '*:tag-and-asset:' ;;
            esac
            ;;
    esac
}

_gh-release "$@"
