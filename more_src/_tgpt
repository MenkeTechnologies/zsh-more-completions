#compdef tgpt

# Zsh completion for tgpt - terminal GPT client (no API key needed)

local -a arguments

arguments=(
  {-p,--provider}'[specify AI provider]:provider name'
  {-m,--model}'[specify model name]:model name'
  {-k,--key}'[API key for the provider]:API key'
  {-t,--temperature}'[set temperature for response generation]:temperature'
  '--top_p[set top_p for response generation]:top_p value'
  '--max_length[set maximum response length]:max length'
  '--preprompt[set a pre-prompt for the conversation]:pre-prompt text'
  {-u,--url}'[custom API URL]:URL'
  '--log[log output to file]'
  {-i,--image}'[generate an image from the prompt]'
  {-i,--interactive}'[start interactive mode]'
  {-ml,--multiline}'[enable multiline input mode]'
  {-s,--shell}'[generate and execute shell commands]'
  {-c,--code}'[generate code only]'
  {-q,--quiet}'[suppress non-essential output]'
  {-w,--whole}'[print the whole response at once]'
  {-v,--version}'[show version information]'
  {-h,--help}'[show help message]'
  '*:prompt text'
)

_arguments -s -S $arguments
