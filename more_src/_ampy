#compdef ampy
# Documentation: https://github.com/scientifichackers/ampy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'get:retrieve a file from the board'
  'ls:list files on the board'
  'mkdir:create a directory'
  'put:put a file or directory onto the board'
  'reset:perform soft reset/reboot'
  'rm:remove a file from the board'
  'rmdir:forcibly remove a directory'
  'run:run a script and print its output'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(-p --port)'{-p,--port}'+[serial port]:port:_files -g "/dev/{tty,cu}*"' \
  '(-b --baud)'{-b,--baud}'+[baud rate]:baud:(115200 9600 57600 38400)' \
  '(-d --delay)'{-d,--delay}'+[delay before connecting sec]:sec:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ampy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--no-output[do not wait for output]' \
          '1:file:_files -g "*.py"' && ret=0 ;;
      (put|get)
        _arguments \
          '1:src:_files' \
          '2:dest:_files' && ret=0 ;;
    esac ;;
esac

return ret
