#compdef afm2pl
# Documentation: afm2pl --help (TeX Live)
# Source: TeX afm2pl — convert AFM (Adobe Font Metric) to TeX PL (Property List).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p+[PostScript encoding file]:encfile:_files -g "*.enc"' \
    '-o[octal character codes in PL]' \
    '-e+[widen (extend) characters by factor]:real:' \
    '-s+[oblique (slant) characters by factor]:real:' \
    '-m+[letterspace by INTEGER/1000 em]:integer:' \
    '-V[verbose (report missing glyphs)]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:input AFM:_files -g "*.afm"' \
    '2:output PL:_files -g "*.pl"' \
    && ret=0

return ret
