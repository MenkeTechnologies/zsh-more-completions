#compdef poscvt
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/core/apps/positioning/poscvt.cpp
# GPSTk position coordinate conversion utility

local ret=1

_arguments -s \
  '--ecef[ECEF "X Y Z" in meters]:xyz' \
  '--geodetic[geodetic "lat lon alt" deg deg m]:lla' \
  '--geocentric[geocentric "lat lon radius" deg deg m]:llr' \
  '--spherical[spherical "theta phi radius" deg deg m]:tpr' \
  '(-l --list-formats)'{-l,--list-formats}'[list available format codes]' \
  '(-F --output-format)'{-F,--output-format}'[write the position with the given format]:fmt' \
  '(-d --debug)'{-d,--debug}'[increase debug level]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[print help usage]' && ret=0

return ret
