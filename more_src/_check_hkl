#compdef check_hkl
# Documentation: https://www.desy.de/~twhite/crystfel/manual-check_hkl.html
# Calculate data quality figures of merit for a reflection list (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-p --pdb)'{-p+,--pdb=}'[unit cell file]:file:_files' \
  '(-y --symmetry)'{-y+,--symmetry=}'[symmetry of reflections]:pointgroup:' \
  '--sigma-cutoff=[discard reflections below I/sigma(I)]:n:' \
  '--rmin=[low resolution cutoff as 1/d in m^-1]:1/d:' \
  '--lowres=[low resolution cutoff in Angstroms]:d:' \
  '--rmax=[high resolution cutoff as 1/d in m^-1]:1/d:' \
  '--highres=[high resolution cutoff in Angstroms]:d:' \
  '--shell-file=[write resolution shell statistics]:file:_files' \
  '--ltest[perform L-test for twinning]' \
  '--wilson[calculate a Wilson plot]' \
  '--ignore-negs[ignore negative intensities]' \
  '--zero-negs[set negative intensities to zero]' \
  '--nshells=[number of resolution shells]:n:' \
  '*:reflection list:_files' && ret=0

return ret
