#compdef postscreen
# Documentation: https://man.archlinux.org/search?q=postscreen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[main.cf directory]:dir:_files -/' \
  '-D[increase debug verbosity]' \
  '-l+[listen mode]:mode:' \
  '-s+[service name]:name:' \
  '-v[verbose]' && ret=0

return ret
