#compdef native-image-configure
# Documentation: https://www.graalvm.org/latest/reference-manual/native-image/metadata/AutomaticMetadataCollection/
# GraalVM Native Image configure tool: generate and merge reachability metadata

local ret=1

_arguments -s -C \
  '1:command:(generate help)' \
  '*::options:->opts' && ret=0

case $state in
  opts)
    _arguments -s \
      '*--trace-input=[read and process a trace-file.json]:trace file:_files' \
      '*--input-dir=[directory containing a set of configuration files]:dir:_files -/' \
      '--output-dir=[destination directory for generated configuration files]:dir:_files -/' && ret=0
    ;;
esac

return ret
