#compdef nvidia-installer
# Documentation: https://man.archlinux.org/search?q=nvidia-installer
# Reference accessed: 2026-05-16

# nvidia-installer: NVIDIA proprietary driver installer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-A[advanced help]' \
  '--advanced-options[advanced help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-i[install (default)]' \
  '--install[install (default)]' \
  '-q[query running install]' \
  '--query[query running install]' \
  '-u[uninstall]' \
  '--uninstall[uninstall]' \
  '--accept-license[accept license non-interactively]' \
  '--add-this-kernel[build new precompiled interface]' \
  '--dkms[install via DKMS]' \
  '--force-libglx-indirect[force indirect GLX]' \
  '--no-dkms[skip DKMS]' \
  '--silent[silent install]' \
  '-s[silent install]' \
  '--no-questions[do not prompt]' \
  '-n[do not prompt]' \
  '--kernel-name=[kernel name]:ver:' \
  '--kernel-source-path=[kernel source path]:dir:_files -/' \
  '--kernel-output-path=[kernel build output dir]:dir:_files -/' \
  '--kernel-install-path=[kernel install path]:dir:_files -/' \
  '--no-x-check[skip X running check]' \
  '--no-precompiled-interface[no precompiled interface]' \
  '--no-distro-scripts[skip distro install scripts]' \
  '--no-opengl-files[skip OpenGL files]' \
  '--installer-prefix=[install prefix]:dir:_files -/' \
  '--utility-prefix=[utility prefix]:dir:_files -/' \
  '--opengl-prefix=[OpenGL prefix]:dir:_files -/' \
  '--documentation-prefix=[doc prefix]:dir:_files -/' \
  '--x-prefix=[X prefix]:dir:_files -/' \
  '--x-module-path=[X module path]:dir:_files -/' \
  '--no-nvidia-modprobe[do not install nvidia-modprobe]' \
  '--ui=[user interface]:ui:(stdio ncurses none)' \
  '--no-ui[no UI]' \
  '--log-file=[log file]:file:_files' \
  '--no-questions[no questions]' \
  '--check[check existing install]' \
  '*::nvidia-installer args:_files' && ret=0
return ret
