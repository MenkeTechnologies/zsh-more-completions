#compdef poly polyc
# Documentation: https://www.polyml.org/documentation/CommandReference.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (poly)
    _arguments -C \
      '--help[show help]' \
      '-v[print version and exit]' \
      '-q[suppress start-up message]' \
      '-i[interactive mode]' \
      '--use+[execute use FILE before ML shell starts]:file:_files -g "*.ML *.sml *.sig"' \
      '--eval+[compile and execute STRING as ML]:expr:' \
      '--error-exit[exit shell on unhandled exception]' \
      '--with-markup[include mark-up in printed output]' \
      '--ideprotocol[run IDE communications protocol]' \
      '--script+[input is a script]:file:_files' \
      '-H+[initial heap size MB]:mb:' \
      '--minheap+[minimum heap size MB]:mb:' \
      '--maxheap+[maximum heap size MB]:mb:' \
      '--gcpercent+[target percentage time in GC 1-99]:n:' \
      '--stackspace+[space to reserve for thread stacks MB]:mb:' \
      '--gcthreads+[number of GC threads]:n:' \
      '--debug+[debug options]:opt:(checkmem gc gcenhanced gcdetail memmgr threads gctasks heapsize x sharing locks rts saving)' \
      '--logfile+[logging file]:file:_files' \
      '--exportstats[enable another process to read statistics]' \
      '*: :_files -g "*.ML *.sml *.sig"' && ret=0 ;;
  (polyc)
    _arguments -C \
      '--help[show help]' \
      '-o+[output executable]:file:_files' \
      '-c[compile only, do not link]' \
      '-b+[use named poly compiler]:compiler:_command_names -e' \
      '*: :_files -g "*.ML *.sml *.sig *.c *.o"' && ret=0 ;;
esac

return ret
