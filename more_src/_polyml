#compdef poly polyc
# Documentation: https://man.archlinux.org/search?q=poly
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (poly)
    _arguments -C \
      '--help[show help]' \
      '-h[show help]' \
      '--version[show version]' \
      '-v[show version]' \
      '-q[suppress greeting]' \
      '--script+[run script and exit]:file:_files' \
      '--use+[load file at startup]:file:_files -g "*.ML *.sml *.sig"' \
      '--eval+[evaluate ML expression]:expr:' \
      '--error-exit[exit on errors]' \
      '-i[interactive]' \
      '--with-markup[include markup in output]' \
      '--ideprotocol[IDE protocol]' \
      '-H+[heap size MB]:mb:' \
      '--heap+[heap size MB]:mb:' \
      '--minheap+[min heap MB]:mb:' \
      '--maxheap+[max heap MB]:mb:' \
      '--gcthreads+[GC threads]:n:' \
      '--gcpercent+[GC %]:n:' \
      '--debug[set debug flag]' \
      '--noDisplay[suppress output]' \
      '--codepage+[code page]:cp:' \
      '*: :_files -g "*.ML *.sml *.sig"' && ret=0 ;;
  (polyc)
    _arguments -C \
      '--help[show help]' \
      '-o+[output file]:file:_files' \
      '-c[compile only]' \
      '-b[generate bind]' \
      '*: :_files -g "*.ML *.sml *.sig *.c *.o"' && ret=0 ;;
esac

return ret
