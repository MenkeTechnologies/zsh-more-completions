#compdef legendary
# Documentation: https://github.com/derrod/legendary
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Legendary (open source game launcher for Epic Games)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authenticate with Epic Games'
  'cleanup:remove old temporary files'
  'crossover:manage CrossOver setup'
  'download:download a game'
  'egl-sync:sync with Epic Games Launcher'
  'import:import a previously installed game'
  'info:print info about a game'
  'install:install a game'
  'launch:launch a game'
  'list-files:list files in a game'
  'list-games:list available games'
  'list-installed:list installed games'
  'list-saves:list available cloud saves'
  'move:move a game to a different location'
  'repair:repair a game installation'
  'status:show Legendary status information'
  'sync-saves:sync cloud saves'
  'uninstall:uninstall a game'
  'update:update a game'
  'verify:verify game file integrity'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-v[set loglevel to debug]' \
  '-y[default to yes for confirmation prompts]' \
  '-V[print version and exit]' \
  '--config-file=[use specified config file]:config file:_files' \
  '-J[set output format to JSON]' \
  '-A[set loglevel to critical]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install|download|update|repair|verify)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--base-path=[set base installation path]:path:_files -/' \
          '--game-folder=[set game folder name]:folder name:' \
          '--max-shared-memory=[maximum shared memory in MiB]:memory:' \
          '--max-workers=[max number of download workers]:workers:' \
          '--manifest=[manifest URL or path]:manifest:' \
          '--old-manifest=[old manifest URL or path]:manifest:' \
          '--delta-manifest=[delta manifest URL or path]:manifest:' \
          '--platform=[platform to install for]:platform:(Windows Mac)' \
          '--prefix=[only fetch files whose path starts with prefix]:prefix:' \
          '--exclude=[exclude files starting with prefix]:prefix:' \
          '--install-tag=[only download files with specified install tag]:tag:' \
          '--enable-reordering[enable reordering to reduce RAM requirements]' \
          '--dl-timeout=[timeout for downloads in seconds]:timeout:' \
          '--save-path=[override save game path]:path:_files -/' \
          '--repair[repair game files]' \
          '--repair-and-update[repair and update game]' \
          '--ignore-free-space[skip free space check]' \
          '--disable-patching[disable delta patching]' \
          '--force[redownload all files]' \
          '--no-install[do not install, only download]' \
          '--with-dlcs[also install DLCs]' \
          '--skip-dlcs[do not install DLCs]' \
          '*:game name:' && ret=0
        ;;
      (launch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--offline[skip login and run game offline]' \
          '--skip-version-check[skip version check]' \
          '--override-username=[override username]:username:' \
          '--dry-run[print launch command without running]' \
          '--language=[override game language]:language:' \
          '--wrapper=[wrapper command for launch]:command:' \
          '--set-defaults[set current arguments as default]' \
          '--reset-defaults[reset default arguments]' \
          '--wine=[path to wine binary]:wine binary:_files' \
          '--wine-prefix=[path to wine prefix]:wine prefix:_files -/' \
          '--no-wine[do not use wine]' \
          '*:game name:' && ret=0
        ;;
      (list-games|list-installed)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--platform=[platform]:platform:(Windows Mac)' \
          '--include-ue[include Unreal Engine]' \
          '-T[include non-installable items]' \
          '--csv[output as CSV]' \
          '--tsv[output as TSV]' \
          '--json[output as JSON]' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--keep-files[do not delete game files]' \
          '*:game name:' && ret=0
        ;;
      (auth)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--import[import from Epic Games Launcher]' \
          '--code=[authorization code]:code:' \
          '--token=[exchange token]:token:' \
          '--sid=[SID from browser]:sid:' \
          '--delete[remove existing credentials]' \
          '--disable-webview[disable embedded browser]' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:game name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
