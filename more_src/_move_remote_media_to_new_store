#compdef move_remote_media_to_new_store
# _move_remote_media_to_new_store — relocate Synapse remote media (element-hq/synapse)
# upstream: https://github.com/element-hq/synapse
# Flags from synapse/_scripts/move_remote_media_to_new_store.py (argparse).

_move_remote_media_to_new_store() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[enable debug logging]' \
        '1:source content repo:_files -/' \
        '2:destination content repo:_files -/'
}

_move_remote_media_to_new_store "$@"
