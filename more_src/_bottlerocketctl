#compdef bottlerocketctl bottlerocket-cli brctl
# _bottlerocketctl — AWS Bottlerocket bottlerocketctl CLI command-line frontend to the Bottlerocket Linux-based container-optimized minimal OS specifically built for hosting containers Kubernetes EKS Anywhere EKS-on-bare-metal updating instance kubelet kernel container-runtime apiclient settings update report subcommands for OS-level reconciliation (AWS Bottlerocket team, Rust); clap
# upstream: https://bottlerocket.dev/

_bottlerocketctl() {
    local -a sub=(
        'apply:apply settings to host'
        'get:get current settings'
        'set:set host settings'
        'update:apply OS update'
        'rollback:rollback to previous boot partition'
        'reboot:reboot host'
        'report:report status'
        'raw:raw apiclient command'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[socket]:file:_files' \
        '--socket-path=+[file]:file:_files' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.json"' \
        '--config=+[file]:file:_files -g "*.toml *.yaml *.json"' \
        '--method=+[m]:m:(GET POST PATCH DELETE)' \
        '--data=+[data]:str:' \
        '-o+[output format]:f:(json yaml table toml raw)' \
        '--output=+[format]:f:(json yaml table toml raw)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bottlerocketctl subcommand' sub ;;
        args)
            case $words[1] in
                set) _arguments '*:key=value:' ;;
                get) _arguments '*:key:' ;;
                update) _arguments '1:op:(check apply cancel)' ;;
                report) _arguments '1:type:(cis fips)' ;;
            esac
            ;;
    esac
}

_bottlerocketctl "$@"
