#compdef vina_split
# Documentation: https://vina.scripps.edu/manual/
# AutoDock Vina: split a multi-model PDBQT output into separate ligand/flex files

local ret=1

_arguments -s -S \
  '(- *)--help[display usage summary]' \
  '(- *)--version[display program version]' \
  '--input=[input to split (PDBQT)]:input file:_files -g "*.pdbqt"' \
  '--ligand=[prefix for output ligand files]:ligand prefix:_files' \
  '--flex=[prefix for output side-chain files]:flex prefix:_files' \
  '*:input file:_files -g "*.pdbqt"' && ret=0

return ret
