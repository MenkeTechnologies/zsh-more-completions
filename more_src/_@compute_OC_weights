#compdef @compute_OC_weights
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@compute_OC_weights.html
# Compute optimally combined weights dataset for multi-echo EPI data

local ret=1

_arguments -s -S \
  '-echo_times[echo times as a quoted list]:TE list' \
  '-echo_times_file[read echo times from a text file]:file:_files' \
  '-echo_dsets[one run of multi-echo EPI datasets]:dsets:_files' \
  '-def_to_equal[default to equal weights instead of T2* limit]:yn:(yes no)' \
  '-oc_method[computation method]:method:(OC_A OC_B)' \
  '-prefix[output weights dataset prefix]:prefix' \
  '-prefix_combine[prefix for combined output (runs 3dMean)]:prefix' \
  '-sum_weight_tolerance[tolerance for weight sum deviation (default 0.001)]:tol' \
  '-t2_star_limit[T2* value limit (default 300)]:limit' \
  '-work_dir[working directory for processing]:dir:_files -/' \
  '-verb[increase output verbosity]' \
  '-help[display help information]' \
  '-hist[show history]' \
  '-ver[display version]' && ret=0

return ret
