#compdef cargo-criterion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--bench=[benchmark target name]:benchmark:' \
  '--benches[benchmark all bench targets]' \
  '-p+[package to benchmark]:package:' \
  '--package=[package to benchmark]:package:' \
  '--all[benchmark all packages]' \
  '--workspace[benchmark all packages in workspace]' \
  '--features=[features to activate]:features:' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '--target=[target triple]:target:' \
  '--profile=[build profile]:profile:(dev release test bench)' \
  '-j+[number of parallel jobs]:jobs:' \
  '--jobs=[number of parallel jobs]:jobs:' \
  '--message-format=[message format]:format:(human-readable json)' \
  '--plotting-backend=[plotting backend]:backend:(gnuplot plotters disabled)' \
  '--output-format=[output format]:format:(criterion bencher)' \
  '--measurement-time=[measurement time per benchmark]:seconds:' \
  '--warm-up-time=[warm-up time]:seconds:' \
  '--sample-size=[sample size]:count:' \
  '--nresamples=[number of resamples]:count:' \
  '--noise-threshold=[noise threshold]:threshold:' \
  '--confidence-level=[confidence level]:level:' \
  '--significance-level=[significance level]:level:' \
  '--history-id=[history ID]:id:' \
  '--color=[coloring]:when:(auto always never)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '*:benchmark filter:' && ret=0

return ret
