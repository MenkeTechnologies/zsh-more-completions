#compdef 3dExchange
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dExchange.html
# AFNI: replace dataset values according to a mapping table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-input[input dataset]:dataset:_files' \
  '-map[value mapping table (.1D)]:file:_files' \
  '-ver[print version]' \
  '*:dataset:_files' && ret=0

return ret
