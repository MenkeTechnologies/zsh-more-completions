#compdef dapr

# Zsh completion for Dapr CLI (Distributed Application Runtime)

local curcontext="$curcontext" state line ret=1

local -a dapr_commands
dapr_commands=(
  'annotate:add dapr annotations to a Kubernetes config'
  'build-info:print build info'
  'completion:generates shell completion scripts'
  'components:list all Dapr components'
  'configurations:list all Dapr configurations'
  'dashboard:start Dapr dashboard'
  'help:help about any command'
  'init:install Dapr on supported hosting platforms'
  'invoke:invoke a method on a given Dapr application'
  'list:list all Dapr instances'
  'logs:get Dapr sidecar logs for an application'
  'mtls:check mTLS status'
  'publish:publish a pub-sub event'
  'run:run Dapr and your application side by side'
  'status:show the health status of Dapr services'
  'stop:stop Dapr instances and their associated apps'
  'uninstall:uninstall Dapr runtime'
  'upgrade:upgrades or downgrades a Dapr control plane installation'
  'version:print the Dapr runtime and CLI version'
)

local -a dapr_global_flags
dapr_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--log-as-json[output logs in JSON format]'
  '--runtime-path=[Dapr runtime install path]:path:_directories'
)

_arguments -s -S \
  $dapr_global_flags \
  '--version[print version]' \
  '1:command:_describe -t commands command dapr_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S \
          $dapr_global_flags \
          '--container-runtime=[container runtime]:runtime:(docker podman)' \
          '--dashboard-version=[dashboard version]:version:' \
          '--enable-ha[enable high availability mode]' \
          '--enable-mtls[enable mTLS in the cluster]' \
          '--from-dir=[path to a local directory with Dapr artifacts]:directory:_directories' \
          '--image-registry=[custom image registry]:registry:' \
          '--image-variant=[Dapr runtime image variant]:variant:(mariner)' \
          '-k[deploy Dapr to a Kubernetes cluster]' \
          '--kubernetes[deploy Dapr to a Kubernetes cluster]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--network=[Docker network to deploy to]:network:' \
          '--runtime-version=[Dapr runtime version]:version:' \
          '-s[initialize Dapr in slim self-hosted mode]' \
          '--slim[initialize Dapr in slim self-hosted mode]' \
          '--timeout=[timeout for init]:timeout:' \
          '--wait[wait for Kubernetes init to complete]' && ret=0
        ;;
      run)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[application id]:app id:' \
          '--app-id=[application id]:app id:' \
          '--app-channel-address=[application channel address]:address:' \
          '--app-health-check-path=[health check path for the app]:path:' \
          '--app-health-probe-interval=[probe interval in seconds]:seconds:' \
          '--app-health-probe-timeout=[probe timeout in milliseconds]:ms:' \
          '--app-health-threshold=[consecutive failures before unhealthy]:count:' \
          '--app-max-concurrency=[max concurrency of the app]:concurrency:' \
          '-p=[port the application is listening on]:port:' \
          '--app-port=[port the application is listening on]:port:' \
          '--app-protocol=[protocol for the application]:protocol:(http grpc https grpcs h2c)' \
          '--app-ssl[enable HTTPS for the app channel]' \
          '-c=[Dapr component file]:component file:_files' \
          '--components-path=[path to components directory]:directory:_directories' \
          '--config=[Dapr configuration file]:config file:_files' \
          '-d=[dapr gRPC port]:port:' \
          '--dapr-grpc-port=[dapr gRPC port]:port:' \
          '-H=[dapr HTTP port]:port:' \
          '--dapr-http-port=[dapr HTTP port]:port:' \
          '--dapr-http-max-request-size=[max request body size in MB]:mb:' \
          '--dapr-http-read-buffer-size=[max header read buffer in KB]:kb:' \
          '--dapr-internal-grpc-port=[dapr internal gRPC port]:port:' \
          '--dapr-listen-addresses=[dapr listen addresses]:addresses:' \
          '--enable-api-logging[enable API logging]' \
          '--enable-app-health-check[enable app health check]' \
          '--enable-profiling[enable pprof profiling]' \
          '-G=[max body size for HTTP pub/sub in MB]:mb:' \
          '--image=[custom Dapr image]:image:' \
          '--log-level=[log level]:level:(debug info warn error fatal panic)' \
          '--metrics-port=[metrics port]:port:' \
          '--placement-host-address=[placement host address]:address:' \
          '--profile-port=[profile port]:port:' \
          '--resources-path=[path to resources directory]:directory:_directories' \
          '--run-file=[path to run template file]:file:_files' \
          '--unix-domain-socket=[path to unix domain socket directory]:directory:_directories' \
          '(--)' \
          '*:command:_command_names' && ret=0
        ;;
      invoke)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[application id to invoke]:app id:' \
          '--app-id=[application id to invoke]:app id:' \
          '-d=[request data]:data:' \
          '--data=[request data]:data:' \
          '-f=[path to JSON data file]:file:_files' \
          '--data-file=[path to JSON data file]:file:_files' \
          '-m=[method to invoke]:method:' \
          '--method=[method to invoke]:method:' \
          '-v=[HTTP verb]:verb:(GET POST PUT DELETE PATCH)' \
          '--verb=[HTTP verb]:verb:(GET POST PUT DELETE PATCH)' \
          '-k[invoke on a Kubernetes cluster]' \
          '--kubernetes[invoke on a Kubernetes cluster]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' && ret=0
        ;;
      publish)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[application id of the publisher]:app id:' \
          '--publish-app-id=[application id of the publisher]:app id:' \
          '-d=[event data]:data:' \
          '--data=[event data]:data:' \
          '-f=[path to JSON data file]:file:_files' \
          '--data-file=[path to JSON data file]:file:_files' \
          '-i=[pubsub component name]:pubsub name:' \
          '--pubsub=[pubsub component name]:pubsub name:' \
          '-m=[metadata for the cloud event]:metadata:' \
          '--metadata=[metadata for the cloud event]:metadata:' \
          '-t=[topic to publish to]:topic:' \
          '--topic=[topic to publish to]:topic:' \
          '-k[publish on a Kubernetes cluster]' \
          '--kubernetes[publish on a Kubernetes cluster]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--unix-domain-socket=[path to unix domain socket]:directory:_directories' && ret=0
        ;;
      stop)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[application id to stop]:app id:' \
          '--app-id=[application id to stop]:app id:' \
          '-k[stop on a Kubernetes cluster]' \
          '--kubernetes[stop on a Kubernetes cluster]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '-f=[path to run template file]:file:_files' \
          '--run-file=[path to run template file]:file:_files' && ret=0
        ;;
      list)
        _arguments -s -S \
          $dapr_global_flags \
          '-A[list from all namespaces]' \
          '--all-namespaces[list from all namespaces]' \
          '-k[list on a Kubernetes cluster]' \
          '--kubernetes[list on a Kubernetes cluster]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '-o=[output format]:format:(table json yaml)' \
          '--output=[output format]:format:(table json yaml)' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[application id]:app id:' \
          '--app-id=[application id]:app id:' \
          '-k[get logs from Kubernetes]' \
          '--kubernetes[get logs from Kubernetes]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--pod-name=[name of the pod]:pod name:' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          $dapr_global_flags \
          '--all[remove all Dapr resources]' \
          '--container-runtime=[container runtime]:runtime:(docker podman)' \
          '-k[uninstall from Kubernetes]' \
          '--kubernetes[uninstall from Kubernetes]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--network=[Docker network]:network:' \
          '--timeout=[timeout for uninstall]:timeout:' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          $dapr_global_flags \
          '-k[upgrade on Kubernetes]' \
          '--kubernetes[upgrade on Kubernetes]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--image-registry=[custom image registry]:registry:' \
          '--image-variant=[Dapr runtime image variant]:variant:(mariner)' \
          '--runtime-version=[Dapr runtime version]:version:' \
          '--set=[set Helm chart values]:values:' \
          '--timeout=[timeout for upgrade]:timeout:' && ret=0
        ;;
      dashboard)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[dashboard listen address]:address:' \
          '--address=[dashboard listen address]:address:' \
          '-k[open in Kubernetes mode]' \
          '--kubernetes[open in Kubernetes mode]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '-p=[port for the dashboard]:port:' \
          '--port=[port for the dashboard]:port:' \
          '--version=[dashboard version]:version:' && ret=0
        ;;
      status)
        _arguments -s -S \
          $dapr_global_flags \
          '-k[show Kubernetes status]' \
          '--kubernetes[show Kubernetes status]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '-o=[output format]:format:(table json yaml list)' \
          '--output=[output format]:format:(table json yaml list)' && ret=0
        ;;
      components)
        _arguments -s -S \
          $dapr_global_flags \
          '-A[list from all namespaces]' \
          '--all-namespaces[list from all namespaces]' \
          '-k[list Kubernetes components]' \
          '--kubernetes[list Kubernetes components]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '-o=[output format]:format:(table json yaml list)' \
          '--output=[output format]:format:(table json yaml list)' \
          '--name=[component name]:name:' && ret=0
        ;;
      mtls)
        local -a mtls_commands
        mtls_commands=(
          'expiry:check mTLS certificate expiry'
          'export:export mTLS root certificate and key'
          'renew-certificate:renew mTLS root certificate'
        )
        _arguments -s -S \
          $dapr_global_flags \
          '-k[check Kubernetes mTLS]' \
          '--kubernetes[check Kubernetes mTLS]' \
          '1:mtls command:_describe -t commands command mtls_commands' \
          '*::mtls args:' && ret=0
        ;;
      annotate)
        _arguments -s -S \
          $dapr_global_flags \
          '-a=[application id]:app id:' \
          '--app-id=[application id]:app id:' \
          '--app-port=[application port]:port:' \
          '--app-protocol=[application protocol]:protocol:(http grpc https grpcs h2c)' \
          '--config=[Dapr configuration]:config:' \
          '--enable-api-logging[enable API logging]' \
          '--enable-debug[enable debug]' \
          '--enable-metrics[enable metrics]' \
          '--enable-profiling[enable pprof profiling]' \
          '--enabled[enable Dapr sidecar]' \
          '--log-level=[log level]:level:(debug info warn error fatal panic)' \
          '--metrics-port=[metrics port]:port:' \
          '-k[annotate Kubernetes resource]' \
          '--kubernetes[annotate Kubernetes resource]' \
          '-n=[Kubernetes namespace]:namespace:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '-r=[Kubernetes resource]:resource:' \
          '--resource=[Kubernetes resource]:resource:' \
          '*:file:_files' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $dapr_global_flags \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S $dapr_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
