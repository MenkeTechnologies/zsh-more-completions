#compdef allquads
# Documentation: http://astrometry.net/doc/build-index.html
# build an index by generating all quads from a FITS reference catalog

local ret=1

_arguments -s \
  '-h[show help]' \
  '-i+[input FITS reference catalog]:input:_files' \
  '-o+[index file output filename]:output:_files' \
  '-u+[upper bound of quad scale (arcmin)]:scale:' \
  '-l+[lower bound of quad scale (arcmin)]:scale:' \
  '-d+[number of stars in a quad]:dimquads:' \
  '-I+[set the unique ID of this index]:unique id:' \
  '-v[verbose]' && ret=0

return ret
