#compdef reattach-to-user-namespace
# Documentation: https://github.com/ChrisJohnsen/tmux-MacOSX-pasteboard
# Reference accessed: 2026-05-20
# Verified: upstream usage `reattach-to-user-namespace [-l] <program> [args...]`.

local -a arguments

arguments=(
    '-l[execute as a login shell]'
    '*:command:_command_names -e'
)

_arguments -s -S $arguments
