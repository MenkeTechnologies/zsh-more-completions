#compdef updatectl
# Documentation: source-direct extraction from upstream
# systemd/systemd src/sysupdate/updatectl.c â€”
#   verb dispatch table at lines 648-1557 (VERB declarations
#     for list/check/update/vacuum/features/enable/disable)
#   parse_argv() at lines 1691-1740 (the OptionParser
#     FOREACH_OPTION_OR_RETURN dispatch + OPTION_LONG entries)
# Reference accessed: 2026-05-30 via gh api.
#
# updatectl is the **D-Bus client for sysupdated** (the system
# update daemon, sister to R219's systemd-sysupdate).  Unlike
# direct systemd-sysupdate which operates on one target at a
# time and runs synchronously, updatectl talks to the
# org.freedesktop.sysupdate1 D-Bus service which manages
# MULTIPLE TARGETs (host OS, machined containers, portable
# services, system extensions) as a single fleet.  All verbs
# accept TARGET[@VERSION] specifiers so a single command can
# update the host AND a specific container in one call.
#
# Critical extraction note: updatectl is the FIRST round in
# the corpus to document `OPTION_COMMON_HOST` /
# `OPTION_COMMON_NO_PAGER` / `OPTION_COMMON_NO_LEGEND` /
# `OPTION_COMMON_NO_ASK_PASSWORD` â€” the systemd v257+
# OptionParser macros that auto-inject the standard set of
# systemd-CLI options every D-Bus client needs.  These macros
# provide `-H`/`--host=REMOTE`, `--no-pager`, `--no-legend`,
# `--no-ask-password` consistently across `systemctl`,
# `loginctl`, `machinectl`, `homectl`, `oomctl`, etc.

# Verbs decoded source-direct from updatectl.c:648-1557.
# `list` is VERB_DEFAULT and VERB_ONLINE_ONLY â€” runs when no
# verb supplied AND requires sysupdated to be running.
local -a subcommands=(
  'list:list available versions (DEFAULT; optionally filter by TARGET[@VERSION])'
  'check:check for updates on one or more TARGETs (no args = all)'
  'update:install latest version on TARGETs (or pin via TARGET@VERSION; no args = all)'
  'vacuum:remove obsolete versions on TARGETs (no args = all)'
  'features:list available transfer features (optionally one FEATURE name)'
  'enable:enable a transfer feature (mandatory FEATURE arg)'
  'disable:disable a transfer feature (mandatory FEATURE arg)'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show package version and exit]' \
  '--reboot[reboot after updating to newer version]' \
  '--offline[do not fetch metadata from the network]' \
  '--now[download/delete resources immediately rather than queuing]' \
  '(-H --host)'{-H+,--host=}'[execute on a remote host via ssh+dbus]:remote:_hosts' \
  '--no-pager[do not pipe output into a pager]' \
  '--no-legend[do not print legend in output]' \
  '--no-ask-password[do not prompt for password]' \
  '1:verb (default: list):->subcmd' \
  '*::verb-args:->args'

case $state in
  subcmd)
    _describe -t subcommands 'updatectl verb' subcommands && return
    ;;
  args)
    case $words[1] in
      list|update)
        _message 'TARGET[@VERSION] (optional; default: all targets, latest)' && return
        ;;
      check|vacuum)
        _message 'TARGET... (optional; default: all targets)' && return
        ;;
      features)
        _message 'FEATURE name (optional)' && return
        ;;
      enable|disable)
        _message 'FEATURE name (mandatory; repeat for multiple)' && return
        ;;
    esac
    ;;
esac
