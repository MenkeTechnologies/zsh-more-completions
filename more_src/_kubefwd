#compdef kubefwd
# Documentation: https://github.com/txn2/kubefwd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'services:forward Kubernetes services'
      'svc:forward Kubernetes services'
      'version:print version'
      'completion:generate shell completion scripts'
      'help:help about any command'
    )
    _describe -t commands 'kubefwd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      services|svc)
        _arguments -s -S \
          '(-c --kubeconfig)'{-c+,--kubeconfig=}'[absolute path to the kubeconfig file]:file:_files' \
          '(-x --context)'{-x+,--context=}'[specify a context to override the current context]:context' \
          '(-n --namespace)'{-n+,--namespace=}'[specify namespace(s) to forward]:namespace' \
          '(-l --selector)'{-l+,--selector=}'[selector (label query) to filter on]:selector' \
          '(-f --field-selector)'{-f+,--field-selector=}'[field selector to filter on]:selector' \
          '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
          '(-d --domain)'{-d+,--domain=}'[append a pseudo domain name to generated host entries]:domain' \
          '(-m --mapping)'{-m+,--mapping=}'[remap ports]:mapping' \
          '(-A --all-namespaces)'{-A,--all-namespaces}'[enable forwarding for all namespaces]' \
          '(-r --reserve)'{-r+,--reserve=}'[reserve IP addresses for specific services]:reserve' \
          '(-z --fwd-conf)'{-z+,--fwd-conf=}'[path to ip reservation configuration]:file:_files' \
          '(-t --timeout)'{-t+,--timeout=}'[port forwarding timeout in seconds]:timeout' \
          '--hosts-path=[path to the hosts file]:file:_files' \
          '(-b --refresh-backup)'{-b,--refresh-backup}'[create backup of the hosts file]' \
          '(-p --purge-stale-ips)'{-p,--purge-stale-ips}'[purge stale IP entries from hosts]' \
          '--resync-interval=[service resync frequency]:duration' \
          '--retry-interval=[retry interval when pods unavailable]:duration' \
          '--tui[enable interactive terminal UI]' \
          '--api[enable REST API endpoints]' \
          '(-a --auto-reconnect)'{-a,--auto-reconnect}'[automatically reconnect lost forwards]' \
          '--theme=[TUI theme]:theme' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
