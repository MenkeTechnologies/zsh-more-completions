#compdef kubefwd

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'services:forward services'
      'svc:forward services'
      'version:print version'
      'help:help about any command'
    )
    _describe -t commands 'kubefwd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      services|svc)
        _arguments -s -S \
          {-n,--namespace}'=[namespace to forward]:namespace' \
          {-c,--context}'=[kubeconfig context]:context' \
          '--kubeconfig=[path to kubeconfig]:kubeconfig:_files' \
          {-l,--selector}'=[label selector]:selector' \
          {-m,--mapping}'=[port mapping]:mapping' \
          {-d,--domain}'=[custom domain]:domain' \
          {-v,--verbose}'[verbose output]' \
          '--fwd-ip=[IP to forward to]:ip address' \
          '--all-namespaces[forward all namespaces]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
