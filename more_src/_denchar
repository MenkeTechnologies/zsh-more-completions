#compdef denchar
# Documentation: https://docs.siesta-project.org/projects/siesta/en/stable/reference/denchar.html
# SIESTA 2D/3D plots of charge/spin density and wavefunctions from an fdf input

local ret=1

_arguments -s -S \
  '-k[select which k-point to process]:k-point index:' \
  '-w[select which wavefunction to plot]:wavefunction index:' \
  '*:fdf file:_files' && ret=0

return ret
