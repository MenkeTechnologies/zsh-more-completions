#compdef sclang
# Documentation: https://man.archlinux.org/search?q=sclang
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-d+[runtime directory]:dir:_files -/' \
  '-D[daemon mode (no input)]' \
  '-g+[heap growth size (e.g. 256k or 4m)]:size:' \
  '-i+[ide name]:ide:' \
  '-l+[library configuration file]:file:_files' \
  '-m+[initial heap size (e.g. 2m)]:size:' \
  '-r[call Main.run on startup]' \
  '-s[call Main.stop on shutdown]' \
  '-u+[UDP listening port]:port:' \
  '-a[abort if any compile errors]' \
  '*:scd_file:_files -g "*.{sc,scd}"' && ret=0

return ret
