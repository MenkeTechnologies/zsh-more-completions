#compdef rekor-cli

local -a _rekor_commands
_rekor_commands=(
  'get:get entry from rekor'
  'loginfo:get log info'
  'logproof:get inclusion proof'
  'search:search rekor'
  'upload:upload entry to rekor'
  'verify:verify entry in rekor'
  'version:print version'
  'help:help about any command'
)

_arguments -C \
  '--format[output format]:format:(default json)' \
  '--rekor_server[rekor server URL]:url' \
  '--retry[retry count]:count' \
  '--timeout[timeout]:timeout' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'rekor-cli commands' _rekor_commands
    ;;
  args)
    case "$words[1]" in
      get)
        _arguments \
          '--log-index[log index]:index' \
          '--uuid[entry UUID]:uuid' \
          '--format[output format]:format:(default json)'
        ;;
      upload)
        _arguments \
          '--artifact[artifact path]:file:_files' \
          '--signature[signature path]:file:_files' \
          '--public-key[public key path]:file:_files' \
          '--pki-format[PKI format]:format:(pgp x509 minisign ssh)' \
          '--type[entry type]:type:(hashedrekord rekord rpm jar intoto alpine helm rfc3161 cose dsse)' \
          '--entry[entry file]:file:_files'
        ;;
      search)
        _arguments \
          '--artifact[artifact path]:file:_files' \
          '--public-key[public key path]:file:_files' \
          '--sha[sha hash]:sha' \
          '--email[email]:email' \
          '--pki-format[PKI format]:format:(pgp x509 minisign ssh)' \
          '--operator[search operator]:operator:(and or)'
        ;;
      verify)
        _arguments \
          '--artifact[artifact path]:file:_files' \
          '--signature[signature path]:file:_files' \
          '--public-key[public key path]:file:_files' \
          '--pki-format[PKI format]:format:(pgp x509 minisign ssh)' \
          '--type[entry type]:type' \
          '--entry[entry file]:file:_files'
        ;;
      logproof)
        _arguments \
          '--first-size[first tree size]:size' \
          '--last-size[last tree size]:size' \
          '--tree-id[tree id]:id'
        ;;
    esac
    ;;
esac
