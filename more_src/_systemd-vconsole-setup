#compdef systemd-vconsole-setup
# _systemd-vconsole-setup (systemd virtual-console font + keymap applier reading /etc/vconsole.conf at boot to set KEYMAP and FONT on every /dev/ttyN; positional argument is an optional VT device when invoked from udev so only that VT is configured)
# upstream: https://github.com/systemd/systemd (src/vconsole)
# Argument shape from systemd src/vconsole/vconsole-setup.c on tip.

_systemd-vconsole-setup() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '1:VT device:_files -g "/dev/tty*"'
}

_systemd-vconsole-setup "$@"
