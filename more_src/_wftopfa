#compdef wftopfa
# Convert a Wadalab (Japanese) base font to PostScript .PFA (or .PFB) format using Ghostscript
# Documentation: https://web.mit.edu/ghostscript/www/Psfiles.htm
# Reference accessed: 2026-06-21

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:Wadalab font name:_files' && ret=0

return ret
