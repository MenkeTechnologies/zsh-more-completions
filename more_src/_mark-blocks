#compdef mark-blocks
# _mark-blocks — Grafana Mimir TSDB block marker (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/mark-blocks/main.go + pkg/storage/bucket on tip.

_mark-blocks() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-mark-type=[mark type (required)]:type:(deletion no-compact)' \
        '-tenant=[block owner tenant ID]:id:' \
        '-details=[detail string to embed in mark]:text:' \
        '-blocks-file=[file with one block ULID per line (- = stdin)]:file:_files' \
        '-resume-index=[block index to resume from]:n:' \
        '-remove[remove existing marks instead of adding]' \
        '-meta-presence-policy=[block meta.json presence policy]:policy:(none skip-block require)' \
        '-dry-run[log changes without writing]' \
        '-concurrency=[concurrent marker uploads/removals]:n:' \
        '-backend=[object store backend]:backend:(s3 gcs azure swift filesystem)' \
        '-blocks-storage.backend=[blocks storage backend]:backend:(s3 gcs azure swift filesystem)' \
        '-blocks-storage.s3.bucket-name=[S3 bucket name]:bucket:' \
        '-blocks-storage.s3.endpoint=[S3 endpoint]:url:_urls' \
        '-blocks-storage.s3.region=[S3 region]:region:' \
        '-blocks-storage.gcs.bucket-name=[GCS bucket name]:bucket:' \
        '-blocks-storage.azure.account-name=[Azure storage account]:name:' \
        '-blocks-storage.azure.container-name=[Azure container name]:name:' \
        '-blocks-storage.filesystem.dir=[local blocks directory]:dir:_files -/' \
        '*:block-ulid:'
}

_mark-blocks "$@"
