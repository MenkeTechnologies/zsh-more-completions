#compdef gridnet GridNet Gridnet
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/GridNetwork.html
# TauDEM: grid network order and flow length

local ret=1

_arguments -s -S \
  '-p[input D8 flow directions grid]:pfile:_files' \
  '-plen[output longest upstream flow length grid]:plenfile:_files' \
  '-tlen[output total upstream path length grid]:tlenfile:_files' \
  '-gord[output Strahler order grid]:gordfile:_files' \
  '-o[input outlets file (OGR readable dataset)]:outletfile:_files' \
  '-mask[input mask grid]:maskfile:_files' \
  '-thresh[threshold for masked input]:threshold:' \
  '(-lyrno)-lyrname[OGR layer name for outlets]:layer name:' \
  '(-lyrname)-lyrno[OGR layer number for outlets]:layer number:' \
  '*:file:_files' && ret=0

return ret
