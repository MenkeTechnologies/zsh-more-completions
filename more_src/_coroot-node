#compdef coroot-node coroot-node-agent
# _coroot-node — Coroot coroot-node-agent CLI for the eBPF-based per-node agent exposing container TCP DNS L7 metrics auto-discovering pod IPs producing Prometheus metrics for Kubernetes Linux nodes (coroot team, Go); flag
# upstream: https://github.com/coroot/coroot-node-agent

_coroot-node() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--listen=+[addr]:str:' \
        '--cgroupfs-root=+[dir]:dir:_files -/' \
        '--collector-endpoint=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--scrape-interval=+[d]:str:' \
        '--metrics-endpoint=+[path]:str:' \
        '--track-public-network=+[csv]:str:' \
        '--ephemeral-port-range=+[range]:str:' \
        '--ebpf-trace[enable ebpf trace]' \
        '--no-l7[disable L7 protocol parsing]' \
        '--no-tcp[disable TCP tracking]' \
        '--no-dns[disable DNS tracking]' \
        '--no-tls[disable TLS tracking]' \
        '--max-l7-payload=+[bytes]:n:' \
        '--profiling-endpoint=+[url]:str:' \
        '--no-profiling[disable profiling]' \
        '--otel-trace-endpoint=+[url]:str:' \
        '--otel-trace-service-name=+[name]:str:' \
        '--gpu-monitoring[enable GPU monitoring]' \
        '--external-networks=+[csv]:str:' \
        '--container-name-strip-tag-regex=+[regex]:str:'
}

_coroot-node "$@"
