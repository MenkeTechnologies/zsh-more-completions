#compdef ioncat
# Documentation: https://docs.siesta-project.org/projects/siesta/en/school-2021/how-to/orbitals.html
# SIESTA extract orbital, KB projector and other info from .ion files

local ret=1

_arguments -s -S \
  '-h[print help message]' \
  '-s[show header information]' \
  '-i[print indexes of unique orbitals]' \
  '-j[print indexes of unique KB projectors]' \
  '-o[generate table for orbital ORBINDEX]:orbital index:' \
  '-k[generate table for KB projector KBINDEX]:kb index:' \
  '-v[generate table for Vna potential]' \
  '-c[generate table for pseudocore charge]' \
  '-l[generate table for Vlocal charge]' \
  '-Z[zoom in near rc for table generation]' \
  '-O[zoom near zero up to 10^rlog]:rlog:' \
  '*:ion file:_files' && ret=0

return ret
