#compdef isabelle

# Zsh completion for isabelle - Isabelle proof assistant

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a subcommands=(
      'build:build and manage Isabelle sessions'
      'clean:clean session build artifacts'
      'doc:view Isabelle documentation'
      'env:print Isabelle environment settings'
      'getenv:get Isabelle environment variable'
      'install:install Isabelle components'
      'jedit:launch Isabelle/jEdit IDE'
      'server:manage Isabelle server'
      'options:print Isabelle system options'
      'sessions:print session information'
      'mkroot:create session root directory'
      'logo:create Isabelle logo'
      'components:manage Isabelle components'
      'dump:dump session theory content'
      'export:export theory content'
      'imports:report theory imports'
      'java:invoke Java in Isabelle environment'
      'latex:run LaTeX in Isabelle environment'
      'log:print session build log'
      'process:raw ML process'
      'profiling:profiling Isabelle sessions'
      'scala:invoke Scala in Isabelle environment'
      'scalac:invoke Scala compiler in Isabelle environment'
      'self_update:self update Isabelle distribution'
      'update:update theory sources'
      'version:display Isabelle version'
      'vscode:launch Isabelle/VSCode'
    )
    _describe -t commands 'isabelle command' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          '-h[show help]' \
          '-a[build all sessions]' \
          '-b[build heap images]' \
          '-c[clean build]' \
          '*-d[session directory]:directory:_directories' \
          '*-D[base directory for session discovery]:directory:_directories' \
          '-e[eval ML expression]:ML expression: ' \
          '-f[fresh build]' \
          '-j[maximum parallel jobs]:number: ' \
          '-l[list sessions only]' \
          '-n[no build, check only]' \
          '*-o[override system option]:option=value: ' \
          '*-R[include session requirements]:session name: ' \
          '-S[system mode]' \
          '-v[verbose]' \
          '*-x[exclude session]:session name: ' \
          '-N[NUMA scheduling]' \
          '-P[purge theory]' \
          '*-g[session group to build]:group name: ' \
          '*-B[base sessions]:session name: ' \
          '*:session name: ' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '-h[show help]' \
          '-a[clean all sessions]' \
          '*-d[session directory]:directory:_directories' \
          '*-D[base directory]:directory:_directories' \
          '-f[force clean]' \
          '-v[verbose]' \
          '*:session name: ' && ret=0
        ;;
      doc)
        _arguments -s -S \
          '-h[show help]' \
          '*:document name: ' && ret=0
        ;;
      jedit)
        _arguments -s -S \
          '-h[show help]' \
          '*-d[session directory]:directory:_directories' \
          '-l[logic image]:logic name: ' \
          '-n[no build before start]' \
          '-s[system mode]' \
          '*:theory file:_files -g "*.thy"' && ret=0
        ;;
      server)
        _arguments -s -S \
          '-h[show help]' \
          '-L[log file]:file:_files' \
          '-n[server name]:name: ' \
          '-p[server port]:port: ' \
          '-v[verbose]' && ret=0
        ;;
      options)
        _arguments -s -S \
          '-h[show help]' \
          '-l[list options]' \
          '-x[export format]:format: ' && ret=0
        ;;
      sessions)
        _arguments -s -S \
          '-h[show help]' \
          '*-d[session directory]:directory:_directories' \
          '*-D[base directory]:directory:_directories' \
          '-a[all sessions]' \
          '-v[verbose]' && ret=0
        ;;
      dump|export)
        _arguments -s -S \
          '-h[show help]' \
          '*-d[session directory]:directory:_directories' \
          '-o[output directory]:directory:_directories' \
          '*-x[exclude session]:session name: ' \
          '-v[verbose]' \
          '*:session name: ' && ret=0
        ;;
      imports)
        _arguments -s -S \
          '-h[show help]' \
          '*-d[session directory]:directory:_directories' \
          '*-D[base directory]:directory:_directories' \
          '-v[verbose]' \
          '*:session name: ' && ret=0
        ;;
      update)
        _arguments -s -S \
          '-h[show help]' \
          '-a[update all sessions]' \
          '*-d[session directory]:directory:_directories' \
          '*-D[base directory]:directory:_directories' \
          '-v[verbose]' \
          '*:session name: ' && ret=0
        ;;
      log)
        _arguments -s -S \
          '-h[show help]' \
          '-v[verbose]' \
          '*:session name: ' && ret=0
        ;;
      mkroot)
        _arguments -s -S \
          '-h[show help]' \
          '-n[session name]:name: ' \
          '*:directory:_directories' && ret=0
        ;;
      components)
        _arguments -s -S \
          '-h[show help]' \
          '-a[resolve all components]' \
          '-l[list components]' \
          '-u[update components]' \
          '*:component:_directories' && ret=0
        ;;
      vscode)
        _arguments -s -S \
          '-h[show help]' \
          '*-d[session directory]:directory:_directories' \
          '-l[logic image]:logic name: ' \
          '-n[no build before start]' \
          '*:theory file:_files -g "*.thy"' && ret=0
        ;;
      version)
        ;;
      *)
        _arguments -s -S \
          '-h[show help]' \
          '-v[verbose]' \
          '*:argument:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
