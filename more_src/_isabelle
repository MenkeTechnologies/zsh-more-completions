#compdef isabelle
# Documentation: https://isabelle.in.tum.de/doc/system.pdf
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (tool registrations in seL4/isabelle source).

# Zsh completion for isabelle - Isabelle proof assistant

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a subcommands=(
      'build:build and manage Isabelle sessions'
      'build_log:retrieve build log information'
      'build_process:run a build process'
      'build_worker:run a build worker'
      'client:console interaction for Isabelle server'
      'components:resolve Isabelle components'
      'console:run Isabelle process with raw ML console'
      'doc:view Isabelle documentation'
      'dump:dump cumulative PIDE session database'
      'env:run a program within the Isabelle environment'
      'export:export theory content from session build database'
      'getenv:get values from Isabelle settings environment'
      'home:print Isabelle distribution directory'
      'install:install standalone Isabelle executables'
      'java:run Java within the Isabelle environment'
      'java_monitor:monitor Java processes'
      'jedit:launch Isabelle/jEdit IDE'
      'logo:create an Isabelle session logo'
      'mkroot:prepare session root directory'
      'options:print Isabelle system options'
      'profiling:report Isabelle build profiling information'
      'scala:run Scala within the Isabelle environment'
      'scala_build:build Isabelle Scala/Java modules'
      'scala_project:setup IntelliJ IDEA project for Isabelle/Scala'
      'scalac:run Scala compiler within the Isabelle environment'
      'server:manage resident Isabelle servers'
      'sessions:explore structure of Isabelle sessions'
      'sync:synchronize Isabelle + AFP repositories'
      'update:update theory sources based on PIDE markup'
      'version:display Isabelle version'
      'vscode:Visual Studio Code with Isabelle support'
    )
    _describe -t commands 'isabelle command' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          '-A+[include AFP with given root directory]:dir:_directories' \
          '*-B+[include session NAME and all descendants]:session: ' \
          '*-D+[include session directory and select its sessions]:directory:_directories' \
          '-H+[additional cluster host specifications]:hosts: ' \
          '-N[cyclic shuffling of NUMA CPU nodes]' \
          '-P+[enable HTML/PDF presentation in directory]:directory:_directories' \
          '-R[refer to requirements of selected sessions]' \
          '-S[soft build: observe source changes only, not heap images]' \
          '*-X+[exclude sessions from group NAME and all descendants]:group: ' \
          '-a[select all sessions]' \
          '-b[build heap images]' \
          '-c[clean build]' \
          '*-d+[include session directory]:directory:_directories' \
          '-e[export files from session specification into file-system]' \
          '-f[fresh build]' \
          '*-g+[select session group NAME]:group: ' \
          '-j+[maximum number of parallel jobs]:number: ' \
          '-l[list session source files]' \
          '-n[no build -- take existing session build databases]' \
          '*-o+[override Isabelle system option]:option=value: ' \
          '-v[verbose]' \
          '*-x+[exclude session NAME and all descendants]:session: ' \
          '*:session name: ' && ret=0
        ;;
      version)
        ;;
      *)
        _arguments -s -S \
          '-h[show help]' \
          '*:argument:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
