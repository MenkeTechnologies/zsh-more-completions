#compdef autotiling
# Documentation: https://github.com/nwg-piotr/autotiling
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-w[limit to specific workspaces]:workspace numbers:' \
  '-e[limit to specific events]:events:' \
  '-d[enable debug logging]' \
  '-l[set split limit]:limit:' && ret=0

return ret
