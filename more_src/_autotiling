#compdef autotiling
# Documentation: https://man.archlinux.org/search?q=autotiling
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-w[limit to specific workspaces]:workspace numbers:' \
  '-e[limit to specific events]:events:' \
  '-d[enable debug logging]' \
  '-l[set split limit]:limit:' && ret=0

return ret
