#
#  Maintained by Joan "joanbono" Bono (security researcher).  56 GH
#  stars on Gurp.  gurp is the COMMAND-LINE INTERFACE for the
#  PortSwigger Burp Suite Professional REST API — exposed at
#  User Options > Misc > REST API in Burp Suite Pro v2.0.0beta+.
#  Used in AUTHORIZED penetration-testing engagements to drive
#  Burp scans programmatically: schedule scans against URL lists,
#  ingest Nmap XML host lists into scan queues, pull issues/
#  metrics for scanned targets, export scan results as JSON for
#  reporting pipelines.  Sister tools: burpsuite (PortSwigger
#  Burp Suite — STOCK on Kali Linux), zaproxy (OWASP ZAP — in
#  corpus via _zap + STOCK on Kali via _zaproxy), sqlmap (in
#  corpus via _sqlmap + STOCK on Kali), nuclei (in corpus via
#  _nuclei), nmap (in corpus via _nmap + STOCK on most distros
#  via _nmap from net-tools), wfuzz (in corpus via _wfuzz +
#  STOCK Kali), ffuf (in corpus via _ffuf), gobuster (in corpus
#  via _gobuster), nikto (in corpus via _nikto + STOCK Kali).
#
#  CLI library taxonomy update: 12th Go CLI library — Eric Greer's
#  **flaggy** (integrii/flaggy).  Go ecosystem now has 12 documented
#  CLI libraries — TYING WITH RUST at the top of the cross-language
#  taxonomy ahead of TypeScript-Node (11).  🎉 Go RE-TIES with Rust
#  at 12.
#
#  flaggy (integrii/flaggy) is Eric "integrii" Greer's FLUENT-STYLE
#  Go arg parser — designed as an ALTERNATIVE to cobra/urfave-cli
#  that uses package-level FUNCTIONAL builder calls instead of a
#  struct-tree.  Distinguishing features: PACKAGE-LEVEL DEFAULT
#  PARSER (call `flaggy.String(&var, "s", "long", "help")` directly
#  without instantiating a parser) + SUBCOMMAND positional binding
#  (subcommands bound to POSITION index via
#  `flaggy.AttachSubcommand(sub, 1)`) + MULTI-CHARACTER SHORT FLAGS
#  (flaggy permits `-sn`/`-sl`-style multi-char short flags
#  alongside conventional single-char `-s`) + POSITIONAL value
#  binding (`flaggy.AddPositionalValue(&var, "NAME", 1, true,
#  "help")`) + AUTO --help/--version with `flaggy.SetVersion()`/
#  `flaggy.SetName()`/`flaggy.SetDescription()` configuration.
#  Used by jesseduffield/lazydocker (51k stars — IN CORPUS via
#  _lazydocker, the FLAGSHIP flaggy user), kuberhealthy/kuberhealthy
#  (Comcast Kubernetes synthetic check operator, 2238 stars),
#  awslabs/amazon-eks-ami (AWS EKS AMI builder nodeadm config —
#  2650 stars), SR-G/sleep-on-lan (multi-platform sleep-on-LAN
#  daemon, 458 stars), joanbono/Gurp (Burp REST API client),
#  4ARMED/kubeletmein (kubelet impersonator security tool),
#  pherklotz/kubecfg, cartermckinnon/filter-feed, mildred/
#  conductor.go, roshith0896/dbREST, vemilyus/borg-collective,
#  rnurgaliyev/co2meter_exporter, devlights/try-golang (Go tutorial
#  examples), and many other Go binaries that prefer flaggy's
#  package-level functional API over cobra's struct trees.
#
#  flaggy API:
#    import "github.com/integrii/flaggy"
#
#    var (
#      target   string
#      port     string
#      verbose  bool
#      sub      *flaggy.Subcommand
#    )
#
#    func main() {
#      // PACKAGE-LEVEL configuration on the DefaultParser
#      flaggy.SetName("mytool")
#      flaggy.SetDescription("My CLI tool description")
#      flaggy.SetVersion("1.0.0")
#      flaggy.DefaultParser.ShowHelpOnUnexpected = true
#      flaggy.DefaultParser.ShowVersionWithVersionFlag = false
#
#      // Top-level flags — pass POINTER, SHORT, LONG, HELP
#      // Empty short ("") means LONG ONLY
#      flaggy.String(&target, "t", "target", "Burp Address")
#      flaggy.String(&port, "p", "port", "Burp API Port")
#      flaggy.Bool(&verbose, "v", "verbose", "Force DEBUG logging")
#      flaggy.Int(&n, "n", "count", "Number of iterations")
#      flaggy.Duration(&dur, "d", "duration", "Run duration")
#      flaggy.StringSlice(&list, "i", "include", "Include pattern")
#
#      // Subcommand support — bind to position index
#      sub = flaggy.NewSubcommand("generate-configuration")
#      flaggy.AttachSubcommand(sub, 1)
#      sub.String(&subFlag, "f", "format", "Output format")
#
#      // Positional values — pointer, name, position(1-based),
#      // required, help
#      flaggy.AddPositionalValue(&inputFile, "INPUT", 1, true,
#                                "Input file path")
#
#      flaggy.Parse()
#      // After Parse: flag vars populated; check sub.Used to
#      // detect subcommand invocation
#    }
#
#  flaggy distinctive features:
#    - PACKAGE-LEVEL DEFAULT PARSER (`flaggy.DefaultParser`) —
#      call setter funcs directly without instantiating; mirrors
#      stdlib `flag` package convention while adding flaggy's rich
#      features
#    - POINTER-FIRST API — `flaggy.String(&var, ...)` writes
#      directly to the caller's variable on Parse (similar to
#      stdlib flag's `StringVar`); contrast cobra which uses
#      `Cmd.Flags().StringVar(...)` on a Command tree node
#    - SUBCOMMAND POSITIONAL BINDING — `AttachSubcommand(sub, 1)`
#      binds the subcommand to position 1 (1-based); flaggy
#      supports POSITIONAL subcommand ROUTING (subcommand only
#      activates when its name appears at that position) — distinct
#      from cobra's hierarchical Run/RunE func dispatch on Command
#      structs
#    - MULTI-CHAR SHORT FLAGS — flaggy permits `-sn`/`-sl`/`-bg`-
#      style multi-character short flags alongside conventional
#      single-char `-s`; UNUSUAL — most arg parsers reserve
#      multi-char to long form `--flag` only.  gurp uses this for
#      `-sn`/`--scan-nmap` and `-sl`/`--scan-list`
#    - AUTO --help GENERATION — `flaggy.SetName()`/`SetDescription()`/
#      `SetVersion()` configure the auto-generated help renderer
#    - REQUIRED FLAGS — `.Required = true` on returned
#      `*StringFlag`/etc. marks required
#    - HIDDEN FLAGS — `.Hidden = true` excludes flag from --help
#    - SHOW HELP ON UNEXPECTED — `DefaultParser.ShowHelpOnUnexpected
#      = true` prints help on unrecognized flag (default: error
#      only)
#    - SHOW VERSION WITH --VERSION — `ShowVersionWithVersionFlag`
#      toggle (default: true)
#    - SUBCOMMAND SHORT NAMES — `NewSubcommandWithShortName(name,
#      short)` creates a subcommand with a short alias
#    - CONFIGURABLE BANNER — `DefaultParser.AdditionalHelpPrepend`/
#      `AdditionalHelpAppend` for custom help banner text
#    - TRAILING ARGUMENT CAPTURE — `TrailingArguments` slice
#      collects positional args not matched by any
#      AddPositionalValue
#    - INSPIRED BY stdlib `flag` package — Eric Greer wanted
#      stdlib-flag's POINTER-FIRST setter API plus subcommand and
#      positional support without cobra's heavier framework weight
#  Distinct from R237 Go spf13/cobra (subcommand-TREE framework
#  with Command structs and Run/RunE func dispatch — Hugo/
#  Kubernetes/Docker/etc.), R237 Go spf13/pflag (POSIX-flag-compat
#  replacement for stdlib flag — used INSIDE cobra), R237 Go
#  urfave/cli (action-callback framework — Docker pre-cobra,
#  restic, etc.), R237 Go alecthomas/kingpin (chained-builder
#  fluent API — Prometheus, etc.), R237 Go jessevdk/go-flags
#  (struct-tag based parser — Helm earlier), R237 Go mitchellh/cli
#  (HashiCorp Terraform), R262 Go stdlib `flag` (POSIX-INCOMPATIBLE
#  single-dash long-flag default — gofmt/go test), R363 Go
#  peterbourgon/ff (functional-options 3-way config flag/env/file
#  merge), R367 Go akamensky/argparse (Python-argparse-style port),
#  R408 Go pborman/getopt (POSIX-getopt(3) faithful BSD/C-style —
#  oklog/ulid).  Go documented libraries so far: stdlib flag,
#  pflag, cobra, urfave-cli, kingpin, jessevdk/go-flags, mitchellh/
#  cli, ff, akamensky/argparse, pborman/getopt, flaggy... that's 12.
#  flaggy's approach: PACKAGE-LEVEL functional-builder with
#  `flaggy.String(&var, short, long, help)` POINTER-FIRST setters +
#  `flaggy.SetName/SetDescription/SetVersion` package-level config
#  + `NewSubcommand` + `AttachSubcommand(sub, position)` POSITIONAL
#  subcommand routing + `AddPositionalValue(&var, NAME, pos,
#  required, help)` positional binding + MULTI-CHAR SHORT FLAGS
#  (-sn/-sl) + auto --help/--version + `ShowHelpOnUnexpected` +
#  `TrailingArguments` capture — corpus's **first documented
#  package-level-functional-builder Go CLI library**.  Brings
#  cross-language CLI library taxonomy variant count to 150; Go
#  ecosystem now has 12 documented CLI libraries — TYING WITH RUST
#  at the top of the cross-language taxonomy ahead of TypeScript-
#  Node (11).
#
#  Surface (verbatim from `Gurp.go` flaggy registrations):
#
#  Usage:
#    gurp [options]
#
#  Connection:
#    -t, --target <ADDR>            Burp Address (Default: 127.0.0.1)
#    -p, --port <PORT>              Burp API Port (Default: 1337)
#    -k, --key <KEY>                API Key (Burp API key — set
#                                   under User Options > Misc >
#                                   REST API)
#
#  Authentication (for authenticated scans):
#    -U, --username <USER>          Username for an authenticated
#                                   scan
#    -P, --password <PASS>          Password for an authenticated
#                                   scan
#
#  Scan submission:
#    -s, --scan <URL>               URL to scan (single URL — Burp
#                                   creates a new scan task)
#    -sn, --scan-nmap <FILE>        Nmap XML file to scan (Burp
#                                   parses the Nmap hosts list and
#                                   schedules scans against each)
#    -sl, --scan-list <FILE>        File with hosts/IPs to scan
#                                   (newline-separated list)
#
#  Scan inspection:
#    -S, --scan-id <ID>             Scanned URL identifier (Burp
#                                   returns a task ID per scan;
#                                   use this to query a specific
#                                   task)
#    -M, --metrics                  Provides metrics for a given
#                                   task (use with --scan-id)
#    -I, --issues                   Provides issues for a given
#                                   task (use with --scan-id)
#    -e, --export <FILE>            Export issues' JSON (writes
#                                   the issues blob to this file)
#
#  Issue descriptions (from PortSwigger's vulnerability KB):
#    -D, --description <NAME>       Provides description for a
#                                   given issue name (queries
#                                   PortSwigger's KB)
#    -d, --description-names        Returns vulnerability names
#                                   from PortSwigger (lists all
#                                   known vulnerability names)
#
#  Meta:
#    -v, --version                  Gurp version
#        --help                     Show help text (auto-generated
#                                   by flaggy)
#
#  Examples:
#    gurp -t 192.168.1.10 -p 1337 -k MYAPIKEY -s https://target.example.com
#    gurp -t 127.0.0.1 -k KEY -sn nmap_scan.xml         # Scan all hosts from Nmap XML
#    gurp -t 127.0.0.1 -k KEY -sl hosts.txt             # Scan from host list file
#    gurp -t 127.0.0.1 -k KEY -S 1 -I                   # Get issues for scan task 1
#    gurp -t 127.0.0.1 -k KEY -S 1 -M                   # Get metrics for scan task 1
#    gurp -t 127.0.0.1 -k KEY -S 1 -I -e issues.json    # Export issues to JSON
#    gurp -t 127.0.0.1 -k KEY -D "SQL injection"        # Get description for issue
#    gurp -t 127.0.0.1 -k KEY -d                        # List all known issue names
#    gurp -U admin -P pass -t 127.0.0.1 -k KEY -s URL   # Authenticated scan
#    gurp -v                                            # Show Gurp version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also flaggy users):
#    - lazydocker (IN CORPUS via _lazydocker — 51k stars FLAGSHIP
#      flaggy user; jesseduffield's lazydocker; already documented)
#    - nodeadm (IN CORPUS via _nodeadm — AWS EKS nodeadm; uses
#      flaggy in nodeadm/cmd/nodeadm/config/dump.go subcommand)
#    - sol (IN CORPUS via _sol — different `sol` tool; SR-G/
#      sleep-on-lan ships as `sol` binary but corpus's `_sol` is
#      a different tool)
#    - conductor (IN CORPUS via _conductor — different `conductor`
#      tool; mildred/conductor.go is a smaller deploy tool with
#      same binary name)
#    - kuberhealthy (Comcast K8s synthetic check operator, 2238
#      stars — runs as in-cluster daemon, only 3 flags surface
#      area is too thin for completion value)
#    - dbREST (roshith0896/dbREST 2 stars — too niche)
#    - filter-feed (cartermckinnon/filter-feed 2 stars — too niche)
#    - kubeletmein (4ARMED/kubeletmein — kubelet impersonator
#      security tool; FUTURE candidate)
# ============================================================================

_gurp() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[show help text]' \
    '(-v --version)'{-v,--version}'[Gurp version]' \
    '(-t --target)'{-t,--target}'[Burp Address (default: 127.0.0.1)]:address:_hosts' \
    '(-p --port)'{-p,--port}'[Burp API Port (default: 1337)]:port:' \
    '(-k --key)'{-k,--key}'[API Key]:key:' \
    '(-U --username)'{-U,--username}'[Username for an authenticated scan]:username:' \
    '(-P --password)'{-P,--password}'[Password for an authenticated scan]:password:' \
    '(-s --scan)'{-s,--scan}'[URL to scan]:url:' \
    '(-sn --scan-nmap)'{-sn,--scan-nmap}'[Nmap XML file to scan]:file:_files -g "*.xml"' \
    '(-sl --scan-list)'{-sl,--scan-list}'[File with hosts/IPs to scan]:file:_files' \
    '(-S --scan-id)'{-S,--scan-id}'[Scanned URL identifier]:id:' \
    '(-M --metrics)'{-M,--metrics}'[provides metrics for a given task]' \
    '(-I --issues)'{-I,--issues}'[provides issues for a given task]' \
    '(-e --export)'{-e,--export}'[export issues JSON]:file:_files' \
    '(-D --description)'{-D,--description}'[provides description for a given issue]:issue:' \
    '(-d --description-names)'{-d,--description-names}'[returns vulnerability names from PortSwigger]'
}

_gurp "$@"
