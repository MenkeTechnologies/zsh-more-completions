#compdef kubectl-passman
# Documentation: https://github.com/chrisns/kubectl-passman
# kubectl-passman - glue between password managers and kubectl

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:provider:(keychain 1password gopass)' \
  '2:item name:' \
  '3:credentials json:' && ret=0

return ret
