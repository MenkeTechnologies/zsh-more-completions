#compdef antsApplyTransformsToPoints
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsApplyTransformsToPoints.cxx — apply ANTs transforms to a point CSV (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-p --precision)'{-p+,--precision=}'[float precision (0/1)]:n:(0 1)' \
    '(-f --forantsr)'{-f+,--forantsr=}'[for ANTsR output (0/1)]:n:(0 1)' \
    '(-i --input)'{-i+,--input=}'[input points CSV]:file:_files -g "*.csv"' \
    '(-o --output)'{-o+,--output=}'[output points CSV]:file:_files' \
    '*'{-t+,--transform=}'[transform (repeatable; last applied first)]:transform:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
