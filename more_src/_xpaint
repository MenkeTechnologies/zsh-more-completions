#compdef xpaint
# Documentation: https://manpages.debian.org/bookworm/xpaint/xpaint.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm xpaint(1) manpage OPTIONS. X11-style
# single-dash long options. File args may be prefixed with /o (open),
# /c (clipboard) or /l (browser).
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# xpaint: X11 simple paint program
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-size[canvas size WxH]:WxH:' \
  '-winsize[window size WxH]:WxH:' \
  '-zoom[zoom level]:Z:' \
  '(-12 -24)-8[8-bit visual]' \
  '(-8 -24)-12[12-bit visual]' \
  '(-8 -12)-24[24-bit visual]' \
  '-visual[X visual]:visual:' \
  '-dpi[display DPI]:dpi:' \
  '-lang[language]:lang:' \
  '-encoding[text encoding]:encoding:(0 8 16)' \
  '-menufont[menu font]:font:' \
  '-textfont[text font]:font:' \
  '-twistcolor[twist color value]:value:' \
  '-hilitcolor[highlight color value]:value:' \
  '-sharedir[shared resource directory]:dir:_files -/' \
  '-rcfile[resource file]:file:_files' \
  '-msgfile[message file]:file:_files' \
  '-helpfile[help file]:file:_files' \
  '-canvas[start with canvas window]' \
  '-fullpopup[full popup menus]' \
  '-simplepopup[simplified popup menus]' \
  '-nomenubar[hide menu bar]' \
  '-screenshot[start in screenshot mode]' \
  '-operation[default operation number]:n:' \
  '-undosize[undo buffer size]:n:' \
  '-filter[filter file]:file:_files' \
  '-proc[processing file]:file:_files' \
  '-nowarn[suppress warnings]' \
  '-astext[treat input as text]' \
  '*:image file:_files' && ret=0
return ret
