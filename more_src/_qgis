#compdef qgis

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--snapshot=+[render to image]:file:_files' \
  '--width=+[snapshot width]:px:' \
  '--height=+[snapshot height]:px:' \
  '--lang=+[locale]:locale:' \
  '--project=+[project file]:file:_files -g "*.{qgs,qgz}"' \
  '--extent=+[map extent xmin,ymin,xmax,ymax]:bbox:' \
  '--nologo[hide splash]' \
  '--noplugins[no plugins]' \
  '--noversioncheck[no version check]' \
  '--profile=+[user profile]:profile:' \
  '--profiles-path=+[profiles dir]:dir:_files -/' \
  '--code=+[python code or file]:src:_files' \
  '--openclprogramfolder=+[OpenCL folder]:dir:_files -/' \
  '--configpath=+[config dir]:dir:_files -/' \
  '--authdbdirectory=+[auth db dir]:dir:_files -/' \
  '--customizationfile=+[customization ini]:file:_files -g "*.ini"' \
  '*:file:_files -g "*.{qgs,qgz,shp,gpkg,geojson,kml,csv,tif,asc,grd}"' && ret=0

return ret
