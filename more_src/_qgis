#compdef qgis
# Documentation: https://github.com/qgis/QGIS/blob/master/src/app/main.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-s,--snapshot}'+[render to image]:file:_files' \
  {-w,--width}'+[snapshot width]:px:' \
  {-h,--height}'+[snapshot height]:px:' \
  {-l,--lang}'+[locale]:locale:' \
  {-p,--project}'+[project file]:file:_files -g "*.{qgs,qgz}"' \
  {-e,--extent}'+[map extent xmin,ymin,xmax,ymax]:bbox:' \
  {-n,--nologo}'[hide splash]' \
  {-d,--defaultui}'[reset UI to default settings]' \
  '--hide-browser[hide browser widget]' \
  {-P,--noplugins}'[no plugins]' \
  '--nopython[disable Python support]' \
  {-B,--skipbadlayers}'[skip missing layers without prompt]' \
  {-C,--nocustomization}'[disable GUI customization]' \
  {-z,--customizationfile}'+[custom GUI settings file]:file:_files -g "*.ini"' \
  {-g,--globalsettingsfile}'+[global settings defaults file]:file:_files -g "*.ini"' \
  '--profile=+[user profile]:profile:' \
  {-S,--profiles-path}'+[profiles dir]:dir:_files -/' \
  {-a,--authdbdirectory}'+[auth db dir]:dir:_files -/' \
  {-f,--code}'+[python file to execute on load]:src:_files' \
  {-F,--py-args}'+[args to pass to python scripts]:args:' \
  '--dxf-export=+[export to DXF file]:file:_files -g "*.dxf"' \
  '--dxf-extent=+[set DXF export extent]:bbox:' \
  '--dxf-symbology-mode=+[set DXF symbology mode]:mode:(none symbollayer feature)' \
  '--dxf-scale-denom=+[set DXF scale]:scale:' \
  '--dxf-encoding=+[set DXF encoding]:encoding:' \
  '--dxf-map-theme=+[use map theme for DXF]:theme:' \
  {-V,--noversioncheck}'[no version check at startup]' \
  '--version-migration[force settings migration]' \
  '--take-screenshots[generate documentation screenshots]' \
  '--screenshots-categories=+[screenshot categories]:cat:' \
  '--openclprogramfolder=+[OpenCL folder]:dir:_files -/' \
  '--configpath=+[config dir]:dir:_files -/' \
  '--optionspath=+[QSettings configuration path]:dir:_files -/' \
  '*:file:_files -g "*.{qgs,qgz,shp,gpkg,geojson,kml,csv,tif,asc,grd}"' && ret=0

return ret
