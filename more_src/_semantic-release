#compdef semantic-release

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*'{-b,--branches=}'[release branches]:branches:' \
  '(-p --plugins)'{-p,--plugins=}'[plugins]:plugins:' \
  '(-e --extends)'{-e,--extends=}'[extend a shareable config]:config:' \
  '(-t --tag-format)'{-t,--tag-format=}'[tag format]:format:' \
  '(-r --repository-url)'{-r,--repository-url=}'[repository URL]:url:' \
  '(-d --dry-run)'{-d,--dry-run}'[dry run]' \
  '--ci[run on CI (default)]' \
  '--no-ci[disable CI mode]' \
  '--debug[debug output]'
