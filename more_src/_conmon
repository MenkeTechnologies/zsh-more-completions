#compdef conmon
# _conmon — OCI container monitor used by podman/cri-o (containers/conmon)
# upstream: https://github.com/containers/conmon
# Flags from src/cli.c GOptionEntry opt_entries[] on tip.

_conmon() {
    _arguments \
        '(- *)--help[show help]' \
        '--version[print version and exit]' \
        '--api-version=[conmon API version]:n:' \
        '(-b --bundle)'{-b,--bundle=}'[OCI bundle path]:dir:_files -/' \
        '(-c --cid)'{-c,--cid=}'[container ID]:id:' \
        '(-u --cuuid)'{-u,--cuuid=}'[container UUID]:uuid:' \
        '(-n --name)'{-n,--name=}'[container name]:name:' \
        '(-r --runtime)'{-r,--runtime=}'[OCI runtime binary path]:file:_files' \
        '*--runtime-arg=[OCI runtime extra arg]:arg:' \
        '*--runtime-opt=[OCI runtime extra opt]:opt:' \
        '(-P --conmon-pidfile)'{-P,--conmon-pidfile=}'[PID file for conmon process]:file:_files' \
        '(-p --container-pidfile)'{-p,--container-pidfile=}'[PID file for container init]:file:_files' \
        '--exit-dir=[directory for exit files]:dir:_files -/' \
        '--exit-command=[command to run on container exit]:cmd:_command_names' \
        '*--exit-command-arg=[exit-command arg]:arg:' \
        '--exit-delay=[delay before exit command (s)]:n:' \
        '(-e --exec)'{-e,--exec}'[exec into a running container]' \
        '--exec-attach[attach to an exec session]' \
        '--exec-process-spec=[exec process spec JSON]:file:_files' \
        '(-l --log-path)*'{-l,--log-path=}'[log file path]:path:_files' \
        '--log-level=[log level]:level:(error warning info debug trace)' \
        '--log-size-max=[max single log file size]:bytes:' \
        '--log-global-size-max=[max total log size]:bytes:' \
        '--log-tag=[extra tag for log lines]:tag:' \
        '*--log-label=[extra log key=value label]:kv:' \
        '--log-rotate[rotate instead of truncate at size]' \
        '--log-max-files=[backup log files to keep]:n:' \
        '*--log-allowlist-dir=[allowed log directory]:dir:_files -/' \
        '--syslog[log to syslog]' \
        '(-i --stdin)'{-i,--stdin}'[open stdin pipe]' \
        '--leave-stdin-open[keep stdin open after detach]' \
        '(-t --terminal)'{-t,--terminal}'[allocate a pseudo-TTY]' \
        '--no-new-keyring[do not create new session keyring]' \
        '--no-pivot[do not use pivot_root]' \
        '--no-container-partial-message[drop partial container log messages]' \
        '--no-sync-log[skip manual log sync on shutdown]' \
        '--persist-dir=[container persistent state dir]:dir:_files -/' \
        '--restore=[restore container from checkpoint]:dir:_files -/' \
        '(-s --systemd-cgroup)'{-s,--systemd-cgroup}'[use systemd cgroups]' \
        '--socket-dir-path=[attach sockets directory]:dir:_files -/' \
        '--sync[keep conmon as direct child (single-fork)]' \
        '(-T --timeout)'{-T,--timeout=}'[kill container after seconds]:n:' \
        '--sdnotify-socket=[host sd-notify socket to relay to]:path:' \
        '--replace-listen-pid[replace LISTEN_PID for OCI runtime]' \
        '--full-attach[use full attach socket path]' \
        '--seccomp-notify-socket=[seccomp notify socket path]:path:' \
        '--seccomp-notify-plugins=[seccomp notify plugin dir]:dir:_files -/'
}

_conmon "$@"
