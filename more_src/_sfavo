#compdef sfavo
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mavo.c
# Madagascar: compute intercept and gradient by least squares

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'offset=[optional input file for offset values]:file:_files' \
  'half=[if y, second axis is half-offset instead of full offset]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
