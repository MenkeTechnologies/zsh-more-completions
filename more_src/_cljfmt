#compdef cljfmt cljstyle
# Documentation: https://man.archlinux.org/search?q=cljfmt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:check formatting issues'
  'fix:auto-fix formatting issues'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--config=[config file]:file:_files -g "*.edn *.clj"' \
  '--include-zero-arity-bodies[include zero arity bodies]' \
  '--no-color[disable colored output]' \
  '--no-parallel[disable parallel processing]' \
  '--prefer-style=[style preference]:s:(legacy modern)' \
  '1: :->cmd' \
  '*::path:_files -g "*.clj *.cljs *.cljc *.edn"' && ret=0

case $state in
  (cmd) _describe -t cmds 'cljfmt command' commands && ret=0 ;;
esac

return ret
