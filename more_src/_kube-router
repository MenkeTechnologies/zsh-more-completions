#compdef kube-router
# Documentation: https://github.com/cloudnativelabs/kube-router/blob/master/docs/user-guide.md
# Turnkey solution for Kubernetes networking (router, firewall, service proxy)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '-v[log level for V logs]:level' \
  '--run-router=[advertise and learn routes to pods via iBGP]:bool:(true false)' \
  '--run-firewall=[set up iptables ingress firewall for pods]:bool:(true false)' \
  '--run-service-proxy=[set up IPVS for Kubernetes services]:bool:(true false)' \
  '--run-loadbalancer[enable loadbalancer address allocator]' \
  '--master=[address of the Kubernetes API server]:url' \
  '--kubeconfig=[path to kubeconfig file with authorization information]:kubeconfig:_files' \
  '--cluster-asn=[ASN number under which cluster nodes run iBGP]:asn' \
  '--hostname-override=[override the NodeName of the node]:hostname' \
  '--nodes-full-mesh=[set up BGP peering with rest of the nodes]:bool:(true false)' \
  '--peer-router-ips=[IP addresses of external routers for peering]:ips' \
  '--peer-router-asns=[ASN numbers of BGP peers]:asns' \
  '--peer-router-ports=[remote ports for external BGP connections]:ports' \
  '--peer-router-passwords=[authentication passwords for BGP peers]:passwords' \
  '--peer-router-multihop-ttl=[enable eBGP multihop support]:ttl' \
  '--bgp-graceful-restart[enable BGP Graceful Restart capability]' \
  '--bgp-holdtime=[holdtime declared to BGP peer]:duration' \
  '--bgp-port=[port for incoming BGP connections]:port' \
  '--advertise-cluster-ip[add Cluster IP of services to RIB for BGP advertisement]' \
  '--advertise-external-ip[add External IP of services to RIB for BGP advertisement]' \
  '--advertise-loadbalancer-ip[add LoadBalancer IP of services to RIB for BGP advertisement]' \
  '--advertise-pod-cidr=[add Nodes POD cidr to the RIB]:bool:(true false)' \
  '--enable-overlay=[use IP-in-IP tunneling for cross-subnet pod networking]:bool:(true false)' \
  '--overlay-encap=[encapsulation type]:type:(ipip fou)' \
  '--overlay-type=[overlay type]:type:(subnet full)' \
  '--enable-pod-egress=[SNAT traffic from pods to destinations outside the cluster]:bool:(true false)' \
  '--service-cluster-ip-range=[CIDR values from which service cluster IPs are assigned]:cidr' \
  '--service-node-port-range=[NodePort range]:range' \
  '--service-external-ip-range=[external IP CIDRs for inter-cluster communication]:cidr' \
  '--loadbalancer-ip-range=[CIDR values from which loadbalancer addresses are assigned]:cidr' \
  '--ipvs-permit-all=[accept all incoming traffic to service VIPs on the node]:bool:(true false)' \
  '--ipvs-sync-period=[delay between ipvs config synchronizations]:duration' \
  '--iptables-sync-period=[delay between iptables rule synchronizations]:duration' \
  '--routes-sync-period=[delay between route updates and advertisements]:duration' \
  '--masquerade-all[SNAT all traffic to cluster IP/node port]' \
  '--hairpin-mode[add iptables rules to support hairpin traffic]' \
  '--override-nexthop[override the next-hop in BGP routes with the local IP]' \
  '--enable-ipv4=[enable IPv4 support]:bool:(true false)' \
  '--enable-ipv6[enable IPv6 support]' \
  '--router-id=[BGP router-id]:id' \
  '--enable-cni=[enable CNI plugin]:bool:(true false)' \
  '--runtime-endpoint=[path to CRI compatible container runtime socket]:socket:_files' \
  '--auto-mtu=[auto detect and set the largest possible MTU]:bool:(true false)' \
  '--health-port=[health check port]:port' \
  '--metrics-port=[Prometheus metrics port]:port' \
  '--metrics-path=[Prometheus metrics path]:path' \
  '--enable-pprof[enable pprof for debugging]' \
  '--cleanup-config[cleanup iptables, ipvs, ipset configuration and exit]' \
  '*::arg:_default' && ret=0

return ret
