#compdef Cart3Convert
# Documentation: https://geographiclib.sourceforge.io/C++/doc/Cart3Convert.1.html
# GeographicLib: convert between geocentric and triaxial coordinate systems

local ret=1

_arguments -s -S \
  '-E[ellipsoidal coordinates beta omega alpha (default)]' \
  '-G[geodetic coordinates phi lambda zeta]' \
  '-P[parametric coordinates]' \
  '-C[geocentric coordinates]' \
  '-GX[geodetic coordinates with north pole on X axis]' \
  '-PX[parametric coordinates with north pole on X axis]' \
  '-CX[geocentric coordinates with north pole on X axis]' \
  '-r[perform reverse conversion]' \
  '-3[include height in calculation]' \
  '-D[include direction/heading in calculation]' \
  '-R[output nrand random points on ellipsoid surface]:nrand:' \
  '--seed[set random number seed]:s:' \
  '-t[specify ellipsoid via semiaxes a b c]:a:' \
  '-e[specify ellipsoid via median semiaxis and shape parameters]:b:' \
  '-d[output angles as degrees, minutes, seconds]' \
  '-:[like -d but use colon as separator]' \
  '-w[toggle longitude-first flag]' \
  '-p[set output precision]:prec:' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
