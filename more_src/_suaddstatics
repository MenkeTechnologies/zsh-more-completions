#compdef suaddstatics
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/statics/suaddstatics.c
# add random statics on seismic data

local ret=1

_arguments -s -S \
  'shift=[static shift generated randomly in [+shift,-shift] (ms)]:shift' \
  'sources=[number of source locations]:sources' \
  'receivers=[number of receiver locations]:receivers' \
  'cmps=[number of common mid point locations]:cmps' \
  'maxfold=[maximum fold of input data]:maxfold' \
  'datafile=[name and complete path of the input file]:file:_files' \
  'dt=[time sampling interval (ms)]:dt' \
  'seed=[seed for random number generator]:seed' \
  'verbose=[=1 print useful information]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
