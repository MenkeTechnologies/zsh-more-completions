#compdef spago
# _spago-bin — Spago PureScript package manager + build tool (Spago contributors, PureScript); manage PureScript projects
# upstream: https://github.com/purescript/spago

_spago-bin() {
    local -a sub=(
        'auth:authentication commands'
        'build:build project'
        'bundle:bundle into single js file'
        'docs:generate docs'
        'fetch:fetch dependencies'
        'glob:glob test'
        'graph:dependency graph'
        'help:show help'
        'init:initialize new project'
        'install:add + fetch dependency'
        'ls:list installed packages'
        'publish:publish package'
        'registry:registry commands'
        'repl:start REPL'
        'run:build + run'
        'script:run script'
        'test:run tests'
        'uninstall:remove dependency'
        'upgrade:upgrade package set'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[no color]' \
        '--offline[offline]' \
        '--json-errors[json errors]' \
        '--config+[config file]:file:_files -g "spago.{dhall,yaml}"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spago subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '-w[watch]' \
                    '--watch[watch]' \
                    '--ensure-ranges[ensure ranges]' \
                    '--censor-codes+[censor codes]:codes:' \
                    '--censor-stats[censor stats]' \
                    '--purs-args+[purs args]:str:' \
                    '--strict[strict]' \
                    '--pedantic-packages[pedantic packages]' \
                    '--show-source[show source]' \
                    '--stash[stash before build]' ;;
                bundle) _arguments \
                    '--bundle-type+[bundle type]:type:(app module)' \
                    '--platform+[platform]:platform:(node browser)' \
                    '--outfile+[output file]:file:_files' \
                    '--minify[minify]' ;;
                init) _arguments \
                    '--name+[project name]:str:' \
                    '--package-set+[package set]:str:' ;;
                test|run) _arguments \
                    '--main+[main module]:module:' \
                    '-m+[main module]:module:' \
                    '--exec-args+[exec args]:str:' \
                    '-a+[exec args]:str:' \
                    '--purs-args+[purs args]:str:' ;;
                install|uninstall) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_spago-bin "$@"
