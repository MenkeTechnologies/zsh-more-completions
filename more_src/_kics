#compdef kics
# Documentation: https://github.com/Checkmarx/kics/blob/master/docs/commands.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for KICS (Keeping Infrastructure as Code Secure)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global=(
  '--ci[display only the results in the output]'
  '(-f --log-format)'{-f,--log-format}'+[log format]:format:(pretty json)'
  '--log-level=[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)'
  '--log-path=[log file path]:file:_files'
  '--no-color[disable CLI color output]'
  '--profiling=[enable profiling]:type:(CPU MEM)'
  '(-s --silent)'{-s,--silent}'[silence stdout messages]'
  '(-v --verbose)'{-v,--verbose}'[write logs to stdout too]'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  $global \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:executes a scan analysis'
      'remediate:auto remediates the project'
      'version:displays the current version'
      'list-platforms:list supported platforms'
      'generate-id:generates uuid for query'
      'help:help about any command'
    )
    _describe -t commands 'kics command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      scan)
        _arguments -s -S \
          $global \
          '(-p --path)*'{-p,--path}'+[paths to scan]:path:_files' \
          '(-o --output-path)'{-o,--output-path}'+[directory for report files]:directory:_directories' \
          '--output-name=[report file name]:name:' \
          '(-q --queries-path)*'{-q,--queries-path}'+[paths to query libraries]:queries path:_directories' \
          '(-b --libraries-path)'{-b,--libraries-path}'+[path to load libraries from]:libraries path:_directories' \
          '(-t --type)*'{-t,--type}'+[type of IaC to scan]:type:(Ansible AzureResourceManager Buildah CICD CloudFormation Crossplane DockerCompose Dockerfile GRPC GoogleDeploymentManager Knative Kubernetes OpenAPI Pulumi ServerlessFW Terraform)' \
          '--exclude-type=[case insensitive list of platform types to exclude]:types:' \
          '(-e --exclude-paths)*'{-e,--exclude-paths}'+[paths or files to exclude]:paths:' \
          '--exclude-queries=[exclude queries by IDs]:query IDs:' \
          '--exclude-categories=[exclude categories]:categories:' \
          '--exclude-severities=[exclude results by severity]:severities:(critical high medium low info trace)' \
          '(-x --exclude-results)*'{-x,--exclude-results}'+[exclude results by similarity ID]:result IDs:' \
          '--exclude-gitignore[exclude paths from .gitignore]' \
          '(-i --include-queries)*'{-i,--include-queries}'+[include queries by IDs]:query IDs:' \
          '--config=[path to configuration file]:config file:_files' \
          '--no-progress[hide the progress bar]' \
          '--minimal-ui[simplified version of the CLI output]' \
          '--no-color[disable CLI color output]' \
          '(-m --bom)'{-m,--bom}'[include bill of materials in the results]' \
          '--cloud-provider=[filter queries by cloud provider]:provider:(alicloud aws azure gcp nifcloud tencentcloud)' \
          '--report-formats=[formats to export results]:format:(all asff codeclimate csv cyclonedx glsast html json junit pdf sarif sonarqube)' \
          '--fail-on=[which severities will fail the scan]:severity:(critical high medium low info)' \
          '--ignore-on-exit=[defines which non-zero exits should be ignored]:value:(all results errors none)' \
          '--timeout=[number of seconds the query has to execute]:seconds:' \
          '--parallel=[number of cores to use on parallel]:n:' \
          '(-d --payload-path)'{-d,--payload-path}'+[file path to store the payload]:file:_files' \
          '--payload-lines[adds line information to the payload file]' \
          '--preview-lines=[number of lines to be displayed]:n:' \
          '--disable-full-descriptions[disable retrieval of full descriptions]' \
          '--disable-secrets[disable secrets detection]' \
          '(-r --secrets-regexes-path)'{-r,--secrets-regexes-path}'+[path to custom secrets regex rules]:file:_files' \
          '--input-data=[path to query input data files]:dir:_files -/' \
          '--terraform-vars-path=[path to terraform vars]:dir:_files -/' \
          '--max-file-size=[max file size in MB]:mb:' \
          '--max-resolver-depth=[max depth to resolve internal files]:n:' \
          '--old-severities[use the old severity scale]' \
          '--enable-openapi-refs[enable OpenAPI references resolution]' \
          '--experimental-queries[enable experimental queries]' \
          && ret=0
        ;;
      remediate)
        _arguments -s -S \
          $global \
          '--results=[path to results file]:results file:_files' \
          '--include-ids=[remediate specific similarity IDs]:ids:' \
          && ret=0
        ;;
      generate-id)
        _arguments -s -S $global && ret=0
        ;;
      list-platforms|version)
        _arguments -s -S $global && ret=0
        ;;
    esac
    ;;
esac

return ret
