#compdef kics

# Zsh completion for KICS (Keeping Infrastructure as Code Secure)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:Scan files or directories for vulnerabilities'
      'remediate:Remediate a file'
      'version:Show version information'
      'list-platforms:List supported platforms'
      'generate-id:Generate a query ID'
    )
    _describe -t commands 'kics command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      scan)
        _arguments -s -S \
          '(-p --path)'{-p,--path}'[path to scan]:path:_files' \
          '(-o --output-path)'{-o,--output-path}'[output directory]:directory:_directories' \
          '--output-name=[output file name]:name' \
          '(-q --queries-path)'{-q,--queries-path}'[path to queries]:queries path:_directories' \
          '(-t --type)'{-t,--type}'[type of IaC to scan]:type:(Ansible AzureResourceManager CloudFormation Dockerfile GoogleDeploymentManager GRPC Kubernetes OpenAPI Terraform)' \
          '(-e --exclude-paths)'{-e,--exclude-paths}'[paths to exclude]:paths' \
          '--exclude-queries=[queries to exclude]:query IDs' \
          '--exclude-categories=[categories to exclude]:categories' \
          '--exclude-severities=[severities to exclude]:severities' \
          '--include-queries=[queries to include]:query IDs' \
          '--config=[path to config file]:config file:_files' \
          '--no-color[disable colored output]' \
          '--no-progress[hide progress bar]' \
          '--minimal-ui[minimal UI output]' \
          '--verbose[verbose output]' \
          '--silent[suppress output]' \
          '--cloud-provider=[filter by cloud provider]:provider:(aws azure gcp)' \
          '--report-formats=[report format]:format:(json sarif html csv glsast sonarqube cyclonedx asff)' \
          '--fail-on=[fail on severity]:severity:(high medium low info)' \
          '--ignore-on-exit=[ignore exit code for]:result:(results errors all none)' \
          '--timeout=[scan timeout in seconds]:seconds' \
          '--profiling=[enable profiling]:type:(CPU MEM)' \
          '--parallel=[number of parallel workers]:workers' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      remediate)
        _arguments -s -S \
          '--results=[path to results file]:results file:_files' \
          '--include-ids=[remediate specific query IDs]:ids' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
