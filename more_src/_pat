#compdef pat
# Documentation: http://psrchive.sourceforge.net/manuals/pat/
# PSRCHIVE: produce pulse time of arrival (TOA) estimates.

local ret=1

_arguments -s -S \
  '-h[show full list of options]' \
  '-A+[fitting algorithm to use]:algorithm:' \
  '-s+[standard template profile]:standard:_files' \
  '*:archive:_files' && ret=0

return ret
