#compdef orbzmq
# _orbzmq — orbuculum project orbzmq CLI ZeroMQ publisher republishing decoded ARM Cortex-M ITM trace stream channel messages onto ZMQ PUB sockets at user-defined endpoints for multi-language clients in Python Rust Go to subscribe to live trace events (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbzmq() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-c+[channel,topic,format]:str:' \
        '-C[print cycle count]' \
        '-E[exception report]' \
        '-g+[trigger]:str:' \
        '-n[no NL]' \
        '-p+[protocol]:p:(itm tpiu etm)' \
        '-s+[server:port]:host:port:' \
        '-t+[tag]:str:' \
        '-T[TPIU framing]' \
        '-z+[zmq bind addr]:str:' \
        '-x+[exclude channel mask]:n:' \
        '*:channel spec:'
}

_orbzmq "$@"
