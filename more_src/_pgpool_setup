#compdef pgpool_setup
# Documentation: https://www.pgpool.net/docs/latest/en/html/pgpool-setup.html
# Create a temporary installation of a Pgpool-II cluster

local ret=1

_arguments -s -S \
  '-m[running mode]:mode:(r s n l i)' \
  '-n[number of PostgreSQL installations]:num clusters:' \
  '-p[base port number for Pgpool-II and PostgreSQL]:base port:' \
  '-pg[base port number used by PostgreSQL]:pg base port:' \
  '--no-stop[do not stop pgpool and PostgreSQL after the work]' \
  '-d[start pgpool with debug mode]' \
  '-s[use replication slot instead of archive in streaming replication mode]' \
  '-r[use pg_rewind command in recovery script]' \
  '-e[omit to create PostgreSQL database]' \
  '-t[set additional parameters to pgpool.conf for regression testing]' \
  '-c[use sample scripts and configuration files from /etc/pgpool-II]' && ret=0

return ret
