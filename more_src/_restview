#compdef restview

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-l --listen)'{-l+,--listen=}'[listen address]:addr:' \
  '(-b --browser)'{-b,--browser}'[open browser on start]' \
  '(-e --execute)'{-e+,--execute=}'[execute command]:cmd:' \
  '(--long-description)--long-description[render long_description]' \
  '(--strict)--strict[strict mode]' \
  '(-w --watch)*'{-w+,--watch=}'[watch path]:path:_files' \
  '(--css)--css=[CSS file]:file:_files -g "*.css"' \
  '(--allowed-hosts)--allowed-hosts=[allowed hosts csv]:list:' \
  '*: :_files -g "*.rst *.txt"' && ret=0

return ret
