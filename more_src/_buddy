#compdef buddy
# Documentation: https://man.archlinux.org/search?q=buddy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'workspaces:list/show workspaces'
  'projects:manage projects'
  'pipelines:manage pipelines (list/show/run/retry/cancel)'
  'executions:manage pipeline executions'
  'actions:list/show pipeline actions'
  'variables:manage variables'
  'permissions:manage permissions'
  'members:manage workspace members'
  'integrations:manage integrations'
  'tokens:manage API tokens'
  'webhooks:manage webhooks'
  'environments:manage environments'
  'sso:manage SSO settings'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[output JSON]' \
  '(-t --token)'{-t+,--token=}'[Buddy auth token]:token:' \
  '(-u --url)'{-u+,--url=}'[base API URL]:url:' \
  '(-w --workspace)'{-w+,--workspace=}'[workspace name]:workspace:' \
  '(-p --project)'{-p+,--project=}'[project name]:project:' \
  '(-l --pipeline)'{-l+,--pipeline=}'[pipeline id]:id:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'buddy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pipelines)
        local -a pl_subs=(
          'list:list pipelines'
          'show:show pipeline details'
          'run:run a pipeline'
          'retry:retry the last failed execution'
          'cancel:cancel running execution'
          'create:create a pipeline'
          'update:update a pipeline'
          'delete:delete a pipeline'
        )
        _describe -t plcmds 'pipelines subcommand' pl_subs && ret=0
        _arguments \
          '--branch=[branch to run]:branch:' \
          '--revision=[revision to run]:rev:' \
          '--wait[wait for completion]' \
          '--comment=[run comment]:comment:' && ret=0 ;;
      (executions)
        _arguments \
          '*::sub:(list show retry cancel)' \
          '--logs[include action logs]' && ret=0 ;;
      (projects)
        _arguments '*::sub:(list show create update delete archive unarchive)' && ret=0 ;;
      (workspaces|members|tokens|webhooks|environments|sso|integrations|actions|variables|permissions)
        _arguments '*::sub:(list show create update delete)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
