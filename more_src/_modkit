#compdef modkit
# Documentation: https://nanoporetech.github.io/modkit/intro_pileup.html
# modkit - tools for working with modified bases from Oxford Nanopore

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--modified-bases=[base modifications to analyze]:mods' \
  '--reference=[reference FASTA]:file:_files' \
  '--log-filepath=[log output file]:file:_files' \
  '--bgzf[output bgzf compressed]' \
  '--preload-references[preload references for transcriptome modBAM]' \
  '--cpg[narrow output to reference CpG dinucleotides]' \
  '--combine-strands[sum counts across complementary strands]' \
  '--combine-mods[binary modified/unmodified counts]' \
  '--motif=[filter to DNA motif with offset]:motif' \
  '--include-bed=[restrict to BED positions]:file:_files' \
  '--phased[partition reads by HP tag]' \
  '--high-depth[allow extremely high depth]' \
  '--bedrmod[output bedRMod format]' \
  '1:subcommand:(pileup adjust-mods update-tags sample-probs summary motif-bed extract repair validate dmr entropy localize stats modbam)' \
  '*::args:_files' && ret=0

return ret
