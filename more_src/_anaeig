#compdef anaeig gmx-anaeig
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-anaeig.html
# Analyze eigenvectors from covariance matrices or normal mode analysis

local ret=1

_arguments -s -S \
  '-v+[input eigenvector trajectory]:trr file:_files -g "*.(trr|cpt|tng|h5md)"' \
  '-v2+[second eigenvector file for comparison]:trr file:_files -g "*.(trr|cpt|tng|h5md)"' \
  '-f+[trajectory file for analysis]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[structure file with mass data]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-eig+[eigenvalues file]:xvg file:_files -g "*.xvg"' \
  '-eig2+[second eigenvalues file]:xvg file:_files -g "*.xvg"' \
  '-comp+[output vector components per atom]:xvg file:_files -g "*.xvg"' \
  '-rmsf+[output RMS fluctuation per atom]:xvg file:_files -g "*.xvg"' \
  '-proj+[output trajectory projections on eigenvectors]:xvg file:_files -g "*.xvg"' \
  '-2d+[output 2D projection data]:xvg file:_files -g "*.xvg"' \
  '-3d+[output 3D projection structure]:structure:_files -g "*.(gro|g96|pdb)"' \
  '-filt+[output filtered trajectory]:trajectory:_files -g "*.(xtc|trr|gro|g96|pdb)"' \
  '-extr+[output extreme projections]:structure:_files -g "*.(gro|g96|pdb)"' \
  '-over+[output subspace overlap values]:xvg file:_files -g "*.xvg"' \
  '-inpr+[output inner-product matrix]:xpm file:_files -g "*.xpm"' \
  '-b+[first frame ps]:time:' \
  '-e+[last frame ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-first+[first eigenvector index]:n:' \
  '-last+[last eigenvector index]:n:' \
  '-skip+[analyze every nth frame]:n:' \
  '-max+[maximum projection value]:value:' \
  '-nframes+[output frame count for extremes]:n:' \
  '-temp+[temperature for entropy]:value:' \
  '-nevskip+[eigenvalues to skip for entropy]:n:' \
  '-w[view output files]' \
  '-split[split projections at zero time]' \
  '-entropy[calculate entropy estimates]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
