#compdef rclone-cli2
# Documentation: https://man.archlinux.org/search?q=rclone-cli2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'about:show storage statistics'
  'authorize:remote authorization helper'
  'backend:run backend-specific command'
  'bisync:bidirectional sync'
  'cat:concat object contents'
  'check:check sources match destination'
  'checksum:checksum files'
  'cleanup:clean up trash'
  'completion:print shell completion'
  'config:configure remotes'
  'copy:copy files (by content not modtime)'
  'copyto:copy files to a single dest'
  'copyurl:copy URL to remote'
  'cryptcheck:check crypted files match'
  'cryptdecode:cryptdecode encrypted file names'
  'dedupe:remove duplicate files'
  'delete:delete files'
  'deletefile:delete a single file'
  'gendocs:generate Markdown docs'
  'genautocomplete:generate shell completion'
  'hashsum:produce hash for objects'
  'help:show help'
  'link:generate public link'
  'listremotes:list configured remotes'
  'ls:list objects'
  'lsd:list directories'
  'lsf:list in custom format'
  'lsjson:list as JSON'
  'lsl:list with size and modtime'
  'md5sum:produce MD5 of files'
  'mkdir:make directory'
  'mount:mount remote as FUSE'
  'move:move files'
  'moveto:move single file or dir'
  'ncdu:explore remote like ncdu'
  'nfsmount:mount via NFS'
  'obscure:obscure password'
  'purge:remove path and all its contents'
  'rc:run command via rc API'
  'rcat:copy stdin to remote'
  'rcd:run rclone daemon'
  'rmdir:remove empty directory'
  'rmdirs:remove empty directories'
  'selfupdate:update rclone itself'
  'serve:serve remote over HTTP/SFTP/etc'
  'settier:change storage class'
  'sha1sum:produce SHA1'
  'size:size of all objects'
  'sync:sync source to dest'
  'test:test commands'
  'touch:create new file or set modtime'
  'tree:list contents in tree-like format'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--config=[file]:file:_files' \
  '*--auto-confirm[auto confirm]' \
  '*--ask-password=[ask password]:b:(true false)' \
  '*--bind=[local IP]:ip:' \
  '*--ca-cert=[file]:file:_files' \
  '*--checkers=[n]:n:' \
  '*--client-cert=[file]:file:_files' \
  '*--client-key=[file]:file:_files' \
  '*--contimeout=[duration]:t:' \
  '*--copy-links[follow symlinks]' \
  '*-L[follow symlinks]' \
  '*--cpuprofile=[file]:file:_files' \
  '*--cutoff-mode=[mode]:m:(hard soft cautious)' \
  '*--default-time=[time]:t:' \
  '*--delete-after[delete after]' \
  '*--delete-before[delete before]' \
  '*--delete-during[delete during]' \
  '*--delete-excluded[delete excluded]' \
  '*--disable=[features csv]:list:' \
  '*--disable-http-keep-alives[no keep-alive]' \
  '*--disable-http2[no HTTP/2]' \
  '*-n[dry run]' \
  '*--dry-run[dry run]' \
  '*--dscp=[priority]:p:' \
  '*--dump=[flags]:f:(headers bodies requests responses auth filters goroutines openfiles mapper)' \
  '*--dump-bodies[dump bodies]' \
  '*--dump-headers[dump headers]' \
  '*--exclude=[pattern]:p:' \
  '*--exclude-from=[file]:file:_files' \
  '*--exclude-if-present=[file]:f:' \
  '*--expect-continue-timeout=[duration]:t:' \
  '*--fast-list[recursive listing]' \
  '*--filter=[rule]:r:' \
  '*--filter-from=[file]:file:_files' \
  '*--files-from=[file]:file:_files' \
  '*--files-from-raw=[file]:file:_files' \
  '*--header=[header]:h:' \
  '*--header-download=[header]:h:' \
  '*--header-upload=[header]:h:' \
  '*--human-readable[human readable]' \
  '*--ignore-case[case insensitive]' \
  '*--ignore-case-sync[case insensitive sync]' \
  '*--ignore-checksum[no checksum]' \
  '*--ignore-errors[ignore errors]' \
  '*--ignore-existing[skip existing]' \
  '*--ignore-size[no size check]' \
  '*--ignore-times[no time check]' \
  '*-I[no time check]' \
  '*--immutable[treat dest as immutable]' \
  '*--include=[pattern]:p:' \
  '*--include-from=[file]:file:_files' \
  '*--inplace[inplace upload]' \
  '*--interactive[interactive]' \
  '*-i[interactive]' \
  '*--kv-lock-time=[duration]:t:' \
  '*--log-file=[file]:file:_files' \
  '*--log-format=[format csv]:list:(date time microseconds shortfile longfile longprefix shortprefix nolevel)' \
  '*--log-level=[level]:l:(EMERGENCY ALERT CRITICAL ERROR WARNING NOTICE INFO DEBUG)' \
  '*--log-systemd[systemd format]' \
  '*--low-level-retries=[n]:n:' \
  '*--max-age=[age]:a:' \
  '*--max-backlog=[n]:n:' \
  '*--max-buffer-memory=[size]:s:' \
  '*--max-connections=[n]:n:' \
  '*--max-delete=[n]:n:' \
  '*--max-delete-size=[size]:s:' \
  '*--max-depth=[n]:n:' \
  '*--max-duration=[duration]:t:' \
  '*--max-size=[size]:s:' \
  '*--max-stats-groups=[n]:n:' \
  '*--max-transfer=[size]:s:' \
  '*--memprofile=[file]:file:_files' \
  '*--metadata-exclude=[pattern]:p:' \
  '*--metadata-exclude-from=[file]:file:_files' \
  '*--metadata-filter=[pattern]:p:' \
  '*--metadata-filter-from=[file]:file:_files' \
  '*--metadata-include=[pattern]:p:' \
  '*--metadata-include-from=[file]:file:_files' \
  '*--metadata-set=[k=v]:v:' \
  '*--min-age=[age]:a:' \
  '*--min-size=[size]:s:' \
  '*--modify-window=[duration]:t:' \
  '*--multi-thread-cutoff=[size]:s:' \
  '*--multi-thread-streams=[n]:n:' \
  '*--multi-thread-write-buffer-size=[size]:s:' \
  '*--no-check-certificate[no cert check]' \
  '*--no-check-dest[no dest check]' \
  '*--no-console[no console]' \
  '*--no-gzip-encoding[no gzip]' \
  '*--no-traverse[no traverse]' \
  '*--no-unicode-normalization[no unicode normalization]' \
  '*--no-update-modtime[no update modtime]' \
  '*--no-update-dir-modtime[no update dir modtime]' \
  '*--order-by=[order]:o:' \
  '*-P[show progress]' \
  '*--progress[show progress]' \
  '*--progress-terminal-title[progress in title]' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*--rc[run rc]' \
  '*--rc-addr=[addr]:a:' \
  '*--rc-allow-origin=[origin]:o:' \
  '*--rc-baseurl=[url]:url:' \
  '*--rc-cert=[file]:file:_files' \
  '*--rc-client-ca=[file]:file:_files' \
  '*--rc-enable-metrics[enable metrics]' \
  '*--rc-files=[dir]:dir:_files -/' \
  '*--rc-htpasswd=[file]:file:_files' \
  '*--rc-job-expire-duration=[duration]:t:' \
  '*--rc-job-expire-interval=[duration]:t:' \
  '*--rc-key=[file]:file:_files' \
  '*--rc-max-header-bytes=[n]:n:' \
  '*--rc-min-tls-version=[v]:v:' \
  '*--rc-no-auth[no auth]' \
  '*--rc-pass=[pass]:p:' \
  '*--rc-realm=[realm]:r:' \
  '*--rc-serve[serve]' \
  '*--rc-server-read-timeout=[t]:t:' \
  '*--rc-server-write-timeout=[t]:t:' \
  '*--rc-template=[file]:file:_files' \
  '*--rc-user=[user]:u:_users' \
  '*--rc-web-fetch-url=[url]:url:' \
  '*--rc-web-gui[web GUI]' \
  '*--rc-web-gui-force-update[force update]' \
  '*--rc-web-gui-no-open-browser[no browser]' \
  '*--rc-web-gui-update[update]' \
  '*--refresh-times[refresh times]' \
  '*--retries=[n]:n:' \
  '*--retries-sleep=[duration]:t:' \
  '*--server-side-across-configs[allow server-side across configs]' \
  '*--size-only[size only]' \
  '*--stats=[duration]:t:' \
  '*--stats-file-name-length=[n]:n:' \
  '*--stats-log-level=[level]:l:' \
  '*--stats-one-line[one line stats]' \
  '*--stats-one-line-date[stats with date]' \
  '*--stats-one-line-date-format=[format]:f:' \
  '*--stats-unit=[unit]:u:(bits bytes)' \
  '*--streaming-upload-cutoff=[size]:s:' \
  '*--suffix=[suffix]:s:' \
  '*--suffix-keep-extension[keep ext]' \
  '*--syslog[log to syslog]' \
  '*--syslog-facility=[facility]:f:' \
  '*--temp-dir=[dir]:dir:_files -/' \
  '*--timeout=[duration]:t:' \
  '*--tpslimit=[n]:n:' \
  '*--tpslimit-burst=[n]:n:' \
  '*--track-renames[track renames]' \
  '*--track-renames-strategy=[strategy]:s:(hash modtime leaf)' \
  '*--transfers=[n]:n:' \
  '*--update[skip newer on dest]' \
  '*-u[skip newer]' \
  '*--use-cookies[use cookies]' \
  '*--use-json-log[JSON logging]' \
  '*--use-mmap[use mmap]' \
  '*--use-server-modtime[server modtime]' \
  '*--user-agent=[ua]:ua:' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rclone command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '1:subcommand:(create delete disconnect dump edit file paths password providers reconnect redacted show touch update userinfo)' \
          '*: :' && ret=0 ;;
      (serve)
        _arguments \
          '1:protocol:(dlna docker ftp http nfs restic s3 sftp webdav)' \
          '*: :' && ret=0 ;;
      (test)
        _arguments \
          '1:subcommand:(changenotify histogram info makefile makefiles memory)' \
          '*: :' && ret=0 ;;
      (mount|nfsmount)
        _arguments \
          '(--allow-non-empty)--allow-non-empty[allow mount over non-empty]' \
          '(--allow-other)--allow-other[allow other users]' \
          '(--allow-root)--allow-root[allow root]' \
          '(--async-read)--async-read=[b]:b:(true false)' \
          '(--cache-dir)--cache-dir=[dir]:dir:_files -/' \
          '(--daemon)--daemon[run as daemon]' \
          '(--default-permissions)--default-permissions[default perms]' \
          '(--read-only)--read-only[readonly]' \
          '(--vfs-cache-mode)--vfs-cache-mode=[mode]:m:(off minimal writes full)' \
          '*: :_files -/' && ret=0 ;;
      (completion|genautocomplete)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
