#compdef cssnano

_arguments -s \
  '(-s --sourcemap)'{-s,--sourcemap}'[generate sourcemap]' \
  '--safe[safe optimisations only]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-autoprefixer[disable autoprefixer]' \
  '--no-calc[disable calc]' \
  '--no-colormin[disable colormin]' \
  '--no-convertValues[disable convertValues]' \
  '--no-core[disable core]' \
  '--no-discardComments[disable discardComments]' \
  '--no-discardDuplicates[disable discardDuplicates]' \
  '--no-discardEmpty[disable discardEmpty]' \
  '--no-discardUnused[disable discardUnused]' \
  '--no-filterOptimiser[disable filterOptimiser]' \
  '--no-filterPlugins[disable filterPlugins]' \
  '--no-functionOptimiser[disable functionOptimiser]' \
  '--no-mergeIdents[disable mergeIdents]' \
  '--no-mergeLonghand[disable mergeLonghand]' \
  '--no-mergeRules[disable mergeRules]' \
  '--no-minifyFontValues[disable minifyFontValues]' \
  '--no-minifyParams[disable minifyParams]' \
  '--no-minifySelectors[disable minifySelectors]' \
  '--no-normalizeUrl[disable normalizeUrl]' \
  '--no-orderedValues[disable orderedValues]' \
  '--no-reduceIdents[disable reduceIdents]' \
  '--no-reduceTransforms[disable reduceTransforms]' \
  '--no-singleCharset[disable singleCharset]' \
  '--no-styleCache[disable styleCache]' \
  '--no-svgo[disable svgo]' \
  '--no-uniqueSelectors[disable uniqueSelectors]' \
  '--no-zindex[disable zindex]' \
  '1:input:_files -g "*.css"' \
  '2:output:_files -g "*.css"'
