#compdef radvd-utils
# Documentation: https://man.archlinux.org/search?q=radvd-utils
# Reference accessed: 2026-05-16

# radvd-utils umbrella for radvdump and friends
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'radvdump:dump RA messages on the wire'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'radvd-utils command' commands && ret=0 ;;
esac
return ret
