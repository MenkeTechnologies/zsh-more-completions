#compdef sgrep

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-c[count results]' \
  '-d[output innermost regions only]' \
  '-e+[expression]:expression' \
  '-f+[read expression from file]:file:_files' \
  '-g[output regions sorted by start position]' \
  '-i[ignore case]' \
  '-l[long output format]' \
  '-n[no default output]' \
  '-N[preprocessing]' \
  '-o+[output format]:format' \
  '-p[preprocessor command]:command' \
  '-P+[post-processor command]:command' \
  '-s+[scanner]:scanner' \
  '-t[show statistics]' \
  '-T[show only statistics]' \
  '*:file:_files' && return 0
