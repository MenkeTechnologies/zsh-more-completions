#compdef sgrep
# Documentation: https://www.cs.helsinki.fi/u/jjaakkol/sgrepman.html
# Reference accessed: 2026-05-21
# Verified: upstream sgrep manual at the URL above.

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '(- *)-C[display copyright notice]' \
  '-a[act as a filter: display matching regions]' \
  '-c[display only the count of matching regions]' \
  '-d[display each matching region once even if nested]' \
  '-D[verbose progress output (debugging)]' \
  '-e+[search input for specified expression]:expression' \
  '-f+[read region expression from file]:file:_files' \
  '-i[ignore case in phrases]' \
  '-l[long output format with region metadata]' \
  '-N[do not add newline after last output region]' \
  '-n[suppress reading default config files]' \
  '-O+[read output format from file]:file:_files' \
  '-o+[set custom output format]:format' \
  '-P[display preprocessed expression without executing]' \
  '-p+[apply preprocessor to expression]:command' \
  '-S[stream mode: regions may cross file boundaries]' \
  '-s[short output format (default)]' \
  '-T[display execution statistics]' \
  '-t[display time usage]' \
  '*:file:_files' && return 0
