#compdef dasm
# Documentation: https://github.com/dasm-assembler/dasm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-?[show help]' \
  '-V[show version]' \
  '-T+[symbol table sort]:s:(0 1 2 3)' \
  '-D+[define symbol]:macro:' \
  '-M+[macro define]:macro:' \
  '-E+[error format]:f:(0 1 2)' \
  '-I+[include path]:dir:_files -/' \
  '-d+[debug]:n:' \
  '-l+[list file]:file:_files' \
  '-L+[full list file]:file:_files' \
  '-o+[output file]:file:_files' \
  '-p+[max passes]:n:' \
  '-P+[print summary]:n:' \
  '-s+[symbols file]:file:_files' \
  '-S+[print symbols]:m:(0 1 2)' \
  '-v+[verbose level]:n:(0 1 2 3 4 5)' \
  '-f+[output format]:f:(1 2 3)' \
  '-r+[range table]:n:' \
  '-mF8[F8]' \
  '-m6502[6502]' \
  '-m6803[6803]' \
  '-m6502d[6502 disassembly]' \
  '-mHD6303[HD6303]' \
  '-m68705[68705]' \
  '-m68HC11[68HC11]' \
  '*: :_files -g "*.asm *.s *.dasm"' && ret=0

return ret
