#compdef swaggerhub
# Documentation: https://github.com/SmartBear/swaggerhub-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'api\:create:create a new API/version'
  'api\:delete:remove an API or version'
  'api\:get:fetch API definition'
  'api\:publish:publish an API version'
  'api\:setdefault:set default API version'
  'api\:unpublish:unpublish an API version'
  'api\:update:update an API'
  'api\:validate:get validation results'
  'domain\:create:create a domain'
  'domain\:delete:delete a domain'
  'domain\:get:get a domain'
  'domain\:publish:publish a domain'
  'domain\:setdefault:set default domain version'
  'domain\:unpublish:unpublish a domain'
  'domain\:update:update a domain'
  'integration\:create:create an integration'
  'integration\:delete:delete an integration'
  'integration\:execute:execute an integration'
  'integration\:get:retrieve an integration'
  'integration\:list:list integrations'
  'integration\:update:update an integration'
  'project\:create:create a project'
  'project\:delete:delete a project'
  'project\:get:get a project'
  'project\:list:list projects'
  'spectral\:upload:upload spectral ruleset'
  'spectral\:download:download spectral ruleset'
  'configure:configure CLI credentials'
  'plugins:list installed plugins'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-v,--version}'[Show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t cmds 'swaggerhub command' commands && ret=0 ;;
  args)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-f --force)'{-f,--force}'[skip confirmation prompts]' \
      '(-j --json)'{-j,--json}'[output in JSON]' \
      '--file=[input file]:file:_files' \
      '*::arg:' && ret=0
    ;;
esac

return ret
