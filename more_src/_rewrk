#compdef rewrk

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[number of connections]:connections:' \
  '--connections=[number of connections]:connections:' \
  '-t+[number of threads]:threads:' \
  '--threads=[number of threads]:threads:' \
  '-d+[duration]:duration:' \
  '--duration=[duration]:duration:' \
  '-H+[custom header]:header:' \
  '--header=[custom header]:header:' \
  '-m+[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--method=[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-b+[request body]:body:' \
  '--body=[request body]:body:' \
  '--pct[show latency percentiles]' \
  '--json[output JSON results]' \
  '--http2[use HTTP/2]' \
  '1:url:' && ret=0

return ret
