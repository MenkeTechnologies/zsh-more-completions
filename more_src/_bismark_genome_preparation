#compdef bismark_genome_preparation
# Documentation: https://github.com/FelixKrueger/Bismark/blob/master/bismark_genome_preparation
# bismark_genome_preparation: prepare bisulfite genome indexes for Bismark

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--verbose[print verbose output for details or debugging]' \
  '--path_to_aligner[full path to Bowtie2, HISAT2, or minimap2 folder]:dir:_files -/' \
  '--bowtie2[create bisulfite indexes for Bowtie 2]' \
  '--hisat2[create bisulfite indexes for HISAT2]' \
  '(--minimap2 --mm2)'{--minimap2,--mm2}'[create bisulfite indexes for minimap2]' \
  '--parallel[use several threads per indexing process]:n:' \
  '--single_fasta[write single-entry FastA files instead of one multi-FastA per chromosome]' \
  '--genomic_composition[calculate and write genomic sequence composition table]' \
  '--slam[transform T to C / A to G instead of in-silico bisulfite conversion]' \
  '--large-index[force generated index to be large]' \
  '*:genome folder:_files -/' && ret=0

return ret
