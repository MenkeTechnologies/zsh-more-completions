#compdef wiresteward
# Documentation: https://github.com/utilitywarehouse/wiresteward
# wiresteward - OAuth2 aware WireGuard peer manager (agent and server)

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-agent[run application in agent mode]' \
  '-server[run application in server mode]' \
  '-config=[config file path]:file:_files' \
  '-device-type=[network device type for the agent]:type:(tun wireguard)' \
  '-agent-listen-address=[address where the agent HTTP server runs]:addr:' \
  '-metrics-address=[metrics server address (server mode)]:addr:' \
  '-log-level=[log level]:level:(debug error)' \
  '-allow-public-routes[allow non-RFC1918/RFC4193 CIDRs]' \
  '-version[print application version]' && ret=0

return ret
