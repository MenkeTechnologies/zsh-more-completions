#compdef distrobox

# Zsh completion for Distrobox - use any Linux distro in terminal via containers

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'assemble:Create and configure containers from a manifest file'
  'create:Create a new distrobox container'
  'enter:Enter a distrobox container'
  'ephemeral:Create a temporary container that is removed on exit'
  'export:Export apps, binaries, or services from the container'
  'generate-entry:Generate a desktop entry for a container'
  'list:List existing distrobox containers'
  'rm:Remove a distrobox container'
  'stop:Stop a running distrobox container'
  'upgrade:Upgrade one or more distrobox containers'
  'help:Show help'
)

_distrobox_containers() {
  local -a containers
  containers=(${(f)"$(distrobox list --no-color 2>/dev/null | tail -n +2 | awk '{print $3}')"})
  compadd -a containers
}

_distrobox_images() {
  local -a images
  images=(${(f)"$(podman images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null || docker images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)"})
  compadd -a images
}

_arguments -s -S -C \
  '--help[Show help]' \
  '--version[Show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'distrobox command' commands && ret=0
    ;;
  args)
    case $words[1] in
      assemble)
        _arguments -s -S \
          '--file[Manifest file path]:manifest file:_files' \
          '--delete[Delete containers defined in manifest]' \
          '--replace[Replace existing containers]' \
          '--help[Show help]' && ret=0
        ;;
      create)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:name' \
          '(-i --image)'{-i,--image}'[Image to use]:image:_distrobox_images' \
          '(-c --clone)'{-c,--clone}'[Clone an existing container]:container:_distrobox_containers' \
          '(-H --home)'{-H,--home}'[Custom home directory]:directory:_files -/' \
          '(-v --volume)'{-v,--volume}'[Additional volume to mount]:volume' \
          '--additional-flags[Additional flags to pass to the container manager]:flags' \
          '--additional-packages[Additional packages to install]:packages' \
          '--init-hooks[Commands to execute inside container during initialization]:hooks' \
          '--pre-init-hooks[Commands to execute inside container before initialization]:hooks' \
          '--init[Use container init system (e.g. systemd)]' \
          '--nvidia[Enable NVIDIA GPU integration]' \
          '--root[Launch container as root]' \
          '--unshare-all[Unshare all namespaces]' \
          '--unshare-devsys[Do not share host /dev and /sys]' \
          '--unshare-groups[Do not share host user groups]' \
          '--unshare-ipc[Do not share host IPC namespace]' \
          '--unshare-netns[Do not share host network namespace]' \
          '--unshare-process[Do not share host PID namespace]' \
          '--compatibility[Show compatibility with older versions]' \
          '--absolutely-disable-root-password-i-am-really-positively-sure[Remove root password from container]' \
          '(-Y --yes)'{-Y,--yes}'[Non-interactive mode, answer yes to all questions]' \
          '--dry-run[Only print the container manager command]' \
          '--help[Show help]' && ret=0
        ;;
      enter)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:container:_distrobox_containers' \
          '--no-workdir[Do not change to the host working directory]' \
          '--additional-flags[Additional flags to pass to the container manager]:flags' \
          '(-e --exec)'{-e,--exec}'[Command to execute]:command:_command_names' \
          '--dry-run[Only print the container manager command]' \
          '--help[Show help]' \
          ':container:_distrobox_containers' \
          '*:command' && ret=0
        ;;
      ephemeral)
        _arguments -s -S \
          '(-i --image)'{-i,--image}'[Image to use]:image:_distrobox_images' \
          '(-n --name)'{-n,--name}'[Container name]:name' \
          '--root[Launch container as root]' \
          '--additional-flags[Additional flags to pass]:flags' \
          '--dry-run[Only print the container manager command]' \
          '--help[Show help]' \
          '*:command' && ret=0
        ;;
      export)
        _arguments -s -S \
          '--app[Export an application]:application' \
          '--bin[Export a binary]:binary:_files' \
          '--service[Export a service]:service' \
          '--delete[Delete an exported entry]' \
          '--export-label[Label for the exported app]:label' \
          '--export-path[Export path for binaries]:path:_files -/' \
          '--extra-flags[Extra flags for the exported app]:flags' \
          '--sudo[Export with sudo prefix]' \
          '--help[Show help]' && ret=0
        ;;
      generate-entry)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:container:_distrobox_containers' \
          '--delete[Delete generated entry]' \
          '--icon[Icon for the entry]:icon file:_files' \
          '--help[Show help]' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          '--no-color[Disable color output]' \
          '--verbose[Show more information]' \
          '--help[Show help]' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:container:_distrobox_containers' \
          '(-f --force)'{-f,--force}'[Force removal]' \
          '(-a --all)'{-a,--all}'[Remove all containers]' \
          '(-Y --yes)'{-Y,--yes}'[Non-interactive mode]' \
          '--dry-run[Only print the container manager command]' \
          '--help[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
      stop)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:container:_distrobox_containers' \
          '(-a --all)'{-a,--all}'[Stop all containers]' \
          '(-Y --yes)'{-Y,--yes}'[Non-interactive mode]' \
          '--dry-run[Only print the container manager command]' \
          '--help[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:container:_distrobox_containers' \
          '(-a --all)'{-a,--all}'[Upgrade all containers]' \
          '--dry-run[Only print the container manager command]' \
          '--help[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
    esac
    ;;
esac

return ret
