#compdef ftabpar
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/ftabpar.txt
# Copy the value of a FITS table element to the parameter file

local ret=1

_arguments -s \
  "fitsfile=[input FITS table file]:file:_files" \
  "column=[column name]:" \
  "row=[row number]:" \
  "element=[vector element number]:" \
  "*:FITS file:_files" && ret=0

return ret
