#compdef getparty

# vbauerster/getparty — HTTP multipart downloader (`getparty.go` go-flags)

local ret=1
_arguments -s -S \
  '-p+[parallel parts]:n:' \
  '-r+[max retries per part (0=infinite)]:n:' \
  '--max-redirect+[max HTTP redirects (0=infinite)]:n:' \
  '-t+[initial buffer timeout (seconds)]:sec:' \
  '-b+[buffer KiB]:kb:(2 4 8 16)' \
  '-l+[speed limit level (0 none; 1–5)]:lvl:(1 2 3 4 5)' \
  '-s+[resume session JSON file]:session:_files' \
  '-U+[User-Agent preset]:ua:(chrome firefox safari edge)' \
  '--username=[HTTP basic user]:user:' \
  '--password=[HTTP basic password]:password:' \
  '*-H+[extra header key:value]:header:' \
  '-x+[HTTP/HTTPS proxy]:proxy:' \
  '-q[quiet: no progress UI]' \
  '-d[debug to stderr]' \
  '-v[print version and exit]' \
  '-c+[custom root CA bundle]:certs:_files' \
  '--no-check-cert[skip TLS verification]' \
  '-o+[output filename]:file:_files' \
  '-f[overwrite output]' \
  '--output-use-path[derive filename from URL path first]' \
  '-m+[mirror list file or -]:mirrors:_files' \
  '-g+[max concurrent mirror probes]:n:' \
  '--mirror-top+[keep top N mirrors]:n:' \
  '--mirror-pass+[mirror timing passes]:n:' \
  '1:URL:_urls' && ret=0
return ret
