#compdef conduit
# Documentation: https://gitlab.com/famedly/conduit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Conduit (famedly Matrix homeserver) reads its config from CONDUIT_CONFIG
# (path to TOML) or CONDUIT_* env vars; the binary itself exposes only help
# and version flags.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]'
