#compdef conduit
# Documentation: https://man.archlinux.org/search?q=conduit
# Reference accessed: 2026-05-16

# Zsh completion for conduit Matrix homeserver (famedly/conduit).
# Runtime configuration is via CONDUIT_CONFIG / CONDUIT_* env; CLI only exposes help/version.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]'
