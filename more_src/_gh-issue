#compdef gh-issue
# _gh-issue — GitHub gh issue subcommand alias (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-issue() {
    local -a sub=(
        'close:close an issue'
        'comment:add a comment to an issue'
        'create:create an issue'
        'delete:delete an issue'
        'develop:manage linked branch for an issue'
        'edit:edit an issue'
        'list:list issues'
        'lock:lock issue conversation'
        'pin:pin a repository issue'
        'reopen:reopen an issue'
        'status:show status of relevant issues'
        'transfer:transfer issue to another repo'
        'unlock:unlock issue conversation'
        'unpin:unpin an issue'
        'view:view an issue'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--repo=+[owner/name]:str:' \
        '-R+[owner/name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh-issue subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--assignee=+[assignee]:list:' \
                    '-a+[assignee]:list:' \
                    '--body=+[body]:str:' \
                    '-b+[body]:str:' \
                    '--body-file=+[body file]:file:_files' \
                    '-F+[body file]:file:_files' \
                    '--editor[open editor]' \
                    '-e[open editor]' \
                    '--label=+[label]:list:' \
                    '-l+[label]:list:' \
                    '--milestone=+[milestone]:str:' \
                    '-m+[milestone]:str:' \
                    '--project=+[project]:list:' \
                    '-p+[project]:list:' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '--recover=+[recover from file]:file:_files' \
                    '--template=+[template]:str:' \
                    '-T+[template]:str:' ;;
                list) _arguments \
                    '--app=+[app]:str:' \
                    '--assignee=+[assignee]:str:' \
                    '-a+[assignee]:str:' \
                    '--author=+[author]:str:' \
                    '-A+[author]:str:' \
                    '--json=+[json fields]:list:' \
                    '--label=+[label]:list:' \
                    '-l+[label]:list:' \
                    '--limit=+[max items]:n:' \
                    '-L+[max items]:n:' \
                    '--mention=+[mention]:str:' \
                    '--milestone=+[milestone]:str:' \
                    '-m+[milestone]:str:' \
                    '--search=+[search query]:str:' \
                    '-S+[search query]:str:' \
                    '--state=+[state]:s:(open closed all)' \
                    '-s+[state]:s:(open closed all)' \
                    '--web[open in browser]' \
                    '-w+[web]' ;;
                view|edit|close|comment|reopen|delete|lock|unlock|pin|unpin|transfer) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '*:issue-number:' ;;
                develop) _arguments \
                    '1:cmd:(create checkout list)' \
                    '*:arg:' ;;
                status) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_gh-issue "$@"
