#compdef taql
# Documentation: https://manpages.debian.org/testing/casacore-tools/taql.1.en.html
# Table Query Language interpreter for casacore tables (SQL-like select/sort/update).

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-s --style)'{-s,--style}'[define the TaQL style (default python; -s alone gives glish)]:style:(python glish base1c)' \
  '(-ps --printselect)'{-ps,--printselect}'[show the values of selected columns]' \
  '(-pm --printmeasure)'{-pm,--printmeasure}'[show values as formatted measures if possible]' \
  '(-pc --printcommand)'{-pc,--printcommand}'[show the expanded TaQL command]' \
  '(-pr --printrows)'{-pr,--printrows}'[show the number of rows selected, updated, etc]' \
  '*:taql command:' && ret=0

return ret
