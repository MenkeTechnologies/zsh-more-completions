#compdef ip-mroute
# Documentation: https://man.archlinux.org/man/ip-mroute.8.en
# ip mroute - multicast routing cache management

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip mroute command' \
      'show[list mroute cache entries]' \
      'to[destination multicast prefix]' 'from[IP source prefix]' \
      'iif[incoming interface]' 'table[multicast table id]' && ret=0
    ;;
esac

return ret
