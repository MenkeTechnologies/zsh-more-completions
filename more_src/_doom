#compdef doom
# Documentation: https://man.archlinux.org/search?q=doom
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sync:install missing packages and regenerate autoloads (alias: refresh, rs)'
  'install:install Doom Emacs initial files'
  'upgrade:upgrade Doom Emacs and packages (alias: up)'
  'doctor:diagnose issues with Doom Emacs'
  'env:regenerate Doom env file'
  'build:rebuild byte-compiled files (alias: b)'
  'purge:remove orphaned files'
  'clean:remove byte-compiled files'
  'compile:byte-compile all configs'
  'gc:run garbage collection over packages'
  'info:print environment info'
  'help:show help'
  'profile:profile selection commands'
  'package:package management'
  'run:execute a function'
  'ci:CI helpers'
  'make:project make helpers'
  'profiles:profiles management'
  'aot:compile native packages eagerly'
  'compile-native:native-compile packages'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '--profile=[profile name]:profile:' \
  '--ours[use local copies of files only]' \
  '(-y --yes)'{-y,--yes}'[answer yes to prompts]' \
  '(-n --no)'{-n,--no}'[answer no to prompts]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'doom command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sync|refresh|rs)
        _arguments \
          '(-u --update)'{-u,--update}'[also update]' \
          '(-p --prune)'{-p,--prune}'[remove unused packages]' \
          '(-e --aot)'{-e,--aot}'[native compile eagerly]' \
          '--profiles[regenerate profile loaders]' \
          '--no-rebuild[skip rebuild]' \
          '--no-envvar[skip env file regen]' && ret=0 ;;
      (upgrade|up)
        _arguments \
          '(-f --force)'{-f,--force}'[force upgrade]' \
          '(-p --packages)'{-p,--packages}'[only upgrade packages]' \
          '(-e --eager)'{-e,--eager}'[native compile eagerly]' && ret=0 ;;
      (env)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output env file path]:file:_files' \
          '--clear[delete env file]' && ret=0 ;;
      (build|b)
        _arguments \
          '(-r --recompile)'{-r,--recompile}'[recompile all]' \
          '(-c --clean)'{-c,--clean}'[clean then rebuild]' && ret=0 ;;
      (purge)
        _arguments \
          '(-g --no-regraft)'{-g,--no-regraft}'[do not regraft repos]' \
          '(-r --regraft)'{-r,--regraft}'[regraft repos]' \
          '(-e --elpa)'{-e,--elpa}'[remove ELPA packages]' \
          '(-b --builds)'{-b,--builds}'[remove builds]' \
          '(-l --lockfile)'{-l,--lockfile}'[clean lockfile]' \
          '(-o --orphans)'{-o,--orphans}'[remove orphans]' && ret=0 ;;
      (profile)
        _arguments \
          '*::sub:(create destroy list rebuild use)' && ret=0 ;;
    esac ;;
esac

return ret
