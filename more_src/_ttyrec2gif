#compdef ttyrec2gif
# Documentation: https://github.com/sugyan/ttyrec2gif
# ttyrec2gif - convert ttyrec to animated GIF

local ret=1

_arguments -s \
  '-in[ttyrec input file]:file:_files' \
  '-out[output animated GIF file name]:file:_files' \
  '-s[play speed]:speed' \
  '-row[terminal height in rows]:rows' \
  '-col[terminal width in columns]:cols' \
  '-noloop[play only once instead of looping]' && ret=0

return ret
