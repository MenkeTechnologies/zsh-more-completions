#compdef tippecanoe-decode tile-join tippecanoe-overzoom tippecanoe-json-tool
# Documentation: source-direct extraction from upstream
# felt/tippecanoe — per-binary `struct option long_options[]`
# tables + the dynamically-built getopt_str loop (each binary
# walks long_options[] and pushes val (+":" if required_argument)
# into the getopt short-string at runtime).
#   - decode.cpp:long_options       -> tippecanoe-decode
#   - tile-join.cpp:long_options    -> tile-join
#   - overzoom.cpp:long_options     -> tippecanoe-overzoom
#   - jsontool.cpp:long_options     -> tippecanoe-json-tool
# Per-binary source mapping decoded from the Makefile target
# block (e.g. `tippecanoe-decode: decode.o ...`).
# Reference accessed: 2026-05-30 via gh api.
# felt tippecanoe R161 — 4-stem multi-binary harvest of the
# tippecanoe sibling binaries shipped alongside the already-
# covered `tippecanoe` main binary in the corpus.  These are
# the post-build utilities for inspecting / joining / overzoom-
# ing / preprocessing the mbtiles and GeoJSON inputs that the
# main tippecanoe binary produces and consumes.  Sister tools
# to the heavily-covered geospatial family (gdaltransform,
# gdalwarp, gdaldem, ogrinfo, gdal_rasterize, gdal_translate,
# gdal_polygonize, gdal_grid, gdal_contour, gdaladdo,
# gdalbuildvrt, osmconvert, osmupdate, osmium-tool, osmosis,
# osm2pgsql).

case $service in

  tippecanoe-decode)
    _arguments -s -S \
      '(-s --projection)'{-s+,--projection=}'[reproject (EPSG:3857 or EPSG:4326)]:proj:(EPSG:3857 EPSG:4326)' \
      '(-F --fractional-coordinates)'{-F,--fractional-coordinates}'[emit fractional decoded coordinates]' \
      '(-I --integer-coordinates)'{-I,--integer-coordinates}'[emit integer coordinates]' \
      '(-z --maximum-zoom)'{-z+,--maximum-zoom=}'[stop decoding above this zoom]:z:' \
      '(-Z --minimum-zoom)'{-Z+,--minimum-zoom=}'[stop decoding below this zoom]:z:' \
      '*'{-l+,--layer=}'[only decode named layer (repeatable)]:layer:' \
      '(-c --tag-layer-and-zoom)'{-c,--tag-layer-and-zoom}'[tag each feature with its layer + zoom]' \
      '(-S --stats)'{-S,--stats}'[emit per-tile feature/byte statistics instead of GeoJSON]' \
      '(-f --force)'{-f,--force}'[overwrite existing output]' \
      '*'{-x+,--exclude-metadata-row=}'[skip metadata row]:row:' \
      '*'{-y+,--include=}'[only include features matching attribute]:attr:' \
      '1:input mbtiles or pmtiles:_files -g "*.(mbtiles|pmtiles)"' \
      '2:zoom:' \
      '3:tile-x:' \
      '4:tile-y:'
    ;;

  tile-join)
    _arguments -s -S \
      '(-o --output -e --output-to-directory)'{-o+,--output=}'[output .mbtiles or .pmtiles file]:file:_files' \
      '(-o --output -e --output-to-directory)'{-e+,--output-to-directory=}'[output directory tree of tiles]:dir:_files -/' \
      '(-f --force)'{-f,--force}'[overwrite existing output]' \
      '(-O --overzoom)'{-O,--overzoom}'[overzoom tiles to fill maximum-zoom]' \
      '(-b --buffer)'{-b+,--buffer=}'[tile buffer pixels]:px:' \
      '(-i --if-matched)'{-i,--if-matched}'[only emit tiles that match a join row]' \
      '(-A --attribution)'{-A+,--attribution=}'[attribution string]:str:' \
      '(-n --name)'{-n+,--name=}'[tileset name]:name:' \
      '(-N --description)'{-N+,--description=}'[tileset description]:desc:' \
      '*'{-p+,--prevent=}'[prevent named optimization]:opt:' \
      '*'{-c+,--csv=}'[join attributes from CSV]:csv:_files -g "*.csv"' \
      '*'{-x+,--exclude=}'[exclude attribute from output]:attr:' \
      '(-X --exclude-all)'{-X,--exclude-all}'[exclude all attributes]' \
      '*'{-y+,--include=}'[only include named attribute]:attr:' \
      '--exclude-all-tile-attributes[strip every attribute from tiles]' \
      '--exclude-all-tile-geometries[strip every geometry from tiles]' \
      '*'{-l+,--layer=}'[only include layer]:layer:' \
      '*'{-L+,--exclude-layer=}'[exclude layer]:layer:' \
      '(-q --quiet)'{-q,--quiet}'[suppress progress]' \
      '(-z --maximum-zoom)'{-z+,--maximum-zoom=}'[maximum output zoom]:z:' \
      '(-Z --minimum-zoom)'{-Z+,--minimum-zoom=}'[minimum output zoom]:z:' \
      '(-J --feature-filter-file)'{-J+,--feature-filter-file=}'[feature filter file]:file:_files' \
      '(-j --feature-filter)'{-j+,--feature-filter=}'[inline feature filter expression]:expr:' \
      '*'{-R+,--rename-layer=}'[rename layer (old:new)]:rename:' \
      '*'{-r+,--read-from=}'[read tile list from file]:file:_files' \
      '--use-attribute-for-id=[use named attribute as feature id]:attr:' \
      '--no-tile-size-limit[do not enforce the 500K-per-tile limit]' \
      '--no-tile-compression[emit uncompressed tiles]' \
      '--empty-csv-columns-are-null[treat empty CSV cells as JSON null]' \
      '--no-tile-stats[do not emit per-tile stats in tileset metadata]' \
      '--tile-stats-attributes-limit=[limit on attribute count in tile stats]:n:' \
      '--tile-stats-sample-values-limit=[limit on sampled values in tile stats]:n:' \
      '--tile-stats-values-limit=[limit on enumerated values in tile stats]:n:' \
      '--unidecode-data=[unidecode data file]:file:_files' \
      '*:input .mbtiles or .pmtiles:_files -g "*.(mbtiles|pmtiles)"'
    ;;

  tippecanoe-overzoom)
    _arguments -s -S \
      '*'{-y+,--include=}'[only emit named attribute]:attr:' \
      '*'{-x+,--exclude=}'[exclude named attribute]:attr:' \
      '*--exclude-prefix=[exclude attributes by name prefix]:prefix:' \
      '(-d --full-detail)'{-d+,--full-detail=}'[grid bits of detail (default 12)]:bits:' \
      '(-b --buffer)'{-b+,--buffer=}'[tile buffer pixels]:px:' \
      '(-o --output)'{-o+,--output=}'[output tile]:file:_files' \
      '(-m --filter-points-multiplier)'{-m,--filter-points-multiplier}'[filter-points multiplier]' \
      '(-j --feature-filter)'{-j+,--feature-filter=}'[inline feature filter expression]:expr:' \
      '(-J --feature-filter-file)'{-J+,--feature-filter-file=}'[feature filter file]:file:_files' \
      '--preserve-input-order[preserve original feature order across the overzoom]' \
      '*'{-E+,--accumulate-attribute=}'[accumulator:attribute (e.g. sum:foo, mean:bar)]:expr:' \
      '--unidecode-data=[unidecode data file]:file:_files' \
      '(-S --line-simplification)'{-S+,--line-simplification=}'[line-simplification distance]:dist:' \
      '--tiny-polygon-size=[tiny-polygon size cutoff]:size:' \
      '(-t --source-tile)'{-t+,--source-tile=}'[source tile id (z/x/y)]:zxy:' \
      '--no-tile-compression[emit uncompressed output tile]' \
      '--deduplicate-by-id[deduplicate features by id]' \
      '*:positional args: source.mbtiles src.z/x/y dst.z/x/y'
    ;;

  tippecanoe-json-tool)
    _arguments -s -S \
      '(-w --wrap)'{-w,--wrap}'[wrap each feature into a FeatureCollection]' \
      '(-e --extract)'{-e+,--extract=}'[extract features by attribute name]:attr:' \
      '*'{-c+,--csv=}'[join attributes from CSV]:csv:_files -g "*.csv"' \
      '--empty-csv-columns-are-null[treat empty CSV cells as JSON null]' \
      '*'{-p+,--prevent=}'[prevent named optimization]:opt:' \
      '*:input .geojson|.json:_files -g "*.(geojson|json)"'
    ;;

esac
