#compdef pktriot
# Documentation: https://docs.packetriot.com/packetriot_cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--config=[custom configuration file location]:file:_files' \
  '--host=[override default service endpoint]:host:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'configure:set up client authentication and region'
      'edit:modify tunnel settings'
      'info:display tunnel hostname, server, and IP'
      'check:run diagnostics for connectivity and authentication'
      'start:launch persistent tunnel with saved traffic rules'
      'http:instant HTTP/S hosting'
      'tcp:quick TCP port forwarding'
      'inspect:debug HTTP requests via built-in web interface'
      'tunnel:manage persistent traffic rules'
      'unmanaged:manage Spokes-server unmanaged client'
      'ports:port mapping (Spokes only)'
      'proxies:configure proxies (Spokes only)'
      'windows:Windows service install/uninstall'
      'version:print version'
    )
    _describe -t commands 'pktriot command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
