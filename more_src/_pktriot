#compdef pktriot

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'setup:link agent to account'
      'http:run HTTP tunnel'
      'tcp:run TCP tunnel'
      'info:print agent info'
      'client:client utilities'
      'upgrade:self-upgrade binary'
      'version:print version'
    )
    _describe -t commands 'pktriot command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-c --config)'{-c,--config}'=[config path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
