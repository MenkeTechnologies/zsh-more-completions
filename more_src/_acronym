#compdef acronym
# Documentation: https://man.archlinux.org/search?q=acronym
# Reference accessed: 2026-05-16

_arguments -s -S \
  '--min-length=[minimum acronym length]:length:' \
  '--max-length=[maximum acronym length]:length:' \
  '--max-results=[max number of suggestions]:count:' \
  '--output=[write results to file (default STDOUT)]:file:_files' \
  '*'{-s,--strict}'[stricter scoring; repeat for very strict]' \
  '(- *)--version[show version]' \
  '1:project name:'
