#compdef bochs-cli
# _bochs-cli — Bochs IA-32 PC emulator CLI alias (Bochs project, C++); custom argparse
# upstream: https://github.com/bochs-emu/Bochs

_bochs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-f+[bochsrc config file]:file:_files -g "bochsrc *.cfg *.bochsrc"' \
        '-q[quick start, no menu]' \
        '-qf[quick start, choose options from CLI]' \
        '-benchmark+[run benchmark for n cycles]:n:' \
        '-r+[restart from snapshot]:str:' \
        '-log+[log file]:file:_files' \
        '-rc+[debugger commands file]:file:_files' \
        '-dbglog+[debugger log file]:file:_files' \
        '-no-debugger[no debugger]' \
        '-no-gui-debugger[no gui debugger]' \
        '-unlock[unlock bochsrc file]' \
        '-debug[debugger]' \
        '-debug-restore[debug restore]' \
        '*:arg:'
}

_bochs-cli "$@"
