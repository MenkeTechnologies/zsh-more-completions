#compdef chisel
# Zsh completion for chisel (TCP/UDP tunnel over HTTP)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[Show help]' \
  '1:command:->command' \
  '*:argument:->args' && ret=0

case "$state" in
  command)
    local -a commands=(
      'server:Run chisel in server mode'
      'client:Run chisel in client mode'
    )
    _describe -t commands 'chisel command' commands && ret=0
    ;;
  args)
    case "${words[2]}" in
      server)
        _arguments -s -S \
          '--host[Network host to listen on]:host:' \
          '--port[Port to listen on]:port:' \
          '--key[Seed string for generating a ECDSA key pair]:key string:' \
          '--authfile[Path to users.json authentication file]:auth file:_files' \
          '--auth[Inline credentials in user\:pass format]:credentials:' \
          '--keepalive[Keepalive interval]:duration:' \
          '--backend[HTTP server to proxy normal requests to]:url:' \
          '--socks5[Allow clients to access internal SOCKS5 proxy]' \
          '--reverse[Allow clients to specify reverse port forwarding]' \
          '--tls-key[TLS private key file]:key file:_files' \
          '--tls-cert[TLS certificate file]:cert file:_files' \
          '--tls-domain[TLS domain for automatic certificate]:domain:' \
          '--tls-ca[TLS CA certificate file for client authentication]:ca file:_files' \
          '--pid[Enable PID file in tmp directory]' \
          '(-v --verbose)'{-v,--verbose}'[Verbose logging]' \
          '(- *)--help[Show help]' && ret=0
        ;;
      client)
        _arguments -s -S \
          '--fingerprint[Server fingerprint for verification]:hash:' \
          '--auth[Credentials in user\:pass format]:credentials:' \
          '--keepalive[Keepalive interval]:duration:' \
          '--max-retry-count[Maximum number of retries]:count:' \
          '--max-retry-interval[Maximum retry interval]:duration:' \
          '--proxy[HTTP CONNECT proxy for the connection]:url:' \
          '--header[Custom header in key\:value format]:header:' \
          '--hostname[Override server hostname]:host:' \
          '--sni[Override SNI hostname]:host:' \
          '--tls-key[TLS private key file]:key file:_files' \
          '--tls-cert[TLS certificate file]:cert file:_files' \
          '--tls-ca[TLS CA certificate file]:ca file:_files' \
          '--pid[Enable PID file in tmp directory]' \
          '(-v --verbose)'{-v,--verbose}'[Verbose logging]' \
          '(- *)--help[Show help]' \
          '1:server URL:' \
          '*:remote spec (local\:remote):' && ret=0
        ;;
    esac
    ;;
esac
return ret
