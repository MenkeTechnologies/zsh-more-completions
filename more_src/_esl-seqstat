#compdef esl-seqstat
# Documentation: https://man.archlinux.org/search?q=esl-seqstat
# Reference accessed: 2026-05-16

# Easel esl-seqstat: summary statistics of a sequence file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-a[show stats per sequence]' \
  '-c[count composition (residue frequencies)]' \
  '--informat[input format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--rna[assume RNA]' \
  '--dna[assume DNA]' \
  '--amino[assume protein]' \
  '*:sequence file:_files' && ret=0
return ret
