#compdef dwginfo
# Documentation: https://man.archlinux.org/search?q=dwginfo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help,--help}'[show help]' \
  '-b[list blocks]' \
  '-l[list layers]' \
  '-e[count entities]' \
  '-platform[Qt platform]:plat:(offscreen minimal xcb cocoa wayland)' \
  '*:cad_file:_files -g "*.{dxf,dwg}"' && ret=0

return ret
