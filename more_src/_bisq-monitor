#compdef bisq-monitor
# _bisq-monitor — Bisq Network bisq-monitor headless monitor CLI for the Bisq peer-to-peer Bitcoin decentralised exchange tracking seed-node availability network performance Tor onion-service reachability dispute-arbitrator response time and metrics reporting (bisq team, Java); JCommander
# upstream: https://github.com/bisq-network/bisq

_bisq-monitor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--appName=+[name]:str:' \
        '--userDataDir=+[dir]:dir:_files -/' \
        '--appDataDir=+[dir]:dir:_files -/' \
        '--baseCurrencyNetwork=+[net]:n:(BTC_MAINNET BTC_TESTNET BTC_REGTEST BTC_DAO_BETANET BTC_DAO_TESTNET BTC_DAO_REGTEST)' \
        '--useTorForBtc[use Tor for BTC]' \
        '--torControlHost=+[host]:str:' \
        '--torControlPort=+[port]:n:' \
        '--torControlPassword=+[password]:str:' \
        '--torControlCookieFile=+[file]:file:_files' \
        '--torrcFile=+[file]:file:_files' \
        '--torrcOptions=+[options]:str:' \
        '--socks5ProxyBtcAddress=+[host:port]:str:' \
        '--socks5ProxyHttpAddress=+[host:port]:str:' \
        '--seedNodes=+[csv]:str:' \
        '--banList=+[csv]:str:' \
        '--myAddress=+[host:port]:str:' \
        '--logLevel=+[level]:l:(off error warn info debug trace)' \
        '--maxMemory=+[MB]:n:' \
        '--maxConnections=+[N]:n:' \
        '--useNativeXyz[use native XYZ]' \
        '--reporter=+[r]:r:(console graphite)' \
        '--metrics.run.interval=+[seconds]:n:' \
        '--metrics.PriceNodeStats.run.interval=+[seconds]:n:' \
        '--metrics.MarketStats.run.interval=+[seconds]:n:' \
        '--metrics.TradeStatistics3Dump.run.interval=+[seconds]:n:' \
        '--metrics.P2PNetworkLoad.run.interval=+[seconds]:n:' \
        '--metrics.P2PRoundTripTime.run.interval=+[seconds]:n:' \
        '--metrics.P2PSeedNodeSnapshot.run.interval=+[seconds]:n:' \
        '--System.useTor[use Tor]'
}

_bisq-monitor "$@"
