#compdef nerdfix
# nerdfix - Find and fix outdated Nerd Font icons in your project

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'check:check files for outdated icons'
  'fix:interactively fix outdated icons'
  'dump:dump icon database'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nerdfix command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      check)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[recursively search directories]' \
          '(-i --input)'{-i+,--input=}'[input file or directory]:path:_files' \
          '--format=[output format]:format:(text json)' \
          '*:files:_files' \
          && ret=0
        ;;
      fix)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[recursively search directories]' \
          '(-i --input)'{-i+,--input=}'[input file or directory]:path:_files' \
          '--write[write fixes to files]' \
          '*:files:_files' \
          && ret=0
        ;;
      dump)
        _arguments \
          '--format=[output format]:format:(text json)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
