#compdef parted-cli
# _parted-cli — GNU Parted partition manipulation CLI alias (GNU team, C); custom argparse
# upstream: https://www.gnu.org/software/parted/

_parted-cli() {
    local -a sub=(
        'align-check:check partition alignment'
        'help:show help'
        'mklabel:create partition table'
        'mkpart:create partition'
        'name:set partition name'
        'print:print partitions'
        'quit:exit'
        'rescue:rescue lost partition'
        'resizepart:resize partition'
        'rm:remove partition'
        'select:select device'
        'disk_set:set disk flag'
        'disk_toggle:toggle disk flag'
        'set:set partition flag'
        'toggle:toggle partition flag'
        'unit:set output unit'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--list[list partition layouts]' \
        '-l[list partition layouts]' \
        '--machine[machine-parseable output]' \
        '-m[machine-parseable output]' \
        '--json[json output]' \
        '-j[json output]' \
        '--script[suppress prompts]' \
        '-s[suppress prompts]' \
        '--fix[automatically fix common issues]' \
        '-f[automatically fix common issues]' \
        '--align=+[alignment]:a:(none cylinder minimal optimal)' \
        '-a+[alignment]:a:(none cylinder minimal optimal)' \
        '1:device:_files -g "/dev/{sd,hd,nvme,mapper}*"' \
        '2:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'parted subcommand' sub ;;
    esac
}

_parted-cli "$@"
