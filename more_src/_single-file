#compdef single-file
# Documentation: https://github.com/gildas-lormeau/single-file-cli
# single-file - save a complete web page into a single HTML file

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--dump-content[output HTML content to console]' \
  '--urls-file=[file containing a list of URLs to process]:file:_files' \
  '--crawl-links[enable link crawling]' \
  '--crawl-inner-links-only[limit crawling to internal links]' \
  '--crawl-max-depth=[maximum depth for link crawling]:depth:' \
  '--crawl-rewrite-rule=[regex rule to rewrite URLs during crawling]:rule:' \
  '--crawl-external-links-max-depth=[depth limit for external link crawling]:depth:' \
  '--browser-executable-path=[path to browser executable]:path:_files' \
  '--filename-template=[template for generated output filenames]:template:' \
  '1:url:_urls' \
  '2:output:_files' && ret=0

return ret
