#compdef deepseek
# Source: https://github.com/MenkeTechnologies/zsh-more-completions/blob/d278e5f1659fc62ca4671ab34a319c3ceb558a41/src/_deepseek
# Repository: MenkeTechnologies/zsh-more-completions (src/_deepseek)

# Zsh completion for deepseek (DeepSeek AI coding agent)

local -a commands
commands=(
  'login:Authenticate with your API key'
  'doctor:Check API connectivity and configuration'
  'models:List all available DeepSeek models'
  'resume:Resume a previous session'
  'serve:Run as an HTTP/SSE API server'
  'mcp:Manage Model Context Protocol servers'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '--yolo[Start in YOLO mode (auto-approve all actions)]' \
  '--http[Run as an HTTP/SSE API server]' \
  '-p[Execute a one-shot prompt]:prompt:' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  resume)
    _arguments \
      '--last[Resume the most recent session]'
    ;;
  mcp)
    local -a mcp_cmds
    mcp_cmds=('list:List active MCP servers')
    _arguments \
      '1: :_describe -t mcp_cmds "mcp command" mcp_cmds'
    ;;
esac
