#compdef ANTSUseLandmarkImagesToGetAffineTransform
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ANTSUseLandmarkImagesToGetAffineTransform.cxx — estimate rigid/affine from labelled landmarks (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:FixedImageWithLabeledLandmarks.nii.gz:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:MovingImageWithLabeledLandmarks.nii.gz:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:type:(rigid affine)' \
    '4:OutAffine.txt:_files -g "*.{txt,mat}"' \
    && ret=0

return ret
