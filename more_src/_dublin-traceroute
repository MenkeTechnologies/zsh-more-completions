#compdef dublin-traceroute

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--sport[Source port]:port:' \
  '--dport[Destination port]:port:' \
  '--npaths[Number of paths to probe]:number:' \
  '--min-ttl[Minimum TTL]:ttl:' \
  '--max-ttl[Maximum TTL]:ttl:' \
  '--delay[Delay between probes in milliseconds]:milliseconds:' \
  '--broken-nat[Enable broken NAT detection]' \
  '(-o --output-file)'{-o,--output-file}'[Output file]:file:_files' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '1:target host:_hosts' && ret=0

return ret
