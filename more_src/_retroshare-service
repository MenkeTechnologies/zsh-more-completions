#compdef retroshare-service
# _retroshare-service — headless RetroShare friend-to-friend networking daemon (RetroShare/RetroShare)
# upstream: https://github.com/RetroShare/RetroShare
# Flags from retroshare-service/src/retroshare-service.cc (argstream).

_retroshare-service() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-s --stderr)'{-s,--stderr}'[output to stderr instead of log file]' \
        '(-u --udp)'{-u,--udp}'[only listen on UDP]' \
        '(-c --base-dir)'{-c+,--base-dir=}'[set base directory]:dir:_files -/' \
        '(-l --log-file)'{-l+,--log-file=}'[log file]:file:_files' \
        '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
        '(-i --ip-address)'{-i+,--ip-address=}'[forced IP address]:ip:' \
        '(-o --opmode)'{-o+,--opmode=}'[operating mode]:mode:(Full NoTurtle Gaming Minimal)' \
        '(-p --port)'{-p+,--port=}'[listening port]:port:' \
        '(-t --tor)'{-t+,--tor=}'[Tor executable full path]:file:_command_names -e' \
        '(-U --user-id)'{-U+,--user-id=}'[selected account ID (use list to enumerate)]:id:' \
        '(-J --jsonApiPort)'{-J+,--jsonApiPort=}'[enable JSON API on TCP port]:port:' \
        '(-P --jsonApiBindAddress)'{-P+,--jsonApiBindAddress=}'[JSON API bind address]:ip:' \
        '(-B --webui-directory)'{-B+,--webui-directory=}'[location of webui html/js files]:dir:_files -/' \
        '(-W --webui-password)'{-W,--webui-password}'[ask WebUI password on the console]' \
        '(-a --auto-login)'{-a,--auto-login}'[enable auto-login]'
}

_retroshare-service "$@"
