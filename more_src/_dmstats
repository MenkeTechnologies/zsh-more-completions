#compdef dmstats
# _dmstats — LVM2 dmstats device-mapper statistics tool CLI alias (lvm2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_dmstats() {
    local -a sub=(
        'clear:reset counters'
        'create:create new region'
        'delete:delete region'
        'group:group commands'
        'list:list regions'
        'print:print stats'
        'report:report stats'
        'ungroup:remove group'
        'update_filemap:update filemap'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--alldevices[all devices]' \
        '--allprograms[all programs]' \
        '--allregions[all regions]' \
        '--alldatabases[all databases]' \
        '--area-size=+[size]:str:' \
        '--areas=+[n]:n:' \
        '--bounds=+[bounds]:str:' \
        '--clear[clear]' \
        '--count=+[n]:n:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--filemap[filemap]' \
        '--following[follow]' \
        '--force[force]' \
        '-f[force]' \
        '--group[group mode]' \
        '--groupid=+[id]:str:' \
        '--histogram[histogram]' \
        '--interval=+[seconds]:n:' \
        '-i+[seconds]:n:' \
        '--length=+[size]:str:' \
        '--major=+[major]:n:' \
        '-j+[major]:n:' \
        '--minor=+[minor]:n:' \
        '-m+[minor]:n:' \
        '--mode=+[mode]:m:(area sectors files)' \
        '--noheadings[no headings]' \
        '--notimesuffix[no time suffix]' \
        '--nogroup[no group]' \
        '-o+[output cols]:str:' \
        '--options=+[output cols]:str:' \
        '--precision=+[digits]:n:' \
        '-p+[digits]:n:' \
        '--programid=+[id]:str:' \
        '-P+[id]:str:' \
        '--rdelay=+[ms]:n:' \
        '--region-id=+[id]:str:' \
        '--regions=+[region ids]:str:' \
        '--rows[rows mode]' \
        '--segments[per segment]' \
        '--separator=+[char]:str:' \
        '--sort=+[sort cols]:str:' \
        '-S+[sort cols]:str:' \
        '--start=+[start]:str:' \
        '--units=+[unit]:u:(B b S k K m M g G t T p P e E)' \
        '--userdata=+[userdata]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dmstats subcommand' sub ;;
    esac
}

_dmstats "$@"
