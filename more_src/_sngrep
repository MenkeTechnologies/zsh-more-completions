#compdef sngrep
# Documentation: https://github.com/irontec/sngrep/blob/master/doc/sngrep.8
# Reference accessed: 2026-05-21
# Verified: upstream doc/sngrep.8 manpage. All flags are short-form only.

# Zsh completion for sngrep - SIP flow viewer

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[help]' \
  '-V[version]' \
  '-c[only show dialogs starting with INVITE]' \
  '-i[invert match expression]' \
  '-v[invert match]' \
  '-N[run without UI, capture only]' \
  '-q[quiet, no dialog output in no-interface mode]' \
  '-r[capture RTP payload]' \
  '-D[print active configuration and exit]' \
  '-I[read from pcap file]:file:_files -g "*.(pcap|pcapng|cap)"' \
  '-O[save captured packets to pcap]:file:_files' \
  '-d[capture device]:interface' \
  '-l[dialog capture limit]:n:' \
  '-B[pcap buffer size in MB]:mb:' \
  '-k[RSA private keyfile for TLS decryption]:file:_files' \
  '-f[load config from file]:file:_files' \
  '-F[skip default config file]' \
  '-T[save pcap to text file]:file:_files' \
  '-t[capture and parse RTP telephone-event packets]' \
  '-R[rotate calls upon reaching limit]' \
  '-H[Homer sipcapture URL]:url:' \
  '-L[listen for encapsulated packets]:proto:' \
  '-E[parse captured HEP3 packets]' && ret=0

return ret
