#compdef sngrep

# Zsh completion for sngrep — SIP flow viewer

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-d --device)'{-d,--device}'[interface]:interface' \
  '(-I --input)'{-I,--input}'[pcap file]:file:_files' \
  '-q[quiet]' && ret=0

return ret
