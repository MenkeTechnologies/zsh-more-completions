#compdef kalign
# Kalign: fast multiple sequence alignment of large datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v -V --version)'{-v,-V,--version}'[show version]' \
  '(-i --input)'{-i,--input}'[input sequence file]:file:_files' \
  '(-o --output)'{-o,--output}'[output alignment file]:file:_files' \
  '(-f --format)'{-f,--format}'[output format]:format:(fasta msf clu)' \
  '--mode[mode preset]:mode:(fast default recall accurate)' \
  '--type[sequence type]:type:(protein dna rna divergent)' \
  '--gpo[gap open penalty]:penalty:' \
  '--gpe[gap extension penalty]:penalty:' \
  '--tgpe[terminal gap extension penalty]:penalty:' \
  '-n[number of threads]:number:' \
  '*:input file:_files' && ret=0

return ret
