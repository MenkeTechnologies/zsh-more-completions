#compdef primer3 primer3_core
# Documentation: https://man.archlinux.org/search?q=primer3
# Reference accessed: 2026-05-16

# Primer3 core: PCR primer/probe design (Boulder-IO format on stdin)
local curcontext="$curcontext" ret=1

_arguments -C \
  '-about[print version and copyright info]' \
  '-format_output[print human-readable output instead of Boulder-IO]' \
  '-default_version=[input file default format version]:version:(1 2)' \
  '-io_version=[Boulder-IO version]:version:(3 4)' \
  '-strict_tags[fail on unrecognized input tags]' \
  '-p3_settings_file=[read settings from file]:settings file:_files' \
  '-echo_settings_file[echo settings file contents to output]' \
  '-output=[write output to file]:file:_files' \
  '-error=[write errors to file]:file:_files' \
  '-dump_args[print parsed arguments and exit]' \
  '*:input boulder-IO file:_files' && ret=0

return ret
