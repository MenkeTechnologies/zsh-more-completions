#compdef flyctl-cli fly-cli flyctl
# _flyctl-cli — Fly.io flyctl deploy app servers worldwide CLI alias (superfly team, Go); cobra
# upstream: https://github.com/superfly/flyctl

_flyctl-cli() {
    local -a sub=(
        'agent:agent commands'
        'apps:apps management'
        'apps create:create app'
        'apps destroy:destroy app'
        'apps list:list apps'
        'apps open:open app in browser'
        'auth:authentication commands'
        'auth login:login'
        'auth logout:logout'
        'auth signup:signup'
        'auth token:show auth token'
        'auth whoami:show current user'
        'autoscale:autoscale commands'
        'certs:certificate commands'
        'certs add:add cert'
        'certs show:show cert'
        'certs check:check cert'
        'certs list:list certs'
        'certs remove:remove cert'
        'checks:checks commands'
        'completion:generate completion'
        'config:config commands'
        'config display:display config'
        'config save:save config'
        'config validate:validate config'
        'console:open console'
        'curl:curl from regions'
        'deploy:deploy app'
        'destroy:destroy app'
        'dig:DNS dig'
        'dns-records:dns commands'
        'docs:open docs'
        'help:show help'
        'history:history commands'
        'image:image commands'
        'image show:show image info'
        'image update:update image'
        'info:show info'
        'ips:IP commands'
        'ips list:list ips'
        'ips allocate-v4:allocate IPv4'
        'ips allocate-v6:allocate IPv6'
        'ips release:release IP'
        'launch:launch new app'
        'logs:show logs'
        'machine:machine commands'
        'machine list:list machines'
        'machine status:machine status'
        'machine start:start machine'
        'machine stop:stop machine'
        'machine restart:restart machine'
        'machine destroy:destroy machine'
        'machine clone:clone machine'
        'machine run:run machine'
        'mysql:mysql commands'
        'open:open app'
        'orgs:org commands'
        'orgs apps:org apps'
        'orgs create:create org'
        'orgs list:list orgs'
        'orgs show:show org'
        'orgs invite:invite user'
        'orgs remove:remove user'
        'orgs revoke:revoke user'
        'platform:platform commands'
        'platform regions:list regions'
        'platform vm-sizes:list vm sizes'
        'platform status:platform status'
        'postgres:postgres commands'
        'proxy:proxy commands'
        'regions:regions commands'
        'releases:show releases'
        'restart:restart app'
        'scale:scale commands'
        'scale count:set count'
        'scale memory:set memory'
        'scale show:show scale'
        'scale vm:set vm size'
        'secrets:secrets commands'
        'secrets deploy:deploy secrets'
        'secrets list:list secrets'
        'secrets set:set secret'
        'secrets unset:unset secret'
        'secrets import:import secrets'
        'services:services commands'
        'settings:settings commands'
        'ssh:ssh commands'
        'ssh console:ssh console'
        'ssh issue:issue ssh cert'
        'ssh sftp:sftp commands'
        'status:show app status'
        'tokens:tokens commands'
        'version:show version'
        'volumes:volume commands'
        'volumes create:create volume'
        'volumes destroy:destroy volume'
        'volumes show:show volume'
        'volumes list:list volumes'
        'wireguard:wireguard commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--access-token=+[token]:str:' \
        '-t+[token]:str:' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--json[json output]' \
        '-j[json output]' \
        '--org=+[org]:str:' \
        '--config=+[config file]:file:_files -g "fly.toml"' \
        '-c+[config file]:file:_files -g "fly.toml"' \
        '-a+[app]:str:' \
        '--app=+[app]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flyctl subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                deploy|launch) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--build-arg=+[arg]:str:' \
                    '--build-secret=+[secret]:str:' \
                    '--build-target=+[target]:str:' \
                    '--dockerfile=+[file]:file:_files -g "Dockerfile*"' \
                    '--image=+[image]:str:' \
                    '-i+[image]:str:' \
                    '--image-label=+[label]:str:' \
                    '--no-cache[no cache]' \
                    '--remote-only[remote only]' \
                    '--local-only[local only]' \
                    '--strategy=+[strategy]:s:(immediate rolling canary bluegreen)' \
                    '--region=+[region]:str:' \
                    '-r+[region]:str:' \
                    '--auto-confirm[auto confirm]' \
                    '--detach[detach]' \
                    '--wait-timeout=+[seconds]:n:' \
                    '--smoke-checks=+[bool]:b:(true false)' \
                    '--ha[high availability]' \
                    '--vm-cpu-kind=+[kind]:k:(shared performance)' \
                    '--vm-cpus=+[count]:n:' \
                    '--vm-memory=+[mb]:n:' \
                    '--vm-size=+[size]:str:' ;;
            esac
            ;;
    esac
}

_flyctl-cli "$@"
