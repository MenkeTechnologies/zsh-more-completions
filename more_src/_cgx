#compdef cgx
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/cgx.1.html
# CalculiX GraphiX pre- and post-processor

local ret=1

_arguments -s -S \
  '(-a -b -bg -c -v)-a[auto-mode, geometry derived from a cad-file]' \
  '(-a -b -bg -c -v)-b[build-mode, geometry (command) file expected]' \
  '(-a -b -bg -c -v)-bg[background, suppress graphic output, geometry file expected]' \
  '(-a -b -bg -c -v)-c[read a solver input file (ccx)]' \
  '(-a -b -bg -c -v)-v[read a result file in frd-format and optional solver input file]' \
  '-duns2d[read duns result files (2D)]' \
  '-duns3d[read duns result files (3D)]' \
  '-isaac2d[read isaac result files (2D)]' \
  '-isaac3d[read isaac result files (3D)]' \
  '-foam[read openFOAM result files]' \
  '-f06[read Nastran f06 file]' \
  '-ng[read Netgen native format]' \
  '-step[read a step file (only points and lines)]' \
  '-stepsplit[read step and write its single parts to the filesystem]' \
  '-stl[read stl triangles]' \
  '-mksets[make node-sets from *DLOAD-values]' \
  '-read[read the complete result-file at startup]' \
  '*:file:_files' && ret=0

return ret
