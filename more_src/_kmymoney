#compdef kmymoney
# Documentation: https://man.archlinux.org/man/kmymoney.1.en
# Reference accessed: 2026-05-19
# Verified: Arch Linux kmymoney(1) manpage (re-confirmed all flags).

# kmymoney: KDE personal finance manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--lang=[language to use]:lang:' \
  '-n[do not open last used file]' \
  '--timers[enable performance timers]' \
  '--nocatch[do not globally catch uncaught exceptions]' \
  '--trace[turn on program traces (debug builds only)]' \
  '--dump-actions[dump QAction names to stdout and quit]' \
  '*:KMyMoney file:_files -g "*.(kmy|kmymoney)(-.)"' && ret=0
return ret
