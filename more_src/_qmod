#compdef qmod
# Grid Engine: modify a queue, job, or queue instance state

local ret=1

_arguments -s \
  '-help[print a listing of all options]' \
  '-cj[clear the error state of the specified jobs]' \
  '-cq[clear the error state of the specified queues]' \
  '-d[disable the queues, dispatching no further jobs]' \
  '-e[enable the queues]' \
  '-f[force the modification despite the apparent current state]' \
  '-rj[reschedule the running jobs]' \
  '-rq[reschedule all jobs running in the queues]' \
  '-sj[suspend the running jobs]' \
  '-sq[suspend the queues and any active jobs]' \
  '-usj[unsuspend the jobs]' \
  '-usq[unsuspend the queues and any active jobs]' \
  '*:queue or job:_message "queue/job"' && ret=0

return ret
