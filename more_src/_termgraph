#compdef termgraph
# Documentation: https://github.com/mkaz/termgraph
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for termgraph (terminal graphs)

_arguments -s -S \
  '--title=[chart title]:title:' \
  '--width=[width of graph]:width:' \
  '--format=[output format]:format:' \
  '--suffix=[suffix for values]:suffix:' \
  '--no-labels[do not print labels]' \
  '--no-values[do not print values]' \
  '--space-between[insert newline after each field]' \
  '*--color=[colors for bars]:color:(red blue green magenta yellow black white default)' \
  '--vertical[display bars vertically]' \
  '--stacked[display stacked bar chart]' \
  '--histogram[display histogram]' \
  '--bins=[number of histogram bins]:bins:' \
  '--different-scale[use different scale for each category]' \
  '--calendar[display a calendar heatmap]' \
  '--start-dt=[start date for calendar]:date:' \
  '--custom-tick=[custom tick character]:char:' \
  '--delim=[delimiter]:delimiter:' \
  '--verbose[verbose output for debugging]' \
  '--label-before[print label before bar]' \
  '--no-readable[disable readable number formatting]' \
  '--percentage[display values as percentages]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:data file:_files' && return 0
