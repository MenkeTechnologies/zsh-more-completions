#compdef react-router
# Documentation: https://reactrouter.com
# Reference accessed: 2026-05-23
# Verified: npx @react-router/dev --help.

# Zsh completion for react-router - React Router framework CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build the project'
  'dev:run local development server'
  'routes:show application routes'
  'reveal:reveal route modules'
  'typegen:generate route types'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '--no-color[disable ANSI colors]'   '(-c --config)'{-c,--config=}'[Vite config file]:file:_files'   '--mode=[env mode]:mode:'   '--logLevel=[log level]:level:(info warn error silent)'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'react-router command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dev)
        _arguments           '--host=[hostname]:host:'           '--port=[port]:port:'           '--open[open browser on startup]'           '--strictPort[exit if port in use]'           '--cors[enable CORS]'           '--force[ignore optimizer cache]' && ret=0 ;;
      (build)
        _arguments           '--sourcemapClient[client sourcemaps]'           '--sourcemapServer[server sourcemaps]'           '--minify[enable minification]'           '--emptyOutDir[force empty outDir]' && ret=0 ;;
      (routes)
        _arguments '--json[print routes as JSON]' && ret=0 ;;
      (typegen)
        _arguments '--watch[regenerate types on route changes]' && ret=0 ;;
      (*)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
