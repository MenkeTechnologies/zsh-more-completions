#compdef pkdumpogr
# Documentation: https://pktools.nongnu.org/html/pkdumpogr.html
# dump OGR vector attributes to ASCII

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input shape file]:file:_files' \
  '(-ln --lname)'{-ln,--lname}'[Layer name(s) in sample (leave empty to select all)]:value:' \
  '(-o --output)'{-o,--output}'[Output ASCII file]:file:_files' \
  '(-n --name)'{-n,--name}'[names of the attributes to select. Each attribute is stored in a separ]:value:' \
  '(-pos --pos)'{-pos,--pos}'[include position (x and y)]' \
  '(-t --transpose)'{-t,--transpose}'[transpose output (does not work for -n ALL]' \
  '(-fs --fs)'{-fs,--fs}'[field separator.]:value:' \
  '*:file:_files' && ret=0

return ret
