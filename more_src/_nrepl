#compdef nrepl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --interactive)'{-i,--interactive}'[start nREPL and attach the built-in client]' \
  '(-p --port)'{-p+,--port=}'[server port (0 = random)]:port:' \
  '(-b --bind)'{-b+,--bind=}'[bind address]:address:_hosts' \
  '(-c --connect)'{-c,--connect}'[connect to a running nREPL with built-in client]' \
  '(-C --color)'{-C,--color}'[colorize output in the REPL]' \
  '(-s --socket)'{-s+,--socket=}'[start on a filesystem socket]:file:_files' \
  '--ack=[acknowledge port to another nREPL server]:ack-port:' \
  '--repl-fn=[fully-qualified REPL function]:fn:' \
  '--handler=[fully-qualified nREPL handler]:fn:' \
  '*--middleware=[middleware var to inject]:middleware:' \
  '--transport=[transport]:transport:(bencode tty edn)' \
  '--tls-keys-file=[PEM bundle TLS file]:file:_files' \
  '--tls-keys-str=[PEM bundle TLS string]:string:' \
  '--host=[connect host]:host:_hosts' \
  '--repl[start a REPL on this nREPL]' \
  '*::extra:' && ret=0

return ret
