#compdef swanctl
# Documentation: https://github.com/strongswan/strongswan (src/swanctl/commands/*.c command_register blocks)
# Reference accessed: 2026-05-29
# strongSwan VPN/IPsec configuration & management tool.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  '--counters:show or reset IKE event counters (-C)'
  '--flush-certs:flush cached X.509 certificates (-F)'
  '--initiate:initiate a connection (-i)'
  '--install:install a trap or shunt policy (-p)'
  '--list-algs:list loaded algorithms (-g)'
  '--list-authorities:list certification authority information (-B)'
  '--list-certs:list stored X.509 certificates (-x)'
  '--list-conns:list loaded configurations (-L)'
  '--list-pols:list currently installed policies (-P)'
  '--list-pools:list loaded pool configurations (-A)'
  '--list-sas:list currently active IKE_SAs (-l)'
  '--load-all:load credentials, authorities, pools, and connections (-q)'
  '--load-authorities:reload authority configurations (-B)'
  '--load-conns:reload connection configurations (-c)'
  '--load-creds:reload credentials (-s)'
  '--load-pools:reload pool configurations (-a)'
  '--log:trace logging output (-T)'
  '--monitor-sa:monitor for IKE_SA and CHILD_SA changes (-m)'
  '--redirect:redirect an IKE_SA (-d)'
  '--rekey:rekey an SA (-R)'
  '--reload-settings:reload daemon strongswan.conf (-S)'
  '--stats:show daemon statistics (-S)'
  '--terminate:terminate a connection (-t)'
  '--uninstall:uninstall a trap or shunt policy (-u)'
  '--version:show version information (-v)'
  '--help:show usage information (-h)'
)

local -a _common
_common=(
  '(-h --help)'{-h,--help}'[show usage information]'
  '(-r --raw)'{-r,--raw}'[dump raw response message]'
  '(-P --pretty)'{-P,--pretty}'[dump raw response message in pretty print]'
)

_arguments -C \
  '(-+)-+[uri]:uri:'  \
  '--uri=[URI for vici socket]:uri:' \
  '*: :->cmd' && ret=0

case $state in
  cmd)
    _describe -t commands 'swanctl command' _subcmds && ret=0
    ;;
esac

return ret
