#compdef multilog
# Documentation: https://cr.yp.to/daemontools/multilog.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: multilog (daemontools) takes a sequence of "script" arguments
#   such as +pattern, -pattern, e, =file, t, ssize, nnum, !processor, dir.
# These are positional words, not options; complete files for dir args.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:script argument:_files' && ret=0

return ret
