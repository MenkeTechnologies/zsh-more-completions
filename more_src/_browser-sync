#compdef browser-sync

_browser_sync() {
  local curcontext="$curcontext" state line ret=1

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      local -a commands=(
        'start:start BrowserSync'
        'init:create a configuration file'
        'reload:send a reload event'
        'recipe:generate a project from a recipe'
      )
      _describe -t commands 'browser-sync command' commands && ret=0
      ;;
    args)
      case ${line[1]} in
        start)
          _arguments \
            '--help[show help]' \
            '(-s --server)'{-s,--server}'[run local server]' \
            '(-p --proxy)'{-p,--proxy}'[proxy an existing server]:url' \
            '--port[specify port]:port' \
            '*'{-f,--files}'[file paths to watch]:patterns' \
            '(-c --config)'{-c,--config}'[specify config file]:file:_files' \
            '(-b --browser)'{-b,--browser}'[choose which browser to open]:browser' \
            '--no-open[do not open browser]' \
            '--no-notify[disable notifications]' \
            '--no-ghost-mode[disable ghost mode]' \
            '--no-inject-changes[reload on every change]' \
            '--no-reload-on-restart[do not reload on restart]' \
            '--host[specify hostname]:host' \
            '--logLevel[set log level]:level:(info debug warn silent)' \
            '--reload-delay[time to delay reload]:milliseconds' \
            '--reload-debounce[debounce reload events]:milliseconds' \
            '--no-ui[disable UI]' \
            '--ui-port[UI port]:port' \
            '--watch-events[specify watch events]:events:(change add unlink addDir unlinkDir)' \
            '--no-online[force offline mode]' \
            '--open[open URL on start]:type:(local external ui ui-external tunnel false)' \
            '--cors[add CORS headers]' \
            '--ss[serve static directory]:directory:_directories' \
            '--serveStatic[serve static directory]:directory:_directories' \
            '--directory[show directory listing]' \
            '--index[specify index page]:file' \
            '--startPath[specify start path]:path' \
            '--https[enable HTTPS]' \
            '--httpModule[specify HTTP module]:module' \
            '--no-snippet[disable snippet]' \
            '--logFileChanges[log file changes]' \
            '--logConnections[log connections]' \
            '--logSnippet[log snippet]' \
            '--tunnel[use a tunnel]:subdomain' \
            '--plugins[load plugins]:modules' \
            '--single[serve SPA]' \
            '--ignore[ignore patterns]:patterns' \
            '--watch[watch files]' && ret=0
          ;;
        init)
          _arguments '--help[show help]' && ret=0
          ;;
        reload)
          _arguments \
            '--help[show help]' \
            '--files[files to reload]:patterns' \
            '--port[target port]:port' \
            '--url[target URL]:url' && ret=0
          ;;
        recipe)
          _arguments \
            '--help[show help]' \
            '--output[output directory]:directory:_directories' \
            '1:recipe name' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_browser_sync "$@"
