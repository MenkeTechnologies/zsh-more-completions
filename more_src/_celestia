#compdef celestia

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--dir=+[install dir]:dir:_files -/' \
  '--conf=+[config file]:file:_files' \
  '--extrasdir=+[extras dir]:dir:_files -/' \
  '--fullscreen[fullscreen]' \
  '--once[do not loop]' \
  '--startloop[start looping]' \
  '*:cel script:_files -g "*.cel"' && ret=0

return ret
