#compdef losetup
# _losetup-bin — util-linux loop device control; set up + control loop devices for image files
# upstream: https://github.com/util-linux/util-linux

_losetup-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[list all used devices]' \
        '(-d --detach)'{-d,--detach}'[detach device]' \
        '(-D --detach-all)'{-D,--detach-all}'[detach all]' \
        '(-f --find)'{-f,--find}'[find unused device]' \
        '(-c --set-capacity)'{-c,--set-capacity}'[resize device]' \
        '(-j --associated)'{-j,--associated}'+[only loops with file]:file:_files' \
        '(-L --nooverlap)'{-L,--nooverlap}'[disallow overlap]' \
        '(-o --offset)'{-o,--offset}'+[offset bytes]:n:' \
        '--sizelimit+[size limit bytes]:n:' \
        '(-b --sector-size)'{-b,--sector-size}'+[sector size]:n:' \
        '(-P --partscan)'{-P,--partscan}'[partition scan]' \
        '(-r --read-only)'{-r,--read-only}'[read-only]' \
        '--direct-io+[direct IO]:bool:(on off)' \
        '--show[print device name after setup]' \
        '(-O --output)'{-O,--output}'+[output cols]:cols:' \
        '--output-all[all columns]' \
        '(-n --noheadings)'{-n,--noheadings}'[no header]' \
        '--raw[raw output]' \
        '(-J --json)'{-J,--json}'[json output]' \
        '(-l --list)'{-l,--list}'[list]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:loop device or file:_files'
}

_losetup-bin "$@"
