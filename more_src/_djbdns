#compdef djbdns
# Documentation: https://man.archlinux.org/search?q=djbdns
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install djbdns'
  'start:start daemon'
  'stop:stop daemon'
  'restart:restart daemon'
  'status:show status'
  'configure:run configure script'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'djbdns command' commands && ret=0 ;;
esac

return ret
