#compdef otbcli_SmallRegionsMerging
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SmallRegionsMerging.html
# Orfeo ToolBox: merge small regions of a segmentation by spectral signature

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image of initial spectral signatures]:image:_files' \
  '-inseg[segmented label image]:image:_files' \
  '-out[output segmented image with merged segments]:output:_files' \
  '-minsize[minimum segment size]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
