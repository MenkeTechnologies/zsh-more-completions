#compdef spack-python
# Documentation: https://spack.readthedocs.io/en/latest/command_index.html
# Spack's bundled Python interpreter with the spack module preloaded

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '-V[show version and exit]' \
  '--path[show path to underlying python interpreter]' \
  '-c[command passed in as string; rest of args passed to the command]:command' \
  '-u[unbuffered binary stdout and stderr]' \
  '-i[interactive console after running script]' \
  '-m[run library module as a script]:module' \
  '*:script:_files' && ret=0

return ret
