#compdef tuxtype
# Documentation: https://manpages.org/tuxtype
# Reference accessed: 2026-05-16
# Verified: tuxtype manpage. Short flags accept one or two dashes.
# Removed from prior file: bogus man.archlinux.org search URL.

# tuxtype: educational typing tutor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -help)'{-h,--help,-help}'[show help]' \
  '(-f --fullscreen -w --window)'{-f,--fullscreen}'[fullscreen display (default)]' \
  '(-f --fullscreen -w --window)'{-w,--window}'[windowed display]' \
  '(-s --sound -ns --nosound)'{-s,--sound}'[allow in-game sounds (default)]' \
  '(-s --sound -ns --nosound)'{-ns,--nosound}'[disable in-game sounds]' \
  '(-sp --speed)'{-sp,--speed}'[speed up gameplay]' \
  '(-st --static)'{-st,--static}'[static (non-scrolling) display]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-vb --verbose)'{-vb,--verbose}'[verbose output]' && ret=0
return ret
