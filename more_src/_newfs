#compdef newfs
# _newfs — OpenBSD newfs (FFS/FFS2 filesystem builder; -O selects FFS version (1 or 2), -b block size, -f frag size, -i bytes-per-inode, -m free-space %, -T disktype from /etc/disktab)
# upstream: https://github.com/openbsd/src (sbin/newfs)
# Flags from sbin/newfs/newfs.8 on tip.

_newfs() {
    _arguments \
        '-N[do not create; show config]' \
        '-q[quiet]' \
        '-b+[block size]:bytes:' \
        '-c+[fragments per cyl group]:n:' \
        '-e+[max blocks-per-group]:n:' \
        '-f+[frag size]:bytes:' \
        '-g+[avg file size]:bytes:' \
        '-h+[avg files per dir]:n:' \
        '-i+[bytes per inode]:bytes:' \
        '-m+[free-space reserve %]:percent:' \
        '-O+[filesystem version]:version:(1 2)' \
        '-o+[optimization]:opt:(space time)' \
        '-S+[sector size]:bytes:' \
        '-s+[fs size sectors]:sectors:' \
        '-T+[disktype]:type:' \
        '-t+[fstype]:fstype:(ffs)' \
        '1:special:_files -g "/dev/r*"'
}

_newfs "$@"
