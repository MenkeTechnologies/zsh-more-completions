#compdef smbios-sys-info
# Documentation: https://man.archlinux.org/search?q=smbios-sys-info
# Reference accessed: 2026-05-16

# smbios-sys-info: dump system info (vendor, model, serial)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  "--system[print system info]" "--bios[print BIOS info]" "--baseboard[print baseboard info]" "--chassis[print chassis info]" "--processor[print processor info]" "--memory[print memory info]" "--cache[print cache info]" "--portconn[print port connectors]" "--onboard[print on-board devices]" "--type=[print specific SMBIOS table]:n:" \
  '*::smbios-sys-info args:_files' && ret=0
return ret
