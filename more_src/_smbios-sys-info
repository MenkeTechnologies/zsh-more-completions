#compdef smbios-sys-info
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-sys-info.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-sys-info: show/set Dell system tags via SMBIOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show program version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--service-tag[show or set service tag]' \
  '--asset-tag[show or set asset tag]' \
  '--property-tag[show or set property tag]' \
  '--set=[set specified tag to new value]:value:' \
  '(-v --verbose)'{-v,--verbose}'[display more verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[minimize program output]' \
  '--trace[enable verbose function tracing]' \
  '--logconfig=[alternate config log]:file:_files' \
  '--password=[BIOS Setup password]:password:' \
  '(-r --rawpassword)'{-r,--rawpassword}'[do not auto-convert password to scancodes]' \
  '--memory-dat=[memory dump file]:file:_files' \
  '--cmos-dat=[CMOS dump file]:file:_files' && ret=0
return ret
