#compdef bwa

# main.c usage() command table
# https://github.com/lh3/bwa

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'index:build FM-index from FASTA'
  'mem:BWA-MEM long-read / Illumina aligner'
  'fastmap:find SMEMs'
  'pemerge:merge overlapping PE reads'
  'aln:BWA-backtrack gapped alignment'
  'samse:convert single SAI to SAM'
  'sampe:convert paired SAI to SAM'
  'bwasw:BWA-SW (deprecated)'
  'shm:shared-memory index helpers'
  'fa2pac:FASTA to packed nucleotide'
  'pac2bwt:BWT from packed sequence'
  'pac2bwtgen:alternative BWT build'
  'bwtupdate:upgrade legacy .bwt'
  'bwt2sa:suffix array from BWT'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'bwa command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
