#compdef arkime moloch
# _arkime — AOL/Arkime large-scale full-packet capture analyzer (formerly Moloch) CLI alias (arkime team, C/JS); custom argparse
# upstream: https://github.com/arkime/arkime

_arkime() {
    local -a sub=(
        'capture:start capture daemon'
        'viewer:start viewer'
        'parliament:start parliament'
        'cont3xt:start cont3xt'
        'wise:start wise daemon'
        'db:init:initialize database'
        'db:upgrade:upgrade database'
        'db:reset:reset database'
        'db:add-user:add admin user'
        'db:remove-user:remove user'
        'db:list-users:list users'
        'db:set-password:set user password'
        'db:expire:run expire'
        'db:status:show status'
        'db:dump:dump database'
        'db:restore:restore database'
        'config:list:list configs'
        'config:reload:reload config'
        'config:set:set config value'
        'config:get:get config value'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.{ini,cfg}"' \
        '-n+[node name]:str:' \
        '-o+[override option]:str:' \
        '--debug[debug]' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arkime subcommand' sub ;;
        args)
            case $words[1] in
                capture) _arguments \
                    '--debug[debug]' \
                    '-i+[interface]:_net_interfaces' \
                    '-r+[pcap file]:file:_files -g "*.pcap*"' \
                    '-R+[recursive dir]:dir:_files -/' \
                    '--tests[run tests]' \
                    '--copy[copy to capture dir]' \
                    '--scheme[scheme name]' \
                    '--monitor=+[dir]:dir:_files -/' \
                    '--simpleEncoding=+[mode]:m:(aes-256-ctr)' \
                    '--nostats[no stats]' ;;
                viewer) _arguments \
                    '--debug[debug]' \
                    '--insecure[skip TLS verify]' ;;
                db:add-user|db:remove-user|db:set-password) _arguments \
                    '1:username:_users' \
                    '*:args:' ;;
                db:expire) _arguments \
                    '1:type:(daily monthly hourly hourlyN)' \
                    '2:retention:' \
                    '--replicas=+[n]:n:' \
                    '--esTimeout=+[seconds]:n:' ;;
            esac
            ;;
    esac
}

_arkime "$@"
