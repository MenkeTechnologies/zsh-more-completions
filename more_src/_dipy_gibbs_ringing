#compdef dipy_gibbs_ringing
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_gibbs_ringing.html
# DIPY: suppress Gibbs ringing oscillations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--slice_axis=[data axis for number of acquired slices]:axis:(0 1 2)' \
  '--n_points=[number of neighbour points to access local TV]:n' \
  '--num_processes=[split calculation to a pool of children processes]:n' \
  '--out_dir=[destination folder for results]:dir:_files -/' \
  '--out_unring=[name of the resulting denoised volume]:file:_files' \
  '*:input volumes:_files' && ret=0

return ret
