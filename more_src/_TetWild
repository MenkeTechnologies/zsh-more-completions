#compdef TetWild
# Documentation: https://github.com/Yixin-Hu/TetWild
# TetWild - robust tetrahedral meshing in the wild

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --ideal-edge-length)'{-l,--ideal-edge-length}'[ideal edge length relative to bbox diagonal (default 0.05)]:length:' \
  '(-e --epsilon)'{-e,--epsilon}'[envelope size for feature preservation (default 1e-3)]:epsilon:' \
  '--targeted-num-v[target vertex count (5%% tolerance)]:count:' \
  '--filter-energy[energy threshold to stop optimization (default 10)]:energy:' \
  '--max-pass[maximum optimization passes (default 80)]:passes:' \
  '--stage[pipeline execution stage (default 1)]:stage:' \
  '--is-laplacian[enable Laplacian smoothing on boundary holes]' \
  '--bg-mesh[background mesh file for sizing field]:file:_files' \
  '--save-mid-result[save intermediate results]:level:(0 1 2)' \
  '(-q --is-quiet)'{-q,--is-quiet}'[suppress console output]' \
  '--log[log file path]:file:_files' \
  '--level[log verbosity (0 verbose, 6 silent)]:level:' \
  '--postfix[output filename postfix]:postfix:' \
  '1:input surface mesh:_files -g "*.{off,obj,stl,ply}"' \
  '2:output tetmesh:_files -g "*.{msh,mesh}"' && ret=0

return ret
