#compdef mysqlctl
# _mysqlctl — Vitess MySQL lifecycle helper (init/start/shutdown/reinit)
# upstream: https://github.com/vitessio/vitess
# Subcommands + persistent flags from go/cmd/mysqlctl/command on tip.

_mysqlctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--mysql-port=[mysqld port]:port:' \
        '--tablet-uid=[tablet UID]:n:' \
        '--mysql-socket=[mysqld socket path]:path:_files' \
        '-v[verbosity level]:n:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:initialize MySQL data dir + config'
                'init-config:write a default mysqld.cnf'
                'reinit-config:rewrite mysqld config from scratch'
                'position:print/parse MySQL replication position'
                'shutdown:shut down mysqld'
                'start:start mysqld'
                'teardown:full teardown (stop + delete data)'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments \
                '--wait-time=[wait this long for mysqld startup/shutdown]:dur:' \
                '*: :_files'
            ;;
    esac
}

_mysqlctl "$@"
