#compdef pass-otp
# Documentation: https://github.com/tadfisher/pass-otp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_pass_otp_commands() {
  local -a commands=(
    'code:generate an OTP code from a stored URI'
    'insert:add an OTP key URI'
    'append:append an OTP key URI to an existing entry'
    'uri:display the stored OTP URI'
    'validate:validate an OTP URI'
    'help:show help'
  )
  _describe 'command' commands
}

_pass_otp_entries() {
  local prefix="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
  local -a entries
  if [[ -d "$prefix" ]]; then
    entries=(${${(f)"$(find "$prefix" -name '*.gpg' -type f 2>/dev/null)"}#$prefix/})
    entries=(${entries%.gpg})
    _describe 'entry' entries
  fi
}

_pass-otp() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:_pass_otp_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        code)
          _arguments \
            '(-c --clip)'{-c,--clip}'[copy code to clipboard]' \
            '1:entry:_pass_otp_entries'
          ;;
        insert)
          _arguments \
            '(-f --force)'{-f,--force}'[overwrite without confirmation]' \
            '(-e --echo)'{-e,--echo}'[echo input during entry]' \
            '1:entry:_pass_otp_entries'
          ;;
        append)
          _arguments \
            '(-f --force)'{-f,--force}'[overwrite existing OTP]' \
            '(-e --echo)'{-e,--echo}'[echo input during entry]' \
            '1:entry:_pass_otp_entries'
          ;;
        uri)
          _arguments \
            '(-c --clip)'{-c,--clip}'[copy URI to clipboard]' \
            '(-q --qrcode)'{-q,--qrcode}'[display URI as QR code]' \
            '1:entry:_pass_otp_entries'
          ;;
        validate)
          _arguments \
            '1:uri:'
          ;;
      esac
      ;;
  esac
}

_pass-otp "$@"
