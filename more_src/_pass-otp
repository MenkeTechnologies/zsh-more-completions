#compdef pass-otp

_pass_otp_commands() {
  local -a commands=(
    'insert:Add an OTP key'
    'append:Append an OTP key to existing entry'
    'code:Generate an OTP code'
    'uri:Display the OTP URI'
    'validate:Validate an OTP URI'
    'help:Show help'
  )
  _describe 'command' commands
}

_pass_otp_entries() {
  local prefix="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
  local -a entries
  if [[ -d "$prefix" ]]; then
    entries=(${${(f)"$(find "$prefix" -name '*.gpg' -type f 2>/dev/null)"}#$prefix/})
    entries=(${entries%.gpg})
    _describe 'entry' entries
  fi
}

_pass-otp() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:_pass_otp_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        insert)
          _arguments \
            '(-f --force)'{-f,--force}'[overwrite existing entry]' \
            '(-e --echo)'{-e,--echo}'[echo the input]' \
            '(-s --secret)'{-s,--secret}'=[provide secret on command line]:secret' \
            '(-a --algorithm)'{-a,--algorithm}'=[hash algorithm]:algorithm:(sha1 sha256 sha512)' \
            '(-d --digits)'{-d,--digits}'=[number of digits]:digits:(6 7 8)' \
            '(-p --period)'{-p,--period}'=[time period in seconds]:period' \
            '(-i --issuer)'{-i,--issuer}'=[issuer name]:issuer' \
            '(-c --counter)'{-c,--counter}'=[HOTP counter]:counter' \
            '1:entry:_pass_otp_entries'
          ;;
        append)
          _arguments \
            '(-f --force)'{-f,--force}'[overwrite existing OTP]' \
            '(-e --echo)'{-e,--echo}'[echo the input]' \
            '(-s --secret)'{-s,--secret}'=[provide secret on command line]:secret' \
            '(-a --algorithm)'{-a,--algorithm}'=[hash algorithm]:algorithm:(sha1 sha256 sha512)' \
            '1:entry:_pass_otp_entries'
          ;;
        code)
          _arguments \
            '(-c --clip)'{-c,--clip}'[copy to clipboard]' \
            '1:entry:_pass_otp_entries'
          ;;
        uri)
          _arguments \
            '(-c --clip)'{-c,--clip}'[copy to clipboard]' \
            '(-q --qrcode)'{-q,--qrcode}'[display QR code]' \
            '1:entry:_pass_otp_entries'
          ;;
        validate)
          _arguments \
            '1:uri'
          ;;
      esac
      ;;
  esac
}

_pass-otp "$@"
