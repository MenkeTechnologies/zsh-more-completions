#compdef gouldtoppm
# Documentation: man gouldtoppm (Netpbm)
# Source: convert a Gould (NP12 scanner) image to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:gould file:_files' \
    && ret=0

return ret
