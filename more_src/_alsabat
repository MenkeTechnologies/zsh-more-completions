#compdef alsabat
# Documentation: https://manpages.debian.org/alsabat.1
# Source: alsa-utils — Basic Audio Tester (loopback + FFT analysis for QA / DAC verification).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-D[soundcard name to test]:card:' \
    '-P[playback PCM device]:device:' \
    '-C[capture PCM device]:device:' \
    '-f[sample format]:fmt:(S16_LE S24_LE S32_LE U8)' \
    '-c[number of channels]:n:' \
    '-r[sampling rate in Hz]:hz:(8000 16000 22050 32000 44100 48000 88200 96000)' \
    '-n[duration of generated signal]:duration:' \
    '-k[sigma k value for analysis]:k:' \
    '-F[target signal frequency in Hz]:hz:' \
    '-p[total periods to play or capture]:n:' \
    '--log=[write stderr/stdout to this log file]:file:_files' \
    '--file=[input WAV file for playback]:file:_files' \
    '--saveplay=[target WAV file to save capture content]:file:_files' \
    '--local[internal loopback mode for testing alsabat]' \
    '--standalone[run without analyzing on a remote machine]' \
    '--roundtriplatency[round-trip latency test]' \
    '--snr-db=[noise detection threshold (SNR dB)]:db:' \
    '--snr-pc=[noise detection threshold (% noise amplitude)]:pct:' \
    && ret=0

return ret
