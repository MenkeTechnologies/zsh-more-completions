#compdef condor_transform_ads

# condor_transform_ads: apply transforms (ClassAd transforms) to a stream of ads
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-rules=[transform rules file]:file:_files' \
  '-set=[set attribute]:attr=value:' \
  '-jobtransforms[apply job transforms]' \
  '-jobtransforms-name=[named transform]:name:' \
  '-jobtransforms-file=[transform file]:file:_files' \
  '-long[long format]' \
  '-debug[debug]' \
  '-out=[output file]:file:_files' \
  '*:input file:_files' && ret=0
return ret
