#compdef condor_transform_ads
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_transform_ads.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]:topic:(rules convert)' \
  '-rules[transform rules file]:file:_files' \
  '-jobtransforms[comma-separated transform names]:names:' \
  '-jobroute[specify a job route]:name:' \
  '-in[input file (form\: long/xml/json/new/auto)]:file:_files' \
  '-out[output file with optional form]:file:_files' \
  '-long[long form for input/output (default)]' \
  '-json[JSON form for input/output]' \
  '-xml[XML form for input/output]' \
  '-verbose[echo transform names and rules to stderr]' \
  '-terse[disable verbose mode]' \
  '-debug[debug output]' \
  '-unit-test[unit-test mode]' \
  '-testing[testing mode]' \
  '-convertoldroutes[convert old route formats]' \
  '*:input file:_files' && ret=0
return ret
