#compdef susmoqcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/susmoqcsv.c
# SUSMOQCSV - input Q-records, alter and spatially smooth, output Q-records

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:f:_files' \
  'qout=[output file for q-records]:f:_files' \
  'rfile=[read a K-file with grid definition]:f:_files' \
  'check=[1 print checking details]:c:(0 1)' \
  'inloc=[input location option]:i:' \
  'keyloc=[location key name]:k:' \
  'cdpt=[grid transposed cdp numbers]:c:' \
  'cname=[name of value to smooth]:c:' \
  'ename=[entry name being processed]:e:' \
  'sname=[smoothed value name]:s:' \
  'navrg=[number of values to average]:n:' \
  'nback=[number of values backward]:n:' \
  'nsmth=[number of smoothing passes]:n:' \
  'extrapt=[extrapolation in time direction]:e:' \
  'formtv=[format of time-velocity values]:f:' \
  'formxy=[format of x-y coordinate values]:f:' \
  'outind=[output independent dimension values]:o:' \
  'outlist=[output value name list]:o:' \
  '*:SU file:_files' && ret=0

return ret
