#compdef miasm miasm-cli
# _miasm — Cea-Sec miasm CLI binary analysis framework command-line frontend supporting reverse engineering disassembly intermediate-representation symbolic-execution decompilation expression-simplification jit-engine for x86 x86_64 ARM ARM64 MIPS PowerPC MSP430 architecture binary CTF reverse-engineering RE pipeline (Cea-Sec team, Python); argparse
# upstream: https://github.com/cea-sec/miasm

_miasm() {
    local -a sub=(
        'disasm:disassemble binary'
        'lifter:lift to IR'
        'symbolic:symbolic execution'
        'decompile:decompile to high-level pseudo-code'
        'cfg:compute control flow graph'
        'simp:expression simplifier'
        'jit:JIT execution'
        'sandbox:sandbox emulation'
        'sembuilder:symbol builder'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--arch=+[a]:a:(x86_32 x86_64 arm aarch64 mips32 mips64 mep ppc32 msp430 sh4)' \
        '--bitness=+[N]:n:(16 32 64)' \
        '--entry=+[addr]:str:' \
        '--start=+[addr]:str:' \
        '--end=+[addr]:str:' \
        '--api-platform=+[p]:p:(win_xp win_7 win_10 linux freebsd macos)' \
        '--graph=+[fmt]:f:(dot dgml gml ascii html)' \
        '--no-stub[no stub]' \
        '--symbols=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'miasm subcommand' sub ;;
        args)
            case $words[1] in
                disasm|lifter|symbolic|decompile|cfg|jit|sandbox) _arguments '*:binary:_files' ;;
            esac
            ;;
    esac
}

_miasm "$@"
