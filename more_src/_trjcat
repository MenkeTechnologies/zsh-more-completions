#compdef trjcat gmx-trjcat
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-trjcat.html
# Concatenate several trajectory files in sorted order, removing duplicate frames

local ret=1

_arguments -s -S \
  '*-f+[input trajectory files]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-demux+[xvg file for reordering trajectories]:xvg file:_files -g "*.xvg"' \
  '-o+[output trajectory file]:trajectory:_files -g "*.(xtc|trr|gro|g96|pdb|tng|h5md)"' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-b+[first time to include ps]:time:' \
  '-e+[last time to include ps]:time:' \
  '-dt+[write frames at intervals ps]:time:' \
  '-settime[interactively change starting time per file]' \
  '-sort[sort trajectory files]' \
  '-keeplast[retain overlapping frames at trajectory end]' \
  '-overwrite[overwrite overlapping frames during append]' \
  '-cat[preserve duplicate time frames]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
