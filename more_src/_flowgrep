#compdef flowgrep
# Documentation: https://monkey.org/~jose/software/flowgrep/
# TCP stream/UDP/IP payload 'grep' utility

local ret=1

_arguments -s -S \
  '-a+[match any stream with pattern]:pattern:' \
  '-c+[match client stream with pattern]:pattern:' \
  '-D+[distance score for libdistance-based match]:num:' \
  '-d+[input device]:interface:_net_interfaces' \
  '-E+[string distance algorithm to use]:algorithm:(levenshtein damerau hamming jaccard)' \
  '-e+[string to compare against for distance-based matches]:string:' \
  '-F+[obtain server patterns from file, one per line]:file:_files' \
  '-f+[obtain client patterns from file, one per line]:file:_files' \
  '-i[case insensitive match]' \
  '-k[kill matched stream, TCP only]' \
  '-l+[log matched flows relative to dir]:dir:_files -/' \
  '-r+[input file in pcap format]:pcap file:_files' \
  '-s+[match server stream with pattern]:pattern:' \
  '-u+[run as username]:user:_users' \
  '-V[print version information and exit]' \
  '-v[select non-matching input]' \
  '-x[print logged filenames for use with xargs]' \
  '*:pcap file:_files' && ret=0

return ret
