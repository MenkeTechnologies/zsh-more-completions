#compdef enroot

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'batch:run batch configuration'
      'create:create container from image'
      'exec:execute command in container'
      'export:export container to image'
      'import:import container image'
      'list:list containers'
      'remove:remove containers'
      'start:start container'
      'version:show version'
    )
    _describe -t commands 'enroot command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '--name=[container name]:name' \
          '1:image:_files -g "*.sqsh(-.)"' && ret=0
        ;;
      import)
        _arguments -s -S \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '1:URI:' && ret=0
        ;;
      start)
        _arguments -s -S \
          '--root[start as root]' \
          '--rw[writable rootfs]' \
          '-m+[mount]:mount spec' \
          '--mount=[mount]:mount spec' \
          '-e+[environment variable]:name=value' \
          '--env=[environment variable]:name=value' \
          '1:container:' \
          '*::command:_command_names -e' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '-f[force removal]' \
          '--force[force removal]' \
          '1:container:' && ret=0
        ;;
    esac
    ;;
esac

return ret
