#compdef ncdump-hdf
# Documentation: https://docs.unidata.ucar.edu/netcdf-c/current/netcdf_utilities_guide.html
# HDF4 build of ncdump: dump an HDF/netCDF file as CDL text

local ret=1

_arguments -s -S \
  '-c[show values of coordinate variables only]' \
  '-h[show only the header information]' \
  '*-v+[include data values for the specified variables]:variables' \
  '-b+[brief CDL comment annotations (c or f)]:lang:(c f)' \
  '-f+[full CDL comment annotations (c or f)]:lang:(c f)' \
  '-l+[maximum line length for lists]:length' \
  '-n+[name for the netCDF file in CDL output]:name' \
  '-p+[default floating-point precision]:precision' \
  '-k[show kind of netCDF file]' \
  '-s[output special virtual attributes]' \
  '-t[display time data as human-readable date-time strings]' \
  '-i[display time data as ISO-8601 date-time strings]' \
  '*-g+[include data values only for the specified groups]:groups' \
  '-w[access remote DAP data with client-side caching]' \
  '-x[output XML (NcML) instead of CDL]' \
  '1:file:_files -g "*.(nc|hdf|h4|cdf)"' && ret=0

return ret
