#compdef crux-mir crux-llvm
# _crux-mir — Crux: symbolic simulator for Rust MIR / LLVM bitcode (GaloisInc/crucible)
# upstream: https://github.com/GaloisInc/crucible
# Flags from crux/src/Crux/Config/Common.hs.

_crux-mir() {
    local -a args
    args=(
        '(-d --sim-verbose)'{-d+,--sim-verbose=}'[simulator verbosity (0-3)]:level:'
        '--path-sat[enable path satisfiability checking]'
        '--path-strategy=[symbolic-execution strategy]:strategy:(always-merge split-dfs)'
        '--output-directory=[directory for output artifacts]:dir:_files -/'
        '--profile-crucible[enable Crucible profiling]'
        '--profile-solver[enable solver profiling]'
        '-p+[profiling sample period (seconds)]:seconds:'
        '--profiling-period=[profiling sample period (seconds)]:seconds:'
        '--branch-coverage[record branch coverage]'
        '(-t --timeout)'{-t+,--timeout=}'[overall timeout in seconds]:seconds:'
        '--goal-timeout=[per-goal solver timeout in seconds]:seconds:'
        '(-i --iteration-bound)'{-i+,--iteration-bound=}'[max symbolic-execution iterations]:n:'
        '(-r --recursion-bound)'{-r+,--recursion-bound=}'[max recursion depth]:n:'
        '(-x --no-execs)'{-x,--no-execs}'[do not generate executables]'
        '--no-unsat-cores[disable unsat-core extraction]'
        '(-n --get-abducts)'{-n+,--get-abducts=}'[number of abducts to request]:n:'
        '(-s --solver)'{-s+,--solver=}'[backend SMT solver]:solver:(z3 yices cvc4 cvc5 boolector stp)'
        '--path-sat-solver=[separate SMT solver for path satisfiability]:solver:(z3 yices cvc4 cvc5)'
        '--force-offline-goal-solving[force offline solver for goal queries]'
        '--path-sat-solver-output=[path-sat solver log file]:file:_files'
        '--online-solver-output=[online solver log file]:file:_files'
        '--offline-solver-output=[offline solver log file]:file:_files'
        '--mcsat[enable MCSAT (Yices only)]'
        '--skip-report[skip writing the HTML report]'
        '--skip-success-reports[skip reports for proved goals]'
        '--skip-incomplete-reports[skip reports for incomplete goals]'
        '--hash-consing[enable hash-consing of symbolic terms]'
        '--skip-print-failures[do not print failure details]'
        '--fail-fast[stop on first proof failure]'
        '(-q --quiet)'{-q,--quiet}'[quiet mode]'
        '(-f --floating-point)'{-f+,--floating-point=}'[floating-point handling]:mode:(default real ieee)'
        '--debug[enable debug output]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*:input file:_files -g "*.(rs|bc|ll|toml)"'
    )
    _arguments -s -S $args
}

_crux-mir "$@"
