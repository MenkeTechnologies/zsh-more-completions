#compdef vscli

# https://github.com/michidk/vscli — src/opts.rs

local curcontext="$curcontext" state line ret=1
local -a _vs_open_behaviors

_vs_open_behaviors=(none workspace devcontainer)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s)'{-s+,--history-path=}'[history JSON path]:file:_files' \
  '--config-dir=[VSCLI config directory]:directory:_files -/' \
  '(-n --dry-run)'{-n,--dry-run}'[do not launch editor]' \
  '(--verbose)'{-v,--verbose}'[increase log verbosity]' \
  '(quiet)'{-q}'[quiet logs (clap verbosity)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _vs_cmds
    _vs_cmds=(
      open:'open devcontainer or folder'
      recent:'pick from recent workspaces'
      config:'manage stored devcontainer configs'
      container:'manage running devcontainers'
    )
    _describe -t commands 'vscli command' _vs_cmds && ret=0
    ;;
  (args)
    case $line[1] in
      (open|o)
        _arguments \
          '::workspace path:_files -/' \
          '(-c --command)'{-c+,--command=}'[editor executable]:command:' \
          '(-b --behavior)'{-b+,--behavior=}"[container strategy]:strategy:($_vs_open_behaviors)" \
          '--config=[devcontainer JSON]:file:_files' \
          '*::extra editor args:' && ret=0
        ;;
      (recent|ui)
        _arguments \
          '--hide-instructions[minimal UI text]' \
          '--hide-info[hide strategy and paths in UI]' \
          '(-c --command)'{-c+,--command=}'[editor executable]:command:' \
          '(-b --behavior)'{-b+,--behavior=}"[container strategy]:strategy:($_vs_open_behaviors)" \
          '--config=[devcontainer JSON]:file:_files' \
          '*::extra editor args:' && ret=0
        ;;
      (config|cfg)
        if (( $#line == 1 )); then
          local -a _vs_cfg
          _vs_cfg=(ui:'picker' list:'list configs' dir:'print config dir' add:'new config' copy:'copy to project' rm:'remove')
          _describe -t actions 'config action' _vs_cfg && ret=0
        else
          case $line[2] in
            (list|ls)
              _arguments '(-l --long)'{-l,--long}'[show full paths]' && ret=0 ;;
            (add)
              _arguments ':config name:' && ret=0 ;;
            (copy|cp)
              _arguments ':stored name:' '*::directory:_files -/' && ret=0 ;;
            (rm)
              _arguments ':config name:' && ret=0 ;;
          esac
        fi
        ;;
      (container|ct)
        if (( $#line == 1 )); then
          local -a _vs_ct
          _vs_ct=(ui:'picker' list:'list containers' info:'inspect' stop:'stop')
          _describe -t actions 'container action' _vs_ct && ret=0
        else
          case $line[2] in
            (list|ls)
              _arguments '(-a --all)'{-a,--all}'[include stopped]' && ret=0 ;;
            (info|stop)
              _arguments ':container id:' && ret=0 ;;
          esac
        fi
        ;;
    esac ;;
esac

return ret
