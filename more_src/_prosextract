#compdef prosextract
# Documentation: https://man.archlinux.org/search?q=prosextract
# Reference accessed: 2026-05-16

# EMBOSS prosextract: build PROSITE motif database for use by patmatmotifs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-prositedir=[directory containing PROSITE files (prosite.dat, prosite.doc)]:dir:_files -/' \
  '*:PROSITE directory:_files -/' && ret=0
return ret
