#compdef raspi-config
# _raspi-config — Raspberry Pi Foundation raspi-config CLI for the Raspberry Pi configuration tool managing system settings expand-rootfs interfaces ssh vnc spi i2c serial onewire boot-options localisation overclock advanced wifi-country (RPi-Distro team, Bash); getopt
# upstream: https://github.com/RPi-Distro/raspi-config

_raspi-config() {
    local -a sub=(
        'nonint:run non-interactive command'
        'expand_rootfs:expand root filesystem'
        'change_passwd:change user password'
        'change_locale:set locale'
        'change_timezone:set timezone'
        'change_hostname:set hostname'
        'change_wifi_country:set Wi-Fi country code'
        'do_ssh:enable/disable SSH'
        'do_vnc:enable/disable VNC'
        'do_spi:enable/disable SPI'
        'do_i2c:enable/disable I2C'
        'do_serial:configure serial port'
        'do_onewire:enable/disable 1-Wire'
        'do_camera:enable/disable camera'
        'do_overscan:enable/disable overscan'
        'do_audio:audio device select'
        'do_resolution:select resolution'
        'do_overclock:overclock options'
        'do_memory_split:set GPU memory split'
        'do_glamor:enable/disable Glamor'
        'do_pi4video:Pi 4 video options'
        'do_blanking:enable/disable screen blanking'
        'do_pixdub:doubled pixel mode'
        'do_compositor:enable/disable compositor'
        'do_overlayfs:enable/disable overlay fs'
        'do_p2wlan:Pi 2 Wi-Fi options'
        'do_xcompmgr:enable/disable xcompmgr'
        'do_wifi_country:set Wi-Fi country code'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--memory_split=+[MB]:n:(16 32 64 128 256 512)' \
        '--expand_rootfs[expand root filesystem]' \
        '--apply_overlay=+[overlay]:str:' \
        '--remove_overlay=+[overlay]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'raspi-config subcommand' sub ;;
        args)
            case $words[1] in
                nonint) _arguments '*:command args:' ;;
                do_ssh|do_vnc|do_spi|do_i2c|do_serial|do_onewire|do_camera|do_overscan|do_blanking|do_overlayfs) _arguments \
                    '*:state:(0 1)' ;;
                do_memory_split) _arguments \
                    '*:MB:(16 32 64 128 256 512)' ;;
                do_audio) _arguments \
                    '*:device:(0 1 2)' ;;
                do_overclock) _arguments \
                    '*:mode:(None Modest Medium High Turbo Pi2)' ;;
            esac
            ;;
    esac
}

_raspi-config "$@"
