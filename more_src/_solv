autoload -U is-at-least

_solv() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_solv_commands" \
"*::: :->solv" \
&& ret=0
    case $state in
    (solv)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:solv-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
'-e+[Visual Studio solution extension]:EXTENSION:_default' \
'--ext=[Visual Studio solution extension]:EXTENSION:_default' \
'-p[Show only solutions with problems. Correct solutions will not be shown.]' \
'--problems[Show only solutions with problems. Correct solutions will not be shown.]' \
'-r[Scan directory recursively. False by default]' \
'--recursively[Scan directory recursively. False by default]' \
'--showerrors[Output solution parsing errors while scanning directories. False by default]' \
'-t[Show scanning time in case of directory scanning. False by default]' \
'--time[Show scanning time in case of directory scanning. False by default]' \
'-h[Print help]' \
'--help[Print help]' \
':PATH -- Sets solution path or directory to analyze:_default' \
":: :_solv__subcmd__validate_commands" \
"*::: :->validate" \
&& ret=0

    case $state in
    (validate)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:solv-validate-command-$line[2]:"
        case $line[2] in
            (fix)
_arguments "${_arguments_options[@]}" : \
'-e+[Visual Studio solution extension]:EXTENSION:_default' \
'--ext=[Visual Studio solution extension]:EXTENSION:_default' \
'-r[Scan directory recursively. False by default]' \
'--recursively[Scan directory recursively. False by default]' \
'--showerrors[Output solution parsing errors while scanning directories. False by default]' \
'-t[Show scanning time in case of directory scanning. False by default]' \
'--time[Show scanning time in case of directory scanning. False by default]' \
'-h[Print help]' \
'--help[Print help]' \
':PATH -- Sets solution path or directory to analyze:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_solv__subcmd__validate__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:solv-validate-help-command-$line[1]:"
        case $line[1] in
            (fix)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(info)
_arguments "${_arguments_options[@]}" : \
'-e+[Visual Studio solution extension]:EXTENSION:_default' \
'--ext=[Visual Studio solution extension]:EXTENSION:_default' \
'-r[Scan directory recursively. False by default]' \
'--recursively[Scan directory recursively. False by default]' \
'--showerrors[Output solution parsing errors while scanning directories. False by default]' \
'-t[Show scanning time in case of directory scanning. False by default]' \
'--time[Show scanning time in case of directory scanning. False by default]' \
'-h[Print help]' \
'--help[Print help]' \
'::PATH -- Sets solution path or directory to analyze:_default' \
&& ret=0
;;
(nuget)
_arguments "${_arguments_options[@]}" : \
'-e+[Visual Studio solution extension]:EXTENSION:_default' \
'--ext=[Visual Studio solution extension]:EXTENSION:_default' \
'-m[Show only mismatched packages if any. i.e. packages with different versions in the same solution]' \
'--mismatch[Show only mismatched packages if any. i.e. packages with different versions in the same solution]' \
'-f[Return not zero exit code if nuget mismatches found]' \
'--fail[Return not zero exit code if nuget mismatches found]' \
'-r[Scan directory recursively. False by default]' \
'--recursively[Scan directory recursively. False by default]' \
'--showerrors[Output solution parsing errors while scanning directories. False by default]' \
'-t[Show scanning time in case of directory scanning. False by default]' \
'--time[Show scanning time in case of directory scanning. False by default]' \
'-h[Print help]' \
'--help[Print help]' \
':PATH -- Sets solution path or directory to analyze:_default' \
&& ret=0
;;
(json)
_arguments "${_arguments_options[@]}" : \
'-e+[Visual Studio solution extension]:EXTENSION:_default' \
'--ext=[Visual Studio solution extension]:EXTENSION:_default' \
'-r[Scan directory recursively. False by default]' \
'--recursively[Scan directory recursively. False by default]' \
'--showerrors[Output solution parsing errors while scanning directories. False by default]' \
'-t[Show scanning time in case of directory scanning. False by default]' \
'--time[Show scanning time in case of directory scanning. False by default]' \
'-p[Pretty-printed output. False by default]' \
'--pretty[Pretty-printed output. False by default]' \
'-h[Print help]' \
'--help[Print help]' \
'::PATH -- Sets solution path or directory to analyze:_default' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':generator:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(bugreport)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_solv__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:solv-help-command-$line[1]:"
        case $line[1] in
            (validate)
_arguments "${_arguments_options[@]}" : \
":: :_solv__subcmd__help__subcmd__validate_commands" \
"*::: :->validate" \
&& ret=0

    case $state in
    (validate)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:solv-help-validate-command-$line[1]:"
        case $line[1] in
            (fix)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(info)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(nuget)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(json)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(bugreport)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_solv_commands] )) ||
_solv_commands() {
    local commands; commands=(
'validate:Validates solutions within directory or file specified' \
'info:Get information about found solutions' \
'nuget:Get nuget packages information within solutions' \
'json:Converts solution(s) into json' \
'completion:Generate the autocompletion script for the specified shell' \
'bugreport:Collect information about the system and the environment that users can send along with a bug report' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'solv commands' commands "$@"
}
