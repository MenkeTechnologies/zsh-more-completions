#compdef bean-web
# _bean-web — start the beancount Bottle-based web server (beancount/beancount)
# upstream: https://github.com/beancount/beancount
# Flags from beancount/web/web.py.

_bean-web() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-q --quiet)'{-q,--quiet}'[no logging]' \
        '--debug[run in debug mode]' \
        '--incognito[hide account names / amounts]' \
        '--no-source[do not include source links]' \
        '--no-colons[do not use colons in URLs]' \
        '--public[bind to public address]' \
        '--port=[port (default 8080)]:port:' \
        '--view=[restrict to a specific view]:view:' \
        '--first-month=[first month of fiscal year (1-12)]:n:' \
        '1:Beancount file:_files -g "*.beancount"'
}

_bean-web "$@"
