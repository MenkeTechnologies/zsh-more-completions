#compdef msr-tools
# _msr-tools — Linux msr-tools rdmsr/wrmsr suite CLI alias (Intel / msr-tools team, C); custom argparse
# upstream: https://github.com/intel/msr-tools

_msr-tools() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--all[all CPUs]' \
        '-a[all CPUs]' \
        '--cpu=+[cpu]:n:' \
        '-p+[cpu]:n:' \
        '--processor=+[processor]:n:' \
        '-0[hex]' \
        '-d[decimal]' \
        '-x[hex]' \
        '-o[octal]' \
        '-c[lowercase]' \
        '-C[uppercase]' \
        '-r[raw binary]' \
        '-f+[bits high:low]:str:' \
        '--bitfield=+[bits high:low]:str:' \
        '-z[zero-padded]' \
        '*:msr-register:'
}

_msr-tools "$@"
