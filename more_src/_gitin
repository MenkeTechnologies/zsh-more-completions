#compdef gitin
# Documentation: https://man.archlinux.org/search?q=gitin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'log:browse commit log in a TUI'
  'status:interactive status view'
  'branch:browse branches'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' && ret=0

case $state in
  (command)
    _describe -t commands 'gitin command' commands && ret=0
    ;;
esac

return ret
