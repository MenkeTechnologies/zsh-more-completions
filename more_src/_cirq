#compdef cirq cirq-cli cirq-google cirq-aqt
# _cirq — Google Quantum AI Cirq Python framework for writing simulating and running NISQ quantum circuits (quantumlib team, Python); argparse
# upstream: https://github.com/quantumlib/Cirq

_cirq() {
    local -a sub=(
        'simulate:simulate a circuit on local simulator'
        'optimize:apply optimization passes'
        'serialize:serialize circuit to JSON/proto'
        'deserialize:deserialize circuit'
        'run:run on a backend'
        'gates:list available gates'
        'devices:list device specs'
        'transform:apply circuit transformer'
        'google:Google quantum backends'
        'aqt:AQT backend subcommands'
        'pasqal:Pasqal backend subcommands'
        'ionq:IonQ backend subcommands'
        'rigetti:Rigetti backend subcommands'
        'experiments:run experimental routines'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--input=+[circuit file]:file:_files -g "*.qasm *.json *.py *.proto"' \
        '-i+[circuit file]:file:_files -g "*.qasm *.json *.py *.proto"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--repetitions=+[N]:n:' \
        '-r+[N]:n:' \
        '--seed=+[seed]:n:' \
        '--backend=+[backend]:b:(simulator density_matrix mps qsim cirq-google cirq-ionq cirq-aqt cirq-rigetti cirq-pasqal)' \
        '--device=+[device id]:str:' \
        '--noise=+[noise model]:str:' \
        '--qubits=+[N]:n:' \
        '--measurement-key=+[key]:str:' \
        '--no-progress[no progress bar]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cirq subcommand' sub ;;
        args)
            case $words[1] in
                google) _arguments '1:google cmd:(list-processors run get-calibration get-engine)' ;;
                ionq|aqt|pasqal|rigetti) _arguments '1:backend cmd:(list-backends run get-status get-result)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_cirq "$@"
