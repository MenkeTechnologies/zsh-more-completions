#compdef code-insiders

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --diff)'{-d,--diff}'[compare two files]:file1:_files:file2:_files' \
  '(-m --merge)'{-m,--merge}'[three-way merge]:file1:_files:file2:_files:base:_files:result:_files' \
  '(-a --add)'{-a,--add}'[add folder to workspace]:folder:_directories' \
  '(-g --goto)'{-g,--goto}'[open file at path\:line\:column]:file:_files' \
  '(-n --new-window)'{-n,--new-window}'[open a new window]' \
  '(-r --reuse-window)'{-r,--reuse-window}'[open in last active window]' \
  '(-w --wait)'{-w,--wait}'[wait for files to be closed]' \
  '--locale=[locale]:locale' \
  '--user-data-dir=[user data directory]:directory:_directories' \
  '--profile=[open with profile]:profile' \
  '--extensions-dir=[extensions directory]:directory:_directories' \
  '--list-extensions[list installed extensions]' \
  '--show-versions[show extension versions]' \
  '--category=[filter extensions by category]:category' \
  '--install-extension=[install extension]:extension' \
  '--uninstall-extension=[uninstall extension]:extension' \
  '--enable-proposed-api=[enable proposed API]:extension' \
  '--verbose[verbose output]' \
  '--log=[log level]:level:(critical error warn info debug trace off)' \
  '--status[print process info]' \
  '--prof-startup[profile startup]' \
  '--disable-extensions[disable all extensions]' \
  '--disable-extension=[disable specific extension]:extension' \
  '--sync=[turn sync on/off]:state:(on off)' \
  '--inspect-extensions=[inspect extensions]:port' \
  '--inspect-brk-extensions=[inspect extensions with break]:port' \
  '--disable-gpu[disable GPU acceleration]' \
  '--max-memory=[max memory in MB]:memory' \
  '--telemetry[show telemetry info]' \
  '--folder-uri=[open folder URI]:URI' \
  '--file-uri=[open file URI]:URI' \
  '*:file or directory:_files' && ret=0

return ret
