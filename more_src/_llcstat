#compdef llcstat llcstat-bpfcc
# _llcstat — sample LLC cache references / misses by process (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/llcstat.py (argparse).

_llcstat() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-c --sample_period)'{-c+,--sample_period=}'[sample one in N cache reference/miss events]:n:'
        '(-t --tid)'{-t,--tid}'[summarize by PID/TID instead of PID]'
        '1:duration (seconds, default 10):'
    )
    _arguments $args
}

_llcstat "$@"
