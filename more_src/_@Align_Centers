#compdef @Align_Centers
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@Align_Centers.html
# Move the center of DSET to the center of BASE

local ret=1

_arguments -s -S \
  '-base[base volume, typically a template]:base:_files' \
  '-dset[anatomical dataset to be aligned to BASE]:dset:_files' \
  '-child[additional datasets in register with DSET to shift]:child:_files' \
  '-no_cp[do not create new data; shift existing datasets]' \
  '-echo[echo all commands to terminal for debugging]' \
  '-overwrite[overwrite existing files]' \
  '-prefix[custom result naming instead of default suffix]:prefix' \
  '-1Dmat_only[output only transform matrix; do not shift children]' \
  '-1Dmat_only_nodset[output only transform matrix; create no datasets]' \
  '-grid[center is the volume grid center (default)]' \
  '-cm[center is the center of mass of the volume]' \
  '-cm_no_amask[use center of mass without automask]' \
  '-shift_xform[apply shift translation from 1D file]:file:_files' \
  '-shift_xform_inv[apply inverse of shift translation from 1D file]:file:_files' && ret=0

return ret
