#compdef shfmt-cli
# _shfmt-cli — Daniel Martí shfmt shell formatter from mvdan/sh CLI alias (mvdan team, Go); custom argparse
# upstream: https://github.com/mvdan/sh

_shfmt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-l[list files whose formatting differs]' \
        '-w[write result to file]' \
        '-d[print diff]' \
        '-s[simplify code]' \
        '--apply-ignore[apply .editorconfig ignore]' \
        '-mn[minify]' \
        '-i+[indent spaces]:n:' \
        '-bn[binary ops at start of next line]' \
        '-ci[switch cases indented]' \
        '-sr[redirect operators followed by space]' \
        '-kp[keep column alignments paddings]' \
        '-fn[function next line]' \
        '-ln+[shell variant]:v:(auto posix bash mksh bats)' \
        '-p[posix]' \
        '-tojson[print syntax tree as JSON]' \
        '-tojson-indent=+[indent json]:n:' \
        '-todoc[print as docs]' \
        '-find[print all paths matching shell]' \
        '-filename=+[filename for stdin]:str:' \
        '*:files or dirs:_files'
}

_shfmt-cli "$@"
