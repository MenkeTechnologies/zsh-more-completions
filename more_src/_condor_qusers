#compdef condor_qusers
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_qusers.html
# query and manage User and Project ClassAds in a condor_schedd

local ret=1

_arguments -s -S \
  '-help[print usage then exit]' \
  '-version[print the version then exit]' \
  '-debug[send debugging information to stderr]' \
  '-name[query the named schedd]:schedd-name' \
  '-pool[query the schedd in the named pool]:pool-name:_hosts' \
  '-user[operate on or query the given User ClassAd]:username:_users' \
  '-projects[operate on or query Project ClassAds]' \
  '-constraint[operate on or query ClassAds matching the constraint]:expression' \
  '-long[print ClassAds in long form]' \
  '-format[print selected attribute using the given format]:fmt:_default:attr' \
  '-autoformat[display attributes formatted according to type]:attrs' \
  '-af[display attributes formatted according to type]:attrs' \
  '-aaf[append specified attributes as additional columns]:attrs' \
  '-usage[display CPU and Slot usage]' \
  '*-add[add User or Project ClassAds with the given names]:name' \
  '*-remove[remove User or Project ClassAds with the given names]:name' \
  '-edit[add custom attributes to User or Project ClassAds]:attr=expr' \
  '*-enable[enable the given users, adding them if necessary]:name:_users' \
  '*-disable[disable the given users]:name:_users' \
  '-reason[provide a reason for disabling]:reason-string' && ret=0

return ret
