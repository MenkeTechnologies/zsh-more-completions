#compdef rocprofv3
# Documentation: https://rocm.docs.amd.com/projects/rocprofiler-sdk/en/latest/how-to/using-rocprofv3.html
# rocprofv3 - ROCprofiler-SDK command-line profiling and tracing tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input}'=[input file for counter/configuration collection]:file:_files' \
  '(-o --output-file)'{-o,--output-file}'=[output file name]:file:_files' \
  '(-d --output-directory)'{-d,--output-directory}'=[output directory]:dir:_files -/' \
  '(-f --output-format)'{-f,--output-format}'=[output format(s)]:format:(csv json pftrace otf2 rocpd)' \
  '--hip-trace[collect HIP runtime and compiler traces]' \
  '--hsa-trace[collect HSA API traces]' \
  '--kernel-trace[collect kernel dispatch traces]' \
  '--memory-copy-trace[collect memory copy traces]' \
  '--marker-trace[collect marker (ROCTX) traces]' \
  '--scratch-memory-trace[collect scratch memory operation traces]' \
  '--sys-trace[collect system-level traces]' \
  '--stats[collect statistics of enabled tracing types]' \
  '(-M --mangled-kernels)'{-M,--mangled-kernels}'[do not demangle kernel names]' \
  '(-T --truncate-kernels)'{-T,--truncate-kernels}'[truncate demangled kernel names]' \
  '--kernel-rename[use ROCTX marker names to rename kernels]' \
  '--pmc=[performance monitoring counters to collect]:counters' \
  '(-L --list-avail)'{-L,--list-avail}'[list available counters and PC sampling configurations]' \
  '--preload=[libraries to prepend to LD_PRELOAD]:libs' \
  '(-P --collection-period)'{-P,--collection-period}'=[collection period (START\:DURATION\:REPEAT)]:period' \
  '*::command:_normal' && ret=0

return ret
