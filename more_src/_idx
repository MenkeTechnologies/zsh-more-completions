#compdef idx

_idx() {
    local line
    local -a subcmds

    subcmds=(
        'restart:Rebuilds and restarts your environment'
        'completion:Generate the autocompletion script for the specified shell'
        'help:Help about any command'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[Display help for the command]' \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'idx commands' subcmds
            ;;
        args)
            case $line[1] in
                help)
                    _describe -t commands 'idx commands' subcmds
                    ;;
            esac
            ;;
    esac
}

_idx "$@"
