#compdef bochs
# Documentation: https://github.com/bochs-emu/Bochs/blob/master/bochs/main.cc
# Reference accessed: 2026-05-16
# Verified: bochs/main.cc bx_init_main() lines 700-870 (hand-rolled if-else
# parser with single-dash long flags throughout).

# Bochs: portable x86 PC emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help (optionally features/cpu)]' \
  '(- *)--version[show version]' \
  '-n[do not load .bochsrc]' \
  '-q[quick start (skip menu)]' \
  '-log[log filename]:file:_files' \
  '-unlock[unlock disk images]' \
  '-debugger[enable debugger]' \
  '-dbg[enable debugger (alias)]' \
  '-dbg_gui[enable debugger GUI]' \
  '-dbglog[debugger log filename]:file:_files' \
  '-f[use this .bochsrc file]:file:_files' \
  '-qf[quick start + use this .bochsrc]:file:_files' \
  '-benchmark[run benchmark for N cycles]:n:' \
  '-dumpstats[dump stats every N (if built)]:n:' \
  '-r[restore from saved state directory]:dir:_files -/' \
  '-noconsole[Windows: do not open console]' \
  '*:bochs config (name=value):_files' && ret=0
return ret
