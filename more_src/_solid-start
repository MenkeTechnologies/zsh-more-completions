#compdef solid

# Zsh completion for SolidStart / SolidJS CLI (via vinxi)

_solid-start() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'start:start the development server'
    'build:build for production'
    'dev:alias for start'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'solid command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        start|dev)
          _arguments -s -S \
            '--port=[port to listen on]:port:' \
            '--host=[host to listen on]:host:_hosts' \
            '--open[open in browser]' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--preset=[deployment preset]:preset:(node node-server static netlify vercel cloudflare-pages cloudflare-workers deno aws-lambda bun)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_solid-start "$@"
