#compdef stackcount stackcount-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/stackcount.py argparse)
# Reference accessed: 2026-05-29
# stackcount — count function calls and their callers (kernel/user stacks via kprobes/uprobes/USDT/tracepoints). BCC/eBPF.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-c --cpu)'{-c,--cpu=}'[trace this CPU only]:cpu:' \
  '(-i --interval)'{-i,--interval=}'[summary interval, seconds]:sec:' \
  '(-D --duration)'{-D,--duration=}'[total duration of trace, seconds]:sec:' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-r --regexp)'{-r,--regexp}'[use regular expressions (default is "*" wildcards only)]' \
  '(-s --offset)'{-s,--offset}'[show address offsets]' \
  '(-P --perpid)'{-P,--perpid}'[display stacks separately for each process]' \
  '(-K --kernel-stacks-only -U --user-stacks-only)'{-K,--kernel-stacks-only}'[kernel stack only]' \
  '(-K --kernel-stacks-only -U --user-stacks-only)'{-U,--user-stacks-only}'[user stack only]' \
  '(-v --verbose)'{-v,--verbose}'[show raw addresses]' \
  '(-d --delimited)'{-d,--delimited}'[insert delimiter between kernel/user stacks]' \
  '(-f --folded)'{-f,--folded}'[output folded format (for flame graphs)]' \
  '--debug[print BPF program before starting (debug)]' \
  '1:pattern (search expression e.g. "vfs_*" or "p\:do_sys_open" or "u\:libc\:malloc"):' \
  && ret=0

return ret
