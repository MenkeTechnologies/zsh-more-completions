#compdef waf
# Documentation: https://waf.io/book/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'configure:configure the project'
  'build:execute the build'
  'clean:clean the project'
  'install:install the targets on the system'
  'uninstall:remove the targets installed'
  'dist:create source tarball for redistribution'
  'distclean:remove the build directory'
  'distcheck:create archive and verify it builds'
  'list:list the targets to execute'
  'step:execute tasks step-by-step for debugging'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show program version number and exit]' \
  '(-j --jobs)'{-j+,--jobs=}'[amount of parallel jobs]:jobs' \
  '(-k --keep)'{-k,--keep}'[keep running on errors]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity (-v -vv -vvv)]' \
  '--zones=[debugging zones]:zones' \
  '-o+[build directory]:out:_directories' \
  '--out=[build directory]:out:_directories' \
  '-t+[source directory]:top:_directories' \
  '--top=[source directory]:top:_directories' \
  '--prefix=[installation prefix]:prefix:_directories' \
  '--download[try to download tools if missing]' \
  '(-p --progress)'{-p,--progress}'[progress bar (-pp for IDE output)]' \
  '--targets=[task generators (comma-separated)]:targets' \
  '--files=[files to process (regexp, for step)]:files' \
  '--destdir=[installation root]:destdir:_directories' \
  '(-f --force)'{-f,--force}'[force file installation]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'waf command' commands && ret=0
    ;;
esac

return ret
