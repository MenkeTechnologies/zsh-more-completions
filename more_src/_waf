#compdef waf

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'configure:configure the project'
  'build:build the project'
  'clean:clean build files'
  'install:install the targets'
  'uninstall:uninstall the targets'
  'dist:create a source distribution archive'
  'distclean:remove all build files and configuration'
  'distcheck:create archive and check it builds'
  'list:list available tasks'
  'step:execute a single task'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-j+[number of jobs]:jobs' \
  '--jobs=[number of jobs]:jobs' \
  '-k[keep going on errors]' \
  '--keep[keep going on errors]' \
  '-v[verbose mode]' \
  '--verbose=[verbose level]:level:(0 1 2 3)' \
  '-f+[use specified wscript]:wscript:_files' \
  '--force[force file installation]' \
  '-o+[set build directory]:directory:_directories' \
  '--out=[set build directory]:directory:_directories' \
  '-t+[set top source directory]:directory:_directories' \
  '--top=[set top source directory]:directory:_directories' \
  '--prefix=[set installation prefix]:directory:_directories' \
  '--bindir=[set binary installation directory]:directory:_directories' \
  '--libdir=[set library installation directory]:directory:_directories' \
  '--destdir=[set destination root]:directory:_directories' \
  '--zones=[debugging zones to activate]:zones' \
  '--profile[profile waf]' \
  '--pdb[start debugger on error]' \
  '-p[show progress bar]' \
  '--progress[show progress bar]' \
  '--targets=[comma-separated list of targets to build]:targets' \
  '--check-c-compiler=[C compiler to check for]:compiler:(gcc clang icc)' \
  '--check-cxx-compiler=[C++ compiler to check for]:compiler:(g++ clang++ icpc)' \
  '--color=[color mode]:mode:(auto yes no 0 1)' \
  '-c+[use specified configuration]:config' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'waf command' commands && ret=0
    ;;
esac

return ret
