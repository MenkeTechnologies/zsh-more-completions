#compdef fauna

# Zsh completion for Fauna CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--domain=[Fauna server domain]:domain' \
  '--scheme=[connection scheme]:scheme:(https http)' \
  '--port=[connection port]:port' \
  '--secret=[Fauna secret key]:secret' \
  '--endpoint=[endpoint alias]:endpoint' \
  '--graphqlHost=[GraphQL host]:host' \
  '--graphqlPort=[GraphQL port]:port' \
  '--timeout=[connection timeout in ms]:timeout' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'login:Log in to Fauna'
      'logout:Log out of Fauna'
      'cloud-login:Log in to Fauna cloud'
      'create-database:Create a database'
      'delete-database:Delete a database'
      'list-databases:List databases'
      'create-key:Create a key'
      'delete-key:Delete a key'
      'list-keys:List keys'
      'list-endpoints:List endpoints'
      'add-endpoint:Add an endpoint'
      'delete-endpoint:Delete an endpoint'
      'default-endpoint:Set default endpoint'
      'endpoint:Manage endpoints'
      'shell:Start an interactive shell'
      'eval:Evaluate a FQL expression'
      'upload-graphql-schema:Upload a GraphQL schema'
      'run-queries:Run queries from a file'
      'schema:Manage database schema'
    )
    _describe -t commands 'fauna command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      cloud-login|login|logout)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      create-database|delete-database)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:database name' && ret=0
        ;;
      list-databases|list-keys)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '--timeout=[connection timeout in ms]:timeout' \
          '--format=[output format]:format:(json shell)' \
          '--version=[FQL version]:version:(4 10)' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:database name' && ret=0
        ;;
      eval)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '--timeout=[connection timeout in ms]:timeout' \
          '--format=[output format]:format:(json shell)' \
          '--version=[FQL version]:version:(4 10)' \
          '--file=[read query from file]:query file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:query or database name' && ret=0
        ;;
      upload-graphql-schema)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '--mode=[upload mode]:mode:(merge replace override)' \
          '--graphqlFilePath=[path to GraphQL schema file]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:database name' && ret=0
        ;;
      create-key)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:database name' \
          '2:role:(admin server server-readonly client)' && ret=0
        ;;
      delete-key)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:key id' && ret=0
        ;;
      add-endpoint)
        _arguments -s -S \
          '--alias=[endpoint alias]:alias' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:endpoint URL' && ret=0
        ;;
      delete-endpoint)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:endpoint alias' && ret=0
        ;;
      default-endpoint)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:endpoint alias' && ret=0
        ;;
      run-queries)
        _arguments -s -S \
          '--endpoint=[endpoint alias]:endpoint' \
          '--secret=[Fauna secret key]:secret' \
          '--dir=[directory with query files]:directory:_directories' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      schema)
        local -a schema_cmds=(
          'diff:Show schema differences'
          'push:Push schema changes'
          'pull:Pull schema from database'
          'status:Show schema status'
          'commit:Commit staged schema'
          'abandon:Abandon staged schema'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'schema command' schema_cmds && ret=0
        else
          _arguments -s -S \
            '--dir=[schema directory]:directory:_directories' \
            '--endpoint=[endpoint alias]:endpoint' \
            '--secret=[Fauna secret key]:secret' \
            '(-h --help)'{-h,--help}'[show help]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
