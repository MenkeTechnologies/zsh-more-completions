#compdef iaito
# Documentation: https://github.com/radareorg/iaito
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iaito: Qt GUI front-end for radare2 (formerly Cutter).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-A --analysis)'{-A+,--analysis=}'[auto-analysis level]:level:(0 1 2 3)' \
  '(-F --format)'{-F+,--format=}'[force file format (bin plugin)]:format:' \
  '(-B --base)'{-B+,--base=}'[load binary at base address]:address:' \
  '-i+[run a script file]:file:_files' \
  '(-w --writemode)'{-w,--writemode}'[open file in write mode]' \
  '(-c --bincache)'{-c,--bincache}'[patch relocs (enable bin.cache)]' \
  '--no-plugins[disable all plugins]' \
  '--no-iaito-plugins[skip iaito plugins]' \
  '--no-r2-plugins[skip radare2 plugins]' \
  '--no-output-redirect[disable console output redirection]' \
  '--welcome[display welcome dialog]' \
  '(-d --debug)'{-d+,--debug=}'[open in debug mode (executable or PID)]:target:' \
  '*:file:_files' && ret=0
return ret
