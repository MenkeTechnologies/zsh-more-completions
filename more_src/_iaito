#compdef iaito

# Iaito: Qt GUI front-end for radare2 (formerly Cutter)
# Documentation: https://book.rada.re/tools/iaito/intro.html
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-p[open project file]:file:_files' \
  '--project=[open project file]:file:_files' \
  '-A[open analysis script]:file:_files' \
  '--analysis-args=[r2 analysis args]:args:' \
  '*:file:_files' && ret=0
return ret
