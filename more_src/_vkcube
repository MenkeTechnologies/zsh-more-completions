#compdef vkcube vkcubepp

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--c[number of frames to render]:n:' \
  '--suppress_popups[suppress popup dialogs]' \
  '--present_mode=[present mode]:mode:(0 1 2 3)' \
  '--width=[window width]:px:' \
  '--height=[window height]:px:' \
  '--validate[enable validation layers]' \
  '--xlib[force xlib WSI]' \
  '--xcb[force xcb WSI]' \
  '--wayland[force Wayland WSI]' \
  '--display=[Direct mode display]:display:' && ret=0

return ret
