#compdef atelier
# _atelier — Ahmed Saadi atelier-tui terminal Postman-style HTTP client with rich keybindings (AhmedSaadi0 team, Rust); clap-derive
# upstream: https://github.com/AhmedSaadi0/atelier

_atelier() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.toml *.json"' \
        '-c+[config file]:file:_files -g "*.toml *.json"' \
        '--collection=+[collection file]:file:_files' \
        '--environment=+[environment]:str:' \
        '-e+[environment]:str:' \
        '--workspace=+[workspace dir]:dir:_files -/' \
        '-w+[workspace dir]:dir:_files -/' \
        '--theme=+[theme]:t:(default dark light dracula nord gruvbox monokai)' \
        '-t+[theme]:t:(default dark light dracula nord gruvbox monokai)' \
        '--no-color[disable color]' \
        '--no-tls-verify[skip TLS verification]' \
        '-k[skip TLS verification]' \
        '--timeout=+[seconds]:n:' \
        '--follow-redirects[follow redirects]' \
        '-L[follow redirects]' \
        '--max-redirects=+[N]:n:' \
        '--user-agent=+[ua]:str:' \
        '*--header=+[k:v]:str:' \
        '*-H+[k:v]:str:' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '*:request file:_files -g "*.toml *.json *.yaml *.yml"'
}

_atelier "$@"
