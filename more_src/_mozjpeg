#compdef mozjpeg cjpeg
# Documentation: https://github.com/mozilla/mozjpeg/blob/master/usage.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (and `cjpeg -help` from mozjpeg).

_arguments -s \
  '-quality[compression quality]:n:' \
  '-grayscale[create monochrome JPEG]' \
  '-rgb[create RGB JPEG]' \
  '-optimize[optimize Huffman tables]' \
  '-progressive[create progressive JPEG]' \
  '-targa[input is Targa format]' \
  '-precision[N-bit data precision]:n:' \
  '-lossless[lossless mode (psv[,Pt])]:psv:' \
  '-arithmetic[use arithmetic coding]' \
  '-dct[DCT method]:method:(int fast float)' \
  '-icc[embed ICC profile]:file:_files' \
  '-restart[restart interval]:n:' \
  '-smooth[smoothing factor]:n:' \
  '-maxmemory[max memory in KB]:n:' \
  '-outfile[output filename]:file:_files' \
  '-memdst[compress to memory]' \
  '-report[report progress]' \
  '-strict[treat warnings as fatal]' \
  '-verbose[verbose output]' \
  '-debug[debug output]' \
  '-version[show version]' \
  '-baseline[force baseline quantization tables]' \
  '-qtables[quantization tables file]:file:_files' \
  '-qslots[component quantization tables]:list:' \
  '-sample[component sampling factors]:list:' \
  '-scans[multi-scan script]:file:_files' \
  '*:input:_files'
