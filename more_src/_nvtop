#compdef nvtop

# Zsh completion for nvtop - GPU process monitor

_arguments \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --delay)'{-d,--delay}'[set update interval in seconds]:seconds' \
  '(-s --sort)'{-s,--sort}'[sort by field]:field:(gpu mem cpu pid name)' \
  '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
  '(-p --gpu-select)'{-p,--gpu-select}'[select specific GPU]:gpu ids' \
  '(-e --gpu-ignore)'{-e,--gpu-ignore}'[ignore specific GPU]:gpu ids' \
  '(-C --no-color)'{-C,--no-color}'[no color]' \
  '(-f --freedom-unit)'{-f,--freedom-unit}'[use Fahrenheit]' \
  '(-E --encode)'{-E,--encode}'[show encoder info]' \
  '(-D --decode)'{-D,--decode}'[show decoder info]' \
  '--no-cache[disable config cache]'
