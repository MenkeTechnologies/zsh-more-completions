#compdef nvtop
# Documentation: https://github.com/Syllo/nvtop
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (src/nvtop.c long_options table).

# Zsh completion for nvtop - GPU process monitor

_arguments \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --delay)'{-d,--delay}'[update interval in tenths of a second]:tenths-of-second:' \
  '(-c --config-file)'{-c,--config-file}'[use this config file]:file:_files' \
  '(-C --no-color --no-colour)'{-C,--no-color,--no-colour}'[disable color in output]' \
  '(-f --freedom-unit)'{-f,--freedom-unit}'[use Fahrenheit for temperatures]' \
  '(-i --gpu-info)'{-i,--gpu-info}'[print GPU info and exit]' \
  '(-E --encode-hide)'{-E,--encode-hide}'[encode/decode hide threshold (seconds)]:seconds:' \
  '(-p --no-plot)'{-p,--no-plot}'[disable plot windows]' \
  '(-P --no-processes)'{-P,--no-processes}'[disable process list window]' \
  '(-r --reverse-abs)'{-r,--reverse-abs}'[reverse memory bar (used on right)]' \
  '(-s --snapshot)'{-s,--snapshot}'[take a snapshot and exit]' \
  '(-l --loop)'{-l,--loop}'[loop the snapshot output]'
