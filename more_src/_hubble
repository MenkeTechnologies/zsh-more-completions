#compdef hubble

# Zsh completion for Hubble CLI (Cilium network observability)

local curcontext="$curcontext" state line ret=1

local -a hubble_commands
hubble_commands=(
  'completion:output shell completion code'
  'list:list resources'
  'observe:observe flows and events'
  'record:record flows to a file'
  'reflect:display API endpoints'
  'status:display Hubble status'
  'version:display version information'
)

local -a hubble_global_flags
hubble_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--server=[address of a Hubble server]:server address:'
  '--timeout=[Hubble server dial timeout]:duration:'
  '--tls[use TLS to connect to Hubble]'
  '--tls-allow-insecure[allow insecure TLS]'
  '--tls-ca-cert-files=[TLS CA certificate files]:files:_files'
  '--tls-client-cert-file=[TLS client certificate file]:file:_files'
  '--tls-client-key-file=[TLS client key file]:file:_files'
  '--tls-server-name=[TLS server name override]:name:'
)

_arguments -s -S \
  $hubble_global_flags \
  '1:command:_describe -t commands command hubble_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      observe)
        _arguments -s -S \
          $hubble_global_flags \
          '--all[get all flows stored in Hubble]' \
          '--first=[get first N flows]:number:' \
          '--follow[follow flows in real-time]' \
          '-f[follow flows in real-time]' \
          '--last=[get last N flows]:number:' \
          '--since=[only return flows since this timestamp]:timestamp:' \
          '--until=[only return flows before this timestamp]:timestamp:' \
          '--verdict=[filter by verdict]:verdict:(FORWARDED DROPPED AUDIT ERROR REDIRECTED TRACED TRANSLATED)' \
          '--type=[filter by event type]:type:(trace trace\:to trace\:from drop l7 policy-verdict debug capture agent)' \
          '--protocol=[filter by L4 protocol]:protocol:(tcp udp icmpv4 icmpv6 sctp)' \
          '--http-status=[filter by HTTP status code]:status code:' \
          '--http-method=[filter by HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS CONNECT TRACE)' \
          '--http-path=[filter by HTTP URL path]:path:' \
          '--http-url=[filter by HTTP URL]:url:' \
          '-t=[filter by event type]:type:' \
          '--from-fqdn=[filter by source FQDN]:fqdn:' \
          '--from-identity=[filter by source identity]:identity:' \
          '--from-ip=[filter by source IP]:ip:' \
          '--from-label=[filter by source label]:label:' \
          '--from-namespace=[filter by source namespace]:namespace:' \
          '--from-pod=[filter by source pod]:pod:' \
          '--from-port=[filter by source port]:port:' \
          '--from-service=[filter by source service]:service:' \
          '--from-workload=[filter by source workload]:workload:' \
          '--to-fqdn=[filter by destination FQDN]:fqdn:' \
          '--to-identity=[filter by destination identity]:identity:' \
          '--to-ip=[filter by destination IP]:ip:' \
          '--to-label=[filter by destination label]:label:' \
          '--to-namespace=[filter by destination namespace]:namespace:' \
          '--to-pod=[filter by destination pod]:pod:' \
          '--to-port=[filter by destination port]:port:' \
          '--to-service=[filter by destination service]:service:' \
          '--to-workload=[filter by destination workload]:workload:' \
          '--identity=[filter by security identity]:identity:' \
          '--ip=[filter by IP address]:ip:' \
          '--ip-version=[filter by IP version]:version:(4 6)' \
          '--label=[filter by label]:label:' \
          '--namespace=[filter by namespace]:namespace:' \
          '--node-name=[filter by node name]:node:' \
          '--not[negate the next filter]' \
          '--pod=[filter by pod]:pod:' \
          '--port=[filter by port]:port:' \
          '--service=[filter by service]:service:' \
          '--workload=[filter by workload]:workload:' \
          '-j[enable JSON output]' \
          '--json[enable JSON output]' \
          '-o=[output format]:format:(compact dict json jsonpb table)' \
          '--output=[output format]:format:(compact dict json jsonpb table)' \
          '--color=[colorize output]:mode:(auto always never)' \
          '--time-format=[time format]:format:(StampMilli RFC3339 RFC3339Nano)' \
          '--cel-expression=[CEL expression to filter flows]:expression:' \
          '--print-node-name[print node name in output]' && ret=0
        ;;
      list)
        local -a list_commands
        list_commands=(
          'nodes:list Hubble nodes'
          'namespaces:list namespaces with flows'
        )
        _arguments -s -S \
          $hubble_global_flags \
          '1:list command:_describe -t commands command list_commands' \
          '*::list args:->list_args' && ret=0
        case "$state" in
          list_args)
            case "${line[1]}" in
              nodes)
                _arguments -s -S \
                  $hubble_global_flags \
                  '-o=[output format]:format:(json jsonpb table)' \
                  '--output=[output format]:format:(json jsonpb table)' && ret=0
                ;;
              *)
                _arguments -s -S $hubble_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      status)
        _arguments -s -S \
          $hubble_global_flags \
          '-o=[output format]:format:(json jsonpb table)' \
          '--output=[output format]:format:(json jsonpb table)' && ret=0
        ;;
      record)
        _arguments -s -S \
          $hubble_global_flags \
          '--all[record all flows]' \
          '--duration=[recording duration]:duration:' \
          '--file-prefix=[output file prefix]:prefix:' \
          '--filenames=[output filenames]:files:_files' \
          '--first=[record first N flows]:number:' \
          '--last=[record last N flows]:number:' \
          '--output=[output directory]:directory:_directories' \
          '--since=[only record flows since]:timestamp:' \
          '--until=[only record flows before]:timestamp:' && ret=0
        ;;
      reflect)
        _arguments -s -S \
          $hubble_global_flags && ret=0
        ;;
      completion)
        _arguments -s -S \
          $hubble_global_flags \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S $hubble_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
