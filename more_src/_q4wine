#compdef q4wine
# Documentation: https://github.com/brezerk/q4wine/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp main() lines 112-180 - literal arg handling of
# -h/--help, -v/--version, -m/--minimize, -b/--binary. No other flags.
# Removed from prior file: -d/--debug (not in source - debug mode flag does
# not exist; q4wine has no console-debug option).

# Q4Wine: Qt GUI for managing Wine prefixes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-m --minimize)'{-m,--minimize}'[minimize main window on startup]' \
  '(-b --binary)'{-b,--binary}'[open Q4Wine run dialog for Windows binary]:binary:_files -g "*.(exe|msi|bat|com)"' && ret=0
return ret
