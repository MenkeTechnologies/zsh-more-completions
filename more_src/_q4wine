#compdef q4wine
# Documentation: https://q4wine.brezblock.org.ua/
# Reference accessed: 2026-05-16

# Q4Wine: Qt GUI for managing Wine prefixes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '*:prefix:_files -/' && ret=0
return ret
