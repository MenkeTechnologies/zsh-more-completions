#compdef foamConfigurePaths
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/tools/foamConfigurePaths — patch etc/bashrc + ThirdParty wmake configs for a relocatable install.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--foamInstall=[installation directory (e.g. /opt)]:dir:_directories' \
    '--projectName=[project name (e.g. openfoam11)]:name:' \
    '--thirdPartyName=[third-party name (e.g. openfoam11/thirdparty)]:name:' \
    '--projectVersion=[project version (e.g. 11)]:ver:' \
    '--archOption=[architecture option (32 or 64)]:arch:(32 64)' \
    '*--dependency=[dependency in name:type:ver form (e.g. SCOTCH=ThirdParty:6.0.9)]:spec:' \
    && ret=0

return ret
