#compdef calibredb

# Zsh completion for calibredb - calibre database management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add books to the database'
  'add_custom_column:add a custom column'
  'add_format:add a format to an existing book'
  'backup_metadata:backup metadata'
  'catalog:generate a catalog'
  'check_library:check the library for problems'
  'clone:clone the current library'
  'custom_columns:list custom columns'
  'embed_metadata:embed metadata into book files'
  'export:export books from the database'
  'is_empty:test whether the library is empty'
  'fts_index:manage full text search index'
  'fts_search:full text search'
  'import:import a previously exported library'
  'list:list books in the database'
  'list_categories:list available categories'
  'merge:merge books'
  'remove:remove books from the database'
  'remove_custom_column:remove a custom column'
  'remove_format:remove a format from a book'
  'restore_database:restore the database from metadata'
  'saved_searches:manage saved searches'
  'search:search the database'
  'set_custom:set the value of a custom column'
  'set_metadata:set the metadata of a book'
  'show_metadata:show the metadata of a book'
)

_arguments -s -S \
  '1:command:->command' \
  '(-l --library-path)'{-l,--library-path}'[path to calibre library]:directory:_files -/' \
  '--with-library=[path to calibre library]:directory:_files -/' \
  '--username=[username for connecting to a calibre server]:username' \
  '--password=[password for connecting to a calibre server]:password' \
  '--timeout=[timeout for connecting to a calibre server]:seconds' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'calibredb command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (add)
        _arguments -s -S \
          '(-d --duplicates)'{-d,--duplicates}'[add duplicate books]' \
          '(-e --empty)'{-e,--empty}'[add empty book with specified title]:title' \
          '(-t --title)'{-t,--title}'[set title]:title' \
          '(-a --authors)'{-a,--authors}'[set authors]:authors' \
          '(-i --isbn)'{-i,--isbn}'[set ISBN]:ISBN' \
          '(-I --identifier)'{-I,--identifier}'[set identifier]:type\:value' \
          '(-T --tags)'{-T,--tags}'[set tags]:tags' \
          '(-s --series)'{-s,--series}'[set series]:series' \
          '(-S --series-index)'{-S,--series-index}'[set series index]:index' \
          '(-c --cover)'{-c,--cover}'[set cover image]:image:_files -g "*.{jpg,jpeg,png,gif}"' \
          '(-l --languages)'{-l,--languages}'[set languages]:languages' \
          '(-r --recurse)'{-r,--recurse}'[recurse into directories]' \
          '--one-book-per-directory[only add one book per directory]' \
          '--automerge=[auto merge duplicates]:mode:(ignore overwrite new_record)' \
          '*:file:_files -g "*.{epub,pdf,mobi,azw3,txt,rtf,html,htm,cbz,cbr,lit,prc,fb2,djvu,doc,docx,odt}"' && ret=0
        ;;
      (remove)
        _arguments '*:book IDs' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '(-f --fields)'{-f,--fields}'[fields to display (comma-separated)]:fields' \
          '--sort-by=[field to sort by]:field' \
          '--ascending[sort in ascending order]' \
          '(-s --search)'{-s,--search}'[search filter]:search query' \
          '(-w --line-width)'{-w,--line-width}'[line width for output]:width' \
          '--separator=[field separator]:separator' \
          '--prefix=[prefix for paths]:prefix' \
          '--limit=[maximum number of results]:limit' \
          '--for-machine[output in JSON format for machine parsing]' && ret=0
        ;;
      (export)
        _arguments -s -S \
          '--all[export all books]' \
          '--to-dir=[export to directory]:directory:_files -/' \
          '--single-dir[export all to single directory]' \
          '--progress[show export progress]' \
          '--formats=[formats to export (comma-separated)]:formats' \
          '--template=[file naming template]:template' \
          '--replace-whitespace[replace whitespace with underscores]' \
          '--to-lowercase[convert file names to lowercase]' \
          '--timefmt=[date format]:format' \
          '*:book IDs' && ret=0
        ;;
      (search)
        _arguments -s -S \
          '(-l --limit)'{-l,--limit}'[maximum number of results]:count' \
          '1:search expression' && ret=0
        ;;
      (show_metadata)
        _arguments -s -S \
          '--as-opf[print metadata in OPF format]' \
          '1:book ID' && ret=0
        ;;
      (set_metadata)
        _arguments -s -S \
          '(-f --field)'{-f,--field}'[set field value]:field\:value' \
          '1:book ID' \
          '2:OPF file:_files -g "*.opf"' && ret=0
        ;;
      (add_format)
        _arguments -s -S \
          '--dont-replace[do not replace existing format]' \
          '1:book ID' \
          '2:book file:_files' && ret=0
        ;;
      (remove_format)
        _arguments '1:book ID' '2:format' && ret=0
        ;;
      (catalog)
        _arguments -s -S \
          '(-i --ids)'{-i,--ids}'[book IDs to include]:IDs' \
          '(-s --search)'{-s,--search}'[search filter]:search' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '1:output file:_files -g "*.{epub,csv,xml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
