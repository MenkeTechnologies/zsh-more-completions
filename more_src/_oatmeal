#compdef oatmeal

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--backend=[AI backend]:backend:(ollama openai)' \
  '--model=[model name]:model:' \
  '--editor=[text editor]:editor:' \
  '--theme=[syntax highlighting theme]:theme:' \
  '--theme-file=[custom theme file]:file:_files' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'chat:start a chat session'
      'sessions:manage chat sessions'
      'completions:generate shell completions'
    )
    _describe -t commands 'oatmeal command' commands && ret=0
    ;;
esac

return ret
