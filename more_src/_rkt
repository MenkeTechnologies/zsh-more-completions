#compdef rkt
# Documentation: https://man.archlinux.org/search?q=rkt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'api-service:run rkt API service'
  'app:operate on apps in pods'
  'cat-manifest:print pod manifest'
  'config:show rkt config'
  'enter:enter running pod'
  'export:export pod to ACI'
  'fetch:fetch image to local store'
  'gc:garbage collect pods'
  'help:show help'
  'image:operate on images'
  'install:set permissions to allow non-root invocation'
  'list:list pods'
  'prepare:prepare pod from images'
  'rm:remove a pod'
  'run:run a pod'
  'run-prepared:run a prepared pod'
  'status:show pod status'
  'stop:stop a pod'
  'trust:add image signing keys'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[debug logging]' \
  '--insecure-options=[insecure options csv]:list:(image tls ondisk all)' \
  '--dir=[rkt data dir]:dir:_files -/' \
  '--user-config=[user config dir]:dir:_files -/' \
  '--system-config=[system config dir]:dir:_files -/' \
  '--local-config=[local config dir]:dir:_files -/' \
  '--trust-keys-from-https[automatically trust gpg keys fetched via https]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rkt command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|prepare)
        _arguments \
          '--cpu=[cpu limit]:cpu:' \
          '--memory=[memory limit]:mem:' \
          '--user=[user inside pod]:user:_users' \
          '--group=[group inside pod]:group:' \
          '--volume=[mount volume]:vol:' \
          '--mount=[bind volume to mount point]:m:' \
          '--port=[publish port]:port:' \
          '--net=[network name]:net:(default host none default-restricted)' \
          '--dns=[DNS server]:server:' \
          '--dns-search=[DNS search domain]:domain:' \
          '--hostname=[pod hostname]:host:' \
          '--exec=[override entrypoint]:cmd:' \
          '--inherit-env[inherit env vars]' \
          '--set-env=[env var]:var:' \
          '--no-overlay[do not use overlay fs]' \
          '--private-users[user namespace remap]' \
          '--pull-policy=[pull policy]:policy:(never new update)' \
          '--signature=[signature file]:file:_files' \
          '--store-only[only use local store]' \
          '--no-store[bypass local store]' \
          '--interactive[interactive container]' \
          '*:image:_files' && ret=0 ;;
      (fetch)
        _arguments \
          '--full[print full image hash]' \
          '--pull-policy=[pull policy]:p:(never new update)' \
          '--store-only[use local store only]' \
          '--no-store[bypass store]' \
          '--signature=[signature file]:file:_files' \
          '*:image:' && ret=0 ;;
      (image) _values 'subcommand' 'cat-manifest' 'export' 'extract' 'gc' 'list' 'render' 'rm' 'verify' && ret=0 ;;
      (config) _values 'subcommand' 'list' 'set' 'unset' && ret=0 ;;
      (rm|stop|status|enter|export|cat-manifest)
        _arguments '*:pod uuid:' && ret=0 ;;
    esac ;;
esac

return ret
