#compdef waydroid-cli waydroid
# Documentation: https://docs.waydro.id/usage/waydroid-command-line-options
# Reference accessed: 2026-05-17
# Verified: Waydroid upstream — container-based Android runtime
# CLI. NOTE: canonical binary is `waydroid`, not `waydroid-cli`.
# Subcommands: status, log, init, upgrade, session(start|stop),
# container(start|stop|restart|freeze|unfreeze),
# app(install|remove|launch|list|intent), prop(get|set),
# show-full-ui, shell, logcat, first-launch.
# Removed from prior file: bogus man.archlinux.org search URL.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'init:initialize container'
  'upgrade:upgrade container OS'
  'session:session management'
  'show-full-ui:show Waydroid UI'
  'app:application management (install/launch/list)'
  'prop:get/set Android properties'
  'shell:shell into the Android container'
  'logcat:tail logcat output'
  'status:show service status'
  'log:show service log'
  'first-launch:first launch wizard'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '-V[verbose]' \
  '--version[show version]' \
  '--verbose[verbose]' \
  '-r[force run]' \
  '--force[force operation]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'waydroid command' commands && ret=0 ;;
esac
return ret
