#compdef waydroid-cli waydroid

# Waydroid CLI: Android container for Linux
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'init:initialize container'
  'upgrade:upgrade container OS'
  'session:session management'
  'show-full-ui:show Waydroid UI'
  'app:application management (install/launch/list)'
  'prop:get/set Android properties'
  'shell:shell into the Android container'
  'logcat:tail logcat output'
  'status:show service status'
  'log:show service log'
  'first-launch:first launch wizard'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '-V[verbose]' \
  '--version[show version]' \
  '--verbose[verbose]' \
  '-r[force run]' \
  '--force[force operation]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'waydroid command' commands && ret=0 ;;
esac
return ret
