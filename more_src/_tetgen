#compdef tetgen
# Documentation: https://wias-berlin.de/software/tetgen/1.5/doc/manual/manual.pdf
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-p[tetrahedralize a PLC]' \
  '-q+[quality mesh generation with radius-edge ratio]:ratio:' \
  '-a+[maximum volume constraint]:volume:' \
  '-r[reconstruct/refine a mesh]' \
  '-A[assign region attributes]' \
  '-Y[preserve surface mesh]' \
  '-V[verbose output]' \
  '-T+[set tolerance]:tolerance:' \
  '-o2[generate second-order elements]' \
  '-i[insert additional points]' \
  '-S+[maximum number of Steiner points]:count:' \
  '-C[check consistency of the mesh]' \
  '-d[detect self-intersections of PLC facets]' \
  '-B[suppress output of boundary information]' \
  '-N[suppress output of node file]' \
  '-E[suppress output of element file]' \
  '-F[suppress output of face file]' \
  '-I[suppress iteration numbers in file names]' \
  '*:input file:_files' && ret=0

return ret
