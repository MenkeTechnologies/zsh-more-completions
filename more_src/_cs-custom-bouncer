#compdef cs-custom-bouncer crowdsec-custom-bouncer
# Documentation: https://docs.crowdsec.net/u/bouncers/custom
# CrowdSec custom bouncer - runs a binary per decision add/delete

local ret=1

_arguments -s \
  '-c[path to crowdsec-custom-bouncer.yaml]:config file:_files' \
  '-v[set verbose mode]' \
  '-version[display version and exit]' \
  '-t[test config and exit]' \
  '-T[show full config (.yaml + .yaml.local) and exit]' && ret=0

return ret
