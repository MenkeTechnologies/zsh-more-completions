#compdef fuzzel

# Zsh completion for fuzzel - Wayland application launcher

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  {-f,--font}'[set font]:font' \
  {-T,--terminal}'[set terminal command]:terminal command' \
  {-l,--lines}'[set number of lines]:lines' \
  {-w,--width}'[set width in characters]:width (chars)' \
  {-x,--horizontal-pad}'[set horizontal padding]:horizontal padding' \
  {-y,--vertical-pad}'[set vertical padding]:vertical padding' \
  {-r,--border-radius}'[set border radius]:border radius' \
  {-b,--border-width}'[set border width]:border width' \
  {-I,--icon-theme}'[set icon theme]:icon theme' \
  {-P,--prompt}'[set prompt string]:prompt' \
  {-p,--placeholder}'[set placeholder text]:placeholder' \
  '--dpi-aware[DPI awareness mode]:mode:(auto yes no)' \
  '--show-actions[show desktop actions]' \
  '--fields[fields to match against]:fields:(filename name generic exec keywords comment categories)' \
  '--password[enable password mode]' \
  '--layer[set layer]:layer:(background bottom top overlay)' \
  '--anchor[set anchor position]:anchor' \
  '--output[set output]:output' \
  '--filter-desktop[filter desktop entries]:filter' \
  '--launch-prefix[command prefix for launching]:prefix' \
  '--log-level[set log level]:level:(info warning error none)' \
  '--log-colorize[colorize log output]:mode:(auto always never)' \
  '--no-fuzzy[disable fuzzy matching]' \
  '--dmenu[run in dmenu mode]' \
  '--index[show selection index]' \
  '--counter[show match counter]' \
  '--match-counter[show match counter]' \
  '--inner-pad[set inner padding]:padding' \
  '--image-size-ratio[set image size ratio]:ratio' \
  '--list-executables-in-path[list executables in PATH]' \
  '--no-exit-on-keyboard-focus-loss[do not exit on keyboard focus loss]' \
  '--tabs[set tab width]:tab width' \
  '*:file:_files'
