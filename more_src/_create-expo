#compdef create-expo
# Documentation: https://www.npmjs.com/package/create-expo
# Reference accessed: 2026-05-23
# Verified: npx create-expo --help.

# Zsh completion for create-expo - create a new Expo project

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-y --yes)'{-y,--yes}'[use default options]' \
  '--no-install[skip installing npm packages or CocoaPods]' \
  '--no-agents-md[skip generating AGENTS.md and CLAUDE.md]' \
  '(-t --template)'{-t,--template=}'[NPM template]:template:(default blank blank-typescript tabs bare-minimum)' \
  '(-e --example)'{-e,--example=}'[Expo example name]:example:' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':project path:_directories' && ret=0

return ret
