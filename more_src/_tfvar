#compdef tfvar
# Documentation: https://github.com/shihanng/tfvar
# tfvar: generate Terraform variable definitions from configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-a --auto-assign)'{-a,--auto-assign}'[use values from TF_VAR_* env vars and variable definitions files]' \
  '(-d --debug)'{-d,--debug}'[print debug log on stderr]' \
  '(-e --env-var)'{-e,--env-var}'[output in environment variable export format]' \
  '--ignore-default[do not use defined default values]' \
  '(-r --resource)'{-r,--resource}'[print output in tfe_variable resource format]' \
  '(-w --workspace)'{-w,--workspace}'[print output variables as Workspace Variables API payloads]' \
  '*--var=[set a variable in the generated definitions]:var:' \
  '*--var-file=[set variables from a file]:file:_files' \
  '*:dir:_files -/' && ret=0

return ret
