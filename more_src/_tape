#compdef tape
# Documentation: https://man.archlinux.org/search?q=tape
# Reference accessed: 2026-05-16

# Zsh completion for tape - TAP-producing test harness for Node.js

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '*'{-r,--require}'=[require module before tests]:module:' \
  '--ignore=[ignore files matching glob pattern]:glob pattern:' \
  '*:test files:_files -g "*.{js,mjs,cjs}"'
