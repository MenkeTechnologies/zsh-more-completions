#compdef mcast
# Documentation: https://meme-suite.org/meme/doc/mcast.html
# MEME Suite: find clusters of motifs (motif cluster alignment and search)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--o=[output directory (default mcast_out), fail if exists]:dir:_files -/' \
  '--oc=[output directory (default mcast_out), overwrite if exists]:dir:_files -/' \
  '--transfac[assume motif file is in TRANSFAC matrix format]' \
  '--max-total-width=[maximum total width of a motif cluster]:max:' \
  '--hardmask[convert lowercase nucleotides to N]' \
  '--motif-pthresh=[p-value threshold for motif hits]:pthresh:' \
  '--max-gap=[maximum allowed gap between motifs]:max gap:' \
  '--output-ethresh=[E-value threshold for output]:out E-value:' \
  '--output-pthresh=[p-value threshold for output]:out p-value:' \
  '--output-qthresh=[q-value threshold for output]:out q-value:' \
  '--max-stored-scores=[maximum number of scores to store]:max:' \
  '--seed=[random seed for generated sequences]:seed:' \
  '--psp=[position-specific priors file]:file:_files' \
  '--prior-dist=[binned distribution of priors file]:file:_files' \
  '--bfile=[background model file]:file:_files' \
  '*:motif/sequence file:_files' && ret=0

return ret
