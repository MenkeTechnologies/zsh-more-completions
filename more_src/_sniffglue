#compdef sniffglue

# Zsh completion for sniffglue - secure multithreaded network sniffer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-d --detailed)'{-d,--detailed}'[show detailed packet info]' \
  '(-r --read)'{-r,--read}'[read pcap file]:file:_files' \
  '(-p --promisc)'{-p,--promisc}'[set interface to promiscuous mode]' \
  '-n[limit number of packets]:count:' \
  '(-h --help -V --version)*:interface:' && return 0
