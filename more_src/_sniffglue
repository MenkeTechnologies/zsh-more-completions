#compdef sniffglue
# Documentation: https://github.com/kpcyrd/sniffglue/blob/main/src/cli.rs
# Reference accessed: 2026-05-21
# Verified: upstream src/cli.rs Args struct (clap).
# Removed from prior file: fabricated -d/--detailed flag (not in upstream).
# Added: -j/--json, --debugging, --insecure-disable-seccomp, --gen-completions,
# -n/--threads (alias --cpus).

# Zsh completion for sniffglue - secure multithreaded network sniffer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-p --promisc)'{-p,--promisc}'[set interface to promiscuous mode]' \
  '(-j --json)'{-j,--json}'[emit JSON output]' \
  '(-r --read)'{-r,--read}'[read from pcap file]' \
  '(-n --threads)'{-n+,--threads=}'[number of worker threads]:n:' \
  '--debugging[enable debug output]' \
  '--insecure-disable-seccomp[disable seccomp sandbox]' \
  '*:interface or pcap path:' && return 0
