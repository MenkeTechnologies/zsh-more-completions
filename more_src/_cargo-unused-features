#compdef unused-features

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:analyze unused features'
  'build-report:build an HTML report'
  'prune:remove unused features from Cargo.toml'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'unused-features command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      analyze)
        _arguments -s -S \
          '-p+[path to workspace]:path:_directories' \
          '--path=[path to workspace]:path:_directories' \
          '-l+[log level]:level:(trace debug info warn error)' \
          '--log=[log level]:level:(trace debug info warn error)' \
          '-o+[output file]:file:_files -g "*.json"' \
          '--output=[output file]:file:_files -g "*.json"' && ret=0
        ;;
      build-report)
        _arguments -s -S \
          '-i+[input file]:file:_files -g "*.json"' \
          '--input=[input file]:file:_files -g "*.json"' && ret=0
        ;;
      prune)
        _arguments -s -S \
          '-i+[input file]:file:_files -g "*.json"' \
          '--input=[input file]:file:_files -g "*.json"' && ret=0
        ;;
    esac
    ;;
esac

return ret
