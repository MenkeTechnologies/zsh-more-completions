#compdef csvtool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '-t[use tab as separator]' \
  '-c[use comma as separator]' \
  '-u[set separator character]:character:' \
  '-o[set output separator character]:character:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'col:select columns'
      'namedcol:select columns by name'
      'head:print first N rows'
      'drop:drop first N rows'
      'cat:concatenate CSV files'
      'paste:paste CSV files side by side'
      'join:join CSV files'
      'square:make all rows the same length'
      'trim:trim whitespace'
      'sub:extract a sub-table'
      'replace:replace cell contents'
      'call:call a command for each row'
      'readable:pretty-print CSV'
      'width:print number of columns'
      'height:print number of rows'
      'setcolumns:set number of columns'
      'setrows:set number of rows'
      'transpose:transpose the CSV'
      'format:format CSV using a format string'
      'md:output as Markdown table'
      'latex:output as LaTeX table'
      'html:output as HTML table'
      'check:check CSV for errors'
    )
    _describe -t commands 'csvtool command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
