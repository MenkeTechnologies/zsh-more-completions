#compdef csvtool
# Documentation: https://github.com/Chris00/ocaml-csv/tree/master/csvtool
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# csvtool from Chris00/ocaml-csv. Command list verified against csvtool.ml.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '-t[use tab as input separator]' \
  '-c[use comma as input separator (default)]' \
  '-u+[set input separator character]:character' \
  '-o+[set output separator character]:character' \
  '-O+[output file (default stdout)]:output file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'col:select columns by index/range'
      'cols:select columns by index/range'
      'namedcol:select columns by name'
      'namedcols:select columns by name'
      'width:print number of columns'
      'columns:print number of columns'
      'height:print number of rows'
      'rows:print number of rows'
      'readable:pretty-print CSV in fixed-width columns'
      'cat:concatenate CSV files'
      'concat:concatenate CSV files'
      'paste:paste CSV files side by side'
      'pastecol:paste selected columns from two files'
      'join:join two files on selected columns'
      'collate:join two files on selected columns'
      'square:pad rows so all have the same length'
      'sub:extract a sub-table by rows/cols'
      'replace:replace columns in input from another source'
      'setcolumns:set number of columns'
      'set_columns:set number of columns'
      'set-columns:set number of columns'
      'setrows:set number of rows'
      'set_rows:set number of rows'
      'set-rows:set number of rows'
      'head:take the first N rows'
      'take:take the first N rows'
      'drop:drop the first N rows'
      'transpose:transpose the CSV'
      'format:format CSV using a format string'
      'call:call an external command for each row'
      'trim:trim leading/trailing whitespace'
    )
    _describe -t commands 'csvtool command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
