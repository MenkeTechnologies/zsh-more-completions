#compdef eopa
# Documentation: https://docs.styra.com/enterprise-opa/reference/cli-reference
# eopa - Styra Enterprise OPA, a drop-in OPA replacement with additional features

local ret=1
local -a commands

commands=(
  'run:start the Enterprise OPA server or REPL'
  'eval:evaluate a Rego query'
  'test:execute Rego test cases'
  'bench:benchmark a Rego query'
  'build:build a bundle from policy and data files'
  'parse:parse a Rego policy file'
  'check:check Rego source files'
  'fmt:format Rego source files'
  'sign:generate a signed bundle signature'
  'deps:analyze Rego query dependencies'
  'inspect:inspect a bundle archive'
  'exec:execute against one or more input files'
  'login:authenticate against a Styra DAS tenant'
  'license:manage the Enterprise OPA license'
  'version:print the version'
  'capabilities:print the capabilities of this version'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--license-key=[location of file containing the license key]:file:_files' \
  '--license-token=[location of file containing the license token]:file:_files' \
  '--bundle[treat path arguments as policy bundles]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'eopa command' commands && ret=0
    ;;
esac

return ret
