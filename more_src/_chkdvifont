#compdef chkdvifont
# Documentation: man chkdvifont (TeX Live 2026 dviout-util)
# Source: inspect a DVI/TFM/VF/GF/PK file and report font information.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[short summary]' \
    '-c[checksum mode]' \
    '-f+[font data file (lowercase)]:file:_files' \
    '-F+[font data file (uppercase)]:file:_files' \
    '(-d -t -p)-d[force DVI mode]' \
    '(-d -t -p)-t[force TFM/OFM mode]' \
    '(-d -t -p)-p[force other FONT (VF/GF/PK) mode]' \
    '1:dvi/tfm/font file:_files -g "*.(dvi|tfm|ofm|vf|gf|pk|*pk)"' \
    && ret=0

return ret
