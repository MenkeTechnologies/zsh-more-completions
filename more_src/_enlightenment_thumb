#compdef enlightenment_thumb
# Documentation: https://man.archlinux.org/search?q=enlightenment_thumb
# Reference accessed: 2026-05-16

# enlightenment_thumb: E thumbnail generation helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::enlightenment_thumb args:_files' && ret=0
return ret
