#compdef LeftAlignIndels
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/LeftAlignIndels.java
# GATK4: left-align indels in read alignments within a BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[output BAM]:file:_files' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '*:options:_files' && ret=0

return ret
