#compdef terser

# Zsh completion for terser - JavaScript compressor/minifier

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-p,--parse}'=[parse options]:options' \
  {-c,--compress}'=[compress options]:options' \
  {-m,--mangle}'=[mangle options]:options' \
  '--mangle-props=[mangle properties options]:options' \
  {-o,--output}'=[output file]:file:_files' \
  '--comments=[filter for comments]:filter:(all some)' \
  '--ecma=[ECMAScript version]:version:(5 2015 2016 2017 2018 2019 2020)' \
  {-b,--beautify}'=[beautify options]:options' \
  '--source-map=[source map options]:options' \
  '--module[input is an ES module]' \
  '--ie8[support IE8]' \
  '--keep-classnames[do not mangle/drop class names]' \
  '--keep-fnames[do not mangle/drop function names]' \
  '--name-cache=[name cache file]:file:_files' \
  '--safari10[work around Safari 10/11 bugs]' \
  '--toplevel[compress and/or mangle top level scope]' \
  '--wrap=[wrap output in function with specified export name]:name' \
  '--enclose=[embed output in a big function with configurable args]:args' \
  '--config-file=[config file]:file:_files' \
  '--timings[display operations run time]' \
  {-d,--define}'=[define global variable]:expression' \
  {-e,--enclose}'[embed output in a big function]' \
  '--no-rename[disable name optimizations]' \
  '*:files:_files -g "*.{js,mjs,cjs}"'
