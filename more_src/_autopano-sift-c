#compdef autopano-sift-c
# Documentation: https://man.archlinux.org/search?q=autopano-sift-c
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '--maxmatches+[max matches per pair]:n:' \
  '--ransac+[RANSAC mode]:mode:(on off)' \
  '--projection+[projection method]:proj:' \
  '*:pto_file_images:_files' && ret=0

return ret
