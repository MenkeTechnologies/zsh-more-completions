#compdef autopano-sift-c
# Documentation: https://hugin.sourceforge.io/docs/manual/Autopano-sift-C.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '--maxmatches+[max matches per pair]:n:' \
  '--ransac+[RANSAC mode]:mode:(on off)' \
  '--projection+[projection method]:proj:' \
  '*:pto_file_images:_files' && ret=0

return ret
