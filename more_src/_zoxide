#compdef zoxide
# _zoxide — Ajeetdsouza zoxide (modern Rust autojumper; smarter `cd` that learns your most-used directories and is driven by the `z`/`zi` shell shims)
# upstream: https://github.com/ajeetdsouza/zoxide
# Subcommands + flags from src/cmd/cmd.rs on tip (clap-derive); honors _ZO_DATA_DIR / _ZO_ECHO / _ZO_EXCLUDE_DIRS / _ZO_FZF_OPTS / _ZO_MAXAGE / _ZO_RESOLVE_SYMLINKS env vars.

_zoxide() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'add:add directory or bump its rank'
                'edit:edit the database (subcommands hidden, intended for shell hook use)'
                'import:import entries from another autojumper (atuin|autojump|fasd|z|z.lua|zsh-z)'
                'init:print shell init code'
                'query:search the database (drives `z` and `zi`)'
                'remove:remove a directory from the database'
            )
            _describe -t commands 'zoxide command' subs
            ;;
        args)
            case $line[1] in
                add)
                    _arguments \
                        '(-s --score)'{-s+,--score=}'[rank to set/increment]:score:' \
                        '*:dir:_files -/'
                    ;;
                init)
                    _arguments \
                        '--no-cmd[do not define z/zi commands]' \
                        '--cmd=[prefix for z/zi commands]:prefix:' \
                        '--hook=[when to increment rank]:hook:(none prompt pwd)' \
                        '1:shell:(bash elvish fish nushell posix powershell tcsh xonsh zsh)'
                    ;;
                import)
                    _arguments \
                        '--merge[merge into existing database]' \
                        '1:source:(atuin autojump fasd z z.lua zsh-z)'
                    ;;
                query)
                    _arguments \
                        '(-a --all)'{-a,--all}'[show unavailable directories]' \
                        '(-i --interactive -l --list)'{-i,--interactive}'[use interactive picker]' \
                        '(-l --list -i --interactive)'{-l,--list}'[list all matches]' \
                        '(-s --score)'{-s,--score}'[print scores with results]' \
                        '--exclude=[exclude this directory]:dir:_files -/' \
                        '--base-dir=[only search within this directory]:dir:_files -/' \
                        '*:keyword:'
                    ;;
                remove)
                    _arguments '*:dir:_files -/'
                    ;;
            esac
            ;;
    esac
}

_zoxide "$@"
