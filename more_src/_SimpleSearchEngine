#compdef SimpleSearchEngine
# Documentation: https://www.openms.org/documentation/html/TOPP_SimpleSearchEngine.html
# OpenMS: simple database search engine for peptide MS/MS identification

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input MS/MS data file (mzML, d)]:file:_files' \
  '-database[protein sequence database (fasta)]:file:_files' \
  '-out[output identification results (idXML)]:file:_files' \
  '-Search:enzyme[protease for digestion]:enzyme:' \
  '-Search:decoys[generate decoy sequences for FDR]' \
  '-Search:precursor:mass_tolerance[precursor mass tolerance]:double:' \
  '-Search:precursor:mass_tolerance_unit[unit]:unit:(ppm Da)' \
  '-Search:precursor:min_charge[minimum charge state]:int:' \
  '-Search:precursor:max_charge[maximum charge state]:int:' \
  '-Search:precursor:isotopes[isotope correction]:isotopes:' \
  '-Search:fragment:mass_tolerance[fragment mass tolerance]:double:' \
  '-Search:fragment:mass_tolerance_unit[unit]:unit:(ppm Da)' \
  '-Search:modifications:fixed[fixed modifications]:mods:' \
  '-Search:modifications:variable[variable modifications]:mods:' \
  '-Search:modifications:variable_max_per_peptide[max mods per peptide]:int:' \
  '-Search:peptide:min_size[minimum peptide length]:int:' \
  '-Search:peptide:max_size[maximum peptide length]:int:' \
  '-Search:peptide:missed_cleavages[allowed missed cleavages]:int:' \
  '-Search:peptide:enzyme_specificity[cleavage requirement]:spec:(full semi none)' \
  '-Search:peptide:motif[regex-based peptide sequence filter]:motif:' \
  '-Search:report:top_hits[reported matches per spectrum]:int:' \
  '-Search:FDR:PSM[q-value threshold for filtering]:double:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
