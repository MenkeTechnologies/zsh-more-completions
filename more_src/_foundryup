#compdef foundryup
# Documentation: https://github.com/foundry-rs/foundry (foundryup/foundryup bash script)
# Reference accessed: 2026-05-29
# Foundry (Ethereum dev toolchain) installer/version manager.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show foundryup installer version]' \
  '(-U --update)'{-U,--update}'[update foundryup to the latest version]' \
  '(-i --install)'{-i,--install=}'[install a specific version (latest, nightly, nightly-<SHA>, or v1.2.3)]:version:(latest nightly stable)' \
  '(-l --list)'{-l,--list}'[list installed versions from built binaries]' \
  '(-u --use)'{-u,--use=}'[activate a specific installed version]:version:' \
  '(-b --branch)'{-b,--branch=}'[build and install from a specific Git branch]:branch:' \
  '(-P --pr)'{-P,--pr=}'[build and install from a Pull Request number]:pr#:' \
  '(-C --commit)'{-C,--commit=}'[build and install a specific commit hash]:sha:' \
  '(-r --repo)'{-r,--repo=}'[build from a remote GitHub repository]:owner/repo:' \
  '(-p --path)'{-p,--path=}'[build and install from a local repository]:path:_directories' \
  '(-j --jobs)'{-j,--jobs=}'[CPU count for building (default: all)]:n:' \
  '(-f --force)'{-f,--force}'[skip SHA verification for downloaded binaries]' \
  '--arch=[install specific architecture]:arch:(amd64 arm64)' \
  '--platform=[install specific OS]:platform:(win32 linux darwin alpine)' && ret=0

return ret
