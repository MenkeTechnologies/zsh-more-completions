#compdef newt
# _newt — Apache Mynewt newt CLI build orchestrator for Mynewt RTOS embedded firmware applications resolving package dependencies cross-compiling targets bootloader application images integrating gdb openocd Segger J-Link transports (Apache Mynewt team, Go); cobra
# upstream: https://github.com/apache/mynewt-newt

_newt() {
    local -a sub=(
        'build:build one or more targets'
        'clean:delete build artifacts for one or more targets'
        'create-image:add image header to bootable binary'
        'debug:open debugger session'
        'help:show help'
        'info:show project information'
        'install:install project dependencies'
        'load:load built target onto board'
        'mfg:manufacturing flash image commands'
        'new:create a new project'
        'pkg:create and manage packages in the current workspace'
        'resign-image:re-sign image'
        'run:build/create-image/download/debug a target'
        'size:size of target components'
        'sync:synchronize project dependencies'
        'target:set and view target information'
        'test:execute unit tests for a package'
        'upgrade:upgrade project dependencies'
        'vals:display valid values for project properties'
        'version:display the newt version number'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-l+[level]:l:(DEBUG INFO WARN ERROR)' \
        '--loglevel=+[level]:l:(DEBUG INFO WARN ERROR)' \
        '-o+[log file]:file:_files' \
        '--outfile=+[file]:file:_files' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-j+[jobs]:n:' \
        '--jobs=+[jobs]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'newt subcommand' sub ;;
        args)
            case $words[1] in
                build|clean|debug|load|run|size|test) _arguments '*:target:' ;;
                target) _arguments \
                    '1:op:(amend cmake config copy create delete dep revdep set show)' ;;
                pkg) _arguments \
                    '1:op:(copy move new remove)' ;;
                new) _arguments '*:project name:' ;;
            esac
            ;;
    esac
}

_newt "$@"
