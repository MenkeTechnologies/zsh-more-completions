#compdef creduce
# Documentation: https://manpages.debian.org/bookworm/creduce/creduce.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm creduce(1) manpage OPTIONS list.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--n=[number of cores to use]:cores' \
  '--tidy[ensure the test case is tidy]' \
  '--not-c[do not assume input is C/C++]' \
  '--timeout=[timeout per test in seconds]:seconds' \
  '--no-default-passes[do not run default passes]' \
  '*--add-pass=[add a custom pass]:pass' \
  '--skip-initial-passes[skip initial passes]' \
  '--no-kill[do not kill test processes on timeout]' \
  '--sllooww[try harder, at the expense of speed]' \
  '--print-diff[print diff of each reduction step]' \
  '--save-temps[save temporary files]' \
  '--abs-timing[show absolute time]' \
  '--also-interesting=[additional interesting exit code]:code:' \
  '--debug[enable debug output]' \
  '--die-on-pass-bug[abort on pass bug]' \
  '--max-improvement=[max improvement bytes]:bytes:' \
  '--no-cache[disable result cache]' \
  '--no-give-up[do not give up early]' \
  '--shaddap[suppress non-error output]' \
  '--skip-key-off[skip key-off prompt]' \
  '--timing[show timing info]' \
  '1:interestingness test script:_files' \
  '2:file to reduce:_files' && ret=0

return ret
