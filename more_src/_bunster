#compdef bunster
# Documentation: https://man.archlinux.org/search?q=bunster
# Reference accessed: 2026-05-16

# Zsh completion for bunster — compile shell to static Go binary (urfave/cli v3)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(ast build generate get)
    _describe -t commands 'bunster command' commands && ret=0
    ;;
  args)
    case $words[1] in
      ast)
        _arguments \
          '(-n --no-ansi)'{-n,--no-ansi}'[disable ANSI in AST dump]' \
          '*:shell script:_files -g "*.sh"' && ret=0
        ;;
      build)
        _arguments \
          '(-o)-o+[output binary path]:file:_files' \
          '*:entry script:_files -g "*.sh"' && ret=0
        ;;
      generate)
        _arguments \
          '(-o)-o+[Go output directory]:dir:_directories' \
          '*:entry script:_files -g "*.sh"' && ret=0
        ;;
      get)
        _arguments '--missing[only fetch missing modules]' \
          '*:module spec:_message "module@version"' && ret=0
        ;;
    esac
    ;;
esac

return ret
