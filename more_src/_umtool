#compdef umtool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'sysdiagnose:dump sysdiagnose information'
)

_arguments -C \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'umtool subcommand' subcommands && ret=0
    ;;
esac

return ret
