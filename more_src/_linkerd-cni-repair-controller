#compdef linkerd-cni-repair-controller cni-repair-controller
# _linkerd-cni-repair-controller — Linkerd CNI repair controller (per-node controller that evicts Linkerd-injected pods whose linkerd-network-validator init container failed so they restart and reacquire their netns)
# upstream: https://github.com/linkerd/linkerd2-proxy-init
# Flags from cni-repair-controller/src/main.rs Args on tip (clap); LINKERD_CNI_REPAIR_CONTROLLER_* env vars bind to each flag and kubert::{ClientArgs, AdminArgs} contribute the standard --kubeconfig + --admin-addr flags.

_linkerd-cni-repair-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--log-level=[tracing log filter (LINKERD_CNI_REPAIR_CONTROLLER_LOG_LEVEL)]:filter:' \
        '--log-format=[log format (LINKERD_CNI_REPAIR_CONTROLLER_LOG_FORMAT)]:fmt:(plain json)' \
        '--node-name=[node this controller watches (LINKERD_CNI_REPAIR_CONTROLLER_NODE_NAME)]:name:' \
        '--controller-pod-name=[controller pod name used for leader-election etc. (LINKERD_CNI_REPAIR_CONTROLLER_POD_NAME)]:name:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:ctx:' \
        '--cluster-domain=[Kubernetes cluster DNS domain]:domain:' \
        '--admin-addr=[admin server bind address]:addr:'
}

_linkerd-cni-repair-controller "$@"
