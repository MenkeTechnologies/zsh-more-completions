#compdef solr-zkcli
# Documentation: https://man.archlinux.org/search?q=solr-zkcli
# Reference accessed: 2026-05-16

# solr-zkcli: Solr ZooKeeper CLI (upconfig, downconfig, etc.)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upconfig:upload a configset'
  'downconfig:download a configset'
  'linkconfig:link a collection to a configset'
  'bootstrap:bootstrap from solr.xml'
  'list:list ZooKeeper tree'
  'ls:list ZooKeeper tree (short)'
  'clear:clear a znode'
  'cp:copy a znode'
  'mv:move a znode'
  'rm:remove a znode'
  'cmd:run any cmd'
  'makepath:create a znode path'
  'put:put data to znode'
  'putfile:put file contents to znode'
  'get:get data from znode'
  'getfile:save znode data to file'
  'updateacls:update ACLs'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-z[ZK host]:host:' \
  '--zkhost=[ZK host]:host:' \
  '-c[Solr collection]:name:' \
  '--collection=[Solr collection]:name:' \
  '-n[config name]:name:' \
  '--confname=[config name]:name:' \
  '-d[config dir]:dir:_files -/' \
  '--confdir=[config dir]:dir:_files -/' \
  '-r[recursive]' \
  '--recursive[recursive]' \
  '--zkpath=[path on zk]:path:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'solr-zkcli command' commands && ret=0 ;;
esac
return ret
