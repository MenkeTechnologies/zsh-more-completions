#compdef antsApplyTransformsToTRX
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsApplyTransformsToTRX.cxx — apply ANTs transforms to a TRX tractogram (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-p --precision)'{-p+,--precision=}'[float precision (0/1)]:n:(0 1)' \
    '(-i --input)'{-i+,--input=}'[input tractogram.trx]:file:_files -g "*.trx"' \
    '(-o --output)'{-o+,--output=}'[output tractogram.warped.trx]:file:_files -g "*.trx"' \
    '*'{-t+,--transform=}'[transform (or [file,useInverse])]:transform:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
