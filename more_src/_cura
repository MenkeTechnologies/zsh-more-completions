#compdef cura CuraEngine
# Documentation: https://github.com/Ultimaker/CuraEngine/blob/main/README.md
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

local -a _cura_subcommands
_cura_subcommands=(
  'slice:slice a 3D model and generate G-code'
  'help:show usage information'
)

_arguments -C \
  '(- *)--help[show help message]' \
  '-v[enable verbose output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cura subcommand' _cura_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      slice)
        _arguments -s -S \
          '-v[enable verbose output]' \
          '-p[show progress information]' \
          '*-j+[load JSON settings file]:settings file:_files -g "*.json"' \
          '*-s+[set a setting (key=value)]:key=value:' \
          '*-l+[load STL model file]:model file:_files -g "*.(stl|STL|obj|OBJ|3mf|3MF)"' \
          '-o+[output G-code file]:output file:_files -g "*.gcode"' \
          '*-e+[select extruder number]:extruder:' \
          '--force-read[force re-reading of input files]' \
          '--threads[number of threads]:threads:' && ret=0
        ;;
      help)
        _message 'no more arguments' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
