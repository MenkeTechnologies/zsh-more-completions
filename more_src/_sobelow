#compdef sobelow
# Documentation: https://sobelow.hexdocs.pm/Mix.Tasks.Sobelow.html
# Security-focused static analysis for the Phoenix framework

local ret=1

_arguments -s \
  '(-r --root)'{-r,--root}'+[specify application root directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[print vulnerable code snippets]' \
  '(-i --ignore)'{-i,--ignore}'+[ignore modules]:modules' \
  '--ignore-files=[ignore files]:files:_files' \
  '(-d --details)'{-d,--details}'+[get module details]:module' \
  '--all-details[get all module details]' \
  '--private[skip update checks]' \
  '--strict[exit when bad syntax is encountered]' \
  '--mark-skip-all[mark all printed findings as skippable]' \
  '--clear-skip[clear configuration added by --mark-skip-all]' \
  '--skip[skip functions flagged with #sobelow_skip]' \
  '--router=[specify router location]:file:_files' \
  '--exit[return non-zero exit status]' \
  '--threshold=[only return findings at or above confidence level]:level:(low medium high)' \
  '--format=[specify findings output format]:format:(txt json compact quiet sarif)' \
  '--quiet[return no output if there are no findings]' \
  '--compact[minimal single-line findings]' \
  '--save-config[generate a configuration file from command line options]' \
  '--config[run with the configuration file]' \
  '--no-config[run without the configuration file]' \
  '--version[output current version of Sobelow]' && ret=0

return ret
