#compdef ftselect
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/ftselect.html
# Copy selected rows of a FITS table that satisfy a boolean expression

local ret=1

_arguments -s -S \
  'infile=[input FITS table with optional extension]:infile:_files' \
  'outfile=[output filtered table file]:outfile:_files' \
  'expression=[boolean row-selection expression, @file allowed]:expression:' \
  'copyall=[copy all HDUs or just filtered table]:copyall:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
