#compdef vitest

_vitest_cmds() {
    local -a commands=(
        'run:run tests without watch mode'
        'bench:run benchmarks'
        'related:run tests related to changed files'
        'watch:watch mode (default)'
        'dev:alias for watch'
        'typecheck:run type checking'
        'list:list all test files'
        'init:initialize Vitest config'
    )
    _describe -t commands 'vitest command' commands
}

_vitest() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-r --root)'{-r,--root}'=[root directory]:dir:_directories' \
        '(-c --config)'{-c,--config}'=[config file]:file:_files' \
        '(-u --update)'{-u,--update}'[update snapshots]' \
        '(-w --watch)'{-w,--watch}'[enable watch mode]' \
        '(-t --testNamePattern)'{-t,--testNamePattern}'=[filter test names by pattern]:pattern' \
        '--dir=[base directory to scan for tests]:dir:_directories' \
        '--reporter=[reporter to use]:reporter:(default verbose dot json tap tap-flat junit html)' \
        '--outputFile=[output file for reporters]:file:_files' \
        '--coverage[enable coverage]' \
        '--coverage.provider=[coverage provider]:provider:(v8 istanbul)' \
        '--coverage.reporter=[coverage reporter]:reporter:(text text-summary lcov html json clover)' \
        '--coverage.include=[coverage include patterns]:pattern' \
        '--coverage.exclude=[coverage exclude patterns]:pattern' \
        '--coverage.all[include all files in coverage]' \
        '--run[run without watch mode]' \
        '--mode=[Vite mode]:mode' \
        '--globals[inject globals]' \
        '--dom[enable DOM environment]' \
        '--browser[run in browser]' \
        '--environment=[test environment]:env:(node jsdom happy-dom edge-runtime)' \
        '--passWithNoTests[pass when no tests found]' \
        '--allowOnly[allow only tests to run]' \
        '--dangerouslyIgnoreUnhandledErrors[ignore unhandled errors]' \
        '--shard=[test shard]:shard' \
        '--changed=[run tests on changed files]:since' \
        '--sequence.shuffle[shuffle test order]' \
        '--sequence.concurrent[run tests concurrently]' \
        '--sequence.seed=[random seed]:seed' \
        '--inspect[enable Node.js inspector]' \
        '--inspect-brk[enable inspector and break before tests]' \
        '--pool=[pool for running tests]:pool:(threads forks vmThreads vmForks)' \
        '--poolOptions.threads.maxThreads=[max threads]:number' \
        '--poolOptions.threads.minThreads=[min threads]:number' \
        '--poolOptions.forks.maxForks=[max forks]:number' \
        '--poolOptions.forks.minForks=[min forks]:number' \
        '--fileParallelism[enable file parallelism]' \
        '--no-fileParallelism[disable file parallelism]' \
        '--maxConcurrency=[max concurrent tests]:number' \
        '--maxWorkers=[max worker threads]:number' \
        '--minWorkers=[min worker threads]:number' \
        '--bail=[bail after N failures]:count' \
        '--retry=[retry count for failed tests]:count' \
        '--isolate[isolate test environments]' \
        '--no-isolate[disable test isolation]' \
        '--logHeapUsage[log heap usage]' \
        '--silent[suppress console output]' \
        '--hideSkippedTests[hide skipped tests from output]' \
        '--clearScreen[clear terminal screen]' \
        '--no-color[disable color output]' \
        '--segfaultRetry=[retries on segfault]:count' \
        '--typecheck[enable type checking]' \
        '--typecheck.only[run only type checking]' \
        '--project=[filter by project name]:project' \
        '--slowTestThreshold=[slow test threshold in ms]:ms' \
        '--teardownTimeout=[teardown timeout in ms]:ms' \
        '1:command:_vitest_cmds' \
        '*:test-files:_files'
}

_vitest "$@"
