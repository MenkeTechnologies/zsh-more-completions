#compdef semodule_expand
# _semodule_expand — SELinux semodule_expand (combine a linked policy module + a base module into a complete binary policy file; -o output, -V version, -v verbose, -c version compatibility, -h help; positional arguments are the base module .pp and the linked module .pp)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libsemanage tools/semodule_expand.c on tip.

_semodule_expand() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-o+[output file]:file:_files' \
        '-v[verbose]' \
        '-c+[policy version]:version:' \
        '1:base module:_files -g "*.pp"' \
        '2:linked module:_files -g "*.pp"'
}

_semodule_expand "$@"
