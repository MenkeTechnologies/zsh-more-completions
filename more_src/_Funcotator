#compdef Funcotator
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037224432-Funcotator
# Functional annotator that adds genomic-context annotations to variants

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-O --output)'{-O,--output}'=[output file for annotated variants]:output:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-V --variant)'{-V,--variant}'=[input VCF of variants]:vcf:_files' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--ref-version=[reference version (hg19, hg38)]:version:(hg19 hg38)' \
  '*--data-sources-path=[path to a data source folder]:dir:_files -/' \
  '--output-file-format=[output file format]:format:(VCF MAF SEG)' \
  '--remove-filtered-variants[do not annotate filtered variants]' \
  '--reannotate-vcf[reannotate an already-annotated VCF]' \
  '--transcript-selection-mode=[transcript selection mode]:mode:(BEST_EFFECT CANONICAL ALL)' \
  '--prefer-mane-transcripts[prefer MANE transcripts]' \
  '--transcript-list=[file of transcript IDs to use]:file:_files' \
  '*--annotation-default=[default annotation key:value]:kv:' \
  '*--annotation-override=[override annotation key:value]:kv:' \
  '*--exclude-field=[annotation field to exclude]:field:' \
  '--five-prime-flank-size=[5-prime flank size in bases]:bases:' \
  '--three-prime-flank-size=[3-prime flank size in bases]:bases:' \
  '--lookahead-cache-bp=[lookahead cache size in bp]:bp:' \
  '--force-b37-to-hg19-reference-contig-conversion[force b37 to hg19 contig conversion]' \
  '--min-num-bases-for-segment-funcotation=[min bases for segment funcotation]:bases:' \
  '--custom-variant-classification-order=[custom variant classification order]:order:' \
  '--splice-site-window-size=[splice site window size]:size:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf:_files' && ret=0

return ret
