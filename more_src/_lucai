_lucai() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'review:perform an AI-enhanced code review'
        'configure:configure AI provider and API key'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'lucai subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                review)
                    _arguments \
                        '--path=[directory to scan]:dir:_files -/' \
                        '--file=[single file to scan]:file:_files' \
                        '--diff[review files changed in last commit]' \
                        '--model=[AI model to use]:model:(gpt-4o gpt-4o-mini gpt-4-turbo gpt-4 gpt-3.5-turbo o1-preview o1-mini o3-mini gemini-1.5-pro-latest gemini-1.5-pro gemini-1.5-flash gemini-2.0-flash-exp gemini-2.0-pro-exp)' \
                        '--output=[output format]:format:(markdown json inline)' \
                        '--output-file=[save report to a file]:file:_files' \
                        '--prompt=[custom system prompt file]:file:_files' \
                        '--summary[append executive summary]' \
                        '--blame[attribute code authorship via git blame]' \
                        '--track[save quality scores to local SQLite history]' \
                        '--profile=[profile from .lucai.json]:profile:' && ret=0
                    ;;
                configure|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_lucai "$@"
