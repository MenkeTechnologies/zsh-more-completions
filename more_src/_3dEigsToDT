#compdef 3dEigsToDT
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dEigsToDT.html
# AFNI: build a diffusion tensor from eigenvalues and eigenvectors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-eig_vals[eigenvalue dataset]:name1:_files' \
  '-eig_vecs[eigenvector dataset]:name2:_files' \
  '-mask[mask dataset]:mask:_files' \
  '-flip_x[flip x component of eigenvectors]' \
  '-flip_y[flip y component of eigenvectors]' \
  '-flip_z[flip z component of eigenvectors]' \
  '-scale_eigs[scale eigenvalues by X]:x:' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '*:dataset:_files' && ret=0

return ret
