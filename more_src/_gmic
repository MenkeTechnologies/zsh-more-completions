#compdef gmic
# Documentation: https://man.archlinux.org/search?q=gmic
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-h[short help]' \
  '(- *)-version[show version]' \
  '-v[verbosity]:level:' \
  '-debug[debug mode]' \
  '-cli-test[CLI test]' \
  '-display[display image]' \
  '-output+[output to file]:file:_files' \
  '-input+[input file]:file:_files' \
  '-resize[resize]' \
  '-rotate[rotate]' \
  '-crop[crop]' \
  '-blur[blur]' \
  '-sharpen[sharpen]' \
  '-denoise[denoise]' \
  '-deinterlace[deinterlace]' \
  '-rgb2gray[convert to grayscale]' \
  '-edit_image[edit image]' \
  '-mirror[mirror axis]' \
  '-noise[add noise]' \
  '-normalize[normalize]' \
  '-grayscale[grayscale]' \
  '-fx_blur[FX blur]' \
  '-fx_edges[FX edges]' \
  '-help+[command help]:cmd:' \
  '*:file_or_command:_files' && ret=0

return ret
