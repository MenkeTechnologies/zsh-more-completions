#compdef frpc

# Zsh completion for frp client (Fast Reverse Proxy)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[config file path]:config:_files -g "*.{toml,ini,yaml,yml,json}"' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'http:run single HTTP proxy'
      'https:run single HTTPS proxy'
      'tcp:run single TCP proxy'
      'udp:run single UDP proxy'
      'tcpmux:run single TCPMUX proxy'
      'stcp:run single secret TCP proxy'
      'sudp:run single secret UDP proxy'
      'xtcp:run single P2P TCP proxy'
      'status:show proxy status'
      'reload:hot reload config'
      'stop:stop the client'
      'verify:verify config file'
      'nathole:nat hole related commands'
      'completion:generate shell completions'
    )
    _describe -t commands 'frpc command' commands && ret=0
    ;;
  args)
    case $line[1] in
      http)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files' \
          '--server-addr=[frps address]:address' \
          '--server-port=[frps port]:port' \
          '-u+[user name]:user' \
          '--user=[user name]:user' \
          '-n+[proxy name]:name' \
          '--proxy-name=[proxy name]:name' \
          '-l+[local port]:port' \
          '--local-port=[local port]:port' \
          '--local-ip=[local IP]:ip' \
          '--custom-domain=[custom domain]:domain' \
          '--sd=[subdomain]:subdomain' \
          '--subdomain=[subdomain]:subdomain' \
          '--locations=[URL locations]:locations' \
          '--http-user=[HTTP auth user]:user' \
          '--http-pwd=[HTTP auth password]:password' \
          '--host-header-rewrite=[host header rewrite]:host' \
          '--uc[use compression]' \
          '--ue[use encryption]' && ret=0
        ;;
      tcp|udp)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files' \
          '--server-addr=[frps address]:address' \
          '--server-port=[frps port]:port' \
          '-u+[user name]:user' \
          '--user=[user name]:user' \
          '-n+[proxy name]:name' \
          '--proxy-name=[proxy name]:name' \
          '-l+[local port]:port' \
          '--local-port=[local port]:port' \
          '--local-ip=[local IP]:ip' \
          '-r+[remote port]:port' \
          '--remote-port=[remote port]:port' \
          '--uc[use compression]' \
          '--ue[use encryption]' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files' && ret=0
        ;;
      reload|stop|verify)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
