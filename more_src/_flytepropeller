#compdef flytepropeller
# Documentation: https://github.com/flyteorg/flytepropeller
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Flyte propeller: workflow engine (Flyte control plane component)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:file:_files' \
  '--logger.level=[log level]:level:(debug info warn error)' \
  '*::flytepropeller args:_files' && ret=0
return ret
