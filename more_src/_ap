#compdef ap
# Documentation: man ap(8)
# Source: nmh uip/ap.c (master) — parse and reformat addresses (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-form+[format file]:file:_files' \
    '-format+[format string]:string:_default' \
    '-width+[output width]:cols:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '*:address:_email_addresses' \
    && ret=0

return ret
