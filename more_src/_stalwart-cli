#compdef stalwart-cli
# Documentation: https://man.archlinux.org/search?q=stalwart-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'describe:describe object schema'
  'get:get an object by id'
  'query:query objects'
  'create:create an object'
  'update:update an object'
  'delete:delete an object'
  'apply:apply YAML/JSON manifest'
  'snapshot:export resources to file'
)

_arguments -C \
  '--url=[Stalwart server URL]:url:' \
  '--user=[username]:user:' \
  '--password=[password]:password:' \
  '--api-key=[API token]:token:' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS verification]' \
  '--no-color[disable color]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'stalwart-cli subcommand' subcommands && ret=0
    ;;
  (args)
    _arguments \
      '*--fields=[fields]:fields:' \
      '--where=[filter]:expr:' \
      '*--field=[field key=value]:KEY=VALUE:' \
      '--json[JSON output]' \
      '--file=[input file]:file:_files' \
      '--stdin[read from stdin]' \
      '*--ids=[object ids]:ids:' \
      '--dry-run[dry run]' \
      '--continue-on-error[continue on error]' \
      '--quiet[quiet]' \
      '--progress[show progress]' \
      '--output=[output file]:file:_files' \
      '--no-destroys[skip destructive ops]' \
      '--include-secrets[include secrets in output]' \
      '--allow-unresolved[allow unresolved refs]' \
      '*::object: ' && ret=0
    ;;
esac

return ret
