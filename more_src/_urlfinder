#compdef urlfinder
# Documentation: https://github.com/projectdiscovery/urlfinder
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

_arguments -s \
  '(-d -list)'{-d,-list}'=[domain or list]:domains:_files' \
  '(-s -sources)'{-s,-sources}'=[sources]:sources:' \
  '(-es -exclude-sources)'{-es,-exclude-sources}'=[exclude sources]:sources:' \
  '-all[use all sources]' \
  '(-us -url-scope)'{-us,-url-scope}'=[in-scope URL regex]:regex:' \
  '(-uos -url-out-scope)'{-uos,-url-out-scope}'=[out-of-scope URL regex]:regex:' \
  '(-fs -field-scope)'{-fs,-field-scope}'=[field scope]:scope:(dn rdn fqdn)' \
  '(-ns -no-scope)'{-ns,-no-scope}'[disable scope]' \
  '(-do -display-out-scope)'{-do,-display-out-scope}'[display out-of-scope]' \
  '(-m -match)'{-m,-match}'=[match URLs]:match:_files' \
  '(-f -filter)'{-f,-filter}'=[filter URLs]:filter:_files' \
  '(-rl -rate-limit)'{-rl,-rate-limit}'=[req/sec]:n:' \
  '(-rls -rate-limits)'{-rls,-rate-limits}'=[per-provider rate]:rate:' \
  '(-up -update)'{-up,-update}'[update]' \
  '(-duc -disable-update-check)'{-duc,-disable-update-check}'[disable update check]' \
  '(-o -output)'{-o,-output}'=[output file]:file:_files' \
  '(-j -jsonl)'{-j,-jsonl}'[JSONL output]' \
  '(-od -output-dir)'{-od,-output-dir}'=[output dir]:dir:_files -/' \
  '(-cs -collect-sources)'{-cs,-collect-sources}'[include sources]' \
  '-config=[config file]:file:_files' \
  '(-pc -provider-config)'{-pc,-provider-config}'=[provider config]:file:_files' \
  '-proxy=[HTTP proxy]:url:' \
  '-silent[silent]' \
  '-version[show version]' \
  '-v[verbose]' \
  '(-nc -no-color)'{-nc,-no-color}'[no color]' \
  '(-ls -list-sources)'{-ls,-list-sources}'[list sources]' \
  '-stats[stats]' \
  '-timeout=[timeout]:seconds:' \
  '-max-time=[max time]:minutes:'
