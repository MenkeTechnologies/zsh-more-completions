#compdef esbuild-cli
# _esbuild-cli — Evan Wallace esbuild JS bundler/minifier CLI alias (Evan Wallace / esbuild team, Go); custom argparse
# upstream: https://github.com/evanw/esbuild

_esbuild-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--bundle[bundle imports]' \
        '--outfile=+[output file]:file:_files' \
        '--outdir=+[output dir]:dir:_files -/' \
        '--outbase=+[output base]:dir:_files -/' \
        '--public-path=+[public path]:str:' \
        '--alias=+[alias key=value]:str:' \
        '--analyze[print bundle analysis]' \
        '--analyze=verbose[print verbose bundle analysis]' \
        '--asset-names=+[asset names template]:str:' \
        '--banner=+[banner type=text]:str:' \
        '--charset=+[charset]:c:(ascii utf8)' \
        '--color=+[color]:b:(true false)' \
        '--define=+[define key=value]:str:' \
        '--drop=+[drop]:list:(console debugger)' \
        '--entry-names=+[entry names template]:str:' \
        '--external=+[external module]:list:' \
        '--footer=+[footer type=text]:str:' \
        '--format=+[format]:f:(iife cjs esm)' \
        '--global-name=+[global name]:str:' \
        '--ignore-annotations[ignore /*\\#__PURE__*/]' \
        '--inject=+[inject path]:file:_files' \
        '--jsx=+[jsx mode]:m:(automatic transform preserve)' \
        '--jsx-dev[jsx dev mode]' \
        '--jsx-factory=+[jsx factory]:str:' \
        '--jsx-fragment=+[jsx fragment]:str:' \
        '--jsx-import-source=+[jsx import source]:str:' \
        '--jsx-side-effects[jsx side effects]' \
        '--keep-names[keep function/class names]' \
        '--legal-comments=+[legal comments]:m:(none inline eof linked external)' \
        '--loader:+[loader]:list:(js jsx ts tsx json text base64 file dataurl binary css default empty copy)' \
        '--log-level=+[log level]:level:(verbose debug info warning error silent)' \
        '--log-limit=+[log limit]:n:' \
        '--log-override=+[log override]:str:' \
        '--main-fields=+[main fields]:list:' \
        '--mangle-cache=+[mangle cache file]:file:_files' \
        '--mangle-props=+[mangle props pattern]:str:' \
        '--mangle-quoted=+[mangle quoted]:b:(true false)' \
        '--metafile=+[metafile output]:file:_files' \
        '--minify[minify]' \
        '--minify-whitespace[minify whitespace]' \
        '--minify-identifiers[minify identifiers]' \
        '--minify-syntax[minify syntax]' \
        '--node-paths=+[node paths]:list:' \
        '--out-extension=+[out extension key=value]:str:' \
        '--packages=+[packages]:p:(external bundle)' \
        '--platform=+[platform]:p:(browser node neutral)' \
        '--preserve-symlinks[preserve symlinks]' \
        '--pure=+[pure expressions]:list:' \
        '--reserve-props=+[reserve props pattern]:str:' \
        '--resolve-extensions=+[resolve extensions]:list:' \
        '--serve=+[serve mode host:port]:str:' \
        '--serve-fallback=+[serve fallback]:dir:_files -/' \
        '--servedir=+[servedir]:dir:_files -/' \
        '--source-root=+[source root]:str:' \
        '--sourcefile=+[sourcefile name]:str:' \
        '--sourcemap=+[sourcemap mode]:m:(external inline linked both)' \
        '--sources-content=+[sources content]:b:(true false)' \
        '--splitting[code splitting]' \
        '--supported=+[supported syntax]:str:' \
        '--target=+[target]:str:' \
        '--tree-shaking=+[tree shaking]:b:(true false)' \
        '--tsconfig=+[tsconfig]:file:_files' \
        '--tsconfig-raw=+[inline tsconfig]:str:' \
        '--watch[watch mode]' \
        '--write[write output files]' \
        '*:input:_files'
}

_esbuild-cli "$@"
