#compdef mace_eval_configs
# Documentation: https://mace-docs.readthedocs.io/en/latest/guide/training.html
# MACE: evaluate a trained model on a set of configurations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--configs=[input XYZ configurations to evaluate]:file:_files' \
  '--model=[trained MACE model file]:file:_files' \
  '--output=[output file path for results]:file:_files' \
  '--device=[computing device]:device:(cuda cpu mps)' \
  '--batch_size=[evaluation batch size]:size' \
  '--default_dtype=[precision]:dtype:(float64 float32)' \
  '*:arg:_files' && ret=0

return ret
