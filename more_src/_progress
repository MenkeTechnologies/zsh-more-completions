#compdef progress

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '-w[wait for all processes to complete]' \
  '--wait[wait for all processes to complete]' \
  '-W[estimate I/O throughput and ETA]' \
  '--wait-delay=[seconds between updates]:seconds' \
  '-m[monitor continuously]' \
  '--monitor[monitor continuously]' \
  '-M[monitor continuously with throughput]' \
  '--monitor-continuously[monitor continuously with throughput]' \
  '-c+[command name to monitor]:command name' \
  '--command=[command name to monitor]:command name' \
  '-a[monitor all matching processes]' \
  '--additional-command=[additional command to monitor]:command name' \
  '-p+[process to monitor]:pid' \
  '--pid=[process to monitor]:pid' \
  '-i+[ignore command]:command name' \
  '--ignore-file=[ignore command]:command name' \
  '-o+[output to file]:output file:_files' \
  '--output=[output to file]:output file:_files' \
  '-b[display bytes instead of throughput]' \
  '--bytes[display bytes instead of throughput]' \
  '-l[use line mode]' \
  '--line[use line mode]' && ret=0

return ret
