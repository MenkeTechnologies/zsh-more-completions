#compdef vitest-cli
# Documentation: https://man.archlinux.org/search?q=vitest-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '(-v)-v[show version]' \
  '(--root -r)'{-r+,--root=}'[project root]:dir:_files -/' \
  '(--config -c)'{-c+,--config=}'[config file]:file:_files -g "vitest.config.* vite.config.*"' \
  '(--update -u)'{-u,--update}'[update snapshots]' \
  '(--watch -w)'{-w,--watch}'[watch mode]' \
  '(--silent)--silent[silent]' \
  '(--reporter)*--reporter=[reporter]:r:(default verbose dot junit json hanging-process tap tap-flat html github-actions blob)' \
  '(--outputFile)--outputFile=[output file]:file:_files' \
  '(--coverage)--coverage[coverage]' \
  '(--coverage.enabled)--coverage.enabled=[coverage]:b:(true false)' \
  '(--coverage.provider)--coverage.provider=[provider]:p:(v8 istanbul custom)' \
  '(--coverage.reporter)*--coverage.reporter=[cov reporter]:r:(text text-summary html lcov clover cobertura json json-summary teamcity)' \
  '(--coverage.reportsDirectory)--coverage.reportsDirectory=[cov dir]:dir:_files -/' \
  '(--coverage.include)*--coverage.include=[cov include]:p:' \
  '(--coverage.exclude)*--coverage.exclude=[cov exclude]:p:' \
  '(--coverage.all)--coverage.all=[all files]:b:(true false)' \
  '(--coverage.thresholds.lines)--coverage.thresholds.lines=[lines threshold]:n:' \
  '(--coverage.thresholds.functions)--coverage.thresholds.functions=[fn threshold]:n:' \
  '(--coverage.thresholds.branches)--coverage.thresholds.branches=[branch threshold]:n:' \
  '(--coverage.thresholds.statements)--coverage.thresholds.statements=[stmt threshold]:n:' \
  '(--run)--run[run once]' \
  '(--changed)--changed[only changed]' \
  '(--shard)--shard=[shard N/M]:s:' \
  '(--passWithNoTests)--passWithNoTests[pass with no tests]' \
  '(--allowOnly)--allowOnly[allow .only]' \
  '(--inspect)--inspect[node inspector]' \
  '(--inspect-brk)--inspect-brk[break on start]' \
  '(--bail)--bail=[bail after N]:n:' \
  '(--retry)--retry=[retry N]:n:' \
  '(--mode)--mode=[mode]:m:(test development production)' \
  '(--workspace)--workspace=[workspace]:file:_files' \
  '(--isolate)--isolate=[isolate]:b:(true false)' \
  '(--no-isolate)--no-isolate[disable isolation]' \
  '(--pool)--pool=[pool]:p:(threads forks vmThreads vmForks)' \
  '(--poolOptions.threads.singleThread)--poolOptions.threads.singleThread[single thread]' \
  '(--poolOptions.threads.maxThreads)--poolOptions.threads.maxThreads=[max threads]:n:' \
  '(--poolOptions.threads.minThreads)--poolOptions.threads.minThreads=[min threads]:n:' \
  '(--maxWorkers)--maxWorkers=[max workers]:n:' \
  '(--minWorkers)--minWorkers=[min workers]:n:' \
  '(--testTimeout)--testTimeout=[ms]:ms:' \
  '(--hookTimeout)--hookTimeout=[ms]:ms:' \
  '(--teardownTimeout)--teardownTimeout=[ms]:ms:' \
  '(--testNamePattern)--testNamePattern=[regex]:re:' \
  '(-t)-t+[regex]:re:' \
  '(--ui)--ui[run UI]' \
  '(--ui.open)--ui.open[open UI in browser]' \
  '(--browser)--browser=[browser mode]:b:' \
  '(--browser.enabled)--browser.enabled[enable browser]' \
  '(--browser.headless)--browser.headless[headless]' \
  '(--browser.name)--browser.name=[browser]:b:(chromium chrome edge firefox safari webkit)' \
  '(--browser.provider)--browser.provider=[provider]:p:(playwright preview webdriverio)' \
  '(--typecheck)--typecheck[type check]' \
  '(--typecheck.enabled)--typecheck.enabled=[enable typecheck]:b:(true false)' \
  '(--typecheck.tsconfig)--typecheck.tsconfig=[tsconfig]:file:_files -g "*.json"' \
  '(--typecheck.checker)--typecheck.checker=[checker]:c:(tsc vue-tsc)' \
  '(--api)--api[start API server]' \
  '(--api.port)--api.port=[port]:p:' \
  '(--api.host)--api.host=[host]:h:_hosts' \
  '(--api.strictPort)--api.strictPort[strict port]' \
  '(--related)--related=[related files csv]:list:_files' \
  '(--clearScreen)--clearScreen=[clear screen]:b:(true false)' \
  '(--logHeapUsage)--logHeapUsage[log heap]' \
  '(--standalone)--standalone[standalone server]' \
  '(--mergeReports)--mergeReports=[merge dir]:dir:_files -/' \
  '(--exclude)*--exclude=[exclude pattern]:p:' \
  '(--include)*--include=[include pattern]:p:' \
  '(--includeSource)*--includeSource=[in-source pattern]:p:' \
  '(--cache)--cache=[cache]:b:(true false)' \
  '(--cache.dir)--cache.dir=[cache dir]:dir:_files -/' \
  '(--no-cache)--no-cache[no cache]' \
  '(--list)--list[list tests]' \
  '(--no-clearScreen)--no-clearScreen[no clear screen]' \
  '(--noColor)--noColor[no color]' \
  '*: :_files' && ret=0

local -a vcommands
vcommands=(
  'run:run tests once'
  'watch:watch tests'
  'dev:alias of watch'
  'related:run related tests'
  'bench:run benchmarks'
  'init:init Vitest config'
  'list:list tests'
  'typecheck:run type check'
)
_describe -t cmds 'vitest command' vcommands && ret=0

return ret
