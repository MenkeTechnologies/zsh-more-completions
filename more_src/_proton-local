#compdef proton-local
# Documentation: https://docs.timeplus.com/proton
# Timeplus Proton local mode (ClickHouse local fork)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --query)'{-q,--query}'=[query to execute]:query' \
  '--queries-file=[file with queries]:file:_files' \
  '(-m --multiquery)'{-m,--multiquery}'[execute multiple semicolon-separated queries]' \
  '(-N --table)'{-N,--table}'=[name of the table]:table name' \
  '(-S --structure)'{-S,--structure}'=[structure of the table]:structure' \
  '--input-format=[input format]:format' \
  '(-f --file)'{-f,--file}'=[input file]:file:_files' \
  '--output-format=[output format]:format' \
  '--stacktrace[print stack traces of exceptions]' \
  '--echo[echo queries before execution]' \
  '--verbose[enable verbose logging]' \
  '--path=[path to data directory]:dir:_files -/' \
  '--max_threads=[maximum number of threads]:threads' \
  '--max_memory_usage=[maximum memory usage in bytes]:bytes' \
  '--interactive[interactive mode]' \
  '--progress[show progress]' \
  '*:file:_files' && ret=0

return ret
