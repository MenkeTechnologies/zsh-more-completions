#compdef toktrack

# Zsh completion for toktrack (AI token and cost tracker)

local -a commands
commands=(
  'daily:Show today’s usage summary'
  'weekly:Show this week’s usage summary'
  'monthly:Show this month’s usage summary'
  'stats:Show general statistics'
  'report:Generate shareable receipts (Text or SVG)'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '(- *)'{-V,--version}'[Show version information]' \
  '--json[Output in JSON format]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  report)
    _arguments \
      '--format=[Specify report format]:format:(text svg)'
    ;;
esac
