#compdef seldon-core-microservice
# Documentation: https://github.com/SeldonIO/seldon-core
# Reference accessed: 2026-05-23
# Verified: seldon-core-microservice --help (Seldon Core inference server).

# Zsh completion for seldon-core-microservice - Seldon Core model microservice

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--service-type[service type]:(MODEL ROUTER TRANSFORMER COMBINER OUTLIER_DETECTOR)' \
  '--persistence[deprecated persistence flag]' \
  '--parameters[parameters JSON]:json:' \
  '--log-level[log level]:(DEBUG INFO WARNING ERROR)' \
  '--debug[enable debug mode]' \
  '--tracing[enable tracing]' \
  '--workers[Gunicorn workers]:count:' \
  '--threads[threads per Gunicorn worker]:count:' \
  '--max-requests[max requests before worker restart]:count:' \
  '--max-requests-jitter[max-requests jitter]:count:' \
  '--keepalive[Keep-Alive seconds]:seconds:' \
  '--single-threaded[force single-threaded Flask app]' \
  '--http-port[HTTP port]:port:' \
  '--grpc-port[gRPC port]:port:' \
  '--metrics-port[metrics port]:port:' \
  '--pidfile[PID file path]:file:_files' \
  '--access-log[enable access log]' \
  '--grpc-threads[gRPC threads]:count:' \
  '--grpc-workers[gRPC workers]:count:' \
  '1:interface_name:user interface name:' && ret=0

return ret
