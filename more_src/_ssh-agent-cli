#compdef ssh-agent
# _ssh-agent-cli — OpenSSH authentication agent; hold private keys for use by ssh
# upstream: https://github.com/openssh/openssh-portable

_ssh-agent-cli() {
    _arguments \
        '-a+[bind socket path]:file:_files' \
        '-c[csh-style output]' \
        '-D[foreground / no daemonize]' \
        '-d[debug mode]' \
        '-E+[fingerprint hash]:algo:(md5 sha256)' \
        '-k[kill running agent (uses $SSH_AGENT_PID)]' \
        '-O+[option]:str:' \
        '-P+[PKCS#11 whitelist]:str:' \
        '-s[Bourne-style output]' \
        '-t+[default identity lifetime sec]:n:' \
        '*::command:_command_names -e'
}

_ssh-agent-cli "$@"
