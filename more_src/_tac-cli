#compdef tac-cli
# _tac-cli — GNU coreutils tac concatenate and print files in reverse CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_tac-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[attach separator before]' \
        '--before[attach separator before]' \
        '-r[separator is regex]' \
        '--regex[separator is regex]' \
        '-s+[separator]:str:' \
        '--separator=+[separator]:str:' \
        '*:files:_files'
}

_tac-cli "$@"
