#compdef cg_annotate cg_diff cg_merge
# _cachegrind — Valgrind cachegrind annotators (Nicholas Nethercote, C); analyze cachegrind.out files
# upstream: https://valgrind.org

_cachegrind() {
    _arguments \
        '--show+[events to show]:events:' \
        '--sort+[sort key]:key:' \
        '--threshold+[threshold pct]:f:' \
        '--auto+[auto annotate]:bool:(yes no)' \
        '--context+[context lines]:n:' \
        '--I1+[I1 cache cfg]:cfg:' \
        '--D1+[D1 cache cfg]:cfg:' \
        '--LL+[LL cache cfg]:cfg:' \
        '--mod-filename+[filename rewrite]:str:' \
        '--mod-funcname+[function rewrite]:str:' \
        '--include+[include source dir]:dir:_files -/' \
        '*:cachegrind.out file:_files'
}

_cachegrind "$@"
