#compdef balance
# Documentation: https://balance.inlab.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-b+[bind address]:addr:' \
  '-B+[outbound address]:addr:' \
  '-t+[client timeout]:sec:' \
  '-T+[server timeout]:sec:' \
  '-a+[allowed clients]:addr:' \
  '-c+[command]:cmd:' \
  '-f[do not fork]' \
  '-i[interactive control]' \
  '-d[debug]' \
  '-p+[pid file]:file:_files' \
  '-M[disable multi-channel]' \
  '-6[IPv6]' \
  '-H[use hash mode]' \
  '*:host:port:_hosts' && ret=0

return ret
