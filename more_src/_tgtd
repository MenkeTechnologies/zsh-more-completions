#compdef tgtd
# Documentation: https://manpages.debian.org/bookworm/tgt/tgtd.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-C --control-port)'{-C,--control-port}'+[control port]:port:' \
  '(-d --debug)'{-d,--debug}'+[debug level]:level:' \
  '--iscsi=[iSCSI parameters (portal,nop_interval,nop_count)]:params:' && ret=0

return ret
