#compdef tgtd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-C --control-port)'{-C,--control-port}'+[control port]:port:' \
  '(-d --debug)'{-d,--debug}'+[debug level]:level:(0 1 2 3)' \
  '(-t --nr_iothreads)'{-t,--nr_iothreads}'+[number of I/O threads]:n:' \
  '(-u --user)'{-u,--user}'+[user to run as]:user:_users' \
  '(-g --group)'{-g,--group}'+[group to run as]:group:_groups' \
  '(-p --pid-file)'{-p,--pid-file}'+[PID file]:file:_files' \
  '(-y --syslog)'{-y,--syslog}'[log to syslog]' && ret=0

return ret
