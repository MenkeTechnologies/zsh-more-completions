#compdef yosay
# Documentation: https://github.com/yeoman/yosay
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--maxLength[Max number of characters per line]:length'
    '--help[Show help]'
    '--version[Show version]'
    '*:message text:'
)

_arguments -s -S $arguments
