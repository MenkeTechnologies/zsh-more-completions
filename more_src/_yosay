#compdef yosay
# Documentation: https://man.archlinux.org/search?q=yosay
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--maxLength[Max number of characters per line]:length'
    '--help[Show help]'
    '--version[Show version]'
    '*:message text:'
)

_arguments -s -S $arguments
