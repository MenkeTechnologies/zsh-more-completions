#compdef bismark
# Documentation: https://felixkrueger.github.io/Bismark/options/alignment/
# bismark - bisulfite read mapper and methylation caller

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--genome=[path to prepared reference genome folder]:dir:_files -/' \
  '-1[forward mate files]:file:_files' \
  '-2[reverse mate files]:file:_files' \
  '(-q --fastq)'{-q,--fastq}'[FastQ input format]' \
  '(-f --fasta)'{-f,--fasta}'[FastA input format]' \
  '(-s --skip)'{-s,--skip}'=[skip first n reads]:n' \
  '(-u --upto)'{-u,--upto}'=[align only first n reads]:n' \
  '--bowtie2[use Bowtie 2 aligner]' \
  '--hisat2[use HISAT2 aligner]' \
  '--minimap2[use minimap2 aligner]' \
  '-N[mismatches allowed in seed]:n:(0 1)' \
  '-L[seed substring length]:len' \
  '(-I --minins)'{-I,--minins}'=[minimum insert size]:size' \
  '(-X --maxins)'{-X,--maxins}'=[maximum insert size]:size' \
  '--score_min=[minimum alignment score function]:func' \
  '-D[seed extension attempts]:n' \
  '-R[max re-seeding attempts]:n' \
  '--non_directional[report alignments to all four strands]' \
  '--pbat[PBAT-Seq library mode]' \
  '--no_dovetail[disable dovetailing alignments]' \
  '--sam[output SAM format]' \
  '--cram[output CRAM format]' \
  '--gzip[compress temporary conversion files]' \
  '(-o --output_dir)'{-o,--output_dir}'=[output directory]:dir:_files -/' \
  '--prefix=[prefix for output filenames]:prefix' \
  '(-B --basename)'{-B,--basename}'=[base filename for outputs]:name' \
  '--un[write unmapped reads to file]' \
  '--ambiguous[write ambiguous reads to file]' \
  '--non_bs_mm[include non-bisulfite mismatch counts]' \
  '(-p)-p[number of parallel search threads]:n' \
  '--parallel=[run concurrent Bismark instances]:n' \
  '--rg_tag[add Read Group tags]' \
  '--rg_id=[Read Group ID]:id' \
  '--rg_sample=[Read Group sample name]:name' \
  '--quiet[suppress non-alignment output]' \
  '--nucleotide_coverage[nucleotide composition statistics]' \
  '--local[local alignment with soft-clipping]' \
  '*:file:_files' && ret=0

return ret
