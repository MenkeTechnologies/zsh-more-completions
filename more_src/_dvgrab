#compdef dvgrab
# _dvgrab — Arne Schirmacher Dan Dennedy dvgrab capture utility for IEEE-1394 FireWire DV/HDV camcorder streams (kinodv team, C++); getopt
# upstream: https://sourceforge.net/projects/kino/

_dvgrab() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--noavc[no AV/C commands]' \
        '--card=+[N]:n:' \
        '--channel=+[N channel]:n:' \
        '--collection=+[type]:t:(default movtxt csv)' \
        '--every=+[N frames]:n:' \
        '--format=+[output format]:f:(dv1 dv2 raw avi hdv mov mpeg2 jpeg qt)' \
        '--guid=+[FireWire GUID]:str:' \
        '--input=+[file]:file:_files' \
        '--frames=+[N]:n:' \
        '--lockstep[lockstep]' \
        '--lockstep-maxdrops=+[N]:n:' \
        '--no-mux[do not mux]' \
        '--opendml[OpenDML for >2GB]' \
        '--rewind[rewind tape]' \
        '--save-mode[save mode]' \
        '--showstatus[show status]' \
        '--size=+[MiB]:n:' \
        '--srt[SRT subs]' \
        '--stdout[write to stdout]' \
        '--testvideo[test video]' \
        '--timecode[use timecode for filenames]' \
        '--timestamp[use timestamp for filenames]' \
        '--timesys[use system time for filenames]' \
        '--rec-date[use rec-date for filenames]' \
        '--csize=+[bytes]:n:' \
        '--cmincutsize=+[bytes]:n:' \
        '--csizelimit=+[bytes]:n:' \
        '--duration=+[smpte time]:str:' \
        '--autosplit=+[mode]:m:(no scene timecode)' \
        '--buffers=+[N]:n:' \
        '--port=+[N]:n:' \
        '--filesys=+[fs]:fs:(default vfat ext)' \
        '--device=+[device]:file:_files -g "*"' \
        '--jvc[JVC ProHD]' \
        '*:base filename:_files'
}

_dvgrab "$@"
