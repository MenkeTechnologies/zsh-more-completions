#compdef gts2dxf
# Documentation: https://linux.die.net/man/1/gts2dxf
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gts2dxf: convert GTS triangulated surface to DXF (reads stdin, writes stdout).

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:GTS file:_files -g "*.gts"' && ret=0

return ret
