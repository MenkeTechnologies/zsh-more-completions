#compdef librarian-puppet
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/librarian-puppet.1.html
# librarian-puppet - bundler-style dependency manager for Puppet modules

local ret=1

_arguments -s -S \
  '--verbose[run in verbose mode]' \
  '1:command:(clean config help init install outdated package show update version)' \
  '*::module:' && ret=0

return ret
