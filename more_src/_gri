#compdef gri yorick
# Documentation: upstream gri(1) and yorick(1) man pages
# Reference accessed: 2026-05-30 via WebFetch of
# manpages.debian.org/bookworm/gri/gri.1.en.html and
# manpages.ubuntu.com/manpages/jammy/man1/yorick.1.html.
# Scientific scripting R85 — 2-stem multi-binary harvest:
# gri (scientific plotting language) and yorick (numerical
# interpreter). Both single-binary CLIs with finite documented
# flag surfaces; bundled together because both are niche numerical
# scripting tools without subcommand trees.

case $service in

  gri)
    # Scientific plotting language (compiles .gri script into PostScript).
    _arguments -s -S \
      '-creator=[extract Gri commands from a PostScript file]:postscript file:_files -g "*.ps"' \
      '(- *)'{-h,-help,--help}'[show help message]' \
      '(- *)'{-v,-version,--version}'[show version number]' \
      '(-b -batch)'{-b,-batch}'[stop printing prompts and hints]' \
      '-chatty=[enable informational messages]:level:' \
      '-c[enable informational messages]' \
      '(-d -debug)'{-d,-debug}'[turn debugging on (sets ..debug.. = 1)]' \
      '-warn_offpage[warn when items drawn outside 8.5x11 page (default)]' \
      '-nowarn_offpage[disable off-page warnings]' \
      '-directory=[directory for startup files]:dir:_directories' \
      '-directory_default[report default startup directory]' \
      '-no_bounding_box[make bounding-box full page]' \
      '-no_expecting[do not warn if version command is missing]' \
      '-no_startup_message[suppress startup message]' \
      '(-p -publication)'{-p,-publication}'[set builtin variable ..publication.. = 1]' \
      '(-s -superuser)'{-s,-superuser}'[enable programmer debugging (optional level)]:level:' \
      '(-t -trace)'{-t,-trace}'[print command lines as they are executed]' \
      '(-y -true)'{-y,-true}"[automatically answer 'yes' to all queries]" \
      '*:gri script:_files -g "*.gri"'
    ;;

  yorick)
    # Yorick numerical interpreter.
    # Just 2 flags + positional .i script files; no other documented
    # CLI surface per upstream man page.
    _arguments -s -S \
      '*-i+[include a Yorick source file at startup (repeatable)]:file:_files -g "*.i"' \
      '-batch=[batch mode (no custom.i, all errors fatal)]:file:_files -g "*.i"' \
      '*:yorick script:_files -g "*.i"'
    ;;

esac
