#compdef cwl-docker-extract
# Documentation: https://github.com/common-workflow-language/cwl-utils
# Pull all software container images referenced in a CWL document

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dir=[directory in which to save images]:dir:_files -/' \
  '(-s --singularity)'{-s,--singularity}'[use singularity to pull the image]' \
  '--container-engine=[command to use to run OCI containers]:engine' \
  '--force-download[force pulling a newer container]' \
  '*:CWL document:_files -g "*.cwl"' && ret=0

return ret
