#compdef grub-ofpathname
# Documentation: https://man.archlinux.org/search?q=grub-ofpathname
# Reference accessed: 2026-05-16

# grub-ofpathname: print OpenFirmware path for a device
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)-V[show version]' \
  '(- *)--usage[show usage]' \
  '1:device:_files -g "/dev/*"' && ret=0
return ret
