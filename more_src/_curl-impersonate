#compdef curl-impersonate curl-impersonate-chrome curl-impersonate-ff curl_chrome116 curl_chrome120 curl_ff117 curl_safari17_2_ios
# _curl-impersonate — curl-impersonate browser-TLS-fingerprint-mimicking curl fork; matches JA3/JA4 of real browsers for bypassing TLS-based fingerprinting
# upstream: https://github.com/lwthiker/curl-impersonate

_curl-impersonate() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-X --request)'{-X,--request}'+[method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
        '(-H --header)'{-H,--header}'+[header]:header:' \
        '(-d --data)'{-d,--data}'+[body data]:data:' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-O --remote-name)'{-O,--remote-name}'[save with remote name]' \
        '(-L --location)'{-L,--location}'[follow redirects]' \
        '(-k --insecure)'{-k,--insecure}'[skip TLS verify]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-s --silent)'{-s,--silent}'[silent mode]' \
        '(-I --head)'{-I,--head}'[headers only]' \
        '(-i --include)'{-i,--include}'[include headers in output]' \
        '(-c --cookie-jar)'{-c,--cookie-jar}'+[cookie jar]:file:_files' \
        '(-b --cookie)'{-b,--cookie}'+[cookie or jar]:cookie:' \
        '(-A --user-agent)'{-A,--user-agent}'+[user agent]:ua:' \
        '(-e --referer)'{-e,--referer}'+[referer]:url:_urls' \
        '(-u --user)'{-u,--user}'+[basic auth]:user:pass:' \
        '(-x --proxy)'{-x,--proxy}'+[proxy]:proxy:' \
        '--http2[force HTTP/2]' \
        '--http3[force HTTP/3]' \
        '*:URL:_urls'
}

_curl-impersonate "$@"
