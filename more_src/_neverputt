#compdef neverputt
# Documentation: https://manpages.debian.org/bookworm/neverball/neverputt.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm neverputt(6) manpage. Same option style
# as neverball (long-only).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated short -d form.

# neverputt: 3D mini-golf companion to neverball
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--data[data directory]:dir:_files -/' && ret=0
return ret
