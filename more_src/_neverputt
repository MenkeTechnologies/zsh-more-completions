#compdef neverputt
# Documentation: https://man.archlinux.org/search?q=neverputt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --datadir)'{-d,--datadir}'+[data dir]:dir:_files -/' && ret=0

return ret
