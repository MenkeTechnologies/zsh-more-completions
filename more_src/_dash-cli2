#compdef dash-cli2 dash2
# _dash-cli2 — Herbert Xu Debian Almquist Shell dash-cli2 CLI command-line frontend wrapping the dash Debian Almquist Shell DASH is a POSIX-compliant Unix shell smaller than bash but largely compatible designed for portability and speed open-source written in C originally Kenneth Almquist NetBSD ash port now Herbert Xu Debian DASH POSIX-compliant /bin/sh on Debian Ubuntu Mint Knoppix used as default /bin/sh on Debian-derived systems fastest shell startup faster boot time NetBSD-Almquist-shell-derived no command-line-editing no history no command-completion -i -l -s -c -a -b -C -e -f -m -n -t -u -v -x -E option monitor noexec noglob nolog notify nounset xtrace verbose (Herbert Xu Debian team Kenneth Almquist NetBSD, C); custom argparse
# upstream: http://gondor.apana.org.au/~herbert/dash/

_dash-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[command]:str:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[stdin command]' \
        '-r[restricted shell]' \
        '-a[allexport]' \
        '-b[notify]' \
        '-C[noclobber]' \
        '-E[no exit on signal]' \
        '-e[errexit]' \
        '-f[noglob]' \
        '-h[hash]' \
        '-m[monitor]' \
        '-n[noexec]' \
        '-t[onecmd]' \
        '-u[nounset]' \
        '-v[verbose]' \
        '-x[xtrace]' \
        '-I+[ignoreeof]' \
        '-o+[option]:o:(allexport errexit ignoreeof monitor noclobber noexec noglob nolog notify nounset verbose vi xtrace pipefail trapsasync onecmd hashall mode)' \
        '+o+[option]:o:(allexport errexit ignoreeof monitor noclobber noexec noglob nolog notify nounset verbose vi xtrace pipefail trapsasync onecmd hashall mode)' \
        '-q[quiet]' \
        '*:dash script:_files -g "*.sh *.dash"'
}

_dash-cli2 "$@"
