#compdef suplane
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/synthetics_waveforms_testpatterns/suplane.c
# SUPLANE - create common offset data file with up to 3 planes

local ret=1

_arguments -s -S \
  'npl=[number of planes]:n:' \
  'nt=[number of time samples]:n:' \
  'ntr=[number of traces]:n:' \
  'taper=[end-of-plane taper (0/1)]:t:(0 1)' \
  'offset=[offset]:o:' \
  'dt=[time sample interval (sec)]:dt:' \
  'liner=[use 64x64 preset parameters]:l:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
