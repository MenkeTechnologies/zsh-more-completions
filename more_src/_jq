#compdef jq
# Documentation: https://jqlang.org/manual/
# Source: jqlang/jq — command-line JSON processor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-n --null-input)'{-n,--null-input}'[no input; run filter once with null]' \
    '(-R --raw-input)'{-R,--raw-input}'[treat input lines as strings]' \
    '(-s --slurp)'{-s,--slurp}'[read entire input into one array]' \
    '(-r --raw-output)'{-r,--raw-output}'[output strings without JSON quotes]' \
    '(-c --compact-output)'{-c,--compact-output}'[minimize output formatting]' \
    '(-j --join-output)'{-j,--join-output}'[like -r but no newlines]' \
    '--raw-output0[NUL-separated output (raw)]' \
    '--tab[use tabs for indentation]' \
    '--indent=[N spaces for indentation (max 7)]:n:(0 1 2 3 4 5 6 7)' \
    '(-S --sort-keys)'{-S,--sort-keys}'[sort object keys]' \
    '(-a --ascii-output)'{-a,--ascii-output}'[escape non-ASCII]' \
    '(-C --color-output -M --monochrome-output)'{-C,--color-output}'[force colored output]' \
    '(-C --color-output -M --monochrome-output)'{-M,--monochrome-output}'[disable color]' \
    '*--arg[define string variable $name=value]:name value:' \
    '*--argjson[define JSON variable $name=json]:name json:' \
    '*--slurpfile[load JSON array from file into $var]:name file:' \
    '*--rawfile[load raw text from file into $var]:name file:' \
    '(--args --jsonargs)--args[remaining args become $ARGS.positional[] strings]' \
    '(--args --jsonargs)--jsonargs[remaining args become $ARGS.positional[] JSON]' \
    '--stream[parse input in streaming mode]' \
    '--unbuffered[flush output after each JSON object]' \
    '(-e --exit-status)'{-e,--exit-status}'[set exit code based on output]' \
    '--seq[input/output uses RFC 7464 record separators]' \
    '--input-filename=[use this filename in error messages]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:jq filter:' \
    '*:JSON file:_files -g "*.(json|ndjson|jsonl)"' \
    && ret=0

return ret
