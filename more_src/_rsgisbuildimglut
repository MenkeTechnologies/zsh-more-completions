#compdef rsgisbuildimglut
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisbuildimglut RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --imgsearch)'{-i,--imgsearch}'[Input search path which includes wildcard (i.e., *) for python glob function to find the images to build the LUT. Note. This input will need to be provided in \\.]:value:_files' \
  '(-o --output)'{-o,--output}'[Output vector file representing the LUT.]:value:_files' \
  '--veclyr[Alternative layer name (if supported) for the LUT vector file.]:value:_files' \
  '--vecformat[OGR vector format for the LUT file.]:value:_files' \
  '--wgs84[Reproject footprints to EPSG\:4326 (WGS84).]' \
  '--ignore_noproj[Silently ignored images which do not have a defined projection.]' \
  '--overwrite[Overwrite the output vector file, if not specified]' \
  '*:file:_files' && ret=0

return ret
