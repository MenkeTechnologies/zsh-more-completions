#compdef wat2wasm wasm2wat wasm-objdump wasm-interp wasm-validate wasm-strip wasm-decompile wasm2c spectest-interp

# completions for wabt - WebAssembly Binary Toolkit

local curcontext="$curcontext" state line ret=1

local -a common_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '(-v --verbose)'{-v,--verbose}'[use multiple times for more info]'
  '(-o --output)'{-o,--output}'[output file]:output file:_files'
)

local -a enable_flags=(
  '--enable-exceptions[enable exceptions extension]'
  '--enable-multi-memory[enable multi-memory extension]'
  '--enable-threads[enable threads extension]'
  '--enable-tail-call[enable tail call extension]'
  '--enable-bulk-memory[enable bulk memory extension]'
  '--enable-reference-types[enable reference types extension]'
  '--enable-simd[enable SIMD extension]'
)

case $service in
  (wat2wasm)
    _arguments -s -S \
      $common_flags \
      $enable_flags \
      '--debug-names[write debug names to the binary file]' \
      '--no-check[don'\''t check for invalid modules]' \
      '--no-canonicalize-leb128s[write all LEB128 sizes as 5-bytes]' \
      '*:input file:_files -g "*.wat"' && ret=0
    ;;
  (wasm2wat)
    _arguments -s -S \
      $common_flags \
      $enable_flags \
      '--fold-exprs[write folded expressions]' \
      '--inline-exports[write all exports inline]' \
      '--inline-imports[write all imports inline]' \
      '--no-debug-names[ignore debug names in the binary file]' \
      '--generate-names[generate names for function types and indices]' \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (wasm-objdump)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]'  \
      '(- *)'{-V,--version}'[show version]' \
      '(-d --disassemble)'{-d,--disassemble}'[disassemble function bodies]' \
      '(-x --details)'{-x,--details}'[show section details]' \
      '(-s --section)'{-s,--section}'[show section contents]:section name' \
      '(-r --reloc)'{-r,--reloc}'[show relocations]' \
      '--headers[show section headers]' \
      '--raw[show raw section contents]' \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (wasm-validate)
    _arguments -s -S \
      $common_flags \
      $enable_flags \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (wasm-strip)
    _arguments -s -S \
      $common_flags \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (wasm-decompile)
    _arguments -s -S \
      $common_flags \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (wasm2c)
    _arguments -s -S \
      $common_flags \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (wasm-interp)
    _arguments -s -S \
      $common_flags \
      $enable_flags \
      '--run-all-exports[run all the exported functions]' \
      '*:input file:_files -g "*.wasm"' && ret=0
    ;;
  (spectest-interp)
    _arguments -s -S \
      $common_flags \
      $enable_flags \
      '*:input file:_files' && ret=0
    ;;
  (*)
    _arguments -s -S \
      $common_flags \
      '*:input file:_files' && ret=0
    ;;
esac

return ret
