#
# Subcommands (sorted alphabetically by sort.Sort):
#   build       Build a test plan into a deployable artifact
#   collect     Collect assets (logs, metrics) from a test run
#   daemon      Start the testground daemon
#   describe    Describe a test plan's interface + test cases
#   healthcheck Verify health of the daemon + runners + builders
#   logs        Tail logs of a running test
#   plan        Manage test plans (create, list, import)
#   run         Run a test plan composition
#   sidecar     Per-instance traffic shaping daemon
#   status      Get status of test runs
#   tasks       List + manage daemon tasks (queue, running)
#   terminate   Terminate runners/builders
#   version     Print version
#
# Global flags:
#   -v          verbose output (DEBUG log level)
#   -vv         super verbose output
#   --endpoint  daemon endpoint URI
#
# Five-axis distinctness from every other documented Go logger:
#
#   1. TYPED-FIELD CTOR API — Every other documented Go logger
#      uses either map-based fields (logrus), variadic keyvalues
#      (slog), or chainable methods (zerolog).  zap uses TYPED
#      CTOR FUNCTIONS (zap.String/Int/Float/...) avoiding
#      reflection entirely.
#
#   2. DUAL-TIER API (Logger + SugaredLogger) — Every other
#      documented Go logger has ONE API.  zap provides TWO:
#      typed Logger (4-10x faster) and SugaredLogger (printf-
#      style ergonomics, still faster than alternatives).
#
#   3. ENCODER + CORE ARCHITECTURE — Every other documented
#      Go logger has monolithic output handling.  zap separates
#      encoder (JSON/Console/Custom) from core (write target +
#      level filter) for composable observability pipelines.
#
#   4. SYNC.POOL-BASED ZERO-ALLOC HOT-PATH — Every other
#      documented Go logger allocates per log call.  zap's
#      sync.Pool architecture achieves 0 allocations/op for
#      typed Logger at INFO level.
#
#   5. KUBERNETES-ECOSYSTEM DEFAULT-STATUS PROVENANCE — Every
#      other documented Go logger is general-purpose.  zap is
#      the default logger for Kubernetes ecosystem tooling
#      (kubebuilder, operator-sdk, controller-runtime,
#      cloud-native CNCF projects).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/testground/testground/blob/master/pkg/cmd/root.go
# RootCommands + RootFlags + per-subcommand cli.Flag definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tg_cmds
_tg_cmds=(
    'build:build a test plan into a deployable artifact'
    'collect:collect assets (logs, metrics) from a test run'
    'daemon:start the testground daemon'
    'describe:describe a test plan'\''s interface + test cases'
    'healthcheck:verify health of daemon + runners + builders'
    'logs:tail logs of a running test'
    'plan:manage test plans (create, list, import)'
    'run:run a test plan composition'
    'sidecar:per-instance traffic shaping daemon'
    'status:get status of test runs'
    'tasks:list and manage daemon tasks'
    'terminate:terminate runners or builders'
    'version:print version'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '-v[verbose output (DEBUG log level)]' \
    '-vv[super verbose output]' \
    '--endpoint=[daemon endpoint URI]:URI:' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'testground subcommand' _tg_cmds && ret=0
        ;;
    args)
        case $words[1] in
            run)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--ignore-artifacts[ignore build artifacts in composition]' \
                    '--collect[collect assets at end of run]' \
                    '--collect-file=[archive output path]:file:_files' \
                    '--run-ids=[specific run id(s) comma-separated]:ids:' \
                    '--metadata-repo=[repo that triggered this run]:repo:' \
                    '--metadata-branch=[branch that triggered this run]:branch:' \
                    '--metadata-commit=[commit that triggered this run]:commit:' \
                    '--instances=[number of test instances]:N:' \
                    '--runner=[runner to use]:runner:(local:exec local:docker cluster:k8s)' \
                    '--run-cfg=[override runner configuration]:cfg:' \
                    '--testcase=[test case to run]:case:' \
                    '*--test-param=[set test parameter]:param:' \
                    && ret=0
                ;;
            build)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-f --file)'{-f+,--file=}'[path to composition file]:file:_files' \
                    '--write-artifacts[write resulting artifacts to composition]' \
                    '--link-sdk[link to local SDK]' \
                    '--wait[wait for build task to complete]' \
                    '--builder=[builder to use]:builder:(docker:go exec:go)' \
                    '*--build-cfg=[set build config parameter]:cfg:' \
                    '*--dep=[set dependency mapping]:dep:' \
                    '(-p --plan)'{-p+,--plan=}'[plan to build]:plan:' \
                    && ret=0
                ;;
            describe)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--plan=[plan name to describe]:plan:' \
                    && ret=0
                ;;
            collect)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--runner=[runner that produced the run]:runner:(local:exec local:docker cluster:k8s)' \
                    '(-o --output)'{-o+,--output=}'[output archive file]:file:_files' \
                    && ret=0
                ;;
            terminate)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--runner=[runner to terminate]:runner:(local:exec local:docker cluster:k8s)' \
                    '--builder=[builder to terminate]:builder:(docker:go docker:generic exec:go)' \
                    && ret=0
                ;;
            healthcheck)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--runner=[runner to check]:runner:(local:exec local:docker cluster:k8s)' \
                    '--builder=[builder to check]:builder:(docker:go exec:go)' \
                    '--fix[apply automatic fixes]' \
                    && ret=0
                ;;
            logs)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--task=[task ID to tail logs for]:task-id:' \
                    '--follow[follow new log lines]' \
                    && ret=0
                ;;
            plan)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '*:plan subcommand:(create list import)' \
                    && ret=0
                ;;
            status|tasks)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
