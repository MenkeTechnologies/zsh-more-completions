#compdef scanadf

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --device-name)'{-d,--device-name}'+[device]:device:' \
  '(-L --list-devices)'{-L,--list-devices}'[list known devices]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-N --no-overwrite)'{-N,--no-overwrite}'[do not overwrite existing files]' \
  '(-o --output-file)'{-o,--output-file}'+[output filename pattern]:pattern:' \
  '(-s --start-count)'{-s,--start-count}'+[start counter value]:n:' \
  '(-e --end-count)'{-e,--end-count}'+[end counter value]:n:' \
  '(-r --raw)'{-r,--raw}'[print device-native data]' \
  '--scan-script=[script run after each scan]:cmd:_command_names' \
  '--script-wait[wait for script to exit before scanning next]' && ret=0

return ret
