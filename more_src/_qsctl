#compdef qsctl
# Documentation: https://qingstor.github.io/qsctl/
# qsctl - advanced command line tool for QingStor Object Storage

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config=}'[assign config file manually]:config:_files' \
  '(-z --zone)'{-z,--zone=}'[in which zone to do the operation]:zone' \
  '1:command:(cat cp ls mb mv presign rb rm stat sync tee)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      cp)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[recursively copy]' \
          '--expect-size=[expected total size of input stream]:size' \
          '--maximum-memory-content=[maximum content loaded in memory]:size' \
          '*:file:_files' && ret=0
        ;;
      sync)
        _arguments -s \
          '(-n --dry-run)'{-n,--dry-run}'[only show files that would be transferred]' \
          '--existing[skip creating new files on dest]' \
          '--ignore-existing[skip updating files that exist on dest]' \
          '(-r --recursive)'{-r,--recursive}'[recursively sync]' \
          '(-u --update)'{-u,--update}'[skip files newer on dest]' \
          '--part-threshold=[threshold to enable multipart]:size' \
          '--part-size=[part size for multipart]:size' \
          '--exclude-regx=[exclude files matching regex]:regex' \
          '--include-regx=[include files matching regex]:regex' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
