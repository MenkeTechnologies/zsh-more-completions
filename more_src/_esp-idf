#compdef esp-idf idf.py

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'all:build all'
  'app:build app'
  'app-flash:flash app'
  'bootloader:build bootloader'
  'bootloader-flash:flash bootloader'
  'build:build project'
  'clean:clean build'
  'flash:flash to device'
  'fullclean:fully clean'
  'menuconfig:open menuconfig'
  'monitor:open serial monitor'
  'partition_table:build partition table'
  'partition_table-flash:flash partition table'
  'reconfigure:reconfigure'
  'set-target:set target'
  'size:show size'
  'size-components:show component sizes'
  'size-files:show file sizes'
  'erase_flash:erase flash'
  'erase_otadata:erase otadata'
  'merge-bin:merge binary'
  'docs:open documentation'
  'create-project:create project'
  'create-component:create component'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-p --port)'{-p,--port}'+[serial port]:port:_files -g "/dev/tty*"' \
  '(-b --baud)'{-b,--baud}'+[baud rate]:rate:(115200 230400 460800 921600)' \
  '(-B --build-dir)'{-B,--build-dir}'+[build dir]:dir:_files -/' \
  '(-D --define-cache-entry)'{-D,--define-cache-entry}'+[cmake cache var]:var:' \
  '(-C --project-dir)'{-C,--project-dir}'+[project dir]:dir:_files -/' \
  '(-G --generator)'{-G,--generator}'+[cmake generator]:gen:(Ninja "Unix Makefiles")' \
  '(-T --ccache)'{-T,--ccache}'[use ccache]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--no-ccache[no ccache]' \
  '--cmake-warn-uninitialized[warn on uninit]' \
  '--no-hints[no hints]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'idf.py command' commands && ret=0 ;;
esac

return ret
