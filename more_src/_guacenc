#compdef guacenc
# Documentation: https://man.archlinux.org/search?q=guacenc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s+[output video dimensions]:WIDTHxHEIGHT:' \
  '-r+[bitrate (bits/sec)]:bitrate:' \
  '-f[force-encode in-progress recordings]' \
  '*:guac dump:_files -g "*.guac"' && ret=0

return ret
