#compdef guacenc
# Documentation: https://www.mankier.com/1/guacenc
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s+[output video dimensions]:WIDTHxHEIGHT:' \
  '-r+[bitrate (bits/sec)]:bitrate:' \
  '-f[force-encode in-progress recordings]' \
  '*:guac dump:_files -g "*.guac"' && ret=0

return ret
