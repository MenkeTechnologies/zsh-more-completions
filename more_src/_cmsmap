#compdef cmsmap
# Documentation: https://github.com/Dionach/CMSmap
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-f --force)'{-f,--force}'=[force CMS]:cms:(W J D M)' \
  '(-F --fullscan)'{-F,--fullscan}'[full scan with large plugin lists]' \
  '(-t --threads)'{-t,--threads}'=[number of threads]:n:' \
  '(-a --agent)'{-a,--agent}'=[custom user agent]:ua:' \
  '*'{-H,--header}'=[custom header]:header:' \
  '(-i --input)'{-i,--input}'=[input file with multiple targets]:file:_files' \
  '(-o --output)'{-o,--output}'=[save output to file]:file:_files' \
  '(-E --noedb)'{-E,--noedb}'[enumerate plugins without Exploit-DB search]' \
  '(-c --nocleanurls)'{-c,--nocleanurls}'[disable clean URLs (Drupal only)]' \
  '(-s --nosslcheck)'{-s,--nosslcheck}'[skip SSL certificate validation]' \
  '(-d --dictattack)'{-d,--dictattack}'[run low-intensity dictionary attack]' \
  '(-u --usr)'{-u,--usr}'=[username or username file]:user:' \
  '(-p --psw)'{-p,--psw}'=[password or password file]:password:' \
  '(-x --noxmlrpc)'{-x,--noxmlrpc}'[brute force WordPress without XML-RPC]' \
  '(-k --crack)'{-k,--crack}'=[password hashes file]:file:_files' \
  '(-w --wordlist)'{-w,--wordlist}'=[wordlist file]:file:_files' \
  '(-D --default)'{-D,--default}'[run with default options]' \
  '(-U --update)'{-U,--update}'=[update target]:target:(C P PC)' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:url: '
