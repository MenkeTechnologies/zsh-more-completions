#compdef cmsmap

_arguments -s \
  '(-f --force)'{-f,--force}'=[force CMS]:cms:(W J D M)' \
  '(-F --fullscan)'{-F,--fullscan}'[full scan]' \
  '(-t --threads)'{-t,--threads}'=[threads]:n:' \
  '(-a --agent)'{-a,--agent}'=[user agent]:ua:' \
  '*'{-H,--header}'=[custom header]:header:' \
  '(-i --input)'{-i,--input}'=[input file]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-E --noedb)'{-E,--noedb}'[no Exploit-DB]' \
  '(-c --nocleanurls)'{-c,--nocleanurls}'[no clean URLs]' \
  '(-s --nosslcheck)'{-s,--nosslcheck}'[no SSL check]' \
  '(-d --dictattack)'{-d,--dictattack}'[dictionary attack]' \
  '(-u --usr)'{-u,--usr}'=[username]:user:' \
  '(-p --psw)'{-p,--psw}'=[password]:password:' \
  '(-x --noxmlrpc)'{-x,--noxmlrpc}'[no XML-RPC]' \
  '(-k --crack)'{-k,--crack}'=[hash file]:file:_files' \
  '(-w --wordlist)'{-w,--wordlist}'=[wordlist]:file:_files' \
  '(-D --default)'{-D,--default}'[default credentials]' \
  '(-U --update)'{-U,--update}'=[update]:target:(C P PC)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:url: '
