#compdef Sherpa
# Documentation: https://sherpa-team.gitlab.io/sherpa/v3.0.1/manual/command-line-options.html
# Sherpa - multi-purpose Monte-Carlo event generator for the LHC

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print a help message]' \
  '(-v --version)'{-v,--version}'[print versioning information]' \
  '(-V --print-version-info)'{-V,--print-version-info}'[print extended version information at startup]' \
  '(-f --run-data)'{-f,--run-data}'=[read settings from input file (deprecated)]:file:_files' \
  '(-p --path)'{-p,--path}'=[read input file from path]:path:_files -/' \
  '(-L --sherpa-lib-path)'{-L,--sherpa-lib-path}'=[set Sherpa library path]:path:_files -/' \
  '(-e --events)'{-e,--events}'=[set number of events to generate]:N_events:' \
  '(-t --event-type)'{-t,--event-type}'=[set the event type]:event_type:' \
  '(-r --result-directory)'{-r,--result-directory}'=[set the result directory]:path:_files -/' \
  '(-R --random-seed)'{-R,--random-seed}'=[set the random number generator seed]:seed:' \
  '(-m --me-generators)'{-m,--me-generators}'=[set the matrix element generator list]:generators:' \
  '(-M --mi-handler)'{-M,--mi-handler}'=[set multiple interaction handler]:handler:' \
  '(-w --event-generation-mode)'{-w,--event-generation-mode}'=[set the event generation mode]:mode:' \
  '(-s --shower-generator)'{-s,--shower-generator}'=[set the parton shower generator]:generator:' \
  '(-F --fragmentation)'{-F,--fragmentation}'=[set the fragmentation module]:module:' \
  '(-D --decay)'{-D,--decay}'=[set the hadron decay module]:module:' \
  '(-a --analysis)'{-a,--analysis}'=[set the analysis handler list]:analyses:' \
  '(-A --analysis-output)'{-A,--analysis-output}'=[set the analysis output path]:path:_files -/' \
  '(-O --output)'{-O,--output}'=[set general output level]:level:' \
  '(-o --event-output)'{-o,--event-output}'=[set output level during event generation]:level:' \
  '(-l --log-file)'{-l,--log-file}'=[set log file name]:logfile:_files' \
  '(-g --disable-result-directory-generation)'{-g,--disable-result-directory-generation}'[do not create result directory]' \
  '(-b --disable-batch-mode)'{-b,--disable-batch-mode}'[switch to non-batch mode]' \
  '(-I --enable-init-only)'{-I,--enable-init-only}'[only initialize the run]' \
  '*:run card:_files' && ret=0

return ret
