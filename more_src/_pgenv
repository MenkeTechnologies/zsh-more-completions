#compdef pgenv
# _pgenv — build/install/switch multiple PostgreSQL versions (theory/pgenv)
# upstream: https://github.com/theory/pgenv
# Subcommands from bin/pgenv (bash case statement).

_pgenv() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'use:switch to and start a built version'
                'switch:switch without starting'
                'start:start the current cluster'
                'stop:stop the current cluster'
                'restart:restart the current cluster'
                'status:show cluster status'
                'build:build a PostgreSQL version from source'
                'rebuild:rebuild an existing version'
                'remove:remove a built version'
                'versions:list locally built versions'
                'version:show the currently linked version'
                'current:alias for version'
                'available:list versions available for download'
                'check:check dependencies and PATH'
                'clear:unlink the current version'
                'config:show/edit/migrate/write/delete config'
                'configuration:alias for config'
                'log:tail the server log'
                'help:show help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                use|switch|build|rebuild|remove)
                    _arguments ':PostgreSQL version (e.g. 16.2):'
                    ;;
                config|configuration)
                    _arguments '1:subcommand:(show edit init write delete migrate path default)'
                    ;;
            esac
            ;;
    esac
}

_pgenv "$@"
