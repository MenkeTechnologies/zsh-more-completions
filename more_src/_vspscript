#compdef vspscript
# Documentation: https://github.com/OpenVSP/OpenVSP/blob/main/src/vsp/common.cpp
# vspscript - OpenVSP AngelScript batch runner (headless OpenVSP)

local ret=1

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-h[show help]' \
  '-script[run a vspscript file]:vspscript file:_files -g "*.vspscript"' \
  '-des[set variables according to a *.des file]:des file:_files -g "*.des"' \
  '-xddm[set variables according to a *.xddm file]:xddm file:_files -g "*.xddm"' \
  '-exp[enable experimental mode]' \
  '*:vsp3 file:_files -g "*.vsp3"' && ret=0

return ret
