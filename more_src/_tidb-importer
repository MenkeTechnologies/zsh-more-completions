#compdef tidb-importer
# _tidb-importer — TiDB synthetic data importer (CREATE TABLE + fill)
# upstream: https://github.com/pingcap/tidb
# Flags from cmd/importer/config.go on tip.

_tidb-importer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-config=[importer config file]:file:_files' \
        '-t=[CREATE TABLE SQL statement]:sql:' \
        '-i=[CREATE INDEX SQL statement]:sql:' \
        '-s=[load stats JSON file]:file:_files' \
        '-c=[parallel worker count]:n:' \
        '-n=[total job count]:n:' \
        '-b=[insert batch commit count]:n:' \
        '-h=[database host IP]:host:' \
        '-u=[database user]:user:' \
        '-p=[database password]:pw:' \
        '-D=[database name]:name:' \
        '-P=[database port]:port:' \
        '-L=[log level]:level:(debug info warn error fatal)'
}

_tidb-importer "$@"
