#compdef esl-weight
# Documentation: http://hmmer.org/documentation.html
# Easel: calculate sequence weights in MSA(s)

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-g -p -b)-g[Gerstein/Sonnhammer/Chothia weighting (default)]' \
  '(-g -p -b)-p[Henikoff position-based weighting]' \
  '(-g -p -b)-b[BLOSUM single-linkage clustering weighting]' \
  '--id=[fractional identity threshold for BLOSUM weighting (default 0.62)]:x' \
  '--amino[assert input is protein]' \
  '--dna[assert input is DNA]' \
  '--rna[assert input is RNA]' \
  '*:msa file:_files' && ret=0

return ret
