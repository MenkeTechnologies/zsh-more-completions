#compdef create-effect-app
# Documentation: https://www.npmjs.com/package/create-effect-app
# Reference accessed: 2026-05-23
# Verified: npx create-effect-app --help.

# Zsh completion for create-effect-app - Effect application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-t --template)'{-t,--template=}'[template name]:template:(basic cli monorepo)' \
  '(-e --example)'{-e,--example=}'[official example]:example:(http-server)' \
  '--changesets[initialize with Changesets]' \
  '--flake[initialize with a Nix flake]' \
  '--eslint[initialize with ESLint]' \
  '--workflows[initialize with GitHub Actions workflows]' \
  ':project directory:_directories' && ret=0

return ret
