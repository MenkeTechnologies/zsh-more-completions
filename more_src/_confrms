#compdef confrms gmx-confrms
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-confrms.html
# gmx confrms: fit two structures and calculate the RMSD

local ret=1

_arguments -s \
  '-f1[structure file with mass database]:file:_files' \
  '-f2[second structure file]:file:_files' \
  '-n1[index file for first structure]:file:_files' \
  '-n2[index file for second structure]:file:_files' \
  '-o[output structure file]:file:_files' \
  '-no[output index file for matching atoms]:file:_files' \
  '-w[view output files]' \
  '-one[write only fitted structure]' \
  '-mw[mass-weighted fitting and RMSD calculation]' \
  '-pbc[attempt to restore molecular continuity]' \
  '-fit[perform least squares superposition]' \
  '-name[compare only matching atom names]' \
  '-label[add chain labels A and B to structures]' \
  '-bfac[write B-factors from atomic MSD values]' && ret=0

return ret
