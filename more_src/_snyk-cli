#compdef snyk
# _snyk-cli — Snyk security CLI (Snyk Ltd, Node.js); SCA + container + IaC + code scanning for projects
# upstream: https://github.com/snyk/cli

_snyk-cli() {
    local -a sub=(
        'auth:authenticate to Snyk'
        'test:scan for issues'
        'monitor:upload snapshot and monitor'
        'container:scan container images'
        'iac:scan infrastructure-as-code'
        'code:run Snyk Code SAST'
        'log4shell:test for log4shell'
        'sbom:generate SBOM'
        'fix:auto-fix vulnerabilities'
        'apps:manage Snyk apps'
        'config:manage Snyk config'
        'ignore:ignore specific issue'
        'policy:manage .snyk policy'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--all-projects[scan all detected projects]' \
        '--detection-depth+[detection depth]:n:' \
        '--exclude+[exclude paths]:str:' \
        '--prune-repeated-subdependencies[prune repeated]' \
        '--strict-out-of-sync+[strict out of sync]:bool:(true false)' \
        '--unmanaged[scan unmanaged deps]' \
        '--ignore-policy[ignore .snyk policy]' \
        '--trust-policies[trust .snyk policy]' \
        '--severity-threshold+[severity]:level:(low medium high critical)' \
        '--fail-on+[fail-on issues]:filter:(all upgradable patchable)' \
        '--json[json output]' \
        '--json-file-output+[json file]:file:_files' \
        '--sarif[SARIF output]' \
        '--sarif-file-output+[sarif file]:file:_files' \
        '--show-vulnerable-paths+[show vulnerable paths]:mode:(none some all)' \
        '--project-name+[project name]:str:' \
        '--target-reference+[target reference]:str:' \
        '--policy-path+[policy file]:file:_files' \
        '--print-deps[print deps]' \
        '--remote-repo-url+[remote repo URL]:url:_urls' \
        '--insecure[skip TLS verify]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snyk subcommand' sub ;;
        args)
            case $words[1] in
                container) _arguments \
                    '--file+[Dockerfile path]:file:_files' \
                    '--platform+[platform]:platform:' \
                    '--exclude-app-vulns[exclude app vulns]' \
                    '*:image:' ;;
                iac) _arguments \
                    '--severity-threshold+[severity]:level:(low medium high critical)' \
                    '--rules+[custom rules path]:path:_files' \
                    '--report[upload to Snyk]' \
                    '--target-reference+[target ref]:str:' \
                    '*:path:_files' ;;
                code) _arguments \
                    '--severity-threshold+[severity]:level:(low medium high critical)' \
                    '*:path:_files' ;;
                test|monitor) _arguments '*:path:_files' ;;
            esac
            ;;
    esac
}

_snyk-cli "$@"
