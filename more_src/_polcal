#compdef polcal
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss2.html
# POLPACK: converts analysed intensity images into a cube holding Stokes vectors.

local ret=1

_arguments -s -S \
  'IN=[input intensity images or cubes]:ndf:_files' \
  'OUT=[output Stokes cube]:ndf:_files' \
  'TITLE=[title for output NDF]:title:' \
  'PMODE=[polarimetry mode]:mode:(CIRCULAR LINEAR)' \
  'DUALBEAM=[process as dual-beam]:flag:(TRUE FALSE)' \
  'DEZERO=[correct zero-point differences]:flag:(TRUE FALSE)' \
  'ETOL=[E-factor convergence tolerance]:tol:' \
  'ILEVEL=[verbosity of screen output]:level:(0 1 2 3)' \
  'MAXIT=[maximum iterations]:n:' \
  'MINFRAC=[min fraction of good data per pixel]:frac:' \
  'NSIGMA=[rejection threshold in std devs]:n:' \
  'SETVAR=[store variance in input components]:flag:(TRUE FALSE)' \
  'SKYSUP=[sky noise suppression factor]:val:' \
  'SMBOX=[smoothing box size in pixels]:n:' \
  'TOLR=[convergence criterion]:tol:' \
  'TOLS=[scale-factor accuracy tolerance]:tol:' \
  'TOLZ=[zero-point accuracy tolerance]:tol:' \
  'TRIMBAD=[remove bad pixel margins]:flag:(TRUE FALSE)' \
  'VARIANCE=[include variances in output]:flag:(TRUE FALSE)' \
  'WEIGHTS=[weighting scheme]:scheme:(1 2 3 4)' \
  '*:ndf:_files' && ret=0

return ret
