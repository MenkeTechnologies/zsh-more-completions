#compdef lzmainfo
# Documentation: https://man.archlinux.org/search?q=lzmainfo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[show help]'
    '--help[show help]'
    '-V[show version]'
    '--version[show version]'
    '*:lzma file:_files -g "*.lzma"'
)

_arguments -s -S $arguments
