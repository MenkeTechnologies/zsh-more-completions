#compdef green
# Documentation: https://github.com/CleanCut/green
# green - a clean, colorful Python test runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version of Green and Python and exit]' \
  '(-s --processes)'{-s,--processes}'[number of processes to use to run tests]:num:' \
  '(-i --initializer)'{-i,--initializer}'[function to run in a worker before running tests]:func:' \
  '(-z --finalizer)'{-z,--finalizer}'[function to run at end of worker lifetime]:func:' \
  '(-X --maxtasksperchild)'{-X,--maxtasksperchild}'[maxtasksperchild for internal pool]:num:' \
  '(-t --termcolor)'{-t,--termcolor}'[force terminal colors on]' \
  '(-T --notermcolor)'{-T,--notermcolor}'[force terminal colors off]' \
  '(-W --disable-windows)'{-W,--disable-windows}'[disable Windows support by turning off Colorama]' \
  '(-a --allow-stdout)'{-a,--allow-stdout}'[let stdout and stderr come through]' \
  '(-q --quiet-stdout)'{-q,--quiet-stdout}'[discard stdout and stderr for successful tests]' \
  '(-k --no-skip-report)'{-k,--no-skip-report}'[do not print the report of skipped tests]' \
  '(-e --no-tracebacks)'{-e,--no-tracebacks}'[do not print tracebacks for failures and errors]' \
  '(-l --logging)'{-l,--logging}'[enable internal debugging output]' \
  '(-d --debug)'{-d,--debug}'[enable internal debugging statements]' \
  '(-v --verbose)'{-v,--verbose}'[verbose; may be specified up to three times]' \
  '(-U --disable-unidecode)'{-U,--disable-unidecode}'[disable unidecode unicode-to-ascii conversion]' \
  '(-f --failfast)'{-f,--failfast}'[stop execution at first test that fails or errors]' \
  '(-c --config)'{-c,--config}'[use this config file to override values]:file:_files' \
  '(-p --file-pattern)'{-p,--file-pattern}'[pattern to match test files]:pattern:' \
  '(-n --test-pattern)'{-n,--test-pattern}'[pattern to match test method names]:pattern:' \
  '(-j --junit-report)'{-j,--junit-report}'[generate a JUnit XML report]:filename:_files' \
  '(-r --run-coverage)'{-r,--run-coverage}'[produce coverage output]' \
  '(-g --cov-config-file)'{-g,--cov-config-file}'[specify a coverage config file]:file:_files' \
  '(-R --quiet-coverage)'{-R,--quiet-coverage}'[do not print coverage report to stdout]' \
  '(-O --clear-omit)'{-O,--clear-omit}'[clear the default coverage omit patterns]' \
  '(-u --include-patterns)'{-u,--include-patterns}'[comma-separated file-patterns to include in coverage]:patterns:' \
  '(-o --omit-patterns)'{-o,--omit-patterns}'[comma-separated file-patterns to omit from coverage]:patterns:' \
  '(-m --minimum-coverage)'{-m,--minimum-coverage}'[minimum coverage value]:value:' \
  '--completion-file[location of the bash and zsh completion file]' \
  '--completions[output possible completions of the given target]' \
  '--options[output all options]' \
  '*:target:' && ret=0

return ret
