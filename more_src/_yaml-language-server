#compdef yaml-language-server
# Documentation: https://github.com/redhat-developer/yaml-language-server
# Reference accessed: 2026-05-21
# Verified: upstream README documents only --stdio for transport.

# Zsh completion for yaml-language-server (LSP server for YAML)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--stdio[use stdio transport]' && ret=0

return ret
