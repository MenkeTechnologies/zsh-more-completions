#compdef yaml-language-server

# Zsh completion for yaml-language-server (LSP server for YAML)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--stdio[Use stdio transport]' \
  '--socket=[Use socket transport on specified port]:port' \
  '--node-ipc[Use node-ipc transport]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-v --version)'{-v,--version}'[Print version]' && ret=0

return ret
