#compdef impacket-keylistattack

# Impacket keylistattack.py: RC4 KeyList request to KDC w/o auth
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-t[target user(s) comma list]:users:' \
  '-tf[target file with usernames]:file:_files' \
  '-rodcNo[rodc krbtgt number]:n:' \
  '-rodcKey[rodc krbtgt key]:key:' \
  '-target-domain[target domain]:domain:' \
  '-dc-ip[DC IP]:ip:' \
  '-full[get full credentials]' \
  '-enumerate[list all RODC accounts]' \
  '*:domain/user[:password]:' && ret=0
return ret
