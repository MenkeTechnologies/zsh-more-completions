#compdef ideviceinstaller
# _ideviceinstaller — install / uninstall iOS apps from .ipa packages (libimobiledevice/ideviceinstaller)
# upstream: https://github.com/libimobiledevice/ideviceinstaller
# Subcommands + flags from src/ideviceinstaller.c.

_ideviceinstaller() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-u --udid)'{-u+,--udid=}'[target the specific device by UDID]:udid:' \
        '(-n --network)'{-n,--network}'[connect to a network-attached device]' \
        '(-w --notify-wait)'{-w,--notify-wait}'[wait for app installed / uninstalled notification]' \
        '(-d --debug)'{-d,--debug}'[enable communication debugging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_ideviceinstaller_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                list)
                    _arguments \
                        '--user[list user apps only (default)]' \
                        '--system[list system apps only]' \
                        '--all[list both user and system apps]' \
                        '--xml[print output as XML property list]' \
                        '(-a --attribute)'{-a+,--attribute=}'[specific attribute to return (see man page)]:attr:' \
                        '(-b --bundle-identifier)'{-b+,--bundle-identifier=}'[only query this bundle id]:bundle:' && ret=0 ;;
                install|upgrade)
                    _arguments \
                        '(-s --sinf)'{-s+,--sinf=}'[pass an external SINF file]:file:_files' \
                        '(-m --metadata)'{-m+,--metadata=}'[pass an external iTunesMetadata.plist]:file:_files -g "*.plist"' \
                        '1:.ipa package:_files -g "*.ipa"' && ret=0 ;;
                uninstall|restore|remove-archive)
                    _arguments '1:bundle identifier:' && ret=0 ;;
                archive)
                    _arguments \
                        '--uninstall[uninstall the package after archiving]' \
                        '--app-only[archive application data only]' \
                        '--docs-only[archive documents (user data) only]' \
                        '--copy=[copy the resulting archive to this directory]:dir:_files -/' \
                        '--remove[remove archive from device after --copy]' \
                        '--xml[print output as XML property list]' \
                        '1:bundle identifier:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ideviceinstaller_commands] )) ||
_ideviceinstaller_commands() {
    local -a commands
    commands=(
        'list:list installed apps'
        'install:install an app from a .ipa package'
        'uninstall:uninstall an app by bundle id'
        'upgrade:upgrade an app from a .ipa package'
        'archive:archive an installed app (with optional uninstall / copy)'
        'restore:restore an archived app by bundle id'
        'remove-archive:remove an archive of an app from the device'
    )
    _describe -t commands 'ideviceinstaller command' commands
}

_ideviceinstaller "$@"
