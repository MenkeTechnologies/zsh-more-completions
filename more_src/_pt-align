#compdef pt-align
# Documentation: https://docs.percona.com/percona-toolkit/pt-align.html
# Align output from other tools into columns

local ret=1

_arguments -s -S \
  '(--help)--help[show help and exit]' \
  '(--version)--version[show version and exit]' \
  '--buffer-stdout[enable STDOUT buffering]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '*:file:_files' && ret=0

return ret
