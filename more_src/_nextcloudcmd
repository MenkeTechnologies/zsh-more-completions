#compdef nextcloudcmd

# Zsh completion for nextcloudcmd - Nextcloud command-line sync client

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-s[request silent operation]' \
  '--silent[request silent operation]' \
  '-h[sync hidden files]' \
  '--hidden[sync hidden files]' \
  '--httpproxy[specify HTTP proxy]:url:' \
  '--trust[trust any SSL certificate]' \
  '--exclude[path to an exclude list]:file:_files' \
  '--unsyncedfolders[file containing list of un-synced folders]:file:_files' \
  '--davpath[custom DAV path]:path:' \
  '--max-sync-retries[number of retries]:n:' \
  '--uplimit[limit the upload speed (KB/s)]:kbs:' \
  '--downlimit[limit the download speed (KB/s)]:kbs:' \
  '--logdebug[enable debug logging]' \
  '--logfile[log file]:file:_files' \
  '--logexpire[log file expiration (hours)]:hours:' \
  '--logdir[log directory]:directory:_files -/' \
  '-u[user to authenticate as]:user:' \
  '--user[user to authenticate as]:user:' \
  '-p[password to use for authentication]:password:' \
  '--password[password to use for authentication]:password:' \
  '--non-interactive[do not prompt for anything]' \
  '1:source directory:_files -/' \
  '2:server url:'
