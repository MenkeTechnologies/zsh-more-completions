#compdef histat
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss75.html
# KAPPA HISTAT - order statistics of an NDF's pixels using a histogram

local ret=1

_arguments -C \
  'NDF=[NDF data structure to analyse]:NDF file:_files' \
  'COMP=[array component (Data/Error/Quality/Variance)]:component:(Data Error Quality Variance)' \
  'METHOD=[mode calculation method]:method:(Histogram Moments Pearson)' \
  'NUMBIN=[number of histogram bins (10-10000)]:bins:' \
  'PERCENTILES=[percentile values 0.0-100.0]:percentiles:' \
  'LOGFILE=[text file for results]:log file:_files' \
  '*:NDF file:_files' && ret=0

return ret
