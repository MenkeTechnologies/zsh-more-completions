    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_abcrypt_commands" \
"*::: :->abcrypt" \
&& ret=0
    case $state in
    (abcrypt)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:abcrypt-command-$line[1]:"
        case $line[1] in
            (encrypt)
_arguments "${_arguments_options[@]}" : \
'-o+[Output the result to a file]:FILE:_files' \
'--output=[Output the result to a file]:FILE:_files' \
'--argon2-type=[Set the Argon2 type]:TYPE:((argon2d\:"Argon2d"
argon2i\:"Argon2i"
argon2id\:"Argon2id"))' \
'--argon2-version=[Set the Argon2 version]:VERSION:((0x10\:"Version 0x10"
0x13\:"Version 0x13"))' \
'-m+[Set the memory size in bytes]:BYTE:_default' \
'--memory-cost=[Set the memory size in bytes]:BYTE:_default' \
'-t+[Set the number of iterations]:NUM:_default' \
'--time-cost=[Set the number of iterations]:NUM:_default' \
'-p+[Set the degree of parallelism]:NUM:_default' \
'--parallelism=[Set the degree of parallelism]:NUM:_default' \
'--passphrase-from-env=[Read the passphrase from the environment variable]:VAR:_default' \
'--passphrase-from-file=[Read the passphrase from the file]:FILE:_files' \
'--passphrase-from-tty[Read the passphrase from /dev/tty]' \
'--passphrase-from-stdin[Read the passphrase from standard input]' \
'--passphrase-from-tty-once[Read the passphrase from /dev/tty only once]' \
'-v[Print the encryption parameters]' \
'--verbose[Print the encryption parameters]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input file:_files' \
&& ret=0
;;
(decrypt)
_arguments "${_arguments_options[@]}" : \
'-o+[Output the result to a file]:FILE:_files' \
'--output=[Output the result to a file]:FILE:_files' \
'--passphrase-from-env=[Read the passphrase from the environment variable]:VAR:_default' \
'--passphrase-from-file=[Read the passphrase from the file]:FILE:_files' \
'--passphrase-from-tty[Read the passphrase from /dev/tty]' \
'--passphrase-from-stdin[Read the passphrase from standard input]' \
'-v[Print the encryption parameters]' \
'--verbose[Print the encryption parameters]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input file:_files' \
&& ret=0
;;
(argon2)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input file:_files' \
&& ret=0
;;
(information)
_arguments "${_arguments_options[@]}" : \
'-j[Output the encryption parameters as JSON]' \
'--json[Output the encryption parameters as JSON]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input file:_files' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Shell to generate completion for:((bash\:"Bash"
elvish\:"Elvish"
fish\:"fish"
nushell\:"Nushell"
powershell\:"PowerShell"
zsh\:"Zsh"))' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_abcrypt__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:abcrypt-help-command-$line[1]:"
        case $line[1] in
            (encrypt)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(decrypt)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(argon2)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(information)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

