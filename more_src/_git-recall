#compdef git-recall
# Documentation: source-direct extraction from upstream
# Fakerr/git-recall - this is a single bash script (NOT a binary;
# decoded from the `#!/usr/bin/env bash` shebang). Option set
# extracted from the `usage()` heredoc in the script body.
# Reference accessed: 2026-05-30 via gh api.
# Fakerr git-recall R136b — interactively browse the most recent
# commits as a git subcommand (invoked via `git recall`). Pairs a
# git log with a stdin-driven keypress UI so each commit can be
# diffed/checked-out/cherry-picked without re-running git log.

_arguments -s -S \
  '(-d --date)'{-d+,--date=}'[show logs from the last N days (default 1)]:days:' \
  '(-a --author)'{-a+,--author=}'[author name filter (use "all" for all users)]:author:' \
  '(-b --branch)'{-b+,--branch=}'[branch to display commits from]:branch:' \
  '(-p --path)'{-p+,--path=}'[path or filename to display commits from]:path:_files' \
  '(-f --fetch)'{-f,--fetch}'[fetch commits from upstream before browsing]' \
  '(-h --help)'{-h,--help}'[show usage and exit]' \
  '(-v --version)'{-v,--version}'[show version and exit]'
