#compdef halfempty
# Documentation: https://github.com/googleprojectzero/halfempty
# Google fast parallel test case minimization tool

local ret=1

_arguments -s -S \
  '--num-threads=[number of worker threads (default all cores)]:threads' \
  '--stable[repeat all strategies until output stops changing]' \
  '--timeout=[send SIGALRM to children after N seconds]:seconds' \
  '*--limit=[fine tune a child resource limit, RLIMIT_???=N]:limit' \
  '--inherit-stdout[do not discard child stdout]' \
  '--inherit-stderr[do not discard child stderr]' \
  '--zero-char=[byte used to overwrite data when simplifying]:byte' \
  '--monitor[generate progress graphs (needs graphviz)]' \
  '--no-terminate[do not kill long running children]' \
  '--output=[output filename (default halfempty.out)]:output:_files' \
  '--noverify[skip initial verification of the input]' \
  '--generate-dot[generate a dot file of the final tree state]' \
  '--gen-intermediate[save best result as it is found]' \
  '--bisect-skip-multiplier=[thoroughness of byte removal via bisection]:N' \
  '--zero-skip-multiplier=[thoroughness of zero/null byte simplification]:N' \
  '--help-all[show full documentation]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:test script:_files' \
  '2:input file:_files' && ret=0

return ret
