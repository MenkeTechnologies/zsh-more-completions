#compdef ANTSJacobian
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ANTSJacobian.cxx — compute Jacobian/log-Jacobian of a warp (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDim:(2 3)' \
    '2:gWarp (deformation field):_files -g "*.{nii,nii.gz}"' \
    '3:outfile:_files' \
    '4::uselog (default 0):(0 1)' \
    '5::mask filename:_files -g "*.{nii,nii.gz}"' \
    '6::normbytotalbool (default 0):(0 1)' \
    '7::projection vector:_default' \
    && ret=0

return ret
