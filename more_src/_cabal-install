#compdef cabal-install
# _cabal-install — alternate compdef for the cabal Haskell package tool (haskell/cabal)
# upstream: https://github.com/haskell/cabal

_cabal-install() {
    if (( CURRENT == 2 )); then
        local -a cmds
        cmds=(
            'build:compile targets in the current project'
            'check:check the package for common mistakes'
            'clean:clean the build artifacts'
            'configure:add extra project configuration'
            'fetch:download packages for later installation'
            'freeze:freeze the project dependencies'
            'gen-bounds:print bounds suggestions for the package dependencies'
            'haddock:generate Haddock documentation'
            'help:show help'
            'info:display information about installed packages'
            'init:create a new .cabal package'
            'install:install packages'
            'list:list packages matching a search string'
            'list-bin:print the path to a built executable'
            'new-build:alias of build (legacy)'
            'outdated:check for outdated dependencies'
            'path:show cabal-install paths'
            'repl:open a REPL for the current project'
            'report:upload build reports to Hackage'
            'run:run one of the executable targets'
            'sandbox:legacy sandbox commands'
            'sdist:create source-distribution tarballs'
            'test:run package test suites'
            'unpack:extract a package source tarball (alias of get)'
            'update:update the local Hackage package list'
            'upload:upload a package to Hackage'
            'user-config:manage cabal-install configuration'
            'v1-build:legacy v1 build'
            'v2-build:alias of build'
            'version:print cabal-install version'
            'bench:run package benchmarks'
            'get:alias of unpack'
        )
        _describe -t commands 'cabal-install command' cmds
        return
    fi

    case $words[2] in
        build|run|test|bench|repl|haddock|sdist|clean|configure)
            _files ;;
        install|fetch|list|info|get|unpack|outdated)
            _arguments '*:package:' ;;
        init)
            _files -/ ;;
        *) ;;
    esac
}

_cabal-install "$@"
