#compdef cbcollect_info
# Documentation: https://docs.couchbase.com/server/current/cli/cbcollect-info-tool.html
# Couchbase diagnostics collector — gathers logs and stats into a zip file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-r+[root Couchbase installation directory]:dir:_files -/' \
  '-v[increase verbosity level]' \
  '-p[gather only product-related information]' \
  '-d[dump the list of commands cbcollect_info runs]' \
  '--bypass-sensitive-data[do not collect sensitive data]' \
  '--task-regexp=[run only tasks matching this regexp]:regexp:' \
  '--tmp-dir=[temporary working directory]:dir:_files -/' \
  '--initargs=[path to the server initargs file]:file:_files' \
  '--log-redaction-level=[log redaction level]:level:(none partial)' \
  '--log-redaction-salt=[salt used for log redaction hashing]:salt:' \
  '--upload-host=[host to upload the collected zip to]:host:_hosts' \
  '--customer=[customer name for the upload]:customer:' \
  '--upload-proxy=[proxy to use for the upload]:proxy:' \
  '--ticket=[support ticket number for the upload]:ticket:' \
  '1:output file:_files -g "*.zip"' && ret=0

return ret
