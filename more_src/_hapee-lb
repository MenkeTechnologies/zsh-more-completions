#compdef hapee-lb
# Documentation: https://www.haproxy.com/documentation/hapee/latest/onepage/management/
# HAProxy Enterprise load balancer (hapee-lb shares the HAProxy CLI options)

local ret=1

_arguments -s \
  '*-f[load configuration file or directory]:cfg:_files' \
  '-C[change to directory before loading configuration]:dir:_files -/' \
  '-D[start as a daemon]' \
  '-p[write process PIDs to file]:file:_files' \
  '-c[check configuration validity and exit]' \
  '-cc[evaluate a conditional block and exit]' \
  '-q[quiet mode, suppress output messages]' \
  '-v[report version and build date]' \
  '-vv[display version, build options and pollers]' \
  '-V[enable verbose mode]' \
  '-W[master-worker mode]' \
  '-Ws[master-worker mode with systemd notify support]' \
  '-db[disable background mode, remain in foreground]' \
  '*-sf[send graceful finish to listed old processes]:pids:' \
  '*-st[send immediate termination to listed old processes]:pids:' \
  '-S[bind master CLI to socket]:bind:' \
  '-x[retrieve listening sockets from old process]:socket:_files' \
  '-N[set default per-proxy maxconn]:limit:' \
  '-n[limit per-process connections]:limit:' \
  '-m[limit allocatable memory in megabytes]:mb:' \
  '-L[change local peer name]:name:' \
  '-d[enable debug mode, stay in foreground]' \
  '-dC[dump configuration after tokenization]' \
  '-dD[enable diagnostic mode]' \
  '-dK[dump registered keywords by class]:class:' \
  '-dL[dump loaded dynamic shared libraries]' \
  '-dM[force memory poisoning]' \
  '-dG[disable getaddrinfo for name resolution]' \
  '-dI[enable insecure fork]' \
  '-dR[disable SO_REUSEPORT]' \
  '-dS[disable splice() syscall]' \
  '-dV[disable SSL verification on server side]' \
  '-dW[refuse startup if configuration warnings detected]' \
  '-dr[ignore server address resolution failures]' \
  '-dc[enable CPU affinity debugging]' \
  '-de[disable epoll poller]' \
  '-dk[disable kqueue poller]' \
  '-dp[disable poll poller]' \
  '-4[force DNS resolvers to IPv4 only]' && ret=0

return ret
