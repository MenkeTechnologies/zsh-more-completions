#compdef sufwmix
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/operations/sufwmix.c
# FX domain multidimensional weighted mix

local ret=1

_arguments -s -S \
  'key=[header words defining mixing dimension]:key' \
  'dx=[distance units for each header word]:dx' \
  'keyg=[header word indicating the start of gather]:keyg' \
  'vf=[=1 do a frequency dependent mix]:vf:(0 1)' \
  'vmin=[velocity of the reflection slope not attenuated]:vmin' \
  '*:file:_files' && ret=0

return ret
