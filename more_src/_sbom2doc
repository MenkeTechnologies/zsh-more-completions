#compdef sbom2doc
# Documentation: https://pypi.org/project/sbom2doc/
# generate documentation from an SBOM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input-file)'{-i,--input-file}'=[SBOM file to process]:file:_files' \
  '--debug[include debug information]' \
  '--include-license[include license text in output]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(console excel html json markdown pdf)' \
  '(-o --output-file)'{-o,--output-file}'=[output destination]:file:_files' \
  '(-V --version)'{-V,--version}'[display version]' && ret=0

return ret
