#compdef cargo-features-manager
# Documentation: https://man.archlinux.org/search?q=cargo-features-manager
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'prune:prune unused features'
)

_arguments -C \
  '(-d --dependency)'{-d,--dependency}'=[dependency]:name:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'features-manager subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (prune)
        _arguments -s \
          '--dry-run[dry run]' \
          '(-d --only-dependency)'{-d,--only-dependency}'[only deps]' \
          '--skip-tests[skip tests]' \
          '(-t --no-tmp)'{-t,--no-tmp}'[no temp dir]' \
          '--clean=[freq]:freq:' && ret=0 ;;
    esac
    ;;
esac

return ret
