#compdef fit-wcs
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/fit-wcs.1 — fit a transformation from x,y and matching RA,Dec (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-x+[XYls input file]:file:_files -g "*.{fits,fit,fts}"' \
    '-X+[X column name (default FIELD_X)]:col:_default' \
    '-Y+[Y column name (default FIELD_Y)]:col:_default' \
    '-r+[RDls input file]:file:_files -g "*.{fits,fit,fts}"' \
    '-R+[RA column name (default INDEX_RA)]:col:_default' \
    '-D+[Dec column name (default INDEX_DEC)]:col:_default' \
    '-c+[correspondences file]:file:_files' \
    '-o+[WCS output file]:file:_files' \
    '-s+[SIP order (default: WCS-TAN, no SIP)]:n:_default' \
    '-W+[image width (default: max X)]:n:_default' \
    '-H+[image height (default: max Y)]:n:_default' \
    '-C[set CRPIX to field center (SIP only)]' \
    '-v[verbose]' \
    && ret=0

return ret
