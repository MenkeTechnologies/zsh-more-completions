#compdef trackma trackma-curses
# Documentation: https://man.archlinux.org/search?q=trackma
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list all shows in your local list'
  'ls:list all shows in your local list'
  'filter:change status filter'
  'sort:change sort order'
  'mediatype:reload with a different media type'
  'info:show detailed info about a show'
  'search:regex search shows (incl. synonyms)'
  'add:search remote service and add a show'
  'delete:remove a show from the local list'
  'del:remove a show from the local list'
  'update:set episode progress'
  'play:start media player on next episode'
  'openfolder:open the folder containing a show'
  'score:change a show score'
  'status:change a show status'
  'altname:set alternative name for tracker'
  'send:send queued changes to remote service'
  'retrieve:download remote list, overwriting local'
  'clearqueue:discard all queued changes'
  'viewqueue:list queued changes'
  'tracker:show tracker status'
  'rescan:re-scan the local library'
  'random:play a random new episode'
  'account:switch to a different account'
  'about:show program information'
  'help:display help'
  'quit:exit trackma'
  'exit:exit trackma'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --account)'{-a+,--account=}'[account number to use]:n:' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-c --config)'{-c+,--config=}'[config directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'trackma command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sort)
        _arguments '*::field:(id title my_progress total my_score)' && ret=0 ;;
      (status)
        _arguments '*::status:(watching completed on-hold dropped plan-to-watch reading reading-paused dropped-reading plan-to-read)' && ret=0 ;;
    esac ;;
esac

return ret
