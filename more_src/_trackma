#compdef trackma trackma-curses
# Documentation: https://github.com/z411/trackma
# Reference accessed: 2026-05-21
# Verified: upstream trackma/ui/cli.py argparse definitions.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'about:display program information'
  'help:show command help'
  'account:switch between accounts'
  'filter:change list filtering by status'
  'sort:modify sorting order'
  'mediatype:switch media types'
  'list:display all shows'
  'ls:display all shows'
  'info:get detailed show information'
  'search:find shows using regex patterns'
  'add:search and add new shows'
  'delete:remove shows from list'
  'del:remove shows from list'
  'rescan:re-scan local library'
  'random:play random new episode'
  'tracker:display tracker status'
  'play:launch media player'
  'openfolder:open show directory'
  'update:update episode progress'
  'score:change show rating'
  'status:modify show status'
  'altname:set alternative show names'
  'send:upload queued changes'
  'retrieve:download remote list'
  'clearqueue:clear pending changes'
  'viewqueue:display queued modifications'
  'quit:close program'
  'exit:close program'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(-a --account)'{-a+,--account=}'[use specific account number]:n' \
  '(-d --debug)'{-d,--debug}'[show debugging messages]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'trackma command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sort)
        _arguments '*::field:(id title my_progress total my_score)' && ret=0 ;;
      (status)
        _arguments '*::status:(watching completed on-hold dropped plan-to-watch reading reading-paused dropped-reading plan-to-read)' && ret=0 ;;
    esac ;;
esac

return ret
