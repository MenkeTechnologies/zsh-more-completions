#compdef firecracker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--api-sock=[API unix socket path]:socket path:_files' \
  '--config-file=[configuration file]:config file:_files' \
  '--id=[microVM unique identifier]:id' \
  '--log-path=[log file path]:log file:_files' \
  '--level=[log level]:level:(Error Warning Info Debug Trace)' \
  '--log-fifo=[named pipe for logging]:fifo:_files' \
  '--metrics-fifo=[named pipe for metrics]:fifo:_files' \
  '--metrics-path=[metrics file path]:metrics file:_files' \
  '--mmds-size-limit=[MMDS size limit in bytes]:bytes' \
  '--no-api[do not start API server]' \
  '--seccomp-filter=[custom seccomp filter]:filter file:_files' \
  '--no-seccomp[disable seccomp filtering]' \
  '--start-time-us=[process start time in microseconds]:microseconds' \
  '--start-time-cpu-us=[process start CPU time in microseconds]:microseconds' \
  '--parent-cpu-time-us=[parent process CPU time in microseconds]:microseconds' \
  '--boot-timer[enable boot timer]' && ret=0

return ret
