#compdef shoelace shoelace-cli sl-cli
# _shoelace — Cory LaViska Shoelace web-components CLI alias (shoelace-style / cory laviska, JavaScript); commander
# upstream: https://github.com/shoelace-style/shoelace

_shoelace() {
    local -a sub=(
        'analyze:analyze components'
        'create:scaffold a project'
        'dev:start dev server'
        'build:build for production'
        'docs:run docs server'
        'serve:serve built site'
        'test:run tests'
        'lint:run linters'
        'translate:run translation utility'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shoelace subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:name:' \
                    '--template=+[template]:t:(basic typescript ts react vue angular)' ;;
                dev|build|preview|serve) _arguments \
                    '--port=+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--open[open browser]' \
                    '--mode=+[mode]:m:(development production)' ;;
                analyze) _arguments \
                    '--outfile=+[output file]:file:_files' \
                    '*:src:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_shoelace "$@"
