#compdef plingeling
# Documentation: https://github.com/arminbiere/lingeling
# plingeling parallel SAT solver

local ret=1

_arguments -s -S \
  '-h[print command line option summary]' \
  '--version[print version and exit]' \
  '-v[increase verbose level]' \
  '-l[increase logging level]' \
  '-n[do not print solution / witness]' \
  '-p[plain portfolio, no sharing]' \
  '--do-not-share-units[disable unit sharing]' \
  '--do-not-share-clauses[disable clause sharing]' \
  '--do-not-share-equivalences[disable equivalence sharing]' \
  '-t+[number of worker threads]:threads' \
  '-m+[maximal memory in MB]:mb' \
  '-g+[maximal memory in GB]:gb' \
  '*:dimacs file:_files' && ret=0

return ret
