#compdef kodicli
# _kodicli — kodicli (Python CLI for Kodi's JSON-RPC API; subcommands: status, play, pause, stop, next, previous, library {scan|clean}, volume, mute, fullscreen, takescreen; --host/--user/--password override config defaults)
# upstream: https://github.com/Lustyn/kodicli
# Subcommands from kodicli kodicli/cli.py on tip.

_kodicli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--host+[Kodi host]:host:_hosts' \
        '--port+[port]:port:' \
        '--user+[user]:user:' \
        '--password+[password]:password:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'kodicli command' '(status play pause stop next previous library volume mute fullscreen takescreen togglefullscreen sendaction execute help)' ;;
        args)
            case $line[1] in
                library) _describe -t commands 'library subcommand' '(scan clean refresh export)' ;;
                volume) _arguments '1:level (0-100):' ;;
                play) _arguments '1:file or URL:_files' ;;
            esac
            ;;
    esac
}

_kodicli "$@"
