#compdef markdownlint mdl

_markdownlint() {
  _arguments \
    '(-c --config)'{-c,--config}'=[config file]:file:_files' \
    '(-d --dot)'{-d,--dot}'[include dot files]' \
    '(-f --fix)'{-f,--fix}'[fix errors automatically]' \
    '(-i --ignore)'{-i,--ignore}'=[ignore pattern]:pattern' \
    '(-j --json)'{-j,--json}'[output as JSON]' \
    '(-o --output)'{-o,--output}'=[output file]:file:_files' \
    '(-p --ignore-path)'{-p,--ignore-path}'=[ignore path file]:file:_files' \
    '(-r --rules)'{-r,--rules}'=[include custom rules]:rules:_files' \
    '(-s --stdin)'{-s,--stdin}'[read from stdin]' \
    '--disable=[disable rules]:rules' \
    '--enable=[enable rules]:rules' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '*:file:_files'
}

_markdownlint "$@"
