#compdef sema
# Source: cargo binstall sema-lang@1.10.0
# Probed via: completions zsh
# Repository: https://github.com/helgesverre/sema

autoload -U is-at-least

_sema() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'(-p --print)-e+[Evaluate an expression and print result (if non-nil)]:EVAL:_default' \
'(-p --print)--eval=[Evaluate an expression and print result (if non-nil)]:EVAL:_default' \
'(-e --eval)-p+[Evaluate an expression and always print result]:PRINT:_default' \
'(-e --eval)--print=[Evaluate an expression and always print result]:PRINT:_default' \
'*-l+[Load file(s) before executing]:LOAD:_default' \
'*--load=[Load file(s) before executing]:LOAD:_default' \
'--sandbox=[Sandbox mode\: restrict dangerous operations. Values\: "strict", "all", or comma-separated list like "no-shell,no-network,no-fs-write" Available capabilities\: shell, fs-read, fs-write, network, env-read, env-write, process, llm]:SANDBOX:_default' \
'--chat-model=[Set default chat model]:CHAT_MODEL:_default' \
'--chat-provider=[Set chat provider (anthropic, openai, gemini, groq, xai, mistral, moonshot, ollama)]:CHAT_PROVIDER:_default' \
'--embedding-model=[Set embedding model]:EMBEDDING_MODEL:_default' \
'--embedding-provider=[Set embedding provider (jina, voyage, cohere, openai)]:EMBEDDING_PROVIDER:_default' \
'--model=[Deprecated\: use --chat-model instead]:MODEL:_default' \
'--provider=[Deprecated\: use --chat-provider instead]:PROVIDER:_default' \
'--allowed-paths=[Restrict file operations to these directories (comma-separated)]:DIRS:_default' \
'-q[Suppress REPL banner]' \
'--quiet[Suppress REPL banner]' \
'-i[Enter REPL after running file or eval]' \
'--interactive[Enter REPL after running file or eval]' \
'--no-init[Skip LLM auto-configuration]' \
'(--no-init)--no-llm[Disable LLM features (same as --no-init)]' \
'--vm[Use bytecode VM instead of tree-walker]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::file -- File to execute:_default' \
'::script_args -- Arguments passed to the script (after --):_default' \
":: :_sema_commands" \
"*::: :->sema" \
&& ret=0
    case $state in
    (sema)
        words=($line[3] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sema-command-$line[3]:"
        case $line[3] in
            (ast)
_arguments "${_arguments_options[@]}" : \
'-e+[Expression to parse]:EVAL:_default' \
'--eval=[Expression to parse]:EVAL:_default' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
'::file -- File to parse:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(compile)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file path (default\: input with .semac extension)]:OUTPUT:_default' \
'--output=[Output file path (default\: input with .semac extension)]:OUTPUT:_default' \
'--check[Validate a .semac file without executing]' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Source file to compile:_default' \
&& ret=0
;;
(disasm)
_arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Bytecode file to disassemble:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_sema__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sema-help-command-$line[1]:"
        case $line[1] in
            (ast)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(compile)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(disasm)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_sema_commands] )) ||
_sema_commands() {
    local commands; commands=(
'ast:Parse source and display the AST' \
'completions:Generate shell completions' \
'compile:Compile source to bytecode (.semac)' \
'disasm:Disassemble a compiled bytecode file' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'sema commands' commands "$@"
}
(( $+functions[_sema__ast_commands] )) ||
_sema__ast_commands() {
    local commands; commands=()
    _describe -t commands 'sema ast commands' commands "$@"
}
(( $+functions[_sema__compile_commands] )) ||
_sema__compile_commands() {
    local commands; commands=()
    _describe -t commands 'sema compile commands' commands "$@"
}
(( $+functions[_sema__completions_commands] )) ||
_sema__completions_commands() {
    local commands; commands=()
    _describe -t commands 'sema completions commands' commands "$@"
}
(( $+functions[_sema__disasm_commands] )) ||
_sema__disasm_commands() {
    local commands; commands=()
    _describe -t commands 'sema disasm commands' commands "$@"
}
(( $+functions[_sema__help_commands] )) ||
_sema__help_commands() {
    local commands; commands=(
'ast:Parse source and display the AST' \
'completions:Generate shell completions' \
'compile:Compile source to bytecode (.semac)' \
'disasm:Disassemble a compiled bytecode file' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'sema help commands' commands "$@"
}
(( $+functions[_sema__help__ast_commands] )) ||
_sema__help__ast_commands() {
    local commands; commands=()
    _describe -t commands 'sema help ast commands' commands "$@"
}
(( $+functions[_sema__help__compile_commands] )) ||
_sema__help__compile_commands() {
    local commands; commands=()
    _describe -t commands 'sema help compile commands' commands "$@"
}
(( $+functions[_sema__help__completions_commands] )) ||
_sema__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'sema help completions commands' commands "$@"
}
(( $+functions[_sema__help__disasm_commands] )) ||
_sema__help__disasm_commands() {
    local commands; commands=()
    _describe -t commands 'sema help disasm commands' commands "$@"
}
(( $+functions[_sema__help__help_commands] )) ||
_sema__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'sema help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_sema" ]; then
    _sema "$@"
else
    compdef _sema sema
fi
