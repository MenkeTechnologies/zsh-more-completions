#compdef opencv_model_diagnostics
# Documentation: https://github.com/opencv/opencv/blob/master/apps/model-diagnostics/model_diagnostics.cpp
# opencv_model_diagnostics — diagnose DNN model import (ONNX/TensorFlow)

local ret=1

_arguments -s -S \
  '(-m --model)'{-m,--model}'=[path to the model file]:file:_files' \
  '(-c --config)'{-c,--config}'=[path to the model configuration file]:file:_files' \
  '(-f --framework)'{-f,--framework}'=[name of the model framework]:framework' \
  '--input0_name=[name of input0]:name' \
  '--input0_shape=[shape of input0]:shape' \
  '--input1_name=[name of input1]:name' \
  '--input1_shape=[shape of input1]:shape' \
  '--input2_name=[name of input2]:name' \
  '--input2_shape=[shape of input2]:shape' \
  '--input3_name=[name of input3]:name' \
  '--input3_shape=[shape of input3]:shape' \
  '--input4_name=[name of input4]:name' \
  '--input4_shape=[shape of input4]:shape' && ret=0

return ret
