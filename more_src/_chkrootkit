#compdef chkrootkit
# Documentation: chkrootkit -h
# Source: rootkit detector / checks for signs of compromise.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show version]' \
    '(- *)-l[list available tests]' \
    '-d[debug]' \
    '-q[quiet]' \
    '-x[expert mode]' \
    '-r+[alternate root directory]:dir:_files -/' \
    '-p+[external commands PATH (colon-separated)]:path:' \
    '-n[skip NFS mount points]' \
    '-T+[skip filesystem type]:fstype:(nfs smbfs cifs procfs sysfs tmpfs devfs)' \
    '*:test name:' \
    && ret=0

return ret
