#compdef coolify

local curcontext="$curcontext" state line ret=1

_coolify_commands() {
  local -a commands=(
    'deploy:Deploy an application'
    'login:Login to Coolify instance'
    'logout:Logout from Coolify instance'
    'status:Show deployment status'
  )
  _describe -t commands 'coolify command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  '--api-url[Coolify API URL]:url' \
  '--token[API token for authentication]:token' \
  '1:command:_coolify_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--api-url[Coolify API URL]:url' \
          '--token[API token]:token' \
          && ret=0
        ;;
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--api-url[Coolify API URL]:url' \
          '--token[API token]:token' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--api-url[Coolify API URL]:url' \
          '--token[API token]:token' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
