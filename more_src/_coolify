#compdef coolify
# Documentation: https://github.com/coollabsio/coolify-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_coolify_commands() {
  local -a commands=(
    'context:manage Coolify instance contexts and tokens'
    'server:manage servers'
    'servers:list servers'
    'projects:manage projects and environments'
    'resources:list deployed resources'
    'private-key:manage SSH private keys'
    'key:manage SSH private keys'
    'domains:manage domains'
    'app:manage applications'
    'database:manage databases'
    'service:manage services'
    'deploy:deploy a resource'
    'github:manage GitHub App integration'
    'team:show team information'
    'config:show config file location'
    'completion:generate shell completion script'
    'update:update CLI to latest version'
    'help:show help for a command'
  )
  _describe -t commands 'coolify command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--context=[context name to use]:context:' \
  '--token=[API bearer token]:token:' \
  '--host=[override Coolify host URL]:url:' \
  '--format=[output format]:format:(table json pretty)' \
  '(-s --show-sensitive)'{-s,--show-sensitive}'[reveal tokens and passwords]' \
  '(-f --force)'{-f,--force}'[skip confirmation prompts]' \
  '--debug[enable debug logging]' \
  '1:command:_coolify_commands' \
  '*::arg:->args' && ret=0

return ret
