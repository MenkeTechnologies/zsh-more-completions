# Zsh completion for cgen - shell completion generator from YAML

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-s --sample)'{-s,--sample}'[print sample YAML configuration]' \
  '*:config file:_files'
