#compdef cosrej
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Reject cosmic rays from cross-sections of similar spectra

local ret=1

_arguments -s -S \
  'IMAGE=[2-D image of similar spectra]:image:_files' \
  'XSTART=[start X value for mean calculation]:xstart:' \
  'XEND=[end X value for mean calculation]:xend:' \
  'CRSIG=[rejection cutoff in standard deviations]:crsig:' \
  'WMEAN=[generate a mean spectrum]:wmean:(TRUE FALSE)' \
  'MSPECT=[output mean spectrum file]:mspect:_files' \
  'OUTPUT=[resulting image with cosmic rays removed]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
