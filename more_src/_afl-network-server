#compdef afl-network-server
# _afl-network-server — AFL++ network proxy server (AFLplusplus/AFLplusplus)
# upstream: https://github.com/AFLplusplus/AFLplusplus
# Flags from utils/afl_network_proxy/afl-network-server.c (getopt usage).

_afl-network-server() {
    _arguments \
        '-i+[port to listen on]:port:' \
        '-f+[input file read by tested program]:file:_files' \
        '-t+[timeout per run (msec)]:ms:' \
        '-m+[memory limit (MB, "none" allowed)]:mem:' \
        '-Q[binary-only instrumentation (QEMU)]' \
        '-U[unicorn-based instrumentation]' \
        '-W[QEMU+Wine instrumentation]' \
        '-h[show help]' \
        '*::target program and args:_command_names -e'
}

_afl-network-server "$@"
