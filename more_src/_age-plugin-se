#compdef age-plugin-se
# Documentation: https://github.com/remko/age-plugin-se
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--generate[generate a new identity bound to the Secure Enclave]' \
  '--access-control=[access control policy]:policy:(none any-biometry any-biometry-or-passcode current-biometry-and-passcode)' \
  '--age-plugin=[run as an age plugin]:state machine' \
  '-o+[output file]:file:_files' && ret=0

return ret
