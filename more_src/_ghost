#compdef ghost

# Zsh completion for Ghost CLI - manage Ghost CMS instances

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-V[verbose output]' \
  '--verbose[verbose output]' \
  '-d+[working directory]:directory:_directories' \
  '--dir=[working directory]:directory:_directories' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'config:view or edit Ghost configuration'
      'doctor:check system for known issues'
      'export:export Ghost content'
      'import:import Ghost content'
      'install:install a Ghost instance'
      'log:view Ghost logs'
      'ls:list running Ghost instances'
      'migrate:run database migrations'
      'restart:restart Ghost'
      'run:run Ghost directly'
      'setup:setup a Ghost instance'
      'start:start Ghost'
      'stop:stop Ghost'
      'uninstall:uninstall a Ghost instance'
      'update:update Ghost'
      'version:show version'
      'buster:clear CDN cache'
    )
    _describe -t commands 'ghost command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--version=[Ghost version to install]:version' \
          '--ip=[host IP]:ip' \
          '--url=[blog URL]:url' \
          '--port=[server port]:port' \
          '--db=[database type]:db:(sqlite3 mysql)' \
          '--dbhost=[database host]:host' \
          '--dbuser=[database user]:user' \
          '--dbpass=[database password]:password' \
          '--dbname=[database name]:name' \
          '--dbpath=[SQLite database path]:path:_files' \
          '--mail=[mail transport]:transport:(Direct SMTP Sendmail)' \
          '--mailservice=[mail service]:service' \
          '--mailuser=[mail user]:user' \
          '--mailpass=[mail password]:password' \
          '--mailhost=[mail host]:host' \
          '--mailport=[mail port]:port' \
          '--no-prompt[disable prompts]' \
          '--no-setup[skip setup]' \
          '--no-start[do not start after install]' \
          '-d+[directory]:directory:_directories' \
          '--dir=[directory]:directory:_directories' \
          '--local[install for local development]' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--version=[update to specific version]:version' \
          '--rollback[rollback last update]' \
          '--force[force update]' \
          '--zip=[path to Ghost zip]:zip:_files -g "*.zip"' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:key' \
          '2:value' && ret=0
        ;;
      log)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f[follow log output]' \
          '--follow[follow log output]' \
          '-n+[number of lines]:lines' \
          '--number=[number of lines]:lines' && ret=0
        ;;
      start|stop|restart)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--enable[enable Ghost autostart]' \
          '--disable[disable Ghost autostart]' && ret=0
        ;;
    esac
    ;;
esac

return ret
