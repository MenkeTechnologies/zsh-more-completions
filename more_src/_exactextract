#compdef exactextract
# Documentation: https://github.com/isciences/exactextract/blob/master/src/exactextract.cpp
# Fast and accurate raster zonal statistics over polygon datasets

local ret=1

_arguments -s \
  '*'{-p,--polygons}'[polygon dataset (required)]:polygons:_files' \
  '*'{-r,--raster}'[raster dataset (required, repeatable)]:raster:_files' \
  '*'{-w,--weights}'[weighting dataset]:weights:_files' \
  '(-f --fid)'{-f,--fid}'[id from polygon dataset to retain in output]:fid:' \
  '(-o --output)'{-o,--output}'[output filename (required)]:output:_files' \
  '*'{-s,--stat}'[statistics to compute]:stat:' \
  '--max-cells=[max raster cells to read in memory at once, in millions]:millions:' \
  '--strategy=[processing strategy]:strategy:(feature-sequential raster-sequential)' \
  '--threads=[max parallel items processed at one time]:threads:' \
  '--id-type=[override type of id field in output]:type:' \
  '--id-name=[override name of id field in output]:name:' \
  '--nested-output[nested output]' \
  '*--include-col=[columns from input to include in output]:column:' \
  '--include-geom[include geometry in output]' \
  '--grid-compat-tol[grid compatibility tolerance]' \
  '--progress[show progress]' && ret=0

return ret
