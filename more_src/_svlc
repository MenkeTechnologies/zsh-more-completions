#compdef svlc

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(--verbose)'{-v,--verbose}'[increase verbosity]' \
  '--skins2-last=[last skin]:skin:' \
  '--skins2-config=[skin config]:cfg:' \
  '--skins2-systray[show in system tray]' \
  '--skins2-taskbar[show in taskbar]' \
  '--skins2-transparency[allow transparency]' \
  '--play-and-exit[exit after playback]' \
  '*:input:_files' && ret=0

return ret
