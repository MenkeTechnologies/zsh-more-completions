#compdef grate
# Documentation: https://github.com/grate-devs/grate/blob/main/docs/ConfigurationOptions/index.md
# grate SQL scripts migration runner

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-c --connectionstring)'{-c,--connectionstring}'=[connection string to the target database]:connstring' \
  '(-a --adminconnectionstring)'{-a,--adminconnectionstring}'=[connection string for admin tasks]:connstring' \
  '(-f --files)'{-f,--files}'=[directory where SQL scripts are located]:dir:_files -/' \
  '--folders=[folder configuration]:folders' \
  '(-o --output)'{-o,--output}'=[location for backups, logs and artifacts]:dir:_files -/' \
  '--accesstoken=[authentication token for SQL Server connections]:token' \
  '(-ct --commandtimeout)'{-ct,--commandtimeout}'=[execution timeout for standard commands]:seconds' \
  '(-cta --admincommandtimeout)'{-cta,--admincommandtimeout}'=[timeout for administrative commands]:seconds' \
  '--databasetype=[database type]:type:(mariadb oracle postgresql sqlite sqlserver)' \
  '(-t --transaction)'{-t,--transaction}'[execute migration within a transaction]' \
  '(-sc --schema)'{-sc,--schema}'=[schema to use for migration tables]:schema' \
  '--drop[remove the target database before running scripts]' \
  '--env=[environment-specific script filtering]:env' \
  '(-w --warnononetimescriptchanges)'{-w,--warnononetimescriptchanges}'[allow rerunning modified one-time scripts with warning]' \
  '--warnandignoreononetimescriptchanges[ignore changed one-time scripts and update hash]' \
  '--disabletokenreplacement[disable token replacement]' \
  '--usertokens=[custom token key=value pairs]:tokens' \
  '--donotstorescriptsruntext[omit full script text from storage]' \
  '--forceanytimescripts[run any time scripts every time]' \
  '--baseline[mark scripts as run without executing them]' \
  '--dryrun[log planned actions without execution]' \
  '--restore=[path to database backup file]:file:_files' \
  '(-ni --silent)'{-ni,--silent}'[suppress interactive prompts]' \
  '(-r --repo)'{-r,--repo}'=[repository identifier for version tracking]:repo' \
  '--version=[database migration version]:version' \
  '--isuptodate[check if database requires migrations]' \
  '(-v --verbosity)'{-v,--verbosity}'=[log level]:level:(Critical Debug Error Information None Trace Warning)' \
  '--createdatabase[create the target database if it does not exist]' && ret=0

return ret
