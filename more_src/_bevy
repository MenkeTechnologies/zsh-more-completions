# Reference accessed: 2026-05-30 via gh api.
# **REWRITTEN source-direct from R258** (previous version
# was URL-cited with incomplete coverage).
#
# bevy (binary name from `#[command(name = "bevy")]`) is the
# **Bevy game engine CLI** — official CLI for the Bevy
# data-driven Rust game engine.  Pivots from blockchain
# (R254 subxt / R257 pop-cli) into the **game development
# CLI cluster**.  Sister to dx (Dioxus CLI; already in
# corpus), wrangler (Cloudflare; in corpus).
#
# Critical extraction note: bevy uses **`visible_alias`
# (NOT `alias`)** at main.rs:113 + 116 on Build → `b` and
# Run → `r`.  Documents the **subtle distinction** between
# `#[command(alias = "X")]` (HIDDEN — works at the CLI
# but not shown in --help) and `#[command(visible_alias =
# "X")]` (SHOWN in --help as `build, b` and `run, r`).
# Plus their array forms `aliases = [..]` /
# `visible_aliases = [..]`.  Distinct from R250 sozo + R257
# pop-cli which both use plain `alias` (hidden).  Corpus's
# **first documented `visible_alias` attribute** —
# completes the **4 clap alias variants taxonomy**: (a)
# `alias = "X"` (hidden single), (b) `aliases = [..]`
# (hidden array), (c) `visible_alias = "X"` (shown single),
# (d) `visible_aliases = [..]` (shown array).
#
# Critical extraction note: bevy uses **per-variant
# `#[command(after_help = fn_name())]`** on 3 of 5
# subcommands (Run, Lint, Completions) at main.rs:117, 122,
# 130.  Each variant has its own fn-builder
# (`run_after_help`, `lint_after_help`,
# `completions_after_help`) returning a `String` with
# examples specific to that subcommand.  Plus a TOP-LEVEL
# `after_help = after_help()` at main.rs:71 returning a
# resources list (URLs to Bevy website, repo, CLI docs).
# Documents the **per-variant after_help pattern** —
# distinct from R247 sncast's single `after_long_help` at
# the top level only.  Allows `--help` for `bevy run` to
# show different examples than `--help` for `bevy lint`.
# Corpus's **first documented per-variant after_help with
# runtime fn-builders**.
#
# Critical extraction note: bevy uses **inline struct
# variant** for `Completions { shell: clap_complete::Shell }`
# at main.rs:131 — NO separate `CompletionsArgs` struct,
# the variant directly takes a single named field.
# Documents the **inline-struct-variant pattern** in clap
# derive — when a subcommand needs ONLY one arg, you can
# put the field inline in the enum variant without
# defining a struct.  Distinct from the typical
# `Subcommand(SubcommandArgs)` tuple-variant pattern
# (R250 sozo / R256 fuel-core-keygen / R257 pop-cli).
# Corpus's **first documented inline-struct-variant** clap
# derive pattern.
#
# Critical extraction note: bevy uses **`last = true,
# name = "ARGS"`** at new/args.rs:46, run/args.rs:36,
# lint/args.rs:30 to mark the trailing-positional
# `Vec<String>` that captures args AFTER `--`.  E.g.
# `bevy new myapp -- --foo` passes `--foo` to cargo-
# generate; `bevy run -- --bar` passes `--bar` to the Bevy
# app.  Plus lint's `forward_args` is **`#[clap(last =
# true, name = "ARGS", global = true)]`** — `global =
# true` on a POSITIONAL!  Most CLIs use `global = true`
# only on FLAGS.  Documents the **`global = true` on
# positional args** pattern — means the positional applies
# to subcommands too.  Corpus's **first documented
# `global = true` on a positional**.  Useful for "args to
# forward to underlying tool" patterns where the positional
# should propagate regardless of subcommand depth.
#
# Critical extraction note: bevy uses **`conflicts_with_all
# = ["revision", "tag"]`** at new/args.rs:32, 36, 40 — a
# 3-way clean mutex (`--branch`, `--tag`, `--revision`
# pick one) implemented via the `conflicts_with_all` array
# attribute.  Distinct from R249 cairo-profiler's repeated
# per-flag `conflicts_with` (3 attributes for 3-way mutex)
# and from R204's `#[group(multiple = false)]` (declarative
# group).  Corpus's **first documented `conflicts_with_all`
# array attribute** — completes the **3 mutex patterns
# taxonomy**: (a) per-pair `conflicts_with` (R255 fuel-
# core single pair), (b) per-flag `conflicts_with_all =
# [..]` (R258 bevy), (c) `#[group(multiple = false)]`
# (R250 sozo).
#
# Critical extraction note: bevy uses **`allow_hyphen_values
# = true`** at build/args.rs:163 + run/args.rs:167 on
# `--wasm-opt Vec<String>` to allow wasm-opt's own dash-
# prefixed flags to pass through.  Without this, clap
# would interpret `--O3` as a missing clap flag.
# Documents the **`allow_hyphen_values` pattern** —
# necessary when a flag's VALUES contain leading dashes
# (e.g. forwarding flags to a downstream tool).  Corpus's
# **first documented `allow_hyphen_values` attribute**.
#
# Critical extraction note: bevy uses **`requires =
# "create_packed_bundle"`** at build/args.rs:168 on
# `--bundle-dir` — declarative dependency at the FIELD
# level (BundleDir requires the Bundle flag to be set).
# Distinct from R248 cairo-coverage's `requires =
# "unstable"` (which gates 2 flags behind 1).

local curcontext="$curcontext" state line ret=1

# 5 top-level subcommands decoded source-direct from
# Subcommands enum at main.rs lines 108-132.
local -a subcommands=(
  'new:create a new Bevy project from a specified template'
  'build:build your Bevy app (visible alias: b)'
  'b:visible alias for `build`'
  'run:run your Bevy app (visible alias: r)'
  'r:visible alias for `run`'
  'lint:check the current project using Bevy-specific lints'
  'completions:print the auto-completion script for a specific shell'
)

local -a build_subs=(
  'web:build your app for the browser (FEATURE-GATED: web)'
)
local -a run_subs=(
  'web:run your app in the browser (FEATURE-GATED: web)'
)
local -a lint_subs=(
  'web:lint your app for the browser (FEATURE-GATED: web)'
  'install:install a bevy_lint version (FEATURE-GATED: rustup)'
  'list:list all available bevy_lint versions'
)

local -a completion_shells=(bash zsh fish powershell elvish)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output: log commands executed + extra info on actions (global)]' \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'bevy subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      new)
        _arguments \
          '--yes[confirm all prompts automatically]' \
          '(-t --template)'{-t+,--template=}'[template name (e.g. `2d` for `bevy_new_2d` or full GitHub URL; default: minimal)]:template:' \
          '(--tag --revision --rev)--branch=[git branch (mutex with --tag/--revision)]:branch:' \
          '(--branch --revision --rev)--tag=[git tag (mutex with --branch/--revision)]:tag:' \
          '(--branch --tag)--revision=[git revision/commit hash (mutex with --branch/--tag; alias: --rev)]:hash:' \
          '(--branch --tag --revision)--rev=[alias for --revision]:hash:' \
          '1:project name (directory name):' \
          '*:cargo-generate forward args (after --):' && ret=0
        ;;
      build|b)
        if (( CURRENT == 2 )); then
          _alternative \
            'subcommands:build target:_describe -t build-subs "verb" build_subs' \
            'flags:cargo build flag:(--yes -p --package -r --release --profile --target --features --no-default-features --all-features --manifest-path)' && ret=0
        else
          case $words[2] in
            web)
              _arguments \
                '(-b --bundle)'{-b,--bundle}'[bundle all web artifacts into a single folder]' \
                '--skip-post-processing[do not perform post-build binding/optimization/bundling (env: BEVY_WEB_SKIP_POST_PROCESSING)]' \
                '*--wasm-opt=[use wasm-opt to optimize wasm binary; accepts dash-values via allow_hyphen_values]:flags:' \
                '--bundle-dir=[copy final packed bundle to dir (REQUIRES --bundle)]:dir:_files -/' && ret=0
              ;;
          esac
        fi
        ;;
      run|r)
        if (( CURRENT == 2 )); then
          _alternative \
            'subcommands:run target:_describe -t run-subs "verb" run_subs' \
            'flags:cargo run flag:(--yes -p --package -r --release --profile --target --bin --example --features --no-default-features)' && ret=0
        else
          case $words[2] in
            web)
              _arguments \
                '(-p --port)'{-p+,--port=}'[web server port (default: 4000)]:port:' \
                '--host=[web server host address (default: 127.0.0.1)]:ip:' \
                '(-o --open)'{-o,--open}'[open the app in the browser]' \
                '(-b --bundle)'{-b,--bundle}'[bundle all web artifacts into a single folder]' \
                '*'{-H+,--headers=}'[headers to add to web responses (name:value or name=value; repeatable)]:header:' \
                '*--wasm-opt=[use wasm-opt to optimize wasm binary]:flags:' && ret=0
              ;;
          esac
        fi
        ;;
      lint)
        if (( CURRENT == 2 )); then
          _alternative \
            'subcommands:lint verb:_describe -t lint-subs "verb" lint_subs' \
            'flags:lint flag:(--version --fix --target --features --no-default-features --all-features)' && ret=0
        else
          case $words[2] in
            install)
              _arguments \
                '--yes[confirm all prompts automatically]' \
                '1:bevy_lint version:' && ret=0
              ;;
          esac
        fi
        ;;
      completions)
        # Inline struct variant: `Completions { shell:
        # clap_complete::Shell }`.  Single required arg.
        _arguments '1:shell:($completion_shells)' && ret=0
        ;;
    esac
    ;;
esac

return ret
