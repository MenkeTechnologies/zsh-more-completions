#compdef bevy
# Documentation: https://github.com/TheBevyFlock/bevy_cli (src/bin/main.rs + src/commands/*/mod.rs)
# Reference accessed: 2026-05-29
# Bevy game engine CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'new:create a new Bevy project from a template'
  'build:build your Bevy app'
  'b:build your Bevy app (alias)'
  'run:run your Bevy app'
  'r:run your Bevy app (alias)'
  'lint:check the current project using Bevy-specific lints'
  'completions:print the auto-completion script for a shell'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'bevy subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --template)'{-t,--template=}'[git repository template]:template:' \
          '(-b --branch)'{-b,--branch=}'[specific git branch]:branch:' \
          '--tag=[specific git tag]:tag:' \
          '--revision=[specific git revision]:rev:' \
          '*:: :_default' \
          ':package name:' && ret=0
        ;;
      build|b|run|r)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--release[build in release mode]' \
          '--web[build for the web target]' \
          '*-F=[features]:features:' \
          '*--features=[features]:features:' \
          '(-p --package)'{-p,--package=}'[package to build/run]:package:' \
          '--example=[run an example]:example:' \
          '--examples[build all examples]' \
          '*:cargo args:_default' && ret=0
        ;;
      completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
