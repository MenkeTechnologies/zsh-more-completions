#compdef kn

_kn_commands() {
  local -a commands=(
    'broker:manage event brokers'
    'channel:manage event channels'
    'completion:generate shell completion'
    'container:manage extra containers'
    'domain:manage domain mappings'
    'help:help about any command'
    'options:print list of global flags'
    'plugin:manage plugins'
    'revision:manage service revisions'
    'route:manage routes'
    'service:manage Knative services'
    'source:manage event sources'
    'subscription:manage event subscriptions'
    'trigger:manage event triggers'
    'version:print version'
  )
  _describe 'command' commands
}

_kn() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '--config[kn config file]:file:_files' \
    '--kubeconfig[kubectl config file]:file:_files' \
    '--log-http[log HTTP requests]' \
    '-n[namespace]:namespace' \
    '--namespace[namespace]:namespace' \
    '--context[kubeconfig context]:context' \
    '--cluster[kubeconfig cluster]:cluster' \
    '-h[display help]' \
    '--help[display help]' \
    '1:command:_kn_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        service)
          local -a subcmds=(
            'apply:apply a service configuration'
            'create:create a service'
            'delete:delete a service'
            'describe:describe a service'
            'list:list services'
            'update:update a service'
          )
          _describe 'subcommand' subcmds
          ;;
        revision)
          local -a subcmds=(
            'delete:delete a revision'
            'describe:describe a revision'
            'list:list revisions'
          )
          _describe 'subcommand' subcmds
          ;;
        route)
          local -a subcmds=(
            'describe:describe a route'
            'list:list routes'
          )
          _describe 'subcommand' subcmds
          ;;
        source)
          local -a subcmds=(
            'apiserver:manage API server sources'
            'binding:manage sink bindings'
            'list:list sources'
            'ping:manage ping sources'
          )
          _describe 'subcommand' subcmds
          ;;
        broker)
          local -a subcmds=(
            'create:create a broker'
            'delete:delete a broker'
            'describe:describe a broker'
            'list:list brokers'
            'update:update a broker'
          )
          _describe 'subcommand' subcmds
          ;;
        trigger)
          local -a subcmds=(
            'create:create a trigger'
            'delete:delete a trigger'
            'describe:describe a trigger'
            'list:list triggers'
            'update:update a trigger'
          )
          _describe 'subcommand' subcmds
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_kn "$@"
