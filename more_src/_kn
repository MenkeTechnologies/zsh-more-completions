#compdef kn
# Documentation: https://github.com/knative/client/blob/main/docs/cmd/kn.md
# Reference accessed: 2026-05-19
# Verified: upstream knative/client kn.md command reference.
# Corrected from prior file: removed invented 'help' subcommand;
# added real 'eventtype' and 'secret'; removed -n/--namespace from
# global flags (per-command, not persistent); added --as/--as-group
# /--as-uid impersonation flags.

_kn_commands() {
  local -a commands=(
    'broker:manage message brokers'
    'channel:manage event channels'
    'completion:output shell completion code'
    'container:manage service'\''s containers (experimental)'
    'domain:manage domain mappings'
    'eventtype:manage eventtypes'
    'options:print list of flags inherited by all commands'
    'plugin:manage kn plugins'
    'revision:manage service revisions'
    'route:list and describe service routes'
    'secret:manage secrets'
    'service:manage Knative services'
    'source:manage event sources'
    'subscription:manage event subscriptions'
    'trigger:manage event triggers'
    'version:show the version of this client'
  )
  _describe 'command' commands
}

_kn() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '--as=[username to impersonate for the operation]:user:' \
    '*--as-group=[group to impersonate (repeatable)]:group:' \
    '--as-uid=[UID to impersonate for the operation]:uid:' \
    '--cluster=[kubeconfig cluster name to use]:cluster:' \
    '--config=[kn config file]:file:_files' \
    '--context=[kubeconfig context name to use]:context:' \
    '--kubeconfig=[kubectl config file]:file:_files' \
    '--log-http[log HTTP traffic]' \
    '(-h --help)'{-h,--help}'[help for kn]' \
    '1:command:_kn_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        service)
          local -a subcmds=(
            'apply:apply a service configuration'
            'create:create a service'
            'delete:delete a service'
            'describe:describe a service'
            'list:list services'
            'update:update a service'
          )
          _describe 'subcommand' subcmds
          ;;
        revision)
          local -a subcmds=(
            'delete:delete a revision'
            'describe:describe a revision'
            'list:list revisions'
          )
          _describe 'subcommand' subcmds
          ;;
        route)
          local -a subcmds=(
            'describe:describe a route'
            'list:list routes'
          )
          _describe 'subcommand' subcmds
          ;;
        source)
          local -a subcmds=(
            'apiserver:manage API server sources'
            'binding:manage sink bindings'
            'list:list sources'
            'ping:manage ping sources'
          )
          _describe 'subcommand' subcmds
          ;;
        broker)
          local -a subcmds=(
            'create:create a broker'
            'delete:delete a broker'
            'describe:describe a broker'
            'list:list brokers'
            'update:update a broker'
          )
          _describe 'subcommand' subcmds
          ;;
        trigger)
          local -a subcmds=(
            'create:create a trigger'
            'delete:delete a trigger'
            'describe:describe a trigger'
            'list:list triggers'
            'update:update a trigger'
          )
          _describe 'subcommand' subcmds
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_kn "$@"
