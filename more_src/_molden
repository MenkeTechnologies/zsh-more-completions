#compdef molden
# molden — molecular orbital and density visualization

_arguments -s -S \
  '-l[read file and list orbital info only]' \
  '-n[suppress geometry optimization convergence window]' \
  '-x[generate X-matrix from Z-matrix]' \
  '-z[generate Z-matrix from Cartesian coordinates]' \
  '-c[clean up temporary files on exit]' \
  '-t[use a monochrome display]' \
  '-u[read cube file as unrestricted]' \
  '-f[read formatted checkpoint file]:file:_files -g "*.fchk"' \
  '-W+[set window size]:size:' \
  '-ON[use Orca NTO output]' \
  '*:input file:_files'
