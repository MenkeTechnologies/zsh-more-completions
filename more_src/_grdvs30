#compdef grdvs30
# GMT supplements/seis — compute Vs30 grid from topography slope

local ret=1

_arguments -s \
  '-C+[craton value/polygons file or grid +g]:craton:_default' \
  '-G+[output grid file]:file:_files' \
  '-R+[region west/east/south/north]:region:_default' \
  '-W+[Vs30 value for water areas (default 600)]:value:_default' \
  '*-V[verbose (stackable)]' \
  '-i+[input column selection]:cols:_default' \
  '-r[pixel registration]' \
  '*:input grid:_files' \
  && ret=0

return ret
