#compdef merge-fdata
# Documentation: https://github.com/llvm/llvm-project/blob/main/bolt/tools/merge-fdata/merge-fdata.cpp
# merge multiple BOLT profile data files into one

local ret=1

_arguments -s \
  '(-help --help)'{-help,--help}'[show help]' \
  '--version[show version]' \
  '-o=[write merged output to file]:output:_files' \
  '-q[do not print merged data to stdout]' \
  '--print=[print function list]:mode:(none exec branches)' \
  '*:profile data:_files' && ret=0

return ret
