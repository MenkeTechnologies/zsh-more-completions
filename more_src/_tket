#compdef tket pytket tket-cli
# _tket — Quantinuum TKET CQC quantum software development kit and compiler for circuit optimization (CQCL team, C++/Python); argparse
# upstream: https://github.com/CQCL/tket

_tket() {
    local -a sub=(
        'compile:compile circuit for backend'
        'transform:apply transformation pass'
        'route:run routing pass'
        'optimize:apply optimization pass'
        'decompose:decompose to basis gates'
        'simulate:simulate a circuit'
        'submit:submit to backend'
        'check:check circuit validity'
        'visualize:render circuit'
        'qasm:QASM subcommands'
        'backend:backend subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--input=+[circuit file]:file:_files -g "*.qasm *.json *.proto *.qpy *.qc"' \
        '-i+[circuit file]:file:_files -g "*.qasm *.json *.proto *.qpy *.qc"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--backend=+[backend]:b:(IBMQBackend IBMQEmulator AerBackend AerStateBackend AerUnitaryBackend QuantinuumBackend IonQBackend BraketBackend RigettiBackend ProjectQBackend QiskitBackend QSharpBackend QulacsBackend QujaxBackend SimulIDQEBackend NullBackend MockBackend)' \
        '-b+[backend]:b:(IBMQBackend AerBackend QuantinuumBackend IonQBackend BraketBackend)' \
        '--device=+[device id]:str:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--optimization-level=+[level]:l:(0 1 2 3)' \
        '-O+[level]:l:(0 1 2 3)' \
        '--seed=+[seed]:n:' \
        '--passes=+[passes csv]:str:' \
        '--predicates=+[predicates csv]:str:' \
        '--basis-gates=+[gates csv]:str:' \
        '--coupling-map=+[json]:str:' \
        '--no-progress-bar[no progress bar]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tket subcommand' sub ;;
        args)
            case $words[1] in
                qasm) _arguments '1:qasm cmd:(parse export validate transform)' '*:file:_files -g "*.qasm"' ;;
                backend) _arguments '1:backend cmd:(list status properties config)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_tket "$@"
