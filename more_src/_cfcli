#compdef cfcli
# Documentation: https://github.com/danielpigott/cloudflare-cli
# Reference accessed: 2026-05-23
# Verified: upstream README cfcli usage (cloudflare-cli npm package).

# Zsh completion for cfcli - Cloudflare DNS and zone management CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a DNS record'
  'always-use-https:toggle Always Use HTTPS mode'
  'devmode:toggle development mode'
  'disable:disable cloudflare caching for a record'
  'edit:edit a DNS record'
  'enable:enable cloudflare caching for a record'
  'find:find a DNS record'
  'ls:list DNS records for the domain'
  'purge:purge cached files or all files'
  'rm:remove a DNS record'
  'zone-add:add a zone'
  'zones:list domains in your Cloudflare account'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config=}'[config YAML path]:file:_files' \
  '(-e --email)'{-e,--email=}'[Cloudflare account email]:email:' \
  '(-k --token)'{-k,--token=}'[Cloudflare API token or key]:token:' \
  '(-u --account)'{-u,--account=}'[named account from config]:account:' \
  '(-d --domain)'{-d,--domain=}'[domain to operate on]:domain:' \
  '(-a --activate)'{-a,--activate}'[activate Cloudflare after creating record]' \
  '(-f --format)'{-f,--format=}'[output format]:format:(csv json table)' \
  '(-t --type)'{-t,--type=}'[DNS record type]:type:(A AAAA CNAME MX TXT SRV NS)' \
  '(-n --newtype)'{-n,--newtype=}'[record type to update to]:type:' \
  '(-p --priority)'{-p,--priority=}'[priority for MX or SRV records]:priority:' \
  '(-q --query)'{-q,--query=}'[comma-separated record filters]:query:' \
  '(-l --ttl)'{-l,--ttl=}'[TTL on add or edit (120-86400 or 1 for auto)]:ttl:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cfcli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (always-use-https|devmode)
        _arguments ':state:(on off)' && ret=0 ;;
      (add|edit|enable|disable|find|rm|purge|ls|zone-add|zones)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
