#compdef qvm
# ============================================================================
#  _qvm — qvm: Quil Virtual Machine (Rigetti Computing quantum simulator)
#
#  Source-direct extraction from
#    https://github.com/quil-lang/qvm/blob/master/app/src/entry-point.lisp
#    https://github.com/fare/command-line-arguments (the
#    command-line-arguments library by François-René Rideau / fare)
#
#  Maintained by Quil Lang / Rigetti Computing (quil-lang/qvm).  454
#  GH stars.  QVM (Quil Virtual Machine) is a HIGH-PERFORMANCE QUANTUM
#  COMPUTING SIMULATOR for the Quil programming language — used by
#  quantum computing researchers and developers at Rigetti Computing
#  and the broader quantum software community.  Simulates quantum
#  circuits with state-vector and density-matrix methods, supports
#  noisy quantum simulation, and exposes a REST API server for
#  cloud-based quantum simulation.  Sister tools: pyQuil (Python
#  Quil client library), Quilc (Quil-to-native-gate compiler, IN
#  CORPUS via _quilc), Forest (Rigetti's quantum computing platform),
#  Cirq (Google quantum), Qiskit (IBM quantum, IN CORPUS), Q#
#  (Microsoft quantum, IN CORPUS).
#
#  CLI library taxonomy update: 5th Common Lisp CLI library —
#  François-René Rideau's **command-line-arguments** (fare/command-
#  line-arguments).  Common Lisp ecosystem now has 5 documented CLI
#  libraries (R285 cl-cli + R286 unix-opts + R351 sjl/adopt + R380
#  dnaeon/clingon + R398 fare/command-line-arguments) — tied with
#  Java/Crystal/OCaml/Python/Scala/TypeScript-Node (all 5-6) at
#  the second-most-documented tier behind Rust/Go (9).
#
#  command-line-arguments (fare/command-line-arguments) is François-
#  René "fare" Rideau's Common Lisp CLI parsing library.  fare is
#  the maintainer of ASDF (the de facto CL build system), Quicklisp
#  contributor, and prolific CL ecosystem developer.  Distinct from
#  R285 cl-cli (older imperative style), R286 unix-opts (POSIX
#  getopt-style with `define-opts` macro), R351 sjl/adopt (REVERSED
#  imperative model with `make-option`/`make-context`), R380 dnaeon/
#  clingon (modern clap/cobra-inspired with `clingon:make-command`/
#  `clingon:make-option` keyword-arg constructors) by being LIST-
#  OF-SPECS DECLARATIVE FORMAT with Common Lisp keyword-property
#  syntax.  Used by `pgloader` (Dimitri Fontaine's PostgreSQL data
#  migration tool, IN CORPUS via _pgloader 6430 stars), Lem editor
#  (lem-project/lem 2972 stars — general-purpose CL editor), QVM
#  (quil-lang/qvm 454 stars — Rigetti Computing quantum simulator),
#  ProjecturEd (143 stars — projectional editor), anoma/geb (Geb
#  categorical computation framework), valtan (cxxxr — CL to JS
#  compiler), GrammaTech/resolve, ruricolist/kiln, fosskers/vend,
#  cleopter, hu.dwim.util, mathematical-systems/cl-gui, and many CL
#  tools that want a stable list-of-specs declarative CLI parser.
#
#  fare/command-line-arguments API:
#    (defparameter *option-spec*
#      '((("input" #\i)         ; long name + optional short char
#         :type string
#         :documentation "Input file path")
#        (("output" #\o)
#         :type string
#         :initial-value "out.txt"  ; default value
#         :documentation "Output file path")
#        (("port" #\p)
#         :type integer
#         :optional t
#         :initial-value 8080
#         :documentation "Listen port")
#        (("verbose" #\v)
#         :type boolean
#         :optional t
#         :initial-value nil
#         :documentation "Verbose output")
#        (("help" #\h)
#         :type boolean
#         :optional t
#         :documentation "Display help")))
#
#    (defun main (&optional (argv (uiop:command-line-arguments)))
#      (command-line-arguments:handle-command-line
#       *option-spec*
#       (lambda (&key input output port verbose help)
#         (if help
#             (command-line-arguments:show-option-help
#              *option-spec* :sort-names t)
#             (run-tool :input input :output output
#                       :port port :verbose verbose)))
#       :command-line argv
#       :name "mytool"))
#
#  fare/command-line-arguments distinctive features:
#    - LIST-OF-SPECS DECLARATIVE FORMAT — `*option-spec*` is a
#      Common Lisp LIST where each element is a LIST: `((LONG-NAME
#      [SHORT-CHAR]) :type TYPE :initial-value V :optional T
#      :documentation "...")`
#    - SHORT NAME via COMMON LISP CHARACTER LITERAL `#\c` (e.g. `#\h`
#      for `-h`); inside the same sublist as the long-name string
#      (similar to R380 Clingon's `:short-name #\h` syntax)
#    - LONG NAME via plain Lisp STRING `"long-name"` — no leading
#      dashes in spec
#    - TYPE via `:type` plist key: `:string` / `:integer` /
#      `:boolean` / `:number` / `:character` / etc.
#    - `:initial-value V` — DEFAULT VALUE when flag not provided
#    - `:optional t` — mark option as optional (default: required)
#    - `:documentation "..."` — per-option help text
#    - `:short` / `:long` keys for explicit short/long name override
#      (when the (LONG-NAME SHORT-CHAR) form is insufficient)
#    - `command-line-arguments:handle-command-line spec callback
#      :command-line args :name name :rest-arity ARITY` — MAIN ENTRY
#      taking spec + callback function + argv + program name
#    - CALLBACK as Common Lisp LAMBDA with `&key` LAMBDA-LIST —
#      receives parsed options as keyword arguments
#      (`(lambda (&key input output port verbose help) ...)`)
#    - `:command-line argv` — argv list (typically from
#      `(uiop:command-line-arguments)`)
#    - `:name "progname"` — program name for help output
#    - `:rest-arity 0` (or 1, 'list, etc.) — how to handle positional
#      args (0 = no positionals, list = collect all)
#    - `command-line-arguments:show-option-help spec :sort-names t`
#      — generate and print formatted help text
#    - `command-line-arguments:process-command-line-options spec args`
#      — LOW-LEVEL processor returning multiple values
#      `(values arguments-plist positional-args)` for caller to
#      process directly (used by pgloader pattern)
#    - PROCESS EXIT model — caller controls via `(uiop:quit N)` or
#      `(sb-ext:exit :code N)`
#    - NO automatic --help — caller checks `:help t` in callback and
#      calls `show-option-help` (but library auto-adds basic --help
#      handling)
#    - NO automatic --version — caller handles
#    - NO subcommand support — caller hand-rolls subcommand dispatch
#      (typically dispatch on first positional)
#    - PRE-DATES Quicklisp era — older API style than modern Clingon
#      (R380)
#  Distinct from R285 Common Lisp cl-cli (older imperative style),
#  R286 Common Lisp unix-opts (POSIX getopt-style with `define-opts`
#  macro — uses similar `:type` keys but different overall structure),
#  R351 Common Lisp sjl/adopt (REVERSED imperative model with
#  `make-option`/`make-context`), R380 Common Lisp dnaeon/clingon
#  (MODERN clap/cobra-inspired with `clingon:make-command`/
#  `clingon:make-option` keyword-arg constructors and rich type
#  system; clingon is the modern standard while command-line-arguments
#  is the older established option), R275 Rust clap-derive (Rust
#  struct + macros), R357 Go mitchellh/cli (Go Cmd interface).
#  command-line-arguments' approach: LIST-OF-SPECS DECLARATIVE
#  FORMAT with `((LONG-NAME [SHORT-CHAR]) :type TYPE :initial-value
#  V :optional T :documentation "...")` per-option entries +
#  COMMON LISP CHARACTER LITERAL `#\c` for short names + `:type`
#  keyword for TYPE COERCION (:string/:integer/:boolean/:number) +
#  `:initial-value V` for defaults + `:optional t` flag + `:documentation
#  "..."` help text + `handle-command-line` MAIN ENTRY with CALLBACK
#  LAMBDA using `&key` LAMBDA-LIST + `show-option-help` for help
#  generation + `process-command-line-options` LOW-LEVEL processor +
#  caller-controlled PROCESS EXIT + NO automatic --help/--version/
#  subcommands — corpus's **first documented list-of-specs-with-
#  callback-lambda Common Lisp CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 137; Common Lisp ecosystem
#  now has 5 documented CLI libraries.
#
#  Surface (verbatim from `app/src/entry-point.lisp` `*option-spec*`):
#
#  Allocation Options:
#        --default-allocation MODE  Where wavefunctions get allocated:
#                                   "native" (default) | "foreign"
#                                   (C-compatible allocation)
#
#  Server Options:
#    -S, --server                   Start a QVM server
#        --host HOST                Host for QVM server (default: 0.0.0.0)
#    -p, --port PORT                Port for QVM server (default: 5000)
#
#  Computation Options:
#    -e, --execute                  Read Quil program from stdin and
#                                   execute it (DEPRECATED)
#    -q, --qubits N                 Number of qubits to force to use
#        --memory-limit BYTES       Limit on usable classical memory
#                                   per program (octets)
#    -w, --num-workers N            Parallel workers (0 = maximum)
#                                   (default: 0)
#        --time-limit MS            Time limit for computations
#                                   (0 = unlimited; in ms)
#        --qubit-limit N            Max qubits allowed in server
#                                   (0 = unlimited)
#        --parallelization-limit N  Qubits to start parallelizing at
#
#  Benchmark Options:
#        --benchmark N              Run benchmark entangling N qubits
#                                   (default: 26)
#        --benchmark-type TYPE      Benchmark type (default: bell):
#                                   bell | qaoa | suprema | qft | ...
#
#  Utility Options:
#        --check-libraries          Check that foreign libraries are
#                                   adequate; exit 0 if so, 1 if not
#    -h, --help                     Display help
#    -v, --version                  Display QVM version and underlying
#                                   library versions
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also command-line-arguments users):
#    - pgloader (IN CORPUS via _pgloader — Dimitri Fontaine's
#      PostgreSQL data migration tool 6430 stars; uses command-line-
#      arguments but already documented under different attribution;
#      flagship use case)
#    - lem (lem-project/lem 2972 stars — general-purpose CL editor;
#      uses command-line-arguments in webview frontend and language
#      server CLI; FUTURE candidate for editor scope)
#    - projectured (143 stars — projectional editor, smaller community)
#    - geb (anoma/geb 34 stars — Geb categorical computation,
#      academic)
#    - valtan (cxxxr/valtan — CL to JS compiler, niche)
#    - GrammaTech/resolve / ruricolist/kiln / fosskers/vend / cleopter
#      / hu.dwim.util / mathematical-systems/cl-gui (smaller community
#      Common Lisp tools)
#    - quilc (IN CORPUS via _quilc — Rigetti's Quil-to-native-gate
#      compiler, sister tool to QVM)
# ============================================================================

_qvm() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--default-allocation=[wavefunction allocation]:mode:(native foreign)' \
    '(-S --server)'{-S,--server}'[start a QVM server]' \
    '--host=[host for QVM server (default 0.0.0.0)]:host:_hosts' \
    '(-p --port)'{-p,--port}'=[port for QVM server (default 5000)]:port' \
    '(-e --execute)'{-e,--execute}'[read Quil from stdin and execute (DEPRECATED)]' \
    '(-q --qubits)'{-q,--qubits}'=[number of qubits to force]:n' \
    '--memory-limit=[classical memory limit (octets)]:bytes' \
    '(-w --num-workers)'{-w,--num-workers}'=[parallel workers (0 = max)]:n' \
    '--time-limit=[time limit for computations (ms; 0 = unlimited)]:ms' \
    '--qubit-limit=[max qubits in server (0 = unlimited)]:n' \
    '--parallelization-limit=[qubit count to start parallelizing]:n' \
    '--benchmark=[run benchmark entangling N qubits (default 26)]:n' \
    '--benchmark-type=[benchmark type]:type:(bell qaoa suprema qft)' \
    '--check-libraries[check foreign libraries are adequate]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-v --version)'{-v,--version}'[display QVM version]'
}

_qvm "$@"
