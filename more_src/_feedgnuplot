#compdef feedgnuplot

# Zsh completion for feedgnuplot (dkogan/feedgnuplot)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--terminal[gnuplot terminal]:term' \
  '--title[plot title]:title' \
  '--hardcopy[write output file]:file:_files' \
  '*:: : _message "see feedgnuplot --help"' && ret=0

return ret
