#compdef git-revise
# Documentation: https://git-revise.readthedocs.io/en/latest/man.html
# Source: https://github.com/mystor/git-revise (gitrevise/tui.py argparse)
# Reference accessed: 2026-05-30
# git revise — efficient pure-Python git history rewriter (update, split, rearrange).
# Three mutex groups: autosquash, index, and mode.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[print version and exit]' \
  '(- *)'{-h,--help}'[show help]' \
  '--ref=[reference to update (default HEAD)]:ref:__git_references' \
  '--reauthor[reset author of targeted commit to current user]' \
  '(--autosquash --no-autosquash)--autosquash[automatically apply fixup! and squash! commits]' \
  '(--autosquash --no-autosquash)--no-autosquash[force disable revise.autoSquash behavior]' \
  '(-a --all -p --patch --no-index)'{-a,--all}'[stage all tracked files before running]' \
  '(-a --all -p --patch --no-index)'{-p,--patch}'[interactively stage hunks before running]' \
  '(-a --all -p --patch --no-index)--no-index[ignore the index while rewriting history]' \
  '(-i --interactive -c --cut -m --message)'{-i,--interactive}'[interactively edit commit stack]' \
  '(-i --interactive -c --cut -m --message)'{-c,--cut}'[interactively cut a commit into two smaller commits]' \
  '(-e --edit)'{-e,--edit}'[edit commit message of targeted commit(s)]' \
  '*'{-m,--message=}'[commit message line (repeatable for multi-line)]:message:' \
  '1:target commit:__git_revisions' \
  && ret=0

return ret
