#compdef cmctl-cli cmctl
# _cmctl-cli — Jetstack cert-manager cmctl-cli CLI command-line frontend wrapping the cmctl command line tool that can help you manage cert-manager and its resources inside your cluster CNCF Graduated open-source written in Go renew check API status convert installCRDs migrate upgrade approve deny experimental create-certificate-request manual-renew uninstall manage Certificate Issuer ClusterIssuer CertificateRequest ACME EAB JWT JOSE Vault Venafi-VBC HashiCorp-Vault Azure-DNS-Cloudflare-DNS GoogleCloudDNS Route53 (Jetstack cert-manager CNCF team Munnerz Jakexks, Go); cobra
# upstream: https://cert-manager.io/

_cmctl-cli() {
    local -a sub=(
        'approve:approve a CertificateRequest'
        'check:check cert-manager components'
        'completion:generate shell completion'
        'convert:convert manifests to v1 API'
        'create:create cert-manager resources'
        'deny:deny a CertificateRequest'
        'experimental:experimental commands'
        'inspect:inspect cert-manager resources'
        'install:install cert-manager'
        'migrate:migrate API versions'
        'renew:renew a Certificate'
        'status:show status of Certificate'
        'uninstall:uninstall cert-manager'
        'upgrade:upgrade cert-manager'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '--context=+[name]:str:' \
        '--cluster=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[ns]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '-l+[selector]:str:' \
        '--selector=+[sel]:str:' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--match-server-version[match server version]' \
        '--reason=+[reason]:str:' \
        '--message=+[msg]:str:' \
        '--ca-cluster-resource-namespace=+[ns]:str:' \
        '--cluster-resource-namespace=+[ns]:str:' \
        '--namespace-flag=+[ns]:str:' \
        '--wait[wait for completion]' \
        '--timeout=+[d]:str:' \
        '-o+[output format]:f:(json yaml)' \
        '--output=+[fmt]:f:(json yaml)' \
        '--show-managed-fields[show managed fields]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cmctl subcommand' sub ;;
        args)
            case $words[1] in
                approve|deny|renew|status) _arguments '*:certificate request:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                create) _arguments '1:type:(certificaterequest)' '*:arg:' ;;
                convert) _arguments '*:file:_files -g "*.yaml *.yml"' ;;
                experimental) _arguments '1:op:(install uninstall create install-crds)' '*:arg:' ;;
                inspect) _arguments '1:type:(secret)' '*:arg:' ;;
            esac
            ;;
    esac
}

_cmctl-cli "$@"
