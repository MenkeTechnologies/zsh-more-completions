#compdef cudaq cudaq-quake nvq++ cudaq-mlir
# _cudaq — NVIDIA CUDA-Q nvq++ compiler and runtime for the CUDA quantum programming model in C++ and Python (NVIDIA team, C++); custom argparse
# upstream: https://github.com/NVIDIA/cuda-quantum

_cudaq() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-target=+[target]:t:(qpp-cpu cusvsim cusvsim-fp32 cusvsim-fp64 tensornet tensornet-mps density-matrix-cpu nvidia nvidia-fp64 nvidia-mgpu nvidia-mqpu remote-mqpu quantum-mock photonics ionq quantinuum iqm oqc orca-photonics rigetti pasqal hyperion qbraid)' \
        '--target=+[target]:t:(qpp-cpu cusvsim cusvsim-fp32 cusvsim-fp64 tensornet tensornet-mps density-matrix-cpu nvidia nvidia-fp64 nvidia-mgpu nvidia-mqpu remote-mqpu quantum-mock photonics ionq quantinuum iqm oqc orca-photonics rigetti pasqal hyperion qbraid)' \
        '--target-option=+[option]:str:' \
        '--list-targets[list available targets]' \
        '--print-target=+[target]:str:' \
        '--qpud[start qpud server]' \
        '--qpud-port=+[port]:port:_ports' \
        '--qpud-host=+[host]:host:_hosts' \
        '-fhost-mlir[use host MLIR]' \
        '-fno-host-mlir[disable host MLIR]' \
        '-fnvqpp-tracing[NVQ++ tracing]' \
        '-fembed-bytecode[embed bytecode]' \
        '-fno-embed-bytecode[no embed bytecode]' \
        '--llvm-args=+[args]:str:' \
        '--mlir-args=+[args]:str:' \
        '--enable-optimization=+[bool]:b:(true false)' \
        '--enable-pre-quantum-optimizations[pre quantum optimizations]' \
        '--enable-post-quantum-optimizations[post quantum optimizations]' \
        '-Wl,+[linker options]:str:' \
        '-o+[output file]:file:_files' \
        '-c[compile only]' \
        '-S[emit asm]' \
        '-emit-llvm[emit LLVM IR]' \
        '-emit-mlir[emit MLIR]' \
        '-emit-quake[emit Quake IR]' \
        '-emit-codegen[emit codegen]' \
        '--qir=+[QIR profile]:p:(base full adaptive)' \
        '--qpu-platform=+[platform]:str:' \
        '--list-platforms[list platforms]' \
        '--list-options[list target options]' \
        '*:source file:_files -g "*.cpp *.cc *.cu *.cuq *.py *.qke *.quake *.mlir"'
}

_cudaq "$@"
