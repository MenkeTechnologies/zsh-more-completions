#compdef kiterunner kr

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'scan:scan targets with kite files'
      'brute:brute force paths on targets'
      'wordlist:manage wordlists'
      'kb:manage the kitebuilder schema'
      'version:print version information'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (scan)
        _arguments \
          '(-w --kitebuilder-list)'{-w,--kitebuilder-list}'=[kitebuilder schema file]:file:_files' \
          '(-x --extensions)'{-x,--extensions}'=[comma-separated list of extensions]:extensions:' \
          '(-A --assetnote-wordlist)'{-A,--assetnote-wordlist}'=[assetnote wordlist names]:wordlist:' \
          '(-H --header)'{-H,--header}'=[custom headers]:header:' \
          '--max-connection-per-host=[max connections per host]:connections:' \
          '--max-redirects=[max redirects to follow]:redirects:' \
          '--max-parallel-hosts=[max parallel hosts]:hosts:' \
          '--delay=[delay between requests in ms]:ms:' \
          '--timeout=[request timeout in seconds]:seconds:' \
          '--user-agent=[custom user agent]:agent:' \
          '--quarantine-threshold=[quarantine threshold]:threshold:' \
          '--progress[show progress bar]' \
          '--fail-status-codes=[status codes to ignore]:codes:' \
          '--success-status-codes=[status codes to accept]:codes:' \
          '--wildcard-detection[enable wildcard detection]' \
          '--force[force scan without confirmation]' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '*:target:' && ret=0
        ;;
      (brute)
        _arguments \
          '(-w --wordlist)'{-w,--wordlist}'=[wordlist file]:file:_files' \
          '(-x --extensions)'{-x,--extensions}'=[comma-separated list of extensions]:extensions:' \
          '(-H --header)'{-H,--header}'=[custom headers]:header:' \
          '--max-connection-per-host=[max connections per host]:connections:' \
          '--delay=[delay between requests in ms]:ms:' \
          '--timeout=[request timeout in seconds]:seconds:' \
          '--user-agent=[custom user agent]:agent:' \
          '--progress[show progress bar]' \
          '--fail-status-codes=[status codes to ignore]:codes:' \
          '--success-status-codes=[status codes to accept]:codes:' \
          '--force[force scan without confirmation]' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '*:target:' && ret=0
        ;;
      (wordlist)
        _arguments \
          '1:action:(list download)' \
          '*:wordlist name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
