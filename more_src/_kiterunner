#compdef kiterunner kr
# Documentation: https://github.com/assetnote/kiterunner
# Reference accessed: 2026-05-19
# Verified: upstream cobra command definitions at the URL above.
# Corrected from prior file: -x is --max-connection-per-host (not
# --extensions); -e/--extensions belongs to brute only; -w is
# --kitebuilder-list (scan) / --wordlist (brute); wordlist subcommands
# are list/save (not download); kb has compile/convert/parse/replay;
# --force is --force-method; -d is --preflight-depth. Added documented
# persistent flags -v/--verbose, -o/--output, -q/--quiet.

local curcontext="$curcontext" state line ret=1

local -a persistent
persistent=(
  '(-v --verbose)'{-v,--verbose}'=[logging verbosity level]:level:(error info debug trace)'
  '(-o --output)'{-o,--output}'=[output format]:format:(json text pretty)'
  '(-q --quiet)'{-q,--quiet}'[quiet mode, mute unnecessary pretty text]'
)

_arguments -C \
  "${persistent[@]}" \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'scan:scan targets using compiled kitebuilder wordlists'
      'brute:bruteforce paths on targets with a text wordlist'
      'wordlist:manage and list available wordlists'
      'kb:kitebuilder schema utilities'
      'version:display version information'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (scan)
        _arguments \
          "${persistent[@]}" \
          '*'{-w,--kitebuilder-list}'=[ogl wordlist to use for scanning]:file:_files' \
          '--kitebuilder-full-scan[full scan mode]' \
          '*'{-A,--assetnote-wordlist}'=[use wordlists from wordlist.assetnote.io (e.g. apiroutes-210228)]:wordlist:' \
          '*'{-H,--header}'=[headers to add to requests]:header:' \
          '--disable-precheck[disable the pre-flight host check]' \
          '(-x --max-connection-per-host)'{-x,--max-connection-per-host}'=[max connections to a single host]:connections:' \
          '(-j --max-parallel-hosts)'{-j,--max-parallel-hosts}'=[max concurrent hosts to scan at once]:hosts:' \
          '--delay=[delay between requests]:duration:' \
          '--user-agent=[user agent to use on requests]:agent:' \
          '(-t --timeout)'{-t,--timeout}'=[timeout to use on all requests]:duration:' \
          '--max-redirects=[max redirects to follow]:redirects:' \
          '--force-method=[force a single HTTP method for all requests]:method:' \
          '--success-status-codes=[status codes treated as success]:codes:' \
          '--fail-status-codes=[status codes treated as failure]:codes:' \
          '*--blacklist-domain=[domains to skip]:domain:' \
          '--wildcard-detection[enable wildcard response detection]' \
          '*--ignore-length=[content lengths to ignore]:length:' \
          '--progress[show progress bar]' \
          '--quarantine-threshold=[quarantine a host after this many errors]:threshold:' \
          '(-d --preflight-depth)'{-d,--preflight-depth}'=[directory depth for baseline wildcard checks]:depth:' \
          '--profile-name=[profile name]:name:' \
          '--filter-api=[filter to a specific API]:api:' \
          '*:target:' && ret=0
        ;;
      (brute)
        _arguments \
          "${persistent[@]}" \
          '*'{-w,--wordlist}'=[normal text wordlist to use for scanning]:file:_files' \
          '*'{-e,--extensions}'=[extensions to append while scanning]:extensions:' \
          '(-D --dirsearch-compat)'{-D,--dirsearch-compat}'[replace %EXT% with the provided extensions]' \
          '*'{-H,--header}'=[headers to add to requests]:header:' \
          '--disable-precheck[disable the pre-flight host check]' \
          '(-x --max-connection-per-host)'{-x,--max-connection-per-host}'=[max connections to a single host]:connections:' \
          '(-j --max-parallel-hosts)'{-j,--max-parallel-hosts}'=[max concurrent hosts to scan at once]:hosts:' \
          '--delay=[delay between requests]:duration:' \
          '--user-agent=[user agent to use on requests]:agent:' \
          '(-t --timeout)'{-t,--timeout}'=[timeout to use on all requests]:duration:' \
          '--max-redirects=[max redirects to follow]:redirects:' \
          '--force-method=[force a single HTTP method for all requests]:method:' \
          '--success-status-codes=[status codes treated as success]:codes:' \
          '--fail-status-codes=[status codes treated as failure]:codes:' \
          '*--blacklist-domain=[domains to skip]:domain:' \
          '--wildcard-detection[enable wildcard response detection]' \
          '*--ignore-length=[content lengths to ignore]:length:' \
          '--progress[show progress bar]' \
          '--quarantine-threshold=[quarantine a host after this many errors]:threshold:' \
          '(-d --preflight-depth)'{-d,--preflight-depth}'=[directory depth for baseline wildcard checks]:depth:' \
          '--profile-name=[profile name]:name:' \
          '--filter-api=[filter to a specific API]:api:' \
          '*:target:' && ret=0
        ;;
      (wordlist)
        _arguments \
          '1:action:(list save)' \
          '*:wordlist name:' && ret=0
        ;;
      (kb)
        _arguments \
          '1:action:(compile convert parse replay)' \
          '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
