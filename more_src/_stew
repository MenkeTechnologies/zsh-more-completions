#compdef stew

# Zsh completion for stew - binary package manager for GitHub releases

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'install:install a binary from GitHub'
      'uninstall:uninstall a binary'
      'upgrade:upgrade installed binaries'
      'list:list installed binaries'
      'browse:browse available binaries'
      'rename:rename an installed binary'
      'config:manage stew configuration'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--tag[install specific tag/version]:tag:' \
          '--asset[select specific asset]:asset:' \
          '*:repo (owner/name):' \
          && ret=0
        ;;
      (uninstall|rename)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:binary:' \
          && ret=0
        ;;
      (upgrade)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--all[upgrade all binaries]' \
          '*:binary:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
