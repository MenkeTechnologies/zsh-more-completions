#compdef gmic-qt

# G'\''MIC-Qt: Qt-based image filter GUI front-end to G'\''MIC
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--gimp=[GIMP-mode input mode]:mode:(active layers visible-layers all-layers)' \
  '--input=[input image]:file:_files' \
  '--output=[output image]:file:_files' \
  '--reapply[reapply the last applied filter]' \
  '*:image file:_files' && ret=0
return ret
