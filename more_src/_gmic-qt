#compdef gmic-qt
# Documentation: https://man.archlinux.org/search?q=gmic-qt
# Reference accessed: 2026-05-16

# G'MIC-Qt: image filtering plugin / standalone GUI (GREYC's Magic Image Converter)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--input=[input image]:file:_files -g "*.(png|jpg|jpeg|tif|tiff|gif|bmp|webp|avif|gmz|cimg|gif|pnm|ppm|pgm|exr|hdr)"' \
  '--output=[output image]:file:_files' \
  '--filter=[apply specific filter (path/internal id)]:filter:' \
  '--standalone[run in standalone mode]' \
  '--filters-pane[open the filters pane]' \
  '--reapply[re-apply last filter]' \
  '*:images:_files -g "*.(png|jpg|jpeg|tif|tiff|gif|bmp|webp|avif|gmz|cimg|pnm|ppm|pgm|exr|hdr)"' && ret=0
return ret
