#compdef postcss

# Zsh completion for postcss-cli - PostCSS command line interface

_arguments -s -S \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-d --dir)'{-d,--dir}'[output directory]:directory:_directories' \
  '(-r --replace)'{-r,--replace}'[replace input file(s) with output]' \
  '--map[enable source maps]' \
  '--no-map[disable source maps]' \
  '*'{-u,--use}'[PostCSS plugin to use]:plugin' \
  '--parser[custom CSS parser]:parser' \
  '--stringifier[custom CSS stringifier]:stringifier' \
  '--syntax[custom CSS syntax]:syntax' \
  '(-w --watch)'{-w,--watch}'[watch files for changes and recompile]' \
  '--verbose[display detailed processing information]' \
  '--env[set a specific environment for plugins]:environment' \
  '--ext[override the output file extension]:extension' \
  '(-c --config)'{-c,--config}'[set config lookup path]:directory:_directories' \
  '--poll[use polling for file watching]' \
  '--base[mirror the directory structure relative to this path]:directory:_directories' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:input files:_files -g "*.css"' && return 0
