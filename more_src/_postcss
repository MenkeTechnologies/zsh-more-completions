#compdef postcss
# Documentation: https://github.com/postcss/postcss-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for postcss-cli - PostCSS command line interface

_arguments -s -S \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-d --dir)'{-d,--dir}'[output directory]:directory:_directories' \
  '(-r --replace)'{-r,--replace}'[overwrite the input file]' \
  '(-m --map)'{-m,--map}'[generate external sourcemap]' \
  '--no-map[turn off default inline sourcemaps]' \
  '*'{-u,--use}'=[PostCSS plugin to apply]:plugin' \
  '--parser=[custom postcss parser]:parser' \
  '--stringifier=[custom postcss stringifier]:stringifier' \
  '--syntax=[custom postcss syntax]:syntax' \
  '(-w --watch)'{-w,--watch}'[watch files for changes and recompile]' \
  '--verbose[display detailed output]' \
  '--env=[NODE_ENV value]:environment' \
  '--ext=[output file extension with --dir]:extension' \
  '--config=[custom config file directory]:directory:_directories' \
  '--include-dotfiles[allow glob to match dotfiles]' \
  '--poll[poll for file changes]' \
  '--base=[mirror directory structure relative to path]:directory:_directories' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:input files:_files -g "*.css"' && return 0
