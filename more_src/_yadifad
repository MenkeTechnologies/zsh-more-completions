#compdef yadifad

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '(-c --config)'{-c+,--config=}'[alternate configuration file]:file:_files -g "*.conf"' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode]' \
  '(-u --uid)'{-u+,--uid=}'[run as user]:user:_users' \
  '(-g --gid)'{-g+,--gid=}'[run as group]:group:_groups' && ret=0

return ret
