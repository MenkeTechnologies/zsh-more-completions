#compdef yadifad
# Documentation: https://manpages.debian.org/testing/yadifa/yadifad.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '(-c --config)'{-c+,--config=}'[use alternate config file]:file:_files -g "*.conf"' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode (default)]' \
  '(-u --uid)'{-u+,--uid=}'[run as user]:user:_users' \
  '(-g --gid)'{-g+,--gid=}'[run as group]:group:_groups' && ret=0

return ret
