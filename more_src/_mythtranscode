#compdef mythtranscode
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythtranscode/mythtranscode_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythtranscode: MythTV recording transcoder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-j --jobid)'{-j,--jobid=}'[job ID]:id:' \
  '--chanid=[channel ID]:id:' \
  '--starttime=[start time]:time:' \
  '(-p --profile)'{-p,--profile=}'[transcoding profile]:profile:' \
  '(-k --allkeys)'{-k,--allkeys}'[all frames should be keyframes]' \
  '--passthrough[pass through audio without re-encoding]' \
  '--audiotrack=[select audio track]:n:' \
  '--allaudiotracks[include all audio tracks]' \
  '(-ro --recorderOptions)'{-ro,--recorderOptions=}'[recorder options]:opts:' \
  '(-m --mpeg2)'{-m,--mpeg2}'[MPEG-2]' \
  '(-e --ostream)'{-e,--ostream=}'[output stream type]:name:' \
  '--avf[generate libavformat output]' \
  '(-f --fifodir)'{-f,--fifodir=}'[fifo directory]:dir:_files -/' \
  '--fifoinfo[show fifo info]' \
  '--fifosync[enforce fifo sync]' \
  '--cleancut[clean cut]' \
  '(-l --honorcutlist)'{-l,--honorcutlist}'[honor cut list]' \
  '--inversecut[inverse cut]' \
  '--showprogress[show progress]' \
  '(-i --infile)'{-i,--infile=}'[input file]:file:_files' \
  '(-o --outfile)'{-o,--outfile=}'[output file]:file:_files' \
  '(-b --buildindex)'{-b,--buildindex}'[build index]' \
  '--video[video mode]' \
  '--queue=[queue]:q:' \
  '--width=[output width]:n:' \
  '--height=[output height]:n:' \
  '--bitrate=[video bitrate Kbps]:n:' \
  '--audiobitrate=[audio bitrate Kbps]:n:' \
  '(-d --delete)'{-d,--delete}'[delete after transcode]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
