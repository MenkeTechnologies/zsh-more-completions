#compdef jack_mixer
# Documentation: https://man.archlinux.org/search?q=jack_mixer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[load config]:file:_files' \
  '(-n --client-name)'{-n,--client-name}'+[JACK client name]:name:' \
  '(-d --debug)'{-d,--debug}'[debug logging]' && ret=0

return ret
