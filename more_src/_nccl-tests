#compdef all_reduce_perf all_gather_perf alltoall_perf broadcast_perf gather_perf hypercube_perf reduce_perf reduce_scatter_perf scatter_perf sendrecv_perf nccl-tests
# _nccl-tests — NVIDIA nccl-tests benchmark suite for the NCCL multi-GPU communication library (NVIDIA team, C++); custom argparse
# upstream: https://github.com/NVIDIA/nccl-tests

_nccl-tests() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-b+[min bytes]:str:' \
        '--minbytes=+[min bytes]:str:' \
        '-e+[max bytes]:str:' \
        '--maxbytes=+[max bytes]:str:' \
        '-i+[stepbytes]:str:' \
        '--stepbytes=+[stepbytes]:str:' \
        '-f+[stepfactor]:n:' \
        '--stepfactor=+[stepfactor]:n:' \
        '-d+[data type]:t:(int8 uint8 int32 uint32 int64 uint64 half float double bfloat16 fp8_e4m3 fp8_e5m2)' \
        '--datatype=+[data type]:t:(int8 uint8 int32 uint32 int64 uint64 half float double bfloat16 fp8_e4m3 fp8_e5m2)' \
        '-o+[operation]:o:(sum prod min max avg mulsum all)' \
        '--op=+[operation]:o:(sum prod min max avg mulsum all)' \
        '-r+[root]:n:' \
        '--root=+[root]:n:' \
        '-g+[number of GPUs]:n:' \
        '--ngpus=+[number of GPUs]:n:' \
        '-t+[threads]:n:' \
        '--nthreads=+[threads]:n:' \
        '-c+[check correctness]:b:(0 1)' \
        '--check=+[check correctness]:b:(0 1)' \
        '-z+[blocking]:b:(0 1)' \
        '--blocking=+[blocking]:b:(0 1)' \
        '-n+[iterations]:n:' \
        '--iters=+[iterations]:n:' \
        '-w+[warmup iterations]:n:' \
        '--warmup_iters=+[warmup iterations]:n:' \
        '-N+[run cycles]:n:' \
        '--cycles=+[run cycles]:n:' \
        '-T+[timeout ms]:n:' \
        '--timeout=+[timeout ms]:n:' \
        '-Z+[CUDA graph]:b:(0 1)' \
        '--cudagraph=+[CUDA graph]:b:(0 1)' \
        '-a+[parallel init]:b:(0 1)' \
        '--parallel_init=+[parallel init]:b:(0 1)' \
        '-p+[port]:port:_ports' \
        '--report-cputime=+[bool]:b:(0 1)' \
        '-m+[multi-thread mode]:b:(0 1)' \
        '--mthreads=+[multi-thread mode]:b:(0 1)'
}

_nccl-tests "$@"
