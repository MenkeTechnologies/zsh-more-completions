#compdef naga
# Documentation: https://man.archlinux.org/search?q=naga
# Reference accessed: 2026-05-16

# https://github.com/anayjoshi/naga — paste bin client (Typer/click; `naga --help`)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '(-u --url)'{-u,--url}'=-[API base URL]:url:' \
  '(-f --file)'{-f,--file}'=-[file to upload]:file:_files' \
  '(-e --expire)'{-e,--expire}'=-[expiry string]:expire:' \
  '*:text or path:_files'
