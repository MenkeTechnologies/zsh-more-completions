#compdef cargo-rdme

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --check)'{-c,--check}'[check only]' \
  '(--readme-path)--readme-path=[README path]:file:_files' \
  '(-w --workspace-project)'{-w+,--workspace-project=}'[workspace project]:p:' \
  '(--entrypoint)--entrypoint=[lib/bin name]:n:' \
  '(--intralinks-strip-links)--intralinks-strip-links[strip intralinks]' \
  '(--intralinks-docs-rs-base-url)--intralinks-docs-rs-base-url=[base URL]:url:' \
  '(--intralinks-docs-rs-version)--intralinks-docs-rs-version=[version]:v:' \
  '(--no-fail-on-warnings)--no-fail-on-warnings[no fail on warnings]' \
  '(--force)--force[force]' \
  '*: :' && ret=0

return ret
