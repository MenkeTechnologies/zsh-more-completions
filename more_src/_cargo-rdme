#compdef cargo-rdme
# Documentation: https://github.com/orium/cargo-rdme (src/options.rs clap)
# Reference accessed: 2026-05-29
# cargo-rdme — generate README.md from a Rust crate's doc comments. Exit codes: 0 ok,
# 3 README out-of-date in --check, 4 warnings.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--entrypoint=[source entrypoint (default auto)]:choice:(auto lib bin)' \
  '--line-terminator=[line terminator to use in README (default auto)]:choice:(auto lf crlf)' \
  '(-r --readme-path)'{-r,--readme-path=}'[README file path (overrides Cargo.toml package.readme)]:file:_files -g "*.(md|markdown)"' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
  '(-w --workspace-project)'{-w,--workspace-project=}'[workspace project to extract docs from]:proj:' \
  '(-c --check)'{-c,--check}'[check README is up to date (exit 3 mismatch, 4 warnings)]' \
  '--no-fail-on-warnings[do not exit non-zero on warnings in --check]' \
  '--intralinks-strip-links[remove intralinks (do not rewrite to docs.rs URLs)]' \
  '--intralinks-docs-rs-base-url=[base URL for intralinks rewrites]:url:' \
  '--intralinks-docs-rs-version=[version for intralinks rewrites]:ver:' \
  '--heading-base-level=[heading level offset added to Rust doc headings]:N:' \
  '(-f --force)'{-f,--force}'[force README update even with uncommitted changes]' \
  && ret=0

return ret
