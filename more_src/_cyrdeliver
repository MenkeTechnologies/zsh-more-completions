#compdef cyrdeliver

# cyrdeliver: deliver mail into Cyrus IMAP
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-e[trust the envelope sender]' \
  '-f[envelope sender]:addr:' \
  '-m[mailbox]:mailbox:' \
  '-a[auth user]:user:_users' \
  '-q[quota override]' \
  '-r[no return path]' \
  '-l[lmtp socket]:socket:_files' \
  '*:recipient:_users' && ret=0
return ret
