#compdef chauffeur
# Documentation: https://www.npmjs.com/package/chauffeur-cli
# Reference accessed: 2026-05-23
# Verified: npx chauffeur-cli --help.

# Zsh completion for chauffeur - minimal Codex-style terminal coding agent

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cwd[workspace directory]:directory:_directories' \
  '--model[model name]:model:' \
  '--api-key[API key]:key:' \
  '--base-url[LLM API base URL]:url:' \
  '*:task:task:' && ret=0

return ret
