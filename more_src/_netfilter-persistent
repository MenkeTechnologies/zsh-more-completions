#compdef netfilter-persistent
# Documentation: https://man.archlinux.org/search?q=netfilter-persistent
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:(start stop restart reload flush save)' && ret=0

return ret
