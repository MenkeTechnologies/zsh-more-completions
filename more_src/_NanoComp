#compdef NanoComp
# Documentation: https://github.com/wdecoster/nanocomp
# NanoComp: compare multiple long-read sequencing datasets and plot statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-t --threads)'{-t,--threads}'+[number of threads to use]:threads' \
  '(-o --outdir)'{-o,--outdir}'+[output directory]:dir:_files -/' \
  '(-p --prefix)'{-p,--prefix}'+[prefix for output files]:prefix' \
  '--verbose[write log messages to the terminal]' \
  '--raw[store extracted data in a tab-separated file]' \
  '--readtype[read type to extract from summary]:type:(1D 2D 1D2)' \
  '--barcoded[process barcoded experiment data, split by barcode]' \
  '--split_runs[TSV file to split summary data by run IDs]:file:_files' \
  '(-f --format)'{-f,--format}'+[output plot format]:format:(png jpg jpeg webp svg pdf eps json)' \
  '(-n --names)'{-n,--names}'+[custom names for datasets]:names' \
  '(-c --colors)'{-c,--colors}'+[colors to assign to datasets]:colors' \
  '--plot[plot type]:type:(violin box ridge false)' \
  '--title[title for all plots]:title' \
  '--fastq[(compressed) fastq input file(s)]:fastq:_files' \
  '--fasta[(compressed) fasta input file(s)]:fasta:_files' \
  '--summary[albacore/guppy summary file(s)]:summary:_files' \
  '--bam[sorted bam input file(s)]:bam:_files -g "*.bam"' && ret=0

return ret
