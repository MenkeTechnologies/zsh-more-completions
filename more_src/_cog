#compdef cog

# Zsh completion for cog (cocogitto) - conventional commits tooling

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'bump:increment the version based on conventional commits'
  'changelog:generate a changelog'
  'check:verify all commits follow conventional commit spec'
  'commit:create a conventional commit'
  'edit:interactively edit non-conventional commits'
  'init:initialize a repository for conventional commits'
  'install-hook:install cog git hooks'
  'log:display conventional commits log'
  'verify:verify a single commit message'
)

local -a commit_types=(
  'feat:a new feature'
  'fix:a bug fix'
  'docs:documentation only changes'
  'style:formatting changes'
  'refactor:code change without feature or fix'
  'perf:performance improvement'
  'test:adding or fixing tests'
  'build:build system or dependencies'
  'ci:CI configuration changes'
  'chore:other changes'
  'revert:revert a previous commit'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'cog subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (bump)
        _arguments \
          '(-v --version)'{-v,--version}'[manually set the next version]:version:' \
          '--auto[automatically determine the bump level]' \
          '--major[force a major bump]' \
          '--minor[force a minor bump]' \
          '--patch[force a patch bump]' \
          '--pre[set a pre-release suffix]:suffix:' \
          '--build[set build metadata]:metadata:' \
          '--dry-run[display the bumped version without making changes]' \
          '--hook-profile[profile to use for bump hooks]:profile:' \
          '--annotated[create an annotated tag]:message:' \
          '--skip-ci[add skip-ci string to tag message]' \
          '--skip-ci-override[custom skip-ci string]:string:' \
          '--skip-untracked[ignore untracked files]' \
          '--disable-changelog[skip changelog generation]' \
          '--disable-bump-commit[skip bump commit creation]' \
          '-p[target a specific package]:package:' \
          '--package[target a specific package]:package:' && ret=0
        ;;
      (changelog)
        _arguments \
          '(-a --at)'{-a,--at}'[generate changelog at tag]:tag:' \
          '--template[template for changelog]:template:_files' \
          '--remote[repository remote URL]:url:' \
          '--owner[repository owner]:owner:' \
          '--repository[repository name]:name:' && ret=0
        ;;
      (check)
        _arguments \
          '--from-latest-tag[check from latest tag only]' \
          '(-l --ignore-merge-commits)'{-l,--ignore-merge-commits}'[ignore merge commits]' && ret=0
        ;;
      (commit)
        _arguments \
          '1:commit type:((${(j: :)commit_types}))' \
          '2:commit message:' \
          '(-s --scope)'{-s,--scope}'[commit scope]:scope:' \
          '(-B --breaking-change)'{-B,--breaking-change}'[mark as breaking change]' \
          '(-e --edit)'{-e,--edit}'[open editor for message]' \
          '(-S --sign)'{-S,--sign}'[sign the commit with GPG]' && ret=0
        ;;
      (verify)
        _arguments '1:commit message:' && ret=0
        ;;
      (log)
        _arguments \
          '(-a --author)'{-a,--author}'[filter by author]:author:' \
          '(-t --type)'{-t,--type}'[filter by commit type]:type:(feat fix docs style refactor perf test build ci chore revert)' \
          '(-s --scope)'{-s,--scope}'[filter by scope]:scope:' \
          '(-B --breaking-change)'{-B,--breaking-change}'[filter breaking changes only]' \
          '(-e --no-error)'{-e,--no-error}'[omit non-conventional commits]' && ret=0
        ;;
    esac
    ;;
esac

return ret
