#compdef kibana

# Zsh completion for Kibana

_kibana() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-e+[Elasticsearch URL]:URL:' \
    '--elasticsearch=[Elasticsearch URL]:URL:' \
    '-c+[config file]:config file:_files -g "*.{yml,yaml}"' \
    '--config=[config file]:config file:_files -g "*.{yml,yaml}"' \
    '-p+[port]:port:' \
    '--port=[port]:port:' \
    '-q[silent mode]' \
    '--quiet[silent mode]' \
    '-Q[silent mode with only errors]' \
    '--silent[silent mode with only errors]' \
    '--verbose[turn on verbose logging]' \
    '-H+[host]:host:_hosts' \
    '--host=[host]:host:_hosts' \
    '-l+[log file]:log file:_files' \
    '--log-file=[log file]:log file:_files' \
    '--log.level=[log level]:level:(all fatal error warn info debug trace off)' \
    '--pid.file=[PID file]:PID file:_files' \
    '--path.data=[data directory]:directory:_files -/' \
    '--server.basePath=[base URL path prefix]:path:' \
    '--server.publicBaseUrl=[public base URL]:URL:' \
    '--server.ssl.enabled=[enable SSL]:enabled:(true false)' \
    '--server.ssl.certificate=[SSL certificate]:cert file:_files' \
    '--server.ssl.key=[SSL key]:key file:_files' \
    '--elasticsearch.hosts=[Elasticsearch hosts]:hosts:' \
    '--elasticsearch.username=[Elasticsearch username]:username:' \
    '--elasticsearch.password=[Elasticsearch password]:password:' \
    '--elasticsearch.ssl.certificateAuthorities=[CA file]:CA file:_files' \
    '--elasticsearch.ssl.verificationMode=[SSL verification]:mode:(full certificate none)' \
    '--elasticsearch.serviceAccountToken=[service account token]:token:' \
    '--xpack.encryptedSavedObjects.encryptionKey=[encryption key]:key:' \
    '--xpack.reporting.encryptionKey=[reporting encryption key]:key:' \
    '--xpack.security.encryptionKey=[security encryption key]:key:' \
    '--monitoring.enabled=[enable monitoring]:enabled:(true false)' \
    '--telemetry.enabled=[enable telemetry]:enabled:(true false)' \
    '(-h --help)'{-h,--help}'[display help]' \
    '-v[display version]' \
    '--version[display version]' \
    && ret=0

  return ret
}

_kibana "$@"
