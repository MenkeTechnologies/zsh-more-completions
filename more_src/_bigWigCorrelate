#compdef bigWigCorrelate
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# correlate bigWig files, optionally only on target regions

local ret=1

_arguments -s -S \
  '-restrict=[confine correlation to regions in this file]:bigBed:_files -g "*.(bb|bigBed)"' \
  '-threshold=[cap values at a maximum threshold]:n' \
  '-rootNames[display only filename without directory or extension]' \
  '-ignoreMissing[exclude positions where either dataset lacks coverage]' \
  '*:bigWig file or list:_files' && ret=0

return ret
