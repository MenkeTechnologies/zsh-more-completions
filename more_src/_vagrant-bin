#compdef vagrant
# _vagrant-bin — HashiCorp Vagrant dev environments CLI (HashiCorp, Ruby); provision portable dev VMs (Virtualbox/libvirt/Hyper-V)
# upstream: https://github.com/hashicorp/vagrant

_vagrant-bin() {
    local -a sub=(
        'autocomplete:install autocomplete'
        'box:box subcommands'
        'cap:VM provider capability commands'
        'cloud:Vagrant Cloud commands'
        'destroy:destroy VM'
        'docker-exec:execute inside a docker container'
        'docker-logs:print docker logs'
        'docker-run:run a one-off docker container'
        'global-status:status of all VMs'
        'halt:stop VM'
        'help:show help'
        'init:initialize Vagrantfile'
        'list-commands:list all commands'
        'login:login to Vagrant Cloud'
        'logout:logout'
        'package:export VM as box'
        'plugin:plugin commands'
        'port:show forwarded ports'
        'powershell:open ps shell'
        'provider:show provider'
        'provision:provision running VM'
        'push:push to cloud'
        'rdp:connect via RDP'
        'reload:reload VM'
        'resume:resume VM'
        'rsync:sync rsync folders'
        'rsync-auto:auto rsync'
        'serve:serve provider plugin'
        'snapshot:snapshot commands'
        'ssh:ssh into VM'
        'ssh-config:print ssh config'
        'status:show VM status'
        'suspend:suspend VM'
        'up:start VM'
        'upload:upload files to VM'
        'validate:validate Vagrantfile'
        'version:show version'
        'winrm:WinRM commands'
        'winrm-config:WinRM config'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug log]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vagrant subcommand' sub ;;
        args)
            case $words[1] in
                up) _arguments \
                    '--provision[force provision]' \
                    '--no-provision[skip provision]' \
                    '--provision-with+[provisioners]:str:' \
                    '--destroy-on-error+[destroy on error]:bool:(true false)' \
                    '--parallel[parallel up]' \
                    '--no-parallel[no parallel]' \
                    '--provider+[provider]:provider:(virtualbox vmware_desktop libvirt docker hyperv aws azure google)' \
                    '*:VM name:' ;;
                ssh) _arguments \
                    '-c+[command to run]:cmd:_command_names -e' \
                    '--command+[command to run]:cmd:_command_names -e' \
                    '-p[plain mode]' \
                    '--plain[plain mode]' \
                    '*:VM name:' ;;
                box) _arguments '1:box cmd:(add list outdated prune remove repackage update)' '*:box:' ;;
                snapshot) _arguments '1:snapshot cmd:(delete list pop push restore save)' '*:args:' ;;
                plugin) _arguments '1:plugin cmd:(expunge install license list repair uninstall update)' '*:plugin:' ;;
                halt|destroy|suspend|resume|reload|status|provision) _arguments '*:VM name:' ;;
            esac
            ;;
    esac
}

_vagrant-bin "$@"
