#compdef mockgen

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-source=[source file]:source file:_files -g "*.go"' \
  '-destination=[destination file]:destination file:_files' \
  '-package=[destination package]:package name:' \
  '-imports=[explicit imports]:imports:' \
  '-aux_files=[auxiliary Go source files]:files:_files' \
  '-build_flags=[build flags]:flags:' \
  '-mock_names=[custom mock names]:name mappings:' \
  '-self_package=[full package import path]:package:' \
  '-copyright_file=[copyright header file]:file:_files' \
  '-exec_only=[subcommand mode binary]:binary:_files' \
  '-prog_only=[subcommand mode output]:output:_files' \
  '-write_package_comment[write package documentation comment]' \
  '-typed[generate type-safe methods]' \
  '-model=[model file]:model:' \
  '*:source:' && ret=0

return ret
