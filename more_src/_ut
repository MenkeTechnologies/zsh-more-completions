#compdef ut

# Zsh completion for ut (it-tools CLI)
# https://github.com/ksdme/ut

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'base64:Base64 encode/decode'
  'hash:Generate cryptographic hashes'
  'uuid:Generate UUIDs'
  'calc:Expression calculator'
  'regex:Regex testing'
  'jwt:JWT decoding/verifying'
  'help:Show help message'
)

_arguments -s -S \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ut command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (base64)
        _arguments -s -S \
          '1:subcommand:(encode decode)' \
          '*: :_files' && ret=0
        ;;
      (hash)
        _arguments -s -S \
          '1:algorithm:(md5 sha1 sha256 sha512)' \
          '*: :_files' && ret=0
        ;;
      (uuid|calc|regex|jwt|help)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
