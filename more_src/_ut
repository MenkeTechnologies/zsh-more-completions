#compdef ut
# Documentation: https://github.com/ksdme/ut
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ut (it-tools CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'base64:Base64 encode/decode'
  'url:URL parse/encode/decode'
  'hash:Generate cryptographic hashes'
  'bcrypt:bcrypt hash/verify'
  'jwt:JWT encode/decode/verify'
  'uuid:Generate UUIDs'
  'token:Generate random token'
  'secret:Generate random secret'
  'password:Generate random password'
  'lorem:Lorem ipsum text generator'
  'random:Random number generator'
  'case:Convert text case'
  'pp:Pretty-print / unescape'
  'pretty-print:Pretty-print / unescape'
  'diff:Compare two files'
  'calc:Expression calculator'
  'cal:Expression calculator'
  'json:JSON builder'
  'regex:Regex testing'
  'crontab:Crontab schedule preview'
  'datetime:Datetime conversion'
  'dt:Datetime conversion'
  'ip:IP CIDR describe'
  'http:HTTP status lookup'
  'serve:Local HTTP server'
  'qr:QR code generator'
  'color:Color converter'
  'unicode:Unicode symbol table'
  'help:Show help message'
)

_arguments -s -S \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ut command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (base64)
        _arguments -s -S \
          '--urlsafe[use URL-safe alphabet]' \
          '1:subcommand:(encode decode)' \
          '*: :_files' && ret=0
        ;;
      (hash)
        _arguments -s -S \
          '1:algorithm:(md5 sha1 sha224 sha256 sha384 sha512)' \
          '*: :_files' && ret=0
        ;;
      (bcrypt)
        _arguments -s -S \
          '1:subcommand:(hash verify)' && ret=0
        ;;
      (jwt)
        _arguments -s -S \
          '--payload=[JWT payload]:payload:' \
          '--secret=[JWT secret]:secret:' \
          '--issuer=[issuer]:issuer:' \
          '--expires-in=[expiration]:duration:' \
          '1:subcommand:(encode decode verify)' && ret=0
        ;;
      (uuid)
        _arguments -s -S \
          '--count=[number of UUIDs]:count:' \
          '--namespace=[UUID namespace]:namespace:' \
          '--name=[UUID name]:name:' \
          '1:version:(v1 v3 v4 v5 v7)' && ret=0
        ;;
      (token|secret|password)
        _arguments -s -S \
          '--length=[length]:length:' \
          '--no-symbols[exclude symbols]' \
          '--no-uppercase[exclude uppercase]' && ret=0
        ;;
      (lorem)
        _arguments -s -S \
          '--paragraphs=[number of paragraphs]:count:' \
          '--min-sentences=[min sentences]:count:' \
          '--max-sentences=[max sentences]:count:' && ret=0
        ;;
      (random)
        _arguments -s -S \
          '--min=[minimum]:value:' \
          '--max=[maximum]:value:' \
          '--step=[step]:value:' \
          '--count=[count]:count:' && ret=0
        ;;
      (case)
        _arguments -s -S \
          '1:case:(lower upper camel snake kebab title constant header sentence)' && ret=0
        ;;
      (diff)
        _arguments -s -S \
          '-a[file a]:file:_files' \
          '-b[file b]:file:_files' && ret=0
        ;;
      (regex)
        _arguments -s -S \
          '--test[test mode]' && ret=0
        ;;
      (crontab)
        _arguments -s -S \
          '(-n --count)'{-n,--count}'[count]:count:' \
          '(-a --after)'{-a,--after}'[after]:datetime:' && ret=0
        ;;
      (datetime|dt)
        _arguments -s -S \
          '--target-timezone=[target timezone]:tz:' \
          '--source-timezone=[source timezone]:tz:' \
          '--parse-format=[parse format]:format:' && ret=0
        ;;
      (serve)
        _arguments -s -S \
          '--port=[port]:port:' \
          '--directory=[directory]:dir:_directories' \
          '--auth=[basic auth]:credentials:' && ret=0
        ;;
      (qr)
        _arguments -s -S \
          '--output=[output PNG file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
