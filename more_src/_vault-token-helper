#compdef vault-token-helper
# _vault-token-helper — secure storage backend for the Vault CLI token (joemiller/vault-token-helper)
# upstream: https://github.com/joemiller/vault-token-helper
# Subcommands from cmd/*.go (cobra).

_vault-token-helper() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file (default ~/.vault-token-helper.yaml)]:file:_files -g "*.(yml|yaml)"' \
        '--debug[enable additional logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'backends:list available token storage backends'
                'enable:write ~/.vault to enable the helper'
                'erase:erase stored token for VAULT_ADDR'
                'get:print stored token for VAULT_ADDR'
                'list:list stored tokens'
                'store:store a token (from stdin) for VAULT_ADDR'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_vault-token-helper "$@"
