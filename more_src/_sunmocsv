#compdef sunmocsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stretching_moveout_resamp/sunmocsv.c
# SUNMOCSV - NMO for an arbitrary velocity function of time and 3D or 2D CDP

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:f:_files' \
  'rfile=[read a K-file with grid definition]:f:_files' \
  'tnmo=[NMO times corresponding to velocities]:t:' \
  'vnmo=[NMO velocities corresponding to times]:v:' \
  'cdp=[CDPs for which vnmo and tnmo are specified]:c:' \
  'smute=[NMO stretch exceeding smute is zeroed]:s:' \
  'lmute=[length (samples) of linear ramp for mute]:l:' \
  'sscale=[=1 divide output by NMO stretch factor]:s:(0 1)' \
  'invert=[=1 perform approximate inverse NMO]:i:(0 1)' \
  'upward=[=1 scan upward to find first sample to kill]:u:(0 1)' \
  'check=[1 print checking details]:c:(0 1)' \
  'print=[print option]:p:' \
  'voutfile=[file for interpolated velocity function]:f:_files' \
  '*:SU file:_files' && ret=0

return ret
