#compdef s6-clock
# Documentation: https://skarnet.org/software/s6-portable-utils/s6-clock.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: s6-clock takes no flags; optional positional TAI64N timestamp argument to set the clock.

local curcontext="$curcontext" ret=1
_arguments -C '*:TAI64N timestamp:' && ret=0
return ret
