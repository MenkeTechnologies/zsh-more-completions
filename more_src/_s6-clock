#compdef s6-clock
# Documentation: https://man.archlinux.org/search?q=s6-clock
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-s[set the clock]' \
  '-r[read the clock]' \
  '-a[adjust the clock]' \
  '*:value:' && ret=0

return ret
