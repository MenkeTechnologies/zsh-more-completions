#compdef strelka-mmrpc
# _strelka-mmrpc — Target Brands Strelka mmrpc multi-master remote-procedure-call helper CLI for sending files directly to Strelka coordinator or frontend bypassing the file-shot harness for testing scanner pipelines (target team, Go); flag
# upstream: https://github.com/target/strelka

_strelka-mmrpc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--frontend=+[host:port]:str:' \
        '--coordinator=+[host:port]:str:' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--client-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--client-key=+[file]:file:_files -g "*.pem *.key"' \
        '--server-name=+[name]:str:' \
        '--insecure[allow self-signed]' \
        '--no-tls[no TLS]' \
        '--source=+[name]:str:' \
        '--scanner=+[csv]:str:' \
        '--tag=+[csv]:str:' \
        '--output=+[file]:file:_files' \
        '--mime=+[mime]:str:' \
        '--timeout=+[d]:str:' \
        '--delete[delete file after submit]' \
        '*:file:_files'
}

_strelka-mmrpc "$@"
