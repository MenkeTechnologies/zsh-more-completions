#compdef dendrite-upgrade-tests
# _dendrite-upgrade-tests — Dendrite upgrade-path test harness (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/dendrite-upgrade-tests/main.go.

_dendrite-upgrade-tests() {
    _arguments \
        '-tmp=[temporary directory for tarballs]:dir:_files -/' \
        '-from=[start version (e.g. 0.3.1 or HEAD-1)]:version:' \
        '-to=[end version (e.g. 0.3.3 or HEAD)]:version:' \
        '-build-concurrency=[image build concurrency]:n:' \
        '-head=[path to a local dendrite repo treated as HEAD]:dir:_files -/' \
        '-docker-host=[docker client hostname]:host:' \
        '-direct[direct upgrade from FROM to TO]' \
        '-sqlite[test SQLite instead of PostgreSQL]' \
        '-repository=[base GitHub repository for tests]:repo:'
}

_dendrite-upgrade-tests "$@"
