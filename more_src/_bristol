#compdef bristol startBristol
# Documentation: https://man.archlinux.org/search?q=bristol
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-engine[run engine only]' \
  '-gui[run GUI only]' \
  '-host+[engine host]:host:_hosts' \
  '-port+[engine port]:port:' \
  '-emulate+[synth model]:model:(mini explorer voyager hammond b3 prophet pro1 odyssey arp2600 axxe juno jupiter dx ms20 obx obxa poly poly6 mono solina vox roadrunner stratus trilogy aks pro52 prophet52 sonic6 trilogy memorymoog rhodes rhodesbass realistic granular sampler)' \
  '-jack[use JACK audio]' \
  '-alsa[use ALSA audio]' \
  '-oss[use OSS audio]' \
  '-pulse[use PulseAudio]' \
  '-osc[OSC server]' \
  '-jdo[disable JACK auto-connect]' \
  '-rate+[sample rate]:rate:(22050 44100 48000 96000)' \
  '-count+[buffer size]:n:' \
  '-preload+[preload voices]:n:' \
  '-voices+[max voices]:n:' \
  '-channel+[midi channel]:ch:' \
  '-velocity[velocity sensitive]' \
  '-debug+[debug level]:lvl:' \
  '-readme[print readme]' && ret=0

return ret
