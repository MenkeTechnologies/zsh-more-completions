#compdef matlab-cli matlab-batch
# _matlab-cli — MathWorks matlab-cli matlab-batch CLI command-line frontend to the MATLAB numerical computing environment running scripts batch noninteractive mode without GUI -nodisplay -nosplash -nodesktop -nojvm -batch -singleCompThread -wait -logfile log-redirection license-checkout for headless server-side compute pipelines (MathWorks team, C); custom argparse
# upstream: https://www.mathworks.com/

_matlab-cli() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-V[show version]' \
        '-v[show version]' \
        '-nodisplay[no display]' \
        '-nodesktop[no desktop]' \
        '-nosplash[no splash screen]' \
        '-nojvm[disable JVM]' \
        '-noFigureWindows[disable figure windows]' \
        '-nofigurewindow[disable figure windows]' \
        '-noopengl[no opengl]' \
        '-softwareopengl[software opengl]' \
        '-singleCompThread[single threaded]' \
        '-batch+[statements]:str:' \
        '-r+[statements]:str:' \
        '-logfile+[file]:file:_files' \
        '-sd+[dir]:dir:_files -/' \
        '-useStartupFolderPref[use startup folder pref]' \
        '-prefdir[print pref dir]' \
        '-glnxa64[64-bit linux]' \
        '-glnx86[32-bit linux]' \
        '-debug[debug]' \
        '-c+[license file]:file:_files' \
        '-licmode=+[mode]:m:(file local network)' \
        '-mlint=+[args]:str:' \
        '-wait[wait]' \
        '-automation[automation server]' \
        '-version[show version]' \
        '-info[show info]' \
        '*:m-file:_files -g "*.m *.mlx *.mat"'
}

_matlab-cli "$@"
