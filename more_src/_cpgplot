#compdef cpgplot
# Documentation: https://man.archlinux.org/search?q=cpgplot
# Reference accessed: 2026-05-16

# EMBOSS cpgplot: identify and plot CpG islands in nucleotide sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-window=[window size to scan]:size:' \
  '-minlen=[minimum CpG island length]:length:' \
  '-minoe=[minimum CpG observed/expected ratio]:ratio:' \
  '-minpc=[minimum %CG content]:pct:' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfeat=[features output file]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
