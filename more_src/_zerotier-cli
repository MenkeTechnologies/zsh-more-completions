#compdef zerotier-cli

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'info:Display status info'
  'listpeers:List all peers'
  'peers:List all peers (alias)'
  'listnetworks:List all networks'
  'join:Join a network'
  'leave:Leave a network'
  'set:Set a network setting'
  'get:Get a network setting'
  'listmoons:List moons'
  'orbit:Join a moon'
  'deorbit:Leave a moon'
  'dump:Debug dump'
  'bond:Manage bonding'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-j[JSON output]' \
  '-D[specify home directory]:dir:_directories' \
  '-p[specify port]:port:' \
  '-T[specify auth token file]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'zerotier-cli command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      join)
        _arguments \
          '--token=[authentication token]:token:' \
          '--allow-managed[allow managed addresses]' \
          '--allow-global[allow global IP assignment]' \
          '--allow-default[allow default route override]' \
          '--allow-dns[allow DNS configuration]' \
          '1:network ID:' && ret=0
        ;;
      leave)
        _arguments \
          '1:network ID:' && ret=0
        ;;
      set)
        _arguments \
          '1:network ID:' \
          '2:property:' \
          '3:value:' && ret=0
        ;;
      get)
        _arguments \
          '1:network ID:' \
          '2:property:' && ret=0
        ;;
      orbit)
        _arguments \
          '1:moon ID:' \
          '2:seed:' && ret=0
        ;;
      deorbit)
        _arguments \
          '1:moon ID:' && ret=0
        ;;
    esac
    ;;
esac

return ret
