#compdef 3dREMLfit
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dREMLfit.html
# AFNI generalized least squares (REML) fit with ARMA(1,1) noise model

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-input[read time series dataset]:dataset:_files' \
  '-matrix[read regression matrix from 3dDeconvolve]:file:_files' \
  '-polort[Legendre polynomial regressors up to order]:P' \
  '-matim[read standard .1D file as matrix]:file:_files' \
  '-mask[apply mask to input dataset]:dataset:_files' \
  '-automask[build mask automatically from voxel RMS]' \
  '-STATmask[mask for FDR curve computation only]:dataset:_files' \
  '-addbase[append baseline model columns from .1D file]:file:_files' \
  '-dsort[add voxel-wise baseline regressor from dataset]:dataset:_files' \
  '-dsort_nods[compare results with and without -dsort]' \
  '-slibase[add slice-dependent baseline regressors]:file:_files' \
  '-slibase_sm[slice-dependent regressors slice-major order]:file:_files' \
  '-usetemp[write intermediate data to disk]' \
  '-nodmbase[skip mean removal from baseline columns]' \
  '-Rvar[save REML variance parameters]:prefix' \
  '-Rbeta[save REML beta weights]:prefix' \
  '-Rbuck[save REML beta + statistics]:prefix' \
  '-Rglt[save REML results for command-line GLTs only]:prefix' \
  '-Rfitts[save REML fitted model]:prefix' \
  '-Rerrts[save REML residuals]:prefix' \
  '-Rwherr[save whitened REML residuals]:prefix' \
  '-Ovar[save OLSQ standard deviation parameter]:prefix' \
  '-Obeta[save OLSQ beta weights]:prefix' \
  '-Obuck[save OLSQ beta + statistics]:prefix' \
  '-Oglt[save OLSQ GLT results]:prefix' \
  '-Ofitts[save OLSQ fitted model]:prefix' \
  '-Oerrts[save OLSQ residuals]:prefix' \
  '-fout[include F-statistics in bucket dataset]' \
  '-rout[include R-squared statistics in bucket]' \
  '-tout[include t-statistics in bucket dataset]' \
  '-noFDR[omit FDR curve data from bucket datasets]' \
  '-nobout[exclude baseline regressor betas from output]' \
  '-gltsym[read symbolic GLT and assign label]:spec' \
  '-MAXa[maximum AR parameter]:am' \
  '-MAXb[maximum MA parameter]:bm' \
  '-Grid[grid resolution for (a,b) parameter space]:pp' \
  '-NEGcor[allow negative correlations]' \
  '-POScor[restrict to positive correlations (default)]' \
  '-WNplus[use AR(1) + white noise model]' \
  '-Mfilt[apply 3D median filter to parameters]:mr' \
  '-CORcut[correlation matrix cutoff threshold]:cc' \
  '-ABfile[read ARMA parameters from dataset]:dataset:_files' \
  '-GOFORIT[force continuation despite collinearity]' \
  '-quiet[suppress progress messages]' \
  '-verb[display additional progress messages]' \
  '*:dataset:_files' && ret=0

return ret
