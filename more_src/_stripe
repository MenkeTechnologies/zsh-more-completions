#compdef stripe

local -a _stripe_commands
_stripe_commands=(
  'balance:manage balance'
  'charges:manage charges'
  'completion:generate shell completion'
  'config:manage configuration'
  'customers:manage customers'
  'events:manage events'
  'feedback:send feedback'
  'fixtures:manage test fixtures'
  'get:make GET requests'
  'help:show help'
  'listen:listen for webhook events'
  'login:log in'
  'logout:log out'
  'logs:interact with Stripe logs'
  'open:open Stripe pages in browser'
  'payment_intents:manage payment intents'
  'payouts:manage payouts'
  'post:make POST requests'
  'delete:make DELETE requests'
  'prices:manage prices'
  'products:manage products'
  'refunds:manage refunds'
  'resources:list API resources'
  'samples:manage sample integrations'
  'serve:serve static files for webhooks'
  'status:show Stripe system status'
  'subscriptions:manage subscriptions'
  'trigger:trigger webhook events'
  'version:show version'
  'whoami:show current user'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-key[API key]:key' \
  '--color[color output]:color:(auto on off)' \
  '--config[config file]:file:_files' \
  '--device-name[device name]:name' \
  '--log-level[log level]:level:(debug info warn error)' \
  '--project-name[project name]:name' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'stripe commands' _stripe_commands
    ;;
  args)
    case "$words[1]" in
      listen)
        _arguments \
          '(-e --events)'{-e,--events}'[events to listen for]:events' \
          '(-f --forward-to)'{-f,--forward-to}'[forward URL]:url' \
          '--forward-connect-to[forward Connect URL]:url' \
          '(-c --headers)'{-c,--headers}'[headers to forward]:headers' \
          '(-l --latest)'{-l,--latest}'[receive latest payload version]' \
          '--live[listen in live mode]' \
          '--load-from-webhooks-api[load from webhooks API]' \
          '--print-json[print JSON]' \
          '--skip-verify[skip TLS verification]'
        ;;
      trigger)
        _arguments \
          '--stripe-account[connected account]:account' \
          '--override[parameter override]:override' \
          '--skip-confirm[skip confirmation]' \
          '--raw[raw JSON request]:json' \
          '1:event:(charge.captured charge.failed charge.succeeded checkout.session.completed customer.created customer.updated customer.subscription.created customer.subscription.deleted customer.subscription.updated invoice.created invoice.finalized invoice.paid invoice.payment_failed invoice.payment_succeeded payment_intent.canceled payment_intent.created payment_intent.payment_failed payment_intent.succeeded)'
        ;;
      get|post|delete)
        _arguments \
          '(-d --data)'{-d,--data}'[request data]:data' \
          '(-e --expand)'{-e,--expand}'[expand field]:field' \
          '(-i --idempotency)'{-i,--idempotency}'[idempotency key]:key' \
          '--stripe-account[connected account]:account' \
          '(-s --show-headers)'{-s,--show-headers}'[show response headers]' \
          '--api-version[API version]:version' \
          '--live[use live mode]' \
          '*:path'
        ;;
      login)
        _arguments \
          '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
          '--api-key[API key]:key' \
          '--project-name[project name]:name'
        ;;
      logs)
        _arguments '1:subcommand:(tail)' \
          '(-f --filter-account)'{-f,--filter-account}'[filter by account]:account' \
          '--filter-http-method[filter by method]:method:(GET POST DELETE)' \
          '--filter-ip-address[filter by IP]:ip' \
          '--filter-request-path[filter by path]:path' \
          '--filter-request-status[filter by status]:status:(succeeded failed)' \
          '--filter-source[filter by source]:source:(api dashboard)' \
          '--filter-status-code[filter by status code]:code' \
          '--filter-status-code-type[filter by code type]:type:(2XX 4XX 5XX)' \
          '--live[use live mode]'
        ;;
      open)
        _arguments '1:page:(api dashboard docs logs events webhooks)'
        ;;
      samples)
        _arguments '1:subcommand:(create list)' '*:args'
        ;;
      config)
        _arguments '1:subcommand:(--list --set --unset --edit)' '*:args'
        ;;
      resources)
        _arguments '--api-version[API version]:version'
        ;;
    esac
    ;;
esac
