#compdef vcctl
# Documentation: https://github.com/volcano-sh/volcano/tree/master/cmd/cli
# Reference accessed: 2026-05-21
# Verified: upstream Volcano scheduler CLI source layout.
# STUB: vcctl bundles subcommands (job, queue, jobflow, jobtemplate); exhaustive flags not enumerated upstream.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'job:manage jobs'
  'queue:manage queues'
  'jobflow:manage job flows'
  'jobtemplate:manage job templates'
)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'vcctl command' commands && ret=0 ;;
esac
return ret
