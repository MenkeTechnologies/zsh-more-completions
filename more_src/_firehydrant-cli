#compdef firehydrant-cli fh
# _firehydrant-cli — FireHydrant firehydrant-cli CLI command-line frontend wrapping the FireHydrant incident management response automation reliability platform REST API providing incident service team runbook environment functionality severity priority milestone status-page retrospective change-event ticketing-integration slack-bot terraform-importer signal alert (FireHydrant team Robert Ross, Go); cobra
# upstream: https://firehydrant.com/

_firehydrant-cli() {
    local -a sub=(
        'init:initialize config'
        'auth:authenticate'
        'whoami:show identity'
        'incident:incident operations'
        'service:service operations'
        'team:team operations'
        'runbook:runbook operations'
        'environment:environment operations'
        'functionality:functionality operations'
        'severity:severity operations'
        'priority:priority operations'
        'status-page:status page operations'
        'retrospective:retrospective operations'
        'change-event:change event operations'
        'signal:signal operations'
        'alert:alert operations'
        'terraform-import:terraform import'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'firehydrant subcommand' sub ;;
        args)
            case $words[1] in
                incident|service|team|runbook|environment|functionality|severity|priority|status-page|retrospective|change-event|signal|alert) _arguments '1:op:(list get create update delete close resolve open mitigate archive restore)' '*:id:' ;;
                auth) _arguments '1:op:(login logout status)' '*:arg:' ;;
            esac
            ;;
    esac
}

_firehydrant-cli "$@"
