#compdef paru

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-S[sync]' \
  '-R[remove]' \
  '-Q[query]' \
  '-D[database]' \
  '-U[upgrade]' \
  '-F[files]' \
  '-G[get PKGBUILD]' \
  '-P[show]' \
  '-L[repoctl]' \
  {-a,--aur}'[AUR only]' \
  '--repo[repo only]' \
  '--gendb[generate development database]' \
  {-c,--clean}'[clean unneeded dependencies]' \
  {-u,--sysupgrade}'[upgrade packages]' \
  {-s,--search}'[search]:query' \
  {-i,--info}'[show info]' \
  {-l,--list}'[list packages]' \
  '--provides[search for package provides]' \
  {-d,--deps}'[only deps]' \
  {-e,--explicit}'[only explicit]' \
  '--upgrade[upgrade installed packages]' \
  '--needed[do not reinstall up-to-date packages]' \
  '--noconfirm[skip confirmation]' \
  '--pgpfetch[fetch PGP keys]' \
  '--newsonupgrade[show news on upgrade]' \
  '--combinedupgrade[combined upgrade]' \
  '--devel[check development packages]' \
  '--develsuffixes=[devel suffixes]:suffixes' \
  '--removemake[remove make dependencies after install]' \
  '--upgrademenu[show upgrade menu]' \
  '--aururl=[AUR URL]:url' \
  '--clonedir=[clone directory]:directory:_directories' \
  '--makepkg=[makepkg path]:makepkg:_files' \
  '--pacman=[pacman path]:pacman:_files' \
  '--git=[git path]:git:_files' \
  '--gpg=[gpg path]:gpg:_files' \
  '--sudo=[sudo path]:sudo:_files' \
  '--bat[use bat for PKGBUILD display]' \
  '--pager=[pager]:pager' \
  '*:package' \
  && ret=0
return ret
