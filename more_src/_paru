#compdef paru
# Documentation: https://github.com/Morganamilo/paru/blob/master/man/paru.8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-D --database)'{-D,--database}'[operate on package database]' \
  '(-F --files)'{-F,--files}'[operate on package files]' \
  '(-Q --query)'{-Q,--query}'[query installed packages]' \
  '(-R --remove)'{-R,--remove}'[remove packages]' \
  '(-S --sync)'{-S,--sync}'[sync packages]' \
  '(-T --deptest)'{-T,--deptest}'[check dependencies]' \
  '(-U --upgrade)'{-U,--upgrade}'[install from local file]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-P --show)'{-P,--show}'[paru show operation]' \
  '(-G --getpkgbuild)'{-G,--getpkgbuild}'[download PKGBUILD]' \
  '(-B --build)'{-B,--build}'[build PKGBUILDs on disk]' \
  '(-L --repoctl)'{-L,--repoctl}'[manage local repos]' \
  '(-C --chrootctl)'{-C,--chrootctl}'[chroot management]' \
  '(-a --aur)'{-a,--aur}'[target AUR packages only]' \
  '--repo[target repository packages only]' \
  '--pkgbuilds[target PKGBUILD repositories]' \
  '--mode=[package source mode]:mode:(any aur repo pkgbuild)' \
  '--interactive[enable interactive selection]' \
  '--aururl=[AUR URL]:url:' \
  '--aurrpcurl=[AUR RPC endpoint URL]:url:' \
  '--clonedir=[clone directory]:directory:_directories' \
  '--makepkg=[makepkg command]:command:_files' \
  '--makepkgconf=[makepkg.conf file]:file:_files' \
  '--pacman=[pacman command]:command:_files' \
  '--pacman-conf=[pacman-conf command]:command:_files' \
  '--git=[git command]:command:_files' \
  '--gitflags=[git arguments]:flags:' \
  '--gpg=[gpg command]:command:_files' \
  '--gpgflags=[gpg arguments]:flags:' \
  '--fm=[file manager for review]:command:_files' \
  '--fmflags=[file manager arguments]:flags:' \
  '--sudo=[sudo command]:command:_files' \
  '--sudoflags=[sudo arguments]:flags:' \
  '--bat=[bat command]:command:_files' \
  '--batflags=[bat arguments]:flags:' \
  '--mflags=[makepkg arguments]:flags:' \
  '--chrootflags=[makechrootpkg arguments]:flags:' \
  '--completioninterval=[completion cache refresh in days]:days:' \
  '--sortby=[sort AUR results]:field:(votes popularity id name basename submitted modified)' \
  '--searchby=[search field]:field:(name name-desc maintainer depends checkdepends makedepends optdepends)' \
  '--skipreview[skip review process]' \
  '--review[do not skip review]' \
  '--upgrademenu[show upgrade menu]' \
  '--noupgrademenu[hide upgrade menu]' \
  '--removemake=[remove make dependencies]:choice:(yes no ask)' \
  '--noremovemake[keep make dependencies]' \
  '--topdown[print results top to bottom]' \
  '--bottomup[print results bottom to top]' \
  '--limit=[limit number of search results]:limit:' \
  '(-x --regex)'{-x,--regex}'[enable regex for AUR search]' \
  '--nocheck[skip checkdepends]' \
  '--installdebug[install debug packages]' \
  '--noinstalldebug[skip debug packages]' \
  '--devel[check development packages]' \
  '--ignoredevel[ignore devel upgrades]' \
  '--nodevel[skip devel checks]' \
  '--develsuffixes=[devel package suffixes]:suffixes:' \
  '--cleanafter[remove untracked files]' \
  '--nocleanafter[keep sources]' \
  '--redownload=[download PKGBUILDs]:choice:(yes no all)' \
  '--noredownload[use cached PKGBUILDs]' \
  '--provides[search providers]' \
  '--noprovides[do not search providers]' \
  '--pgpfetch[import PGP keys]' \
  '--nopgpfetch[do not import PGP keys]' \
  '--newsonupgrade[print news during upgrade]' \
  '--useask[use pacman --ask flag]' \
  '--nouseask[manual conflict resolution]' \
  '--savechanges[commit PKGBUILD changes]' \
  '--nosavechanges[do not commit changes]' \
  '--failfast[exit on first AUR build failure]' \
  '--nofailfast[continue on failures]' \
  '--keepsrc[keep src/pkg directories]' \
  '--nokeepsrc[remove src/pkg directories]' \
  '--combinedupgrade[combined repo and AUR upgrade]' \
  '--nocombinedupgrade[separate upgrades]' \
  '--batchinstall[batch queued packages]' \
  '--nobatchinstall[install immediately]' \
  '--rebuild=[force rebuild]:choice:(yes no all tree)' \
  '--norebuild[use cached packages]' \
  '--sudoloop[prevent sudo timeout]' \
  '--nosudoloop[do not loop sudo]' \
  '--gendb[generate development database]' \
  '*:package:' \
  && ret=0
return ret
