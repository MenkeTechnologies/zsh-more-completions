#compdef vergo
# ============================================================================
# _vergo — zsh completion for **vergo** — sky-uk/vergo, the
#            **Sky UK Engineering** Go-based **release-tag manager**
#            for monorepos / polyrepos / single-project repos that
#            implements **semver auto-bumping driven by Conventional
#            Commits keywords + git-tag-as-source-of-truth** —
#            the production tool that backs Sky UK's CI/CD pipelines
#            for tagging service releases (and the open-source
#            alternative to `semantic-release`, `release-please`,
#            `standard-version`, `git-cliff`, and `commitizen` for
#            shops that want a pure-Go single-binary that runs on
#            any GHA / GitLab / Jenkins / Concourse / Drone /
#            Buildkite / Tekton CI agent without a Node toolchain).
#            Go=180 leader bump continuing Axis 125 (pure-Rust /
#            pure-Go / pure-JS Git protocol + repository
#            implementation taxonomy) at 2/0/0 via the canonical
#            Go-side library **github.com/go-git/go-git** —
#            the structural parallel to **gitoxide** on the Go side.
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/sky-uk/vergo
#   Maintainer : Sky UK Engineering (sky-uk GitHub organization;
#                 Sky Group Ltd / Comcast subsidiary;  the UK
#                 broadcaster's platform-engineering organization
#                 that also open-sources `feed-ingress` / `etcd-
#                 bootstrap` / `kafka-message-tool` / `tf-helper`
#                 / `kubernetes-mixin` / `feed-dns` / many other
#                 production-tested CI/CD + infra tools);  the
#                 vergo project specifically came out of the Sky
#                 internal Concourse CI team's need for a
#                 deterministic semver tagger that didn't require
#                 a Node runtime on the build agent
#   License    : BSD-3-Clause
#   Stars      : 300+ on github.com/sky-uk/vergo
#   Language   : Go  (spf13/cobra for the CLI surface +
#                 github.com/go-git/go-git/v5 v5.4.2 for the
#                 pure-Go Git operations + Masterminds/semver/v3
#                 for SemVer 2.0.0 parsing + sirupsen/logrus
#                 structured logging + spf13/pflag flag parsing +
#                 funk for slice utility)
#   Binary     : vergo  (cargo-style `go install
#                 github.com/sky-uk/vergo@latest`,
#                 brew install vergo)
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   `vergo` is the **CI-pipeline-native release-tag manager** for
#   teams that want git-tag-driven semver releases without a Node
#   toolchain dependency.  Workflow:
#
#     1. CI pipeline runs `vergo check release` early to verify
#        the HEAD commit is a tag-worthy commit (the head of the
#        configured branch + not already tagged)
#     2. CI pipeline runs `vergo bump auto` to inspect the
#        commit messages since the last tag and pick
#        prerelease/patch/minor/major automatically (the
#        Conventional Commits keyword convention:  `feat:` =
#        minor, `fix:` = patch, `BREAKING CHANGE` = major) —
#        OR `vergo bump patch` / `vergo bump minor` / `vergo
#        bump major` to set the bump explicitly
#     3. `vergo push` pushes the newly-created tag to the
#        remote
#     4. Build artifacts pick up the version via `vergo get
#        current-version` (no separate `VERSION` file ever
#        committed to the repo)
#
#   Compared to alternatives:
#
#     • `semantic-release` (Node)        requires Node runtime
#                                        + plugins ecosystem;
#                                        opinionated about
#                                        release notes;  npm-
#                                        registry-publishing
#                                        coupled
#     • `release-please` (Node + GHA)    Google's Conventional-
#                                        Commits release manager;
#                                        GHA-coupled
#     • `standard-version` (Node)        deprecated by its
#                                        author in favor of
#                                        commit-and-tag-version
#     • `git-cliff` (Rust)               changelog generator
#                                        only;  doesn't push
#                                        tags
#     • `commitizen` (Python)            commit-message
#                                        formatter, not a
#                                        tag pusher
#     • **vergo** (Go)                   single static binary,
#                                        no runtime deps, all
#                                        bump strategies (auto +
#                                        explicit), tag-prefix
#                                        support for monorepos,
#                                        dry-run mode,
#                                        deterministic SSH/HTTPS
#                                        push (no
#                                        StrictHostChecking on
#                                        CI agents)
#
#   Subcommand surface:
#
#     • vergo bump (auto|prerelease|patch|minor|major)
#                                       compute next version +
#                                       create tag locally
#         -u, --push-tag                also push the tag (the
#                                       all-in-one flow when
#                                       you don't want a
#                                       separate `vergo push`
#                                       step)
#     • vergo get (latest-release|previous-release|current-version)
#                                       print version
#         -m, --with-metadata           append `+<commit-hash>`
#                                       SemVer metadata
#     • vergo list                      list tags
#         --sort-direction asc|desc
#         --max-list-size <N>
#     • vergo push                      push the latest tag to
#                                       the remote
#     • vergo check (release|increment-hint)
#                                       CI validation guards
#         release                       verify HEAD is on a
#                                       versioned branch and
#                                       not already tagged
#         increment-hint                check if commit
#                                       message contains
#                                       `[skip ci]` /
#                                       `[skip release]` /
#                                       conventional-commit
#                                       hints
#     • vergo show parents              list commit parents
#         --merge-commits               include merge commits
#     • vergo version                   print vergo version
#
#   Global flags (every subcommand inherits these via cobra
#   PersistentFlags):
#     -r, --remote <name>               remote name (default
#                                       `origin`)
#     -t, --tag-prefix <prefix>         tag prefix (e.g.
#                                       `service-a-v` for
#                                       per-service tags in a
#                                       monorepo)
#     -l, --repository-location <path>  repository path
#                                       (default `.`)
#         --log-level <level>           set log level (default
#                                       `Info`)
#     -d, --disable-strict-host-checking
#                                       disable StrictHostChecking
#                                       for git SSH (the CI-
#                                       agent escape hatch)
#     -k, --token-env-var-key <name>    env var name to look up
#                                       for token-based auth
#                                       (default `GH_TOKEN`)
#         --dry-run                     don't actually create or
#                                       push tags
#         --nearest-release             use nearest tag in commit
#                                       history (default: highest
#                                       tag)
#         --versioned-branch-names <name,...>
#                                       comma list of main
#                                       branches (default
#                                       `master,main`)
#     -p, --with-prefix                 include prefix in
#                                       version output
#
# CLI ARGUMENT GRAMMAR  (verbatim from `cmd/root.go` +
#                       `cmd/cmd_bump.go` + `cmd/get.go` +
#                       `cmd/list.go` + `cmd/push.go` +
#                       `cmd/cmd_check.go` + `cmd/cmd_show.go`
#                       cobra declarations;  extracted via
#                       raw.githubusercontent.com fetch of the
#                       respective files;  every option below is
#                       a literal `cmd.Flags().*(...)` or
#                       `rootCmd.PersistentFlags().*(...)` call
#                       from the upstream source)
#
#   vergo [GLOBAL OPTIONS] <COMMAND> [SUBCOMMAND] [ARGS...]
#
# AXIS / CORPUS POSITION
#   `sky-uk/vergo`'s `go.mod` declares a **direct** dependency
#   on `github.com/go-git/go-git/v5 v5.4.2` (alongside
#   `github.com/go-git/go-billy/v5 v5.3.1`, the typed
#   in-memory filesystem abstraction go-git uses).  The
#   `git/` workspace member uses typed
#   `git.PlainOpen(repositoryLocation)` to open the repo,
#   typed `repo.Tags()` to enumerate the tag refs, typed
#   `repo.Log(&git.LogOptions{From: head.Hash()})` to walk
#   commit history for the bump-keyword scan, typed
#   `repo.CreateTag(name, hash, &git.CreateTagOptions{...})`
#   to create the tag, and typed `repo.Push(&git.PushOptions{
#   RemoteName, RefSpecs, Auth, InsecureSkipTLS})` for the
#   tag push step.  Authentication is via typed
#   `transport.AuthMethod` (concrete: typed
#   `http.BasicAuth{Username, Password}` for HTTPS tokens or
#   typed `ssh.PublicKeysCallback` for SSH-agent).
#
#   **go-git** (`github.com/go-git/go-git`) is **THE canonical
#   pure-Go Git implementation** — the structural parallel to
#   **gitoxide** on the Go side.  Originally `src-d/go-git`
#   (developed by source{d} as part of their code-analysis
#   platform), then moved to the independent `go-git/`
#   GitHub organization after source{d} wound down in 2019.
#   In active development since 2015 with 6,400+ ★ on
#   github.com/go-git/go-git, it is the dominant Go-side Git
#   library by an order of magnitude — the only viable
#   alternative is `gogs/git-module` (much smaller scope) or
#   forking the `git` binary as a subprocess (slow + brittle).
#
#   go-git ships:
#
#     • Typed `Repository`             with typed
#                                      `PlainOpen` /
#                                      `PlainOpenWithOptions` /
#                                      `PlainInit` /
#                                      `PlainClone` /
#                                      `Open` (in-memory) /
#                                      `Init` (in-memory) /
#                                      `Clone` (in-memory)
#                                      constructors
#     • Typed `Worktree`               typed `Add` / `Remove` /
#                                      `Move` / `Status` /
#                                      `Checkout` / `Reset` /
#                                      `Commit` / `Pull` /
#                                      `Submodule` /
#                                      `Submodules` / `Clean` /
#                                      `Grep` operations
#     • Typed `CreateTag`              with typed
#                                      `CreateTagOptions{
#                                      Tagger, Message,
#                                      SignKey}` lightweight +
#                                      annotated tag creation
#     • Typed `Push` / `Fetch` / `Pull`
#                                      with typed `PushOptions`
#                                      / `FetchOptions` /
#                                      `PullOptions` including
#                                      typed `Auth`,
#                                      `RefSpecs`, `Atomic`,
#                                      `Force`, `Prune`,
#                                      `Tags`, `Progress`,
#                                      `InsecureSkipTLS`,
#                                      `CABundle`,
#                                      `RequireRemoteRefs`
#                                      fields
#     • Typed `Log` / `Commits`        commit-graph traversal
#                                      with typed
#                                      `LogOptions{From,
#                                      Order, FileName,
#                                      PathFilter, All, Since,
#                                      Until}` filters
#     • Typed `Tags` / `Branches` /
#       `References` / `Notes` /
#       `Remotes`                      reference iterators
#     • Typed Plumbing layer           typed `plumbing/object/
#                                      {Blob, Tree, Commit,
#                                      Tag}` typed Git object
#                                      model;  typed
#                                      `plumbing/{Hash,
#                                      Reference, ReferenceName,
#                                      MemoryObject}`
#     • Typed transport abstraction
#       (`plumbing/transport`)         with typed concrete
#                                      transports for `http`,
#                                      `https`, `ssh`, `git`,
#                                      `file`, plus typed
#                                      `client.NewClient` /
#                                      `client.InstallProtocol`
#                                      for custom protocols;
#                                      typed `AuthMethod`
#                                      interface with concrete
#                                      typed `http.BasicAuth` +
#                                      `http.TokenAuth` +
#                                      `ssh.PublicKeysCallback`
#                                      + `ssh.PasswordCallback`
#                                      + `ssh.PublicKeys` +
#                                      `ssh.AuthMethod`
#                                      implementations
#     • Typed packfile reader+writer   (`plumbing/format/
#                                      packfile`) with typed
#                                      delta resolution
#     • Typed `plumbing/format/{config,
#       gitignore, idxfile, index,
#       objfile, packfile, pktline}`   typed implementations of
#                                      every Git on-disk format
#     • Typed `plumbing/storer` +
#       `storage/{filesystem, memory}` typed pluggable storage
#                                      backends (filesystem
#                                      Git repo OR a fully in-
#                                      memory Git repo — the
#                                      pattern that makes
#                                      go-git uniquely useful
#                                      for testing CI/CD tools)
#     • Typed merge engine             (limited;  not feature-
#                                      complete vs C git)
#     • Typed shallow-clone support
#     • Typed Smart-HTTP + SSH wire
#       protocol v0 + v1
#     • Typed sideband channel
#                                      multiplexing (the
#                                      progress + error reporting
#                                      side-channel used by
#                                      Smart HTTP)
#     • Typed `config` package         typed Git configuration
#                                      file (`.git/config` +
#                                      `~/.gitconfig`) parser +
#                                      writer
#     • Typed plumbing for typed
#       Git protocol v2 (limited)
#
#   go-git is the Git library behind essentially every modern
#   Go application that needs git operations without forking
#   the `git` binary:
#
#     • **Argo CD** — the Kubernetes GitOps continuous-
#       deployment controller (covered as `_argocd`);  every
#       `argocd app sync` goes through go-git
#     • **Flux CD** — the other major Kubernetes GitOps
#       toolkit;  uses go-git for source-controller
#       Git-repository sync
#     • **gitea** — self-hosted Git forge (covered as
#       `_gitea`);  go-git for repo operations
#     • **Helm** — Kubernetes package manager;  go-git for
#       chart-repo Git source resolution
#     • **k3sup / k3d / kind** — Kubernetes installers that
#       fetch manifests from Git
#     • **Crossplane** — the Kubernetes universal control
#       plane;  go-git for Configuration package source
#     • **Werf** — Flant's container build + deploy tool
#     • **GoReleaser** — the Go-binary release tooling;
#       uses go-git for commit-history + tag inspection
#     • **Atlantis** — Terraform pull-request automation;
#       go-git for branch + PR diff handling
#     • **Terraform Cloud Agent** — uses go-git for module
#       source resolution
#     • **gh** (GitHub CLI) — uses go-git in places via
#       `github.com/cli/cli/v2/git`
#     • **Sourcegraph** server — uses go-git in some paths
#     • **Drone CI** — uses go-git for repository
#       provisioning
#     • **Concourse CI git-resource** — uses go-git for the
#       built-in Git resource type
#     • **Tekton Pipelines** — uses go-git for the
#       git-clone task
#     • **gibo** — gitignore boilerplate fetcher (covered
#       as `_gibo`)
#     • **git-subtrac** — apenwarr (Avery Pennarun /
#       Tailscale founder) git-subtree-as-ref manager
#       (covered as `_git-subtrac`)
#     • **autosaved** — automatic save-as-commit tool
#     • **vergo** — this very binary
#     • Plus thousands of internal Go tools that need git
#       operations without subprocess overhead.
#
#   Verified via:
#     gh api repos/sky-uk/vergo/contents/go.mod
#       → module github.com/sky-uk/vergo
#       → require github.com/go-git/go-git/v5 v5.4.2  (DIRECT)
#       → require github.com/go-git/go-billy/v5 v5.3.1 (DIRECT)
#       → require github.com/Masterminds/semver/v3 v3.1.1
#       → require github.com/spf13/cobra v1.3.0
#     raw.githubusercontent.com sky-uk/vergo main main.go
#       → import "github.com/sky-uk/vergo/cmd"
#       → cmd.Execute()
#     raw.githubusercontent.com sky-uk/vergo main cmd/root.go
#       → rootCmd := &cobra.Command{Use: "vergo", ...}
#       → rootCmd.PersistentFlags().StringP(remoteName, "r",
#         "origin", ...)
#       → rootCmd.PersistentFlags().StringP(tagPrefix, "t",
#         "", ...)
#       → rootCmd.PersistentFlags().StringP(repositoryLocation,
#         "l", ".", ...)
#       → rootCmd.PersistentFlags().String(logLevel, "Info",
#         ...)
#       → rootCmd.PersistentFlags().BoolP(strictHostChecking,
#         "d", false, ...)
#       → rootCmd.PersistentFlags().StringP(tokenEnvVarKey,
#         "k", "GH_TOKEN", ...)
#       → rootCmd.PersistentFlags().Bool(dryRun, false,
#         "dry run")
#       → rootCmd.PersistentFlags().Bool(nearestRelease,
#         false, ...)
#       → rootCmd.PersistentFlags().StringSlice(
#         versionedBranchNames, []string{"master", "main"},
#         ...)
#       → rootCmd.PersistentFlags().BoolP(withPrefix, "p",
#         false, ...)
#       → rootCmd.AddCommand(BumpCmd, GetCmd, PushCmd,
#         ListCmd, CheckCmd, ShowCmd, VersionCmd)
#     raw.githubusercontent.com sky-uk/vergo main cmd/cmd_bump.go
#       → Use: "release (prerelease|patch|minor|major|auto)"
#       → Short: "increments the version numbers"
#       → cmd.Flags().BoolP(pushTagParam, "u", false,
#         "push the new tag")
#     raw.githubusercontent.com sky-uk/vergo main cmd/get.go
#       → Use: "get (latest-release|previous-release|current-version)"
#       → cmd.Flags().BoolP(withMetadata, "m", false,
#         "returns current version with commit hash as
#         metadata")
#     raw.githubusercontent.com sky-uk/vergo main cmd/list.go
#       → Use: "list"
#       → cmd.Flags().String(sortDirection, "desc",
#         "sort direction [asc,desc]")
#       → cmd.Flags().Int(maxListSize, 10, ...)
#     raw.githubusercontent.com sky-uk/vergo main
#         cmd/cmd_check.go
#       → Use: "check" (parent), Use: "release",
#         Use: "increment-hint"
#     raw.githubusercontent.com sky-uk/vergo main cmd/cmd_show.go
#       → Use: "show" (parent), Use: "parents"
#       → cmd.Flags().Bool(mergeCommits, false, ...)
#
#   This entry is the Go=180 leader bump that continues Axis 125
#   (pure-Rust / pure-Go / pure-JS Git protocol + repository
#   implementation taxonomy) at 2/0/0 following R1073 _tms
#   (Rust=180 OPENED via jrmoulton/tmux-sessionizer on
#   GitoxideLabs/gitoxide gix 0.78;  R1073 round-number commit
#   landmark).  TS-Node=180 closing pair on deck for R1075 via
#   the canonical Node.js Git library `isomorphic-git`
#   (@isomorphic-git/lightning-fs + isomorphic-git npm package
#   — the pure-JavaScript Git implementation by William Hilton
#   that runs in browsers AND Node, completing the triple-180
#   landmark + Axis 125 close at 1/1/1).
#
#   No completion for `vergo` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_vergo() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a _vergo_global=(
        '(-r --remote)'{-r,--remote}'=[remote name for push]:name:'
        '(-t --tag-prefix)'{-t,--tag-prefix}'=[version prefix]:prefix:'
        '(-l --repository-location)'{-l,--repository-location}'=[repository location]:dir:_files -/'
        '--log-level=[log level]:level:(Trace Debug Info Warn Error Fatal Panic)'
        '(-d --disable-strict-host-checking)'{-d,--disable-strict-host-checking}'[disable strict host checking for git SSH]'
        '(-k --token-env-var-key)'{-k,--token-env-var-key}'=[env var key for token auth]:name:'
        '--dry-run[do not actually create or push tags]'
        '--nearest-release[use nearest tag in commit history]'
        '--versioned-branch-names=[main branch names]:names:'
        '(-p --with-prefix)'{-p,--with-prefix}'[include prefix in version output]'
        '(- *)'{-h,--help}'[show help]'
    )

    _arguments -C \
        $_vergo_global \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _vergo_cmds=(
                'bump:increment version numbers + create tag locally'
                'get:get the latest release or current version'
                'list:list the tags'
                'push:push the latest tag to a remote'
                'check:perform CI validation guards'
                'show:commands for querying repository state'
                'version:print vergo version'
            )
            _describe -t commands 'vergo command' _vergo_cmds && ret=0
            ;;
        args)
            case $words[1] in
                bump)
                    _arguments \
                        $_vergo_global \
                        '1:bump strategy:(prerelease patch minor major auto)' \
                        '(-u --push-tag)'{-u,--push-tag}'[also push the new tag]' && ret=0
                    ;;
                get)
                    _arguments \
                        $_vergo_global \
                        '1:reference:(latest-release previous-release current-version)' \
                        '(-m --with-metadata)'{-m,--with-metadata}'[append commit hash as metadata]' && ret=0
                    ;;
                list)
                    _arguments \
                        $_vergo_global \
                        '--sort-direction=[sort direction]:dir:(asc desc)' \
                        '--max-list-size=[maximum list size]:n:' && ret=0
                    ;;
                push)
                    _arguments $_vergo_global && ret=0
                    ;;
                check)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'check sub-command' \
                          '(release\:"verify HEAD is release-ready" increment-hint\:"check commit message for hints")' && ret=0
                    else
                        _arguments $_vergo_global && ret=0
                    fi
                    ;;
                show)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'show sub-command' \
                          '(parents\:"list parents of a commit")' && ret=0
                    else
                        _arguments \
                            $_vergo_global \
                            '--merge-commits[include merge commits when listing parents]' && ret=0
                    fi
                    ;;
                version)
                    _arguments $_vergo_global && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_vergo "$@"
