#compdef claude-vault
# Source: cargo binstall claude-vault@0.1.0
# Probed via: completions zsh
# Repository: https://github.com/kuroko1t/claude-vault

autoload -U is-at-least

_claude-vault() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--db=[Path to the SQLite database file]:DB:_files' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_claude-vault_commands" \
"*::: :->claude-vault" \
&& ret=0
    case $state in
    (claude-vault)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:claude-vault-command-$line[1]:"
        case $line[1] in
            (import)
_arguments "${_arguments_options[@]}" : \
'--claude-dir=[Path to Claude config directory (default\: ~/.claude)]:CLAUDE_DIR:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(import-file)
_arguments "${_arguments_options[@]}" : \
'--project=[Project name]:PROJECT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':path -- Path to the JSONL file:_files' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-l+[Maximum number of results]:LIMIT:_default' \
'--limit=[Maximum number of results]:LIMIT:_default' \
'-p+[Filter by project name (substring match)]:PROJECT:_default' \
'--project=[Filter by project name (substring match)]:PROJECT:_default' \
'-r+[Filter by role (user or assistant)]:ROLE:_default' \
'--role=[Filter by role (user or assistant)]:ROLE:_default' \
'--since=[Only show results after this date (e.g. 2024-01-01)]:SINCE:_default' \
'--until=[Only show results before this date (e.g. 2024-12-31)]:UNTIL:_default' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
':query -- Search query (FTS5 syntax):_default' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'--last=[Export the Nth most recent session (1 = latest, 2 = second latest, ...)]::N:_default' \
'-f+[Output format]:FORMAT:(markdown json text)' \
'--format=[Output format]:FORMAT:(markdown json text)' \
'-h[Print help]' \
'--help[Print help]' \
'::session_id -- Session ID or prefix (e.g. "47cf1f2e"):_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-n+[Number of sessions to show (0 = all)]:LIMIT:_default' \
'--limit=[Number of sessions to show (0 = all)]:LIMIT:_default' \
'-p+[Filter by project name (substring match)]:PROJECT:_default' \
'--project=[Filter by project name (substring match)]:PROJECT:_default' \
'--since=[Only show sessions after this date (e.g. 2024-01-01)]:SINCE:_default' \
'--until=[Only show sessions before this date (e.g. 2024-12-31)]:UNTIL:_default' \
'--json[Output as JSON]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-y[Skip confirmation prompt]' \
'--yes[Skip confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
':session_id -- Session ID or prefix:_default' \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_claude-vault__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:claude-vault-help-command-$line[1]:"
        case $line[1] in
            (import)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(import-file)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(verify)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_claude-vault_commands] )) ||
_claude-vault_commands() {
    local commands; commands=(
'import:Import all JSONL files from ~/.claude/projects/' \
'import-file:Import a single JSONL session file' \
'search:Search conversations using full-text search' \
'export:Export a session in various formats' \
'list:List sessions' \
'delete:Delete a session and all its messages' \
'stats:Show database statistics' \
'verify:Verify database integrity' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'claude-vault commands' commands "$@"
}
