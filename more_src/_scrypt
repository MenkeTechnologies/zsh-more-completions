#compdef scrypt

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'enc:Encrypt a file'
      'dec:Decrypt a file'
      'info:Display parameters used for encryption'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (enc)
        _arguments \
          '-f[force overwrite output file]' \
          '-M+[max memory usage in bytes]:bytes:' \
          '-m+[max memory fraction]:fraction:' \
          '-t+[max time in seconds]:seconds:' \
          '-v[verbose mode]' \
          '--logN=[CPU/memory cost parameter]:logN:' \
          '-r+[block size parameter]:r:' \
          '-p+[parallelization parameter]:p:' \
          '--passphrase=[passphrase handling]:mode:(dev\:stdin-once dev\:tty-stdin env\:VAR file\:path)' \
          '1:input file:_files' \
          '2::output file:_files' && ret=0
        ;;
      (dec)
        _arguments \
          '-f[force overwrite output file]' \
          '-M+[max memory usage in bytes]:bytes:' \
          '-m+[max memory fraction]:fraction:' \
          '-t+[max time in seconds]:seconds:' \
          '-v[verbose mode]' \
          '--passphrase=[passphrase handling]:mode:(dev\:stdin-once dev\:tty-stdin env\:VAR file\:path)' \
          '1:input file:_files' \
          '2::output file:_files' && ret=0
        ;;
      (info)
        _arguments \
          '1:encrypted file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
