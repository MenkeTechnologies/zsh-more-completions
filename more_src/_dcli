#compdef dcli

# Zsh completion for dcli - Dashlane CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--output=[output format]:format:(json csv table)' \
  '--json[output as JSON]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'sync:Synchronize vault data'
      'password:Retrieve a password'
      'note:Retrieve a secure note'
      'otp:Retrieve an OTP code'
      'configure:Configure the CLI'
      'logout:Log out'
      'lock:Lock the vault'
      'backup:Backup local vault'
      'reset:Reset local vault data'
      'inject:Inject credentials into a template'
      'read:Read a secret by path'
      'devices:Manage registered devices'
      'team:Team management commands'
    )
    _describe -t commands 'dcli command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      password)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--output=[output format]:format:(json csv table)' \
          '--json[output as JSON]' \
          '1:filter or path' && ret=0
        ;;
      note)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--output=[output format]:format:(json csv table)' \
          '--json[output as JSON]' \
          '1:filter or path' && ret=0
        ;;
      otp)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:filter or path' && ret=0
        ;;
      inject)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-i --in)'{-i,--in}'[input template file]:template:_files' \
          '(-o --out)'{-o,--out}'[output file]:output:_files' && ret=0
        ;;
      read)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:secret path' && ret=0
        ;;
      backup)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:backup directory:_directories' && ret=0
        ;;
      configure)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      devices)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--json[output as JSON]' && ret=0
        ;;
      team)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
