# -----------------------------------------------------------------------------
#
# THE email-sleuth CLI
#
# email-sleuth is a single-command CLI (no subcommands)
# built on clap v4.x with the `derive` macro.
# Invocation:
#   email-sleuth [options]
#
# Two operating modes selected by argument presence:
#
#   1. SINGLE-CONTACT MODE
#      Triggered by both --name + --domain:
#        email-sleuth --name "Jane Doe" --domain example.com
#
#   2. BATCH (FILE) MODE
#      Triggered by --input (default "input.json"):
#        email-sleuth --input contacts.json --output results.json
#
# All flags have EMAIL_SLEUTH_* environment-variable
# counterparts (clap's env feature).
#
# Required flags (one set):
#   -i, --input <PATH>                input JSON file
#                                     (default "input.json";
#                                     env EMAIL_SLEUTH_INPUT)
#   --name <NAME>                     single-contact name
#                                     (env EMAIL_SLEUTH_NAME)
#   --domain <DOMAIN>                 single-contact domain
#                                     (env EMAIL_SLEUTH_DOMAIN)
#
# Output:
#   -o, --output <PATH>               output JSON file
#                                     (default "results.json";
#                                     env EMAIL_SLEUTH_OUTPUT)
#   --stdout                          emit single-contact
#                                     result to stdout
#                                     (env EMAIL_SLEUTH_STDOUT)
#
# Verification mode:
#   -m, --mode <MODE>                 basic | enhanced |
#                                     comprehensive
#                                     (default basic)
#
# Behavior tuning:
#   -c, --concurrency <N>             max concurrent tasks
#                                     (env EMAIL_SLEUTH_CONCURRENCY)
#   --config-file <PATH>              TOML config file
#                                     (env EMAIL_SLEUTH_CONFIG)
#   --smtp-sender <EMAIL>             sender for SMTP probes
#                                     (env EMAIL_SLEUTH_SMTP_SENDER)
#   --user-agent <UA>                 HTTP User-Agent string
#                                     (env EMAIL_SLEUTH_USER_AGENT)
#   --smtp-timeout <SECS>             SMTP timeout
#                                     (env EMAIL_SLEUTH_SMTP_TIMEOUT)
#   --request-timeout <SECS>          HTTP timeout
#                                     (env EMAIL_SLEUTH_REQUEST_TIMEOUT)
#   --dns-timeout <SECS>              DNS timeout
#                                     (env EMAIL_SLEUTH_DNS_TIMEOUT)
#   --dns-servers <SVR,...>           comma-separated DNS servers
#                                     (env EMAIL_SLEUTH_DNS_SERVERS)
#   --early-termination-threshold <0..100>
#                                     stop verification
#                                     when confidence >= N
#                                     (env EMAIL_SLEUTH_EARLY_TERM_THRESHOLD)
#
# Advanced verification:
#   --enable-api-checks               turn on M365 API checks
#                                     (env EMAIL_SLEUTH_ENABLE_API_CHECKS)
#   --enable-headless-checks          turn on browser checks
#                                     (env EMAIL_SLEUTH_ENABLE_HEADLESS_CHECKS)
#   --webdriver-url <URL>             WebDriver instance URL
#                                     (env EMAIL_SLEUTH_WEBDRIVER_URL)
#   --chromedriver-path <PATH>        ChromeDriver binary path
#                                     (env EMAIL_SLEUTH_CHROMEDRIVER_PATH)
#
# Service management (ChromeDriver):
#   --service <CMD>                   start|stop|restart|status|logs
#   --log-lines <N>                   lines for `--service logs`
#                                     (default 20)
#
# Common invocations:
#   # Single contact lookup
#   email-sleuth --name "Jane Doe" --domain example.com \
#     --mode comprehensive --stdout
#
#   # Batch from input.json → results.json (basic mode)
#   email-sleuth -i contacts.json -o results.json
#
#   # Batch with custom concurrency + tighter timeouts
#   email-sleuth -i contacts.json -c 10 \
#     --smtp-timeout 10 --request-timeout 8 \
#     --dns-timeout 5
#
#   # Enhanced mode (SMTP + M365 API)
#   email-sleuth -i contacts.json -m enhanced
#
#   # Comprehensive mode (SMTP + API + headless browser)
#   email-sleuth -i contacts.json -m comprehensive \
#     --webdriver-url http://localhost:4444
#
#   # Use Cloudflare + Google DNS instead of system resolver
#   email-sleuth -i contacts.json \
#     --dns-servers 1.1.1.1,8.8.8.8
#
#   # ChromeDriver service management
#   email-sleuth --service start
#   email-sleuth --service status
#   email-sleuth --service logs --log-lines 50
#   email-sleuth --service stop
#
#   # Load defaults from TOML, override mode via flag
#   email-sleuth --config-file ./sleuth.toml -m enhanced
#
# OPTIONS (sourced directly from
# https://github.com/buyukakyuz/email-sleuth/blob/main/src/main.rs):
#
# All long flags also accept EMAIL_SLEUTH_<UPPER_NAME>
# environment variables.
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _es_modes
_es_modes=(
    'basic:SMTP verification only (default; fastest)'
    'enhanced:SMTP + M365 API checks'
    'comprehensive:SMTP + API + headless browser checks (slowest, most thorough)'
)

local -a _es_service_cmds
_es_service_cmds=(
    'start:start ChromeDriver service'
    'stop:stop ChromeDriver service'
    'restart:restart ChromeDriver service'
    'status:show ChromeDriver service status'
    'logs:show ChromeDriver service logs'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-i --input)'{-i,--input}'=[input JSON file (default input.json)]:input file:_files -g "*.json"' \
    '(-o --output)'{-o,--output}'=[output JSON file (default results.json)]:output file:_files -g "*.json"' \
    '--name=[single-contact name (requires --domain)]:name: ' \
    '--domain=[single-contact domain or URL (requires --name)]:domain: ' \
    '--stdout[emit single-contact result to stdout]' \
    '--config-file=[TOML configuration file]:config file:_files -g "*.(toml|TOML)"' \
    '(-c --concurrency)'{-c,--concurrency}'=[max concurrent tasks]:n: ' \
    '--smtp-sender=[sender email for SMTP probes]:email: ' \
    '--user-agent=[HTTP User-Agent string]:user-agent: ' \
    '--smtp-timeout=[SMTP connection/command timeout in seconds]:seconds: ' \
    '--request-timeout=[HTTP request timeout in seconds]:seconds: ' \
    '--dns-timeout=[DNS resolution timeout in seconds]:seconds: ' \
    '--dns-servers=[comma-separated DNS server list]:dns servers: ' \
    '--enable-api-checks[enable M365 API verification checks]' \
    '--enable-headless-checks[enable headless browser verification (requires WebDriver)]' \
    '--early-termination-threshold=[stop verification when confidence >= N (0..100)]:threshold: ' \
    '--webdriver-url=[WebDriver instance URL (e.g. http://localhost:4444)]:url: ' \
    '--chromedriver-path=[ChromeDriver executable path]:chromedriver:_files' \
    '(-m --mode)'{-m,--mode}'=[verification mode]:mode:->mode' \
    '--service=[manage ChromeDriver service]:service command:->servicecmd' \
    '--log-lines=[lines to show for --service logs (default 20)]:lines: ' \
    && ret=0

case $state in
    mode)
        _describe -t modes 'verification mode' _es_modes && ret=0
        ;;
    servicecmd)
        _describe -t servicecmds 'service command' _es_service_cmds && ret=0
        ;;
esac

return ret
