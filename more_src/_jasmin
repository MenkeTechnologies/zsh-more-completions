#compdef jasmin
# Documentation: https://man.archlinux.org/search?q=jasmin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-d+[output dir]:dir:_files -/' \
  '-encoding+[input encoding]:enc:' \
  '-g[generate debug info]' \
  '-h[show help]' \
  '-warn[warn]' \
  '-noWarning[no warnings]' \
  '*: :_files -g "*.j *.jasmin"' && ret=0

return ret
