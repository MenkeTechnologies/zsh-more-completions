#compdef snforge
# Documentation: upstream crates/forge/src/lib.rs at
# github.com/foundry-rs/starknet-foundry
# Reference accessed: 2026-05-30 via gh api inspection of every
# clap-derive #[command(...)] enum variant and #[arg(...)] macro.
# Starknet Foundry snforge R75 — Cairo testing framework for
# Starknet smart contracts (Foundry-equivalent). 6 top-level
# subcommands.

local curcontext="$curcontext" state line ret=1

local -a _subcmds _shells _templates _color_when _clean_components _tracked
_subcmds=(
  'test:run tests for a project in the current directory'
  'new:create a new Forge project at PATH'
  'clean:clean snforge-generated directories'
  'check-requirements:check if all snforge requirements are installed'
  'completions:generate completions script'
  'optimize-inlining:find optimal inlining-strategy value to minimize gas cost'
)
_shells=( bash zsh fish elvish powershell )
_templates=( cairo-program balance-contract erc20-contract )
_color_when=( auto always never )
_clean_components=( coverage profile cache trace )
_tracked=( cairo-steps sierra-gas )

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'snforge subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      test|optimize-inlining)
        _arguments -s -S \
          '(-e --exact)'{-e,--exact}'[use exact matches for test_filter (requires test_filter)]' \
          '*--skip=[skip any tests whose name contains string (repeatable)]:string:' \
          '(-x --exit-first)'{-x,--exit-first}'[stop executing tests after the first failed test]' \
          '(-r --fuzzer-runs)'{-r,--fuzzer-runs}'=[number of fuzzer runs]:N:' \
          '(-s --fuzzer-seed)'{-s,--fuzzer-seed}'=[seed for the fuzzer]:N:' \
          '--ignored[run only tests marked with #[ignore]]' \
          '--include-ignored[run all tests regardless of #[ignore]]' \
          '--detailed-resources[display more detailed info about used resources]' \
          '--color=[control when colored output is used]:when:($_color_when)' \
          '--rerun-failed[run tests that failed during the last run]' \
          '--save-trace-data[save execution traces of passed non-fuzz tests]' \
          '--build-profile[build cairo-profiler profiles of passed non-fuzz tests]' \
          '--coverage[generate cairo-coverage report for passed non-fuzz tests]' \
          '--max-n-steps=[max steps during a single test]:N:' \
          '--no-optimization[build contracts separately in scarb starknet contract target]' \
          '--tracked-resource=[tracked resource type]:resource:($_tracked)' \
          '--gas-report[display a table of L2 gas breakdown for each contract/selector]' \
          '--partition=[run only an index of total partition (e.g. 1/4)]:INDEX/TOTAL:' \
          '--max-threads=[max worker threads]:N:' \
          '--launch-debugger[launch debugger on test (requires --exact)]' \
          '--run-native[run contracts on cairo-native instead of cairo-vm]' \
          '*--features=[features to activate (comma/space-separated)]:features:' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate the default feature]' \
          '(-p --package)*'{-p,--package}'=[scarb package (glob, repeatable)]:package:' \
          '--workspace[apply to all packages in the workspace]' \
          '--profile=[scarb profile to use]:profile:' \
          '*:test_filter:' \
          && ret=0
        ;;
      new)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'=[name of the new project (defaults to directory name)]:name:' \
          '--no-vcs[do not initialize a new Git repository]' \
          '--overwrite[try to create the project even if PATH is not empty]' \
          '(-t --template)'{-t,--template}'=[template for the new project]:template:($_templates)' \
          '1:project path:_directories' \
          && ret=0
        ;;
      clean)
        _arguments \
          '*:clean component:($_clean_components)' && ret=0
        ;;
      check-requirements)
        _arguments '--help[show help]' && ret=0
        ;;
      completions)
        _arguments '1:shell:($_shells)' && ret=0
        ;;
    esac
    ;;
esac

return ret
