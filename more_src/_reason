#compdef reason refmt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse[input syntax]:syntax:(re ml)' \
  '--print[output format]:format:(re ml ast binary binary_reason)' \
  '--interface[parse as interface file]:bool:(true false)' \
  '--use-stdin[read from stdin]:bool:(true false)' \
  '--is-interface-pp[is interface pretty print]' \
  '--recoverable[enable error recovery]' \
  '--assume-explicit-arity[assume explicit arity for constructors]' \
  '--in-place[modify file in place]' \
  '--print-width[max print width]:width' \
  '*:file:_files -g "*.(re|ml|rei|mli)"' && ret=0

return ret
