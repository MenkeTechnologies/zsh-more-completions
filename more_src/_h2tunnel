#compdef h2tunnel
# Documentation: https://github.com/boronine/h2tunnel
# h2tunnel - TCP over HTTP/2 tunnel reverse proxy

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(client server)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      client)
        _arguments -s \
          '--crt=[certificate file path]:file:_files' \
          '--key=[private key file path]:file:_files' \
          '--tunnel-host=[tunnel server hostname]:host:' \
          '--tunnel-port=[tunnel server port]:port:' \
          '--origin-host=[local TCP server hostname]:host:' \
          '--origin-port=[local TCP server port]:port:' && ret=0
        ;;
      server)
        _arguments -s \
          '--crt=[certificate file path]:file:_files' \
          '--key=[private key file path]:file:_files' \
          '--tunnel-listen-ip=[tunnel server binding IP]:ip:' \
          '--tunnel-listen-port=[tunnel server listening port]:port:' \
          '--proxy-listen-ip=[remote TCP proxy binding IP]:ip:' \
          '--proxy-listen-port=[remote TCP proxy listening port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
