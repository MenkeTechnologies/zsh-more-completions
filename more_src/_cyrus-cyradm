#compdef cyrus-cyradm
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/cyradm.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org cyradm(1) reference manpage.
# Removed from prior file: bogus man.archlinux.org search URL; --help and
# --version are real here so kept.

# cyrus-cyradm: interactive Cyrus IMAP administrative shell (Perl)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-u --user)'{-u+,--user=}'[authenticate as user]:user:_users' \
  '--authz=[authorize connection as user]:user:_users' \
  '(--rc)--norc[do not load configuration files]' \
  '(--norc)--rc[load configuration files (default)]' \
  '--systemrc=[system configuration file]:file:_files' \
  '--userrc=[user configuration file]:file:_files' \
  '--port=[connect to port]:port:' \
  '--auth=[SASL mechanism]:mechanism:(PLAIN LOGIN CRAM-MD5 DIGEST-MD5 GSSAPI EXTERNAL ANONYMOUS)' \
  '--server=[server hostname]:host:_hosts' \
  '*:server:_hosts' && ret=0
return ret
