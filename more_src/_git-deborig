#compdef git-deborig
# Documentation: https://manpages.debian.org/git-deborig
# Source: debian/devscripts scripts/git-deborig.pl — produce orig.tar from git for upload (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --force)'{-f,--force}'[overwrite existing orig.tar]' \
    '--just-print[print suggested archive command and tag]' \
    '--just-print-tag-names[print suggested tag names]' \
    '--version=-[upstream version]:version:_default' \
    && ret=0

return ret
