#compdef grdshake
# GMT supplements/seis — predict ground shaking from fault rupture and magnitude

local ret=1

_arguments -s \
  '-G+[output grid file (%s for components)]:file:_files' \
  '-L+[fault trace coordinates file]:file:_files' \
  '-M+[earthquake magnitude]:magnitude:_default' \
  '-C+[output components acceleration/velocity/intensity]:components:_default' \
  '-F+[focal mechanism 1=unknown 2=strike-slip 3=normal 4=thrust]:mech:(1 2 3 4)' \
  '-R+[region west/east/south/north]:region:_default' \
  '*-V[verbose (stackable)]' \
  '-i+[input column selection]:cols:_default' \
  '*:input table:_files' \
  && ret=0

return ret
