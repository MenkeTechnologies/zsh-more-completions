#compdef flux-get
# Documentation: https://fluxcd.io/flux/cmd/flux_get/
# FluxCD get: retrieve Flux resource statuses

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[display results across all namespaces]' \
  '(-w --watch)'{-w,--watch}'[monitor for changes after listing resources]' \
  '(-l --label-selector)'{-l,--label-selector}'=[filter by label selector]:selector:' \
  '--status-selector=[filter by status condition and desired state]:selector:' \
  '--no-header[omit header output]' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' \
  '*::subcommand:(alert-providers alerts all artifacts helmreleases images kustomizations receivers sources)' && ret=0

return ret
