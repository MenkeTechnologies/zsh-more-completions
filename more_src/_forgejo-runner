#compdef forgejo-runner
# Documentation: https://forgejo.org/docs/v11.0/admin/actions/runner-installation/
# Forgejo Actions runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config=[path to configuration file]:path:_files' \
  '1:command:(register daemon exec generate-config create-runner-file)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      register)
        _arguments -s -S \
          '--instance=[Forgejo instance URL]:url' \
          '--token=[registration token]:token' \
          '--name=[runner name]:name' \
          '--labels=[comma-separated runner labels]:labels' \
          '--no-interactive[register without interactive prompts]' && ret=0
        ;;
      daemon)
        _arguments -s -S '--config=[path to configuration file]:path:_files' && ret=0
        ;;
      create-runner-file)
        _arguments -s -S \
          '--instance=[Forgejo instance URL]:url' \
          '--secret=[shared registration secret]:secret' && ret=0
        ;;
      exec)
        _arguments -s -S '--enable-ipv6[enable IPv6 in container networks]' && ret=0
        ;;
    esac
    ;;
esac

return ret
