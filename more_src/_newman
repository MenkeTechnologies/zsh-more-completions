#compdef newman

# Zsh completion for newman - Postman CLI collection runner

_newman() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'run:run a Postman collection'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'newman command' commands
            ;;
        args)
            case $words[1] in
                run)
                    _arguments -s -S \
                        '(- *)'{-h,--help}'[show help]' \
                        '(-e --environment)'{-e,--environment}'=[specify an environment file]:file:_files' \
                        '(-g --globals)'{-g,--globals}'=[specify a globals file]:file:_files' \
                        '(-d --iteration-data)'{-d,--iteration-data}'=[specify a data file for iterations]:file:_files' \
                        '(-n --iteration-count)'{-n,--iteration-count}'=[number of iterations]:number:' \
                        '--folder=[run requests within a particular folder]:folder name:' \
                        '--timeout=[time to wait for the entire collection run (ms)]:milliseconds:' \
                        '--timeout-request=[time to wait for requests to return (ms)]:milliseconds:' \
                        '--timeout-script=[time to wait for scripts to complete (ms)]:milliseconds:' \
                        '--delay-request=[delay between requests (ms)]:milliseconds:' \
                        '--bail[stop a collection run on encountering the first error]' \
                        '--silent[disable terminal output]' \
                        '--disable-unicode[force use of plain text instead of unicode]' \
                        '--color=[enable or disable colored output]:mode:(on off auto)' \
                        '*--reporters=[specify reporters]:reporter:' \
                        '--reporter-cli-no-summary[disable the CLI summary table]' \
                        '--reporter-cli-no-failures[disable CLI failure output]' \
                        '--reporter-cli-no-assertions[disable CLI assertions output]' \
                        '--export-environment=[export the final environment to a file]:file:_files' \
                        '--export-globals=[export the final globals to a file]:file:_files' \
                        '--export-collection=[export the executed collection to a file]:file:_files' \
                        '(-k --insecure)'{-k,--insecure}'[disable SSL verification]' \
                        '--ignore-redirects[prevent newman from following redirects]' \
                        '--verbose[show detailed information of collection run]' \
                        '--ssl-client-cert=[path to public client certificate]:file:_files' \
                        '--ssl-client-key=[path to private client key]:file:_files' \
                        '--ssl-client-passphrase=[client certificate passphrase]:passphrase:' \
                        '1:collection file:_files'
                    ;;
            esac
            ;;
    esac
}

_newman "$@"
