#
# THE node-dev CLI
#
# node-dev is invoked as:
#   node-dev [NODE-DEV-OPTIONS] [NODE-FLAGS] <script.js> [SCRIPT-ARGS...]
#
# Common invocations:
#   # Run + watch a Node.js script
#   node-dev server.js
#
#   # Run with Node arguments
#   node-dev --inspect server.js
#
#   # Disable desktop notifications
#   node-dev --notify=false server.js
#
#   # Clear screen between restarts
#   node-dev --clear server.js
#
#   # Run in fork mode (subprocess isolation)
#   node-dev --fork server.js
#
#   # Use polling instead of native fs.watch (for network FS)
#   node-dev --poll --interval 500 server.js
#
#   # Debounce restarts (avoid restart-storm)
#   node-dev --debounce 1000 server.js
#
#   # Ignore additional paths
#   node-dev --ignore "logs/**" --ignore "tmp/**" server.js
#
#   # Watch node_modules to a depth of 2
#   node-dev --deps 2 server.js
#
#   # Graceful shutdown signal
#   node-dev --graceful_ipc SIGTERM server.js
#
#   # VM-context restart isolation
#   node-dev --vm server.js
#
#   # Respawn even on clean exit
#   node-dev --respawn server.js
#
#   # Custom timestamp on restart messages
#   node-dev --timestamp "HH:MM:ss" server.js
#
#   # Pass node --require for preload (e.g., ts-node, babel/register)
#   node-dev --require ts-node/register server.ts
#
# OPTIONS (sourced directly from
# https://github.com/fgnass/node-dev/blob/master/lib/cli.js):
#
# node-dev flags:
#   --clear                        Clear screen before each restart
#   --dedupe                       Enable dynamic module dedupe
#   --fork                         Use child_process.fork (subprocess
#                                  isolation)
#   --notify                       Desktop notifications (default true)
#                                  Use --notify=false to disable
#   --poll                         Use polling instead of fs.watch
#   --respawn                      Respawn even on clean exit
#   --vm                           Use VM context per restart
#   --debounce <ms>                Debounce restarts (milliseconds)
#   --deps <N>                     node_modules watch depth
#   --interval <ms>                Poll interval (with --poll)
#   --graceful_ipc <signal>        Graceful shutdown signal
#   --ignore <path>                Ignore path (repeatable)
#   --timestamp <format>           Timestamp format (dateformat)
#
# Node.js flags (passed through):
#   -r, --require <module>         Preload module(s)
#   --inspect[=host:port]          Enable Node inspector
#   --inspect-brk[=host:port]      Enable inspector + break on first line
#   --expose_gc                    Expose global.gc()
#   --preserve-symlinks            Preserve symlinks
#   --no-warnings                  Suppress process warnings
#
# Positional:
#   <script.js>                    Node.js script to run
#   [args...]                      Args forwarded to the script
#
# Config files:
#   .node-dev.json                 Project-local config (in cwd)
#   ~/.node-dev.json               User-global config
#   $NODE_DEV_CONFIG               Override config file via env var
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--clear[clear screen before each restart]' \
    '--dedupe[enable dynamic module dedupe]' \
    '--fork[use child_process.fork (subprocess isolation)]' \
    '(--notify)--notify=[desktop notifications]:bool:(true false)' \
    '(--notify=)--notify[enable desktop notifications]' \
    '--no-notify[disable desktop notifications]' \
    '--poll[use polling instead of fs.watch]' \
    '--respawn[respawn even on clean exit]' \
    '--vm[use VM context per restart]' \
    '--debounce=[debounce restarts (ms)]:ms:_default' \
    '--deps=[node_modules watch depth]:n:_default' \
    '--interval=[poll interval (ms)]:ms:_default' \
    '--graceful_ipc=[graceful shutdown signal]:signal:(SIGTERM SIGINT SIGUSR1 SIGUSR2 SIGHUP)' \
    '*--ignore=[ignore path (repeatable)]:path:_files' \
    '--timestamp=[timestamp format (dateformat)]:format:_default' \
    '*'{-r,--require=}'[preload module]:module:_default' \
    '--inspect=[enable Node inspector (host:port)]:host\:port:_default' \
    '--inspect-brk=[enable inspector + break on first line]:host\:port:_default' \
    '--expose_gc[expose global.gc()]' \
    '--preserve-symlinks[preserve symlinks]' \
    '--no-warnings[suppress process warnings]' \
    '1:script:_files -g "*.(js|mjs|cjs|ts|mts|cts)"' \
    '*::script argument:_default' \
    && ret=0

return ret
