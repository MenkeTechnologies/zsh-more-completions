#compdef dotter
# Documentation: https://github.com/SuperCuber/dotter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dotter - dotfile manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-g,--global-config}'=[global config file]:file:_files' \
  {-l,--local-config}'=[local config file]:file:_files' \
  '--cache-file=[cache file path]:file:_files' \
  '--cache-directory=[cache directory path]:directory:_directories' \
  '--diff-context-lines=[number of diff context lines]:lines' \
  '--pre-deploy=[pre-deploy hook script path]:file:_files' \
  '--post-deploy=[post-deploy hook script path]:file:_files' \
  '--pre-undeploy=[pre-undeploy hook script path]:file:_files' \
  '--post-undeploy=[post-undeploy hook script path]:file:_files' \
  {-p,--patch}'[read a patch from stdin]' \
  {-y,--noconfirm}'[do not ask for confirmation]' \
  {-d,--dry-run}'[dry run, do not modify files]' \
  {-f,--force}'[force operation]' \
  {-q,--quiet}'[suppress output]' \
  '*'{-v,--verbose}'[increase verbosity, up to 3 times]' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'deploy:deploy dotfiles (default)'
      'undeploy:remove deployed dotfiles'
      'init:initialize dotter configuration'
      'watch:watch for changes and auto-deploy'
      'gen-completions:generate shell completion scripts'
      'help:display help for a command'
    )
    _describe -t commands 'dotter command' commands && ret=0
    ;;
esac

return ret
