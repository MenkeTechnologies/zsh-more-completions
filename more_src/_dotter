#compdef dotter

# Zsh completion for dotter - dotfile manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-g,--global-config}'=[global config file]:file:_files' \
  {-l,--local-config}'=[local config file]:file:_files' \
  '--cache-file=[cache file path]:file:_files' \
  '--cache-directory=[cache directory path]:directory:_directories' \
  '--diff-context-lines=[number of diff context lines]:lines' \
  {-d,--dry-run}'[dry run, do not modify files]' \
  {-f,--force}'[force operation]' \
  {-q,--quiet}'[suppress output]' \
  {-v,--verbose}'[enable verbose output]' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'deploy:deploy dotfiles'
      'undeploy:remove deployed dotfiles'
      'init:initialize dotter configuration'
      'watch:watch for changes and auto-deploy'
    )
    _describe -t commands 'dotter command' commands && ret=0
    ;;
esac

return ret
