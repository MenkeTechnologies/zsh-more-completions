#compdef mate-session mate-session-manager

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--autostart=[autostart dir]:dir:_files -/' \
  '--debug[debug logging]' \
  '--failsafe[failsafe mode]' \
  '--disable-acceleration-check[disable hardware acceleration check]' \
  '--help-all[show all help options]' \
  '--help-gtk[show gtk options]' \
  '--display=[X display]:display:' && ret=0

return ret
