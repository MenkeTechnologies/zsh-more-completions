#compdef redmine-cli redmine_cli
# Documentation: https://man.archlinux.org/search?q=redmine-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'issue:issue commands'
  'project:project commands'
  'user:user commands'
  'time:time entry commands'
  'login:authenticate to Redmine'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--url=[Redmine base URL]:url:' \
  '--api-key=[Redmine API key]:key:' \
  '--username=[username]:user:' \
  '--password=[password]:password:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'redmine-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (issue|project|user|time)
        _arguments \
          '*::sub:(list show create update delete close reopen)' && ret=0 ;;
    esac ;;
esac

return ret
