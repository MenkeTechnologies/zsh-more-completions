#compdef CollectAllelicCounts
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/CollectAllelicCounts.java
# Collects reference and alternate allele counts at specified sites

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[Output file for allelic counts.]:value:_files' \
  '--minimum-base-quality=[Minimum base quality. Base calls with lower quality will be filtered out of pileups.]:value:' \
  '*:argument:_files' && ret=0

return ret
