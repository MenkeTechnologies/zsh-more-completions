#compdef ogrtindex

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-lnum+[layer numbers from each input]:n:' \
  '-lname+[layer names from each input]:name:' \
  '-f+[output format]:format:(ESRI\ Shapefile MapInfo\ File GeoJSON GPKG SQLite KML)' \
  '-write_absolute_path[write absolute file paths]' \
  '-skip_different_projection[skip files with different projection]' \
  '-t_srs+[target SRS]:srs:' \
  '-src_srs_name+[name of source SRS field]:name:' \
  '-src_srs_format+[source SRS format]:format:(AUTO WKT EPSG PROJ)' \
  '-accept_different_schemas[accept different schemas]' \
  '*-lyr_name+[layer name]:name:' \
  '1:output index file:_files' \
  '*:input vector files:_files' && ret=0

return ret
