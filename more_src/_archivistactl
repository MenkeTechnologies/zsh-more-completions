#compdef archivistactl
# _archivistactl — CLI for the Archivista attestation store (in-toto/archivista)
# upstream: https://github.com/in-toto/archivista
# Subcommands + flags from cmd/archivistactl/cmd/*.go (cobra).

_archivistactl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-u --archivistaurl)'{-u+,--archivistaurl=}'[archivista server URL]:url:' \
        '*'{-H+,--headers=}'[extra request header (Name: value, repeatable)]:header:' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_archivistactl_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                retrieve)
                    local -a sub
                    sub=(
                        'envelope:retrieve a DSSE envelope by gitoid'
                        'subjects:retrieve all subjects on an in-toto statement by envelope gitoid'
                    )
                    _describe -t retrieve-subcommands 'retrieve subcommand' sub
                    [[ "$words[2]" == envelope ]] && \
                        _arguments \
                            '(-o --out)'{-o+,--out=}'[file to write envelope to (default stdout)]:file:_files' \
                            '1:gitoid:'
                    ;;
                store)
                    _arguments '*:attestation file:_files'
                    ;;
                search)
                    _arguments '1:gitoid or query:'
                    ;;
                iam)
                    _arguments \
                        '--dryrun[show fake auth-token result without contacting AWS]' \
                        '1:sql-backend:(postgres mysql)' \
                        '2:connection-string:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_archivistactl_commands] )) ||
_archivistactl_commands() {
    local -a commands
    commands=(
        'store:store an attestation on the archivista server'
        'retrieve:retrieve information (envelope / subjects) from archivista'
        'search:search archivista for attestations matching a query'
        'iam:convert a SQL connection string to use AWS RDS IAM auth'
        'help:help about any command'
    )
    _describe -t commands 'archivistactl command' commands
}

_archivistactl "$@"
