#compdef lighthouse
# Documentation: https://github.com/GoogleChrome/lighthouse
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lighthouse - Google Lighthouse web audit CLI

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*--output=[output format]:format:(json html csv)' \
  '--output-path=[output file path]:file:_files' \
  '--view[open HTML report in browser]' \
  '--port=[Chrome debugging port]:port:' \
  '--hostname=[hostname]:host:' \
  '--chrome-flags=[Chrome flags]:flags:' \
  '--only-categories=[categories to run]:categories:(performance accessibility best-practices seo pwa)' \
  '--only-audits=[audits to run]:audits:' \
  '--skip-audits=[audits to skip]:audits:' \
  '--budget-path=[budget file]:file:_files' \
  '--preset=[configuration preset]:preset:(perf desktop experimental)' \
  '--extra-headers=[extra HTTP headers as JSON]:json:' \
  '--form-factor=[form factor to emulate]:mode:(mobile desktop)' \
  '--throttling-method=[throttling method]:method:(simulate devtools provided)' \
  '--screenEmulation.disabled[disable screen emulation]' \
  '--screenEmulation.mobile[emulate mobile screen]' \
  '--max-wait-for-load=[max wait for page load in ms]:milliseconds:' \
  '--enable-error-reporting[enable error reporting]' \
  '--no-enable-error-reporting[disable error reporting]' \
  '--quiet[suppress output]' \
  '--verbose[verbose output]' \
  '--list-all-audits[list all available audits]' \
  '--list-trace-categories[list trace categories]' \
  '--blocked-url-patterns=[URL patterns to block]:patterns:' \
  '--config-path=[config file path]:file:_files' \
  '--locale=[locale for report]:locale:' \
  '--gather-mode[run only artifact gathering]' \
  '--audit-mode[run only auditing]' \
  '1:url:'
