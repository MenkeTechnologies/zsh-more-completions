#compdef unitd

# Completion for unitd - NGINX Unit application server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--control=[control API socket path]:socket path:_files' \
  '--group=[group name]:group:_groups' \
  '--log=[log file path]:log file:_files' \
  '--modules=[modules directory]:directory:_directories' \
  '--pid=[PID file path]:pid file:_files' \
  '--state=[state directory]:directory:_directories' \
  '--tmp=[temp directory]:directory:_directories' \
  '--user=[user name]:user:_users' \
  '--no-daemon[run in foreground]' && ret=0

return ret
