#compdef gscan2pdf
# Documentation: https://man.archlinux.org/search?q=gscan2pdf
# Reference accessed: 2026-05-16

# gscan2pdf: GUI to scan documents and save as PDF / DjVu / image
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--debug[enable debug output]' \
  '--device=[scanner device]:device:' \
  '--import[import these files at startup]:file:_files' \
  '--locale=[run with this locale]:locale:' \
  '--log=[log to file]:file:_files' \
  '--log-level=[log level]:level:(error warning info debug trace)' \
  '*:files to import:_files -g "*.(pdf|djvu|tif|tiff|jpg|jpeg|png|pnm|pbm|pgm|ppm|gif)"' && ret=0
return ret
