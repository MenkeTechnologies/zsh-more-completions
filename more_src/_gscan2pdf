#compdef gscan2pdf

# gscan2pdf: GTK scanner-to-PDF/DjVu workflow application
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[debug output]' \
  '--device=[default SANE device]:device:' \
  '--config=[config file]:file:_files' \
  '--log=[log file]:file:_files' \
  '*:image file(s) to import:_files -g "*.(pdf|djvu|jpg|jpeg|png|tif|tiff)"' && ret=0
return ret
