#compdef metallb-cli metallbctl
# _metallb-cli — MetalLB Authors metallb-cli CLI command-line frontend to the MetalLB Kubernetes load-balancer service implementation for on-premises bare-metal clusters supporting Layer-2 ARP NDP advertisement BGP-mode address-pool L3-AS-IP-pool node-selector controller-state-pool-claim peer-status-advertisement management (MetalLB team, Go); cobra
# upstream: https://metallb.universe.tf/

_metallb-cli() {
    local -a sub=(
        'install:install MetalLB'
        'uninstall:uninstall MetalLB'
        'status:show controller speaker status'
        'pool:address-pool management'
        'l2:Layer-2 advertisements'
        'bgp:BGPAdvertisement and BGPPeer'
        'community:Community CRD management'
        'logs:fetch controller speaker logs'
        'config:fetch configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'metallb-cli subcommand' sub ;;
        args)
            case $words[1] in
                pool|l2|bgp|community) _arguments \
                    '1:op:(list get create update delete)' \
                    '*:name:' ;;
                logs) _arguments \
                    '--component=+[c]:c:(controller speaker)' \
                    '-f[follow]' \
                    '--follow[follow]' \
                    '--tail=+[N]:n:' ;;
            esac
            ;;
    esac
}

_metallb-cli "$@"
