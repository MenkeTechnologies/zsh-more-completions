#compdef ellpro
# Documentation: https://starlink.eao.hawaii.edu/docs/sun180.htx/sun180ss3.html
# ESP: fits a galaxy profile using simple intensity analysis.

local ret=1

_arguments -s -S \
  'IN=[input NDF data structure]:ndf:_files' \
  'OUT=[output text file for profile data]:file:_files' \
  'OUTCAT=[output catalogue file]:cat:_files' \
  'INFILE=[text file with galaxy coordinates]:file:_files' \
  'ARDFIL=[ARD file for masking regions]:file:_files' \
  'MODE=[interactive or file input mode]:flag:(TRUE FALSE)' \
  'DEVICE=[graphics device for results]:device:' \
  'IMGDEV=[graphics device displaying image]:device:' \
  'BACK=[background count value]:val:' \
  'SIGMA=[std deviation of background]:val:' \
  'PSIZE=[pixel size in arc seconds]:val:' \
  'ZEROP=[surface brightness zero point]:val:' \
  'ORIGIN=[image coordinates for origin]:coords:' \
  'RLIM=[radius limit for profiling in pixels]:n:' \
  'FINE=[ellipse separation factor]:val:' \
  'FAST=[use faster profiling method]:flag:(TRUE FALSE)' \
  'LIM1=[max ratio of mean counts]:val:' \
  'LIM2=[lower limit for mean profile count]:val:' \
  'LIM3=[radius where parameters freeze]:n:' \
  'FRACT=[min fraction of ellipse points]:frac:' \
  'MINMOD=[ellipse-residual minimisation type]:type:(0 1 2)' \
  'AUTOL=[find better initial centre]:flag:(TRUE FALSE)' \
  'AUTOLT=[centre refinement method]:flag:(TRUE FALSE)' \
  'FRZORI=[freeze galaxy position]:flag:(TRUE FALSE)' \
  'CURSOR=[use graphics cursor or keyboard]:flag:(TRUE FALSE)' \
  'SAME=[display graph on image device]:flag:(TRUE FALSE)' \
  'AGAIN=[repeat profiling on current image]:flag:(TRUE FALSE)' \
  'COLOUR=[pen colour for centre marking]:n:' \
  'ANGCON=[angle rotation convention]:flag:(TRUE FALSE)' \
  'ANGOFF=[angular offset in degrees]:deg:' \
  '*:ndf:_files' && ret=0

return ret
