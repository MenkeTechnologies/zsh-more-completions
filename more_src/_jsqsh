#compdef jsqsh
# Documentation: https://man.archlinux.org/search?q=jsqsh
# Reference accessed: 2026-05-16

_arguments -s \
  '(-A --autoconnect)'{-A,--autoconnect}'[auto connect]' \
  '(-d --driver)'{-d,--driver}'=[JDBC driver]:driver:' \
  '(-S --server)'{-S,--server}'=[server]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[port]:port:' \
  '(-D --database)'{-D,--database}'=[database]:db:' \
  '(-U --username)'{-U,--username}'=[user]:user:' \
  '(-P --password)'{-P,--password}'=[password]:password:' \
  '(-u --jdbc-url)'{-u,--jdbc-url}'=[JDBC URL]:url:' \
  '(-c --jdbc-class)'{-c,--jdbc-class}'=[JDBC class]:class:' \
  '(-w --domain)'{-w,--domain}'=[domain]:domain:' \
  '(-O --prop)'{-O,--prop}'=[driver property]:KEY=VALUE:' \
  '(-V --url-var)'{-V,--url-var}'=[URL var]:VAR=VAL:' \
  '(-C --config-dir)'{-C,--config-dir}'=[config dir]:dir:_files -/' \
  '(-b --debug)'{-b,--debug}'=[debug class:level]:debug:' \
  '(-e --echo)'{-e,--echo}'[echo input]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --input-file)'{-i,--input-file}'=[input file]:file:_files' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive]' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-R --drivers)'{-R,--drivers}'[list drivers]' \
  '(-X --exit)'{-X,--exit}'=[exit on error count]:n:' \
  '(-g --gui)'{-g,--gui}'[GUI mode]' \
  '(-r --readline)'{-r,--readline}'=[readline impl]:impl:(jline gnu purejava)' \
  '(-z --setup)'{-z,--setup}'[wizard]' \
  '(-t --topic)'{-t,--topic}'=[help topic]:topic:' \
  '*'{-v,--var}'=[variable]:VAR=VAL:' \
  '(-W --width)'{-W,--width}'=[output width]:n:'
