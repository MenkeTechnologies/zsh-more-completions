#compdef grabc
# Documentation: https://github.com/muquit/grabc
# Identify a pixel color of an X Window System screen

local ret=1

_arguments -s -S \
  '-h[show usage]' \
  '-v[show version info]' \
  '-hex[print pixel value as Hex on stdout]' \
  '-rgb[print pixel value as RGB on stderr]' \
  '-W[print the Window id at mouse click]' \
  '-w[window id in hex, use with -l +x+y]:window id' \
  '-l[pixel co-ordinate, e.g. +10+20 (requires window id)]:coordinate' \
  '-a[print all 16 bits of color]' \
  '-d[show debug messages]' && ret=0

return ret
