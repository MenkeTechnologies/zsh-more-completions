#compdef nmap-parse-output

# Zsh completion for nmap-parse-output - Nmap XML output parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:nmap XML file:_files -g "*.xml"' \
  '2:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'http-ports:list all open HTTP ports'
      'tls-ports:list all open TLS ports'
      'service-names:list all service names'
      'product-names:list all product names'
      'banner-comments:list all banner comments'
      'host-ports:list host-port pairs'
      'hosts:list all hosts'
      'port-info:list detailed port info'
      'group-by-ports:group hosts by open ports'
      'group-by-product:group hosts by product'
      'group-by-service:group hosts by service'
    )
    _describe -t commands 'nmap-parse-output command' commands && ret=0
    ;;
esac

return ret
