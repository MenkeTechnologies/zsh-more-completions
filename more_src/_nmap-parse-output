#compdef nmap-parse-output
# Documentation: https://github.com/ernw/nmap-parse-output
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Subcommand list taken from ernw/nmap-parse-output README (Extract Data,
# Manipulate Scan, Convert Scan sections). The prior URL pointed at a
# placeholder search; the canonical upstream is ernw/nmap-parse-output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:nmap XML file:_files -g "*.xml"' \
  '2:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'all-hosts:line-separated list of all hosts'
      'banner:ports with specific services'
      'blocked-ports:ports marked admin-prohibited or tcpwrapped'
      'group-by-ports:group hosts by open TCP ports'
      'group-by-product:group ports by product name'
      'group-by-service:group ports by service name'
      'host-ports:open ports in host:port format'
      'host-ports-protocol:open ports with protocol (tcp/udp)'
      'hosts:hosts with open ports'
      'hosts-to-port:hosts with specific port open'
      'http-info:HTTP port info from script scans'
      'http-ports:HTTP/HTTPS port list'
      'http-title:HTML titles from HTTP ports'
      'nmap-cmdline:display nmap scan parameters'
      'port-info:detailed port info'
      'ports:comma-separated open ports'
      'ports-reachable:comma-separated reachable ports'
      'product:detected product names'
      'search-product:search product names case-sensitive'
      'service:open ports with specific service'
      'service-names:detected service names'
      'show-comments:show added comments'
      'ssl-common-name:TLS/SSL certificate info'
      'tls-ports:TLS ports for testssl.sh'
      'comment-hosts:add comments to hosts'
      'comment-ports:add comments to ports'
      'exclude:remove hosts by IP'
      'exclude-ports:remove ports'
      'include:keep only specified hosts'
      'include-ports:keep only specified ports'
      'mark-ports:color-highlight ports'
      'reachable:remove hosts with all filtered ports'
      'html:convert XML to HTML report'
      'html-bootstrap:convert XML to Bootstrap HTML report'
      'to-json:convert nmap output to JSON'
    )
    _describe -t commands 'nmap-parse-output command' commands && ret=0
    ;;
esac

return ret
