#compdef suslowift
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suslowift.c
# Fourier Transforms by (SLOW) DFT algorithm (Not an FFT)

local ret=1

_arguments -s -S \
  'sign=[sign]:sign:' \
  'dt=[dt]:dt:' \
  '*:file:_files' && ret=0

return ret
