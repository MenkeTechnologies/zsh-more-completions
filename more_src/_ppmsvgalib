#compdef ppmsvgalib
# Documentation: https://netpbm.sourceforge.net/doc/ppmsvgalib.html
# display a PPM image on the Linux console using Svgalib

local ret=1

_arguments -s \
  '-mode=[Svgalib video mode number]:mode' \
  '-verbose[report details of the video mode to standard error]' \
  '*:ppm file:_files -g "*.(ppm|pnm|pam)"' && ret=0

return ret
