#compdef kanidm-cli
# _kanidm-cli — Kanidm Project kanidm-cli CLI command-line frontend wrapping the Kanidm modern identity management platform Rust-implemented PostgreSQL-backed-free providing person service account oauth2 group system account policy session reauth credential update authentication-context login devicecode totp passkey backup restore (Kanidm team, Rust); clap
# upstream: https://kanidm.com/

_kanidm-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'reauth:re-authenticate for elevated session'
        'person:person account operations'
        'service-account:service account operations'
        'group:group operations'
        'oauth2:OAuth2 client management'
        'system:system configuration'
        'session:session management'
        'policy:policy management'
        'sync:sync operations'
        'recycle-bin:recycle bin operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--name=+[name]:str:' \
        '-D+[username]:str:' \
        '--password=+[password]:str:' \
        '--code=+[totp code]:str:' \
        '--ca=+[file]:file:_files' \
        '-C+[ca file]:file:_files' \
        '--url=+[url]:str:' \
        '-H+[url]:str:' \
        '-o+[format]:f:(json yaml table text)' \
        '--output=+[format]:f:(json yaml table text)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kanidm-cli subcommand' sub ;;
        args)
            case $words[1] in
                person|service-account|group|oauth2|policy) _arguments '1:op:(list get create update delete add-credential remove-credential ssh-key cert credential-policy)' '*:name:' ;;
            esac
            ;;
    esac
}

_kanidm-cli "$@"
