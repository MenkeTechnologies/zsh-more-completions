#compdef readal
# Documentation: https://trimal.readthedocs.io/
# readAl: MSA format converter (part of the trimAl suite)

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '--version[show readAl version]' \
  '-in[input file in several formats]:file:_files' \
  '-out[output file name (default STDOUT)]:file:_files' \
  '-format[print info about input file format and alignment]' \
  '-type[print info about biological sequence datatype]' \
  '-info[print info about sequence number and lengths]' \
  '-onlyseqs[generate output with only residues from input file]' \
  '-html[output residues colored by physicochemical properties]' \
  '-reverse[output the reverse of input sequences]' \
  '-nbrf[output file in NBRF/PIR format]' \
  '-mega[output file in MEGA format]' \
  '-nexus[output file in NEXUS format]' \
  '-clustal[output file in CLUSTAL format]' \
  '-fasta[output file in FASTA format]' \
  '-fasta_m10[output file in FASTA format, names up to 10 chars]' \
  '-phylip[output file in PHYLIP/PHYLIP4 format]' \
  '-phylip_m10[output file in PHYLIP/PHYLIP4 format, names up to 10 chars]' \
  '-phylip_paml[output file in PHYLIP format compatible with PAML]' \
  '-phylip_paml_m10[output PHYLIP for PAML, names up to 10 chars]' \
  '-phylip3.2[output file in PHYLIP3.2 format]' \
  '-phylip3.2_m10[output file in PHYLIP3.2 format, names up to 10 chars]' && ret=0

return ret
