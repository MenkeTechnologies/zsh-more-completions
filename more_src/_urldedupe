#compdef urldedupe
# Documentation: https://github.com/ameenmaali/urldedupe
# pass in a list of URLs with query strings, get back a unique list

local ret=1

_arguments -s -S \
  '(-u --urls)'{-u,--urls}'[filename containing urls (else read stdin)]:urls file:_files' \
  '(-r --regex-parse)'{-r,--regex-parse}'[slower but more thorough/accurate parsing]' \
  '(-s --similar)'{-s,--similar}'[remove similar URLs (based on integers and image/font files)]' \
  '(-qs --query-strings-only)'{-qs,--query-strings-only}'[only include URLs if they have query strings]' \
  '(-ne --no-extensions)'{-ne,--no-extensions}'[exclude URLs that have an extension]' \
  '(-m --mode)'{-m,--mode}'[modes/filters to enable (comma separated)]:mode' \
  '(-V --version)'{-V,--version}'[get current version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
