#compdef firefox-profiler
# _firefox-profiler — Firefox Profiler CLI tools wrapper (Mozilla); profiler.firefox.com helper for opening local profiles in browser
# upstream: https://github.com/firefox-devtools/profiler

_firefox-profiler() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--port+[port]:port:' \
        '--host+[bind host]:host:_hosts' \
        '--no-open[do not open browser]' \
        '*:profile json:_files -g "*.json"'
}

_firefox-profiler "$@"
