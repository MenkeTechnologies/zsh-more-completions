#compdef embark

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'new:create a new empty DApp project'
  'demo:bootstrap a demo DApp using all features'
  'run:build and launch DApp with dashboard'
  'console:run embark in console mode'
  'test:run DApp tests'
  'blockchain:launch blockchain node from config'
  'simulator:launch a blockchain simulator'
  'build:build the DApp output'
  'deploy:deploy the DApp to configured environment'
  'eject-build-config:export internal webpack config'
  'graph:generate dependency graph'
  'reset:reset embark state and cache'
  'upload:upload DApp to IPFS/Swarm'
  'version:show version'
  'help:show help'
  'plugin:plugin commands (init/install/list)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'embark command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '--simple[create a minimal DApp]' \
          '--template=[scaffolding template]:template:' \
          '*::dapp_name:' && ret=0 ;;
      (run|console)
        _arguments \
          '*::env_or_target:' \
          '--port=[dev server port]:port:' \
          '--logfile=[log file]:file:_files' \
          '--nodashboard[disable dashboard]' \
          '--locale=[locale]:locale:' \
          '--client=[Ethereum client]:client:(geth parity ganache-cli)' && ret=0 ;;
      (test)
        _arguments \
          '--node=[node URL or "embark"|"vm"]:node:(embark vm)' \
          '--coverage[enable coverage]' \
          '--gasDetails[show gas usage details]' \
          '--all[run all tests]' \
          '--solc[only run solc compilation]' \
          '--loglevel=[log level]:level:(error warn info debug trace)' \
          '*::test_files:_files -g "*.{js,sol}"' && ret=0 ;;
      (build|deploy)
        _arguments \
          '*::env:(development production test custom)' \
          '--logfile=[log file]:file:_files' \
          '--loglevel=[log level]:level:(error warn info debug trace)' \
          '--contracts[only build/deploy contracts]' \
          '--pipeline=[pipeline]:pipeline:(production development)' && ret=0 ;;
      (blockchain|simulator)
        _arguments \
          '*::env:(development production test custom)' \
          '--client=[Ethereum client]:client:(geth parity ganache-cli)' \
          '--locale=[locale]:locale:' && ret=0 ;;
      (upload)
        _arguments \
          '*::platform:(ipfs swarm)' \
          '--ens=[ENS subdomain to register]:domain:' \
          '--logfile=[log file]:file:_files' && ret=0 ;;
      (plugin)
        _arguments '*::sub:(init install list)' && ret=0 ;;
      (graph)
        _arguments \
          '--skipUndeployed[skip undeployed contracts]' \
          '--skipFunctions[skip functions]' \
          '--skipEvents[skip events]' && ret=0 ;;
    esac ;;
esac

return ret
