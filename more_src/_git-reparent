#compdef git-reparent
# Documentation: https://github.com/MarkLodato/git-reparent
# git reparent — recommit HEAD with a new set of parents.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show the help]' \
  '(-e --edit)'{-e,--edit}'[edit the commit message in an editor first]' \
  '--keep-committer[do not rewrite committer name and date]' \
  '(-m --message)'{-m+,--message=}'[use the given message instead of that of HEAD]:message:' \
  '(--no-parent)*'{-p+,--parent=}'[new parent to use; may be given multiple times]:parent:__git_commits' \
  '(-p --parent)--no-parent[create a parentless commit]' \
  '(-q --quiet)'{-q,--quiet}'[be quiet; only report errors]' \
  '(--reset)--no-reset[print the new object id instead of updating HEAD]' \
  '(--no-reset)--reset[update HEAD (default behavior)]' && ret=0

return ret
