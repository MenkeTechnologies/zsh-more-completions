#compdef equery

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --no-color)'{-C,--no-color}'[disable colors]' \
  '(-N --no-pipe)'{-N,--no-pipe}'[disable pipe detection]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'belongs:list packages owning file'
      'changes:show changelog'
      'check:verify package integrity'
      'depends:list packages depending on given package'
      'depgraph:show dependency graph'
      'files:list files installed by package'
      'has:list packages with matching IUSE flag'
      'hasuse:list packages with matching USE flag'
      'keywords:show keywords for specified architectures'
      'list:list installed packages'
      'meta:show metadata about a package'
      'size:show disk usage for a package'
      'uses:show USE flags for a package'
      'which:show ebuild path'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      belongs)
        _arguments '(-e --early-out)'{-e,--early-out}'[stop at first match]' '(-f --full-regex)'{-f,--full-regex}'[use regex]' '*:file:_files' && ret=0
        ;;
      files)
        _arguments '--tree[show as tree]' '(-f --filter)'{-f,--filter}'[filter types]:type:(dir obj sym dev fif cmd doc man info)' '*:package' && ret=0
        ;;
      list)
        _arguments '(-d --duplicates)'{-d,--duplicates}'[list only duplicates]' '(-f --full-regex)'{-f,--full-regex}'[use regex]' '(-o --overlay-tree)'{-o,--overlay-tree}'[show overlay]' '(-p --portage-tree)'{-p,--portage-tree}'[show in portage tree]' '*:pattern' && ret=0
        ;;
      uses|depends|depgraph|check|size|meta|which|changes)
        _arguments '*:package' && ret=0
        ;;
    esac
    ;;
esac

return ret
