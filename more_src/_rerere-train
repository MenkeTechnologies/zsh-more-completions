#compdef rerere-train
# Documentation: https://github.com/git/git/blob/master/contrib/rerere-train.sh
# Source: git/git contrib/rerere-train.sh — prime rerere database from existing merge commits (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-o,--overwrite}'[overwrite existing rerere cache]' \
    '*:rev-list args:_default' \
    && ret=0

return ret
