#compdef puppet-generate
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/generate.md
# puppet generate - generate Puppet code for custom types

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console dot)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '--force[force generation, skip up-to-date checks]' \
  '--format=[generation output format]:format:(pcore)' \
  '--environment=[environment to generate type definitions for]:environment:' \
  '1:action:(types)' && ret=0

return ret
