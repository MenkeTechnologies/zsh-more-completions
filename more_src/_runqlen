#compdef runqlen runqlen-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/runqlen.py argparse)
# Reference accessed: 2026-05-29
# runqlen — CPU run queue length as a histogram (samples queue length at intervals). BCC/eBPF.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-O --runqocc)'{-O,--runqocc}'[report run queue occupancy]' \
  '(-C --cpus)'{-C,--cpus}'[print output for each CPU separately]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default unlimited):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
