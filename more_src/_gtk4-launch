#compdef gtk4-launch
# Documentation: gtk4-launch --help (GTK 4)
# Source: launch an application by its .desktop name (GTK 4 variant).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:application:' \
    '*:uri:' \
    && ret=0

return ret
