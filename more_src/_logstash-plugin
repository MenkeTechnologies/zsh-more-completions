#compdef logstash-plugin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'list:list installed plugins'
  'install:install a plugin (gem name or .gem path)'
  'update:update plugins to latest version'
  'remove:remove a plugin'
  'prepare-offline-pack:create an offline plugin pack'
  'generate:generate plugin scaffold'
  'pack:pack plugins (deprecated)'
  'unpack:unpack plugins (deprecated)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'logstash-plugin subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '--verbose[show verbose info]' \
          '--group=[plugin group]:group:(input filter codec output)' \
          '*:plugin:' && ret=0
        ;;
      (install)
        _files
        ret=0
        ;;
      (update)
        _arguments \
          '--level=[update level]:level:(minor major)' \
          '*:plugin:' && ret=0
        ;;
      (remove)
        _values 'plugin' && ret=0
        ;;
    esac
    ;;
esac

return ret
