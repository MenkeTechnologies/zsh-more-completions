#compdef epiphany-cli epiphany-bin

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--new-window[open in a new window]' \
  '--incognito-mode[private browsing]' \
  '--application-mode[run as a web app]' \
  '--profile=[explicit profile directory]:dir:_files -/' \
  '--private-instance[private (no profile share)]' \
  '*:url_or_file:_files' && ret=0

return ret
