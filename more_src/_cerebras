#compdef cerebras
# _cerebras — Cerebras Systems cerebras Cloud SDK CLI for the Cerebras Inference fast LLM serving platform (cerebras team, Python); typer
# upstream: https://github.com/Cerebras/cerebras-cloud-sdk-python

_cerebras() {
    local -a sub=(
        'auth:authentication subcommands'
        'completions:chat completion subcommands'
        'chat:start chat session'
        'models:list available models'
        'metrics:fetch usage metrics'
        'config:configuration subcommands'
        'whoami:show current user'
        'doctor:run diagnostic checks'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--api-key=+[API key]:str:' \
        '--base-url=+[base URL]:url:_urls' \
        '--config=+[config file]:file:_files -g "*.toml *.json *.yaml *.yml"' \
        '--output=+[format]:f:(text json yaml table)' \
        '-o+[format]:f:(text json yaml table)' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cerebras subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments '1:auth cmd:(login logout status)' ;;
                chat|completions) _arguments \
                    '--model=+[model]:m:(llama3.1-8b llama3.1-70b llama-3.3-70b llama-4-scout-17b-16e-instruct llama-4-maverick-17b-128e-instruct qwen-3-32b qwen-3-coder-480b qwen-3-235b-a22b-instruct qwen-3-235b-a22b-thinking qwen-3-235b-a22b-instruct-2507)' \
                    '--temperature=+[float]:f:' \
                    '--max-tokens=+[N]:n:' \
                    '--top-p=+[float]:f:' \
                    '--seed=+[N]:n:' \
                    '--stop=+[stop seq]:str:' \
                    '--stream[stream]' \
                    '--no-stream[no stream]' \
                    '*:prompt:' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                metrics) _arguments \
                    '--start=+[start time]:str:' \
                    '--end=+[end time]:str:' ;;
            esac
            ;;
    esac
}

_cerebras "$@"
