#compdef mma

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-V+[volume]:n:' \
  '-r+[transpose]:n:' \
  '-T+[tempo]:n:' \
  '-d[debug]' \
  '-D+[debug level]:lvl:' \
  '-f+[output midi]:file:_files -g "*.{mid,midi}"' \
  '-w[write midi instead of playing]' \
  '-W+[write midi width]:n:' \
  '-e+[exec command]:cmd:' \
  '-x[expand variables]' \
  '-c+[chord-only convert]:file:_files' \
  '-g+[group output]:file:_files' \
  '-G+[group/key]:opts:' \
  '-L+[library list]:lib:' \
  '-I+[include path]:dir:_files -/' \
  '-n[no warnings]' \
  '-N+[max bars]:n:' \
  '-p+[port number]:port:' \
  '*:mma file:_files -g "*.mma"' && ret=0

return ret
