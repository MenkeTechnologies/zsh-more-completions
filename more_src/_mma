#compdef mma
# Documentation: http://www.huge-man-linux.net/man1/mma.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# mma: Musical MIDI Accompaniment generator (Bob van der Poel)

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d[extensive debugging output]' \
  '-p[show pattern definitions as created]' \
  '-s[print sequence information]' \
  '-r[show running progress]' \
  '-w[suppress warning messages]' \
  '-n[skip MIDI file generation]' \
  '-e[display parsed and expanded lines]' \
  '-c[show default channel mappings]' \
  '-m+[max bars (default 500)]:n:' \
  '-o[display complete file paths]' \
  '-g[generate groove dependency files]' \
  '-v[print version information]' \
  '-D+[extract documentation]:opt:' \
  '-f+[output filename]:file:_files -g "*.{mid,midi}"' \
  '*:mma file:_files -g "*.mma"' && ret=0

return ret
