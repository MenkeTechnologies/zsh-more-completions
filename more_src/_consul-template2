#compdef consul-template2
# _consul-template2 — HashiCorp consul-template2 CLI command-line frontend wrapping the Consul Template open-source tool that uses HashiCorp Consul to perform service discovery from Consul and dynamically render template files with the latest values from Consul KV Catalog Service Mesh Vault and Nomad written in Go template-engine secret-management generates HAProxy NGINX Apache files for application restart kill-signal exec command source destination wait once dedup-mode dry-run pid-file log-level dump-signal max-stale retry-attempts (HashiCorp team Seth Vargo Mitchell Hashimoto, Go); flag
# upstream: https://github.com/hashicorp/consul-template

_consul-template2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[show version]' \
        '-block-query-wait=+[d]:str:' \
        '-config=+[file/dir]:_files' \
        '*-config=+[file/dir]:_files' \
        '-consul-addr=+[host:port]:_hosts' \
        '-consul-auth=+[user:pwd]:str:' \
        '-consul-namespace=+[ns]:str:' \
        '-consul-partition=+[part]:str:' \
        '-consul-retry[retry consul]' \
        '-consul-retry-attempts=+[N]:n:' \
        '-consul-retry-backoff=+[d]:str:' \
        '-consul-retry-max-backoff=+[d]:str:' \
        '-consul-ssl[consul SSL]' \
        '-consul-ssl-ca-cert=+[file]:file:_files' \
        '-consul-ssl-ca-path=+[path]:_files' \
        '-consul-ssl-cert=+[file]:file:_files' \
        '-consul-ssl-key=+[file]:file:_files' \
        '-consul-ssl-server-name=+[name]:str:' \
        '-consul-ssl-verify[verify SSL]' \
        '-consul-token=+[token]:str:' \
        '-consul-token-file=+[file]:file:_files' \
        '-consul-transport-custom-dialer[custom dialer]' \
        '-consul-transport-dial-keep-alive=+[d]:str:' \
        '-consul-transport-dial-timeout=+[d]:str:' \
        '-consul-transport-disable-keep-alives[disable keep alives]' \
        '-consul-transport-idle-conn-timeout=+[d]:str:' \
        '-consul-transport-max-idle-conns=+[N]:n:' \
        '-consul-transport-max-idle-conns-per-host=+[N]:n:' \
        '-consul-transport-tls-handshake-timeout=+[d]:str:' \
        '-dedup[deduplication]' \
        '-dedup-max-stale=+[d]:str:' \
        '-dedup-prefix=+[path]:str:' \
        '-dedup-ttl=+[d]:str:' \
        '-default-left-delim=+[delim]:str:' \
        '-default-right-delim=+[delim]:str:' \
        '-dry[dry run]' \
        '-exec=+[command]:str:' \
        '-exec-kill-signal=+[sig]:str:' \
        '-exec-kill-timeout=+[d]:str:' \
        '-exec-reload-signal=+[sig]:str:' \
        '-exec-splay=+[d]:str:' \
        '-kill-signal=+[sig]:str:' \
        '-log-file=+[file]:file:_files' \
        '-log-level=+[l]:l:(debug info warn err)' \
        '-log-rotate-bytes=+[N]:n:' \
        '-log-rotate-duration=+[d]:str:' \
        '-log-rotate-max-files=+[N]:n:' \
        '-max-stale=+[d]:str:' \
        '-no-color[no color]' \
        '-once[run once]' \
        '-parse-only[parse only]' \
        '-pid-file=+[file]:file:_files -g "*.pid"' \
        '-reload-signal=+[sig]:str:' \
        '-retry=+[d]:str:' \
        '-syslog[enable syslog]' \
        '-syslog-facility=+[f]:f:(LOCAL0 LOCAL1 LOCAL2 LOCAL3 LOCAL4 LOCAL5 LOCAL6 LOCAL7 USER DAEMON)' \
        '-syslog-name=+[name]:str:' \
        '-template=+[src:dst:cmd]:str:' \
        '*-template=+[src:dst:cmd]:str:' \
        '-vault-addr=+[url]:str:' \
        '-vault-agent-token-file=+[file]:file:_files' \
        '-vault-default-lease-duration=+[d]:str:' \
        '-vault-namespace=+[ns]:str:' \
        '-vault-renew-token[renew token]' \
        '-vault-retry[retry vault]' \
        '-vault-retry-attempts=+[N]:n:' \
        '-vault-retry-backoff=+[d]:str:' \
        '-vault-retry-max-backoff=+[d]:str:' \
        '-vault-ssl[vault SSL]' \
        '-vault-ssl-ca-cert=+[file]:file:_files' \
        '-vault-ssl-ca-path=+[path]:_files' \
        '-vault-ssl-cert=+[file]:file:_files' \
        '-vault-ssl-key=+[file]:file:_files' \
        '-vault-ssl-server-name=+[name]:str:' \
        '-vault-ssl-verify[verify SSL]' \
        '-vault-token=+[token]:str:' \
        '-vault-unwrap-token[unwrap token]' \
        '-wait=+[d]:str:' \
        '*:args:'
}

_consul-template2 "$@"
