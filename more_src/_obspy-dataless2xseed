#compdef obspy-dataless2xseed
# Documentation: https://docs.obspy.org/
# ObsPy: convert dataless SEED into XML-SEED files

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --split-stations)'{-s,--split-stations}'[split multiple stations into multiple XML-SEED files]' \
  '(-d --debug)'{-d,--debug}'[show debugging information]' \
  '(-q --quiet)'{-q,--quiet}'[non verbose mode]' \
  '(-o --output)'{-o,--output}'+[output filename or directory]:file:_files' \
  '(-x --xml-version)'{-x,--xml-version}'+[XML-SEED version]:version:(1.0 1.1)' \
  '*:files:_files' && ret=0

return ret
