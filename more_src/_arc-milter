#compdef arc-milter

# arc-milter: Authenticated Received Chain milter (openarc)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '-f[run in foreground]' \
  '-l[log to syslog]' \
  '-n[validate config and exit]' \
  '-P[PID file]:file:_files' \
  '-p[milter socket]:path:_files' \
  '-u[run as user]:user:_users' \
  '-v[verbose]' \
  '*::arc-milter args:_files' && ret=0
return ret
