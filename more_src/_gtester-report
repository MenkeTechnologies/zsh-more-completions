#compdef gtester-report
# Documentation: gtester-report --help (GLib utils)
# Source: GLib gtester-report — generate HTML/subunit reports from gtester XML logs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show program version]' \
    '(-s --subunit)'{-s,--subunit}'[output subunit instead of HTML]' \
    '1:gtester XML log:_files -g "*.xml"' \
    && ret=0

return ret
