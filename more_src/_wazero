#compdef wazero

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'run:run a WebAssembly binary'
      'compile:compile a WebAssembly binary'
      'version:show version'
    )
    _describe -t commands 'wazero command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      run)
        _arguments -s -S \
          '(-m --mount)'{-m,--mount}'[mount a directory]:dir mount (host=guest):_directories' \
          '(-e --env)'{-e,--env}'[set environment variable]:key=value:' \
          '--cachedir[directory for compilation cache]:directory:_directories' \
          '--timeout[timeout for execution]:timeout:' \
          '--hostlogging[enable host logging]:category:(proc filesystem memory poll clock random sock)' \
          '1:wasm file:_files -g "*.wasm"' \
          '*:arguments:' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '--cachedir[directory for compilation cache]:directory:_directories' \
          '1:wasm file:_files -g "*.wasm"' && ret=0
        ;;
    esac
    ;;
esac

return ret
