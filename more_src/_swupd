#compdef swupd
# swupd — Clear Linux Software Updater

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'autoupdate:manage automatic updates'
  'bundle-add:add software bundles'
  'bundle-info:display bundle information'
  'bundle-list:list installed bundles'
  'bundle-remove:remove software bundles'
  'check-update:check for available updates'
  'clean:clean cached files'
  'diagnose:verify and fix system file integrity'
  'hashdump:dump file hashes'
  'info:show system and swupd info'
  'mirror:configure mirror URL'
  'os-install:install Clear Linux to a target directory'
  'repair:repair the system'
  'search:search for bundles'
  'search-file:search for files in bundles'
  'update:update to the latest or a specific version'
  'verify:verify system integrity'
  '3rd-party:manage 3rd-party repositories'
)

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'swupd command' subcommands && ret=0
    ;;
  (args)
    local -a common_opts=(
      '(-p --path)'{-p,--path=}'[set target path]:path:_files -/'
      '(-u --url)'{-u,--url=}'[set content URL]:url:'
      '(-c --certpath)'{-c,--certpath=}'[set certificate path]:path:_files -/'
      '(-n --nosigcheck)'{-n,--nosigcheck}'[skip signature verification]'
      '(-S --statedir)'{-S,--statedir=}'[set state directory]:dir:_files -/'
      '--no-scripts[do not run post-update scripts]'
      '--no-boot-update[do not update boot files]'
      '--max-parallel-downloads=[max concurrent downloads]:n:'
      '--json-output[output in JSON format]'
      '(-q --quiet)'{-q,--quiet}'[quiet output]'
      '(-d --debug)'{-d,--debug}'[debug output]'
    )
    case $line[1] in
      (bundle-add)
        _arguments -s -S $common_opts \
          '--skip-diskspace-check[skip disk space check]' \
          '--skip-optional[skip optional bundles]' \
          '*:bundle:' \
          && ret=0
        ;;
      (bundle-remove)
        _arguments -s -S $common_opts \
          '(-x --force)'{-x,--force}'[force remove even if required by other bundles]' \
          '--orphans[remove orphaned bundles]' \
          '*:bundle:' \
          && ret=0
        ;;
      (bundle-list)
        _arguments -s -S $common_opts \
          '--all[list all available bundles]' \
          '--deps=[show bundle dependencies]:bundle:' \
          '--has-dep=[show bundles with this dependency]:bundle:' \
          '--status[show installation status]' \
          && ret=0
        ;;
      (bundle-info)
        _arguments -s -S $common_opts \
          '--files[show files in bundle]' \
          '--dependencies[show dependencies]' \
          '*:bundle:' \
          && ret=0
        ;;
      (update)
        _arguments -s -S $common_opts \
          '(-V --version)'{-V,--version=}'[update to specific version]:version:' \
          '--download[download only, do not install]' \
          '--status[show current version]' \
          '--migrate[migrate to new format]' \
          '--allow-mix-collisions[allow file collisions with mix content]' \
          '--keepcache[do not remove cached content after update]' \
          && ret=0
        ;;
      (search|search-file)
        _arguments -s -S $common_opts \
          '(-l --library)'{-l,--library=}'[search for a library]:name:' \
          '(-b --binary)'{-b,--binary=}'[search for a binary]:name:' \
          '--init[initialize search database]' \
          '--order=[order results]:order:(alpha size)' \
          '*:search term:' \
          && ret=0
        ;;
      (diagnose)
        _arguments -s -S $common_opts \
          '(-V --version)'{-V,--version=}'[verify against specific version]:version:' \
          '--picky[check extra files under /usr]' \
          '--picky-tree=[set the tree to check]:path:_files -/' \
          '--picky-whitelist=[regex for whitelist]:regex:' \
          '--extra-files-only[only list extra files]' \
          '--file=[verify single file]:file:_files' \
          && ret=0
        ;;
      (repair)
        _arguments -s -S $common_opts \
          '(-V --version)'{-V,--version=}'[repair against specific version]:version:' \
          '--picky[repair extra files under /usr]' \
          '--picky-tree=[set the tree to repair]:path:_files -/' \
          '--picky-whitelist=[regex for whitelist]:regex:' \
          '--extra-files-only[only repair extra files]' \
          '--file=[repair single file]:file:_files' \
          && ret=0
        ;;
      (clean)
        _arguments -s -S $common_opts \
          '--all[remove all cached content]' \
          '--dry-run[show what would be removed]' \
          && ret=0
        ;;
      (mirror)
        _arguments -s -S $common_opts \
          '--set=[set mirror URL]:url:' \
          '--unset[unset mirror URL]' \
          && ret=0
        ;;
      (autoupdate)
        _arguments -s -S $common_opts \
          '--enable[enable auto-update]' \
          '--disable[disable auto-update]' \
          && ret=0
        ;;
      (info)
        _arguments -s -S $common_opts && ret=0
        ;;
      (check-update)
        _arguments -s -S $common_opts && ret=0
        ;;
      (*)
        _arguments -s -S $common_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
