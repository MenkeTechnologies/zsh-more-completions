#compdef swupd
# Zsh completion for swupd - Clear Linux OS software update tool
# https://github.com/clearlinux/swupd-client

local -a commands=(
  'autoupdate:manage automatic updates'
  'bundle-add:add software bundles'
  'bundle-info:show information about a bundle'
  'bundle-list:list installed bundles'
  'bundle-remove:remove software bundles'
  'check-update:check for available updates'
  'clean:clean cached files'
  'diagnose:verify system against server manifest'
  'hashdump:dump file hashes'
  'info:show swupd configuration info'
  'mirror:configure alternate update mirror'
  'os-install:install Clear Linux OS'
  'repair:repair system'
  'search:search for bundles containing a file'
  'search-file:search for bundles by filename'
  'update:update system software'
  'verify:alias for diagnose'
  '3rd-party:manage 3rd-party repositories'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p+[set path prefix]:path:_files -/' \
  '-u+[set server URL]:URL:' \
  '-c+[set certificate path]:cert path:_files' \
  '-C+[set content URL]:URL:' \
  '-V+[set version URL]:URL:' \
  '-P+[set port number]:port:' \
  '-F+[set format]:format:' \
  '-S+[set state directory]:directory:_files -/' \
  '-n[run in no-scripts mode]' \
  '-I[ignore time for certificate checks]' \
  '-t+[set max parallel downloads]:number:' \
  '-j+[set JSON output file]:file:_files' \
  '--quiet[suppress most output]' \
  '--debug[enable debug output]' \
  '--no-progress[suppress progress bars]' \
  '--wait-for-scripts[wait for post-update scripts]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'swupd command' commands
    ;;
  args)
    case $words[1] in
      bundle-add|bundle-remove|bundle-info)
        _arguments '*:bundle name:'
        ;;
      update)
        _arguments \
          '-s[set target version]:version:' \
          '--download[only download, do not apply]' \
          '--status[show current version]'
        ;;
      clean)
        _arguments \
          '--all[remove all cached content]' \
          '--dry-run[only show what would be removed]'
        ;;
      search|search-file)
        _arguments \
          '-l[list known bundles]' \
          '*:search term:'
        ;;
      repair)
        _arguments \
          '--picky[also check non-tracked files]' \
          '--force[force repair]' \
          '-V+[set target version]:version:'
        ;;
    esac
    ;;
esac
