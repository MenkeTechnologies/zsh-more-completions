#compdef megals
# megals — list files in your MEGA account

local curcontext="$curcontext" ret=1

_arguments -s -S \
  {-e,--export}'[show public export links]' \
  {-h,--human}'[human-readable file sizes]' \
  '--header[show column header in long listing]' \
  {-l,--long}'[long listing format]' \
  {-R,--recursive}'[list directories recursively]' \
  {-n,--names}'[show only file names]' \
  {-0,--print0}'[separate entries with null byte]' \
  '--config=[load configuration from a file]:config file:_files' \
  '--ignore-config-file[do not load configuration file]' \
  '--debug=[enable debugging output]:debug flags:' \
  '(- *)--version[show version]' \
  '--reload[reload filesystem cache]' \
  '--no-ask-password[never ask interactively for a password]' \
  '--disable-previews[do not generate previews on upload]' \
  ':remote path:' && ret=0

return ret
