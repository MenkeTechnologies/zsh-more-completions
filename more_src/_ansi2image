#compdef ansi2image

# Zsh completion for ansi2image (ANSI to Image converter)
# https://github.com/helviojunior/ansi2image

_arguments \
  '1:input file:_files' \
  '(-o --output)'{-o,--output}'[image output file]:output file:_files' \
  '--font[font type (default\: JetBrains Mono Regular)]:font name' \
  '--font-list[list all supported font family and variations]' \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '*-v[increase verbosity level]' \
  '(- *)--version[show current version]'
