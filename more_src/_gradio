#compdef gradio

# Gradio CLI completion

_gradio_subcommands() {
  local -a subcmds=(
    'deploy:Deploy a Gradio app to Hugging Face Spaces'
    'environment:Print environment information'
    'cc:Custom components management'
  )
  _describe -t commands 'gradio subcommand' subcmds
}

_gradio_cc_subcommands() {
  local -a subcmds=(
    'create:Create a new custom component'
    'build:Build a custom component'
    'dev:Start dev mode for a custom component'
    'publish:Publish a custom component'
    'show:Show details about a custom component'
    'install:Install a custom component'
    'docs:Generate docs for a custom component'
  )
  _describe -t commands 'cc subcommand' subcmds
}

_gradio() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_gradio_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        deploy)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--title=[app title]:title' \
            '--app-file=[path to app file]:file:_files'
          ;;
        environment)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        cc)
          _arguments -C \
            '(- *)'{-h,--help}'[show help]' \
            '1:subcommand:_gradio_cc_subcommands' \
            '*::arg:->cc_args'
          case $state in
            cc_args)
              case ${line[1]} in
                create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--name=[component name]:name' \
                    '--directory=[output directory]:directory:_directories' \
                    '--template=[template to use]:template'
                  ;;
                build)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:path:_directories'
                  ;;
                dev)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:path:_directories'
                  ;;
                publish)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:path:_directories'
                  ;;
                show)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:component name:'
                  ;;
                install)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:component name:'
                  ;;
                docs)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:path:_directories'
                  ;;
              esac
              ;;
          esac
          ;;
        *)
          # gradio app.py - run a demo
          _arguments \
            '1:app file:_files -g "*.py"'
          ;;
      esac
      ;;
  esac
}

_gradio "$@"
