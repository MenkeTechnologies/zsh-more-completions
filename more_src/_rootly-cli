#compdef rootly-cli rootly
# _rootly-cli — Rootly rootly-cli CLI command-line frontend wrapping the Rootly incident management Slack-native response platform REST API providing init auth whoami incident service team severity environment functionality status-page playbook genius runbook retrospective postmortem alert workflow form-field cause-of-failure dashboard heartbeat schedule (Rootly team Quentin Rousseau, Go); cobra
# upstream: https://rootly.com/

_rootly-cli() {
    local -a sub=(
        'init:initialize config'
        'auth:authenticate'
        'whoami:show identity'
        'incident:incident operations'
        'service:service operations'
        'team:team operations'
        'severity:severity operations'
        'environment:environment operations'
        'functionality:functionality operations'
        'status-page:status page operations'
        'playbook:playbook operations'
        'runbook:runbook operations'
        'retrospective:retrospective operations'
        'workflow:workflow operations'
        'alert:alert operations'
        'schedule:schedule operations'
        'dashboard:dashboard operations'
        'heartbeat:heartbeat operations'
        'genius-workflow:genius workflow ops'
        'cause:cause operations'
        'form-field:form field ops'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--workspace=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rootly subcommand' sub ;;
        args)
            case $words[1] in
                incident|service|team|severity|environment|functionality|status-page|playbook|runbook|retrospective|workflow|alert|schedule|dashboard|heartbeat|cause|form-field) _arguments '1:op:(list get create update delete close resolve open mitigate cancel archive restore)' '*:id:' ;;
                auth) _arguments '1:op:(login logout status)' '*:arg:' ;;
            esac
            ;;
    esac
}

_rootly-cli "$@"
