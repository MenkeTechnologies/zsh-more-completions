#compdef hbtop

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --delay)'{-d,--delay=}'[refresh interval in seconds]:secs:' \
  '(-n --numberOfIterations)'{-n,--numberOfIterations=}'[batch mode iterations]:n:' \
  '(-m --mode)'{-m,--mode=}'[metric mode]:mode:(Region Namespace Table RegionServer User Client)' \
  '(-O --outputFieldNames)'{-O,--outputFieldNames}'[print field names then exit]' \
  '(-s --sortField)'{-s,--sortField=}'[field to sort by]:field:' \
  '(-f --fields)'{-f,--fields=}'[comma-separated field list]:fields:' \
  '(-i --filters)'{-i,--filters=}'[filter expression]:filter:' \
  '*-D-[set property key=value]:property:'
