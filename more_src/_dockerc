#compdef dockerc
# Documentation: https://github.com/NilsIrl/dockerc
# dockerc: compile a container image into a single static executable

local ret=1

_arguments -s -S \
  '--image=[container image source (docker://, docker-daemon:, ...)]:image' \
  '--output=[output binary filename]:file:_files' \
  '--arch=[target architecture (e.g. arm64, x86_64)]:arch:(arm64 x86_64)' \
  '*-e[specify environment variables (docker run style)]:env' \
  '*-v[specify volumes (docker run style)]:volume' \
  '*::args:_default' && ret=0

return ret
