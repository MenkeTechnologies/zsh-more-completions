#compdef atob
# Documentation: man atob(1)
# Source: nss-dev/nss cmd/atob/atob.c (master) — NSS ASCII-to-binary base64 decoder (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input file]:file:_files' \
    '-o+[output file]:file:_files' \
    '(-? -h)'{-\\?,-h}'[show help]' \
    && ret=0

return ret
