#compdef kresc kresd-cli
# _kresc — CZ.NIC Knot Resolver kresc (interactive Lua/HTTP control client over the kresd control socket; -h help, -V version, -s socket path override, -t timeout seconds; once attached: hint.*, cache.*, net.*, policy.*, modules.*, stats.*, watchdog.*, predict.*, prefill.*, http.*, daemon-builtin globals)
# upstream: https://gitlab.nic.cz/knot/knot-resolver
# Flags from knot-resolver src/utils/kresc on tip.

_kresc() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-s+[socket path]:file:_files' \
        '-t+[timeout seconds]:seconds:' \
        '*::command:'
}

_kresc "$@"
