#compdef cargo-ndk
# Documentation: https://github.com/bbqsrc/cargo-ndk
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for cargo-ndk (Android NDK Rust builds)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '*-t+[Target Android architecture (ABI or triple)]:target:(armeabi-v7a arm64-v8a x86 x86_64 armv7-linux-androideabi aarch64-linux-android i686-linux-android x86_64-linux-android thumbv7neon-linux-androideabi)' \
  '*--target=[Target Android architecture (ABI or triple)]:target:(armeabi-v7a arm64-v8a x86 x86_64 armv7-linux-androideabi aarch64-linux-android i686-linux-android x86_64-linux-android thumbv7neon-linux-androideabi)' \
  '-p+[Android platform API level]:platform' \
  '--platform=[Android platform API level]:platform' \
  '-o+[Output directory for built libraries]:dir:_directories' \
  '--output-dir=[Output directory for built libraries]:dir:_directories' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '--bindgen[Use bindgen for generating bindings]' \
  '--no-strip[Do not strip debug symbols]' \
  '--link-builtins[Link compiler builtins]' \
  '--link-libcxx-shared[Link libc++_shared.so]' \
  '*-v[Verbose output (stackable)]' \
  '*:cargo args' && ret=0

return ret
