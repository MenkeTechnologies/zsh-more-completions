#compdef cargo-ndk

# Zsh completion for cargo-ndk (Android NDK Rust builds)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-t+[Target Android architecture]:target:(armv7-linux-androideabi aarch64-linux-android i686-linux-android x86_64-linux-android thumbv7neon-linux-androideabi)' \
  '--target=[Target Android architecture]:target:(armv7-linux-androideabi aarch64-linux-android i686-linux-android x86_64-linux-android thumbv7neon-linux-androideabi)' \
  '-p+[Android platform API level]:platform' \
  '--platform=[Android platform API level]:platform' \
  '-o+[Output directory for built libraries]:dir:_directories' \
  '--output-dir=[Output directory for built libraries]:dir:_directories' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '--bindgen[Use bindgen for generating bindings]' \
  '--no-strip[Do not strip debug symbols]' \
  '*:cargo args' && ret=0

return ret
