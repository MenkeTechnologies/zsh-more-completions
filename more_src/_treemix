#compdef treemix
# Documentation: https://speciationgenomics.github.io/Treemix/
# TreeMix: infer population splits and mixtures from allele frequency data

local ret=1

_arguments -s -S \
  '-i+[input file (.frq.gz format)]:file:_files -g "*.frq.gz"' \
  '-o+[output file prefix]:prefix' \
  '-m+[number of migration edges to add]:int' \
  '-root+[designate the outgroup population]:population' \
  '-bootstrap[enable bootstrap resampling]' \
  '-k+[block size for jackknife resampling]:int' \
  '-noss[disable correction for small sample size]' && ret=0

return ret
