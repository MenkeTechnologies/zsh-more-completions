#compdef spflux
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Flux calibrate a spectrum using a calibration spectrum

local ret=1

_arguments -s -S \
  'SPECTRUM=[spectrum to be calibrated]:spectrum:_files' \
  'CALSPECT=[calibration spectrum to apply]:calspect:_files' \
  'OUTPUT=[resulting calibrated spectrum]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
