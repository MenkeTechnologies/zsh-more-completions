#compdef gup

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'update:update all binaries installed by go install'
  'list:list installed Go binaries'
  'remove:remove a Go binary'
  'check:check for available updates'
  'export:export list of installed packages'
  'import:install packages from exported list'
  'bug-report:generate a bug report'
  'version:show version'
  'completion:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gup command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (update)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-d[dry run]' \
          '-j[number of parallel jobs]:jobs:' \
          '-e[exclude packages]:package:' \
          '*:package:' && ret=0
        ;;
      (remove)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:package:' && ret=0
        ;;
      (export)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-o[output file]:file:_files' && ret=0
        ;;
      (import)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-i[input file]:file:_files' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
