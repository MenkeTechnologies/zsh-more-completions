#compdef pdftoedn
# Documentation: https://github.com/jackrusher/pdftoedn/blob/master/src/main.cc
# pdftoedn - extract PDF document data and save it in EDN format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this message]' \
  '(-v --version)'{-v,--version}'[display version information and exit]' \
  '(-F --show_font_map_list)'{-F,--show_font_map_list}'[display the configured font substitution list and exit]' \
  '(-a --use_page_crop_box)'{-a,--use_page_crop_box}'[use page crop box instead of media box]' \
  '(-D --debug_meta)'{-D,--debug_meta}'[include additional debug metadata in output]' \
  '(-f --force)'{-f,--force}'[overwrite output file if it exists]' \
  '(-i --invisible_text)'{-i,--invisible_text}'[include invisible text (for OCR documents)]' \
  '(-d --write_doc_edn_only)'{-d,--write_doc_edn_only}'[write only EDN output, omit image blobs]' \
  '(-L --links_only)'{-L,--links_only}'[extract only link data]' \
  '(-T --text_only)'{-T,--text_only}'[extract only text data]' \
  '(-G --graphics_only)'{-G,--graphics_only}'[extract only graphics data]' \
  '(-O --omit_outline)'{-O,--omit_outline}'[do not extract outline data]' \
  '(-m --font_map_file)'{-m,--font_map_file}'=[JSON font mapping configuration file]:file:_files -g "*.json"' \
  '(-p --page_number)'{-p,--page_number}'=[extract data for only this page]:page' \
  '(-t --owner_password)'{-t,--owner_password}'=[PDF owner password]:password' \
  '(-u --user_password)'{-u,--user_password}'=[PDF user password]:password' \
  '(-o --output_file)'{-o,--output_file}'=[REQUIRED destination .edn file]:file:_files -g "*.edn"' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
