#compdef phalanx
# Documentation: https://man.archlinux.org/search?q=phalanx
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-l+[learning file]:file:_files' \
  '-b+[opening book]:file:_files' \
  '-e+[engine option]:opt:' \
  '-o+[option]:opt:' \
  '-d+[skill level]:lvl:' && ret=0

return ret
