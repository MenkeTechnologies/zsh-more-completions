#compdef fireworks

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--api-key[Fireworks API key]:key:' \
  '--account-id[account ID]:id:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'login:log in to Fireworks'
      'deploy:deploy a model'
      'fine-tune:create a fine-tuning job'
      'models:manage models'
      'accounts:manage accounts'
    )
    _describe -t commands 'fireworks command' commands && ret=0
    ;;
  args)
    case $line[1] in
      models)
        local -a model_commands
        model_commands=(
          'list:list models'
        )
        _describe -t commands 'models command' model_commands && ret=0
        ;;
      accounts)
        local -a account_commands
        account_commands=(
          'list:list accounts'
          'get:get account details'
        )
        _describe -t commands 'accounts command' account_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
