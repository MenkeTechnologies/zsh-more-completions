#compdef tap

# Zsh completion for node-tap (Node.js TAP test runner)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run test files (default)'
  'report:generate a report from TAP input'
  'replay:replay a previous test run from .tap directory'
  'plugin:manage plugins'
  'config:manage configuration'
  'list:list test files'
  'build:build the test runner'
  'version:show the version'
  'help:get help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-R --reporter)'{-R,--reporter}'[set reporter]:reporter:(base terse min spec tap junit markdown json jsonstream classic)' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel test jobs]:jobs' \
  '(-t --timeout)'{-t,--timeout}'[timeout for each test in ms]:ms' \
  '--bail[bail out on first failure]' \
  '--no-bail[do not bail on first failure]' \
  '--comments[print all TAP comments]' \
  '--no-comments[suppress TAP comments]' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '(-c --coverage)'{-c,--coverage}'[enable coverage reporting]' \
  '--no-coverage[disable coverage reporting]' \
  '--coverage-report[set coverage report type]:type:(text text-summary html json lcov)' \
  '--coverage-map[coverage map module]:file:_files -g "*.js"' \
  '(-g --grep)'{-g,--grep}'[filter tests by pattern]:pattern' \
  '(-i --invert)'{-i,--invert}'[invert grep pattern match]' \
  '--changed[only run tests for changed files]' \
  '--save[save failed tests to file]:file:_files' \
  '--only[only run tests with .only]' \
  '--typecheck[type-check test files]' \
  '--no-typecheck[skip type checking]' \
  '--node-arg[pass arguments to node]:arg' \
  '--before[script to run before tests]:file:_files' \
  '--after[script to run after tests]:file:_files' \
  '--output-dir[directory for coverage and results]:dir:_files -/' \
  '--output-file[file to write TAP output]:file:_files' \
  '--debug[turn on debug mode]' \
  '*:test file:_files -g "*.{js,mjs,cjs,ts,mts,cts,jsx,tsx}"' && ret=0

case $state in
  (command)
    _describe -t commands 'tap command' commands && ret=0
    ;;
esac

return ret
