#compdef llvm-strings
# _llvm-strings — LLVM strings (LLVM project, C++); print printable sequences, GNU strings-compatible
# upstream: https://github.com/llvm/llvm-project

_llvm-strings() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-a[scan whole file]' \
        '--all[scan whole file]' \
        '-f[print filename]' \
        '--print-file-name[print filename]' \
        '-n+[min length]:n:' \
        '--bytes=+[min length]:n:' \
        '-s+[separator]:str:' \
        '--separator=+[separator]:str:' \
        '-t+[radix]:base:(d o x)' \
        '--radix=+[radix]:base:(d o x)' \
        '*:file:_files'
}

_llvm-strings "$@"
