#compdef hdfimport
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdfimport.1.en.html
# Import ASCII or binary data into an HDF SDS or raster image

local ret=1

_arguments -s \
  '*-t+[data type for ASCII input (FP32,FP64,INT32,INT16,INT8)]:type:(FP32 FP64 INT32 INT16 INT8)' \
  '*-type+[data type for ASCII input (FP32,FP64,INT32,INT16,INT8)]:type:(FP32 FP64 INT32 INT16 INT8)' \
  '*-n[binary input file contains 64-bit floating point data]' \
  '(-o -outfile)'{-o+,-outfile+}'[output HDF file]:output file:_files -g "*.(hdf|h4)"' \
  '(-r -raster)'{-r,-raster}'[store output as a raster image set]' \
  '(-f -float)'{-f,-float}'[store output as a scientific data set (default)]' \
  '(-e -expand)'{-e,-expand}'[expand float data via pixel replication]' \
  '(-i -interp)'{-i,-interp}'[apply bilinear/trilinear interpolation to float data]' \
  '(-p -palfile)'{-p+,-palfile+}'[associate a palette with the output image]:palette file:_files' \
  '(-m -mean)'{-m+,-mean+}'[scale image data symmetrically around mean]:mean' \
  '*:input file:_files' && ret=0

return ret
