#compdef git-subtree

# Zsh completion for git-subtree (merge subtrees and split repositories)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-P --prefix)'{-P,--prefix}'[specify subtree prefix directory]:prefix:_files -/' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'add:add a subtree'
      'merge:merge recent changes into subtree'
      'split:extract a new project history from subtree'
      'pull:pull recent changes from subtree repository'
      'push:push recent changes to subtree repository'
    )
    _describe -t commands 'git-subtree command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (add)
        _arguments \
          '--squash[merge subtree changes as single commit]' \
          '(-m --message)'{-m,--message}'[specify commit message]:message' \
          '1:repository:_urls' \
          '2:ref' && ret=0
        ;;
      (merge)
        _arguments \
          '--squash[merge subtree changes as single commit]' \
          '(-m --message)'{-m,--message}'[specify commit message]:message' \
          '1:ref' && ret=0
        ;;
      (split)
        _arguments \
          '--annotate[add annotation to commit messages]:annotation' \
          '(-b --branch)'{-b,--branch}'[create a new branch]:branch name' \
          '--onto[set starting commit for split]:commit' \
          '--ignore-joins[ignore prior splits]' \
          '--rejoin[merge split history back]' && ret=0
        ;;
      (pull)
        _arguments \
          '--squash[merge subtree changes as single commit]' \
          '(-m --message)'{-m,--message}'[specify commit message]:message' \
          '1:repository:_urls' \
          '2:ref' && ret=0
        ;;
      (push)
        _arguments \
          '1:repository:_urls' \
          '2:ref' && ret=0
        ;;
    esac
    ;;
esac

return ret
