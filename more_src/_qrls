#compdef qrls
# Documentation: https://linux.die.net/man/1/qrls-torque
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qrls: release a hold on PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h+[hold types to release]:hold_list:(u o s)' \
  '*:jobid:' && ret=0
return ret
