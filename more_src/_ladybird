#compdef ladybird Ladybird
# Documentation: https://github.com/LadybirdBrowser/ladybird (Libraries/LibWebView/Application.cpp)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--headless=-[run without a browser window (optional mode: screenshot)]::mode:(screenshot)' \
  '--screenshot-delay=[seconds to wait before screenshot]:seconds:' \
  '--window-width=[viewport width in pixels]:pixels:' \
  '--window-height=[viewport height in pixels]:pixels:' \
  '(-C --certificate)'{-C,--certificate=}'[path to a certificate file]:cert:_files' \
  '(-n --new-window)'{-n,--new-window}'[force opening in a new window]' \
  '--force-new-process[force creation of a new browser process]' \
  '--allow-popups[disable popup blocking]' \
  '--disable-scripting[disable scripting by default]' \
  '--disable-sql-database[disable SQL database]' \
  '--tuple-file-origins[treat file:// URLs as having tuple origins]' \
  '--debug-process=[wait for debugger to attach to process]:name:' \
  '--profile-process=[enable callgrind profiling of process]:name:' \
  '--webdriver-mach-server-name=[mach server name for WebDriver]:name:' \
  '--webdriver-content-path=[path to WebDriver IPC]:path:_files' \
  '--test-mode[enable test mode]' \
  '--log-all-js-exceptions[log all JavaScript exceptions]' \
  '--disable-site-isolation[disable site isolation]' \
  '--enable-idl-tracing[enable IDL tracing]' \
  '--disable-http-memory-cache[disable HTTP memory cache]' \
  '--disable-http-disk-cache[disable HTTP disk cache]' \
  '--disable-content-blocker[disable content blocker]' \
  '*--content-blocker-list=[path to a content blocker list (repeatable)]:path:_files' \
  '--enable-autoplay[enable multimedia autoplay]' \
  '--expose-experimental-interfaces[expose experimental IDL interfaces]' \
  '--expose-internals-object[expose internals object]' \
  '--force-cpu-painting[force CPU painting]' \
  '--force-fontconfig[force using fontconfig for font loading]' \
  '(-g --collect-garbage-on-every-allocation)'{-g,--collect-garbage-on-every-allocation}'[collect garbage after every JS heap allocation]' \
  '--disable-scrollbar-painting[do not paint scrollbars on the main viewport]' \
  '--disable-async-scrolling[disable async scrolling]' \
  '--dns-server=[DNS server address]:addr:' \
  '--dns-port=[DNS server port]:port:' \
  '--dot[use DNS over TLS]' \
  '--dnssec[validate DNSSEC locally]' \
  '--default-time-zone=[default time zone]:tz:' \
  '--resource-map=[JSON file mapping URLs to local files]:file:_files' \
  '--dump-style-invalidation-counters=[dump style invalidation counters every N]:N:' \
  '--devtools=-[enable Firefox DevTools server (optional port)]::port:' \
  '--user-agent-preset=[name of User-Agent preset]:preset:' \
  '*:url:_urls' && ret=0

return ret
