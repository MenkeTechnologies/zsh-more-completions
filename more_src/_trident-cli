#compdef trident-cli tridentctl
# _trident-cli — NetApp Trident dynamic storage orchestrator for Kubernetes CLI alias (NetApp team, Go); cobra
# upstream: https://github.com/NetApp/trident

_trident-cli() {
    local -a sub=(
        'create:create resource'
        'create backend:create backend'
        'create configurator:create configurator'
        'delete:delete resource'
        'delete backend:delete backend'
        'delete node:delete node'
        'delete snapshot:delete snapshot'
        'delete storageclass:delete storage class'
        'delete volume:delete volume'
        'get:get resource'
        'get backend:get backend'
        'get backends:list backends'
        'get node:get node'
        'get nodes:list nodes'
        'get snapshot:get snapshot'
        'get snapshots:list snapshots'
        'get storageclass:get storage class'
        'get storageclasses:list storage classes'
        'get volume:get volume'
        'get volumes:list volumes'
        'get backend-config:get backend config'
        'get backend-status:get backend status'
        'get logging-level:get logging level'
        'install:install Trident'
        'list:list resources'
        'logs:get logs'
        'send:send a file to Trident'
        'set:set values'
        'set logging-level:set logging level'
        'uninstall:uninstall Trident'
        'update:update resource'
        'update backend:update backend'
        'version:show version'
        'help:show help'
        'completion:generate completion'
        'images:show required container images'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--server=+[host:port]:str:' \
        '-s+[host:port]:str:' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--config=+[kubeconfig]:file:_files' \
        '--debug[debug]' \
        '-d[debug]' \
        '--output=+[format]:f:(json yaml name wide)' \
        '-o+[format]:f:(json yaml name wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tridentctl subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                create:backend) _arguments \
                    '--filename=+[file]:file:_files -g "*.{json,yaml,yml}"' \
                    '-f+[file]:file:_files -g "*.{json,yaml,yml}"' \
                    '--base64-data=+[data]:str:' ;;
                install) _arguments \
                    '--silence-autosupport[silence autosupport]' \
                    '--silent[silent]' \
                    '--in-cluster[run as in-cluster job]' \
                    '--use-custom-yaml=+[dir]:dir:_files -/' \
                    '--generate-custom-yaml[generate yaml]' \
                    '--csi[csi mode]' \
                    '--enable-node-prep[enable node prep]' \
                    '--log-format=+[format]:f:(text json)' \
                    '--image-registry=+[registry]:str:' \
                    '--image-pull-secrets=+[secret]:str:' \
                    '--trident-image=+[image]:str:' \
                    '--autosupport-image=+[image]:str:' \
                    '--autosupport-proxy=+[proxy]:str:' \
                    '--autosupport-custom-url=+[url]:url:_urls' \
                    '--kubelet-dir=+[dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_trident-cli "$@"
