#compdef wlink
# Documentation: https://github.com/ch32-rs/wlink/blob/main/README.md
# WCH-Link command line tool for CH32 RISC-V MCUs

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --device)'{-d,--device}'=[device index to operate on]:index' \
  '*--verbose[increase verbosity]' \
  '--no-detach[do not detach chip after operation]' \
  '--chip=[specify chip type]:chip' \
  '--speed=[connection speed]:speed:(high low)' \
  '1: :((flash\:"flash firmware" dump\:"dump memory to file" regs\:"dump general purpose registers" erase\:"erase chip" unprotect\:"disable read protection" protect\:"enable read protection" write-reg\:"write register" write-mem\:"write memory word" halt\:"halt the core" resume\:"resume the core" reset\:"reset the device" status\:"show device status" mode-switch\:"switch link mode" list\:"list probes" set-power\:"set target power" sdi-print\:"control SDI print" dev\:"developer commands"))' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      flash)
        _arguments -s \
          '(-a --address)'{-a,--address}'=[flash address]:address' \
          '(-e --erase)'{-e,--erase}'[erase before flashing]' \
          '(-R --no-run)'{-R,--no-run}'[do not run after flashing]' \
          '--enable-sdi-print[enable SDI print]' \
          '--watch-serial[watch serial output]' \
          '*:firmware:_files' && ret=0
        ;;
      erase)
        _arguments -s '--method=[erase method]:method:(power-off pin-rst default)' && ret=0
        ;;
      dump)
        _arguments -s '(-o --out)'{-o,--out}'=[output file]:file:_files' && ret=0
        ;;
      reset)
        _arguments -s '1:mode:(quit run halt dm)' && ret=0
        ;;
      mode-switch)
        _arguments -s '--rv[switch to RV mode]' '--dap[switch to DAP mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
