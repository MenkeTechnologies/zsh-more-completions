#compdef iex
# Documentation: iex --help
# Source: Elixir IEx — interactive shell.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--dbg=[Kernel.dbg/2 backend]:backend:(pry)' \
    '--dot-iex=[evaluate FILE for IEx environment]:file:_files' \
    '--remsh=[connect via remote shell to NODE]:node:' \
    '*-e+[evaluate command]:command:' \
    '(- *)'{-h,--help}'[show help]' \
    '*-r+[require files]:file:_files' \
    '-S+[find and execute script]:script:_command_names -e' \
    '*-pa+[prepend to code path]:dir:_files -/' \
    '*-pz+[append to code path]:dir:_files -/' \
    '(- *)'{-v,--version}'[print versions]' \
    '(--color --no-color)--color[ANSI coloring]' \
    '(--color --no-color)--no-color[disable ANSI coloring]' \
    '*--erl=[Erlang switches]:switches:' \
    '--no-halt[do not halt VM after execution]' \
    '--cookie=[distributed-node cookie]:cookie:' \
    '--hidden[hidden node]' \
    '--name=[distributed node name]:name:' \
    '--sname=[distributed node short name]:name:' \
    '*:script + args:_files -g "*.{exs,ex}"' \
    && ret=0

return ret
