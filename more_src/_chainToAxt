#compdef chainToAxt
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# convert from chain to axt file

local ret=1

_arguments -s -S \
  '-maxGap=[maximum gap size allowed without breaking (default 100)]:n' \
  '-maxChain=[maximum chain size allowed without breaking]:n' \
  '-minScore=[minimum score of chain]:n' \
  '-minId=[minimum percentage ID within blocks]:n' \
  '-bed[output bed instead of axt]' \
  '1:in chain:_files -g "*.chain"' \
  '2:target nib dir or 2bit:_files' \
  '3:query nib dir or 2bit:_files' \
  '4:out axt:_files' && ret=0

return ret
