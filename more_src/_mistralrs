#compdef mistralrs mistralrs-server mistralrs-bench

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run interactive chat / inference'
  'serve:launch OpenAI-compatible HTTP server'
  'bench:run inference benchmarks'
  'tune:auto-tune optimal settings for the host'
  'from-config:run with a tuned configuration file'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --model)'{-m+,--model=}'[model id (HF) or path]:model:' \
  '--isq=[in-situ quantization level]:level:(2 3 4 5 6 8)' \
  '--cpu[force CPU only]' \
  '--num-device-layers=[layers per accelerator]:layers:' \
  '--max-seqs=[max parallel sequences]:n:' \
  '--no-kv-cache[disable KV cache]' \
  '--prompt-batchsize=[prompt batch size]:n:' \
  '--token-source=[HF token source]:src:' \
  '--seed=[random seed]:n:' \
  '--throughput[print throughput]' \
  '-i+[one-shot prompt input]:prompt:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mistralrs command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '--ui[serve a web UI]' \
          '--port=[server port]:port:' \
          '--host=[bind host]:host:_hosts' \
          '--api-key=[server API key]:key:' \
          '--max-running-requests=[max concurrent requests]:n:' && ret=0 ;;
      (run)
        _arguments \
          '--image=[image file for vision models]:file:_files' \
          '--audio=[audio file for audio models]:file:_files' && ret=0 ;;
      (tune)
        _arguments \
          '--emit-config=[output config file]:file:_files -g "*.toml"' \
          '--measure-time=[measurement duration]:duration:' && ret=0 ;;
      (from-config)
        _arguments \
          '(-f --file)'{-f+,--file=}'[config file]:file:_files -g "*.toml"' && ret=0 ;;
      (bench)
        _arguments \
          '--n-gen=[tokens to generate]:n:' \
          '--n-prompt=[prompt tokens]:n:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
