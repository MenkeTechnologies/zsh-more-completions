#compdef rust-strip
# Documentation: https://github.com/rust-embedded/cargo-binutils
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# cargo-binutils wrapper invoking llvm-strip.

# rust-strip: cargo-binutils wrapper for llvm-strip
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-s[remove all symbols]' \
  '-g[remove debug info]' \
  '-o[output file]:file:_files' \
  '*:object file:_files' && ret=0
return ret
