#compdef firewalld
# _firewalld-cli — firewalld daemon (dynamic + zone-based Linux firewall manager backed by nftables (or legacy iptables); -h help, -V version, --debug, --debug-gc trace gc events, --nofork stay foreground, --nopid skip pidfile; controlled at runtime by firewall-cmd(1) — daemon itself accepts very few flags beyond startup tuning)
# upstream: https://github.com/firewalld/firewalld
# Flags from firewalld src/firewalld.in on tip.

_firewalld-cli() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '--debug[debug]' \
        '--debug-gc[trace gc events]' \
        '--nofork[stay foreground]' \
        '--nopid[skip pidfile]'
}

_firewalld-cli "$@"
