#compdef elm-review

# Zsh completion for elm-review - opinionated Elm static analyzer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create an elm-review configuration'
  'new-package:create a new elm-review rule package'
  'new-rule:create a new elm-review rule in a package'
  'suppress:manage suppressed errors'
  'prepare-offline:prepare to run elm-review offline'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show elm-review version]' \
  '--config[path to review config]:dir:_files -/' \
  '--template[use a remote review configuration template]:template:' \
  '--compiler[path to elm compiler]:file:_files' \
  '--elm-format-path[path to elm-format]:file:_files' \
  '--elmjson[path to the elm.json file]:file:_files -g "elm.json"' \
  '--fix[automatically apply fixes]' \
  '--fix-all[apply all fixes]' \
  '--fix-all-without-prompt[apply all fixes without prompting]' \
  '--fix-limit[max fixes to apply]:n:' \
  '--unsuppress[remove suppression entries]' \
  '--unsuppress-rules[rules to unsuppress]:rules:' \
  '--rules[rules to run]:rules:' \
  '--ignore-dirs[directories to ignore]:dirs:' \
  '--ignore-files[files to ignore]:files:_files' \
  '--report[reporter format]:format:(human json ndjson)' \
  '--no-details[do not show error details]' \
  '--watch[watch for changes and re-run]' \
  '--watch-code[watch only source files]' \
  '--extract[extract rule data]' \
  '--details[show error details]' \
  '--debug[show debug info]' \
  '--benchmark-info[print benchmarking info]' \
  '--github-auth[GitHub auth token]:token:' \
  '--no-color[disable colored output]' \
  '--offline[do not fetch anything]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'elm-review command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--config[config directory]:dir:_files -/' \
          '--template[template]:template:' && ret=0
        ;;
      (new-rule)
        _arguments '1:rule name:' && ret=0
        ;;
      (suppress)
        _arguments '1:subcommand:(check)' && ret=0
        ;;
    esac
    ;;
esac

return ret
