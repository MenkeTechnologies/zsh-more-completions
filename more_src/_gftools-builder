#compdef gftools-builder
# Documentation: https://github.com/googlefonts/gftools
# Build a font family from sources using a recipe config

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--graph[draw a graph of the build process]' \
  '--no-ninja[do not run ninja]' \
  '--generate[just generate and output recipe from recipe builder]' \
  '--experimental-fontc=[use fontc instead of fontmake; path to fontc executable]:fontc:_files' \
  '--experimental-simple-output=[generate a reduced set of targets and copy to directory]:dir:_files -/' \
  '--experimental-single-source=[only compile the single named source file]:source:_files' \
  '*:config or source file:_files' && ret=0

return ret
