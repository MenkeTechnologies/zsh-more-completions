#compdef semgrep2
# _semgrep2 — Semgrep r2c semgrep2 CLI command-line frontend wrapping the Semgrep lightweight static analysis tool for many languages SAST find bugs and enforce code standards open-source written in OCaml and Python 30+ languages supported scan ci install-semgrep-pro publish login logout test validate show shouldafound lsp Pro-Engine SCA-software-composition-analysis interfile interfile-analysis taint-analysis dataflow-analysis Rules-from-Registry registry pattern AI-policies (Semgrep r2c team Drew Dennison, OCaml/Python); click
# upstream: https://semgrep.dev/

_semgrep2() {
    local -a sub=(
        'scan:scan code'
        'ci:CI scan'
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'install-semgrep-pro:install Semgrep Pro Engine'
        'publish:publish rules'
        'test:test rules'
        'validate:validate rules'
        'show:show info'
        'shouldafound:report missed finding'
        'lsp:LSP server'
        'install-pre-commit:install pre-commit'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '-c+[config]:str:' \
        '*-c+[config]:str:' \
        '--config=+[config]:str:' \
        '*--config=+[config]:str:' \
        '-e+[pattern]:str:' \
        '--pattern=+[pattern]:str:' \
        '-l+[language]:l:(python javascript typescript java go ruby c cpp rust kotlin swift php scala bash html json yaml hcl terraform docker generic)' \
        '--lang=+[lang]:l:(python javascript typescript java go ruby c cpp rust kotlin swift php scala bash html json yaml hcl terraform docker generic)' \
        '--include=+[glob]:str:' \
        '*--include=+[glob]:str:' \
        '--exclude=+[glob]:str:' \
        '*--exclude=+[glob]:str:' \
        '--exclude-rule=+[id]:str:' \
        '--severity=+[s]:s:(INFO WARNING ERROR)' \
        '*--severity=+[s]:s:(INFO WARNING ERROR)' \
        '--jobs=+[N]:n:' \
        '-j+[jobs]:n:' \
        '--max-memory=+[MB]:n:' \
        '--timeout=+[sec]:n:' \
        '--timeout-threshold=+[N]:n:' \
        '--no-rewrite-rule-ids[no rewrite]' \
        '--metrics=+[m]:m:(auto on off)' \
        '--disable-version-check[no version check]' \
        '--baseline-commit=+[sha]:str:' \
        '--use-git-ignore[use gitignore]' \
        '--no-git-ignore[no gitignore]' \
        '--scan-unknown-extensions[scan unknown ext]' \
        '--skip-unknown-extensions[skip unknown ext]' \
        '--enable-version-check[enable version check]' \
        '--strict[strict]' \
        '--dry-run[dry run]' \
        '--dryrun[dry run]' \
        '--autofix[autofix]' \
        '-a[autofix]' \
        '--replacement=+[str]:str:' \
        '--text[plain output]' \
        '--json[JSON output]' \
        '--gitlab-sast[GitLab SAST format]' \
        '--gitlab-secrets[GitLab secrets format]' \
        '--junit-xml[JUnit XML format]' \
        '--sarif[SARIF format]' \
        '--emacs[Emacs format]' \
        '--vim[Vim format]' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--time[show timing]' \
        '--verbose-stats[verbose stats]' \
        '--no-suppress-errors[no suppress errors]' \
        '--error[fail on findings]' \
        '--max-target-bytes=+[bytes]:n:' \
        '--max-lines-per-finding=+[N]:n:' \
        '--enable-experimental[experimental]' \
        '--oss-only[OSS only]' \
        '--interfile-timeout=+[sec]:n:' \
        '--pro[use Pro engine]' \
        '--pro-intrafile[Pro intrafile]' \
        '--pro-langs[Pro languages]' \
        '--pro-interfile[Pro interfile]' \
        '--code[code policies]' \
        '--supply-chain[SCA policies]' \
        '--secrets[secrets policies]' \
        '--no-secrets-validation[no secrets validation]' \
        '--allow-untrusted-validators[allow untrusted]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'semgrep subcommand' sub ;;
        args) _arguments '*:path:_files -/' ;;
    esac
}

_semgrep2 "$@"
