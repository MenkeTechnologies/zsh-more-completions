#compdef showorf
# showorf - Display a nucleotide sequence and translation in pretty format

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input nucleotide sequence]:file:_files' \
  '-frames[reading frames to translate]:frames:' \
  '-outfile[output file name]:file:_files' \
  '-table[genetic code table for translation]:table:' \
  '-ruler[toggle ruler display above sequences]' \
  '-plabel[number translation lines]' \
  '-nlabel[number DNA sequence lines]' \
  '-width[screen display width in characters]:width:' \
  '-sbegin1[sequence start position]:pos:' \
  '-send1[sequence end position]:pos:' \
  '-sreverse1[reverse DNA sequence]' \
  '-sformat1[input sequence format]:format:' \
  '-sdbname1[database name]:db:' \
  '-sid1[entry name]:id:' \
  '-auto[turn off prompts]' \
  '-verbose[report command line options]' \
  '-debug[write debug output]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
