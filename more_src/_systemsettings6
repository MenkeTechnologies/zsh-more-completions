#compdef systemsettings6
# Documentation: https://invent.kde.org/plasma/systemsettings
# Reference accessed: 2026-05-16
# Verified: Qt KCommandLineParser standard options. systemsettings5 (KF5) and
# systemsettings6 (KF6) share the same flag surface.

# systemsettings: KDE Plasma System Settings
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--list[list available modules]' \
  '*:module name:' && ret=0
return ret
