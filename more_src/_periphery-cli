#compdef periphery-cli
# _periphery-cli — peripheryapp Periphery Swift unused code identifier CLI alias (Ian Leitch / peripheryapp, Swift); custom argparse
# upstream: https://github.com/peripheryapp/periphery

_periphery-cli() {
    local -a sub=(
        'scan:scan project for unused code'
        'check-update:check for updates'
        'clear-cache:clear file cache'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".periphery.yml *.yml"' \
        '-c+[config file]:file:_files -g ".periphery.yml *.yml"' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--disable-update-check[disable update check]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'periphery subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '--project=+[xcode project]:file:_files -g "*.xcodeproj"' \
                    '-p+[xcode project]:file:_files -g "*.xcodeproj"' \
                    '--workspace=+[xcode workspace]:file:_files -g "*.xcworkspace"' \
                    '-w+[xcode workspace]:file:_files -g "*.xcworkspace"' \
                    '--schemes=+[schemes]:list:' \
                    '-s+[schemes]:list:' \
                    '--targets=+[targets]:list:' \
                    '-t+[targets]:list:' \
                    '--exclude-targets=+[exclude targets]:list:' \
                    '--exclude-tests[exclude tests]' \
                    '--retain-public[retain public]' \
                    '--retain-objc-accessible[retain objc accessible]' \
                    '--retain-objc-annotated[retain objc annotated]' \
                    '--retain-unused-protocol-func-params[retain unused protocol func params]' \
                    '--retain-swift-ui-previews[retain SwiftUI previews]' \
                    '--retain-codable-properties[retain codable properties]' \
                    '--retain-encodable-properties[retain encodable properties]' \
                    '--retain-files=+[retain files]:list:_files' \
                    '--clean-build[clean build]' \
                    '--build-arguments=+[build arguments]:str:' \
                    '--index-store-path=+[index store path]:dir:_files -/' \
                    '--skip-build[skip build]' \
                    '--report-includes=+[report includes]:list:' \
                    '--report-excludes=+[report excludes]:list:' \
                    '--strict[strict mode]' \
                    '--retain-assign-only-property[retain assign-only properties]' \
                    '--retain-assign-only-property-types=+[retain assign-only types]:list:' \
                    '--external-encodable-protocols=+[external encodable protocols]:list:' \
                    '--external-test-case-classes=+[external test case classes]:list:' \
                    '--file-targets-path=+[file targets path]:file:_files' \
                    '--format=+[output format]:fmt:(xcode csv codeclimate json checkstyle github-actions)' \
                    '-f+[output format]:fmt:(xcode csv codeclimate json checkstyle github-actions)' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--baseline=+[baseline file]:file:_files' \
                    '--write-baseline=+[write baseline]:file:_files' \
                    '--swift-version=+[swift version]:str:' \
                    '--use-build-cache[use build cache]' \
                    '--no-use-build-cache[no use build cache]' \
                    '--use-index-store[use index store]' \
                    '--package-manifest-path=+[package manifest path]:file:_files' ;;
            esac
            ;;
    esac
}

_periphery-cli "$@"
