#compdef jp2a
# Documentation: https://manpages.debian.org/testing/jp2a/jp2a.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jp2a - JPEG/PNG/WebP to ASCII converter.
# Corrected from prior file: removed invented --clear; value options
# now take =arg per the man page; added real flags --xhtml, --htmlls,
# --term-zoom, --term-center, --zoom, --edge-threshold, --edges-only,
# --debug.

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--debug[print additional debug information]' \
  '--verbose[verbose output]' \
  '--width=[set output width]:width:' \
  '--height=[set output height]:height:' \
  '--size=[set output dimension WxH]:WxH:' \
  '--chars=[set character ramp]:characters:' \
  '--colors[enable color output]' \
  '--color-depth=[set color depth]:depth:(4 8 24)' \
  '--background=[set background mode]:mode:(light dark)' \
  '--border[draw border around image]' \
  '--fill[use fill characters]' \
  '--flipx[flip image horizontally]' \
  '--flipy[flip image vertically]' \
  '--grayscale[convert to grayscale]' \
  '--invert[invert image]' \
  '--html[output as HTML]' \
  '--xhtml[output as XHTML]' \
  '--htmlls[output as HTML using CSS line-height]' \
  '--html-fill[use background fill in HTML output]' \
  '--html-fontsize=[set HTML font size]:size:' \
  '--html-no-bold[disable bold in HTML output]' \
  '--html-raw[output raw HTML]' \
  '--html-title=[set HTML title]:title:' \
  '--output=[write output to file]:output file:_files' \
  '--red=[set red weight]:weight:' \
  '--green=[set green weight]:weight:' \
  '--blue=[set blue weight]:weight:' \
  '--edge-threshold=[gradient above which to shade edges]:threshold:' \
  '--edges-only[only render edges]' \
  '--term-fit[fit to terminal size]' \
  '--term-height[fit to terminal height]' \
  '--term-width[fit to terminal width]' \
  '--term-center[center output in the terminal]' \
  '--term-zoom[zoom to fill terminal]' \
  '--zoom[zoom the image]' \
  '*:image file:_files -g "*.{jpg,jpeg,png,gif,bmp,tif,tiff,webp}"'
