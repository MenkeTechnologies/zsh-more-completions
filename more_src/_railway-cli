#compdef railway

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add database to project'
  'completion:generate shell completion'
  'connect:connect to a database'
  'deploy:deploy a Dockerfile/template'
  'docs:open docs'
  'down:remove most recent deployment'
  'environment:environment commands'
  'help:show help'
  'init:initialize project'
  'link:link to a project'
  'list:list projects'
  'login:log in'
  'logout:log out'
  'logs:show logs'
  'open:open project in browser'
  'redeploy:redeploy latest deployment'
  'run:run a command with railway env vars'
  'service:service commands'
  'shell:open shell with railway env'
  'ssh:open SSH session'
  'starship:starship prompt module'
  'status:show project status'
  'unlink:unlink from project'
  'up:upload and deploy project'
  'variables:variable commands'
  'volume:volume commands'
  'whoami:show current user'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'railway command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-s --service)'{-s+,--service=}'[service]:s:' \
          '(-e --environment)'{-e+,--environment=}'[environment]:e:' \
          '*: :' && ret=0 ;;
      (logs)
        _arguments \
          '(-d --deployment)'{-d,--deployment}'[deployment logs]' \
          '(-b --build)'{-b,--build}'[build logs]' \
          '(-s --service)'{-s+,--service=}'[service]:s:' \
          '(-e --environment)'{-e+,--environment=}'[environment]:e:' \
          '*: :' && ret=0 ;;
      (variables)
        _arguments \
          '1:subcommand:(get set delete list)' \
          '*: :' && ret=0 ;;
      (environment)
        _arguments \
          '1:subcommand:(use create delete)' \
          '*: :' && ret=0 ;;
      (service)
        _arguments \
          '1:subcommand:(create delete connect)' \
          '*: :' && ret=0 ;;
      (volume)
        _arguments \
          '1:subcommand:(create attach detach delete list)' \
          '*: :' && ret=0 ;;
      (up)
        _arguments \
          '(-c --ci)'{-c,--ci}'[CI mode]' \
          '(--detach)--detach[detach]' \
          '(-s --service)'{-s+,--service=}'[service]:s:' \
          '(-e --environment)'{-e+,--environment=}'[environment]:e:' \
          '(-p --path-as-root)'{-p,--path-as-root}'[path as root]' \
          '*: :_files' && ret=0 ;;
      (deploy)
        _arguments \
          '(-d --detach)'{-d,--detach}'[detach]' \
          '(-t --template)'{-t+,--template=}'[template URL]:url:' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
