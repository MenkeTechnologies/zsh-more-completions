#compdef osmcoastline_ways
# Documentation: https://docs.osmcode.org/osmcoastline/latest/osmcoastline_ways.html
# Write coastline ways from osmcoastline_filter output into a Spatialite database.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:input OSM file:_files -g "*.(osm|osm.bz2|osm.pbf|osm.gz|opl)(-.)"' \
  '2:output database:_files -g "*.db(-.)"' && ret=0

return ret
