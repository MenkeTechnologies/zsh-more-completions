#compdef xfs_rtcp
# _xfs_rtcp — xfsprogs xfs_rtcp (copy a regular file to the XFS realtime device subvolume; -e extsize sets the realtime extent size, -p prealloc only, -V show version, last argument is target on the realtime subvolume)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs rtcp/xfs_rtcp.c on tip.

_xfs_rtcp() {
    _arguments \
        '-V[show version]' \
        '-e+[realtime extent size]:bytes:' \
        '-p[preallocate only]' \
        '*:file:_files'
}

_xfs_rtcp "$@"
