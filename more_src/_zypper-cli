#compdef zypper-cli
# _zypper-cli — openSUSE Zypper RPM package manager CLI alias (SUSE / openSUSE community, C++); custom argparse
# upstream: https://github.com/openSUSE/zypper

_zypper-cli() {
    local -a sub=(
        'help:show help'
        'install:install packages'
        'in:install (alias)'
        'remove:remove packages'
        'rm:remove (alias)'
        'verify:check dependencies'
        've:verify (alias)'
        'source-install:install source packages'
        'si:source-install (alias)'
        'install-new-recommends:install new recommends'
        'inr:install-new-recommends (alias)'
        'update:update'
        'up:update (alias)'
        'list-updates:list updates'
        'lu:list-updates (alias)'
        'patch:install patches'
        'list-patches:list patches'
        'lp:list-patches (alias)'
        'dist-upgrade:distribution upgrade'
        'dup:dist-upgrade (alias)'
        'patch-check:check for patches'
        'pchk:patch-check (alias)'
        'patches:list patches'
        'pch:patches (alias)'
        'packages:list packages'
        'pa:packages (alias)'
        'patterns:list patterns'
        'pt:patterns (alias)'
        'products:list products'
        'pd:products (alias)'
        'info:show info'
        'if:info (alias)'
        'patch-info:show patch info'
        'pattern-info:show pattern info'
        'product-info:show product info'
        'what-provides:list providers'
        'wp:what-provides (alias)'
        'search:search packages'
        'se:search (alias)'
        'repos:list repositories'
        'lr:repos (alias)'
        'addrepo:add repository'
        'ar:addrepo (alias)'
        'removerepo:remove repository'
        'rr:removerepo (alias)'
        'renamerepo:rename repository'
        'nr:renamerepo (alias)'
        'modifyrepo:modify repository'
        'mr:modifyrepo (alias)'
        'refresh:refresh repositories'
        'ref:refresh (alias)'
        'clean:clean cache'
        'cc:clean (alias)'
        'services:list services'
        'ls:services (alias)'
        'addservice:add service'
        'as:addservice (alias)'
        'removeservice:remove service'
        'rs:removeservice (alias)'
        'modifyservice:modify service'
        'ms:modifyservice (alias)'
        'refresh-services:refresh services'
        'refs:refresh-services (alias)'
        'targetos:show target OS'
        'tos:targetos (alias)'
        'versioncmp:compare versions'
        'vcmp:versioncmp (alias)'
        'licenses:show installed licenses'
        'ps:list processes using deleted files'
        'lock:lock packages'
        'al:lock (alias)'
        'unlock:unlock packages'
        'rl:unlock (alias)'
        'locks:show locks'
        'll:locks (alias)'
        'cleanlocks:clean locks'
        'cl:cleanlocks (alias)'
        'shell:start zypper shell'
        'sh:shell (alias)'
        'subcommand:list/run subcommands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--non-interactive[non interactive]' \
        '-n[non interactive]' \
        '--no-gpg-checks[no gpg checks]' \
        '--gpg-auto-import-keys[gpg auto import keys]' \
        '--root=+[root]:dir:_files -/' \
        '-R+[root]:dir:_files -/' \
        '--installroot=+[install root]:dir:_files -/' \
        '--xmlout[XML output]' \
        '-x[XML output]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--reposd-dir=+[reposd dir]:dir:_files -/' \
        '-D+[reposd dir]:dir:_files -/' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '-C+[cache dir]:dir:_files -/' \
        '--no-refresh[no refresh]' \
        '--no-cd[no CD]' \
        '--no-remote[no remote]' \
        '--releasever=+[release version]:str:' \
        '--terse[terse output]' \
        '-t[terse output]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--ignore-unknown[ignore unknown]' \
        '-i[ignore unknown]' \
        '--no-cd[no CD]' \
        '--plus-repo=+[plus repo]:str:' \
        '-p+[plus repo]:str:' \
        '--plus-content=+[plus content]:str:' \
        '--disable-repositories[disable repos]' \
        '--exclude-debuginfo[exclude debuginfo]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zypper subcommand' sub ;;
        args)
            case $words[1] in
                install|in|remove|rm|info|if|verify|ve|search|se|update|up|patch|source-install|si|download|what-provides|wp) _arguments '*:package:' ;;
                addrepo|ar) _arguments \
                    '--check[check]' \
                    '--no-check[no check]' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--keep-packages[keep packages]' \
                    '-K[keep packages]' \
                    '--no-keep-packages[no keep packages]' \
                    '-k[no keep packages]' \
                    '--gpgcheck[gpgcheck]' \
                    '-g[gpgcheck]' \
                    '--no-gpgcheck[no gpgcheck]' \
                    '-G[no gpgcheck]' \
                    '--enable[enable]' \
                    '--disable[disable]' \
                    '--refresh[refresh]' \
                    '-f[refresh]' \
                    '--priority=+[priority]:n:' \
                    '-p+[priority]:n:' \
                    '*:repo-url:_urls' ;;
                lock|al|unlock|rl) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_zypper-cli "$@"
