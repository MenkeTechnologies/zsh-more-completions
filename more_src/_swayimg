#compdef swayimg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-r --recursive)'{-r,--recursive}'[search directories recursively]' \
  '(-o --order)'{-o,--order}'[set file sorting order]:order:(none alpha random)' \
  '(-s --scale)'{-s,--scale}'[set initial scale]:scale:(optimal fit real fill)' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
  '(-p --position)'{-p,--position}'[set window position]:position:' \
  '(-g --size)'{-g,--size}'[set window size]:size:' \
  '(-a --class)'{-a,--class}'[set window class]:class:' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config:_files' \
  '--no-sway[do not use sway integration]' \
  '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,tiff,tif,webp,svg,ico,pnm,ppm,pgm,pbm,qoi,avif,jxl,heif,heic}(-.)"' && ret=0

return ret
