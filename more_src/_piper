#compdef piper
# Documentation: https://man.archlinux.org/search?q=piper
# Reference accessed: 2026-05-16

_arguments -s \
  '(-m --model)'{-m,--model}'[onnx model path]:model:_files -g "*.onnx"' \
  '(-c --config)'{-c,--config}'[model config file]:config:_files -g "*.json"' \
  '*'{-i,--input-file}'[input text file]:file:_files' \
  '(-f --output-file)'{-f,--output-file}'[output WAV file]:file:_files' \
  '(-d --output-dir)'{-d,--output-dir}'[output directory]:dir:_files -/' \
  '--output-dir-naming=[naming scheme]:scheme:(timestamp text)' \
  '--output-raw[stream raw audio to stdout]' \
  '(-s --speaker)'{-s,--speaker}'[speaker id]:int:' \
  '--length-scale=[phoneme length]:float:' \
  '--noise-scale=[generator noise]:float:' \
  '--noise-w-scale=[phoneme width noise]:float:' \
  '--cuda[use GPU]' \
  '--sentence-silence=[sentence silence (s)]:float:' \
  '--volume=[volume multiplier]:float:' \
  '--no-normalize[disable volume normalization]' \
  '*--data-dir=[voice model dir]:dir:_files -/' \
  '--debug[debug logging]'
