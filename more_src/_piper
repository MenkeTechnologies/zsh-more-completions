#compdef piper
# Documentation: https://github.com/rhasspy/piper
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Args verified against src/python_run/piper/__main__.py.

_arguments -s \
  '(-m --model)'{-m,--model}'[onnx model path or name]:model:_files -g "*.onnx"' \
  '(-c --config)'{-c,--config}'[model config file]:config:_files -g "*.json"' \
  '(-f --output-file)'{-f,--output-file}'[output WAV file]:file:_files' \
  '(-d --output-dir)'{-d,--output-dir}'[output directory]:dir:_files -/' \
  '--output-raw[stream raw audio to stdout]' \
  '(-s --speaker)'{-s,--speaker}'[speaker id]:int:' \
  '--length-scale=[phoneme length]:float:' \
  '--noise-scale=[generator noise]:float:' \
  '--noise-w=[phoneme width noise]:float:' \
  '--cuda[use GPU]' \
  '--sentence-silence=[sentence silence (s)]:float:' \
  '*--data-dir=[voice model dir]:dir:_files -/' \
  '--download-dir=[directory for downloaded models]:dir:_files -/' \
  '--update-voices[update voices.json before lookup]' \
  '--debug[debug logging]'
