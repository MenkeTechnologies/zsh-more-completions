#compdef Hopper hopper
# _hopper — Hopper Disassembler (cryptic apps); macOS/Linux native disassembler/decompiler GUI with scripting
# upstream: https://www.hopperapp.com

_hopper() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-e+[execute hopper script]:file:_files -g "*.py"' \
        '-s+[execute Hopper Script Language]:file:_files -g "*.hopperscript"' \
        '-o+[output dir]:dir:_files -/' \
        '-y[skip confirmations]' \
        '-l+[loader]:loader:' \
        '-d+[document file]:file:_files' \
        '-r[generate readable assembly]' \
        '*:binary:_files'
}

_hopper "$@"
