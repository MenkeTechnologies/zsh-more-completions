#compdef icadd
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Add a constant to an image

local ret=1

_arguments -s -S \
  'IMAGE=[image]:image:_files' \
  'FACTOR=[constant value]:factor:' \
  'OUTPUT=[resulting image]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
