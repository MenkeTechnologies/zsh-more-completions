#compdef vmgateway
# VictoriaMetrics gateway for multi-tenant JWT auth and rate limiting

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-auth.httpHeader=[HTTP header name to look for JWT authorization token]:header' \
  '-auth.jwksEndpoints=[JWKS endpoints to fetch keys for JWT signature verification]:endpoints' \
  '-auth.oidcDiscoveryEndpoints=[OpenID Connect discovery endpoints]:endpoints' \
  '-auth.publicKeyFiles=[path to files containing public keys for JWT verification]:_files' \
  '-auth.publicKeys=[public keys for JWT verification]:keys' \
  '-enable.auth[activate JWT-based authentication]' \
  '-enable.rateLimit[activate rate limiter functionality]' \
  '-ratelimit.config=[configuration file path for rate limits]:_files' \
  '-ratelimit.configCheckInterval=[how often to reload rate limit config]:interval' \
  '-ratelimit.extraLabels=[additional labels for datasource queries]:labels' \
  '-ratelimit.refreshInterval=[refresh interval for rate limit data]:interval' \
  '-clusterMode[enable cluster version support]' \
  '-read.url=[read access endpoint]:url' \
  '-write.url=[write access endpoint]:url' \
  '-datasource.url=[datasource URL]:url' \
  '-http.pathPrefix=[optional path prefix for all routes]:prefix' \
  '-httpListenAddr=[TCP address for incoming requests]:addr' \
  '-tls[enable HTTPS]' \
  '-tlsCertFile=[path to TLS certificate]:_files' \
  '-tlsKeyFile=[path to TLS key]:_files' \
  '-licenseFile=[path to file with VictoriaMetrics Enterprise license key]:_files' && ret=0

return ret
