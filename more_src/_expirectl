#compdef expirectl
# Documentation: man expirectl(8)
# Source: InterNetNews/inn contrib/expirectl.c — adjust expire.ctl based on free space (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose status output]' \
    '(-f -n)-f[force modification]' \
    '(-f -n)-n[do not modify (dry run)]' \
    '-b+[min free bytes (suffix k/m)]:size:_default' \
    '-i+[min free inodes (suffix k/m)]:N:_default' \
    && ret=0

return ret
