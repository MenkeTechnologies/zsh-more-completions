#compdef krb5kdc
# Documentation: https://web.mit.edu/kerberos/krb5-latest/doc/admin/admin_commands/krb5kdc.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# -h/-4/-X; -r is repeatable; -m fetches the master password
# from the keyboard.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-x+[database-specific arguments]:arg:' \
  '-d+[principal database name]:file:_files' \
  '-k+[master key type]:keytype:' \
  '-M+[master key principal name]:name:' \
  '-m[fetch the master database password from the keyboard]' \
  '-P+[write the KDC PID to this file]:file:_files' \
  '-p+[UDP/TCP port numbers (comma-separated)]:port:' \
  '-n[do not background or disassociate from the terminal]' \
  '-w+[fork this many worker processes]:n:' \
  '*-r+[realm to serve]:realm:' \
  '-T+[time offset in seconds (for testing)]:sec:' && ret=0

return ret
