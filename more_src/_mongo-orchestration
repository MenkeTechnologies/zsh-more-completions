#compdef mongo-orchestration
# Documentation: https://rueckstiess.github.io/mtools/
# REST API server for creating and managing MongoDB configurations on a single host

local ret=1

_arguments -s -S \
  '(-h --help)-h[show help]' \
  '(-f --config)'{-f,--config}'=[path to config file]:file:_files' \
  '(-e --env)'{-e,--env}'=[default release to use, as specified in the config file]:env' \
  '--no-fork[run server in foreground]' \
  '(-b --bind)'{-b,--bind}'=[host on which to listen for requests]:host:_hosts' \
  '-p+[port number (8889 by default)]:port' \
  '(-s --server)'{-s,--server}'=[HTTP backend to use]:backend:(auto cheroot wsgiref)' \
  '--socket-timeout-ms=[socket timeout when connecting to MongoDB servers]:ms' \
  '--pidfile=[location to place the pid file]:file:_files' \
  '--enable-majority-read-concern[enable majority read concern where supported]' \
  '1:command:(start stop restart)' && ret=0

return ret
