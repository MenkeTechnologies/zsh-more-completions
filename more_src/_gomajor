#compdef gomajor
# Documentation: https://github.com/icholy/gomajor
# gomajor: major version upgrade helper for Go modules

local ret=1
local -a commands

commands=(
  'get:upgrade a module to a new major version'
  'list:list available module updates'
  'path:modify the module path'
)

_arguments -C \
  '(-h -help)'{-h,-help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'gomajor command' commands && ret=0
    ;;
  args)
    case $line[1] in
      get|list)
        _arguments -s \
          '-cached[only fetch cached versions from the module proxy]' \
          '-rewrite[rewrite import paths when there are multiple major versions]' \
          '*:module:' && ret=0
        ;;
      path)
        _arguments -s \
          '-next[increment the module path version]' \
          '-version=[set the module path to a specific version]:version' && ret=0
        ;;
    esac
    ;;
esac

return ret
