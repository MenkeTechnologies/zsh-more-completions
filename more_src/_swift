#compdef swift

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build Swift packages'
  'package:create and work on packages'
  'run:run a program from a package'
  'test:run package tests'
  'repl:experiment with Swift code interactively'
  'sdk:perform operations on Swift SDKs'
  'demangle:demangle mangled Swift symbols'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,-help,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*-D-[set conditional compilation flag]:flag:' \
  '-O[optimize for speed]' \
  '-Onone[disable optimization]' \
  '-Osize[optimize for size]' \
  '-g[generate debug info]' \
  '-sdk=[SDK path]:dir:_files -/' \
  '-target=[target triple]:triple:' \
  '-module-name=[module name]:name:' \
  '-emit-executable[emit executable]' \
  '-emit-library[emit library]' \
  '-emit-module[emit module]' \
  '*-I+[include directory]:dir:_files -/' \
  '*-L+[library directory]:dir:_files -/' \
  '*-l+[link library]:lib:' \
  '*-F+[framework search path]:dir:_files -/' \
  '*-Xcc+[pass to clang]:flag:' \
  '*-Xlinker+[pass to linker]:flag:' \
  '*-Xfrontend+[pass to frontend]:flag:' \
  '-enable-testing[enable testing imports]' \
  '-enable-library-evolution[enable library evolution]' \
  '-warnings-as-errors[treat warnings as errors]' \
  '-working-directory=[working directory]:dir:_files -/' \
  '-package-name=[package name]:name:' \
  '-parse-as-library[parse as library]' \
  '-static-stdlib[link static stdlib]' \
  '-v[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'swift subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (package)
        _values 'package action' \
          'add-dependency' 'add-product' 'add-target' 'add-target-dependency' 'add-setting' \
          'experimental-audit-binary-artifact' 'clean' 'purge-cache' 'reset' 'update' \
          'describe' 'init' 'migrate' 'experimental-install' 'experimental-uninstall' \
          'diagnose-api-breaking-changes' 'dump-symbol-graph' 'dump-package' \
          'edit' 'unedit' 'config' 'resolve' 'show-dependencies' 'show-executables' \
          'show-traits' 'tools-version' 'compute-checksum' 'archive-source' \
          'completion-tool' 'plugin' && ret=0
        ;;
      (sdk)
        _values 'sdk action' \
          'configure' 'configuration' 'install' 'list' 'remove' && ret=0
        ;;
    esac
    ;;
esac

return ret
