#compdef promptfoo
# Documentation: https://www.promptfoo.dev/docs/usage/command-line/
# Reference accessed: 2026-05-20
# Verified: upstream promptfoo command-line reference.

# Promptfoo CLI completion

_promptfoo_subcommands() {
  local -a subcmds=(
    'init:Set up a new promptfoo project'
    'eval:Evaluate prompts and models'
    'view:Start the browser UI to view results'
    'share:Create a shareable URL for results'
    'auth:Manage cloud authentication'
    'cache:Manage cache storage'
    'config:Edit configuration'
    'debug:Display troubleshooting info'
    'generate:Generate datasets, assertions or redteam tests'
    'list:List evals, prompts, datasets'
    'show:Display resource details'
    'delete:Remove eval by ID'
    'import:Import eval from JSON'
    'export:Export eval records or logs'
    'logs:View log files'
    'feedback:Send developer feedback'
    'redteam:Red teaming commands'
    'scan-model:Scan ML models for security issues'
    'code-scans:Code vulnerability scans'
    'mcp:Start MCP server'
    'retry:Rerun failed tests'
    'validate:Validate configuration files'
  )
  _describe -t commands 'promptfoo subcommand' subcmds
}

_promptfoo() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-v --verbose)'{-v,--verbose}'[enable debug logs]' \
    '--env-file=[load environment variables]:file:_files' \
    '--env-path=[load environment variables]:file:_files' \
    '1:subcommand:_promptfoo_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        eval)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            \*{-c,--config}'=[config files]:config file:_files' \
            \*{-p,--prompts}'=[prompt files]:file:_files' \
            \*{-r,--providers}'=[providers]:provider' \
            \*{-t,--tests}'=[test case CSV]:file:_files' \
            \*{-o,--output}'=[output paths]:file:_files' \
            {-j,--max-concurrency}'=[max concurrent requests]:n' \
            '--delay=[ms between tests]:ms' \
            '--repeat=[run count per test]:n' \
            '--filter-first-n=[limit test quantity]:n' \
            '--filter-range=[test index range]:start\:end' \
            '--filter-pattern=[regex match descriptions]:regex' \
            '--filter-prompts=[match prompt IDs]:pattern' \
            '--filter-providers=[target providers]:pattern' \
            '--filter-metadata=[match metadata]:key=value' \
            '--no-cache[skip caching]' \
            '--resume=[continue incomplete run]:eval id' \
            '--retry-errors[rerun ERROR results]' \
            '--share[create shareable link]' \
            '--watch[auto-rerun on changes]'
          ;;
        init)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:directory:_directories'
          ;;
        view)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            {-p,--port}'=[port to listen on]:port' \
            '--yes[skip confirmation]'
          ;;
        share)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--yes[skip confirmation]'
          ;;
        cache)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(clear list)'
          ;;
        list)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:resource:(evals prompts datasets)'
          ;;
        generate)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:type:(dataset assertions redteam)'
          ;;
        export)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            {-o,--output}'=[output file]:file:_files'
          ;;
        delete)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:eval id'
          ;;
        auth)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(login logout whoami can-create-targets teams)'
          ;;
        redteam)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(init setup run discover generate poison eval report plugins)'
          ;;
      esac
      ;;
  esac
}

_promptfoo "$@"
