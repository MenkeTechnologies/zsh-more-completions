#compdef makechrootpkg
# Documentation: https://github.com/archlinux/devtools/blob/master/src/makechrootpkg.in
# Reference accessed: 2026-05-27
# Verified: upstream getopts string 'hcur:I:l:nCTD:d:U:x:t:' and usage() in src/makechrootpkg.in (archlinux/devtools).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help message]' \
  '-c[clean the chroot before building]' \
  '-u[update the working copy of the chroot before building]' \
  '-r[chroot directory to use]:dir:_files -/' \
  '*-I[install a local package into the working copy of the chroot]:file:_files -g "*.pkg.tar*(-.)"' \
  '-l[directory name to use as the working copy of the chroot]:copy:' \
  '-n[run namcap on the built package]' \
  '-C[run checkpkg on the built package]' \
  '-T[build in a temporary chroot directory]' \
  '*-D[bind directory into build chroot as read-only]:dir:_files -/' \
  '*-d[bind directory into build chroot as read-write]:dir:_files -/' \
  '*-t[mount a tmpfs at directory (dir[:opts])]:dir[:opts]:_files -/' \
  '-U[run makepkg as the specified user]:user:_users' \
  '-x[inspect chroot after build]:when:(never always failure)' \
  '*:makepkg arg:' && ret=0

return ret
