#compdef db_upgrade
# Documentation: db_upgrade usage (Berkeley DB 18.1.40)
# Source: upgrade Berkeley DB database file format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-N[silent: do not acquire DB env lock]' \
    '-s[duplicates not sorted in older versions]' \
    '-v[verbose]' \
    '-h+[environment home]:dir:_files -/' \
    '-m+[message prefix]:msg_pfx:' \
    '-P+[password]:password:' \
    '-S+[verify ov]:flags:(o v ov)' \
    '*:db file:_files' \
    && ret=0

return ret
