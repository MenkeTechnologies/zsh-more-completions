#compdef dnf-automatic
# Documentation: https://man.archlinux.org/search?q=dnf-automatic
# Reference accessed: 2026-05-16

_arguments -s \
  '--installupdates[install updates]' \
  '--downloadupdates[download updates]' \
  '--timer[run as timer]' \
  '(- *)'{-h,--help}'[show help]' \
  ':config file:_files -g "*.conf"'
