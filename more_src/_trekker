# -----------------------------------------------------------------------------
#
# THE trekker CLI
#
# trekker is invoked as:
#   trekker [--toon] <command> [subcommand] [args...]
#
# Common invocations:
#   # Initialize a new trekker database in current dir
#   trekker init
#
#   # Quickstart with sample epic + tasks
#   trekker quickstart
#
#   # Add an epic
#   trekker epic add "Q1 Refactor"
#
#   # List all epics
#   trekker epic list
#
#   # Add a task to an epic
#   trekker task add --epic 1 "Migrate to Drizzle"
#
#   # List tasks
#   trekker task list
#   trekker list                # alias for list-all
#
#   # Find tasks ready to start (deps met)
#   trekker ready
#
#   # Mark task done
#   trekker task done 5
#
#   # Add subtask
#   trekker subtask add --task 5 "Update schema"
#
#   # Add task dependency
#   trekker dep add --task 5 --depends-on 3
#
#   # Add comment
#   trekker comment add --task 5 "Blocked on DB review"
#
#   # Search for tasks/epics/comments
#   trekker search "drizzle"
#
#   # Show history of changes
#   trekker history
#
#   # Wipe the database (destructive!)
#   trekker wipe
#
#   # Configuration
#   trekker config set <key> <value>
#   trekker config get <key>
#
#   # Output in TOON format (for LLM consumption)
#   trekker --toon list
#
# OPTIONS (sourced directly from
# https://github.com/obsfx/trekker/blob/main/src/index.ts):
#
# Global flags:
#   --toon                       Output in TOON format
#   --help, -h                   Show help
#   --version, -V                Show version
#
# Commands:
#   init                         Initialize trekker DB
#   wipe                         Destroy all trekker data
#   epic                         Manage epics
#   task                         Manage tasks
#   subtask                      Manage subtasks
#   comment                      Manage comments
#   dep                          Manage dependencies
#   quickstart                   Onboarding wizard
#   seed                         Seed DB with sample data
#   search QUERY                 Full-text search
#   history                      Show change history
#   list                         List all entities
#   ready                        Show tasks ready to start
#   config                       Get/set configuration
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _trekker_commands
_trekker_commands=(
    'init:initialize trekker DB'
    'wipe:destroy all trekker data'
    'epic:manage epics'
    'task:manage tasks'
    'subtask:manage subtasks'
    'comment:manage comments'
    'dep:manage task dependencies'
    'quickstart:onboarding wizard (creates sample epic + tasks)'
    'seed:seed DB with sample data'
    'search:full-text search across tasks/epics/comments'
    'history:show change history'
    'list:list all entities'
    'ready:show tasks ready to start (deps met)'
    'config:get/set configuration values'
    'help:show help'
)

_arguments -C \
    '--toon[output in TOON format (for LLM consumption)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:command:->cmd' \
    '*::arg:_default' \
    && ret=0

case $state in
    cmd) _describe -t cmds 'trekker command' _trekker_commands && ret=0 ;;
esac

return ret
