#compdef html2text
# Documentation: html2text -help
# Source: format HTML documents into ASCII text.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '-check[syntax check only]' \
    '-debug-scanner[report parsed tokens]' \
    '-debug-parser[report parser activity]' \
    '-rcfile+[alternate rcfile]:file:_files' \
    '-width+[screen width]:cols:' \
    '(-bs -nobs)-nobs[no boldface/underline/colours]' \
    '(-bs -nobs)-bs[render via backspaces]' \
    '-ansi[render with ANSI colours]' \
    '-links[generate reference list]' \
    '-from_encoding+[input encoding]:encoding:' \
    '-to_encoding+[output encoding]:encoding:' \
    '-ascii[plain ASCII output]' \
    '-utf8[both ends are UTF-8]' \
    '-o+[output file]:file:_files' \
    '*:html file:_files -g "*.(html|htm)"' \
    && ret=0

return ret
