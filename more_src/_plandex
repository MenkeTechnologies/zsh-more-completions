#compdef plandex pdx
# Documentation: https://github.com/plandex-ai/plandex/tree/main/app/cli/cmd
# Reference accessed: 2026-05-20
# Verified: upstream source at the URL above.

# Zsh completion for plandex - AI coding agent CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --chat)'{-c,--chat}'[start in chat mode]' \
  '(-t --tell)'{-t,--tell}'[start in tell mode]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:create a new plan'
      'load:load files or notes into context'
      'cd:change to a plan directory'
      'current:show current plan'
      'plans:list plans'
      'ls:list context files'
      'delete-plan:delete a plan'
      'rename:rename a plan'
      'tell:send a prompt to implement a task'
      'chat:start a chat conversation'
      'continue:continue the current plan'
      'build:build pending changes'
      'log:show plan log'
      'rewind:rewind to a previous state'
      'reject:reject pending changes'
      'connect:connect to a Plandex server'
      'sign-in:sign in to Plandex'
      'users:list users'
      'invite:invite a user'
      'revoke:revoke a user invitation'
      'models:list models'
      'model-packs:list model packs'
      'set-model:set model for a role'
      'context-show:show context'
      'summary:show plan summary'
      'diffs:show diffs'
      'apply:apply pending changes'
      'branches:list branches'
      'checkout:checkout a branch'
      'delete-branch:delete a branch'
      'convo:show conversation'
      'archive:archive a plan'
      'unarchive:unarchive a plan'
      'config:show config'
      'set-config:set config'
      'ps:list active plan streams'
      'stop:stop a plan stream'
      'reject:reject pending changes'
      'repl:start the REPL'
      'update:update the CLI'
      'usage:show usage'
      'billing:billing info'
      'browser:open browser to Plandex'
      'clear:clear context'
      'debug:debug info'
      'version:show version'
    )
    _describe -t commands 'plandex command' commands && ret=0
    ;;
esac

return ret
