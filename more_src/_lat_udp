#compdef lat_udp
# Documentation: https://lmbench.sourceforge.net/man/lat_udp.8.html
# lat_udp - lmbench UDP latency benchmark

local ret=1

_arguments -s -S \
  '-s[run in server mode]' \
  '-S[shutdown a running server]:host:_hosts' \
  '-m[message size]:size' \
  '-P[degree of parallelism]:count' \
  '-W[number of warmup iterations]:count' \
  '-N[number of repetitions]:count' \
  '*::host:_hosts' && ret=0

return ret
