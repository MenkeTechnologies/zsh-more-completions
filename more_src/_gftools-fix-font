#compdef gftools-fix-font
# Documentation: https://github.com/googlefonts/gftools
# Fix a font so it conforms to the Google Fonts specification

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-o --out)'{-o,--out}'=[output path for fixed font]:file:_files' \
  '--include-source-fixes[fix font issues that should be fixed in the source files]' \
  '--rename-family=[change the family name]:name' \
  '--fvar-instance-axis-dflts=[fvar instance axis defaults]:dflts' \
  '--skip-fvar-instances[do not re-write fvar instances]' \
  '1:font:_files -g "*.(ttf|otf|TTF|OTF)"' && ret=0

return ret
