#compdef kivaloo-kvlds-dump
# _kivaloo-kvlds-dump — dump KVLDS contents to filesystem or stdout (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from kvlds-dump/main.c (libcperciva GETOPT).

_kivaloo-kvlds-dump() {
    _arguments \
        '(- *)--version[print version]' \
        '-t+[KVLDS socket]:socket:' \
        '--fs=[dump into the given directory]:dir:_files -/' \
        '*-v+[increase verbosity]:n:'
}

_kivaloo-kvlds-dump "$@"
