#compdef elasticsearch-keystore

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add settings to keystore'
  'add-file:add files to keystore as setting-path pairs'
  'create:initialize the keystore'
  'list:list all settings'
  'passwd:change or set keystore password'
  'remove:delete settings from keystore'
  'show:display a single setting value'
  'upgrade:update keystore to latest format'
  'has-passwd:check if keystore is password-protected'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-s,--silent}'[silent output]' \
  {-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'elasticsearch-keystore subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          {-f,--force}'[skip confirmation prompts]' \
          '--stdin[read value from stdin]' \
          '*:setting name:' && ret=0
        ;;
      (add-file)
        _arguments \
          {-f,--force}'[skip confirmation]' \
          '*:setting path file pairs:_files' && ret=0
        ;;
      (create)
        _arguments \
          '-p[prompt for password]' && ret=0
        ;;
      (show)
        _arguments \
          {-o+,--output=}'[output file]:file:_files' \
          '1:setting name:' && ret=0
        ;;
      (remove)
        _arguments \
          '*:setting name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
