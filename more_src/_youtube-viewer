#compdef youtube-viewer gtk-youtube-viewer
# Documentation: https://github.com/trizen/youtube-viewer
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (bin/youtube-viewer GetOptions help).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-sv --search-videos)'{-sv,--search-videos}'[search for YouTube videos]' \
  '(-sc --channels)'{-sc,--channels}'[search for YouTube channels]' \
  '(-sp --search-pl)'{-sp,--search-pl}'[search for playlists]' \
  '(-uv --uploads)'{-uv,--uploads=}'[list videos from a channel]:channel:' \
  '(-pv --popular)'{-pv,--popular=}'[most popular videos from a channel]:channel:' \
  '(-rv --related)'{-rv,--related=}'[show related videos]:video:' \
  '(-f --fullscreen)'{-f,--fullscreen}'[enable fullscreen mode]' \
  '(-n --novideo)'{-n,--novideo}'[audio-only playback]' \
  '--player=[select media player]:player:' \
  '--append-arg=[add custom player parameters]:args:' \
  '(-d --download)'{-d,--download}'[activate download mode]' \
  '(-dp --dl-play)'{-dp,--dl-play}'[play after downloading]' \
  '--downloads-dir=[download directory]:dir:_directories' \
  '--skip-if-exists[avoid re-downloading]' \
  '--copy-caption[download captions]' \
  '--duration=[filter by video length]:duration:' \
  '--caption=[filter by caption availability]:caption:' \
  '--safe-search=[content filtering level]:level:' \
  '--order=[sort results]:order:' \
  '--results=[results per page]:count:' \
  '--config=[specify config file]:file:_files' \
  '--update-config[refresh configuration]' \
  '--login[authenticate via OAuth 2.0]' \
  '--logout[remove authentication]' \
  '*:search query or URL:' && ret=0

return ret
