#compdef otbcli_ComputeConfusionMatrix
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ComputeConfusionMatrix.html
# Orfeo ToolBox: compute confusion matrix of a classification against ground truth

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input classification image]:image:_files' \
  '-out[output matrix in CSV format]:output:_files' \
  '-format[output format]:format:(confusionmatrix contingencytable)' \
  '-ref[ground truth format]:ref:(raster vector)' \
  '-ref.raster.in[ground truth label image]:image:_files' \
  '-ref.raster.nodata[label treated as nodata in reference raster]:value:' \
  '-ref.vector.in[ground truth vector data]:vector:_files' \
  '-ref.vector.field[field name containing label values]:name:' \
  '-ref.vector.nodata[label treated as nodata in reference vector]:value:' \
  '-nodatalabel[label treated as nodata in classification]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
