#compdef avinfo
# _avinfo — BlueZ avinfo (probe a Bluetooth audio (A2DP / AVRCP) endpoint and dump its supported codecs + capabilities; -h help, -i hciX, positional argument is the target BD_ADDR (XX:XX:XX:XX:XX:XX))
# upstream: https://github.com/bluez/bluez (tools/avinfo.c)
# Flags from bluez tools/avinfo.c on tip.

_avinfo() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX device]:device:' \
        '1:BD_ADDR:'
}

_avinfo "$@"
