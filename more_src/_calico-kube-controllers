#compdef calico-kube-controllers kube-controllers
# _calico-kube-controllers — Calico Kubernetes-side controllers (projectcalico/calico)
# upstream: https://github.com/projectcalico/calico
# Flags from kube-controllers/pkg/kubecontrollers/command.go on tip.

_calico-kube-controllers() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--status-file=[file to write status information to]:file:_files' \
        '--health-port=[HTTP health-probe port (0 disables)]:port:' \
        '-v[klog verbosity level]:n:'
}

_calico-kube-controllers "$@"
