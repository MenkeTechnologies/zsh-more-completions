#compdef genocat
# Documentation: https://genozip.com/genocat
# genocat - view and filter genozip-compressed genomic files

local ret=1

_arguments -s -S \
  '(-e --reference)'{-e,--reference}'=[reference file for decompression]:file:_files' \
  '(-f --force)'{-f,--force}'[overwrite output files]' \
  '(-o --output)'{-o,--output}'=[output file or directory]:file:_files' \
  '(-p --password)'{-p,--password}'=[password for encrypted files]:password' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress indicators]' \
  '(-w --stats)'{-w,--stats}'[display compression statistics]' \
  '(-r --regions)'{-r,--regions}'=[show one or more regions]:region' \
  '(-R --regions-file)'{-R,--regions-file}'=[load regions from file]:file:_files' \
  '--grep=[filter by substring match]:pattern' \
  '(-g --grep-w)'{-g,--grep-w}'=[whole-word substring match]:pattern' \
  '(-n --lines)'{-n,--lines}'=[display specific line ranges]:lines' \
  '--head=[show lines from start]:n' \
  '--tail=[show lines from end]:n' \
  '--downsample=[display one in every N lines]:n' \
  '--bases=[filter by nucleotide codes]:bases' \
  '(-s --samples)'{-s,--samples}'=[display subset of samples]:samples' \
  '(-G --drop-genotypes)'{-G,--drop-genotypes}'[omit sample data]' \
  '--snps-only[keep only SNP variants]' \
  '--indels-only[keep only indel variants]' \
  '(-H --no-header)'{-H,--no-header}'[omit header lines]' \
  '(-h --header-only)'{-h,--header-only}'[display only headers]' \
  '--FLAG=[filter by alignment flags]:flag' \
  '--MAPQ=[filter by mapping quality]:mapq' \
  '--qnames=[filter by read names]:names' \
  '--bam[output BAM format]' \
  '--cram[output CRAM format]' \
  '--sam[output SAM format]' \
  '--seq-only[display only sequences]' \
  '--qual-only[display only quality scores]' \
  '--interleaved[show paired reads interleaved]' \
  '--sequential[single line per sequence]' \
  '*:file:_files' && ret=0

return ret
