#compdef git-mob
# Documentation: https://github.com/rkotze/git-mob
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h)-h[show help]' \
  '-o[overwrite primary author too]:initials:' \
  '--list[list available co-authors]' \
  '-p[print path to .git-coauthors]' \
  '*:initials:'
