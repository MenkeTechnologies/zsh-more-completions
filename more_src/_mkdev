#compdef mkdev
# ---------------------------------------------------------------------------
# mkdev — local-development HTTPS reverse proxy with auto-trusted TLS:
#         maps https://<name>.<tld> → local upstream :PORT, automatically
#         generating + trusting a local Certificate Authority and
#         optionally adding entries to /etc/hosts + advertising the
#         hostnames on the LAN via mDNS for visibility from other
#         devices (Go, 135★)
#
# upstream: https://github.com/venkatkrishna07/mkdev
# author : Venkat Krishna (venkatkrishna07)
# license: MIT
#
# Source-direct completion: every subcommand + flag below is verbatim
# from internal/cli/root.go + internal/cli/{add,remove,list,serve,
# install,uninstall,hostshelper,tui,version,completion}.go on the
# venkatkrishna07/mkdev tip — spf13/cobra `cobra.Command{Use, Short,
# RunE}` declarations + `cmd.Flags().BoolVar(...) / StringVar(...)`
# registrations parsed exactly as declared.  Persistent root flags
# (-v/--verbose, --home with $MKDEV_HOME env fallback) from
# root.PersistentFlags() in internal/cli/root.go.
#
# Direct deps from go.mod (selected):
#   github.com/hashicorp/mdns       v1.0.6   ← canonical Go mDNS / DNS-
#                                              SD / Zeroconf service
#                                              discovery library (this
#                                              axis) — by HashiCorp
#                                              (hashicorp/mdns); pure-
#                                              Go implementation of RFC
#                                              6762 (Multicast DNS) +
#                                              RFC 6763 (DNS-SD /
#                                              Bonjour Service
#                                              Discovery) with both
#                                              server (advertise a
#                                              service) and client
#                                              (browse for services)
#                                              modes, IPv4 + IPv6,
#                                              TXT/PTR/SRV/A/AAAA
#                                              record handling.  THE
#                                              Go answer to "advertise
#                                              / discover services on
#                                              the local network" —
#                                              used internally by
#                                              Consul (HashiCorp's
#                                              service-mesh tool) as
#                                              its mDNS discovery
#                                              layer, and externally by
#                                              dkron, openbao/vault
#                                              forks, DataDog Agent's
#                                              local-discovery
#                                              feature, grafana/alloy,
#                                              and most Go tools that
#                                              need cross-machine
#                                              service discovery
#                                              without a central DNS.
#                                              mkdev uses
#                                              hashicorp/mdns to
#                                              ADVERTISE the
#                                              configured domain
#                                              mappings on the LAN —
#                                              so when you map
#                                              `https://api.dev.test`
#                                              to localhost:3000, the
#                                              hostname becomes
#                                              discoverable from
#                                              phones / tablets / other
#                                              dev machines on the
#                                              same network without
#                                              requiring them to edit
#                                              their /etc/hosts files.
#   github.com/spf13/cobra                  (CLI framework — root
#                                              cobra.Command +
#                                              AddCommand tree)
#   github.com/charmbracelet/bubbletea +    (TUI shown when running
#       lipgloss + bubbles                   `mkdev` / `mkdev tui` /
#                                              `mkdev serve` without a
#                                              subcommand — interactive
#                                              list of mappings,
#                                              live request log,
#                                              CA trust status)
#   golang.org/x/crypto                     (private CA cert
#                                              generation + signing)
#   filippo.io/mkcert                       (CA-trust shim — mkdev
#                                              vendors a fork of
#                                              FiloSottile/mkcert's
#                                              system-trust API, hence
#                                              the LICENSE-MKCERT in
#                                              the repo root)
#   modernc.org/sqlite                      (state.db — embedded
#                                              SQLite for the mapping
#                                              store; pure-Go, no CGO)
#
# mkdev is a "FiloSottile/mkcert meets Caddy meets Avahi" tool: one
# command (`mkdev add api localhost:3000`) generates a private CA cert
# (if none exists), trusts it in the OS keychain, adds an entry to
# /etc/hosts mapping `api.dev.test` to 127.0.0.1, advertises that
# hostname on the LAN via mDNS, and starts a reverse proxy from
# `https://api.dev.test/` → `http://localhost:3000/`.  The default
# `mkdev` invocation (no subcommand) launches a Bubble Tea TUI showing
# the live list of mappings + request log; the same TUI is available
# explicitly via `mkdev tui` or the legacy alias `mkdev serve`.
#
# === AXIS 185 CONTINUES — mDNS / DNS-SD / Zeroconf service discovery ======
# Axis position: Go=240 continues Axis 185 (slot 2/0/0).  Canonical Go
# mDNS/DNS-SD library is `github.com/hashicorp/mdns` by HashiCorp —
# pure-Go implementation of RFC 6762 + RFC 6763 used internally by
# Consul (HashiCorp's service-mesh tool) as its mDNS discovery layer.
# The HashiCorp variant has won the de-facto Go standard slot over the
# alternative `grandcat/zeroconf` library because of Consul's
# widespread deployment in production environments — every Go tool
# that wants to interoperate with Consul-style service advertisements
# pulls in hashicorp/mdns.  Both server (advertise) and client (browse)
# modes; IPv4 + IPv6; TXT/PTR/SRV/A/AAAA record handling.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=240     _fcast               ← previous round (axis 185 OPENS, 1/0/0)
#   Go=240       ← THIS FILE          (axis 185 continues, slot 2/0/0)
#   TS-Node=240  ← next round         (axis 185 CLOSES at triple-240, 1/1/1)
#
# Cross-language design contrast for axis 185:
#   Rust    : mdns-sd by keepsimple1 — small independent library
#             focused exclusively on mDNS+DNS-SD; not affiliated with a
#             larger service-discovery system.  Test suite cross-
#             validates against real Avahi (Linux) + mDNSResponder
#             (macOS Bonjour) instances.
#   Go      : hashicorp/mdns — emerged from HashiCorp's Consul service-
#             mesh; the Consul installed base is the implicit
#             integration test.  Less feature-complete than mdns-sd
#             (no IPv6 in some configurations historically, no NSEC
#             record support) but the de-facto standard because of
#             Consul's reach.
#   JS/Node : bonjour-service / multicast-dns — multi-layered: the
#             low-level `multicast-dns` (mafintosh) handles RFC 6762
#             packet wire format, while `bonjour-service` (onlxltd
#             TypeScript rewrite of the original `bonjour`) adds RFC
#             6763 service publishing/browsing on top.  Composable
#             two-layer design typical of the npm ecosystem.
#             [TBD next round]
# ---------------------------------------------------------------------------

_mkdev() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '(-v --verbose)'{-v,--verbose}'[enable debug logging (slog.LevelDebug instead of slog.LevelInfo)]' \
        '--home=[override config dir (default ~/.mkdev; overrides $MKDEV_HOME)]:dir:_files -/' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'add:map https://<name>.<tld> to a local upstream URL'
                'remove:remove a domain mapping'
                'list:list domain mappings (defaults to table; --json for JSON)'
                'serve:launch the mkdev TUI (legacy alias for the default command)'
                'tui:launch the mkdev TUI (interactive list of mappings + live request log)'
                'install:generate the private CA, add it to the OS trust store, prepare ~/.mkdev state directory'
                'uninstall:untrust the CA and optionally purge state (--purge to delete config/certs)'
                'hosts-helper:privileged /etc/hosts editor (invoked internally via sudo by add/remove; rarely called directly)'
                'version:print the mkdev version string'
                'completion:generate shell completion scripts (bash / zsh / fish / powershell)'
                'help:print help for a subcommand'
            )
            _describe -t commands 'mkdev command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                add)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--insecure[skip upstream TLS verification (useful when upstream uses its own self-signed cert / private CA)]' \
                        '1:name (the <name> in https://<name>.dev.test):' \
                        '2:target (upstream URL, e.g. http://localhost:3000 or unix:///path/to/socket):' && ret=0
                    ;;
                remove)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1:name to remove (use `mkdev list` to see mappings):' && ret=0
                    ;;
                list)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--json[output as JSON instead of a human-readable table]' && ret=0
                    ;;
                uninstall)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '--purge[also delete config, state.db, certificates (in addition to untrusting the CA)]' && ret=0
                    ;;
                hosts-helper)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1: :->hhcmds' \
                        '*::hh-arg:->hhargs' && ret=0
                    case $state in
                        hhcmds)
                            _describe -t hosts-helper-commands 'hosts-helper subcommand' \
                                '(add:add an entry to /etc/hosts remove:remove an entry from /etc/hosts)' && ret=0
                            ;;
                        hhargs)
                            _arguments '1:hostname:' && ret=0
                            ;;
                    esac
                    ;;
                completion)
                    _arguments \
                        '(- *)'{-h,--help}'[print help]' \
                        '1:shell:(bash zsh fish powershell)' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(add remove list serve tui install uninstall hosts-helper version completion)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_mkdev "$@"
