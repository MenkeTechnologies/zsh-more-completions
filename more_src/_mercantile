#compdef mercantile
# Documentation: https://mercantile.readthedocs.io/en/stable/cli.html
# Spherical mercator coordinate and tile utilities

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)--version[show the version and exit]' \
  '(- *)--help[show help and exit]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*'{-q,--quiet}'[decrease verbosity]' \
  '1:command:((
    bounding-tile\:"print the bounding tile of a GeoJSON object"
    children\:"print children of a tile"
    neighbors\:"print adjacent tiles on the same zoom level"
    parent\:"print parents of a tile"
    quadkey\:"convert between tiles and quadkeys"
    shapes\:"print tiles as GeoJSON feature collections or sequences"
    tiles\:"print Web Mercator tiles intersecting GeoJSON"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      tiles|bounding-tile)
        _arguments -s -S \
          '(--seq --lf)--seq[write RS-delimited JSON sequences]' \
          '(--seq --lf)--lf[write line-feed-delimited JSON]' \
          '--help[show help]' && ret=0
        ;;
      parent|children)
        _arguments -s -S \
          '--depth=[number of zoom levels to traverse]:depth' \
          '--help[show help]' && ret=0
        ;;
      shapes)
        _arguments -s -S \
          '--precision=[decimal precision of coordinates]:precision' \
          '--indent=[indentation level for JSON output]:indent' \
          '(--compact --no-compact)--compact[use compact separators]' \
          '(--compact --no-compact)--no-compact[do not use compact separators]' \
          '(--geographic --mercator)--geographic[output in geographic coordinates (default)]' \
          '(--geographic --mercator)--mercator[output in Web Mercator coordinates]' \
          '--seq[write RS-delimited JSON sequences]' \
          '--feature[output as sequence of GeoJSON features]' \
          '--bbox[output as sequence of bounding boxes]' \
          '--collect[output as a GeoJSON feature collection]' \
          '(--extents --no-extents)--extents[write shape extents as ws-separated strings]' \
          '(--extents --no-extents)--no-extents[do not write shape extents]' \
          '--buffer=[buffer shapes by a fraction of tile size]:buffer' \
          '--help[show help]' && ret=0
        ;;
      *)
        _arguments '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
