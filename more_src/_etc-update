#compdef etc-update
# Documentation: https://wiki.gentoo.org/wiki/Etc-update
# Gentoo configuration file update tool

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --preen)'{-p,--preen}'[auto-merge trivial changes]' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '--automode[set auto mode]:mode:(merge discard)' \
  '*:config path:_files -/' \
  && return 0
