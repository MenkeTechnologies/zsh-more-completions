#compdef metaMDBG
# Documentation: https://github.com/GaetanBenoitDev/metaMDBG
# metaMDBG: assembler for long and accurate metagenomics reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    if (( CURRENT == 1 )); then
      _values 'metaMDBG subcommand' \
        'asm[perform the assembly]' \
        'gfa[generate assembly graphs]' && ret=0
    else
      case $words[1] in
        asm)
          _arguments -s -S \
            '--out-dir=[output directory for contigs and temporary files]:dir:_files -/' \
            '*--in-hifi=[PacBio HiFi read filename(s)]:file:_files' \
            '*--in-ont=[Nanopore R10.4+ read filename(s)]:file:_files' \
            '--threads=[number of processor cores]:threads' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
