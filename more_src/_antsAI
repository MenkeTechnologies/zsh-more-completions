#compdef antsAI
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsAI.cxx — affine initializer with metric search (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-m --metric)'{-m+,--metric=}'[similarity metric spec]:spec:_default' \
    '(-t --transform)'{-t+,--transform=}'[transform type spec]:spec:_default' \
    '(-p --align-principal-axes)'{-p+,--align-principal-axes=}'[align principal axes (0/1)]:n:(0 1)' \
    '(-b --align-blobs)'{-b+,--align-blobs=}'[align blobs spec]:spec:_default' \
    '(-s --search-factor)'{-s+,--search-factor=}'[search-factor spec]:spec:_default' \
    '(-g --translation-search-grid)'{-g+,--translation-search-grid=}'[translation search grid spec]:spec:_default' \
    '(-c --convergence)'{-c+,--convergence=}'[convergence spec]:spec:_default' \
    '(-x --masks)'{-x+,--masks=}'[fixed/moving mask images]:spec:_default' \
    '(-o --output)'{-o+,--output=}'[output transform file]:file:_files' \
    '--random-seed=[random seed]:n:_default' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
