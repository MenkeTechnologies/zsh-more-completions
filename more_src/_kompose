#compdef kompose
# Documentation: https://raw.githubusercontent.com/kubernetes/kompose/main/cmd/convert.go
# Reference accessed: 2026-05-19
# Verified: upstream cobra flag definitions in cmd/convert.go and cmd/root.go.

# Zsh completion for kompose - Docker Compose to Kubernetes converter

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _kompose_global_flags
_kompose_global_flags=(
  '(-f --file)'{-f,--file}'[specify an alternative compose file]:file:_files'
  '--provider=[specify a provider]:provider:(kubernetes openshift)'
  '--suppress-warnings[suppress all warnings]'
  '--error-on-warning[treat any warning as an error]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -s -S -C \
  "${_kompose_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'convert:convert a Docker Compose file'
      'completion:output shell completion code'
      'version:print version information'
    )
    _describe -t commands 'kompose commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      convert)
        _arguments -s -S \
          "${_kompose_global_flags[@]}" \
          '(-c --chart)'{-c,--chart}'[create a Helm chart for converted objects]' \
          '--controller=[set the output controller]:controller:(deployment daemonSet replicationController)' \
          '--multiple-container-mode[create multiple containers grouped by kompose.service.group label]' \
          '--service-group-mode=[group services into single workload by]:mode:(label volume)' \
          '--service-group-name=[final service name for the group]:name:' \
          '--secrets-as-files[convert compose secrets into files]' \
          '(-y --yaml)'{-y,--yaml}'[generate resource files in YAML format]' \
          '(-j --json)'{-j,--json}'[generate resource files in JSON format]' \
          '--stdout[print converted objects to stdout]' \
          '(-o --out)'{-o,--out}'[file or directory to save objects to]:path:_files' \
          '--replicas=[number of replicas in the generated spec]:count:' \
          '--volumes=[volumes to be generated]:type:(persistentVolumeClaim emptyDir hostPath configMap)' \
          '--pvc-request-size=[size of pvc storage requests]:size:' \
          '--emptyvols[use empty volumes, do not generate PVCs]' \
          '--namespace=[namespace of the generated resources]:namespace:' \
          '--generate-network-policies[generate network policies]' \
          '--with-kompose-annotation[add kompose annotations to resources]' \
          '--no-interpolate[keep environment variable names in the Compose file]' \
          '--indent=[spaces length to indent generated yaml files]:spaces:' \
          '--build=[set the type of build]:build:(local build-config none)' \
          '--build-repo=[source repository for buildconfig]:repo:' \
          '--build-branch=[repository branch for buildconfig]:branch:' \
          '--build-command=[override the docker build command]:command:' \
          '--push-command=[override the docker push command]:command:' \
          '--push-image[push the docker image we built]' \
          '--push-image-registry=[override registry from image name]:registry:' \
          '--insecure-repository[use an insecure Docker repository for OpenShift ImageStream]' \
          '--deployment-config[generate an OpenShift deploymentconfig object]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
