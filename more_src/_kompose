#compdef kompose

# Zsh completion for kompose - Docker Compose to Kubernetes converter

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_kompose_global_flags=(
  '(-f --file)'{-f,--file}'[specify compose file]:file:_files'
  '--provider[specify provider]:provider:(kubernetes openshift)'
  '--suppress-warnings[suppress warnings]'
  '-v[verbose output]'
  '--verbose[verbose output]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -s -S -C \
  "${_kompose_global_flags[@]}" \
  '(- *)version[print version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'convert:convert Docker Compose file'
      'completion:output shell completion code'
      'version:print version information'
    )
    _describe -t commands 'kompose commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      convert)
        _arguments -s -S \
          "${_kompose_global_flags[@]}" \
          '(-c --chart)'{-c,--chart}'[create a Helm chart]' \
          '--controller=[set the output controller]:controller:(deployment daemonSet replicationController)' \
          '(-j --json)'{-j,--json}'[generate JSON resource files]' \
          '(-o --out)'{-o,--out}'[output file or directory]:path:_files' \
          '--replicas=[specify number of replicas]:count:' \
          '--volumes=[volume type]:type:(persistentVolumeClaim emptyDir hostPath configMap)' \
          '--with-kompose-annotation[add kompose annotations]' \
          '--multiple-container-mode=[multi-container mode]:mode:(linked composefile)' \
          '--build=[build policy]:policy:(none local)' \
          '--build-repo=[repository for build image]:repo:' \
          '--build-branch=[branch for build]:branch:' \
          '--push-image[push docker image after build]' \
          '--push-image-registry=[registry for push]:registry:' \
          '--pvc-request-size=[PVC request size]:size:' \
          '--indent=[YAML indentation]:spaces:' \
          '--namespace=[Kubernetes namespace]:namespace:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
