#compdef neosync

local curcontext="$curcontext" state line ret=1

_neosync_commands() {
  local -a commands=(
    'accounts:manage accounts'
    'connections:manage connections'
    'jobs:manage jobs'
    'login:authenticate with Neosync'
    'logout:log out of Neosync'
    'sync:synchronize data'
    'version:print version'
    'whoami:display current user info'
  )
  _describe -t commands 'neosync command' commands
}

_arguments -s -S \
  '--api-key[API key]:key' \
  '--api-url[API URL]:url' \
  '--account-id[account ID]:id' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_neosync_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      connections)
        _arguments -s -S \
          '1:action:(list create delete)' \
          '--name[connection name]:name' \
          '--type[connection type]:type:(postgres mysql s3)' && ret=0
        ;;
      jobs)
        _arguments -s -S \
          '1:action:(list create trigger status delete)' \
          '--name[job name]:name' \
          '--id[job ID]:id' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '--connection-id[connection ID]:id' \
          '--destination-connection-id[destination connection ID]:id' \
          '--source-connection-id[source connection ID]:id' \
          '--config[config file]:file:_files' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
