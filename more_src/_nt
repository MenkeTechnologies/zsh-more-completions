#compdef nt
# Documentation: https://github.com/marcusbandit/newtree
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Source: cargo binstall newtree@0.2.0
# Probed via: --generate-completions zsh
# Repository: https://github.com/marcusbandit/newtree

autoload -U is-at-least

_nt() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-L+[Descend only N directories deep]:N:_default' \
'--level=[Descend only N directories deep]:N:_default' \
'-P+[List only files/dirs whose name contains PATTERN (case-insensitive)]:PATTERN:_default' \
'--pattern=[List only files/dirs whose name contains PATTERN (case-insensitive)]:PATTERN:_default' \
'-m+[Stop after N pattern matches (requires -P)]:N:_default' \
'--max-matches=[Stop after N pattern matches (requires -P)]:N:_default' \
'-I+[Do NOT list files/dirs whose name contains PATTERN (case-insensitive)]:PATTERN:_default' \
'--ignore=[Do NOT list files/dirs whose name contains PATTERN (case-insensitive)]:PATTERN:_default' \
'--color=[Color mode\: always, auto (default), simple, never]:WHEN:((always\:"Full file-type coloring"
auto\:"Smart\: no color when piped, simple when output is busy, full otherwise"
simple\:"Color directories and symlinks only"
never\:"No color"))' \
'--search=[Pre-fill the TUI search box]:TERM:_default' \
'--generate-completions=[Generate shell completions and print to stdout]:SHELL:(bash elvish fish powershell zsh)' \
'-a[All files are listed (including hidden)]' \
'--all[All files are listed (including hidden)]' \
'-d[List directories only]' \
'--dirs-only[List directories only]' \
'-l[Follow symbolic links like directories]' \
'--follow-links[Follow symbolic links like directories]' \
'-f[Print the full path prefix for each file]' \
'--full-path[Print the full path prefix for each file]' \
'-x[Stay on the current filesystem only]' \
'--one-file-system[Stay on the current filesystem only]' \
'--prune[Prune empty directories from the output]' \
'-v[Sort files alphanumerically by version (natural sort)]' \
'--version-sort[Sort files alphanumerically by version (natural sort)]' \
'-t[Sort files by last modification time]' \
'--time-sort[Sort files by last modification time]' \
'-c[Sort files by last status change time]' \
'--change-sort[Sort files by last status change time]' \
'-U[Leave files unsorted]' \
'--unsorted[Leave files unsorted]' \
'-r[Reverse the order of the sort]' \
'--reverse[Reverse the order of the sort]' \
'-s[Print file sizes; directories show recursive total]' \
'--size[Print file sizes; directories show recursive total]' \
'-h[Human-readable sizes (implies -s)]' \
'--human[Human-readable sizes (implies -s)]' \
'-p[Print file type and permissions, e.g. \[drwxr-xr-x\]]' \
'--permissions[Print file type and permissions, e.g. \[drwxr-xr-x\]]' \
'-D[Print the date of last modification (or status change with -c)]' \
'--date[Print the date of last modification (or status change with -c)]' \
'--icons[Show Nerd Font icons (default\: on when TTY)]' \
'--no-icons[Disable Nerd Font icons]' \
'-J[Print a JSON representation of the tree]' \
'--json[Print a JSON representation of the tree]' \
'-X[Print an XML representation of the tree]' \
'--xml[Print an XML representation of the tree]' \
'--tui[Launch the interactive TUI instead of streaming to stdout]' \
'--help[Print help]' \
'::path -- Directory to display (default\: current directory):_files' \
&& ret=0
}

(( $+functions[_nt_commands] )) ||
_nt_commands() {
    local commands; commands=()
    _describe -t commands 'nt commands' commands "$@"
}

if [ "$funcstack[1]" = "_nt" ]; then
    _nt "$@"
else
    compdef _nt nt
fi
