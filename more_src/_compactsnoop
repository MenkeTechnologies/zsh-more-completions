#compdef compactsnoop compactsnoop-bpfcc
# _compactsnoop — trace memory compaction events + issuing PID (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/compactsnoop.py (argparse).

_compactsnoop() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '(-d --duration)'{-d+,--duration=}'[total trace duration (seconds)]:seconds:'
        '(-K --kernel-stack)'{-K,--kernel-stack}'[output kernel stack trace]'
        '(-e --extended_fields)'{-e,--extended_fields}'[show system memory state]'
    )
    _arguments $args
}

_compactsnoop "$@"
