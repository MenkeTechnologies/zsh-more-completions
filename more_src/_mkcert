#compdef mkcert

# Zsh completion for mkcert (locally-trusted development certificates)

_mkcert() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -s -S \
        '(-install -uninstall)-install[install the local CA in the system trust store]' \
        '(-install -uninstall)-uninstall[uninstall the local CA from the system trust store]' \
        '-CAROOT[print the CA certificate and key storage location]' \
        '-cert-file=[customize the output cert file path]:cert file:_files' \
        '-key-file=[customize the output key file path]:key file:_files' \
        '-p12-file=[customize the output PKCS#12 file path]:p12 file:_files' \
        '-client[generate a certificate for client authentication]' \
        '-ecdsa[generate a certificate with an ECDSA key]' \
        '-pkcs12[generate a PKCS#12 file (.p12/.pfx) instead of PEM]' \
        '(- *)--help[show help]' \
        '*:domain name (hostname, IP, or wildcard):'
}

_mkcert "$@"
