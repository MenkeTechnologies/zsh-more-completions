#compdef sndinfo
# Documentation: https://csound.com/docs/manual/
# Csound utility to print soundfile header information

local ret=1

_arguments -s -S \
  '-i[print instrument information including looping]' \
  '-i1[print instrument information including looping]' \
  '-i0[stop printing instrument information]' \
  '-b[print broadcast information for WAV files]' \
  '-b0[stop printing broadcast information]' \
  '*:soundfile:_files' && ret=0

return ret
