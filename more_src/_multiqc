#compdef multiqc
# Documentation: https://man.archlinux.org/search?q=multiqc
# Reference accessed: 2026-05-16

# MultiQC: aggregate QC reports from many tools into one HTML report
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-f --force)'{-f,--force}'[overwrite existing reports]' \
  '(-d --dirs)'{-d,--dirs}'[prepend directory to sample names]' \
  '(-dd --dirs-depth)'{-dd,--dirs-depth=}'[directory depth to prepend]:n:' \
  '(-s --fullnames)'{-s,--fullnames}'[use full filenames as sample names]' \
  '(-fn --filename)'{-fn,--filename=}'[report filename]:file:_files' \
  '(-o --outdir)'{-o,--outdir=}'[output directory]:dir:_files -/' \
  '(-t --template)'{-t,--template=}'[report template]:tmpl:(default simple sections geo gathered)' \
  '(-x --ignore)'{-x,--ignore=}'[ignore files matching glob]:pattern:' \
  '(-i --title)'{-i,--title=}'[report title]:title:' \
  '(-b --comment)'{-b,--comment=}'[report comment]:text:' \
  '(-c --config)'{-c,--config=}'[YAML config file]:file:_files' \
  '--cl-config=[YAML config string]:yaml:' \
  '--cl_config=[YAML config string]:yaml:' \
  '(-m --module)'{-m,--module=}'[only use specified module]:module:' \
  '(-e --exclude)'{-e,--exclude=}'[exclude module]:module:' \
  '--data-format=[data file format]:fmt:(tsv yaml json)' \
  '(-zip --zip-data-dir)'{-zip,--zip-data-dir}'[zip data directory]' \
  '(-n --no-data-dir)'{-n,--no-data-dir}'[do not save data dir]' \
  '(-pdf --pdf)'{-pdf,--pdf}'[also produce PDF report]' \
  '(-flat --flat)'{-flat,--flat}'[use flat (non-interactive) plots]' \
  '(-no-megaqc)'{-no-megaqc,--no-megaqc-upload}'[do not upload to MegaQC]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[only show warnings]' \
  '(-l --file-list)'{-l,--file-list}'[treat ANALYSIS_DIRS as file list]' \
  '*:directories to scan:_files -/' && ret=0
return ret
