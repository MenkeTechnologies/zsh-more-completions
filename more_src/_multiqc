#compdef multiqc
# Documentation: https://docs.seqera.io/multiqc/getting_started/running_multiqc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# MultiQC: aggregate QC reports from many tools into one HTML report
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-f --force)'{-f,--force}'[overwrite existing reports]' \
  '(-d --dirs)'{-d,--dirs}'[prepend directory to sample names]' \
  '(-dd --dirs-depth)'{-dd,--dirs-depth=}'[directory depth to prepend]:n:' \
  '(-s --fullnames)'{-s,--fullnames}'[use full filenames as sample names]' \
  '(-n --filename)'{-n,--filename=}'[report filename]:file:_files' \
  '(-o --outdir)'{-o,--outdir=}'[output directory]:dir:_files -/' \
  '(-t --template)'{-t,--template=}'[report template]:tmpl:(default simple sections geo gathered)' \
  '*'{-x,--ignore=}'[ignore files matching glob]:pattern:' \
  '*--ignore-samples=[ignore sample matching glob]:pattern:' \
  '--ignore-symlinks[ignore symlinked dirs and files]' \
  '(-i --title)'{-i,--title=}'[report title]:title:' \
  '(-b --comment)'{-b,--comment=}'[report comment]:text:' \
  '(-c --config)'{-c,--config=}'[YAML config file]:file:_files' \
  '--cl-config=[YAML config string]:yaml:' \
  '--cl_config=[YAML config string]:yaml:' \
  '*'{-m,--module=}'[only use specified module]:module:' \
  '*'{-e,--exclude=}'[exclude module]:module:' \
  '--require-logs[fail if specified modules produce no output]' \
  '(-k --data-format)'{-k,--data-format=}'[data file format]:fmt:(tsv yaml json)' \
  '--data-dir[create the data directory]' \
  '--no-data-dir[do not save data dir]' \
  '(-z --zip-data-dir)'{-z,--zip-data-dir}'[zip data directory]' \
  '(-p --export)'{-p,--export}'[export plots as static images]' \
  '--pdf[also produce PDF report]' \
  '--flat[use flat (non-interactive) plots]' \
  '--interactive[use interactive plots]' \
  '--no-megaqc-upload[do not upload to MegaQC]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[only show warnings]' \
  '(-l --file-list)'{-l,--file-list}'[treat input as file list]' \
  '*:directories to scan:_files -/' && ret=0
return ret
