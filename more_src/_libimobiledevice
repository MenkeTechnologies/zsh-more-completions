#compdef libimobiledevice
# _libimobiledevice — libimobiledevice cross-platform library to communicate with iOS devices CLI alias (libimobiledevice team, C); custom argparse for shared options
# upstream: https://github.com/libimobiledevice/libimobiledevice

_libimobiledevice() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--udid=+[device UDID]:str:' \
        '-u+[device UDID]:str:' \
        '--network[connect over network]' \
        '-n[connect over network]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--device=+[device identifier]:str:' \
        '*:arg:'
}

_libimobiledevice "$@"
