#compdef ktor
# Documentation: https://github.com/ktorio/ktor-cli
# Reference accessed: 2026-05-19
# Verified: ktorio/ktor-cli README usage section. Removed from prior
# file: invented "completions" command, -V version short form, -h help
# short form, --verbose long form; corrected to documented flags only
# and replaced bogus man.archlinux.org search URL.

_arguments -s \
  '--help[show usage information]' \
  '--version[show tool version]' \
  '-v[verbose output]' \
  '(-p --project)'{-p+,--project=}'[project directory path]:dir:_directories' \
  '(-o --output)'{-o+,--output=}'[output directory]:dir:_directories' \
  '1:command:(new add openapi dev version help)' \
  '*::arguments:_default'
