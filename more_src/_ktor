#compdef ktor

# https://github.com/ktorio/ktor-cli — custom parser (internal/app/cli/processing.go)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage]' \
  '(-V --version)'{-V,--version}'[build info]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1:command:(new add openapi dev completions version help)' \
  '*::arguments:_default'
