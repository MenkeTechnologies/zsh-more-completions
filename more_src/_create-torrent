#compdef create-torrent
# Documentation: https://www.npmjs.com/package/create-torrent
# Reference accessed: 2026-05-24
# Verified: npm view create-torrent bin; npx create-torrent --help output.

# Zsh completion for create-torrent - torrent file generator

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-o --outfile)'{-o,--outfile}'[output torrent file]:file:_files'   '(-n --name)'{-n,--name}'[torrent name]:name:'   '--creationDate=[creation date]:date:'   '--comment=[torrent comment]:comment:'   '--createdBy=[created by client]:client:'   '--private[private torrent]'   '--pieceLength=[piece length]:length:'   '--announce=[tracker URL]:url:'   '--urlList=[web seed URL]:url:'   ':path to file or directory:_files' && ret=0

return ret
