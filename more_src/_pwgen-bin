#compdef pwgen
# _pwgen-bin — pwgen password generator (C); produces pronounceable / secure / numeric passwords by length
# upstream: https://sourceforge.net/projects/pwgen

_pwgen-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-c --capitalize)'{-c,--capitalize}'[at least one uppercase]' \
        '(-A --no-capitalize)'{-A,--no-capitalize}'[no uppercase]' \
        '(-n --numerals)'{-n,--numerals}'[at least one digit]' \
        '(-0 --no-numerals)'{-0,--no-numerals}'[no digits]' \
        '(-y --symbols)'{-y,--symbols}'[at least one symbol]' \
        '(-s --secure)'{-s,--secure}'[fully random secure]' \
        '(-B --ambiguous)'{-B,--ambiguous}'[avoid ambiguous chars]' \
        '(-N --num-passwords)'{-N,--num-passwords}'+[number of passwords]:n:' \
        '(-r --remove-chars)'{-r,--remove-chars}'+[chars to exclude]:chars:' \
        '(-H --sha1)'{-H,--sha1}'+[seed via sha1 of file/argument]:file:_files' \
        '(-C)'-C'[print in columns]' \
        '(-1)'-1'[print one per line]' \
        '(-v --no-vowels)'{-v,--no-vowels}'[no vowels (very limited)]' \
        '*:length:'
}

_pwgen-bin "$@"
