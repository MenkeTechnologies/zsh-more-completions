#compdef flankBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/flank.html
# create flanking intervals upstream/downstream of features (bedtools flank)

local ret=1

_arguments -s -S \
  '-i[input BED/GFF/VCF file]:file:_files' \
  '-g[genome file defining chromosome lengths]:file:_files' \
  '-b[increase entry by same bp in each direction]:bp' \
  '-l[bp to subtract from the start coordinate]:bp' \
  '-r[bp to add to the end coordinate]:bp' \
  '-s[define -l and -r based on strand]' \
  '-pct[define -l and -r as a fraction of feature length]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
