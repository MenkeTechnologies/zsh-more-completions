#compdef argocd-proj
# Documentation: https://argo-cd.readthedocs.io/en/stable/user-guide/commands/argocd_proj/
# Argo CD proj: manage projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--auth-token=[authentication token]:token:' \
  '--server=[Argo CD server address]:server:' \
  '--insecure[skip server certificate and domain verification]' \
  '--grpc-web[enable gRPC-web protocol]' \
  '--config=[path to Argo CD config]:file:_files' \
  '--plaintext[disable TLS]' \
  '--port-forward[connect to a random argocd-server port using port forwarding]' \
  '--port-forward-namespace=[namespace name used for port forwarding]:namespace:' \
  '--core[CLI talks directly to Kubernetes instead of the Argo CD API server]' \
  '*::subcommand:(add-destination add-destination-service-account add-orphaned-ignore add-signature-key add-source add-source-namespace allow-cluster-resource allow-namespace-resource create delete deny-cluster-resource deny-namespace-resource edit get list remove-destination remove-destination-service-account remove-orphaned-ignore remove-signature-key remove-source remove-source-namespace role set windows)' && ret=0

return ret
