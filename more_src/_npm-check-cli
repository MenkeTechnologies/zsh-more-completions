#compdef npm-check
# Documentation: https://github.com/dylang/npm-check
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: alternate completion file alongside _npm-check; both target the same
# binary so only one will be picked up depending on fpath ordering.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --update)'{-u,--update}'[interactive update]' \
  '(-y --update-all)'{-y,--update-all}'[update all without prompting]' \
  '(-g --global)'{-g,--global}'[check global modules]' \
  '(-s --skip-unused)'{-s,--skip-unused}'[skip unused packages check]' \
  '(-p --production)'{-p,--production}'[skip devDependencies]' \
  '(-d --dev-only)'{-d,--dev-only}'[check only devDependencies]' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore dependencies matching glob]:glob:' \
  '(-E --save-exact)'{-E,--save-exact}'[save exact versions]' \
  '--specials=[depcheck specials list to include]:list:' \
  '--no-color[disable color output]' \
  '--no-emoji[disable emoji in output]' \
  '--debug[show debug output]' \
  '*: :_files -/' && ret=0

return ret
