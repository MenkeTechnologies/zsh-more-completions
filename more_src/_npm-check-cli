#compdef npm-check
# Documentation: https://man.archlinux.org/search?q=npm-check
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --update)'{-u,--update}'[interactive update]' \
  '(-y --update-all)'{-y,--update-all}'[update all]' \
  '(-g --global)'{-g,--global}'[check global]' \
  '(-s --skip-unused)'{-s,--skip-unused}'[skip unused]' \
  '(-p --production)'{-p,--production}'[production deps only]' \
  '(-d --dev-only)'{-d,--dev-only}'[dev deps only]' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore pattern]:p:' \
  '(-E --save-exact)'{-E,--save-exact}'[save exact]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--no-color)--no-color[no color]' \
  '(--no-emoji)--no-emoji[no emoji]' \
  '(--debug)--debug[debug]' \
  '(--specials)--specials=[special tasks csv]:list:' \
  '(--no-spinner)--no-spinner[no spinner]' \
  '(--installer)--installer=[installer]:i:(npm yarn pnpm)' \
  '*: :_files -/' && ret=0

return ret
