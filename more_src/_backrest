#compdef backrest

# Zsh completion for backrest (restic backup web UI and orchestrator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config[config file]:file:_files -g "*.{json,yaml,yml}"' \
  '--data-dir[data directory]:directory:_files -/' \
  '--bind-address[bind address]:address' \
  '--listen-port[listen port]:port' \
  '--verbose[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
