#compdef xbps-alternatives
# Documentation: https://man.voidlinux.org/xbps-alternatives.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config)'{-C,--config}'+[XBPS configuration directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-g --group)'{-g,--group}'+[alternative group name]:name:' \
  '(-i --ignore-conf-repos)'{-i,--ignore-conf-repos}'[ignore repos in configuration files]' \
  '-R[enable repository mode]' \
  '*--repository=[repository URL]:url:' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '(-l --list -s --set)'{-l,--list}'[list alternative groups]' \
  '(-l --list -s --set)'{-s,--set}'[set alternative groups]' \
  '*:package: ' && ret=0

return ret
