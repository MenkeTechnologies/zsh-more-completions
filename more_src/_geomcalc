#compdef geomcalc
# Documentation: https://www.ccp4.ac.uk/html/geomcalc.html
# CCP4: molecular geometry calculations (distances, angles, planes)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate file]:output:_files' \
  '*:keyword:(ANGLE ATOM CENTRE CURRENT DISTANCE FOLD FROMPLANE PLANE READ SEPARATION TILT TORSION TRANSFORM WRITE XAXIS END)' && ret=0

return ret
