#compdef astscript-zeropoint
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astscript_002dzeropoint.html
# astscript-zeropoint — calculate the zeropoint of an image from reference images or catalog

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra stdout information]' \
  '--cite[show BibTeX citation for this program]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads to use]:number' \
  '(-h --hdu)'{-h,--hdu}'[HDU/extension name or number of input]:HDU' \
  '(-S --starcat)'{-S,--starcat}'[catalog with positions for aperture photometry]:file:_files' \
  '--starcathdu[HDU of table in starcat]:HDU' \
  '--starcatra[column in starcat containing RA]:column' \
  '--starcatdec[column in starcat containing DEC]:column' \
  '--mksrc[Makefile for developers when debugging]:file:_files' \
  '(-a --aperarcsec)'{-a,--aperarcsec}'[aperture radius in arc-seconds for photometry]:radius' \
  '(-M --magnituderange)'{-M,--magnituderange}'[range of magnitude to be considered]:range' \
  '(-c --refcat)'{-c,--refcat}'[reference catalog file name]:file:_files' \
  '(-C --refcathdu)'{-C,--refcathdu}'[reference catalog HDU name or number]:HDU' \
  '(-r --refcatra)'{-r,--refcatra}'[reference catalog RA column]:column' \
  '(-d --refcatdec)'{-d,--refcatdec}'[reference catalog DEC column]:column' \
  '(-m --refcatmag)'{-m,--refcatmag}'[reference catalog magnitude column]:column' \
  '(-s --matchradius)'{-s,--matchradius}'[radius in arcsec to match with reference]:radius' \
  '(-R --refimgs)'{-R,--refimgs}'[reference image name(s) with known zeropoint]:file:_files' \
  '(-H --refimgshdu)'{-H,--refimgshdu}'[reference image HDU name(s) or number(s)]:HDU' \
  '(-z --refimgszp)'{-z,--refimgszp}'[zero point(s) of reference image(s)]:zeropoint' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-t --tmpdir)'{-t,--tmpdir}'[directory to keep temporary files]:dir:_files -/' \
  '(-k --keeptmp)'{-k,--keeptmp}'[keep temporary/auxiliary files]' \
  '(-K --keepzpap)'{-K,--keepzpap}'[keep each aperture zeropoint in different HDU]' \
  '*:input:_files' && ret=0

return ret
