#compdef xbps-fetch
# _xbps-fetch — fetch URLs using the XBPS libfetch wrapper (void-linux/xbps)
# upstream: https://github.com/void-linux/xbps
# Flags from bin/xbps-fetch/main.c.

_xbps-fetch() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show XBPS version]'
        '(-d --debug)'{-d,--debug}'[enable debug messages to stderr]'
        '(-o --out)'{-o+,--out=}'[rename the downloaded file]:file:_files'
        '(-s --sha256)'{-s,--sha256}'[print sha256sums of the downloaded files]'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '*:URL:'
    )
    _arguments -s -S $args
}

_xbps-fetch "$@"
