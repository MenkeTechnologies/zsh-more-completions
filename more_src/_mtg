local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 5 subcommands decoded source-direct from CLI
# struct at internal/cli/cli.go:5-12
local -a mtg_subcmds=(
  'generate-secret:generate a new proxy secret'
  'doctor:check that proxy can run correctly'
  'access:print access information'
  'run:run proxy with config file'
  'simple-run:run proxy without config file'
)

local -a mtg_prefer_ip=(
  'prefer-ipv6:prefer IPv6 with IPv4 fallback (default)'
  'prefer-ipv4:prefer IPv4 with IPv6 fallback'
  'only-ipv6:only IPv6'
  'only-ipv4:only IPv4'
)

_arguments -C \
  '(- *)'{-h,--help}'[display kong auto-generated help]' \
  '(- *)'{-v,--version}'[print version]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'mtg subcommand' mtg_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      generate-secret)
        _arguments -s -S \
          '(-x --hex)'{-x,--hex}'[print secret in hex encoding]' \
          '(-h --help)'{-h,--help}'[help]' \
          '1:hostname for domain fronting:' && ret=0
        ;;
      doctor)
        _arguments -s -S \
          '--skip-native-check[skip native network connectivity check]' \
          '(-h --help)'{-h,--help}'[help]' \
          '1:config file:_files -g "*.toml"' && ret=0
        ;;
      access)
        _arguments -s -S \
          '(-i --ipv4)'{-i+,--ipv4=}'[public IPv4 address]:ipv4:' \
          '(-I --ipv6)'{-I+,--ipv6=}'[public IPv6 address]:ipv6:' \
          '(-p --port)'{-p+,--port=}'[port number]:port:' \
          '(-x --hex)'{-x,--hex}'[print secret in hex encoding]' \
          '(-h --help)'{-h,--help}'[help]' \
          '1:config file:_files -g "*.toml"' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help]' \
          '1:config file:_files -g "*.toml"' && ret=0
        ;;
      simple-run)
        _arguments -s -S \
          '(-d --debug)'{-d,--debug}'[run in debug mode]' \
          '(-c --concurrency)'{-c+,--concurrency=}'[max concurrent connections (default 8192)]:concurrency:' \
          '(-b --tcp-buffer)'{-b+,--tcp-buffer=}'[deprecated and ignored (default 4KB)]:size:' \
          '(-i --prefer-ip)'{-i+,--prefer-ip=}'[IP preference (default prefer-ipv6)]:mode:->prefer_ip_modes' \
          '(-p --domain-fronting-port)'{-p+,--domain-fronting-port=}'[domain fronting port (default 443)]:port:' \
          '--domain-fronting-host=[hostname or IP to dial for domain fronting]:host:' \
          '(-n --doh-ip)'{-n+,--doh-ip=}'[DNS-over-HTTP IP (default 1.1.1.1)]:DoH IP:' \
          '(-t --timeout)'{-t+,--timeout=}'[network timeout (default 10s)]:duration:' \
          '*'{-s+,--socks5-proxy=}'[SOCKS5 proxy address (repeatable)]:socks5 address:' \
          '(-a --antireplay-cache-size)'{-a+,--antireplay-cache-size=}'[anti-replay cache size (default 1MB)]:size:' \
          '--proxy-protocol-listener[expect PROXY protocol headers (v1 or v2) on listener]' \
          '(-h --help)'{-h,--help}'[help]' \
          '1:host:port to bind proxy to:' \
          '2:proxy secret:' && ret=0
        ;;
    esac
    case $state in
      prefer_ip_modes)
        _describe -t prefer_ip_modes 'IP preference' mtg_prefer_ip && ret=0
        ;;
    esac
    ;;
esac

return ret
