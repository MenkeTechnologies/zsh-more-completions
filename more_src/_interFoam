#compdef interFoam
# interFoam — OpenFOAM multiphase VOF flow solver

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-help,--help}'[show help]' \
  '-case+[specify case directory]:case dir:_directories' \
  '-parallel[run in parallel]' \
  '-noFunctionObjects[do not execute function objects]' \
  '-postProcess[run post-processing only]' \
  '-decomposeParDict+[decompose dictionary]:dict file:_files' \
  '-roots+[slave root directories for distributed runs]:roots file:_files' \
  '-fileHandler+[file handler type]:handler:(collated uncollated masterUncollated)' \
  '-libs=[additional libraries]:libraries:' \
  '-doc[display documentation in browser]' \
  '-srcDoc[display source documentation in browser]' && ret=0

return ret
