#compdef zsync

# Zsh completion for zsync (efficient file download using rsync algorithm)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-A+[Append authorization header for specified hostname]:hostname=username:password' \
  '-i+[Seed file to read for existing data]:file:_files' \
  '-k+[Specify a gzip compressed seed file]:file:_files -g "*.gz"' \
  '-o+[Output filename]:file:_files' \
  '-q[Quiet mode]' \
  '-s[Specify that the seed file is compressed]' \
  '-u+[Specify a base URL for the download]:url' \
  '-V[Print version information]' \
  ':zsync control file URL' && ret=0

return ret
