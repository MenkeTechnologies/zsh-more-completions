#compdef runghc-9.14.1 runhaskell-9.14.1

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-f+[path to GHC]:ghc:_command_names -e' \
  '*--ghc-arg=[pass option to GHC]:arg:' \
  '*:Haskell source:_files -g "*.(hs|lhs)"' && ret=0

return ret
