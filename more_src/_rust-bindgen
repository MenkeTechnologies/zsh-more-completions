#compdef rust-bindgen bindgen
# Documentation: https://rust-lang.github.io/rust-bindgen/command-line-usage.html
# Reference accessed: 2026-05-16
# Verified: rust-lang/rust-bindgen command-line-usage docs.
# Removed from prior file: bogus man.archlinux.org search URL.

# rust-bindgen: C/C++ to Rust FFI bindings generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output bindings file]:file:_files' \
  '*--allowlist-function=[allow function regex]:regex:' \
  '*--allowlist-type=[allow type regex]:regex:' \
  '*--allowlist-var=[allow variable regex]:regex:' \
  '*--blocklist-function=[block function regex]:regex:' \
  '*--blocklist-type=[block type regex]:regex:' \
  '*--blocklist-item=[block item regex]:regex:' \
  '--no-layout-tests[disable layout tests]' \
  '--target=[target triple]:triple:' \
  '--wrap-static-fns[generate wrappers for static functions]' \
  '--generate-inline-functions[generate inline functions]' \
  '--use-core[use core instead of std]' \
  '--ctypes-prefix=[c_types prefix]:prefix:' \
  '--no-doc-comments[do not generate doc comments]' \
  '*--raw-line=[raw line to emit]:line:' \
  '--rust-target=[target Rust version]:version:' \
  '*:C/C++ header:_files -g "*.(h|hpp|hxx)(-.)"' && ret=0
return ret
