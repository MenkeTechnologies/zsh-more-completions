#compdef zsh
# Documentation: man 1 zsh (Ubuntu jammy manpage)
# Reference accessed: 2026-05-29
# Z Shell — interactive shell with extensive completion.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show available invocation options]' \
  '(- *)--version[show version and exit]' \
  '(-c)-c[take first argument as command to execute]:command:' \
  '-i[force interactive mode]' \
  '-l[login shell]' \
  '-s[read commands from standard input]' \
  '-b[end option processing (sh/ksh emulation excluded)]' \
  '-r[restricted mode (no cd, no PATH change)]' \
  '-f[bypass startup file execution]' \
  '-d[do not source /etc/zsh/zshenv]' \
  '-D[do not source /etc/zsh/zshrc]' \
  '-y[short-form invocation processing]' \
  '--emulate=[set emulation mode (must precede other options)]:mode:(sh ksh csh zsh)' \
  '--no-rcs[do not source rc files]' \
  '--no-globalrcs[do not source global rc files]' \
  '-x[print commands and arguments as they execute (xtrace)]' \
  '-v[print shell input lines as they are read (verbose)]' \
  '-n[read commands without executing (no-exec)]' \
  '-o[set option]:option:' \
  '+o[unset option]:option:' \
  '*:script or args:_files' && ret=0

return ret
