#compdef btp2
# Documentation: https://gitlab.com/sousaw/BoltzTraP2/-/raw/public/BoltzTraP2/interface.py
# BoltzTraP2 command-line interface for band interpolation and transport coefficients

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity level]' \
  '(-n --nworkers)'{-n,--nworkers}'[number of parallel worker processes]:nworkers:' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:command:(interpolate integrate dope plotbands plot fermisurface fermisurface_2d fermiintegrals)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      interpolate)
        _arguments -s \
          '(-o --output)'{-o,--output}'[output file prefix]:output:' \
          '(-d --derivatives)'{-d,--derivatives}'[also compute band derivatives]' \
          '(-e --emin)'{-e,--emin}'[minimum energy]:emin:' \
          '(-E --emax)'{-E,--emax}'[maximum energy]:emax:' \
          '(-a --absolute)'{-a,--absolute}'[use absolute energy window]' \
          '(-k --kpoints)'{-k,--kpoints}'[number of k points]:kpoints:' \
          '(-m --multiplier)'{-m,--multiplier}'[interpolation density multiplier]:multiplier:' \
          '*:directory:_files -/' && ret=0
        ;;
      integrate|dope)
        _arguments -s \
          '(-p --prefix)'{-p,--prefix}'[input file prefix]:prefix:' \
          '(-b --bins)'{-b,--bins}'[number of bins]:bins:' \
          '(-s --scissor)'{-s,--scissor}'[scissor operator gap size]:scissor:' \
          '(-t --tau)'{-t,--tau}'[relaxation time model]:tau:' \
          '(-l --lambda)'{-l,--lambda}'[lambda parameter]:lambda:' \
          '*:file:_files' && ret=0
        ;;
      plotbands)
        _arguments -s \
          '(-k --nkpoints)'{-k,--nkpoints}'[number of k points along the path]:nkpoints:' \
          '*:file:_files' && ret=0
        ;;
      plot)
        _arguments -s \
          '(-c --components)'{-c,--components}'[tensor components to plot]:components:' \
          '(-u --mu)'{-u,--mu}'[chemical potential as abscissa]' \
          '(-T --temperature)'{-T,--temperature}'[temperature as abscissa]:temperature:' \
          '(-s --subsample)'{-s,--subsample}'[subsample factor]:subsample:' \
          '*:file:_files' && ret=0
        ;;
      fermisurface)
        _arguments -s \
          '(-t --thickness)'{-t,--thickness}'[energy thickness]:thickness:' \
          '*:file:_files' && ret=0
        ;;
      fermisurface_2d)
        _arguments -s \
          '(-u --unit)'{-u,--unit}'[unit for the axes]:unit:' \
          '(-b --broadening)'{-b,--broadening}'[broadening parameter]:broadening:' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
