#compdef tanzu

local curcontext="$curcontext" state line ret=1

_tanzu_commands() {
  local -a commands=(
    'accelerator:manage accelerators'
    'apps:manage applications'
    'builder:manage builders'
    'cluster:manage Kubernetes clusters'
    'completion:generate shell completions'
    'config:manage CLI configuration'
    'context:manage contexts'
    'deploy:deploy an application'
    'insight:manage metadata store insights'
    'login:log in to a platform'
    'management-cluster:manage management clusters'
    'operations:day-2 operations'
    'package:manage packages'
    'plugin:manage CLI plugins'
    'project:manage projects'
    'secret:manage secrets'
    'services:manage service instances'
    'space:manage spaces'
    'version:print CLI version'
  )
  _describe -t commands 'tanzu command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--log-file=[log file path]:file:_files' \
  '--verbose=[verbosity level]:level' \
  '1: :_tanzu_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    ;;
esac

return ret
