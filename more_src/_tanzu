#compdef tanzu
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/cli/tanzu-cli/1-5/cli/index.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_tanzu_commands() {
  local -a commands=(
    'plugin:manage CLI plugins (install, search, sync)'
    'config:manage CLI configuration and certificates'
    'telemetry:manage CLI usage analytics'
    'version:print CLI version'
    'completion:generate shell completions'
  )
  _describe -t commands 'tanzu command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :_tanzu_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      plugin)
        local -a plugin_cmds=(
          'install:install a plugin'
          'list:list plugins'
          'search:search for plugins'
          'sync:sync plugins'
          'uninstall:uninstall a plugin'
          'group:operate on plugin groups'
        )
        _describe -t commands 'tanzu plugin command' plugin_cmds && ret=0
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    ;;
esac

return ret
