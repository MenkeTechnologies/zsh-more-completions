#compdef ezmlm-manage
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-manage.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-b[include instructions in replies (default)]' \
  '-B[omit instructions from replies]' \
  '-c[allow -get commands (default)]' \
  '-C[disable -get commands]' \
  '-d[alias for -e]' \
  '-D[alias for -E]' \
  '-e[allow remote admins to edit text files]' \
  '-E[disallow text editing (default)]' \
  '-f[extract sender from confirmations (default)]' \
  '-F[ignore From: headers]' \
  '-l[enable -list commands for moderators]' \
  '-L[ignore list commands (default)]' \
  '-m[require moderator approval for unsubscribes]' \
  '-M[unsubscribes do not require moderator (default)]' \
  '-n[notify when added/removed (default)]' \
  '-N[suppress notifications]' \
  '-q[do not notify owner (default)]' \
  '-Q[notify owner of failed unsubscribes]' \
  '-s[normal subscription confirmation (default)]' \
  '-S[no subscription confirmation]' \
  '-u[normal unsubscription confirmation (default)]' \
  '-U[no unsubscription confirmation]' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' && ret=0

return ret
