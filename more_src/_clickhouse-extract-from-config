#compdef clickhouse-extract-from-config
# Documentation: https://github.com/ClickHouse/ClickHouse/blob/master/programs/extract-from-config/clickhouse-extract-from-config.cpp
# Reference accessed: 2026-05-17
# Verified: ClickHouse multi-call symlink off the `clickhouse`
# server binary. Real flags: --config-file, --key, --try,
# --process-zk-includes, --log-level, --stacktrace, --help.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-C+,--config-file=}'[config file]:file:_files -g "*.(xml|yaml|yml)"' \
  {-K+,--key=}'[XPath key to extract]:xpath:' \
  '--process-zk-includes[process ZooKeeper includes]' \
  '--try[do not error if key is missing]' && ret=0

return ret
