#compdef clickhouse-extract-from-config

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-C+,--config-file=}'[config file]:file:_files -g "*.(xml|yaml|yml)"' \
  {-K+,--key=}'[XPath key to extract]:xpath:' \
  '--process-zk-includes[process ZooKeeper includes]' \
  '--try[do not error if key is missing]' && ret=0

return ret
