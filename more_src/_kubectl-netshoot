#compdef kubectl-netshoot
# Documentation: https://github.com/nilic/kubectl-netshoot
# kubectl-netshoot: kubectl plugin to spin up netshoot for network troubleshooting.

local curcontext="$curcontext" state line ret=1

_arguments -C -s \
  '(- *)'{-h,--help}'[show help]' \
  '--namespace=[namespace scope]:namespace:' \
  '--context=[kubeconfig context to use]:context:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '1:command:((run\:"create a throwaway netshoot pod" debug\:"attach an ephemeral netshoot container to a pod or node"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      run)
        _arguments -s \
          '--image-name=[container image to use]:image:' \
          '--image-tag=[netshoot container image tag]:tag:' \
          '--host-network[run on the node network namespace]' \
          '--node-selector=[node labels for pod scheduling]:selector:' \
          '--namespace=[namespace scope]:namespace:' && ret=0
        ;;
      debug)
        _arguments -s \
          '--image-name=[container image to use]:image:' \
          '--image-tag=[netshoot container image tag]:tag:' \
          '--namespace=[namespace scope]:namespace:' \
          '1:target pod or node:' && ret=0
        ;;
    esac
    ;;
esac

return ret
