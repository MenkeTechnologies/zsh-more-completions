#compdef pcapfix

# Zsh completion for pcapfix (repair broken pcap/pcapng files)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d[deep scan for corrupted data]' \
  '-n[force data link type to ethernet (DLT_EN10MB)]' \
  '-o[specify output file]:output file:_files' \
  '-t[force specific data link type]:data link type number' \
  '-v[verbose output]' \
  '--pcapng[force output in pcapng format]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:pcap file:_files -g "*.(pcap|pcapng|cap)(N)"' && ret=0

return ret
