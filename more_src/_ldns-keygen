#compdef ldns-keygen
# _ldns-keygen — NLnet Labs ldns-keygen (DNSSEC key-pair generator; writes K<name>+<alg>+<id>.{key,private,ds} files)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-keygen.c usage on tip.

_ldns-keygen() {
    _arguments \
        '-a+[signing algorithm (use "list" to list)]:alg:(list RSAMD5 DSA RSASHA1 RSASHA1-NSEC3-SHA1 RSASHA256 RSASHA512 ECC-GOST ECDSAP256SHA256 ECDSAP384SHA384 ED25519 ED448)' \
        '-k[set flags to 257 (Key-Signing Key)]' \
        '-b+[key length in bits]:n:' \
        '-r+[random device]:file:_files' \
        '-s[also create constant-named symlinks]' \
        '-f[force overwrite of existing symlinks]' \
        '-v[show version and exit]' \
        '1:domain:'
}

_ldns-keygen "$@"
