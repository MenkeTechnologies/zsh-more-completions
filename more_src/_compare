    '-compress[image compression type]:type:(None BZip Fax Group4 JPEG JPEG2000 Lossless LZW RLE Zip)' \
    '-decipher[convert cipher pixels to plain]:filename:_files' \
    '*-define[define format option]:format\:option:' \
    '-density[horizontal+vertical density (dpi)]:geometry:' \
    '-depth[image depth]:value:' \
    '-dissimilarity-threshold[max distortion for (sub)image match]:value:' \
    '-encipher[convert plain pixels to cipher]:filename:_files' \
    '-extract[extract area from image]:geometry:' \
    '-format[output formatted image characteristics]:string:' \
    '-fuzz[colors within this distance are equal]:distance:' \
    '-gravity[text placement]:type:(NorthWest North NorthEast West Center East SouthWest South SouthEast)' \
    '-highlight-color[emphasize pixel differences with this color]:color:' \
