#compdef diskus
# Documentation: https://man.archlinux.org/search?q=diskus
# Reference accessed: 2026-05-16

# Flags from diskus --help (https://github.com/sharkdp/diskus)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-j+,--threads=}'[thread count]:threads:' \
  '--size-format=[byte size style]:format:(decimal binary)' \
  {-v,--verbose}'[surface filesystem errors]' \
  '--directories=[count directory metadata sizes]:mode:(auto included excluded)' \
  {-b,--apparent-size}'[sum file sizes instead of allocated blocks]' \
  '*:path:_files -/' && ret=0

return ret
