#compdef f3
# Documentation: https://man.archlinux.org/search?q=f3
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'write:write test files'
  'read:read and verify'
  'probe:probe device for fakeness'
  'fix:fix fake flash drive'
  'brew:brew flash test'
  'verify:verify test files'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'f3 command' commands && ret=0 ;;
esac

return ret
