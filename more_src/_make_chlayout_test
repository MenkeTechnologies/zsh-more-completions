#compdef make_chlayout_test
# Documentation: https://ffmpeg.org/ffmpeg.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (FFmpeg tools/make_chlayout_test).
# Tool accepts a channel count and an output-options string positionally;
# no flag interface.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:channels:' \
  '*:output options:' && ret=0

return ret
