#compdef nabc
# Documentation: https://github.com/dacase/nabc
# AmberTools nabc: NAB-C molecular manipulation compiler

local ret=1

_arguments -s -S \
  '-O[optimize the object code]' \
  '-c[suppress linking, produce a .o file]' \
  '-v[verbosely report on the compile process]' \
  '-noassert[ignore assert statements]' \
  '-nodebug[ignore debug statements]' \
  '-o[name the output file]:file:_files' \
  '*-D[define string to the C preprocessor]:string:' \
  '*:source file:_files -g "*.nab *.c"' && ret=0

return ret
