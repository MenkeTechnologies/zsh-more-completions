#compdef octant

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[debug logging]' \
  '--context=[initial kube context]:context:' \
  '--disable-cluster-overview[disable cluster overview pane]' \
  '--enable-feature-applications[enable applications view]' \
  '--kubeconfig=[absolute path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[initial namespace]:namespace:' \
  '--namespace-list=[namespaces to show on startup]:names:' \
  '--plugin-path=[extra plugin directory]:dir:_files -/' \
  '--accepted-hosts=[allowed browser hosts (dev)]:hosts:' \
  '--browser-path=[override browser binary]:file:_files' \
  '--client-burst=[API client burst]:num:' \
  '--client-max-recv-msg-size=[max gRPC message size]:bytes:' \
  '--client-qps=[maximum Kubernetes client QPS]:qps:' \
  '--disable-open-browser[do not launch browser]' \
  '--disable-origin-check[disable CORS checks]' \
  '--enable-opencensus[enable OpenCensus tracing]' \
  '--klog-verbosity=[kube client log verbosity]:level:' \
  '--listener-addr=[dashboard listen address]:addr:' \
  '--local-content=[local UI content path]:dir:_files -/' \
  '--meminterval=[memory polling interval]:duration:' \
  '--memstats=[write memory stats to file]:file:_files' \
  '--proxy-frontend=[proxy frontend requests to URL]:url:' \
  '--ui-url=[public dashboard URL]:url:' \
  '*:ignored args:'
