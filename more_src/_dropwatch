#compdef dropwatch
# Documentation: https://man.archlinux.org/search?q=dropwatch
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-l+[lookup translation method]:method:(kas)' \
  '-c+[command file to execute]:file:_files' && ret=0

return ret
