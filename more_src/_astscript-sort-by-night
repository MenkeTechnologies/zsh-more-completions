#compdef astscript-sort-by-night
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astscript_002dsort_002dby_002dnight.html
# astscript-sort-by-night — organize FITS files by observation night from timestamp headers

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information in stdout]' \
  '--cite[show BibTeX citation for this program]' \
  '(-h --hdu)'{-h,--hdu}'[which HDU/extension to read from input]:HDU' \
  '(-k --key)'{-k,--key}'[header keyword containing the date information]:keyword' \
  '(-H --hour)'{-H,--hour}'[hour threshold for defining night boundaries]:hour' \
  '(-l --link)'{-l,--link}'[create symbolic links with night and file number]' \
  '(-c --copy)'{-c,--copy}'[copy files instead of creating symbolic links]' \
  '(-p --prefix)'{-p,--prefix}'[prefix added to output filenames]:prefix' \
  '--stdintimeout[microseconds to wait for standard input]:microseconds' \
  '*:input:_files' && ret=0

return ret
