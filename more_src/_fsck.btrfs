#compdef fsck.btrfs
# Documentation: https://man7.org/linux/man-pages/man8/fsck.btrfs.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-A[do not abort on errors]' \
  '-a[automatic repair (placeholder, does nothing)]' \
  '-p[preen mode (placeholder, does nothing)]' \
  '-y[automatic yes (placeholder, does nothing)]' \
  '*:device:_files' && ret=0

return ret
