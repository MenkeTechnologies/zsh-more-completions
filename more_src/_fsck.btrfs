#compdef fsck.btrfs
# Documentation: https://man.archlinux.org/search?q=fsck.btrfs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A[do not abort on errors]' \
  '-a[automatic repair]' \
  '-y[automatic yes]' \
  '*:device:_files' && ret=0

return ret
