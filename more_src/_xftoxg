_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -InputFile)'{-input,-InputFile}'[Input file with f transforms]:file:_files' \
  '(-goutput -GOutputFile)'{-goutput,-GOutputFile}'[Output file for g transforms. If an output filename is ]:file:_files' \
  '(-nfit -NumberToFit)'{-nfit,-NumberToFit}'[Number of adjacent sections to fit, 0 for global alignm]:value:' \
  '(-ref -ReferenceSection)'{-ref,-ReferenceSection}'[Do a global alignment to the given section; this will g]:value:' \
  '(-order -OrderOfPolynomialFit)'{-order,-OrderOfPolynomialFit}'[Order of the polynomial fit to the data. The default is]:value:' \
  '(-mixed -HybridFits)'{-mixed,-HybridFits}'[Number of parameters to eliminate trends for with a hyb]:value:' \
  '(-range -RangeOfAnglesInAverage)'{-range,-RangeOfAnglesInAverage}'[Compute the global average center position, and the cen]:value:' \
  '(-robust -RobustFit)'{-robust,-RobustFit}'[Use robust weighting when fitting to find the center po]' \
  '(-kfactor -KFactorScaling)'{-kfactor,-KFactorScaling}'[Amount to scale the K factor that controls how many poi]:value:' \
