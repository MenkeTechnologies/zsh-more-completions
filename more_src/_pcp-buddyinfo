#compdef pcp-buddyinfo
# _pcp-buddyinfo — PCP-based buddy allocator stats (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/buddyinfo/pcp-buddyinfo.1 SYNOPSIS.

_pcp-buddyinfo() {
    _arguments \
        '(- *)-?[show help]' \
        '(- *)-V[show version]' \
        '-u[unbuffered output]' \
        '-z[use archive recording timezone]' \
        '-s+[samples to collect]:n:' \
        '-a+[PCP archive folio]:archive:_files' \
        '-Z+[timezone]:tz:'
}

_pcp-buddyinfo "$@"
