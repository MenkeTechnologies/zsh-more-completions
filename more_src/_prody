#compdef prody
# Documentation: https://prody.readthedocs.io/en/latest/apps/prody/
# ProDy command line application for protein dynamics analysis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --cite)'{-c,--cite}'[print citation details and exit]' \
  '(-v --version)'{-v,--version}'[print ProDy version and exit]' \
  '1:command:(anm gnm pca eda align blast biomol catdcd contacts fetch select)' \
  '*::args:->args' && ret=0

return ret
