#compdef influxctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'auth:log in or log out'
  'cluster:list cluster information'
  'database:manage databases'
  'help:show help'
  'management:manage management tokens'
  'query:query data'
  'token:manage database tokens'
  'user:manage cluster users'
  'version:show version'
  'write:write line protocol'
)

_arguments -C \
  '--debug[enable debug logging]' \
  '--account=[account ID]:id:' \
  '--cluster=[cluster ID]:id:' \
  '--config=[config file]:file:_files' \
  '--profile=[connection profile]:name:' \
  '--timeout=[API timeout]:duration:' \
  '--trace[verbose debug logging]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'influxctl subcommand' subcommands && ret=0
    ;;
esac

return ret
