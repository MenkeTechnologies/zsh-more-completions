#compdef radiusctl
# _radiusctl — OpenBSD radiusctl (control + introspect radiusd(8); test command sends a RADIUS Access-Request with tunable port/method/msgauth/interval/tries; ipcp subcommand inspects/manages IPCP-allocated addresses)
# upstream: https://github.com/openbsd/src (usr.sbin/radiusctl)
# Commands from usr.sbin/radiusctl/radiusctl.8 on tip.

_radiusctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'radiusctl command' \
                '(test:send RADIUS Access-Request and show result ipcp:show/monitor/dump/delete/disconnect IPCP sessions)'
            ;;
        args)
            case $line[1] in
                ipcp) _describe -t commands 'ipcp subcommand' '(show monitor dump delete disconnect)' ;;
                test)
                    _arguments \
                        '1:hostname:_hosts' \
                        '2:radius_secret:' \
                        '3:user_name:_users' \
                        '*::test-option:(msgauth method nas-port port password tries interval maxwait)'
                    ;;
            esac
            ;;
    esac
}

_radiusctl "$@"
