#compdef age-plugin-op
# Documentation: https://github.com/bromanko/age-plugin-op
# age client plugin using 1Password sourced keys

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--generate[generate a new age identity file from a 1Password item reference]' \
  '(-o --output)'{-o,--output}'[write identity to file]:output file:_files' \
  '--decrypt[decrypt input using a 1Password sourced key]' \
  '(-i --identity)'{-i,--identity}'[identity file]:identity file:_files' \
  '*:op reference:_default' && ret=0

return ret
