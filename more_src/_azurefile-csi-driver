#compdef azurefile-csi-driver azurefileplugin
# _azurefile-csi-driver — Azure File CSI driver
# upstream: https://github.com/kubernetes-sigs/azurefile-csi-driver
# Flags from pkg/azurefileplugin/main.go + pkg/azurefile/azurefile_option.go on tip.

_azurefile-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print the version and exit]' \
        '--metrics-address=[Prometheus metrics bind address]:addr:' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--nodeid=[node id]:id:' \
        '--drivername=[name of the driver]:name:' \
        '--kubeconfig=[kubeconfig file (required out of cluster)]:file:_files' \
        '--cloud-config-secret-name=[secret name of cloud config]:name:' \
        '--cloud-config-secret-namespace=[secret namespace of cloud config]:ns:' \
        '--custom-user-agent=[custom userAgent]:ua:' \
        '--user-agent-suffix=[userAgent suffix]:s:' \
        '--allow-empty-cloud-config=[allow running driver without cloud config]:bool:(true false)' \
        '--enable-get-volume-stats=[expose CSI Node GetVolumeStats]:bool:(true false)' \
        '--enable-vhd=[enable VHD disk feature]:bool:(true false)' \
        '--mount-permissions=[default mount permissions for the file share]:mode:' \
        '--fs-group-change-policy=[fsGroup change policy]:policy:(None Always OnRootMismatch)' \
        '--enable-windows-host-process[run on Windows HostProcess container]' \
        '--enable-otel-tracing[enable OpenTelemetry tracing]' \
        '--enable-traffic-manager[enable traffic manager]' \
        '--traffic-manager-port=[default traffic manager port]:port:' \
        '--vmss-cache-ttl-seconds=[VMSS cache TTL]:s:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_azurefile-csi-driver "$@"
