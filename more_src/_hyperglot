#compdef hyperglot
# Documentation: https://github.com/rosettatype/hyperglot
# Detect which languages a font supports

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[print version number]' \
  '*'{-c,--check}'=[character set: base, auxiliary, punctuation, numerals, currency, all]:set:(base auxiliary punctuation numerals currency all)' \
  '--validity=[filter by data validity]:validity:(todo draft preliminary verified)' \
  '(-s --status)'{-s,--status}'=[language status]:status:(living historical constructed all)' \
  '(-o --orthography)'{-o,--orthography}'=[orthography types]:type:(primary secondary historical transliteration all)' \
  '(-d --decomposed)'{-d,--decomposed}'[accept component characters instead of precomposed]' \
  '(-m --marks)'{-m,--marks}'[require all combining marks]' \
  '--sort=[sort order]:order:(alphabetic speakers)' \
  '--sort-dir=[sort direction]:dir:(asc desc)' \
  '(-y --output)'{-y,--output}'=[write YAML output to file]:file:_files' \
  '(-t --shaping-threshold)'{-t,--shaping-threshold}'=[frequency threshold for shaping checks]:threshold' \
  '--no-shaping[disable shaping checks]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '*:font file:_files -g "*.(ttf|otf|TTF|OTF)"' && ret=0

return ret
