#compdef hakoriginfinder
# _hakoriginfinder — Luke Stephens hakoriginfinder CLI for identifying origin IP addresses behind CDN proxies CloudFlare Akamai by comparing host-header-based responses to direct-IP responses (hakluke team, Go); flag
# upstream: https://github.com/hakluke/hakoriginfinder

_hakoriginfinder() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-h+[hostname]:h:_hosts' \
        '--hostname=+[hostname]:h:_hosts' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-p+[port]:n:(80 443 8080 8443 8000 8008 8888 8009 8081 8082 8083 8084 8085)' \
        '--port=+[port]:n:(80 443 8080 8443 8000 8008 8888 8009 8081 8082 8083 8084 8085)' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-i[ignore certificate errors]' \
        '--insecure[ignore certificate errors]' \
        '--scheme=+[s]:s:(http https both)' \
        '--similarity-threshold=+[F]:f:' \
        '*:IP list file:_files'
}

_hakoriginfinder "$@"
