#compdef hv_vss_daemon hv-vss-daemon
# _hv-vss — Linux hv_vss_daemon (Hyper-V Volume Shadow-copy Service daemon; lets the Hyper-V host freeze the guest filesystem for an application-consistent snapshot; -n no daemonize, -d debug)
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git (tools/hv)
# Flags from kernel tools/hv/hv_vss_daemon.c on tip.

_hv-vss() {
    _arguments \
        '-h[show help]' \
        '-n[no daemonize]' \
        '-d[debug]'
}

_hv-vss "$@"
