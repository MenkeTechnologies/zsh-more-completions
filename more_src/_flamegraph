#compdef flamegraph
# Documentation: https://github.com/flamegraph-rs/flamegraph
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flamegraph (flamegraph-rs): Rust binary that wraps perf/dtrace to produce SVG flame graphs.

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  {-o,--output}'=[output SVG file]:file:_files'
  {-F,--freq}'=[sampling frequency in Hz (default 997)]:hz:'
  '--min-width=[minimum width of a frame]:pixels:'
  '--image-width=[SVG image width in pixels]:pixels:'
  '--palette=[color palette]:palette:(hot mem io red green blue aqua yellow purple orange wakeup java perl js rust)'
  '--deterministic[use deterministic colors across runs]'
  '--inverted[invert (icicle graph)]'
  '--reverse[reverse stack order]'
  '--flamechart[time-sorted flame chart instead of flame graph]'
  '--notes=[embed notes in the SVG]:text:'
  '(-c --cmd)'{-c,--cmd}'=[custom perf/dtrace command]:command:'
  {-p,--pid}'=[PID to profile]:pid:_pids'
  '--perfdata=[path to perf data file]:file:_files'
  '--no-inline[disable inline frame expansion]'
  '--post-process=[post-processing folding command]:cmd:'
  '--root[run perf with sudo]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '--open[open SVG in default viewer]'
  '--completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)'
  '--skip-after=[function name to skip after]:func:'
  '--ignore-status[ignore perf exit status]'
  '*:command:'
)

_arguments -s -S $arguments
