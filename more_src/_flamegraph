#compdef flamegraph

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  {-o,--output}'=[output file]:file:_files'
  {-F,--freq}'=[sampling frequency in Hz]:hz:'
  '--min-width=[minimum width of a frame in pixels]:pixels:'
  '--image-width=[image width in pixels]:pixels:'
  '--palette=[color palette]:palette:(hot mem io red green blue aqua yellow purple orange wakeup java perl js rust)'
  '--deterministic[use deterministic colors]'
  '--inverted[invert the flame graph (icicle graph)]'
  '--reverse[reverse stack order]'
  '--flamechart[produce a flame chart instead of flame graph]'
  '--notes=[add notes to the flame graph]:text:'
  '--cmd=[command to profile]:command:'
  {-p,--pid}'=[PID to profile]:pid:_pids'
  '--perfdata=[path to perf data file]:file:_files'
  '--no-inline[disable inline frame expansion]'
  '--post-process=[post-processing command]:cmd:'
  '--root[run perf as root]'
  '--verbose[verbose output]'
  '--open[open the output in a browser]'
  '--completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)'
  '--skip-after=[function name to skip after]:func:'
  '--title=[title of the flame graph]:title:'
  '--subtitle=[subtitle of the flame graph]:subtitle:'
  '--countname=[name for the count type]:name:'
  '*:command:'
)

_arguments -s -S $arguments
