#compdef codes_config
# Documentation: https://confluence.ecmwf.int/display/ECC/codes_config
# Source: ecmwf/eccodes tools/codes_config.in — ecCodes build/version info script (bash).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)--version[print ecCodes version string]' \
    '(- *)--info[print full build configuration info]' \
    '(- *)--git[print the git SHA-1 of the build]' \
    && ret=0

return ret
