#compdef wazuh-manager
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/wazuh-control.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. wazuh-manager is the systemd
# service wrapping wazuh-control; direct invocation is rare. Daemons it
# launches share the common flag set.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version and license info]' \
  '-c[config file]:file:_files' \
  '*-d[debug mode (repeatable)]' \
  '-f[run in foreground]' \
  '-t[test configuration]' \
  '-u[run as user]:user:_users' \
  '-g[run as group]:group:_groups' && ret=0
return ret
