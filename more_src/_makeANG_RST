#compdef makeANG_RST
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools makeANG_RST: build sander angle/torsion restraints from constraints

local ret=1

_arguments -s -S \
  '-help[show usage]' \
  '-pdb[ambpdb file]:file:_files -g "*.pdb"' \
  '-con[constraint file]:file:_files' \
  '-lib[library file]:file:_files' \
  '-les[LES file]:file:_files' \
  '*:file:_files' && ret=0

return ret
