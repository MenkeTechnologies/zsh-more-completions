#compdef kserve-agent
# _kserve-agent — KServe predictor sidecar (model puller, logger, batcher) (kserve/kserve)
# upstream: https://github.com/kserve/kserve
# Flags from cmd/agent/main.go on tip.

_kserve-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[agent HTTP port]:port:' \
        '--component-port=[wrapped model HTTP port]:port:' \
        '--enable-puller[enable model puller]' \
        '--config-dir=[model-config directory]:dir:_files -/' \
        '--model-dir=[model storage directory]:dir:_files -/' \
        '--log-url=[URL receiving request/response logs]:url:_urls' \
        '--workers=[concurrent worker goroutines]:n:' \
        '--source-uri=[CloudEvents source URI]:uri:' \
        '--log-mode=[logged side]:mode:(request response all)' \
        '--log-store-path=[blob-storage log output path]:path:' \
        '--log-store-format=[blob-storage marshal format]:fmt:(json csv parquet)' \
        '--log-marshaller-url=[log marshaller service URL]:url:_urls' \
        '--log-marshaller-port=[embedded marshaller HTTP port]:port:' \
        '--log-batch-size=[records per batch]:n:' \
        '--log-batch-interval=[max partial-batch flush wait]:dur:' \
        '--inference-service=[InferenceService name header]:name:' \
        '--namespace=[namespace header]:ns:' \
        '--endpoint=[endpoint name header]:name:' \
        '--component=[component name header]:comp:(predictor explainer transformer)' \
        '*--metadata-headers=[allowed metadata headers]:list:' \
        '*--metadata-annotations=[allowed metadata annotations]:list:' \
        '--enable-batcher[enable request batcher]' \
        '--max-batchsize=[max batch size]:n:' \
        '--max-latency=[max batcher latency (ms)]:n:' \
        '--probe-period=[readiness probe timeout]:dur:' \
        '--logger-ca-cert-file=[logger CA cert file]:file:_files' \
        '--logger-tls-skip-verify[skip logger TLS verification]'
}

_kserve-agent "$@"
