#compdef teip

# Zsh completion for teip (masking tool for shell pipeline)

_arguments -s -S \
  '(-g --only-matching)'{-g,--only-matching}'[select only matched parts by regex]:pattern:' \
  '(-o)-o[only output matched parts]' \
  '(-c --characters)'{-c,--characters}'[select characters by range]:range:' \
  '(-l --lines)'{-l,--lines}'[select lines by range]:range:' \
  '(-f --fields)'{-f,--fields}'[select fields by range]:range:' \
  '(-d --delimiter)'{-d,--delimiter}'[field delimiter]:delimiter:' \
  '(-D --regex-delimiter)'{-D,--regex-delimiter}'[field delimiter as regex]:regex:' \
  '(-s --solid)'{-s,--solid}'[treat consecutive delimiters as a single one]' \
  '(-v --invert-match)'{-v,--invert-match}'[invert the sense of matching]' \
  '--csv[parse as CSV]' \
  '-I[replace string in command]:string:' \
  '-e[execute command for each line]' \
  '--chomp[suppress the trailing newline]' \
  '--sed[use sed-like syntax]' \
  '--completion[generate shell completion]:shell:(bash zsh fish)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--:command and args:_command_names -e' && return 0
