#compdef bitfinex-cli bitfinex
# _bitfinex-cli — Bitfinex bitfinex-cli CLI command-line frontend wrapping the Bitfinex Honey Framework cryptocurrency exchange Spot Margin Funding Derivatives REST WebSocket API managing accounts wallets orders trades positions funding-offers credits margin-infos derivatives-positions tickers candles books historical-trades stats (Bitfinex team, Go); cobra
# upstream: https://www.bitfinex.com/

_bitfinex-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'wallet:wallet operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'funding:funding offers and credits'
        'margin:margin infos'
        'derivative:derivative operations'
        'ticker:ticker operations'
        'candle:candle data'
        'book:order book'
        'history:trade history'
        'stats:stats operations'
        'config:configuration'
        'transfer:transfer operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--api-version=+[v]:v:(v1 v2)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bitfinex-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list new cancel cancel-all status update)' \
                    '--symbol=+[sym]:str:' \
                    '--type=+[t]:t:(EXCHANGE_MARKET EXCHANGE_LIMIT EXCHANGE_STOP EXCHANGE_TRAILING_STOP MARKET LIMIT STOP TRAILING_STOP)' \
                    '--amount=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '*:order id:' ;;
                wallet|trade|position|funding|margin|derivative|history|stats|config|transfer) _arguments '1:op:(list get create update delete cancel)' '*:id:' ;;
                ticker|candle|book) _arguments \
                    '--symbol=+[sym]:str:' \
                    '--timeframe=+[t]:t:(1m 5m 15m 30m 1h 3h 6h 12h 1D 7D 14D 1M)' \
                    '--precision=+[p]:p:(P0 P1 P2 P3 P4 R0)' ;;
            esac
            ;;
    esac
}

_bitfinex-cli "$@"
