#compdef checkov2
# _checkov2 — Bridgecrew Prisma Cloud checkov2 CLI command-line frontend wrapping the Checkov static code analysis tool for infrastructure as code IaC and software composition analysis SCA open-source written in Python scans cloud infrastructure provisioned using Terraform Terraform-plan CloudFormation AWS-SAM Kubernetes Helm-Charts Kustomize Dockerfile Serverless framework Bicep ARM templates Ansible OpenAPI policies-Python-YAML-DSL-graph-based built-in-Best-Practices over-1500-built-in-checks (Bridgecrew Prisma Cloud team, Python); argparse
# upstream: https://www.checkov.io/

_checkov2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '-d+[directory]:dir:_files -/' \
        '--directory=+[dir]:dir:_files -/' \
        '*-d+[dir]:dir:_files -/' \
        '-f+[file]:file:_files' \
        '--file=+[file]:file:_files' \
        '*-f+[file]:file:_files' \
        '--baseline=+[file]:file:_files -g ".checkov.baseline"' \
        '--config-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--create-config=+[file]:file:_files' \
        '--show-config[show config]' \
        '--external-checks-dir=+[dir]:dir:_files -/' \
        '--external-checks-git=+[url]:str:' \
        '*--external-checks-dir=+[dir]:dir:_files -/' \
        '-l[soft fail]' \
        '--soft-fail[soft fail]' \
        '--soft-fail-on=+[ids]:str:' \
        '--hard-fail-on=+[ids]:str:' \
        '--bc-api-key=+[key]:str:' \
        '--prisma-api-url=+[url]:str:' \
        '--policy-metadata-filter=+[filter]:str:' \
        '--repo-id=+[id]:str:' \
        '--include-all-checkov-policies[include all]' \
        '--branch=+[name]:str:' \
        '--skip-cve-package=+[pkg]:str:' \
        '--skip-resources-without-violations[skip clean]' \
        '--framework=+[fw]:fw:(terraform terraform_plan kubernetes helm kustomize cloudformation serverless secrets dockerfile bicep arm sca_package sca_image openapi argo_workflows circleci_pipelines github_actions gitlab_pipelines bitbucket_pipelines azure_pipelines github_configuration gitlab_configuration bitbucket_configuration ansible all)' \
        '*--framework=+[fw]:fw:(terraform terraform_plan kubernetes helm kustomize cloudformation serverless secrets dockerfile bicep arm sca_package sca_image openapi argo_workflows circleci_pipelines github_actions gitlab_pipelines bitbucket_pipelines azure_pipelines github_configuration gitlab_configuration bitbucket_configuration ansible all)' \
        '--skip-framework=+[fw]:str:' \
        '-c+[check ids]:str:' \
        '--check=+[ids]:str:' \
        '*-c+[check id]:str:' \
        '--skip-check=+[ids]:str:' \
        '-o+[output]:o:(cli cyclonedx cyclonedx_json csv json junitxml github_failed_only gitlab_sast sarif spdx)' \
        '*-o+[output]:o:(cli cyclonedx cyclonedx_json csv json junitxml github_failed_only gitlab_sast sarif spdx)' \
        '--output=+[fmt]:f:(cli json cyclonedx junitxml github_failed_only gitlab_sast sarif spdx)' \
        '--output-file-path=+[path]:_files' \
        '--output-bc-ids[BC IDs]' \
        '--no-guide[no guide]' \
        '--quiet[quiet]' \
        '--compact[compact]' \
        '--skip-suppressions[skip suppressions]' \
        '--skip-policy-download[skip policy download]' \
        '--skip-download[skip download]' \
        '--download-external-modules=+[v]:v:(true false)' \
        '--repo-root-for-plan-enrichment=+[dir]:dir:_files -/' \
        '--deep-analysis[deep analysis]' \
        '--evaluate-variables=+[v]:v:(true false)' \
        '--use-enforcement-rules[enforcement rules]' \
        '--policy-metadata-cmd[policy metadata]' \
        '--add-check[add check]' \
        '--openai-api-key=+[key]:str:' \
        '*:args:'
}

_checkov2 "$@"
