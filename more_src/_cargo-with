#compdef cargo-with
# Documentation: https://github.com/cbourjau/cargo-with
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# cargo-with: wrap cargo invocations to run a tool (gdb, valgrind, etc.) on
# the produced binary. The command string substitutes {bin} for the artifact
# and {args} for trailing arguments.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[print help]' \
  '--bin=[which binary to build and run]:bin:' \
  '--example=[which example to execute]:example:' \
  '--lib=[library artifact (test command only)]:lib:' \
  '--test=[unit test artifact (test command only)]:test:' \
  '1:command template with {bin} {args}:' \
  '*:: :_default' && ret=0

return ret
