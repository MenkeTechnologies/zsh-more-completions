_frangipanni() {
    _arguments -s \
        '-h[show help]' \
        '--help[show help]' \
        '--version[print frangipanni version and exit]' \
        '--separators[print leading separators on branches]' \
        '--sort=[sort by]:sort by:(input alpha counts)' \
        '--order=[deprecated alias of --sort]:sort by:(input alpha counts)' \
        '--format=[output format]:format:(indent json)' \
        '--breaks=[characters to slice lines with]:chars:' \
        '--no-fold[do not fold single-child branches]' \
        '--level=[analyse down to level N]:level:' \
        '--chars[slice line after each character]' \
        '--counts[print match counts at end of each line]' \
        '--depth=[maximum tree depth to print]:depth:' \
        '--indent=[spaces per indent level (default 4)]:n:' \
        '--spacer=[indent character(s) (default space)]:chars:' \
        '--lua=[Lua script to run against parsed tree]:lua file:_files -g "*.lua"' \
        '--skip=[skip N leading fields per line]:n:' \
        '--down[descending sort order]'
}

