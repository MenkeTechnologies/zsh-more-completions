#compdef omprep
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omprep/node4.html
# Clone OM ODF files and modify them for subsequent pipeline processing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--set=[name of input ODF to be cloned]:file:_files' \
  '--nphset=[name of OM Non-Periodic Housekeeping File]:file:_files' \
  '--pehset=[name of OM Periodic Housekeeping File]:file:_files' \
  '--wdxset=[name of OM Priority Window Data Auxiliary File]:file:_files' \
  '--outset=[name of output file]:file:_files' \
  '--modeset=[observation mode]:mode:(0 1 2 3)' \
  '--rawattitude=[attitude data source]:value:(0 1 2)' \
  '*:param=value:_default' && ret=0

return ret
