#compdef containerd-stargz-grpc
# _containerd-stargz-grpc — Stargz containerd snapshotter daemon (containerd/stargz-snapshotter)
# upstream: https://github.com/containerd/stargz-snapshotter
# Flags from cmd/containerd-stargz-grpc/main.go (flag).

_containerd-stargz-grpc() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[print version]' \
        '-address=[gRPC server unix socket]:file:_files' \
        '-config=[path to configuration file]:file:_files -g "*.toml"' \
        '-log-level=[log level]:level:(trace debug info warn error fatal panic)' \
        '-root=[snapshotter root directory]:dir:_files -/'
}

_containerd-stargz-grpc "$@"
