#compdef knoxnl
# Documentation: https://github.com/xnl-h4ck3r/knoxnl
# knoxnl - python wrapper around the KNOXSS API

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[a single URL, or file of URLs]:input:_files' \
  '(-o --output)'{-o,--output}'[file for saving successful XSS and payloads]:file:_files' \
  '(-ow --output-overwrite)'{-ow,--output-overwrite}'[overwrite existing output file]' \
  '(-oa --output-all)'{-oa,--output-all}'[write all results, not just successful]' \
  '(-X --http-method)'{-X,--http-method}'[HTTP method]:method:(GET POST BOTH)' \
  '(-pd --post-data)'{-pd,--post-data}'[POST request data]:data:' \
  '(-H --headers)'{-H,--headers}'[custom headers separated by pipe]:headers:' \
  '(-A --api-key)'{-A,--api-key}'[KNOXSS API key]:key:' \
  '(-s --success-only)'{-s,--success-only}'[display only successful payloads]' \
  '(-p --processes)'{-p,--processes}'[number of threads per minute]:processes:' \
  '(-t --timeout)'{-t,--timeout}'[seconds to wait for API response]:seconds:' \
  '(-st --stall-timeout)'{-st,--stall-timeout}'[seconds between scan steps before aborting]:seconds:' \
  '(-bp --burp-piper)'{-bp,--burp-piper}'[use with Burp Piper extension]' \
  '(-dw --discord-webhook)'{-dw,--discord-webhook}'[Discord webhook for XSS notifications]:url:' \
  '(-dwc --discord-webhook-complete)'{-dwc,--discord-webhook-complete}'[Discord webhook for completion]:url:' \
  '(-r --retries)'{-r,--retries}'[retry attempts for connection issues]:retries:' \
  '(-ri --retry-interval)'{-ri,--retry-interval}'[seconds between retries]:seconds:' \
  '(-rb --retry-backoff)'{-rb,--retry-backoff}'[backoff multiplier for retries]:multiplier:' \
  '(-pur --pause-until-reset)'{-pur,--pause-until-reset}'[wait for API limit reset]' \
  '(-sb --skip-blocked)'{-sb,--skip-blocked}'[skip after N 403 responses per domain]:n:' \
  '(-fn --force-new)'{-fn,--force-new}'[force new scan instead of cached results]' \
  '(-rl --runtime-log)'{-rl,--runtime-log}'[stream live KNOXSS scan logs]' \
  '(-nt --no-todo)'{-nt,--no-todo}'[do not create .todo file]' \
  '(-up --update)'{-up,--update}'[update knoxnl to latest version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-do --debug-output)'{-do,--debug-output}'[save terminal output to file]:file:_files' \
  '--version[display current version]' && ret=0

return ret
