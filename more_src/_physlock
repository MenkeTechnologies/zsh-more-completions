#compdef physlock
# Documentation: https://manpages.debian.org/testing/physlock/physlock.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-d[fork and detach before prompting]' \
  '-l[only lock console switching]' \
  '-L[only enable (unlock) console switching]' \
  '-m[mute kernel messages on console]' \
  '-p+[message before password prompt]:msg:' \
  '-s[disable SysRq mechanism]' && ret=0

return ret
