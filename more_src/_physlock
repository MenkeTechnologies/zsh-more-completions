#compdef physlock
# Documentation: https://man.archlinux.org/search?q=physlock
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-d[fork and detach]' \
  '-l[only lock console switching]' \
  '-L[only enable console switching]' \
  '-m[mute kernel messages]' \
  '-p+[message before password prompt]:msg:' \
  '-s[disable sysrq key]' && ret=0

return ret
