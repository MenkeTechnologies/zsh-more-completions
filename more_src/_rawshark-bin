#compdef rawshark
# _rawshark-bin — Wireshark raw packet dissector; reads raw libpcap data on stdin and prints decoded fields
# upstream: https://gitlab.com/wireshark/wireshark

_rawshark-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-d+[encapsulation]:str:' \
        '-F+[field list]:fields:' \
        '-l[flush output after each pkt]' \
        '-m+[max memory]:n:' \
        '-n[disable name resolution]' \
        '-N+[name resolution flags]:flags:' \
        '-o+[set preference]:k=v:' \
        '-p[no promiscuous]' \
        '-q[quiet]' \
        '-r+[input file]:file:_files' \
        '-R+[read filter]:filter:' \
        '-s[print packet contents]' \
        '-S[print as PSML format]' \
        '-X+[ext option]:str:' \
        '-Z+[zero offset]:str:' \
        '*:filter:'
}

_rawshark-bin "$@"
