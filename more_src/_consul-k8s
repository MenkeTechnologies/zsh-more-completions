#compdef consul-k8s

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'install:install Consul on Kubernetes'
      'uninstall:uninstall Consul from Kubernetes'
      'upgrade:upgrade Consul on Kubernetes'
      'status:show status of Consul on Kubernetes'
      'proxy:manage Connect proxy'
      'troubleshoot:troubleshoot Consul on Kubernetes'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments \
          '(-f --config-file)'{-f,--config-file}'=[Helm values file]:file:_files -g "*.yaml"' \
          '--set=[set a value override]:key=value:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--auto-approve[skip confirmation prompt]' \
          '--dry-run[perform dry run]' \
          '--wait[wait for resources to be ready]' \
          '--timeout=[timeout for Kubernetes commands]:duration:' \
          '--context=[Kubernetes context]:context:' \
          '--kubeconfig=[kubeconfig file]:file:_files' && ret=0
        ;;
      (uninstall)
        _arguments \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--auto-approve[skip confirmation prompt]' \
          '--name=[release name]:name:' \
          '--context=[Kubernetes context]:context:' \
          '--kubeconfig=[kubeconfig file]:file:_files' \
          '--wipe-data[wipe persistent data]' && ret=0
        ;;
      (upgrade)
        _arguments \
          '(-f --config-file)'{-f,--config-file}'=[Helm values file]:file:_files -g "*.yaml"' \
          '--set=[set a value override]:key=value:' \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--auto-approve[skip confirmation prompt]' \
          '--dry-run[perform dry run]' \
          '--wait[wait for resources to be ready]' \
          '--timeout=[timeout]:duration:' \
          '--context=[Kubernetes context]:context:' \
          '--kubeconfig=[kubeconfig file]:file:_files' && ret=0
        ;;
      (status)
        _arguments \
          '--namespace=[Kubernetes namespace]:namespace:' \
          '--context=[Kubernetes context]:context:' \
          '--kubeconfig=[kubeconfig file]:file:_files' && ret=0
        ;;
      (proxy)
        _arguments \
          '1:action:(list read)' \
          '--pod-name=[pod name]:pod:' \
          '--namespace=[Kubernetes namespace]:namespace:' && ret=0
        ;;
    esac
    ;;
esac

return ret
