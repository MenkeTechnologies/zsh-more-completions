#compdef ansible-config-cli
# _ansible-config-cli — Red Hat Ansible configuration management CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/ansible

_ansible-config-cli() {
    local -a sub=(
        'dump:dump current settings'
        'init:create initial config file'
        'list:list configurable options'
        'view:view current config file'
        'validate:validate config'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-vvv[more verbose]' \
        '--config=+[file]:file:_files -g "ansible.cfg"' \
        '-c+[file]:file:_files -g "ansible.cfg"' \
        '--type=+[type]:t:(all base module connection lookup callback shell strategy inventory)' \
        '-t+[type]:t:(all base module connection lookup callback shell strategy inventory)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ansible-config subcommand' sub ;;
        args)
            case $words[1] in
                dump|list) _arguments \
                    '--only-changed[only changed]' \
                    '--format=+[format]:f:(json yaml ini env)' \
                    '-f+[format]:f:(json yaml ini env)' ;;
                init) _arguments \
                    '--disabled[disabled]' \
                    '-d[disabled]' \
                    '--format=+[format]:f:(ini env vars)' \
                    '-f+[format]:f:(ini env vars)' ;;
                validate) _arguments \
                    '--format=+[format]:f:(ini env yaml)' \
                    '-f+[format]:f:(ini env yaml)' ;;
            esac
            ;;
    esac
}

_ansible-config-cli "$@"
