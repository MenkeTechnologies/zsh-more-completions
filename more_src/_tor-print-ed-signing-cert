#compdef tor-print-ed-signing-cert
# Documentation: https://man.archlinux.org/man/tor-print-ed-signing-cert.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:signing cert file:_files' && ret=0

return ret
