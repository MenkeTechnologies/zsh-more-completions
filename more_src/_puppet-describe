#compdef puppet-describe
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/describe.md
# puppet describe - print documentation for resource types and providers

local ret=1

_arguments -s -S \
  '--help[print this help text]' \
  '--providers[describe providers in detail for each type]' \
  '--list[list all types]' \
  '--meta[list all metaparameters]' \
  '--short[list only parameters without detail]' \
  '*:type:' && ret=0

return ret
