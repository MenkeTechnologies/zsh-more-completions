#compdef cadd
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss12.html
# KAPPA CADD - add a scalar to an NDF data structure

local ret=1

_arguments -C \
  'IN=[input NDF data structure]:NDF file:_files' \
  'OUT=[output NDF data structure]:NDF file:_files' \
  'SCALAR=[value to be added to the data array]:value:' \
  'TITLE=[title for the output NDF]:title:' \
  '*:NDF file:_files' && ret=0

return ret
