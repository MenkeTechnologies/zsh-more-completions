#compdef pcsx2 pcsx2-qt
# Documentation: https://pcsx2.net/docs/advanced/cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-batch[batch mode]' \
  '-nogui[disable GUI]' \
  '-portable[portable mode]' \
  '-datapath+[set user data path]:dir:_files -/' \
  '-elf+[load ELF file]:file:_files -g "*.elf"' \
  '-gameargs+[game arguments]:args:' \
  '-disc+[boot from disc path]:file:_files' \
  '-logfile+[log file]:file:_files' \
  '-bios[boot to BIOS]' \
  '-fastboot[force fastboot]' \
  '-slowboot[force slow boot through BIOS]' \
  '-state+[load save state by slot]:slot:' \
  '-statefile+[load save state from file]:file:_files' \
  '-fullscreen[start in fullscreen]' \
  '-nofullscreen[disable fullscreen]' \
  '-bigpicture[start in big picture mode]' \
  '-earlyconsolelog[enable console logging early]' \
  '-testconfig[test configuration and exit]' \
  '-setupwizard[run setup wizard]' \
  '-debugger[start debugger]' \
  '-turbo[start in turbo mode]' \
  '-unlimited[start in unlimited frame mode]' \
  '-raintegration[enable RAIntegration]' \
  '-startpaused[start paused]' \
  '-cleanup[cleanup after update]' \
  '*: :_files -g "*.iso *.bin *.cue *.mdf *.mds *.gz *.cso *.dump *.zip *.elf *.chd"' && ret=0

return ret
