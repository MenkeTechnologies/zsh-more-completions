#compdef pcsx2 pcsx2-qt
# Documentation: https://man.archlinux.org/search?q=pcsx2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-batch[batch mode]' \
  '-fullscreen[start fullscreen]' \
  '-nogui[no GUI]' \
  '-nofullscreen[no fullscreen]' \
  '-bigpicture[big picture]' \
  '-portable[portable mode]' \
  '-elf+[load ELF]:file:_files -g "*.elf"' \
  '-irx+[load IRX]:file:_files -g "*.irx"' \
  '-state+[save state file]:file:_files' \
  '-statefolder+[states folder]:dir:_files -/' \
  '-bios[force boot to BIOS]' \
  '-bootmenu[boot to menu]' \
  '-cfgpath+[config path]:dir:_files -/' \
  '-cfg+[config file]:file:_files' \
  '-noaudio[no audio]' \
  '-nohacks[no hacks]' \
  '-gamesettings[force game settings]' \
  '-gs+[GS plugin]:plug:_files -g "*.so *.dll"' \
  '-spu2+[SPU2 plugin]:plug:_files' \
  '-pad+[PAD plugin]:plug:_files' \
  '-cdvd+[CDVD plugin]:plug:_files' \
  '-usb+[USB plugin]:plug:_files' \
  '-fw+[FW plugin]:plug:_files' \
  '-dev9+[DEV9 plugin]:plug:_files' \
  '-debugger[start debugger]' \
  '-disable-fastboot[disable fastboot]' \
  '-fastboot[force fastboot]' \
  '*: :_files -g "*.iso *.bin *.cue *.mdf *.mds *.gz *.cso *.dump *.zip *.elf"' && ret=0

return ret
