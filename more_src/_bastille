#compdef bastille

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'bootstrap:bootstrap a FreeBSD release'
      'clone:clone a jail'
      'cmd:execute a command in jail(s)'
      'config:view and edit jail configuration'
      'console:access jail console'
      'convert:convert jail between types'
      'cp:copy files to/from jails'
      'create:create a new jail'
      'destroy:destroy a jail'
      'edit:edit jail configuration files'
      'export:export a jail to archive'
      'help:show help'
      'htop:show htop for jail'
      'import:import a jail from archive'
      'limits:set resource limits for a jail'
      'list:list jails'
      'mount:mount a volume in a jail'
      'pkg:manage packages in a jail'
      'rdr:redirect host port to jail'
      'rename:rename a jail'
      'restart:restart a jail'
      'service:manage services in a jail'
      'setup:configure host for Bastille'
      'start:start a jail'
      'stop:stop a jail'
      'sysrc:manage sysrc in a jail'
      'tags:manage jail tags'
      'template:apply a Bastillefile template'
      'top:show top for jail'
      'umount:unmount a volume from a jail'
      'update:update jail to latest patch level'
      'upgrade:upgrade jail to new release'
      'verify:verify jail integrity'
      'zfs:manage ZFS for a jail'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    local -a jails
    jails=(${(f)"$(bastille list jails 2>/dev/null)"})
    case ${words[1]} in
      (console|start|stop|restart|destroy|rename|export|cmd|cp|pkg|service|sysrc|mount|umount|rdr|limits|top|htop|config|edit|clone|convert|update|upgrade|verify|zfs|tags)
        _arguments '1:jail:($jails ALL)' '*:args:' && ret=0
        ;;
      (create)
        _arguments \
          '1:jail name:' \
          '2:release:' \
          '3:interface:' \
          '4:IP address:' && ret=0
        ;;
      (bootstrap)
        _arguments '1:release:' && ret=0
        ;;
      (import)
        _arguments '1:archive:_files' && ret=0
        ;;
      (template)
        _arguments '1:jail:($jails ALL)' '2:template:' && ret=0
        ;;
    esac
    ;;
esac

return ret
