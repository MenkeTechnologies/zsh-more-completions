#compdef suricatasc
# Documentation: https://man.archlinux.org/search?q=suricatasc
# Reference accessed: 2026-05-16

# suricatasc: socket client to running Suricata IDS (unix-socket commands)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c[command to run]:cmd:' \
  '--command=[command to run]:cmd:' \
  '-v[verbose]' \
  '*:socket file:_files' && ret=0
return ret
