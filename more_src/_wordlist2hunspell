#compdef wordlist2hunspell
# Documentation: https://github.com/hunspell/hunspell/blob/master/src/tools/wordlist2hunspell
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:wordlist file:_files' \
  '2:locale (e.g. en_US, br_FR):' && ret=0

return ret
