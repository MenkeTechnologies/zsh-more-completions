#compdef at batch atq atrm
# _at — OpenBSD at/batch/atq/atrm (queued one-off command execution; -t time_arg/timespec when to run, -q selects queue letter, -l/-f variants list/feed jobs, -c/-r print/remove jobs)
# upstream: https://github.com/openbsd/src (usr.bin/at)
# Flags from usr.bin/at/at.1 on tip.

_at() {
    _arguments \
        '-b[batch mode]' \
        '-c[print job script to stdout]' \
        '-l[list pending jobs]' \
        '-m[mail on completion]' \
        '-r[remove jobs]' \
        '-f+[command file]:file:_files' \
        '-q+[queue letter (a-z A-Z)]:queue:' \
        '-t+[time_arg [[CC]YY]MMDDhhmm[.SS]]:time_arg:' \
        '*:timespec or job:'
}

_at "$@"
