#compdef fastapi

# Zsh completion for FastAPI CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:run a FastAPI app in development mode'
  'run:run a FastAPI app in production mode'
)

_arguments -s -S \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'fastapi command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      dev|run)
        _arguments \
          '--host=[bind host]:host:' \
          '--port=[bind port]:port:' \
          '--reload[enable auto-reload]' \
          '--workers=[number of workers]:workers:' \
          '--root-path=[ASGI root path]:path:' \
          '--app=[application import string]:app:' \
          '--proxy-headers[enable proxy headers]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_files -g "*.py"'
        ;;
    esac
    ;;
esac

return ret
