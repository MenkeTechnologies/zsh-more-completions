#compdef ptar

local -a arguments

arguments=(
    '-c[create archive]'
    '-x[extract archive]'
    '-t[list archive contents]'
    '-f[archive file]:archive file:_files -g "*.tar*"'
    '-z[filter through gzip]'
    '-j[filter through bzip2]'
    '-v[verbose output]'
    '-C[change directory]:directory:_directories'
    '-I[use compression program]:program:_command_names -e'
    '-h[follow symlinks]'
    '*:file:_files'
)

_arguments -s -S $arguments
