#compdef ptar
# Documentation: https://perldoc.perl.org/ptar
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (man ptar local).

local -a arguments

arguments=(
    '-c[create ARCHIVE_FILE from FILEs]'
    '-x[extract from ARCHIVE_FILE]'
    '-t[list contents of ARCHIVE_FILE]'
    '-f+[name of archive file]:archive file:_files -g "*.tar*"'
    '-z[read/write zlib compressed archive]'
    '-v[print filenames as added or extracted]'
    '-C[CPAN mode - drop 022 from permissions]'
    '-T+[get names to create from file]:file:_files'
    '-h[print help message]'
    '*:file:_files'
)

_arguments -s -S $arguments
