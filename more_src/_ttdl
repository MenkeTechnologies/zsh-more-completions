#compdef ttdl
# Documentation: https://github.com/VladimirMarkelov/ttdl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# https://github.com/VladimirMarkelov/ttdl — getopts (src/conf.rs parse_args)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage]' \
  '--version[print version]' \
  '1:command:(list l ls add a new done d complete close u undone open c clean arc archive e edit rm remove app append prep start stop stats postpone lp listproj listprojects lc listcon listcontexts lh listhash listhashtags ag agenda)' \
  '(-a --all)'{-a,--all}'[include completed todos]' \
  '(-A --only-completed)'{-A,--only-completed}'[only completed todos]' \
  '(-t --active)'{-t,--active}'[only active todos]' \
  '--dry-run[show planned mutations only]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-e --regex)'{-e,--regex}'[treat filter as regex]' \
  '--wipe[clean deletes instead of archiving]' \
  '(-s --sort)'{-s,--sort}'=-[comma field sort order]:fields:' \
  '--sort-rev[reverse sort]' \
  '--group=-[group by field]:field:' \
  '--rec=-[recurrence filter any|none]:type:' \
  '--due=-[due date filter]:expr:' \
  '--created=-[created filter]:expr:' \
  '--completed=-[completion date filter]:expr:' \
  '--threshold=-[threshold filter]:expr:' \
  '--project=-[project filter]:list:' \
  '--context=-[context filter]:list:' \
  '--tag=-[tag filter]:list:' \
  '--pri=-[priority filter]:expr:' \
  '--hashtag=-[hashtag filter]:list:' \
  '--set-pri=-[mutate priority]:val:' \
  '--set-rec=-[mutate recurrence]:val:' \
  '--set-due=-[mutate due date]:val:' \
  '--set-time=-[mutate time tag]:val:' \
  '--set-threshold=-[mutate threshold]:val:' \
  '--set-proj=-[add projects]:list:' \
  '--set-ctx=-[add contexts]:list:' \
  '--set-tag=-[add structured tags]:list:' \
  '--set-hashtag=-[add hashtags]:list:' \
  '--del-proj=-[remove project]:proj:' \
  '--del-ctx=-[remove context]:ctx:' \
  '--del-tag=-[remove tag]:tag:' \
  '--del-hashtag=-[remove hashtag]:tag:' \
  '--repl-proj=-[replace projects]:map:' \
  '--repl-ctx=-[replace contexts]:map:' \
  '--repl-hashtag=-[replace hashtags]:map:' \
  '--short[condensed rows]' \
  '--wrap[wrap subject column]' \
  '(-w --width)'{-w,--width}'=-[force output width]:cols:' \
  '--human=-[relative dates for fields]:fields:' \
  '--compact[compact human dates]' \
  '--fields=-[visible columns]:fields:' \
  '--local[use cwd todo.txt]' \
  '--no-colors[disable color]' \
  '--done[operate on done.txt only]' \
  '(-c --config)'{-c,--config}'=-[config file]:file:_files' \
  '--todo-file=-[todo.txt path]:file:_files' \
  '--done-file=-[done.txt path]:file:_files' \
  '--strict[strict parsing]' \
  '--hidden[include hidden tasks]' \
  '--calendar=-[calendar highlight window]:range:' \
  '--syntax[keyword highlight subjects]' \
  '--no-syntax[disable highlights]' \
  '--markdown[parse Markdown in subjects]' \
  '--no-markdown[disable Markdown]' \
  '--keep-empty[archive without dropping empties]' \
  '--clean-subject=-[strip from subject column]:mode:' \
  '--auto-hide-cols[hide empty columns]' \
  '--auto-show-cols[show columns with any value]' \
  '--always-hide-cols=-[never show columns]:fields:' \
  '--priority-on-done=-[priority handling when done]:mode:' \
  '--add-completion-date-always[always record completion date]' \
  '(-k --keep-tags)'{-k,--keep-tags}'[edit mode keep tags when replacing text]' \
  '(-i --interactive)'{-i,--interactive}'[bulk edit via $EDITOR]' \
  '--init[write default config in XDG dir]' \
  '--init-local[write default ./.config]' \
  '--stdin[read todo text from stdin]' \
  '(-H --no-headers)'{-H,--no-headers}'[omit headers/footers]' \
  '--max=-[limit listed todos]:n:' \
  '(-f --filter)'{-f,--filter}'=-[custom tag filter expression]:expr:' \
  '--filter-tag=-[deprecated alias of --filter]:expr:' \
  '--update-threshold[postpone updates threshold too]' \
  '--hide-fields=-[hide columns + subject bits]:fields:' \
  '--date-format=-[date rendering]:format:' \
  '--on=-[agenda anchor date]:date:' \
  '--time=-[agenda time span]:span:' \
  '--slot=-[agenda minutes per slot]:min:' \
  '--hide-all-day[hide all-day agenda bucket]' \
  '--no-hide-all-day[force all-day bucket]' \
  '(-r --resolution)'{-r,--resolution}'=-[done note / resolution text]:text:' \
  '--src=-[multi-list source name]:name:' \
  '--list-sources[print configured lists]' \
  '*:free text / ids / filters:_default'
