#compdef rfifind
# Documentation: https://github.com/scottransom/presto/blob/master/docs/rfifind.1
# PRESTO: examine radio data for narrow- and wide-band RFI and produce a mask.

local ret=1

_arguments -s -S \
  '-ncpus=[number of OpenMP processors]:n:' \
  '-o+[root of output file names]:root:' \
  '-filterbank[raw data in SIGPROC filterbank format]' \
  '-psrfits[raw data in PSRFITS format]' \
  '-noweights[do not apply PSRFITS weights]' \
  '-noscales[do not apply PSRFITS scales]' \
  '-nooffsets[do not apply PSRFITS offsets]' \
  '-wapp[raw data in WAPP format]' \
  '-window[window correlator lags with Hamming window]' \
  '-numwapps=[number of WAPPs with contiguous freqs]:n:' \
  '-if=[a specific IF to use]:if:' \
  '-clip=[time-domain sigma for clipping]:sigma:' \
  '-noclip[do not clip the data]' \
  '-invert[flip (invert) the band]' \
  '-zerodm[subtract mean of all channels from each sample]' \
  '-xwin[draw plots to screen as well as PS file]' \
  '-nocompute[just plot and remake the mask]' \
  '-rfixwin[show the RFI instances on screen]' \
  '-rfips[plot the RFI instances in a PS file]' \
  '-time=[seconds to integrate for stats and FFT]:time:' \
  '-blocks=[number of blocks to integrate for stats]:blocks:' \
  '-timesig=[sigma cutoff for rejecting time chunks]:timesig:' \
  '-freqsig=[sigma cutoff for rejecting freq chunks]:freqsig:' \
  '-chanfrac=[fraction bad channels to mask an interval]:chanfrac:' \
  '-intfrac=[fraction bad intervals to mask a channel]:intfrac:' \
  '-zapchan=[channels to explicitly mask]:zapchan:' \
  '-zapints=[intervals to explicitly mask]:zapints:' \
  '-mask=[file containing masking information]:maskfile:_files' \
  '-ignorechan=[channels to ignore]:chans:' \
  '*:input data file:_files' && ret=0

return ret
