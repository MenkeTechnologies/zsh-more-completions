#compdef fluent-bit-cli flb fluentbit-cli
# _fluent-bit-cli — Calyptia Fluent Bit (CNCF) lightweight log shipper CLI (Fluent Org / Calyptia, C); custom argparse
# upstream: https://github.com/fluent/fluent-bit

_fluent-bit-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.(conf|yaml|yml)"' \
        '-c+[config file]:file:_files -g "*.(conf|yaml|yml)"' \
        '--daemon[run as daemon]' \
        '-d[run as daemon]' \
        '--dry-run[dry run]' \
        '-D[dry run]' \
        '--input=+[input plugin]:plugin:' \
        '-i+[input plugin]:plugin:' \
        '--filter=+[filter plugin]:plugin:' \
        '-F+[filter plugin]:plugin:' \
        '--output=+[output plugin]:plugin:' \
        '-o+[output plugin]:plugin:' \
        '--prop=+[set property]:str:' \
        '-p+[set property]:str:' \
        '--match=+[tag match]:str:' \
        '-m+[tag match]:str:' \
        '--tag=+[set tag]:str:' \
        '-t+[set tag]:str:' \
        '--sosreport[generate sosreport]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--coro-stack-size=+[coroutine stack size]:n:' \
        '-s+[coroutine stack size]:n:' \
        '--http[enable HTTP server]' \
        '-H[enable HTTP server]' \
        '--http-port=+[HTTP server port]:port:' \
        '-P+[HTTP server port]:port:' \
        '--workdir=+[working dir]:dir:_files -/' \
        '-w+[working dir]:dir:_files -/' \
        '--plugin=+[external plugin path]:file:_files' \
        '-e+[external plugin path]:file:_files' \
        '--log_file=+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--log-format=+[log format]:fmt:(text json)' \
        '--enable-chunk-trace[enable chunk trace]' \
        '--enable-hot-reload[enable hot reload]' \
        '*:arg:'
}

_fluent-bit-cli "$@"
