#compdef create-redwood-app
# Documentation: https://www.npmjs.com/package/create-redwood-app
# Reference accessed: 2026-05-23
# Verified: npx create-redwood-app --help.

# Zsh completion for create-redwood-app - RedwoodJS project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[skip prompts and use defaults]' \
  '--overwrite[create even if target directory is not empty]' \
  '--typescript[generate a TypeScript project]' \
  '--ts[generate a TypeScript project]' \
  '--git-init[initialize a git repository]' \
  '--git[initialize a git repository]' \
  '-m[initial commit message]:message:' \
  '--commit-message=[initial commit message]:message:' \
  '--telemetry[enable Redwood telemetry]' \
  ':project directory:_directories' && ret=0

return ret
