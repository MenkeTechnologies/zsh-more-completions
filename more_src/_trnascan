#compdef tRNAscan-SE trnascan tRNAscan
# _trnascan — Todd Lowe Patricia Chan tRNAscan-SE detection of tRNA genes in genomic DNA RNA sequences (UCSC team, Perl); getopt
# upstream: https://github.com/UCSC-LoweLab/tRNAscan-SE

_trnascan() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-E[eukaryotic mode]' \
        '--euk[eukaryotic mode]' \
        '-B[bacterial mode]' \
        '--bact[bacterial mode]' \
        '-A[archaeal mode]' \
        '--arch[archaeal mode]' \
        '-M+[mito source]:m:(mammal vert mtDNA mt)' \
        '--mt=+[mito source]:m:(mammal vert mtDNA mt)' \
        '-O[organelle mode]' \
        '--organ[organelle mode]' \
        '-G[general mode]' \
        '--general[general mode]' \
        '-r[no infernal post-filter]' \
        '--noinfernal[no infernal post-filter]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-Q[no overwrite]' \
        '--brief[brief output]' \
        '-y[show progress]' \
        '--progress[show progress]' \
        '-f+[output file]:file:_files' \
        '--struct=+[output structure]:file:_files' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-s+[secondary structure]:file:_files' \
        '--stats=+[stats file]:file:_files' \
        '-b+[BED output]:file:_files -g "*.bed"' \
        '-a+[fasta output]:file:_files -g "*.fa *.fasta"' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-N+[nci_score cutoff]:f:' \
        '-X+[hmm_score cutoff]:f:' \
        '-d[detailed output]' \
        '--detail[detailed output]' \
        '-D+[default config]:file:_files' \
        '-c+[config file]:file:_files -g "*.conf *.cfg *.ini"' \
        '--conf=+[config file]:file:_files -g "*.conf *.cfg *.ini"' \
        '-x[infernal output]' \
        '--infern[infernal output]' \
        '--filtbits[disable BD score filter]' \
        '-H[show hits]' \
        '--hits[show hits]' \
        '-Y[no first pass]' \
        '--nofirst[no first pass]' \
        '-z[no eufindtrnascan]' \
        '--noeufind[no eufindtrnascan]' \
        '-F[no false-positive filter]' \
        '--nofilt[no false-positive filter]' \
        '*:fasta input:_files -g "*.fa *.fasta *.fna *.fa.gz"'
}

_trnascan "$@"
