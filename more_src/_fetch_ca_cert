#compdef fetch_ca_cert
# _fetch_ca_cert — fetch a CA certificate chain for Fulcio bootstrapping (sigstore/fulcio)
# upstream: https://github.com/sigstore/fulcio
# Flags from cmd/fetch_ca_cert/fetch_ca_cert.go (flag).

_fetch_ca_cert() {
    _arguments \
        '-gcp-ca-parent=[resource path to GCP CA Service CA]:path:' \
        '-kms-resource=[KMS key resource path]:path:' \
        '-tink-keyset-path=[Tink keyset file]:file:_files' \
        '-tink-kms-resource=[KMS key for decrypting Tink keyset]:path:' \
        '-output=[output certificate chain file]:file:_files'
}

_fetch_ca_cert "$@"
