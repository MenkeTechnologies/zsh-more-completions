#compdef cjpeg-turbo

# cjpeg-turbo: libjpeg-turbo'\''s JPEG compressor
local curcontext="$curcontext" ret=1
_arguments -C \
  '-arithmetic[use arithmetic coding]' \
  '-baseline[force baseline JPEG]' \
  '-dct[DCT method]:method:(int fast float)' \
  '-grayscale[output grayscale]' \
  '-icc[embed ICC profile from file]:file:_files' \
  '-maxmemory=[max in-memory work buffer (kB)]:n:' \
  '-memdst[write to memory and dump]' \
  '-nosmooth[no fancy pixel smoothing]' \
  '-optimize[optimize Huffman tables]' \
  '-outfile[output file]:file:_files' \
  '-progressive[progressive JPEG]' \
  '-quality=[output quality 0..100]:n:' \
  '-restart[restart marker interval]:n:' \
  '-rgb[force 24-bit RGB output]' \
  '-rgb565[RGB565 output]' \
  '-sample=[sampling factors WxH,...]:HxV:' \
  '-scale[scale]:M/N:' \
  '-smooth=[smoothing factor 1..100]:n:' \
  '-strict[reject corrupt input]' \
  '-targa[input is Targa]' \
  '-version[show version]' \
  '*:input PPM/PGM/Targa/BMP file:_files' && ret=0
return ret
