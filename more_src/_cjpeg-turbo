#compdef cjpeg-turbo cjpeg
# Documentation: https://manpages.debian.org/testing/libjpeg-turbo-progs/cjpeg.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (libjpeg-turbo cjpeg(1)).

# cjpeg-turbo: encode image to JPEG using libjpeg-turbo
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-quality[quality 0..100]:n:' \
  '-q[quality 0..100]:n:' \
  '-grayscale[encode as grayscale]' \
  '-rgb[encode as full RGB (no chroma subsampling)]' \
  '-progressive[progressive JPEG]' \
  '-baseline[baseline-compatible quantization tables]' \
  '-optimize[optimize Huffman tables]' \
  '-arithmetic[arithmetic coding]' \
  '-dct[DCT method]:method:(int fast float)' \
  '-icc[embed ICC profile]:file:_files' \
  '-targa[input is Targa]' \
  '-restart[restart interval]:n:' \
  '-smooth[smoothing factor]:n:' \
  '-maxmemory[max memory in kB]:n:' \
  '-memdst[compress to memory instead of file]' \
  '-outfile[output filename]:file:_files' \
  '-qtables[custom quantization tables]:file:_files' \
  '-qslots[quantization table slots]:slots:' \
  '-sample[sampling factors]:factors:' \
  '-scans[scan script]:file:_files' \
  '-report[show compression progress]' \
  '-strict[treat warnings as fatal]' \
  '-verbose[enable debug output]' \
  '-v[enable debug output]' \
  '-debug[enable debug trace]' \
  '*:input image:_files -g "*.(bmp|tga|targa|ppm|pgm|pbm|gif|png)"' && ret=0
return ret
