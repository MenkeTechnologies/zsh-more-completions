#compdef cloud-api-adaptor
# _cloud-api-adaptor — Confidential Containers cloud-api-adaptor daemon (proxies Kata sandbox creation to a cloud provider so the PodVM runs in the cloud)
# upstream: https://github.com/confidential-containers/cloud-api-adaptor
# Top-level usage from src/cloud-api-adaptor/cmd/cloud-api-adaptor/main.go on tip; the FIRST positional is the cloud-provider name and selects the per-provider flag set.

_cloud-api-adaptor() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                aws:'use the AWS provider (Nitro EC2)'
                azure:'use the Azure provider (CVM)'
                gcp:'use the GCP provider (Confidential VM)'
                alibabacloud:'use the Alibaba Cloud provider'
                ibmcloud:'use the IBM Cloud VPC provider'
                'ibmcloud-powervs':'use the IBM Cloud PowerVS provider'
                libvirt:'use the local libvirt provider'
                byom:'bring-your-own-machine provider'
                help:'show usage'
                version:'show version'
            )
            _describe -t commands 'cloud-api-adaptor provider' subs
            ;;
        args)
            case $line[1] in
                aws|azure|gcp|alibabacloud|ibmcloud|ibmcloud-powervs|libvirt|byom)
                    _arguments \
                        '-socket=[KAA UNIX socket path]:socket:_files' \
                        '-disable-tls[disable TLS (testing only)]' \
                        '-ca-cert-file=[CA cert file]:file:_files' \
                        '-cert-file=[server TLS cert]:file:_files' \
                        '-cert-key=[server TLS key]:file:_files' \
                        '-pods-dir=[directory for pod state]:dir:_files -/' \
                        '-pod-namespace=[network namespace where pods run]:ns:' \
                        '-podvm-image=[image to use for the PodVM]:image:' \
                        '-cri-runtime-endpoint=[CRI runtime endpoint]:uri:' \
                        '-help[show provider-specific options]'
                    ;;
            esac
            ;;
    esac
}

_cloud-api-adaptor "$@"
