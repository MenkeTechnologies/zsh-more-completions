#compdef taskset-cli
# _taskset-cli — util-linux taskset set or retrieve a process' CPU affinity CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_taskset-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[set on all threads]' \
        '--all-tasks[set on all threads]' \
        '-c[CPU list format]' \
        '--cpu-list[CPU list format]' \
        '-p+[operate on pid]:pid:_pids' \
        '--pid=+[operate on pid]:pid:_pids' \
        '*:mask command:_command_names'
}

_taskset-cli "$@"
