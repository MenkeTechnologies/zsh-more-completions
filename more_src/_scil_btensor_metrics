#compdef scil_btensor_metrics
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_btensor_metrics.html
# Scilpy: compute b-tensor encoding metrics (microFA, MK, etc.)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--in_dwis=[input DWI volumes]:files:_files' \
  '--in_bvals=[input b-value files]:files:_files' \
  '--in_bvecs=[input b-vector files]:files:_files' \
  '--in_bdeltas=[b-tensor shape deltas]:deltas:(0 1 -0.5 0.5)' \
  '--mask=[binary mask]:mask:_files' \
  '--tolerance=[tolerated gap between b-values]:tol' \
  '--fit_iters=[number of fit iterations]:iters' \
  '--random_iters=[number of random initializations]:iters' \
  '--processes=[number of sub-processes]:nbr' \
  '--op=[orientation parameter output]:file:_files' \
  '--fa=[FA output]:file:_files' \
  '--md=[MD output]:file:_files' \
  '--ufa=[micro-FA output]:file:_files' \
  '--mk_i=[isotropic mean kurtosis output]:file:_files' \
  '--mk_a=[anisotropic mean kurtosis output]:file:_files' \
  '--mk_t=[total mean kurtosis output]:file:_files' \
  '--skip_b0_check[skip b0 existence validation]' \
  '--do_weight_bvals[weight by b-values]' \
  '--do_weight_pa[weight by powder average]' \
  '--do_multiple_s0[fit multiple s0]' \
  '--not_all[only saved metrics are computed]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' && ret=0

return ret
