#compdef subnet-cli
# Documentation: https://github.com/ava-labs/subnet-cli
# subnet-cli - Avalanche subnet creation and management CLI

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'create:create VMIDs, keys, subnets, and blockchains'
  'add:add validators to networks and subnets'
  'wizard:automated end-to-end subnet creation workflow'
  'status:check blockchain status and information'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--private-key-path=[private key file location]:file:_files' \
  '--public-uri=[network endpoint to connect to]:url:' \
  '--enable-prompt[toggle interactive prompt mode]' \
  '--node-ids=[node identifiers for validator operations]:ids:' \
  '--subnet-id=[target subnet id]:id:' \
  '--vm-id=[virtual machine identifier]:id:' \
  '--ledger[use a hardware (ledger) wallet]' \
  '--log-level=[log verbosity level]:level:(debug info warn error)' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'subnet-cli command' sub && ret=0 ;;
  args)
    case $words[1] in
      create) _arguments '1:create cmd:(VMID key subnet blockchain)' && ret=0 ;;
      add) _arguments '1:add cmd:(validator subnet-validator)' && ret=0 ;;
    esac
    ;;
esac

return ret
