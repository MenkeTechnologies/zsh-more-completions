#compdef vtclient
# _vtclient — Vitess simple query client (DML/DDL load gen + ad-hoc queries)
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtclient/cli/vtclient.go on tip.

_vtclient() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--server=[VTGate server host\:port]:host\:port:' \
        '--timeout=[per-query timeout]:dur:' \
        '--streaming=[use streaming query]:bool:(true false)' \
        '--target=[keyspace\:shard@tablet_type]:target:' \
        '--json=[emit JSON output]:bool:(true false)' \
        '--parallel=[DMLs only: threads per query]:n:' \
        '--count=[DMLs only: queries per thread]:n:' \
        '--min-sequence-id=[min sequence ID for bind variables]:n:' \
        '--max-sequence-id=[max sequence ID for bind variables]:n:' \
        '--use-random-sequence=[use random IDs instead of sequential]:bool:(true false)' \
        '--qps=[per-thread queries-per-second throttle]:n:' \
        '-v[verbosity level]:n:' \
        '*: :_files'
}

_vtclient "$@"
