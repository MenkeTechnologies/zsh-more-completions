#compdef 3dKruskalWallis
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dKruskalWallis.html
# AFNI: nonparametric Kruskal-Wallis test for several independent samples

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-levels[number of treatments]:num:' \
  '*-dset[treatment level and filename]:level filename:_files' \
  '-workmem[megabytes of RAM to use]:mega:' \
  '-voxel[print results for given voxel]:num:' \
  '-out[output prefix name]:prefix:_files' \
  '*:dataset:_files' && ret=0

return ret
