#compdef imaptest
# Documentation: https://man.archlinux.org/search?q=imaptest
# Reference accessed: 2026-05-16

# imaptest: Dovecot's IMAP server benchmarking and conformance tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:imaptest key=value:_files' && ret=0
return ret
