#compdef imaptest
# Documentation: https://dovecot.github.io/imaptest/configuration.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Dovecot's IMAP server benchmarking and conformance tool. Uses key=value arguments.

local -a _imaptest_keys
_imaptest_keys=(
  'host=' 'hostip=' 'port=' 'user=' 'user2=' 'userfile=' 'pass=' 'mech='
  'mbox=' 'box=' 'copybox=' 'clients=' 'msgs=' 'secs=' 'seed='
  'random=' 'random_msg_size=' 'no_pipelining=' 'no_tracking='
  'qresync=' 'imap4rev2=' 'ssl=' 'ssl_ca_file=' 'master='
  'disconnect_quit=' 'error_quit=' 'stalled_disconnect_timeout='
  'rawlog=' 'output=' 'domains=' 'users='
  'checkpoint=' 'own_flags=' 'own_msgs=' 'profile=' 'test='
)

_arguments -s -S \
  '*: :{_values "imaptest key=value" $_imaptest_keys}'
