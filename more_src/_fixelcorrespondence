#compdef fixelcorrespondence
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixelcorrespondence.html
# Source: MRtrix3/mrtrix3 cmd/fixelcorrespondence.cpp — match subject fixel data into template fixel directory (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-angle+[max inter-subject fixel correspondence angle (degrees, default 45)]:value:_default' \
    '1:subject_data (fixel data file):_files' \
    '2:template_directory:_files -/' \
    '3:output_directory:_files -/' \
    '4:output_data (filename in output dir):_default' \
    && ret=0

return ret
