#compdef amcheckdump
# _amcheckdump — Zmanda Amanda amcheckdump CLI for verifying integrity of Amanda backup dump files reading the raw dump stream from tape or holding-disk validating dump headers checksums chunked-format compressed encryption (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amcheckdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-t+[timestamp]:str:' \
        '--timestamp=+[timestamp]:str:' \
        '-l[just list dumps]' \
        '--list[just list dumps]' \
        '-o+[option]:str:' \
        '--no-restore[no restore]' \
        '--no-summary[no summary]' \
        '-D+[device]:file:_files' \
        '--device=+[device]:file:_files' \
        '*:config:'
}

_amcheckdump "$@"
