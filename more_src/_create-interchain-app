#compdef create-interchain-app
# Documentation: https://github.com/hyperweb-io/create-interchain-app#readme
# Reference accessed: 2026-05-24
# Verified: npm view create-interchain-app bin; Options table in GitHub README at the URL above.

# Zsh completion for create-interchain-app - Interchain (Cosmos) app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--repo=[custom repository for cia templates]:repo:' \
  '--install[automatically install dependencies]' \
  '--no-install[do not install dependencies]' \
  '--printCmd[print the command to run after setup]' \
  '--no-printCmd[do not print post-setup command]' \
  '(-n --name)'{-n,--name=}'[project name]:name:' \
  '(-e --example)'{-e,--example=}'[example name]:example:' \
  '(-t --template)'{-t,--template=}'[template to use]:template:' \
  '(-b --fromBranch)'{-b,--fromBranch=}'[branch to clone templates from]:branch:' \
  ':project directory:_directories' && ret=0

return ret
