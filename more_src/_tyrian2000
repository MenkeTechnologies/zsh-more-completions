#compdef tyrian2000 opentyrian
# Documentation: https://github.com/opentyrian/opentyrian
# Reference accessed: 2026-05-16

# Tyrian2000 / OpenTyrian: scrolling shoot-em-up port
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--data=[data dir]:dir:_files -/' \
  '--fullscreen[fullscreen]' \
  '--window[windowed]' \
  '--scaler=[scaler]:scaler:(2x 3x 4x crt hq2x hq3x hq4x scale2x scale3x scale4x)' \
  '--sound=[sound system]:sys:(sdl alsa pulse oss none)' \
  '--no-sound[disable sound]' \
  '--no-music[disable music]' \
  '*::tyrian2000 args:_files' && ret=0
return ret
