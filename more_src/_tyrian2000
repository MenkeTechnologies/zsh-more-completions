#compdef tyrian2000 opentyrian
# Documentation: https://github.com/opentyrian/opentyrian/blob/master/src/params.c
# Reference accessed: 2026-05-21
# Verified: upstream src/params.c Options[] table.
# Removed from prior file: --fullscreen, --window, --scaler=, --sound= (none of
# these are in the Options[] table), --no-music (real flag is --no-sound which
# disables all audio).

# Tyrian2000 / OpenTyrian: scrolling shoot-em-up port
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-s --no-sound)'{-s,--no-sound}'[disable audio]' \
  '(-j --no-joystick)'{-j,--no-joystick}'[disable joystick/gamepad input]' \
  '(-x --no-xmas)'{-x,--no-xmas}'[disable Christmas mode]' \
  '(-X --xmas)'{-X,--xmas}'[force Christmas mode]' \
  '(-t --data)'{-t,--data=}'[Tyrian data directory]:dir:_files -/' \
  '(-n --net)'{-n,--net=}'[start a networked game (HOST\:PORT)]:host\:port:' \
  '--net-player-name=[local player name]:name:' \
  '--net-player-number=[local player number (1 or 2)]:n:(1 2)' \
  '(-p --net-port)'{-p,--net-port=}'[local port to bind (default 1333)]:port:' \
  '(-d --net-delay)'{-d,--net-delay=}'[network delay]:n:' \
  '(-c --constant)'{-c,--constant}'[constant play]' \
  '(-k --death)'{-k,--death}'[constant death]' \
  '(-r --record)'{-r,--record}'[record demo]' \
  '(-l --loot)'{-l,--loot}'[loot cheat]' && ret=0
return ret
