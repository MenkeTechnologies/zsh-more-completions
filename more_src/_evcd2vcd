#compdef evcd2vcd
# Convert Extended VCD (EVCD) dumpfiles to VCD

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help screen]' \
  '(-f --filename)'{-f+,--filename=}'[specify EVCD input filename]:file:_files -g "*.(evcd|vcd)"' \
  '*:EVCD file:_files -g "*.(evcd|vcd)"' && ret=0

return ret
