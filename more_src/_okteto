#compdef okteto

# Zsh completion for Okteto CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'up:activate a development container'
      'down:deactivate a development container'
      'build:build images'
      'deploy:deploy an environment'
      'destroy:destroy an environment'
      'context:manage contexts'
      'namespace:manage namespaces'
      'pipeline:manage pipelines'
      'preview:manage preview environments'
      'stack:manage stacks'
      'exec:execute a command in the development container'
      'logs:show development container logs'
      'status:show development container status'
      'restart:restart development container pods'
      'init:create an okteto manifest'
      'doctor:generate a doctor file for troubleshooting'
      'analytics:manage analytics settings'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'okteto command' commands && ret=0
    ;;
  args)
    case $line[1] in
      up)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '--build[build images before activation]' \
          '--reset[reset the development container]' \
          && ret=0
        ;;
      down)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '-v[remove persistent volumes]' \
          && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '-t+[image tag]:tag' \
          '--no-cache[do not use cache]' \
          '*:path:_files' \
          && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '--name=[environment name]:name' \
          '--wait[wait for deployment to complete]' \
          '--build[build images before deploying]' \
          '--no-bash[disable bash commands in deploy section]' \
          && ret=0
        ;;
      destroy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '--name=[environment name]:name' \
          '--volumes[destroy volumes]' \
          && ret=0
        ;;
      context)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->ctx_cmds' && ret=0
        case $state in
          ctx_cmds)
            local -a ctx_commands=(
              'use:set the current context'
              'list:list available contexts'
              'delete:delete a context'
              'show:show the current context'
            )
            _describe -t commands 'context subcommand' ctx_commands && ret=0
            ;;
        esac
        ;;
      namespace)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->ns_cmds' && ret=0
        case $state in
          ns_cmds)
            local -a ns_commands=(
              'create:create a namespace'
              'delete:delete a namespace'
              'list:list namespaces'
              'use:set current namespace'
            )
            _describe -t commands 'namespace subcommand' ns_commands && ret=0
            ;;
        esac
        ;;
      pipeline)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->pipe_cmds' && ret=0
        case $state in
          pipe_cmds)
            local -a pipe_commands=(
              'deploy:deploy a pipeline'
              'destroy:destroy a pipeline'
            )
            _describe -t commands 'pipeline subcommand' pipe_commands && ret=0
            ;;
        esac
        ;;
      preview)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->prev_cmds' && ret=0
        case $state in
          prev_cmds)
            local -a prev_commands=(
              'deploy:deploy a preview environment'
              'destroy:destroy a preview environment'
              'list:list preview environments'
              'endpoints:show preview environment endpoints'
            )
            _describe -t commands 'preview subcommand' prev_commands && ret=0
            ;;
        esac
        ;;
      stack)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->stack_cmds' && ret=0
        case $state in
          stack_cmds)
            local -a stack_commands=(
              'deploy:deploy a stack'
              'destroy:destroy a stack'
            )
            _describe -t commands 'stack subcommand' stack_commands && ret=0
            ;;
        esac
        ;;
      exec)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '*:command' \
          && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f+[manifest file]:file:_files' \
          '--all[show logs from all containers]' \
          '--since=[show logs since duration]:duration' \
          '--tail=[number of lines]:lines' \
          && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--overwrite[overwrite existing manifest]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
