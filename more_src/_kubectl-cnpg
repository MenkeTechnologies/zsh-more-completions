#compdef kubectl-cnpg cnpg

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:generate YAML manifest for operator install'
  'status:cluster health/replication overview'
  'promote:elevate a pod to primary role'
  'certificate:generate TLS certs signed by cluster CA'
  'restart:rollout restart cluster or instance'
  'reload:trigger reconciliation'
  'maintenance:modify maintenance window settings'
  'report:bundle troubleshooting ZIPs'
  'logs:aggregate pod logs'
  'destroy:remove instance and PVCs'
  'hibernate:suspend cluster'
  'pgbench:run pgbench against a cluster'
  'fio:storage benchmark on a storage class'
  'backup:request a physical backup'
  'psql:interactive psql to a cluster'
  'pgadmin4:deploy pgAdmin (demo)'
  'publication:manage logical replication publications'
  'subscription:manage logical replication subscriptions'
  'version:plugin version'
)

_arguments -C \
  '--color=[colorize output]:when:(always never auto)' \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kubectl-cnpg subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (status)
        _arguments \
          '*'{-v,--verbose}'[increase verbosity]' \
          '--timeout=[timeout]:duration:' \
          '(-o --output)'{-o,--output=}'[output format]:format:(yaml json)' \
          '--color=[color]:when:(always never auto)' && ret=0
        ;;
      (certificate)
        _arguments \
          '--cnpg-cluster=[cluster]:cluster:' \
          '--cnpg-user=[user]:user:' && ret=0
        ;;
      (maintenance)
        _values 'maintenance action' 'set' 'unset' && ret=0
        ;;
      (report)
        _values 'report action' 'operator' 'cluster' && ret=0
        ;;
      (logs)
        _values 'logs action' 'cluster' 'pretty' && ret=0
        ;;
      (destroy)
        _arguments '--keep-pvc[keep PVCs]' && ret=0
        ;;
      (hibernate)
        _values 'hibernate action' 'on' 'off' && ret=0
        ;;
      (backup)
        _arguments \
          '-m=[backup method]:method:(volumeSnapshot barmanObjectStore)' \
          '--backup-target=[target]:target:' \
          '--online[online backup]' \
          '--immediate-checkpoint[immediate checkpoint]' \
          '--wait-for-archive[wait for archive]' && ret=0
        ;;
      (psql)
        _arguments '--replica[connect to replica]' && ret=0
        ;;
      (pgadmin4)
        _arguments \
          '--mode=[mode]:mode:(desktop server)' \
          '--dry-run[dry run]' && ret=0
        ;;
      (publication)
        _values 'publication action' 'create' 'drop' && ret=0
        ;;
      (subscription)
        _values 'subscription action' 'create' 'drop' 'sync-sequences' && ret=0
        ;;
    esac
    ;;
esac

return ret
