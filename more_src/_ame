#compdef ame
# Documentation: https://meme-suite.org/meme/doc/ame.html
# MEME Suite: analysis of motif enrichment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default ame_out), fail if exists]:dir:_files -/' \
  '--oc[output directory (default ame_out), overwrite if exists]:dir:_files -/' \
  '--text[output tab-delimited text to stdout, no other files]' \
  '--control[control sequences (FASTA file or --shuffle--)]:file:_files' \
  '--kmer[preserve k-mer frequencies when shuffling]:k:' \
  '--seed[random number seed for shuffling]:s:' \
  '--method[enrichment test method]:method:(fisher ranksum pearson spearman 3dmhg 4dmhg)' \
  '--scoring[sequence scoring method]:scoring:(avg max sum totalhits)' \
  '--hit-lo-fraction[fraction of maximum log-odds for a hit]:fraction:' \
  '--evalue-report-threshold[E-value reporting threshold]:evalue:' \
  '--fasta-threshold[FASTA score classification threshold]:score:' \
  '--fix-partition[evaluate a single partition of N sequences]:N:' \
  '--poslist[axis used for partition maximization]:poslist:(pwm fasta)' \
  '--log-fscores[convert FASTA scores to log-space]' \
  '--log-pwmscores[convert PWM scores to log-space]' \
  '--linreg-switchxy[swap X and Y axes for correlation methods]' \
  '--noseq[do not output the sequences.tsv file]' \
  '--verbose[verbosity level]:level:(1 2 3 4 5)' \
  '*:sequence/motif file:_files' && ret=0

return ret
