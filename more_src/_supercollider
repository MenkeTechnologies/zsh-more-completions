#compdef supercollider scide scserver
# Documentation: https://man.archlinux.org/search?q=supercollider
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:scd_file:_files -g "*.{sc,scd}"' && ret=0

return ret
