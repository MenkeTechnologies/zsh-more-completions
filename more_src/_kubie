#compdef kubie

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ctx:switch context'
      'ns:switch namespace'
      'exec:execute command in context/namespace'
      'info:print current context/namespace info'
      'lint:lint kubeconfig files'
      'update:update kubie'
      'delete:delete context'
      'edit:edit kubeconfig'
      'export:export kubeconfig'
      'help:help about any command'
    )
    _describe -t commands 'kubie command' commands && ret=0
    ;;
  args)
    case $words[1] in
      ctx)
        _arguments -s -S \
          {-n,--namespace}'=[namespace]:namespace' \
          {-r,--recursive}'[apply recursively]' \
          '1:context' \
          && ret=0
        ;;
      ns)
        _arguments -s -S \
          '1:namespace' \
          && ret=0
        ;;
      exec)
        _arguments -s -S \
          '1:context' \
          '2:namespace' \
          '*:command' \
          && ret=0
        ;;
      info)
        _arguments -s -S \
          '1:info type:(ctx ns)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
