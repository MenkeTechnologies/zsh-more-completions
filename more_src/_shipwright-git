#compdef shipwright-git
# _shipwright-git — Shipwright Build helper that clones a Git repository into the workspace
# upstream: https://github.com/shipwright-io/build
# Flags from cmd/git/main.go on tip.

_shipwright-git() {
    _arguments \
        '--help[print the help]' \
        '--url=[URL of the Git repository]:url:_urls' \
        '--revision=[revision to clone (default: default branch)]:rev:' \
        '--target=[target directory of the clone operation]:dir:_files -/' \
        '--result-file-commit-sha=[file to write the commit sha to]:file:_files' \
        '--result-file-commit-author=[file to write the commit author to]:file:_files' \
        '--result-file-source-timestamp=[file to write the source timestamp to]:file:_files' \
        '--result-file-branch-name=[file to write the branch name to]:file:_files' \
        '--secret-path=[directory containing basic-auth or SSH key + known hosts]:dir:_files -/' \
        '--result-file-error-message=[file to write the error message to]:file:_files' \
        '--result-file-error-reason=[file to write the error reason to]:file:_files' \
        '--depth=[shallow-clone depth]:n:' \
        '--skip-validation[skip pre-requisite validation]' \
        '--git-url-rewrite[apply git config url.insteadOf rewrites]' \
        '--verbose[verbose logging]' \
        '--show-listing[print file listing of files cloned]'
}

_shipwright-git "$@"
