#compdef suminphase
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/suminphase.c
# convert input to minimum phase

local ret=1

_arguments -s -S \
  'sign1=[sign1]:sign1:' \
  'sign2=[sign2]:sign2:' \
  'pnoise=[pnoise]:pnoise:' \
  'verbose=[verbose]:verbose:' \
  'mode=[mode]:mode:' \
  'key=[key]:key:' \
  'op=[op]:op:' \
  '*:file:_files' && ret=0

return ret
