#compdef claude-trace
# Documentation: https://github.com/badlogic/lemmy/tree/main/apps/claude-trace
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--generate-html[generate HTML report from JSONL]' \
  '--index[generate conversation index]' \
  '--run-with=[wrap a different binary]:cmd:_command_names' \
  '--model=[select specific Claude model]:model' \
  '--include-all-requests[include non-Claude API requests]' \
  '--extract-token[extract OAuth token]' \
  '--no-open[do not auto-open HTML report]' \
  '*:input_or_passthrough:_files' && ret=0

return ret
