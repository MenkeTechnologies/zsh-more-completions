#compdef chef

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'exec:run commands in context of embedded Ruby'
      'env:print environment variables used by Chef Workstation'
      'gem:run the embedded gem command'
      'generate:generate a new repository, cookbook, recipe, etc.'
      'shell-init:initialize shell for Chef Workstation'
      'install:install cookbooks from a Policyfile'
      'update:update cookbooks in a Policyfile'
      'push:push a policy to a Chef Infra Server'
      'push-archive:push a policy archive to a Chef Infra Server'
      'show-policy:show policyfile revisions on server'
      'diff:show diff between local policy and server'
      'export:export a policy lock as an archive'
      'clean-policy-cookbooks:delete unused policyfile cookbooks'
      'clean-policy-revisions:delete unused policy revisions'
      'delete-policy-group:delete a policy group'
      'delete-policy:delete all revisions of a policy'
      'undelete:undo delete operations'
      'describe-cookbook:show cookbook information'
      'report:view Chef Infra Client run reports'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (generate)
        local -a gen_commands=(
          'repo:generate a Chef Infra repository'
          'cookbook:generate a cookbook'
          'recipe:generate a recipe'
          'attribute:generate an attribute file'
          'template:generate a template'
          'file:generate a cookbook file'
          'resource:generate a custom resource'
          'helpers:generate a helpers module'
          'generator:generate a custom generator cookbook'
        )
        _describe -t commands 'generator' gen_commands && ret=0
        ;;
      (exec)
        _arguments '*:command:_command_names' && ret=0
        ;;
      (gem)
        _arguments '*:gem command:' && ret=0
        ;;
      (shell-init)
        _values 'shell' bash zsh fish powershell
        ;;
      (install|update)
        _arguments \
          '--chef-license+[accept license]:action:(accept accept-no-persist accept-silent)' \
          '*:Policyfile:_files -g "*.rb(-.)"' && ret=0
        ;;
      (push)
        _arguments \
          '1:policy group:' \
          '2:Policyfile:_files -g "*.lock.json(-.)"' && ret=0
        ;;
      (export)
        _arguments \
          '1:Policyfile:_files -g "*.lock.json(-.)"' \
          '2:destination:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
