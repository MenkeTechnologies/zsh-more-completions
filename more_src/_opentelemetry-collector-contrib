#compdef opentelemetry-collector-contrib
# Documentation: https://man.archlinux.org/search?q=opentelemetry-collector-contrib
# Reference accessed: 2026-05-16

# opentelemetry-collector-contrib: OpenTelemetry Collector
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file/URI]:file:_files' \
  '--feature-gates=[feature gates]:gates:' \
  '--set=[override config key=value]:kv:' \
  '*::opentelemetry-collector-contrib args:_files' && ret=0
return ret
