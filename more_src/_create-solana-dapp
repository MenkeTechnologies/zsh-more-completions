#compdef create-solana-dapp
# Documentation: https://github.com/solana-foundation/create-solana-dapp
# Reference accessed: 2026-05-24
# Verified: npm view create-solana-dapp bin; src/utils/get-args.ts at the URL above.

# Zsh completion for create-solana-dapp - Solana dApp template scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[output the version number]' \
  '(-h --help)'{-h,--help}'[display help for command]' \
  '--pm=[package manager]:manager:(npm pnpm yarn bun)' \
  '--package-manager=[package manager]:manager:(npm pnpm yarn bun)' \
  '--yarn[use yarn as the package manager]' \
  '--pnpm[use pnpm as the package manager]' \
  '--bun[use bun as the package manager]' \
  '(-d --dry-run)'{-d,--dry-run}'[dry run without writing files]' \
  '(-t --template)'{-t,--template=}'[template name or github-org/github-repo]:template:' \
  '--list-template-ids[list available template ids as JSON]' \
  '--list-templates[list available templates]' \
  '--list-versions[list Anchor/AVM/Rust/Solana versions]' \
  '--minimal[select the minimal nextjs-anchor template]' \
  '--skip-git[skip git initialization]' \
  '--skip-init[skip running the template init script]' \
  '--skip-install[skip installing dependencies]' \
  '--skip-version-check[skip checking for CLI updates]' \
  '--templates-url=[url to templates.json]:url:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  ':project name:' && ret=0

return ret
