#compdef bandit2
# _bandit2 — PyCQA bandit bandit2 CLI command-line frontend wrapping the Bandit tool designed to find common security issues in Python code open-source written in Python processes each file builds an AST and runs appropriate plugins against the AST nodes once Bandit has finished scanning all the files it generates a report SAST-tool-for-Python pluggable-tests-blacklisted-imports-blacklisted-calls-shell-injection-SQL-injection-Crypto-key-XML-Use-of-MD5-MD4-DES-RC4-Weak-Cipher-Hardcoded-Password-SSL Try Except Pass-statements (PyCQA team, Python); argparse
# upstream: https://github.com/PyCQA/bandit

_bandit2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-a+[aggregate by]:a:(file vuln)' \
        '--aggregate=+[a]:a:(file vuln)' \
        '-n+[context lines]:n:' \
        '--number=+[N]:n:' \
        '-c+[config file]:file:_files -g "bandit.yml *.yml *.yaml"' \
        '--configfile=+[file]:file:_files -g "bandit.yml *.yml *.yaml"' \
        '-p+[profile]:str:' \
        '--profile=+[name]:str:' \
        '-t+[tests to run]:str:' \
        '--tests=+[ids]:str:' \
        '-s+[tests to skip]:str:' \
        '--skip=+[ids]:str:' \
        '-l[low severity]' \
        '--level=+[l]:l:(low medium high)' \
        '-i[low confidence]' \
        '--confidence=+[c]:c:(low medium high)' \
        '-f+[format]:f:(csv custom html json screen txt xml yaml)' \
        '--format=+[fmt]:f:(csv custom html json screen txt xml yaml)' \
        '--msg-template=+[tmpl]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--severity-level=+[l]:l:(low medium high all)' \
        '--confidence-level=+[l]:l:(low medium high all)' \
        '-x+[exclude paths]:str:' \
        '--exclude=+[paths]:str:' \
        '-b+[baseline file]:file:_files' \
        '--baseline=+[file]:file:_files' \
        '--ini=+[file]:file:_files -g "*.ini"' \
        '--ignore-nosec[ignore nosec]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--silent[quiet]' \
        '--debug[debug]' \
        '*:files:_files'
}

_bandit2 "$@"
