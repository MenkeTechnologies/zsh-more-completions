#compdef astget
# Documentation: http://www.starlink.ac.uk/docs/sun211.htx/sun211.html
# ATOOLS: gets an attribute value for an AST Object

local ret=1

_arguments -s \
  'THIS=[input AST Object]:object:_files' \
  'ATTRIB=[name of the attribute to get]:attribute' \
  'FMT=[output format for the result]:fmt' \
  '*:object:_files' && ret=0

return ret
