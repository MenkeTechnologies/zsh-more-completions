#compdef mri_deface
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_deface
# FreeSurfer remove facial features from MRI for anonymization

local ret=1

_arguments -s -S \
  '1:input volume:_files' \
  '2:brain+skull atlas (talairach_mixed_with_skull.gca):_files' \
  '3:face atlas (face.gca):_files' \
  '4:defaced output:_files' && ret=0

return ret
