#compdef avro-cli avro avro-tools2
# _avro-cli — Apache Avro avro-cli CLI command-line frontend wrapping the Apache Avro data serialization system providing compile schema fragtojson jsontofrag random recodec rpcprotocol rpcreceive rpcsend tether totext concat fingerprint getmeta getschema canonical-schema parsing converting between Avro JSON binary text (Apache Avro team, Java); custom argparse
# upstream: https://avro.apache.org/

_avro-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:command:(compile schema fragtojson jsontofrag random recodec rpcprotocol rpcreceive rpcsend tether totext concat fingerprint getmeta getschema canonical-schema convert idl idl2schemata jsontofrag fromjson trevni_meta trevni_random trevni_tojson rpcprotocol fromtext rpcsend rpcreceive)'
}

_avro-cli "$@"
