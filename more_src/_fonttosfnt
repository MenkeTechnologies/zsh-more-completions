#compdef fonttosfnt
# Documentation: man fonttosfnt(1) (X.Org)
# Source: X.Org fonttosfnt — wrap a BDF/bitmap font in an OpenType (sfnt) wrapper (.otb).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose output]' \
    '-c[do not crop glyphs]' \
    '-b[write byte-aligned glyph data]' \
    '-r[do not reencode fonts to Unicode]' \
    '-g+[scalable-glyph mode (0=none, 1=undef, 2=blanks)]:n:(0 1 2)' \
    '-m+[scalable-metrics mode (0=none, 1=single+lsb, 2=all)]:n:(0 1 2)' \
    '-o+[output .otb file (mandatory)]:file:_files -g "*.otb"' \
    '*:input BDF font:_files -g "*.bdf"' \
    && ret=0

return ret
