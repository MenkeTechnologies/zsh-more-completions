# _starship-cli2 — Matan Kushner Starship starship-cli2 CLI command-line frontend wrapping the Starship minimal blazing-fast highly-customizable cross-shell prompt open-source written in Rust originally Matan Kushner now Starship community fast minimalist cross-shell prompt written in Rust supports bash zsh fish powershell cmd nushell elvish tcsh xonsh ion fast easy-to-use minimalist Nerd-Font icons module fish-like Git status integration battery status command duration package python ruby node golang rust kotlin java dotnet cpp time aws gcloud terraform openstack kubernetes pulumi vcsh container init explain print-config preset bug-report config session module timings completions toggle prompt config-path (Matan Kushner Starship community team, Rust); clap
# upstream: https://starship.rs/

_starship-cli2() {
    local -a sub=(
        'bug-report:Create a bug report'
        'completions:Generate shell completions'
        'config:Edit Starship configuration'
        'configure:Edit Starship configuration'
        'explain:Explain current prompt'
        'format-string:Format a string with Starship'
        'help:show help'
        'init:Print init script'
        'module:Print a single module'
        'preset:Apply a configuration preset'
        'print-config:Print computed Starship config'
        'prompt:Print Starship prompt'
        'session:Generate session key'
        'time:Print current time in milliseconds'
        'timings:Print module timings'
        'toggle:Toggle a module'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--print-full-init[print full init]' \
        '--keymap=+[keymap]:k:(emacs vi)' \
        '-k+[keymap]:str:' \
        '--status=+[code]:n:' \
        '-s+[status]:n:' \
        '--pipestatus=+[codes]:str:' \
        '*--pipestatus=+[codes]:str:' \
        '--cmd-duration=+[ms]:n:' \
        '-d+[cmd duration]:n:' \
        '--jobs=+[N]:n:' \
        '-j+[jobs]:n:' \
        '--terminal-width=+[N]:n:' \
        '-w+[terminal width]:n:' \
        '--logical-path=+[path]:str:' \
        '-l+[logical path]:str:' \
        '--path=+[path]:str:' \
        '-p+[path]:str:' \
        '--profile=+[name]:str:' \
        '--shell=+[name]:s:(bash zsh fish powershell pwsh cmd ion nushell elvish xonsh tcsh)' \
        '--right[right-side prompt]' \
        '--target=+[t]:t:(left right continuation)' \
        '--list[list modules]' \
        '--value=+[v]:v:(true false)' \
        '-V+[value]:v:(true false)' \
        '--config-path=+[file]:file:_files -g "*.toml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'starship subcommand' sub ;;
        args)
            case $words[1] in
                init|completions) _arguments '1:shell:(bash zsh fish powershell pwsh cmd elvish ion nushell tcsh xonsh)' ;;
                module|toggle) _arguments '1:module:' ;;
                preset) _arguments '1:preset:' ;;
            esac
            ;;
    esac
}

_starship-cli2 "$@"
