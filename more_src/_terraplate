#compdef terraplate
# Documentation: https://github.com/verifa/terraplate
# terraplate - a thin wrapper around Terraform to keep things DRY

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-C --chdir)'{-C,--chdir}'=[switch to a different working directory before executing]:dir:_files -/' \
  '--skip-build[skip build process]' \
  '--init[run terraform init also]' \
  '--dev[start dev mode after plan finishes]' \
  '(-j --jobs)'{-j,--jobs}'=[number of concurrent terraform jobs to run]:jobs' \
  '--output-level=[level of output to show]:level:(all drift)' \
  '1:command:(apply build dev drift init plan show version)' \
  '*::arg:_files' && ret=0

return ret
