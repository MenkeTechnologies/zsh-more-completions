#compdef btrfs-zero-log
# _btrfs-zero-log — btrfs-progs btrfs-zero-log (clear the tree-log on an unmounted btrfs filesystem; intended for recovery only when mount with -o nologreplay still fails because of a corrupt log; positional argument is the device)
# upstream: https://github.com/kdave/btrfs-progs
# Argument shape from btrfs-progs btrfs-zero-log.c on tip.

_btrfs-zero-log() {
    _arguments \
        '1:device:_files -g "/dev/*"'
}

_btrfs-zero-log "$@"
