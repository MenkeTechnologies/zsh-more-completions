#compdef aarch64-linux-g++ aarch64-linux-gnu-g++ aarch64-none-linux-gnu-g++
# _aarch64-linux-g++ — GNU GCC aarch64-linux-g++ CLI cross-arch C++ compiler driver for ARMv8 AArch64 Linux Cortex-A53 Cortex-A55 Cortex-A72 Apple M1 Marvell ThunderX producing ELF64 DWARF binaries with C++14 C++17 C++20 C++23 RTTI exceptions SVE SVE2 NEON BTI PAC march mcpu mtune (GNU team, C); custom argparse
# upstream: https://gcc.gnu.org/

_aarch64-linux-g++() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-E[stop after preprocessor]' \
        '-S[stop after compilation]' \
        '-c[compile or assemble only]' \
        '-o+[output file]:file:_files' \
        '-O+[optimization level]:l:(0 1 2 3 s g fast)' \
        '-g[debug info]' \
        '-Wall[enable common warnings]' \
        '-Wextra[enable extra warnings]' \
        '-Werror[treat warnings as errors]' \
        '-Wpedantic[strict ISO C++]' \
        '-fPIC[position independent code]' \
        '-fPIE[position independent executable]' \
        '-pie[link as PIE]' \
        '-static[link statically]' \
        '-shared[link as shared object]' \
        '-fexceptions[enable exceptions]' \
        '-fno-exceptions[no exceptions]' \
        '-frtti[enable RTTI]' \
        '-fno-rtti[no RTTI]' \
        '-mcpu=+[cpu]:c:(generic cortex-a35 cortex-a53 cortex-a55 cortex-a57 cortex-a65 cortex-a72 cortex-a73 cortex-a75 cortex-a76 cortex-a77 cortex-a78 cortex-a510 cortex-a710 cortex-a715 cortex-a720 cortex-x1 cortex-x2 cortex-x3 cortex-x4 neoverse-n1 neoverse-n2 neoverse-v1 neoverse-v2 thunderx thunderx2t99 apple-m1 native)' \
        '-mtune=+[tune]:str:' \
        '-march=+[arch]:a:(armv8-a armv8.1-a armv8.2-a armv8.3-a armv8.4-a armv8.5-a armv8.6-a armv8.7-a armv8.8-a armv9-a armv9.1-a armv9.2-a armv9.3-a armv9.4-a native)' \
        '-mabi=+[abi]:a:(lp64 ilp32)' \
        '-mbranch-protection=+[bp]:str:' \
        '-std=+[std]:s:(c++98 c++11 c++14 c++17 c++20 c++23 gnu++11 gnu++14 gnu++17 gnu++20 gnu++23)' \
        '-D+[macro]:str:' \
        '-U+[macro]:str:' \
        '-I+[include dir]:dir:_files -/' \
        '-isystem+[system include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-Wl,+[linker option]:str:' \
        '-flto[link time optimization]' \
        '-ffunction-sections[per-function sections]' \
        '-fdata-sections[per-data sections]' \
        '-MD[generate dependency .d file]' \
        '-MMD[generate dependency .d file no system]' \
        '-MP[add phony rules]' \
        '-MF+[file]:file:_files' \
        '-x+[lang]:l:(c c-header c++ c++-header assembler assembler-with-cpp none)' \
        '--sysroot=+[dir]:dir:_files -/' \
        '*:source file:_files -g "*.cc *.cpp *.cxx *.C *.c++ *.hpp *.hxx *.h *.s *.S *.o *.a *.so"'
}

_aarch64-linux-g++ "$@"
