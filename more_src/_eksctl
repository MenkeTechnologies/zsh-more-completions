#compdef eksctl

# Zsh completion for eksctl (Amazon EKS CLI)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'anywhere:EKS-Anywhere'
  'associate:Associate resources with a cluster'
  'completion:Generate bash/zsh completion scripts'
  'create:Create resource(s)'
  'delete:Delete resource(s)'
  'deregister:Deregister a non-EKS cluster'
  'disassociate:Disassociate resources from a cluster'
  'drain:Drain resource(s)'
  'enable:Enable features in a cluster'
  'get:Get resource(s)'
  'help:Help about any command'
  'info:Output the version of eksctl, kubectl, and OS info'
  'register:Register a non-EKS cluster'
  'scale:Scale resources(s)'
  'set:Set values'
  'unset:Unset values'
  'update:Update resource(s)'
  'upgrade:Upgrade resource(s)'
  'utils:Various utils'
  'version:Output the version of eksctl'
)

_arguments -C \
  {-C,--color}'=[Toggle colorized logs]:color:(true false fabulous)' \
  {-d,--dumpLogs}'[Dump logs to disk on failure]' \
  {-h,--help}'[Help for eksctl]' \
  {-v,--verbose}'=[Set log verbosity (0-5)]:level:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'eksctl command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      create)
        local -a create_cmds
        create_cmds=(
          'addon:Create an addon'
          'cluster:Create a cluster'
          'fargateprofile:Create a Fargate profile'
          'iamidentitymapping:Create an IAM identity mapping'
          'iamserviceaccount:Create an IAM service account'
          'nodegroup:Create a nodegroup'
          'podidentityassociation:Create a pod identity association'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd)
            _describe -t create_cmds 'create subcommand' create_cmds && ret=0
            ;;
          subargs)
            case "${line[1]}" in
              cluster)
                _arguments \
                  '--alb-ingress-access[Enable ALB ingress access]' \
                  '--appmesh-access[Enable App Mesh access]' \
                  '--appmesh-preview-access[Enable App Mesh preview access]' \
                  '--asg-access[Enable ASG access]' \
                  '--auto-kubeconfig[Save kubeconfig output in per-cluster directory]' \
                  '--dry-run[Dry-run mode for reviewing changes]' \
                  '--external-dns-access[Enable External DNS access]' \
                  '--fargate[Create a Fargate profile]' \
                  {-f,--config-file}'=[Load configuration from a file]:file:_files' \
                  '--full-ecr-access[Enable full ECR access]' \
                  '--install-nvidia-plugin[Install Nvidia plugin]' \
                  '--install-neuron-plugin[Install Neuron plugin]' \
                  '--kubeconfig=[Path to write kubeconfig]:file:_files' \
                  '--managed[Create EKS-managed nodegroup]' \
                  {-n,--name}'=[EKS cluster name]:name:' \
                  '--node-ami=[Specify AMI id for nodes]:ami:' \
                  '--node-ami-family=[Specify the node AMI family]:family:(AmazonLinux2 Ubuntu2004 Ubuntu1804 Bottlerocket WindowsServer2019CoreContainer WindowsServer2019FullContainer WindowsServer2022CoreContainer WindowsServer2022FullContainer)' \
                  '--node-labels=[Extra labels for nodes]:labels:' \
                  '--node-private-networking[Use private networking for nodes]' \
                  '--node-security-groups=[Additional security groups]:groups:' \
                  '--node-type=[Node instance type]:type:' \
                  '--node-volume-size=[Node volume size in GB]:size:' \
                  '--node-volume-type=[Node volume type]:type:(gp2 gp3 io1 io2 sc1 st1)' \
                  '--node-zones=[Limit nodes to specific zones]:zones:' \
                  '--nodegroup-name=[Name of the nodegroup]:name:' \
                  {-N,--nodes}'=[Number of nodes]:count:' \
                  {-m,--nodes-min}'=[Minimum nodes in ASG]:count:' \
                  {-M,--nodes-max}'=[Maximum nodes in ASG]:count:' \
                  {-p,--profile}'=[AWS credentials profile]:profile:' \
                  {-r,--region}'=[AWS region]:region:(us-east-1 us-east-2 us-west-1 us-west-2 eu-west-1 eu-west-2 eu-west-3 eu-central-1 eu-north-1 ap-northeast-1 ap-northeast-2 ap-southeast-1 ap-southeast-2 ap-south-1 ca-central-1 sa-east-1 me-south-1 af-south-1)' \
                  '--set-kubeconfig-context[Set current-context in kubeconfig]' \
                  '--spot[Use spot instances for nodes]' \
                  '--ssh-access[Control SSH access for nodes]' \
                  '--ssh-public-key=[SSH public key to use for nodes]:key:_files' \
                  '--tags=[A list of key-value pairs to tag resources]:tags:' \
                  '--timeout=[Timeout for any long running operation]:duration:' \
                  '--version=[Kubernetes version]:version:(1.24 1.25 1.26 1.27 1.28 1.29 1.30)' \
                  '--vpc-cidr=[Global CIDR to use for VPC]:cidr:' \
                  '--vpc-from-kops-cluster=[VPC from a kops cluster]:cluster:' \
                  '--vpc-nat-mode=[VPC NAT mode]:mode:(Single HighlyAvailable Disable)' \
                  '--vpc-private-subnets=[Private subnets]:subnets:' \
                  '--vpc-public-subnets=[Public subnets]:subnets:' \
                  '--with-oidc[Enable the IAM OIDC provider]' \
                  '--without-nodegroup[Create cluster without default nodegroup]' \
                  '--write-kubeconfig[Write kubeconfig]' \
                  '--zones=[Availability zones]:zones:' && ret=0
                ;;
              nodegroup)
                _arguments \
                  '--cluster=[Name of the EKS cluster]:name:' \
                  {-f,--config-file}'=[Load configuration from a file]:file:_files' \
                  '--exclude=[Nodegroups to exclude]:names:' \
                  '--include=[Nodegroups to include]:names:' \
                  '--managed[Create EKS-managed nodegroup]' \
                  {-n,--name}'=[Nodegroup name]:name:' \
                  '--node-ami=[Specify AMI id]:ami:' \
                  '--node-ami-family=[Specify AMI family]:family:' \
                  '--node-labels=[Extra labels for nodes]:labels:' \
                  '--node-private-networking[Use private networking]' \
                  '--node-type=[Instance type]:type:' \
                  '--node-volume-size=[Volume size in GB]:size:' \
                  '--node-volume-type=[Volume type]:type:(gp2 gp3 io1 io2)' \
                  {-N,--nodes}'=[Number of nodes]:count:' \
                  {-m,--nodes-min}'=[Minimum nodes]:count:' \
                  {-M,--nodes-max}'=[Maximum nodes]:count:' \
                  {-r,--region}'=[AWS region]:region:' \
                  '--spot[Use spot instances]' \
                  '--ssh-access[Control SSH access]' \
                  '--ssh-public-key=[SSH public key]:key:_files' \
                  '--subnet-ids=[Subnet IDs]:ids:' \
                  '--tags=[Tags for resources]:tags:' \
                  '--timeout=[Timeout]:duration:' \
                  '--update-auth-configmap[Update aws-auth ConfigMap]' \
                  '--version=[Kubernetes version]:version:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      delete)
        local -a delete_cmds
        delete_cmds=(
          'addon:Delete an addon'
          'cluster:Delete a cluster'
          'fargateprofile:Delete a Fargate profile'
          'iamidentitymapping:Delete an IAM identity mapping'
          'iamserviceaccount:Delete an IAM service account'
          'nodegroup:Delete a nodegroup'
          'podidentityassociation:Delete a pod identity association'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t delete_cmds 'delete subcommand' delete_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              cluster)
                _arguments \
                  {-f,--config-file}'=[Config file]:file:_files' \
                  '--disable-nodegroup-eviction[Force drain to use delete]' \
                  '--force[Force deletion]' \
                  {-n,--name}'=[Cluster name]:name:' \
                  {-r,--region}'=[AWS region]:region:' \
                  '--timeout=[Timeout]:duration:' \
                  {-w,--wait}'[Wait for deletion]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      get)
        local -a get_cmds
        get_cmds=(
          'addon:Get an addon'
          'cluster:Get cluster(s)'
          'fargateprofile:Get Fargate profile(s)'
          'iamidentitymapping:Get IAM identity mapping(s)'
          'iamserviceaccount:Get IAM service account(s)'
          'labels:Get nodegroup labels'
          'nodegroup:Get nodegroup(s)'
          'podidentityassociation:Get pod identity association(s)'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t get_cmds 'get subcommand' get_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              cluster)
                _arguments \
                  {-A,--all-regions}'[List clusters across all supported regions]' \
                  '--chunk-size=[Return large lists in chunks]:size:' \
                  {-n,--name}'=[Cluster name]:name:' \
                  {-o,--output}'=[Output format]:format:(table json yaml)' \
                  {-r,--region}'=[AWS region]:region:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      scale)
        _arguments -C \
          '1:resource:(nodegroup)' \
          '--cluster=[Cluster name]:name:' \
          {-f,--config-file}'=[Config file]:file:_files' \
          {-n,--name}'=[Nodegroup name]:name:' \
          {-N,--nodes}'=[Desired number of nodes]:count:' \
          '--nodes-max=[Maximum number of nodes]:count:' \
          '--nodes-min=[Minimum number of nodes]:count:' \
          {-r,--region}'=[AWS region]:region:' \
          '--timeout=[Timeout]:duration:' && ret=0
        ;;
      upgrade)
        _arguments -C \
          '1:resource:(cluster nodegroup)' \
          '--approve[Apply the changes]' \
          '--cluster=[Cluster name]:name:' \
          {-f,--config-file}'=[Config file]:file:_files' \
          {-n,--name}'=[Name]:name:' \
          {-r,--region}'=[AWS region]:region:' \
          '--timeout=[Timeout]:duration:' \
          '--version=[Kubernetes version]:version:' && ret=0
        ;;
      utils)
        local -a utils_cmds
        utils_cmds=(
          'associate-iam-oidc-provider:Setup IAM OIDC provider for a cluster'
          'describe-addon-configuration:Describe addon configuration'
          'describe-addon-versions:Describe addon versions'
          'describe-stacks:Describe CloudFormation stacks for a cluster'
          'install-vpc-controllers:Install VPC controller Helm charts'
          'nodegroup-health:Get nodegroup health'
          'schema:Output the ClusterConfig JSON Schema'
          'update-aws-node:Update aws-node addon'
          'update-cluster-endpoints:Update cluster API endpoint access'
          'update-cluster-logging:Update cluster logging configuration'
          'update-cluster-vpc-config:Update cluster VPC configuration'
          'update-coredns:Update coredns addon'
          'update-kube-proxy:Update kube-proxy addon'
          'update-legacy-subnet-settings:Update legacy subnet settings'
          'write-kubeconfig:Write kubeconfig for a cluster'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t utils_cmds 'utils subcommand' utils_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      info|version)
        _arguments \
          {-o,--output}'=[Output format]:format:(table json yaml)' && ret=0
        ;;
    esac
    ;;
esac

return ret
