#compdef score_jd2
# Documentation: https://docs.rosettacommons.org/docs/latest/application_documentation/analysis/score-commands
# Rosetta score_jd2 structure (re)scoring application

local ret=1

_arguments -s -S \
  '-help[display all available options]' \
  '-in:file:s+[input PDB file]:pdb:_files -g "*.pdb"' \
  '-in:file:l+[list of input PDB files]:pdblist:_files' \
  '-in:file:silent+[silent format input file]:silent:_files' \
  '-in:file:native+[native PDB for CaRMS calculation]:native:_files -g "*.pdb"' \
  '-in:file:fullatom[treat input as full-atom]' \
  '-score:weights+[designate weight set or weights file]:weights:_files' \
  '-score:patch+[specify scoring patch set]:patch:_files' \
  '-out:file:scorefile+[name of scorefile (default score.sc)]:scorefile:_files' \
  '-out:nooutput[suppress PDB structure printing]' \
  '-out:output[enable PDB structure printing]' \
  '-out:path:all+[output directory path]:path:_files -/' \
  '-rescore:verbose[display score breakdown]' \
  '-database+[path to Rosetta database directory]:database:_files -/' \
  '-overwrite[overwrite existing output files]' \
  '-ignore_unrecognized_res[allow unrecognized residues]' \
  '*-mute+[suppress output from a tracer channel]:channel:' \
  '*-unmute+[enable output from a tracer channel]:channel:' \
  '*:file:_files' && ret=0

return ret
