#compdef aalib-config
# Documentation: https://aa-project.sourceforge.net/aalib/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' && ret=0

return ret
