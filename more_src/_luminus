#compdef luminus
# _luminus — Dmitri Sotnikov Luminus Clojure micro-framework CLI alias (luminus-framework team, Clojure); leiningen template
# upstream: https://github.com/luminus-framework/luminus-template

_luminus() {
    local -a sub=(
        'new:create new luminus project'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'luminus subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:project name:' \
                    '+http-kit[use http-kit server]' \
                    '+jetty[use jetty server]' \
                    '+undertow[use undertow server]' \
                    '+aleph[use aleph server]' \
                    '+immutant[use immutant server]' \
                    '+postgres[postgres]' \
                    '+mysql[mysql]' \
                    '+sqlite[sqlite]' \
                    '+h2[h2]' \
                    '+mssql[mssql]' \
                    '+mongodb[mongodb]' \
                    '+xtdb[xtdb]' \
                    '+swagger[swagger]' \
                    '+kafka[kafka]' \
                    '+graphql[graphql]' \
                    '+oauth[oauth]' \
                    '+auth[auth]' \
                    '+sente[sente websockets]' \
                    '+websocket[raw websocket]' \
                    '+kee-frame[kee-frame]' \
                    '+reagent[reagent]' \
                    '+re-frame[re-frame]' \
                    '+shadow-cljs[shadow-cljs]' \
                    '+cljs[cljs]' \
                    '+cider[cider]' \
                    '+graalvm[graalvm native]' \
                    '+selmer[selmer templating]' \
                    '+hiccup[hiccup templating]' \
                    '+rum[rum]' \
                    '+sass[sass]' \
                    '+less[less]' \
                    '+tailwind[tailwind]' \
                    '+test[test setup]' \
                    '+dev[dev profile]' \
                    '+expanded[expanded scaffold]' \
                    '+log4j[log4j]' \
                    '+kit[kit framework setup]' \
                    '--to-dir=+[target dir]:dir:_files -/' \
                    '--force[force overwrite]' ;;
            esac
            ;;
    esac
}

_luminus "$@"
