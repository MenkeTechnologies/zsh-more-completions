#compdef btgatt-server
# Documentation: https://github.com/bluez/bluez/blob/master/tools/btgatt-server.c
# Source: BlueZ tools/btgatt-server.c — GATT peripheral / server over ATT/L2CAP.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --index)'{-i+,--index=}'[adapter index (e.g. hci0)]:idx:' \
    '(-m --mtu)'{-m+,--mtu=}'[ATT MTU]:mtu:' \
    '(-s --security-level)'{-s+,--security-level=}'[security level]:level:(low medium high)' \
    '(-t --type)'{-t+,--type=}'[source address type]:type:(public random)' \
    '(-v --verbose)'{-v,--verbose}'[extra logging]' \
    '(-r --heart-rate)'{-r,--heart-rate}'[enable Heart Rate service]' \
    '(- *)'{-h,--help}'[display help]' \
    && ret=0

return ret
