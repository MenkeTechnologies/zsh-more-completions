#compdef copyq
# _copyq-bin — CopyQ advanced clipboard manager (Lukáš Holeček, Qt5/Qt6); scriptable clipboard manager with tabs, JS API, image+text
# upstream: https://github.com/hluk/CopyQ

_copyq-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-s --session)'{-s,--session}'+[session name]:session:' \
        '--start-server[start server]' \
        '--info+[print info]:item:' \
        '(-c --clipboard-access)'{-c,--clipboard-access}'[clipboard access mode]' \
        '*:command:'
}

_copyq-bin "$@"
