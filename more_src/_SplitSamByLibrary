#compdef SplitSamByLibrary
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/sam/SplitSamByLibrary.java
# Splits a SAM/BAM/CRAM file into individual files by library

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--INPUT -I)'{--INPUT,-I}'=[input SAM/BAM/CRAM file]:value:_files' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[output directory]:dir:_files -/' \
  '*:argument:_files' && ret=0

return ret
