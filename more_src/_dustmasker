#compdef dustmasker
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK279684/
# BLAST+ tool to mask low-complexity regions of nucleotide sequences (symmetric DUST)
# Flags from NCBI C++ Toolkit src/app/dustmasker/README

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-in=[input file name (- for stdin)]:file:_files' \
  '-out=[output file name (- for stdout)]:file:_files' \
  '-infmt=[input data format]:format:(fasta blastdb)' \
  '-outfmt=[output format]:format:(interval acclist fasta maskinfo_asn1_bin maskinfo_asn1_text seqloc_asn1_bin seqloc_asn1_text)' \
  '-window=[DUST window length]:int:' \
  '-level=[10 times the DUST score threshold]:int:' \
  '-linker=[max gap to merge adjacent masked intervals]:int:' \
  '-parse_seqids[parse Seq-ids in FASTA input]' \
  '-hard_masking[output sequence in hard-masked form]' && ret=0

return ret
