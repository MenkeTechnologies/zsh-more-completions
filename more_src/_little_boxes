autoload -U is-at-least

_little_boxes() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-t+[Add a title to the box]:TITLE:_default' \
'--title=[Add a title to the box]:TITLE:_default' \
'-c+[The charset to draw the box with]:CHARSET:(thick thin double box rounded dot ascii)' \
'--charset=[The charset to draw the box with]:CHARSET:(thick thin double box rounded dot ascii)' \
'-f+[Read input from a file instead of stdin]:FILE:_files' \
'--file=[Read input from a file instead of stdin]:FILE:_files' \
'--all[Compare all charsets]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_little_boxes_commands] )) ||
_little_boxes_commands() {
    local commands; commands=()
    _describe -t commands 'little_boxes commands' commands "$@"
}

if [ "$funcstack[1]" = "_little_boxes" ]; then
    _little_boxes "$@"
else
    compdef _little_boxes little_boxes
fi
