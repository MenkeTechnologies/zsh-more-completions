#compdef branchprotector
# _branchprotector — Prow tool that applies GitHub branch-protection rules (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/branchprotector/protect.go (flag).

_branchprotector() {
    _arguments \
        '-confirm[mutate GitHub if set]' \
        '-verify-restrictions[verify authorized apps/collaborators/teams]' \
        '-enable-apps-restrictions[enforce apps restrictions in branch protection rules]' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls' \
        '-github-app-id=[GitHub App ID]:id:' \
        '-github-app-private-key-path=[GitHub App private key]:file:_files'
}

_branchprotector "$@"
