#compdef create-knapsack
# Documentation: https://www.npmjs.com/package/create-knapsack
# Reference accessed: 2026-05-24
# Verified: npm view create-knapsack bin; npx create-knapsack --help; npx create-knapsack workspace-foundation --help.

# Zsh completion for create-knapsack - Knapsack workspace scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--version[show version number]'   '(-h --help)'{-h,--help}'[show help]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' workspace-foundation && ret=0
    ;;
  args)
    _arguments -C       '--siteId=[Knapsack site id]:id:'       '--renderers=[renderer stacks]:renderer:(react vue html web-components twig hbs angular)'       '(-h --help)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
