#compdef cloud-sql-proxy cloud_sql_proxy

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--instances=[csv project:region:instance[=tcp:port]]:list:' \
  '-instances=[csv project:region:instance[=tcp:port]]:list:' \
  '--projects=[projects to open all instances csv]:list:' \
  '-projects=[projects to open all instances csv]:list:' \
  '--credentials-file=[service account JSON]:file:_files -g "*.json"' \
  '-credential_file=[service account JSON]:file:_files -g "*.json"' \
  '--token=[OAuth2 bearer token]:tok:' \
  '-token=[OAuth2 bearer token]:tok:' \
  '--login-token=[user login token JSON]:tok:' \
  '--gcloud-auth[use gcloud user credentials]' \
  '--auto-iam-authn[auto IAM authentication]' \
  '--quota-project=[quota project]:proj:' \
  '--dir=[unix socket directory]:dir:_files -/' \
  '-dir=[unix socket directory]:dir:_files -/' \
  '--max-connections=[max connections]:n:' \
  '-max_connections=[max connections]:n:' \
  '--fuse=[FUSE mount path]:dir:_files -/' \
  '-fuse=[FUSE mount path]:dir:_files -/' \
  '--fuse-tmp-dir=[FUSE tmp dir]:dir:_files -/' \
  '--api-endpoint=[admin API endpoint]:url:' \
  '--port=[default TCP port]:port:' \
  '--address=[default address]:addr:' \
  '--unix-socket=[default unix socket]:path:_files' \
  '--prometheus[enable Prometheus metrics]' \
  '--prometheus-namespace=[prometheus namespace]:ns:' \
  '--http-port=[health/metrics HTTP port]:port:' \
  '--health-check[enable HTTP health check]' \
  '--http-address=[HTTP address]:addr:' \
  '--debug[enable pprof debug]' \
  '--debug-logs[enable debug logs]' \
  '--quiet[quiet output]' \
  '--structured-logs[structured logs]' \
  '--telemetry-project=[telemetry GCP project]:proj:' \
  '--telemetry-prefix=[telemetry prefix]:p:' \
  '--telemetry-tracing-sample-rate=[trace sample rate]:n:' \
  '--disable-built-in-authentication[disable built-in auth]' \
  '--disable-traces[disable traces]' \
  '--disable-metrics[disable metrics]' \
  '--max-sigterm-delay=[graceful sigterm delay]:dur:' \
  '--exit-zero-on-sigterm[exit 0 on sigterm]' \
  '--user-agent=[custom user agent]:ua:' \
  '--auto-ip[try public then private]' \
  '--private-ip[force private IP]' \
  '--psc[connect via PSC]' \
  '--lazy-refresh[lazy refresh]' \
  '--run-connection-test[test connections then exit]' \
  '--token-info-host=[token introspection host]:host:_hosts' \
  '*: :' && ret=0

return ret
