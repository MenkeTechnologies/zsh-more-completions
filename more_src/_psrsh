#compdef psrsh
# Documentation: http://psrchive.sourceforge.net/manuals/psrsh/
# PSRCHIVE: command language interpreter for archive preprocessing.

local ret=1

_arguments -s -S \
  '-H[show complete list of supported commands]' \
  '*-j+[semicolon-separated preprocessing commands]:commands:' \
  '*-J+[psrsh script file for preprocessing]:file:_files' \
  '*:archive or script:_files' && ret=0

return ret
