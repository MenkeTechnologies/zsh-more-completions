#compdef registry-server
# _registry-server — operator-registry sqlite-backed catalog gRPC server (loads a bundles.db and serves api.Registry)
# upstream: https://github.com/operator-framework/operator-registry
# Flags from cmd/registry-server/main.go on tip (cobra).

_registry-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --database)'{-d,--database}'=[relative path to sqlite db]:file:_files' \
        '(-p --port)'{-p,--port}'=[port number to serve on]:port:' \
        '(-t --termination-log)'{-t,--termination-log}'=[container termination log path]:file:_files' \
        '--skip-migrate[do not migrate to the latest db revision on startup]' \
        '--debug[enable debug logging (hidden)]'
}

_registry-server "$@"
