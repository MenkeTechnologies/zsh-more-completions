# CLIProxyAPI server (Go flag package).

_arguments -s -S \
  '-login[OAuth: Google Account]' \
  '-codex-login[OAuth: Codex]' \
  '-codex-device-login[Codex device code flow]' \
  '-claude-login[OAuth: Claude]' \
  '-no-browser[do not open browser for OAuth]' \
  '-oauth-callback-port=[override OAuth callback port]:port:' \
  '-antigravity-login[OAuth: Antigravity]' \
  '-kimi-login[OAuth: Kimi]' \
  '-project_id=[Gemini project id]:id:' \
  '-config=[config file path]:file:_files' \
  '-vertex-import=[Vertex service account JSON]:file:_files' \
  '-vertex-import-prefix=[prefix for Vertex model namespacing]:prefix:' \
  '-tui[start management TUI]' \
  '-standalone[with TUI: embedded local server]' \
  '-local-model[embedded model catalog only; skip remote fetch]'
