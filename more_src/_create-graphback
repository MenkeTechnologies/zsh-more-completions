# Zsh completion for create-graphback - Graphback GraphQL server scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--templateName=[predefined template name]:name:'   '--templateUrl=[GitHub template URL]:url:'   '--filter=[filter displayed templates]:filter:(postgres mongo sqlite)'   '(-v --version)'{-v,--version}'[show version]'   '(-h --help)'{-h,--help}'[show help]'   ':project name:' && ret=0

return ret
