#compdef hdr10plus_tool
# Documentation: https://github.com/quietvoid/hdr10plus_tool
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# clap subcommands: extract inject remove plot editor

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'extract:dump HDR10+ JSON from HEVC'
  'inject:interleave HDR10+ metadata NALs'
  'remove:strip HDR10+ SEI NALs'
  'plot:plot brightness metadata'
  'editor:edit metadata in place'
)

_arguments -s -S \
  '--verify[check for HDR10+ dynamic metadata]' \
  '--skip-validation[skip profile validation]' \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'hdr10plus_tool command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
