#compdef dbclient
# Documentation: https://man.archlinux.org/search?q=dbclient
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-p+[remote port]:port:' \
  '-i+[identity key file]:key file:_files' \
  '-L+[local port forward]:listen_port\:host\:port:' \
  '-R+[remote port forward]:listen_port\:host\:port:' \
  '-l+[login name]:user:_users' \
  '-t[allocate PTY]' \
  '-T[do not allocate PTY]' \
  '-N[do not run a shell/command]' \
  '-f[go to background]' \
  '-g[allow remote hosts to connect to forwarded ports]' \
  '-y[always accept remote host key]' \
  '-A[enable agent forwarding]' \
  '-W+[receive window size]:size:' \
  '-K+[keepalive interval]:seconds:' \
  '-I+[idle timeout]:seconds:' \
  '-B+[endhost\:endport for -J]:host\:port:' \
  '-J+[netcat-alike proxy command]:proxy command:' \
  '-c+[cipher list]:ciphers:(aes128-ctr aes256-ctr chacha20-poly1305@openssh.com)' \
  '-m+[MAC list]:MACs:(hmac-sha1 hmac-sha2-256)' \
  '-o+[ssh option]:option:' \
  '-s[invoke subsystem]:subsystem:' \
  '-V[show version]' \
  '-b+[bind address]:address:_hosts' \
  '(-):host:_hosts' \
  '*:command:' && ret=0

return ret
