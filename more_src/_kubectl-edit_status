#compdef kubectl-edit_status
# Documentation: https://github.com/ulucinar/kubectl-edit-status
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. krew replaces `-` with `_`
# in the binary name; invoked as `kubectl edit-status` via krew.
# Flags are kubectl genericclioptions config flags (standard set).

# kubectl-edit_status: edit status subresource of a Kubernetes object
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--as=[user to impersonate]:user:' \
  '*--as-group=[group to impersonate]:group:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kube context]:context:' \
  '--cluster=[cluster name]:cluster:' \
  '--user=[user name]:user:' \
  '--token=[bearer token]:token:' \
  '--server=[API server URL]:url:' \
  '--certificate-authority=[CA bundle path]:file:_files' \
  '--client-certificate=[client cert path]:file:_files' \
  '--client-key=[client key path]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS verify]' \
  '--tls-server-name=[TLS SNI server name]:name:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
  '--namespaced[resource is namespaced (default true)]' \
  '(-e --editor)'{-e+,--editor=}'[editor]:editor:_command_names' \
  '--cache-dir=[cache directory]:dir:_files -/' \
  '--request-timeout=[request timeout]:duration:' \
  '*:resource:_default' && ret=0
return ret
