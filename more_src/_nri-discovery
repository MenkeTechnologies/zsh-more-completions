#compdef nri-discovery

# nri-discovery: discovery agent for nri-* integrations
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-config_file=[config file]:file:_files' \
  '--config_file=[config file]:file:_files' \
  '-verbose[verbose]' \
  '--verbose[verbose]' \
  '-pretty[pretty output]' \
  '-show_version[show version]' \
  '*::nri-discovery args:_files' && ret=0
return ret
