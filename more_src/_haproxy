#compdef haproxy

# Zsh completion for haproxy - reliable, high performance TCP/HTTP load balancer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '(- *)-vv[show verbose version and build options]' \
  '*-f+[configuration file or directory]:config file:_files' \
  '-c[check configuration and exit]' \
  '-d[enable debug mode, disables daemon mode]' \
  '-D[run as daemon]' \
  '-db[disable background mode, stay in foreground]' \
  '-de[disable use of epoll]' \
  '-dp[disable use of poll]' \
  '-dS[disable use of splice]' \
  '-dG[disable use of getaddrinfo]' \
  '-dR[disable SO_REUSEPORT usage]' \
  '-dV[disable SSL]' \
  '-dr[ignore server address resolution failures]' \
  '-S+[stats socket specification]:bind address:' \
  '-n+[set the maximum total number of connections]:max connections:' \
  '-N+[set the default per-proxy maxconn]:default maxconn:' \
  '-p+[write PIDs of all children to file]:pid file:_files' \
  '-L+[set the local peer name]:peer name:' \
  '-q[quiet mode, do not display messages]' \
  '-s[show statistics from running process]' \
  '*-sf+[finish connections then replace running process]:pids:_pids' \
  '*-st+[terminate connections then replace running process]:pids:_pids' \
  '-W[master-worker mode]' \
  '-Ws[master-worker mode with systemd notify support]' \
  '-x+[get listening sockets from unix socket for seamless reload]:socket:_files'
