#compdef calidns
# Documentation: https://doc.powerdns.com/authoritative/manpages/calidns.1.html
# Read DNS queries from a file and send them recursively to measure server performance

local ret=1

_arguments -s -S \
  '--ecs[append EDNS Client Subnet using random addresses from subnet]:subnet:' \
  '--ecs-from-file[use IP/subnet values from the query file as ECS]' \
  '--increment[QPS multiplier per iteration]:num:' \
  '--maximum-qps[halt QPS increases at this threshold]:num:' \
  '--minimum-success-rate[terminate when success rate falls below percent]:num:' \
  '--plot-file[save results to file]:file:_files' \
  '--proxy-protocol[prepend Proxy Protocol header with random source addresses]' \
  '--proxy-protocol-from-file[use IP values from query file as PROXY source addresses]' \
  '--quiet[show only final maximum QPS achieved]' \
  '--want-recursion[enable Recursion Desired flag]' \
  '1:query-file:_files' \
  '2:destination:_hosts' \
  '3:initial-qps:' \
  '4:hitrate:' && ret=0

return ret
