#compdef gpaste-client gpaste

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'about:show about dialog'
  'add:add text to history'
  'a:alias for add'
  'add-password:add name-password to history'
  'ap:alias for add-password'
  'add-file:add file contents to history'
  'af:alias for add-file'
  'backup-history:backup current history'
  'bh:alias for backup-history'
  'daemon-reexec:reexec daemon after upgrade'
  'dr:alias for daemon-reexec'
  'daemon-version:check daemon version'
  'dv:alias for daemon-version'
  'delete:delete item by uuid'
  'd:alias for delete'
  'delete-history:delete a history'
  'dh:alias for delete-history'
  'delete-password:delete password by name'
  'dp:alias for delete-password'
  'empty-history:empty current history'
  'eh:alias for empty-history'
  'get:get item by uuid'
  'get-history:get current history name'
  'gh:alias for get-history'
  'get-raw:get raw item by uuid'
  'gr:alias for get-raw'
  'history:show history with indexes'
  'h:alias for history'
  'history-size:show size of history'
  'hs:alias for history-size'
  'list-histories:list histories'
  'lh:alias for list-histories'
  'merge:merge items into clipboard'
  'rename-password:rename password'
  'rp:alias for rename-password'
  'replay:replay item by uuid'
  'r:alias for replay'
  'search:search history'
  's:alias for search'
  'select:select item by uuid'
  'sl:alias for select'
  'set-password:set password for current item'
  'sp:alias for set-password'
  'show-history:show items in named history'
  'sh:alias for show-history'
  'start:start tracking changes'
  'on:alias for start'
  'stop:stop tracking changes'
  'off:alias for stop'
  'switch-history:switch to another history'
  'sw:alias for switch-history'
  'ui:show graphical tool'
  'upload:upload item to pastebin'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gpaste-client command' commands && ret=0 ;;
esac

return ret
