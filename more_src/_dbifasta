#compdef dbifasta
# Documentation: https://man.archlinux.org/search?q=dbifasta
# Reference accessed: 2026-05-16

# EMBOSS dbifasta: build an EMBOSS index for a FASTA database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-dbname=[database name to index]:name:' \
  '-standardfilename=[standard filename layout (yes/no)]:bool:(Y N)' \
  '-directory=[directory containing the FASTA files]:dir:_files -/' \
  '-filenames=[wildcard for files to index]:pattern:' \
  '-idformat=[identifier format]:format:(simple idacc gcgid gcgidacc ncbi dbid)' \
  '-fields=[fields to index (id,acc,des,sv,gi)]:fields:' \
  '-release=[database release number]:release:' \
  '-date=[database date (dd/mm/yy)]:date:' \
  '-exclude=[wildcard names of files to exclude]:patterns:' \
  '-files=[explicit list of files]:files:_files' \
  '-indexoutdir=[output directory for index files]:dir:_files -/' \
  '-maxindex=[maximum index file count]:n:' \
  '-sortoptions=[external sort options]:opts:' \
  '-systemsort[use OS sort utility]' \
  '-cleanup[delete temporary files after indexing]' \
  '-staden[Staden format input]' \
  '*:database name:' && ret=0
return ret
