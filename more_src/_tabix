#compdef tabix

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-p+[preset format]:preset:(gff bed sam vcf)' \
  '-s+[sequence column]:n:' \
  '-b+[begin column]:n:' \
  '-e+[end column]:n:' \
  '-c+[comment character]:char:' \
  '-S+[skip lines]:n:' \
  '-f[force overwrite]' \
  '-0[zero-based coordinates]' \
  '-h[print header lines]' \
  '-l[list sequence names]' \
  '-T+[tabix index file (.tbi/.csi)]:file:_files -g "*.(tbi|csi)"' \
  '-C[generate CSI index]' \
  '-m+[minimum bin shift for CSI]:n:' \
  '-D[do not download index]' \
  '*:input file:_files -g "*.(gff|bed|sam|vcf|gz|bgz|tbi|csi)"' && ret=0

return ret
