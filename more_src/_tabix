#compdef tabix
# Documentation: https://www.htslib.org/doc/tabix.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-0 --zero-based)'{-0,--zero-based}'[treat positions as 0-based half-open]' \
  '(-p --preset)'{-p+,--preset=}'[preset input format]:preset:(gff bed sam vcf)' \
  '(-s --sequence)'{-s+,--sequence=}'[column of sequence name]:n:' \
  '(-b --begin)'{-b+,--begin=}'[column of start chromosomal position]:n:' \
  '(-e --end)'{-e+,--end=}'[column of end chromosomal position]:n:' \
  '(-c --comment)'{-c+,--comment=}'[skip lines starting with character]:char:' \
  '(-S --skip-lines)'{-S+,--skip-lines=}'[skip first INT lines]:n:' \
  '(-f --force)'{-f,--force}'[overwrite existing index]' \
  '(-h --print-header)'{-h,--print-header}'[include header lines in output]' \
  '-H[print only the header/meta lines]' \
  '--only-header[print only the header/meta lines]' \
  '(-l --list-chroms)'{-l,--list-chroms}'[list sequence names from index]' \
  '(-r --reheader)'{-r+,--reheader=}'[replace header with FILE]:file:_files' \
  '(-R --regions)'{-R+,--regions=}'[restrict output to regions in FILE]:file:_files' \
  '(-T --targets)'{-T+,--targets=}'[skip regions not listed in FILE]:file:_files' \
  '(-C --csi)'{-C,--csi}'[generate CSI format index]' \
  '(-m --min-shift)'{-m+,--min-shift=}'[minimal interval size for CSI (2^INT)]:n:' \
  '-D[do not download index]' \
  '--cache=[BGZF block cache size in megabytes]:mb:' \
  '--separate-regions[insert region names before records]' \
  '--verbosity=[control logging detail]:n:' \
  {-@+,--threads=}'[number of processing threads]:n:' \
  '*:input file:_files -g "*.(gff|bed|sam|vcf|gz|bgz|tbi|csi)"' && ret=0

return ret
