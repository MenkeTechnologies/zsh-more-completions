#compdef amplify-cli
# _amplify-cli — AWS Amplify CLI alias (aws-amplify team, TypeScript); commander
# upstream: https://github.com/aws-amplify/amplify-cli

_amplify-cli() {
    local -a sub=(
        'init:initialize project'
        'configure:configure amplify'
        'push:push changes to cloud'
        'pull:pull cloud changes'
        'publish:publish hosting'
        'status:show resource status'
        'env:list:list environments'
        'env:add:add environment'
        'env:checkout:checkout environment'
        'env:get:get env config'
        'env:remove:remove environment'
        'env:pull:pull env'
        'env:push:push env'
        'env:import:import env'
        'env:update:update env'
        'mock:mock backend locally'
        'serve:run locally'
        'codegen:generate code'
        'codegen:add:add codegen'
        'codegen:configure:configure codegen'
        'codegen:statements:generate statements'
        'codegen:types:generate types'
        'codegen:models:generate models'
        'console:open amplify console'
        'delete:delete project'
        'help:show help'
        'add:add resource'
        'update:update resource'
        'remove:remove resource'
        'override:override resource'
        'import:import resource'
        'upgrade:upgrade cli'
        'logout:logout'
        'plugin:list:list plugins'
        'plugin:add:add plugin'
        'plugin:remove:remove plugin'
        'plugin:scan:scan plugins'
        'notifications:add:add notification'
        'notifications:remove:remove notification'
        'notifications:update:update notification'
        'notifications:console:open notifications console'
        'notifications:status:notification status'
        'logs:show cloud function logs'
        'export:export project'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--profile=+[aws profile]:str:' \
        '--region=+[region]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amplify subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--app=+[github url]:url:_urls' \
                    '--envName=+[env name]:str:' \
                    '--amplify=+[amplify config]:str:' \
                    '--frontend=+[frontend config]:str:' \
                    '--providers=+[providers]:str:' \
                    '--categories=+[categories]:str:' \
                    '--profile=+[profile]:str:' ;;
                push|pull|publish) _arguments \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '--codegen[codegen]' \
                    '--no-codegen[no codegen]' \
                    '--allow-destructive-graphql-schema-updates[allow destructive schema updates]' ;;
                add|update|remove) _arguments \
                    '1:category:(api auth analytics function hosting storage notifications interactions predictions xr custom geo)' ;;
                env:add|env:checkout|env:remove|env:get|env:pull|env:push) _arguments \
                    '1:env name:' \
                    '--name=+[env name]:str:' ;;
            esac
            ;;
    esac
}

_amplify-cli "$@"
