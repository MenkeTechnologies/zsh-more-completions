#compdef qpid-route

local curcontext="$curcontext" state line ret=1
local -a top

top=(
  'dynamic:dynamic route management'
  'route:static route management'
  'queue:queue route management'
  'link:link management'
  'list:list routes'
  'flush:flush routes'
  'map:map routes between brokers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-d[durable route]' \
  '-e[delete empty link with route]' \
  '-s[src-local route]' \
  '-t[transport]:transport:' \
  '1: :->op' \
  '*::arg:->args' && ret=0

case $state in
  (op)
    _describe -t top 'qpid-route op' top && ret=0
    ;;
  (args)
    case $line[1] in
      (dynamic)
        _values 'dynamic action' 'add' 'del' && ret=0
        ;;
      (route)
        _values 'route action' 'add' 'del' 'list' 'flush' 'map' && ret=0
        ;;
      (queue)
        _values 'queue action' 'add' 'del' && ret=0
        ;;
      (link)
        _values 'link action' 'add' 'del' 'list' && ret=0
        ;;
    esac
    ;;
esac

return ret
