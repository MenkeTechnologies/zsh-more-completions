#compdef aicm

_aicm() {
    local line state
    local -a commands
    commands=(
        'setup:Configure AI provider and API keys'
        'help:View current configuration and help'
        'backup:Backup configs to a local folder'
        'restore:Restore configs and install missing tools'
        'sync:Sync backups to a private Git repo'
        'update:Update all AI tools'
    )

    _arguments -C \
        '(-p --provider)'{-p,--provider}'[Switch AI providers]:provider:(openai ollama groq anthropic gemini)' \
        '(-m --models)'{-m,--models}'[Interactively select a model]' \
        '(-f --format)'{-f,--format}'[Choose message format]:format:(simple conventional gitmoji)' \
        '1: :->command' \
        '*: :_files'

    case $state in
        command)
            _describe -t commands 'aicm command' commands
            ;;
    esac
}

_aicm "$@"
