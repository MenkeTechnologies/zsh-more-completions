#compdef size-limit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--json[output as JSON]' \
  '--why[show analysis of bundle contents]' \
  '--save-bundle=[save bundle to directory]:directory:_directories' \
  '--clean-dir[clean output directory before saving]' \
  '--hide-passed[hide passed checks]' \
  '--highlight-less[highlight less in output]' \
  '--compare-with=[compare with base branch]:branch:->branches' \
  '--debug[enable debug output]' && ret=0

case $state in
  (branches)
    local -a branches
    branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
    _describe -t branches 'branch' branches && ret=0
    ;;
esac

return ret
