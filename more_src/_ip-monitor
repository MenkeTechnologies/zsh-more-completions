#compdef ip-monitor
# Documentation: https://man.archlinux.org/man/ip-monitor.8.en
# ip monitor - watch netlink state changes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t -timestamp)'{-t,-timestamp}'[add timestamp on separate line]' \
  '(-ts -tshort)'{-ts,-tshort}'[add short timestamp on event line]' \
  '*::object:->objs' && ret=0

case $state in
  objs)
    _values 'ip monitor object' \
      'all[monitor all object types]' 'link[link events]' 'address[address events]' \
      'route[route events]' 'mroute[mroute events]' 'maddress[multicast address events]' \
      'acaddress[anycast address events]' 'prefix[prefix events]' \
      'neigh[neighbour events]' 'netconf[netconf events]' 'rule[rule events]' \
      'stats[stats events]' 'nsid[nsid events]' 'nexthop[nexthop events]' \
      'label[show message family prefix]' 'all-nsid[listen to all nsid namespaces]' \
      'dev[only events for device]' 'file[read from saved binary file]' && ret=0
    ;;
esac

return ret
