#compdef impacket-tstool

# Impacket tstool.py: Terminal Services / RDP utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug output]' \
  '-target[target user[:pwd]@host]:target:' \
  '-hashes[NTLM hashes LM:NT]:hashes:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos]' \
  '-aesKey[Kerberos AES key]:key:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target host IP]:ip:' \
  '-port[connection port]:port:' \
  '-codec[encoding codec]:codec:' \
  '-debug-stdout[debug to stdout]' \
  '*::tstool subcmd:_files' && ret=0
return ret
