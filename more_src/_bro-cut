#compdef bro-cut
# _bro-cut — Zeek formerly Bro bro-cut CLI for extracting columns from Zeek tab-separated log files preserving header rows handling time conversions and accepting log streams via stdin (zeek team, C); getopt
# upstream: https://github.com/zeek/zeek-aux

_bro-cut() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c[also print comments]' \
        '-C[do not print comments]' \
        '-d[use UTC times]' \
        '-D+[time format]:str:' \
        '--time-format=+[fmt]:str:' \
        '-F+[separator]:str:' \
        '--field-separator=+[sep]:str:' \
        '-m[output missing as -]' \
        '-n+[unset character]:str:' \
        '-N[no newline]' \
        '-u[use ISO 8601 UTC]' \
        '-U[use ISO 8601 local]' \
        '-w[show available fields]' \
        '*:column names:'
}

_bro-cut "$@"
