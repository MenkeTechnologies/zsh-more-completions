#compdef cloudflared
# _cloudflared-cli — Cloudflare Tunnel daemon (Go); zero-trust tunnels to private resources via cloudflare edge
# upstream: https://github.com/cloudflare/cloudflared

_cloudflared-cli() {
    local -a sub=(
        'tunnel:manage Tunnels'
        'access:Cloudflare Access helpers'
        'service:install/uninstall as system service'
        'update:update binary'
        'proxy-dns:run a recursive DNS-over-HTTPS proxy'
        'login:authenticate against your Cloudflare account'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--config+[YAML config]:file:_files -g "*.yml"' \
        '--origincert+[origin cert]:file:_files' \
        '--credentials-file+[credentials JSON]:file:_files -g "*.json"' \
        '--loglevel+[log level]:level:(debug info warn error fatal)' \
        '--transport-loglevel+[transport log level]:level:(debug info warn error fatal)' \
        '--metrics+[metrics bind]:addr:' \
        '--proto+[protocol]:proto:(http2 quic)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cloudflared subcommand' sub ;;
        args)
            case $words[1] in
                tunnel) _arguments \
                    '1:tunnel cmd:(login create delete list info route run cleanup token ingress)' \
                    '*:args:' ;;
                service) _arguments '1:action:(install uninstall)' ;;
                proxy-dns) _arguments \
                    '--port+[bind port]:port:' \
                    '--address+[bind addr]:host:_hosts' \
                    '--upstream+[upstream DoH]:url:_urls' ;;
            esac
            ;;
    esac
}

_cloudflared-cli "$@"
