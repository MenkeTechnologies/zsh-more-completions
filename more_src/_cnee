#compdef cnee gnee
# Documentation: https://man.archlinux.org/search?q=cnee
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --record)'{-r,--record}'[record session]' \
  '(-rt --replay)'{-rt,--replay}'[replay session]' \
  '--retype[retype session]' \
  '(-d --distribute)'{-d+,--distribute=}'[distribute events to displays csv]:list:' \
  '(-o --out-file)'{-o+,--out-file=}'[output file]:file:_files' \
  '(-e --err-file)'{-e+,--err-file=}'[error file]:file:_files' \
  '(-f --file)'{-f+,--file=}'[input file]:file:_files' \
  '(-t --time)'{-t+,--time=}'[delay seconds before start]:secs:' \
  '(-l --loops)'{-l+,--loops=}'[event count to record]:n:' \
  '(-sk --stop-key)'{-sk+,--stop-key=}'[stop key sequence]:keys:' \
  '(-pk --pause-key)'{-pk+,--pause-key=}'[pause key sequence]:keys:' \
  '(-rk --resume-key)'{-rk+,--resume-key=}'[resume key sequence]:keys:' \
  '(-fk --fast-key)'{-fk+,--fast-key=}'[fast forward key]:keys:' \
  '(-bk --back-key)'{-bk+,--back-key=}'[back/rewind key]:keys:' \
  '(-rwp --recall-window-position)'{-rwp,--recall-window-position}'[recall window pos on replay]' \
  '(-sp --speed-percent)'{-sp+,--speed-percent=}'[replay speed pct]:pct:' \
  '(-ev --events-to-record)'{-ev+,--events-to-record=}'[events list]:list:' \
  '(-de --device-event-range)'{-de+,--device-event-range=}'[device range]:range:' \
  '(-sre --synchronised-replay)'{-sre,--synchronised-replay}'[synchronised replay]' \
  '(-ns --no-synchronise)'{-ns,--no-synchronise}'[no sync replay]' \
  '(-mt --mouse-time-multiplier)'{-mt+,--mouse-time-multiplier=}'[mouse time mult]:n:' \
  '(-rd --record-display)'{-rd+,--record-display=}'[record display]:display:' \
  '(-di --display)'{-di+,--display=}'[display]:display:' \
  '(-keyboard --keyboard)'{-keyboard,--keyboard}'[record keyboard]' \
  '(-mouse --mouse)'{-mouse,--mouse}'[record mouse]' \
  '(-all-events)-all-events[record all events]' \
  '(-all-clients)-all-clients[record all clients]' \
  '(-future-clients)-future-clients[record future clients]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0

return ret
