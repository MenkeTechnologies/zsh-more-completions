#compdef sfwarp1
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: multicomponent data registration by 1-D warping

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'niter=[number of iterations]:niter:' \
  'nliter=[number of nonlinear iterations]:nliter:' \
  'accuracy=[interpolation accuracy]:accuracy:' \
  'warpin=[input warp file]:warpin:_files' \
  'rect1=[smoothing radius on first axis]:rect1:' \
  'arect1=[smoothing radius for derivative]:arect1:' \
  'noamp=[do not estimate amplitude (y/n)]:noamp:(y n)' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
