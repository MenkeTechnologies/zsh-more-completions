#compdef force-pyramid
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/pyramid.html
# FORCE: generate image pyramids (overviews)

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-j)-j[number of parallel jobs]:jobs:' \
  '(-r)-r[resampling method]:method:' \
  '(-l)-l[pyramid levels (comma-separated)]:levels:' \
  '*:image:_files' && ret=0

return ret
