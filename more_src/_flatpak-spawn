#compdef flatpak-spawn

# Zsh completion for flatpak-spawn (run commands in Flatpak sandboxes)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--host[run command on host system]' \
  '--latest-version[use latest version of app]' \
  '--sandbox[run in a new sandbox]' \
  '--no-network[disable network access]' \
  '--sandbox-expose[expose path to sandbox]:path:_files' \
  '--sandbox-expose-ro[expose path read-only to sandbox]:path:_files' \
  '--sandbox-flag[sandbox flags]:flag' \
  '--directory[working directory]:directory:_files -/' \
  '--watch-bus[exit when caller disconnects]' \
  '--clear-env[start with empty environment]' \
  '--env[set environment variable]:var=value' \
  '--unset-env[unset environment variable]:variable' \
  '--verbose[enable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:_command_names -e' \
  '*:arguments' && ret=0

return ret
