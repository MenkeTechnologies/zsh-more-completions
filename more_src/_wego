#compdef wego
# Documentation: https://github.com/schachmat/wego
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# wego: weather client for the terminal. README documents only --frontend,
# --monochrome, --cache-ttl, --man and positional args (location, days).
# Settings are normally configured in ~/.wegorc.
local curcontext="$curcontext" ret=1
_arguments -C \
  '--frontend=[output frontend]:frontend:(ascii-art-table emoji json)' \
  '--monochrome[disable colored output]' \
  '--cache-ttl=[cache TTL]:duration:' \
  '--man[show built-in man page]' \
  '*:location/days:' && ret=0
return ret
