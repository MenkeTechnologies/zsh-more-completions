#compdef wego

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --city)'{-c,--city}'[city to show weather for]:city name' \
  '(-f --frontend)'{-f,--frontend}'[frontend to use]:frontend:(ascii-art-table)' \
  '(-b --backend)'{-b,--backend}'[weather data backend]:backend:(openweathermap worldweatheronline forecast.io)' \
  '(-d --days)'{-d,--days}'[number of days to forecast]:days' \
  '(-u --units)'{-u,--units}'[unit system]:units:(metric imperial si)' \
  '(-l --lang)'{-l,--lang}'[language code]:language'
