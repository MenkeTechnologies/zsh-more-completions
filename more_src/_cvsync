#compdef cvsync
# Documentation: https://man.freebsd.org/cgi/man.cgi?cvsync
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cvsync: portable BSD CVS repository synchronization utility.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-4[force IPv4 only]' \
  '-6[force IPv6 only]' \
  '-L[force errormode=fixup for all collections]' \
  '-V[print version to stderr]' \
  '-Z[disable compression]' \
  '-z[enable compression]' \
  '-c+[config and collections file]:file:_files' \
  '-h[print default config location and protocol revision]' \
  '-p+[pid file]:file:_files' \
  '-q[silent mode]' \
  '-v[verbose mode]' && ret=0

return ret
