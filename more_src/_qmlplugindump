#compdef qmlplugindump

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-nonrelocatable[non-relocatable plugin]' \
  '-relocatable[relocatable plugin]' \
  '-noinstantiate[do not instantiate types]' \
  '-defaultplatform[force default platform]' \
  '-dependencies[generate dependencies file]:file:_files' \
  '-merge[merge with existing JSON]:file:_files' \
  '-output[output file]:file:_files' \
  '-v[verbose]' \
  '1:URI:' \
  '2:major.minor version:' \
  '3::import path:_files -/' && ret=0

return ret
