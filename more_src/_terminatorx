#compdef terminatorx terminatorX
# Documentation: https://manpages.debian.org/testing/terminatorx/terminatorX.1.en.html
# terminatorX realtime audio synthesizer / scratching tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help info]' \
  '(-f --file)'{-f,--file}'[load saved terminatorX set file]:set file:_files' \
  '(-r --rc-file)'{-r,--rc-file}'[load alternate rc file]:rc file:_files' \
  '(-d --dont-save)'{-d,--dont-save}'[do not save settings at exit]' \
  '(-s --std-out)'{-s,--std-out}'[use stdout for sound output]' \
  '--device=[use alternate device for sound output]:output device' \
  '*:set file:_files' && ret=0

return ret
