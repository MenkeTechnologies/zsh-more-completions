#compdef cshark
# Documentation: https://github.com/cloudshark/cshark (src/cshark.c getopt "i:w:s:T:P:S:p:kvh")
# Reference accessed: 2026-05-30
# cshark — CloudShark capture client. Records traffic + uploads to cloudshark.org. OpenWrt-focused.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[display help message]' \
  '-v[show version information]' \
  '-i+[listen on interface]:iface:_net_interfaces' \
  '-w+[write raw packets to this file]:file:_files' \
  '-s+[snarf snaplen bytes of data]:bytes:' \
  '-k[keep the file after uploading to cloudshark.org]' \
  '-T+[stop capture after N seconds (0 = no timeout)]:sec:' \
  '-P+[stop capture after N packets (0 = no limit)]:N:' \
  '-S+[stop capture after N bytes saved (0 = no limit)]:bytes:' \
  '-p+[save PID to a file]:file:_files' \
  && ret=0

return ret
