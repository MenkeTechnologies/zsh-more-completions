#compdef pdftops

_arguments -s \
  '(- *)-v[show version]' \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-f=[first page]:n:' \
  '-l=[last page]:n:' \
  '-eps[generate Encapsulated PostScript]' \
  '-pdf[generate PDF (PS-shell)]' \
  '-level1[level 1 PostScript]' \
  '-level1sep[level 1 separable PostScript]' \
  '-level2[level 2 PostScript]' \
  '-level2sep[level 2 separable PostScript]' \
  '-level3[level 3 PostScript]' \
  '-level3sep[level 3 separable PostScript]' \
  '-origpagesizes[use original page sizes]' \
  '-paper=[paper size]:size:(A4 letter legal)' \
  '-paperw=[paper width]:px:' \
  '-paperh=[paper height]:px:' \
  '-r=[resolution DPI]:dpi:' \
  '-binary[write binary PostScript]' \
  '-noembt1[do not embed Type 1 fonts]' \
  '-noembtt[do not embed TrueType fonts]' \
  '-noembcidps[do not embed CID PostScript fonts]' \
  '-noembcidtt[do not embed CID TrueType fonts]' \
  '-passfonts[pass fonts through]' \
  '-preload[preload images and forms]' \
  '-expand[expand to paper size]' \
  '-noshrink[do not shrink to fit]' \
  '-nocenter[do not center on paper]' \
  '-duplex[print duplex]' \
  '-opw=[owner password]:password:' \
  '-upw=[user password]:password:' \
  '-q[do not print errors]' \
  '*:input:_files -g "*.pdf"'
