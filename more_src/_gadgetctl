#compdef gadgetctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run a gadget instance'
  'list:list running gadget instances'
  'attach:attach to a running instance'
  'detach:detach from an instance'
  'delete:delete an instance'
  'logs:show instance logs'
  'image:manage gadget images'
  'config:manage configuration'
  'completion:generate shell completion'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '--remote-address=[remote daemon address]:addr:' \
  '--detach[run detached]' \
  '(-o --output)'{-o,--output=}'[output format]:fmt:(columns json yaml)' \
  '--verify-image[verify gadget image signature]' \
  '--public-keys=[public keys for verification]:keys:' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--config=[config file]:file:_files' \
  '--authfile=[auth file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'gadgetctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (image)
        _values 'image action' 'pull' 'push' 'build' 'tag' 'list' 'inspect' 'export' 'import' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
