#compdef fitpatches
# Documentation: https://bio3d.colorado.edu/imod/doc/man/fitpatches.html
# Manage and fit to patch vector files for supermontaging

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-info -i -InfoFile)'{-info,-i,-InfoFile}'[Name of a supermontage info file in which all data about...]:file:_files' \
  '(-xrun -x -XRunStartEnd)'{-xrun,-x,-XRunStartEnd}'[Starting and ending frame number in X for patch files to...]:value' \
  '(-yrun -y -YRunStartEnd)'{-yrun,-y,-YRunStartEnd}'[Starting and ending frame number in Y for patch files to...]:value' \
  '(-zrun -z -ZRunStartEnd)'{-zrun,-z,-ZRunStartEnd}'[Starting and ending Z value for patch files to analyze]:value' \
  '(-target -t -TargetMeanResidual)'{-target,-t,-TargetMeanResidual}'[Multiple floats]' \
  '(-clip -c -ClippingPlaneBoxSize)'{-clip,-c,-ClippingPlaneBoxSize}'[Four clipping planes will be added to the reduced and...]:value' \
  '(-scale -s -ScaleFactor)'{-scale,-s,-ScaleFactor}'[Factor for scaling vectors in reduced and residual models....]:value' \
  '(-rescale -r -RescaleModels)'{-rescale,-r,-RescaleModels}'[Remake the reduced and residual models with the current...]' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
