#compdef ocp-browser
# Documentation: https://man.archlinux.org/search?q=ocp-browser
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-I+[include path]:dir:_files -/' \
  '*:ml file:_files -g "*.{ml,mli}"' && ret=0

return ret
