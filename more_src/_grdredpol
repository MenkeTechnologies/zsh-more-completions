#compdef grdredpol
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/potential — reduce magnetic anomaly grid to the pole

local ret=1

_arguments -s \
  '-C+[constant declination/inclination of field and magnetization]:angles:_default' \
  '-E+[magnetization inclination/declination grids]:grids:_default' \
  '-F+[filter window size row/column]:size:_default' \
  '-G+[output RTP grid filename]:file:_files' \
  '-M+[boundary conditions mirror|replicate]:bc:(m r)' \
  '-N[disable Taylor expansion]' \
  '-R+[output region]:region:_default' \
  '-T+[decimal year for IGRF]:year:_default' \
  '-W+[moving window size in degrees]:size:_default' \
  '-Z+[write filter coefficients to grid]:file:_files' \
  '*-V[verbose (stackable)]' \
  '-n+[grid interpolation mode]:mode:_default' \
  '*:input grid:_files' \
  && ret=0

return ret
