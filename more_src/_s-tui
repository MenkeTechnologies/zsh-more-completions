#compdef s-tui

# Zsh completion for s-tui (Stress Terminal UI)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-V[Show version]' \
  '--version[Show version]' \
  '-d[Debug mode, outputs to s-tui_log.txt]' \
  '--debug[Debug mode, outputs to s-tui_log.txt]' \
  '-c[Dump data to CSV file]' \
  '--csv[Dump data to CSV file]' \
  '-t[Run stress test on startup]' \
  '--test[Run stress test on startup]' \
  '-j[Output JSON data]' \
  '--json[Output JSON data]' \
  '-n[Show only sensors available in JSON mode]' \
  '--no-smooth[Disable graph smoothing]' \
  '-nm[Disable mouse support]' \
  '--no-mouse[Disable mouse support]' \
  '-tt+[Set terminal temperature threshold]:threshold (°C):' \
  '--t_thresh=[Set terminal temperature threshold]:threshold (°C):' \
  '--sensor-path=[Specify sensor path]:path:_files' \
  '--gpio-fan-path=[Specify GPIO fan path]:path:_files' && return 0
