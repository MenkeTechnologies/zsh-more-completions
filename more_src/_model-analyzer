#compdef model-analyzer
# Documentation: https://docs.nvidia.com/deeplearning/triton-inference-server/user-guide/docs/model_analyzer/docs/cli.html
# NVIDIA Triton Model Analyzer for profiling and analyzing model configurations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging output except errors]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-m --mode)'{-m,--mode}'=[execution context]:mode:(online offline)' \
  '(-f --config-file)'{-f,--config-file}'=[path to YAML configuration file]:file:_files -g "*.yaml *.yml"' \
  '--checkpoint-directory=[directory for profiling checkpoints]:dir:_files -/' \
  '--profile-models=[comma separated models to profile]:models:' \
  '--output-model-repository-path=[directory for generated model config variants]:dir:_files -/' \
  '--latency-budget=[latency constraint for online mode]:ms:' \
  '--min-throughput=[minimum throughput threshold for offline mode]:n:' \
  '--run-config-search-mode=[config search strategy]:mode:(brute quick optuna)' \
  '(-e --export-path)'{-e,--export-path}'=[output directory for reports]:dir:_files -/' \
  '1:command:(profile report analyze)' \
  '*::arg:->args' && ret=0

return ret
