#compdef memcached-tool
# Documentation: https://github.com/memcached/memcached/blob/master/scripts/memcached-tool
# Reference accessed: 2026-05-19
# Verified: upstream scripts/memcached-tool usage section.

# Zsh completion for memcached-tool - stats/dump/show slabs of a memcached instance

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:host\:port' \
  '2:mode:(display stats settings sizes dump keys move)' \
  '*:extra:_files' && ret=0

return ret
