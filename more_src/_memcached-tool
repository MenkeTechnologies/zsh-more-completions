#compdef memcached-tool
# Documentation: https://man.archlinux.org/search?q=memcached-tool
# Reference accessed: 2026-05-16

# Zsh completion for memcached-tool - stats/dump/show slabs of a memcached instance

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:host\:port' \
  '2:mode:(display stats settings sizes dump move)' && ret=0

return ret
