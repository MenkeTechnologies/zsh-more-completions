#compdef asprof
# _asprof — async-profiler command-line interface
# upstream: https://github.com/async-profiler/async-profiler

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-e --event)'{-e,--event=}'[profiling event]:event:(cpu alloc lock wall itimer ctimer)' \
    '(-d --duration)'{-d,--duration=}'[profiling duration in seconds]:seconds:' \
    '(-i --interval)'{-i,--interval=}'[sampling interval]:interval:' \
    '(-j --jstackdepth)'{-j,--jstackdepth=}'[maximum Java stack depth]:depth:' \
    '(-t --threads)'{-t,--threads}'[profile different threads separately]' \
    '(-s --simple)'{-s,--simple}'[simple class names instead of FQN]' \
    '(-o --output)'{-o,--output=}'[output file name]:file:_files' \
    '(-f --file)'{-f,--file=}'[output file name (deprecated, use -o)]:file:_files' \
    '--title=[flame graph title]:title:' \
    '--minwidth=[minimum frame width in pixels]:pixels:' \
    '--reverse[generate reverse flame graph]' \
    '(-I --include)'{-I,--include=}'[include only matching stack traces]:pattern:' \
    '(-X --exclude)'{-X,--exclude=}'[exclude matching stack traces]:pattern:' \
    '--all-user[include only user-mode events]' \
    '--all-kernel[include only kernel-mode events]' \
    '--cstack=[C stack walking mode]:mode:(fp dwarf lbr no)' \
    '--begin=[start profiling when function is called]:function:' \
    '--end=[stop profiling when function is called]:function:' \
    '--loop=[run profiler in a loop]:duration:' \
    '--chunksize=[approximate size of JFR chunk]:bytes:' \
    '--chunktime=[duration of JFR chunk]:seconds:' \
    '--jfrsync=[synchronize with JFR recording]:config:' \
    '--lib=[load agent library]:path:_files' \
    '1:action:(start stop resume dump check status list collect)' \
    '2:pid or command:_pids' \
    && return 0
