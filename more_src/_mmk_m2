#compdef mmk_m2
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/mmk_m2.1.html
# Scotch: create a 2D mesh source file

local ret=1

_arguments -s \
  '-g-[output graph vertex coordinates (geometry) to file]:cfile:_files' \
  '-h[display help]' \
  '-V[display version and copyright]' \
  '*:file:_files' && ret=0

return ret
