#compdef rados

# Zsh completion for rados - RADOS object store utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'ls:list objects in a pool'
  'get:fetch an object'
  'put:write an object'
  'rm:remove an object'
  'stat:stat an object'
  'cp:copy an object'
  'append:append data to an object'
  'truncate:truncate an object'
  'create:create an object'
  'getxattr:get an extended attribute'
  'setxattr:set an extended attribute'
  'rmxattr:remove an extended attribute'
  'listxattr:list extended attributes'
  'lspools:list pools'
  'mkpool:create a pool'
  'rmpool:delete a pool'
  'cppool:copy a pool'
  'purge:remove all objects from a pool'
  'df:show pool utilization statistics'
  'bench:run benchmarks'
  'cleanup:clean up benchmark data'
  'watch:watch for object notifications'
  'notify:send notification to object watchers'
  'listwatchers:list watchers on an object'
  'lock:lock an object'
  'unlock:unlock an object'
  'listlockers:list lockers on an object'
  'export:export pool contents to a file'
  'import:import pool contents from a file'
  'cache-flush:flush a cache tier'
  'cache-try-flush:try to flush a cache tier'
  'cache-evict:evict an object from a cache tier'
  'cache-flush-evict-all:flush and evict all objects from a cache tier'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --pool)'{-p,--pool}'[pool name]:pool' \
  '--pgid=[PG id]:pgid' \
  '(-N --namespace)'{-N,--namespace}'[RADOS namespace]:namespace' \
  '(-s --snap)'{-s,--snap}'[snapshot name]:snap' \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' \
  '--create[create the pool or directory if missing]' \
  '--order=[object size for benchmarking (in bytes)]:bytes' \
  '--block-size=[block size for benchmarking]:bytes' \
  '-b[block size for benchmarking]:bytes' \
  '-t[concurrent operations for benchmarking]:count' \
  '--run-name=[benchmark run name]:name' \
  '--no-cleanup[do not clean up after write bench]' \
  '--no-hints[do not send osd data placement hints]' \
  '-n[client name]:name' \
  '--id=[client id]:id' \
  '-c[ceph configuration file]:file:_files' \
  '--keyring=[keyring file]:file:_files' \
  '-m[monitor addresses]:address' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rados command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (bench)
        _arguments -s -S \
          '1:seconds:' \
          '2:mode:(write seq rand)' && ret=0
        ;;
      (get|stat|rm|create|truncate|watch|listwatchers)
        _arguments '1:object name' && ret=0
        ;;
      (put|append)
        _arguments '1:object name' '2:input file:_files' && ret=0
        ;;
      (cp)
        _arguments '1:source object' '2:destination object' && ret=0
        ;;
      (getxattr|rmxattr)
        _arguments '1:object name' '2:attribute name' && ret=0
        ;;
      (setxattr)
        _arguments '1:object name' '2:attribute name' '3:attribute value' && ret=0
        ;;
      (listxattr)
        _arguments '1:object name' && ret=0
        ;;
      (mkpool|rmpool|purge)
        _arguments '1:pool name' && ret=0
        ;;
      (cppool)
        _arguments '1:source pool' '2:destination pool' && ret=0
        ;;
      (export)
        _arguments '1:output file:_files' && ret=0
        ;;
      (import)
        _arguments '1:input file:_files' && ret=0
        ;;
      (lock)
        _arguments '1:object name' '2:lock name' && ret=0
        ;;
      (unlock)
        _arguments '1:object name' '2:lock name' '3:locker name' && ret=0
        ;;
    esac
    ;;
esac

return ret
