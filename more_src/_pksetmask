#compdef pksetmask
# Documentation: https://pktools.nongnu.org/html/pksetmask.html
# apply mask to raster image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input image]:file:_files' \
  '(-m --mask)'{-m,--mask}'[Mask image(s)]:file:_files' \
  '(-msknodata --msknodata)'{-msknodata,--msknodata}'[Mask value(s) where image has nodata. Use one value for each mask, or]:value:' \
  '(-mskband --mskband)'{-mskband,--mskband}'[Mask band to read (0 indexed). Provide band for each mask.]:value:' \
  '(-o --output)'{-o,--output}'[Output mask file]:file:_files' \
  '(-nodata --nodata)'{-nodata,--nodata}'[nodata value to put in image if not valid]:value:' \
  '(-p --operator)'{-p,--operator}'[Operator\: < = > !. Use operator for each msknodata option]:value:' \
  '(-ot --otype)'{-ot,--otype}'[Data type for output image ({Byte/Int16/UInt16/UInt32/Int32/Float32/Fl]:value:' \
  '(-of --oformat)'{-of,--oformat}'[Output image format (see also gdal_translate)]:value:' \
  '(-co --co)'{-co,--co}'[Creation option for output file. Multiple options can be specified.]:value:' \
  '(-ct --ct)'{-ct,--ct}'[color table (file with 5 columns\: id R G B ALFA (0\: transparent, 255\:]:file:_files' \
  '*:file:_files' && ret=0

return ret
