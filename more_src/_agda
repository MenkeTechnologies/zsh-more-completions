#compdef agda

# Zsh completion for agda - a dependently typed functional programming language and proof assistant

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[print version number]' \
  '(-?  --help)'{-\?,--help}'[show help]' \
  '(-i --include-path)'{-i+,--include-path=}'[look for imports in DIR]:dir:_directories' \
  '(-l --library)'{-l+,--library=}'[use library]:library' \
  '--library-file=[use given library file]:file:_files' \
  '--no-libraries[do not use any library files]' \
  '--no-default-libraries[do not use default libraries]' \
  '(-c --compile)'{-c,--compile}'[compile program using GHC backend]' \
  '--ghc[compile using the GHC backend]' \
  '--js[compile using the JavaScript backend]' \
  '--compile-dir=[directory for compiler output]:dir:_directories' \
  '--ghc-dont-call-ghc[do not call GHC]' \
  '--ghc-flag=[pass flag to GHC]:flag' \
  '--interactive[start in interactive mode]' \
  '--interaction[for use with editors]' \
  '--interaction-json[JSON interaction for editors]' \
  '--html[generate HTML files]' \
  '--html-dir=[directory for HTML output]:dir:_directories' \
  '--html-highlight=[HTML highlight mode]:mode:(all code auto)' \
  '--css=[CSS file to use]:file:_files' \
  '--latex[generate LaTeX files]' \
  '--latex-dir=[directory for LaTeX output]:dir:_directories' \
  '--count-clusters[count grapheme clusters]' \
  '--vim[generate vim tag files]' \
  '--ignore-interfaces[ignore existing interface files]' \
  '--ignore-all-interfaces[ignore all interface files]' \
  '(-v --verbose)'{-v+,--verbose=}'[set verbosity level]:n' \
  '--allow-unsolved-metas[allow unsolved meta-variables]' \
  '--allow-incomplete-matches[allow incomplete matches]' \
  '--no-positivity-check[do not perform positivity check]' \
  '--no-termination-check[do not perform termination check]' \
  '--type-in-type[allow Set : Set]' \
  '--sized-types[enable sized types]' \
  '--without-K[disable axiom K]' \
  '--with-K[enable axiom K]' \
  '--cubical[enable cubical mode]' \
  '--safe[require safe flag to be used]' \
  '--double-check[double check all terms]' \
  '--no-unicode[disable unicode in output]' \
  '--syntactic-equality[use syntactic equality]' \
  '--copatterns[enable copatterns]' \
  '--no-copatterns[disable copatterns]' \
  '--no-pattern-matching[disable pattern matching]' \
  '--exact-split[require exact split in pattern matching]' \
  '--no-eta-equality[disable eta equality]' \
  '--rewriting[enable rewriting rules]' \
  '--confluence-check[check confluence of rewrite rules]' \
  '--no-irrelevant-projections[disable irrelevant projections]' \
  '--no-forcing[disable forcing]' \
  '--no-print-pattern-synonyms[do not unfold pattern synonyms]' \
  '*:file:_files -g "*.(agda|lagda|lagda.md|lagda.rst|lagda.tex)"' && ret=0

return ret
