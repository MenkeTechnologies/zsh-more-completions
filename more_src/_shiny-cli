#compdef shiny-cli shiny
# _shiny-cli — Posit RStudio shiny-cli CLI command-line frontend for the Shiny R interactive web application framework providing run-app-create-app-deploy-app-static-export modes around shinyServer expressions reactive-bindings htmlwidgets bs4Dash bslib templated themes hosting through Shiny Server Open Source Posit Connect (Posit team, R); custom argparse
# upstream: https://shiny.posit.co/

_shiny-cli() {
    local -a sub=(
        'run:run an app from a directory'
        'create:scaffold a new app'
        'deploy:deploy to Shiny Server Posit Connect'
        'static:render static html output'
        'reload:reload the running app'
        'add:add a module or component'
        'rsconnect-deploy:deploy via rsconnect'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--launch-browser[launch browser]' \
        '--no-launch-browser[no browser]' \
        '--reload[auto reload on file change]' \
        '--bookmark-store=+[m]:m:(disable url server)' \
        '--display-mode=+[m]:m:(auto normal showcase)' \
        '--debug[debug]' \
        '--log-level=+[l]:l:(TRACE DEBUG INFO WARN ERROR FATAL)' \
        '--workers=+[N]:n:' \
        '--template=+[name]:str:' \
        '--app-name=+[name]:str:' \
        '--account=+[name]:str:' \
        '--app-id=+[id]:str:' \
        '--server=+[url]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shiny-cli subcommand' sub ;;
        args)
            case $words[1] in
                run|deploy|static|reload) _arguments '*:app dir:_files -/' ;;
                create) _arguments '*:name:' ;;
            esac
            ;;
    esac
}

_shiny-cli "$@"
