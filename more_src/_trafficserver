#compdef trafficserver traffic_server
# Documentation: https://docs.trafficserver.apache.org/en/latest/appendices/command-line/traffic_server.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information]' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '(-a --accepts_thread)'{-a,--accepts_thread}'[enable accept threads]' \
  '(-B --action_tags)'{-B+,--action_tags=}'[action tags]:tags' \
  '--bind_stdout=[file to bind stdout stream]:file:_files' \
  '--bind_stderr=[file to bind stderr stream]:file:_files' \
  '(-C --command)'{-C+,--command=}'[maintenance command]:cmd:(list check clear clear_cache clear_hostdb verify_config verify_global_plugin verify_remap_plugin help)' \
  '(-f --disable_freelist)'{-f,--disable_freelist}'[disable caching of common data structures]' \
  '(-F --disable_pfreelist)'{-F,--disable_pfreelist}'[disable free lists in ProxyAllocator]' \
  '(-R --regression)'{-R+,--regression=}'[regression level]:level' \
  '(-r --regression_test)'{-r+,--regression_test=}'[regression test name]:test' \
  '(-l --regression_list)'{-l,--regression_list}'[list available regression tests]' \
  '(-T --debug_tags)'{-T+,--debug_tags=}'[debug tags]:tags' \
  '(-i --interval)'{-i+,--interval=}'[interval count]:count' \
  '(-m --maxRecords)'{-m+,--maxRecords=}'[max entries for metrics]:count' \
  '(-n --net_threads)'{-n+,--net_threads=}'[number of net threads]:count' \
  '(-k --clear_hostdb)'{-k,--clear_hostdb}'[clear hostdb]' \
  '(-K --clear_cache)'{-K,--clear_cache}'[clear cache]' \
  '--accept_mss=[accept TCP MSS]:mss' \
  '(-t --poll_timeout)'{-t+,--poll_timeout=}'[poll timeout in milliseconds]:msecs' \
  '(-p --httpport)'{-p+,--httpport=}'[http port]:port' \
  '(-U --udp_threads)'{-U+,--udp_threads=}'[number of UDP threads]:count' && ret=0

return ret
