#compdef trafficserver
# Documentation: https://man.archlinux.org/search?q=trafficserver
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start traffic_server'
  'stop:stop traffic_server'
  'restart:restart traffic_server'
  'reload:reload configuration'
  'status:show status'
  'condrestart:restart only if running'
  'try-restart:restart only if running'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'trafficserver command' commands && ret=0 ;;
esac

return ret
