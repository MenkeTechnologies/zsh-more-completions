#compdef tinyscheme scheme
# Documentation: https://github.com/dchest/tinyscheme
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (Manual.txt).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-?[show help]' \
  '-1+[load file (shebang #! mode)]:file:_files -g "*.scm"' \
  '-c+[execute Scheme commands]:scheme code:' \
  '*: :_files -g "*.scm"' && ret=0

return ret
