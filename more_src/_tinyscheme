#compdef tinyscheme scheme
# Documentation: https://man.archlinux.org/search?q=tinyscheme
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-?[show help]' \
  '-h[show help]' \
  '-1+[load and exit]:file:_files -g "*.scm"' \
  '-c+[evaluate expression]:expr:' \
  '*: :_files -g "*.scm"' && ret=0

return ret
