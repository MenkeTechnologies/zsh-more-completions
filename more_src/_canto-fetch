#compdef canto-fetch canto-daemon
# Documentation: https://man.archlinux.org/search?q=canto-fetch
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --dir)'{-D,--dir}'+[config directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-p --plugins)'{-p,--plugins}'+[plugin directory]:dir:_files -/' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-a --address)'{-a,--address}'+[listen address]:addr:' \
  '(-P --port)'{-P,--port}'+[listen port]:port:' \
  '(-n --no-fork)'{-n,--no-fork}'[do not fork]' && ret=0

return ret
