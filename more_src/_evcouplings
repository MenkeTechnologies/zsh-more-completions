#compdef evcouplings
# Documentation: https://github.com/debbiemarkslab/EVcouplings
# EVcouplings command-line application to run/configure coevolution workflows

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-P --prefix)'{-P,--prefix}'+[job output prefix]:prefix:' \
  '(-S --stages)'{-S,--stages}'+[stages to run]:stages:' \
  '(-p --protein)'{-p,--protein}'+[protein/job name]:protein:' \
  '(-s --seqfile)'{-s,--seqfile}'+[input sequence file]:seqfile:_files' \
  '(-a --alignment)'{-a,--alignment}'+[input alignment file]:alignment:_files' \
  '(-r --region)'{-r,--region}'+[region of sequence to use]:region:' \
  '(-b --bitscores)'{-b,--bitscores}'+[bitscore thresholds]:bitscores:' \
  '(-e --evalues)'{-e,--evalues}'+[E-value thresholds]:evalues:' \
  '(-n --iterations)'{-n,--iterations}'+[number of search iterations]:iterations:' \
  '(-d --database)'{-d,--database}'+[sequence database]:database:' \
  '(-i --id)'{-i,--id}'+[sequence identity threshold]:id:' \
  '(-f --seqcov)'{-f,--seqcov}'+[sequence coverage threshold]:seqcov:' \
  '(-m --colcov)'{-m,--colcov}'+[column coverage threshold]:colcov:' \
  '(-t --theta)'{-t,--theta}'+[sequence reweighting threshold]:theta:' \
  '--plmiter=[number of plmc iterations]:plmiter:' \
  '(-Q --queue)'{-Q,--queue}'+[compute queue]:queue:' \
  '(-T --time)'{-T,--time}'+[job time limit]:time:' \
  '(-N --cores)'{-N,--cores}'+[number of cores]:cores:' \
  '(-M --memory)'{-M,--memory}'+[memory limit]:memory:' \
  '(-y --yolo)'{-y,--yolo}'[do not validate config before running]' \
  '*:config:_files' && ret=0

return ret
