#compdef kiex

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcmds
    subcmds=(
      'install:Install an Elixir version'
      'list:List installed Elixir versions'
      'default:Set default Elixir version'
      'use:Use an Elixir version in the current shell'
      'shell:Set Elixir version for the current shell'
      'selfupdate:Update kiex itself'
      'uninstall:Uninstall an Elixir version'
      'help:Show help'
    )
    _describe -t commands 'kiex subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '1:version:' && ret=0
        ;;
      uninstall|default|use|shell)
        local -a installed_versions
        installed_versions=(${(f)"$(kiex list 2>/dev/null | grep -oE '[0-9]+\.[0-9]+[0-9.]*')"})
        _arguments -s -S \
          '1:version:compadd -a installed_versions' && ret=0
        ;;
    esac
    ;;
esac

return ret
