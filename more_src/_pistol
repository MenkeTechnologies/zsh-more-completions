#compdef pistol
# Documentation: https://man.archlinux.org/search?q=pistol
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[config file]:config file:_files' \
  '--config[config file]:config file:_files' \
  '1:file to preview:_files' && ret=0

return ret
