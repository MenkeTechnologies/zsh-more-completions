#compdef pistol
# Documentation: https://github.com/doronbehar/pistol
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration file]:config file:_files' \
  '1:file to preview:_files' \
  '*:extras:_files' && ret=0

return ret
