#compdef pt-table-sync
# Documentation: https://docs.percona.com/percona-toolkit/pt-table-sync.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--algorithms=[algorithm preference order]:algorithms:(Chunk Nibble GroupBy Stream)' \
  '--ask-pass[prompt for password]' \
  '--bidirectional[enable two-way sync between first and other hosts]' \
  '(--bin-log --no-bin-log)'{--bin-log,--no-bin-log}'[log changes to binary log]' \
  '--buffer-in-mysql[buffer results on MySQL server]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '(--buffer-to-client --no-buffer-to-client)'{--buffer-to-client,--no-buffer-to-client}'[fetch rows incrementally]' \
  '--channel=[replication channel name]:channel:' \
  '--charset=[default character set]:charset:' \
  '(--check-child-tables --no-check-child-tables)'{--check-child-tables,--no-check-child-tables}'[verify no cascading deletes]' \
  '(--check-replica --no-check-replica)'{--check-replica,--no-check-replica}'[check if destination is a replica]' \
  '(--check-source --no-check-source)'{--check-source,--no-check-source}'[verify detected source is authentic]' \
  '(--check-triggers --no-check-triggers)'{--check-triggers,--no-check-triggers}'[verify no triggers on destination]' \
  '--chunk-column=[column to chunk on]:column:' \
  '--chunk-index=[index to use for chunking]:index:' \
  '--chunk-size=[rows per chunk]:rows:' \
  '--columns=[columns to compare]:columns:' \
  '--config=[comma-separated config files]:files:_files' \
  '--conflict-column=[conflict column]:column:' \
  '--conflict-comparison=[conflict comparison]:comparison:(newest oldest greatest least equals matches)' \
  '--conflict-error=[error on conflict]:action:(warn die)' \
  '--conflict-threshold=[conflict threshold]:threshold:' \
  '--conflict-value=[conflict value]:value:' \
  '--databases=[databases to sync]:databases:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--dry-run[dry run - analyze without executing]' \
  '--engines=[engines to limit sync to]:engines:' \
  '--execute[execute the sync]' \
  '--explain-hosts[print connection information]' \
  '--float-precision=[float precision]:digits:' \
  '(--foreign-key-checks --no-foreign-key-checks)'{--foreign-key-checks,--no-foreign-key-checks}'[enable foreign key constraints]' \
  '--function=[hash function]:function:(CRC32 FNV_64 MD5 MURMUR_HASH SHA1)' \
  '(--hex-blob --no-hex-blob)'{--hex-blob,--no-hex-blob}'[use HEX() for binary columns]' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--ignore-columns=[columns to ignore]:columns:' \
  '--ignore-databases=[databases to ignore]:databases:' \
  '--ignore-engines=[engines to ignore]:engines:' \
  '--ignore-tables=[tables to ignore]:tables:' \
  '--ignore-tables-regex=[regex for tables to ignore]:regex:' \
  '(--index-hint --no-index-hint)'{--index-hint,--no-index-hint}'[add index hints to queries]' \
  '--lock=[lock level]:level:(0 1 2 3)' \
  '--lock-and-rename[atomic lock and rename]' \
  '--mysql_ssl=[create SSL connection]:n:' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--port=[MySQL port]:port:' \
  '--print[print SQL statements]' \
  '--recursion-method=[method to find replicas]:method:(processlist hosts dsn none)' \
  '--replace[use REPLACE for all inserts/updates]' \
  '--replica-password=[password for replica connections]:pw:' \
  '--replica-user=[user for replica connections]:user:' \
  '--replicate=[replicate table]:table:' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--sync-to-source[sync replica to its source]' \
  '--tables=[tables to sync]:tables:' \
  '--timeout-ok[continue if replica wait times out]' \
  '(--transaction --no-transaction)'{--transaction,--no-transaction}'[use transactions instead of locks]' \
  '--trim[TRIM VARCHAR in comparisons]' \
  '(--unique-checks --no-unique-checks)'{--unique-checks,--no-unique-checks}'[enable unique constraint checks]' \
  '--user=[MySQL user]:username:' \
  '--verbose[verbose output]' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '--wait=[seconds to wait for replicas]:sec:' \
  '--where=[WHERE clause]:where:' \
  '(--zero-chunk --no-zero-chunk)'{--zero-chunk,--no-zero-chunk}'[add chunk for zero values]' \
  '*:DSN:' && ret=0

return ret
