#compdef dep deployer
# Documentation: https://deployer.org/docs/7.x/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# deployphp/deployer — PHP deployment tool invoked as `dep` or `deployer`
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:deploy your project'
  'rollback:rollback to previous release'
  'run:run any task on hosts'
  'ssh:connect to host via SSH'
  'init:initialize deployer in the project'
  'autocomplete:dump the shell completion script'
  'tree:display the task-dependency tree'
  'config:display configuration'
  'blackjack:play blackjack easter egg'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[specify deploy file]:deploy file:_files -g "*.php"' \
  '--file=[specify deploy file]:deploy file:_files -g "*.php"' \
  '-l+[log output to file]:log file:_files' \
  '--log=[log output to file]:log file:_files' \
  '-p[run tasks in parallel]' \
  '--parallel[run tasks in parallel]' \
  '-o+[set option (key=value)]:option' \
  '--option=[set option (key=value)]:option' \
  '--limit=[restrict to specific hosts]:host pattern' \
  '--no-hooks[run task without hooks]' \
  '--plan[show execution plan]' \
  '--start-from=[start task execution from]:task name' \
  '-n[do not ask interactive questions]' \
  '--no-interaction[do not ask interactive questions]' \
  '-v[verbose mode]' \
  '-vv[more verbose]' \
  '-vvv[debug mode]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'deployer command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      deploy)
        _arguments -s -S \
          '--revision=[specify deploy revision]:revision' \
          '--branch=[deploy specific branch]:branch' \
          '--tag=[deploy specific tag]:tag' \
          '-s+[specify stage]:stage:(production staging development)' \
          '*:host:' && ret=0
        ;;
      rollback)
        _arguments -s -S \
          '*:host:' && ret=0
        ;;
      run)
        _arguments -s -S \
          '*:task name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
