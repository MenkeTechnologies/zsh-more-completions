#compdef ha
# Documentation: https://github.com/home-assistant/cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'addons:manage Home Assistant add-ons'
  'audio:manage Home Assistant audio'
  'backups:manage Home Assistant backups'
  'cli:manage the Home Assistant CLI'
  'core:manage Home Assistant Core'
  'dns:manage Home Assistant DNS'
  'hardware:show hardware info'
  'host:manage the host system'
  'info:show supervisor info'
  'jobs:manage jobs'
  'multicast:manage multicast'
  'network:manage networking'
  'observer:manage observer'
  'os:manage the operating system'
  'resolution:manage resolution center'
  'supervisor:manage the supervisor'
  'updates:list pending updates'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--api-token=[API token for authentication]:token:' \
  '--endpoint=[supervisor API endpoint]:url:' \
  '--log-level=[log verbosity]:level:(trace debug info warning error fatal)' \
  '--no-progress[disable progress output]' \
  '--raw-json[output raw JSON]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ha command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (core)
        local -a core_cmds=(
          'check:validate configuration'
          'info:show core info'
          'logs:show core logs'
          'options:set core options'
          'rebuild:rebuild core container'
          'restart:restart core'
          'start:start core'
          'stats:show core resource usage'
          'stop:stop core'
          'update:update core'
        )
        _describe -t commands 'core command' core_cmds && ret=0
        ;;
      (supervisor)
        local -a sup_cmds=(
          'info:show supervisor info'
          'logs:show supervisor logs'
          'options:set supervisor options'
          'reload:reload add-on store'
          'repair:repair supervisor'
          'restart:restart supervisor'
          'stats:show supervisor resource usage'
          'update:update supervisor'
        )
        _describe -t commands 'supervisor command' sup_cmds && ret=0
        ;;
      (host)
        local -a host_cmds=(
          'info:show host info'
          'logs:show host logs'
          'options:set host options'
          'reboot:reboot host'
          'reload:reload host info'
          'shutdown:shutdown host'
          'update:update host OS'
        )
        _describe -t commands 'host command' host_cmds && ret=0
        ;;
      (addons)
        local -a addon_cmds=(
          'info:show add-on info'
          'install:install add-on'
          'logs:show add-on logs'
          'options:set add-on options'
          'rebuild:rebuild add-on'
          'restart:restart add-on'
          'start:start add-on'
          'stats:show add-on resource usage'
          'stop:stop add-on'
          'uninstall:uninstall add-on'
          'update:update add-on'
        )
        _describe -t commands 'addons command' addon_cmds && ret=0
        ;;
      (backups)
        local -a backup_cmds=(
          'info:show backup info'
          'list:list all backups'
          'new:create new backup'
          'reload:reload backups'
          'remove:remove a backup'
          'restore:restore from backup'
        )
        _describe -t commands 'backups command' backup_cmds && ret=0
        ;;
      (network)
        local -a net_cmds=(
          'info:show network info'
          'options:set network options'
          'reload:reload network info'
          'update:update interface settings'
        )
        _describe -t commands 'network command' net_cmds && ret=0
        ;;
      (os)
        local -a os_cmds=(
          'info:show operating system info'
          'update:update the operating system'
        )
        _describe -t commands 'os command' os_cmds && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
