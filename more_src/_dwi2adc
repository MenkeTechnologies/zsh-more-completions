#compdef dwi2adc
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwi2adc.html
# Source: MRtrix3/mrtrix3 cmd/dwi2adc.cpp — convert DWI to apparent diffusion coefficient image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '1:input DWI:_files -g "*.{nii,nii.gz,mif}"' \
    '2:output ADC image:_files' \
    && ret=0

return ret
