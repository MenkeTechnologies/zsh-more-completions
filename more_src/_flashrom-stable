#compdef flashrom-stable

# flashrom-stable: stable channel of flashrom (same CLI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-R --version)'{-R,--version}'[show version]' \
  '(-r --read)'{-r,--read=}'[read chip to file]:file:_files' \
  '(-w --write)'{-w,--write=}'[write file to chip]:file:_files' \
  '(-v --verify)'{-v,--verify=}'[verify chip against file]:file:_files' \
  '(-E --erase)'{-E,--erase}'[erase chip]' \
  '(-N --noverify)'{-N,--noverify}'[skip verify after write]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-c --chip)'{-c,--chip=}'[force chip type]:chip:' \
  '(-l --layout)'{-l,--layout=}'[layout file]:file:_files' \
  '(-i --image)'{-i,--image=}'[only operate on region]:region:' \
  '(-p --programmer)'{-p,--programmer=}'[programmer type]:prog:(internal serprog ch341a_spi dummy buspirate_spi linux_spi linux_mtd ft2232_spi)' \
  '(-L --list-supported)'{-L,--list-supported}'[list supported chips]' \
  '(-o --output)'{-o,--output=}'[log file]:file:_files' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '*::flashrom-stable args:_files' && ret=0
return ret
