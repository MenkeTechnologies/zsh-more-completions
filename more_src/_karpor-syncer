#compdef karpor-syncer
# _karpor-syncer — KusionStack Karpor resource syncer (per-cluster informer that streams resources into Elasticsearch for karpor-server search)
# upstream: https://github.com/KusionStack/karpor
# Flags from cmd/karpor/app/syncer.go on tip.

_karpor-syncer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '*--elastic-search-addresses=[Elasticsearch addresses]:url:_urls' \
        '--elastic-search-username=[Elasticsearch username]:user:' \
        '--elastic-search-password=[Elasticsearch password]:password:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr]:bool:(true false)'
}

_karpor-syncer "$@"
