#compdef condor_status
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_status.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-pool[central manager host[:port]]:pool:' \
  '-direct[query daemon directly]:hostname:_hosts' \
  '-ads[read ClassAds from file]:file:_files' \
  '-annex[query resources in named annex]:annex:' \
  '-subsystem[query specific subsystem]:type:' \
  '-absent[display absent resources]' \
  '-any[query all ClassAds]' \
  '-avail[identify available resources]' \
  '-broken[display broken slots/machines]' \
  '-claimed[claimed resources]' \
  '-cod[machines with COD claims]' \
  '-collector[collector ads]' \
  '-defrag[defrag ads]' \
  '-grid[grid ads]' \
  '-java[Java-capable resources]' \
  '-license[license ads]' \
  '-lvm[disk usage enforcement]' \
  '-master[master ads]' \
  '-negotiator[negotiator ads]' \
  '-offline[machines with offline universes]' \
  '-run[machines running jobs]' \
  '-schedd[scheduler ads]' \
  '-server[server attributes]' \
  '-startd[startd ads]' \
  '-state[state info]' \
  '-storage[machines with network storage]' \
  '-submitters[submitter ads]' \
  '-vm[VM-enabled machines]' \
  '-long[full ClassAds]' \
  '-l[full ClassAds]' \
  '-xml[XML output]' \
  '-json[JSON output]' \
  '-compact[one-line per machine]' \
  '-totals[totals only]' \
  '-expert[shorter error messages]' \
  '-autoformat[format attributes]:list:' \
  '-af[format attributes]:list:' \
  '-format[printf format]:format attr:' \
  '-print-format[print format file]:file:_files' \
  '-attributes[limit displayed attributes]:list:' \
  '-sort[sort by expression]:expr:' \
  '-limit[max results]:num:' \
  '-constraint[constraint expression]:expr:' \
  '-target[target ClassAd]:file:_files' \
  '-merge[compare with file]:file:_files' \
  '-snapshot[internal state snapshot]:details:' \
  '-statistics[statistics list]:cats:' \
  '-diagnose[print query without executing]' \
  '-debug[debug output]' \
  '*:hostname:_hosts' && ret=0
return ret
