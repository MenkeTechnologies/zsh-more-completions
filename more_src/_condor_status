#compdef condor_status

# condor_status: query Condor pool status
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-server[show servers]' \
  '-startd[startd ads]' \
  '-schedd[schedd ads]' \
  '-collector[collector ads]' \
  '-master[master ads]' \
  '-negotiator[negotiator ads]' \
  '-defrag[defrag ads]' \
  '-grid[grid ads]' \
  '-license[license ads]' \
  '-storage[storage ads]' \
  '-credd[credd ads]' \
  '-quill[quill ads]' \
  '-submitter[submitter ads]' \
  '-any[any ad type]' \
  '-direct[query daemon directly]:target:' \
  '-format[printf format]:format attr:' \
  '-autoformat[autoformat]:list:' \
  '-af[autoformat]:list:' \
  '-print-format[print format file]:file:_files' \
  '-long[long format]' \
  '-l[long format]' \
  '-xml[XML output]' \
  '-json[JSON output]' \
  '-attributes[attributes]:list:' \
  '-claimed[claimed slots]' \
  '-cod[COD slots]' \
  '-state[show state]' \
  '-data[data servers]' \
  '-debug[debug]' \
  '-compact[compact mode]' \
  '-statistics[stats categories]:cats:' \
  '-constraint[constraint]:expr:' \
  '*:hostname:_hosts' && ret=0
return ret
