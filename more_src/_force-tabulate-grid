#compdef force-tabulate-grid
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/tabulate-grid.html
# FORCE: extract the processing grid as a shapefile/kml

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v)-v[show version]' \
  '(-i)-i[show program purpose]' \
  '(-b)-b[bounding box bottom,top,left,right (geographic coords)]:bbox:' \
  '(-f)-f[output format]:format:(shp kml)' \
  '1:datacube dir:_files -/' && ret=0

return ret
