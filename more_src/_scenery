#compdef scenery
# Documentation: https://github.com/dmlittle/scenery
# Terraform plan output prettifier (reads plan output from stdin)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-color[suppress color output]' && ret=0

return ret
