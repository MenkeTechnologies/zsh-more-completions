# Thirteen axes at three-language symmetry.)
#
# -----------------------------------------------------------------------------
#
# WHY tera IS THE 76TH RUST CLI LIBRARY
#
# tera is the canonical Rust Jinja2-family template engine.
# Distinct from every previously-documented Rust library in this
# taxonomy by being a TEMPLATE ENGINE — a new abstraction
# focused on text-rendering-with-variables (not logging, errors,
# tables, progress, colors, prompts, boxes, humanization, text
# wrap, config, paths, dates, HTTP, file watching, WebSockets,
# Markdown, or YAML).
#
# Five distinguishing characteristics:
#
#   1. JINJA2-FAMILY SYNTAX — `{{ var }}` for interpolation,
#      `{% if %}` / `{% for %}` / `{% block %}` / `{% extends %}`
#      / `{% include %}` for control + composition.  Filters
#      via `{{ value | filter }}`.  Familiar to Django / Flask
#      / Twig / Nunjucks / Liquid users.
#
#   2. RUNTIME COMPILATION — templates loaded + compiled at
#      runtime; not at Rust compile time.  Distinct from askama
#      (compile-time proc-macro templates).  Allows dynamic
#      template editing without recompilation — critical for
#      content-authoring workflows (Zola, Hugo-style SSGs).
#
#   3. INHERITANCE + INCLUDES — {% extends "base.html" %} and
#      {% block content %} / {% endblock %} for template
#      inheritance; {% include "partial.html" %} for
#      composition.
#
#   4. RICH FILTER + TEST LIBRARY — ~60 built-in filters and
#      ~10 built-in tests; extensible via tera.register_filter
#      / register_tester / register_function APIs.
#
#   5. VINCENT-PROUILLET / Keats ECOSYSTEM PROVENANCE — Keats
#      is a 2-library author in our taxonomy (config-rs R629
#      + tera R673).  Distinct maintainer ecosystem from
#      David Tolnay, Sean McArthur, Sindre Sorhus, etc.
#
# -----------------------------------------------------------------------------
#
# THE rag CLI — custom ragit-cli + tera (PDL templates) + reqwest + tokio
#
# rag's CLI is in src/main.rs.  Uses ragit's own ragit-cli
# crate's ArgParser (a custom parser, not clap / structopt;
# tuned to ragit-cli's match-arm style).
#
# Subcommands (35+):
#   add FILE [FILE...]                   stage documents for processing
#   archive-create / archive            create archive of vault
#   archive-extract / extract           extract archive into vault
#   audit                               security audit of vault
#   build                               process staged docs + embed
#   cat-file UID                        show contents of a chunk by uid
#   check                               integrity check of vault
#   clone URL                           clone remote RAG vault
#   config --get KEY                    get config value
#   config --set KEY=VALUE              set config value
#   config --get-all                    list all config values
#   extract-keywords TEXT               extract keywords from text
#   gc                                  garbage-collect old chunks
#   help [TOPIC]                        show help on optional topic
#       --help / -h                     show top-level help
#   ii-build                            build inverted index
#   ii-reset                            reset inverted index
#   ii-status                           inverted index status
#   init                                initialize new .ragit/ vault
#   ls-chunks                           list chunks in vault
#   ls-files                            list files in vault
#   ls-images                           list images in vault
#   ls-models                           list available LLM models
#   ls-queries                          list past queries
#   ls-terms                            list inverted-index terms
#   merge                               merge another vault
#   meta --get KEY                      get document metadata
#   meta --set KEY=VALUE                set document metadata
#   meta --add / --remove               manage metadata entries
#   meta --remove-all                   clear metadata
#   migrate                             migrate vault to new version
#   model NAME                          select default LLM model
#   pull URL                            pull updates from remote
#   push URL                            push to remote vault
#   query TEXT                          query the RAG system
#   remove FILE / rm FILE               remove file from vault
#   status                              show vault status
#   summary [--mode MODE]               summarize vault
#   version [--build-options]           show ragit version
#
# Help topics (via `rag help TOPIC`):
#   chunks                              chunking model
#   config-reference                    complete config reference
#   pdl-format                          PDL (Prompt Description Language)
#   pipeline                            RAG pipeline overview
#   quick-guide                         5-minute tutorial
#   uid-query                           UID query syntax
#
# tera is used in ragit-pdl for rendering PDL prompts:
#   PDL = Prompt Description Language; PDL files contain
#   tera template syntax with LLM-specific helpers.
#   Tera renders the prompt with runtime context (retrieved
#   chunks, user query, conversation history) before sending
#   to the LLM provider.
#
# Five-axis distinctness from all previously-documented Rust
# libraries:
#
#   1. TEMPLATING ABSTRACTION — tera renders text templates;
#      distinct from every other Axis.
#
#   2. JINJA2-FAMILY SYNTAX — `{% %}` / `{{ }}` syntax.
#
#   3. RUNTIME COMPILATION — vs askama's compile-time.
#
#   4. INHERITANCE + INCLUDES — full template composition.
#
#   5. KEATS / Vincent Prouillet ECOSYSTEM — 2-library author
#      (config-rs + tera).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/baehyunsol/ragit/blob/master/src/main.rs
# match-arm Some("subcommand") => ... blocks.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rag_cmds _rag_help_topics _rag_config_actions _rag_meta_actions
_rag_cmds=(
    'add:stage documents for processing'
    'archive-create:create archive of vault'
    'archive:create archive of vault (alias)'
    'archive-extract:extract archive into vault'
    'extract:extract archive (alias)'
    'audit:security audit of vault'
    'build:process staged docs + embed'
    'cat-file:show contents of a chunk by uid'
    'check:integrity check of vault'
    'clone:clone remote RAG vault'
    'config:configuration management'
    'extract-keywords:extract keywords from text'
    'gc:garbage-collect old chunks'
    'help:show help on optional topic'
    'ii-build:build inverted index'
    'build-ii:build inverted index (alias)'
    'ii-reset:reset inverted index'
    'reset-ii:reset inverted index (alias)'
    'ii-status:inverted index status'
    'init:initialize new .ragit/ vault'
    'ls-chunks:list chunks in vault'
    'ls-files:list files in vault'
    'ls-images:list images in vault'
    'ls-models:list available LLM models'
    'ls-queries:list past queries'
    'ls-terms:list inverted-index terms'
    'merge:merge another vault'
    'meta:document metadata management'
    'migrate:migrate vault to new version'
    'model:LLM model selection'
    'pull:pull updates from remote'
    'push:push to remote vault'
    'query:query the RAG system'
    'remove:remove file from vault'
    'rm:remove file (alias)'
    'status:show vault status'
    'summary:summarize vault'
    'version:show ragit version'
)
_rag_help_topics=(
    'chunks:chunking model'
    'config-reference:complete config reference'
    'pdl-format:Prompt Description Language format'
    'pipeline:RAG pipeline overview'
    'quick-guide:5-minute tutorial'
    'uid-query:UID query syntax'
)
_rag_config_actions=(
    '--get:get a config value'
    '--set:set a config value'
    '--get-all:list all config values'
)
_rag_meta_actions=(
    '--get:get a metadata value'
    '--get-all:list all metadata'
    '--set:set a metadata value'
    '--add:add a metadata entry'
    '--remove:remove a metadata entry'
    '--unset:remove a metadata entry (alias)'
    '--remove-all:clear all metadata'
    '--unset-all:clear all metadata (alias)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'rag subcommand' _rag_cmds && ret=0
        ;;
    args)
        case $words[1] in
            help)
                _describe -t topics 'help topic' _rag_help_topics && ret=0
                ;;
            config)
                _describe -t actions 'config action' _rag_config_actions && ret=0
                ;;
            meta)
                _describe -t actions 'meta action' _rag_meta_actions && ret=0
                ;;
            add|remove|rm|cat-file)
                _files && ret=0
                ;;
            version)
                _values 'version flag' '--build-options' && ret=0
                ;;
            summary)
                _values 'summary flag' '--mode' && ret=0
                ;;
        esac
        ;;
esac

return ret
