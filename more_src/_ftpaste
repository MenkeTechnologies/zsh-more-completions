#compdef ftpaste
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftpaste.html
# Merge columns from two FITS tables into a single output table

local ret=1

_arguments -s -S \
  'infile=[first input table with optional extension/filters]:infile:_files' \
  'pastefile=[second table whose columns are appended]:pastefile:_files' \
  'outfile=[output combined table file]:outfile:_files' \
  'copyall=[include additional HDUs from input]:copyall:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
