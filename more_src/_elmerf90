#compdef elmerf90
# Documentation: https://man.archlinux.org/search?q=elmerf90
# Reference accessed: 2026-05-16

# elmerf90: wrapper to compile Fortran user subroutines for Elmer
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-o[output shared library name]:file:_files' \
  '*:Fortran source file:_files -g "*.(f|f90|F|F90|f95|F95)"' && ret=0
return ret
