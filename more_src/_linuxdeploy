#compdef linuxdeploy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--appdir[path to AppDir]:directory:_directories' \
  '*'{-e,--executable}'[executable to deploy]:executable:_files' \
  '*'{-d,--desktop-file}'[desktop file to deploy]:desktop file:_files -g "*.desktop"' \
  '*'{-i,--icon-file}'[icon file to deploy]:icon file:_files' \
  '*'{-l,--library}'[library to deploy]:library:_files' \
  '*'{-p,--plugin}'[plugin to use]:plugin' \
  '--output[output type]:type:(appimage)' \
  '--verbosity[set verbosity level]:level:(0 1 2 3)' && ret=0

return ret
