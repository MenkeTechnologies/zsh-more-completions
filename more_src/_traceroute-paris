#compdef traceroute-paris paris-traceroute

# Paris-traceroute: traceroute variant that controls per-flow hashing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-a[algorithm]:algo:(hopbyhop concurrent paris)' \
  '--algorithm=[algorithm]:algo:(hopbyhop concurrent paris)' \
  '-p[port]:port:' \
  '-q[probes per hop]:n:' \
  '-r[max retries]:n:' \
  '-t[timeout (sec)]:seconds:' \
  '-w[wait between probes (sec)]:seconds:' \
  '-m[max ttl]:n:' \
  '-f[first ttl]:n:' \
  '-s[source address]:addr:' \
  '-i[source interface]:iface:' \
  '-T[probe protocol]:proto:(udp icmp tcp)' \
  '-d[destination port]:port:' \
  '-D[discard rate]:n:' \
  '-n[no DNS resolution]' \
  '-A[traceback]' \
  '-l[label flow]:label:' \
  '-c[constant id]:id:' \
  '1:host:_hosts' \
  '*::traceroute-paris args:_files' && ret=0
return ret
