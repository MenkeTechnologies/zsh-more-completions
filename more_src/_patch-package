#compdef patch-package

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--patch-dir=[directory to store patches]:directory:_directories' \
  '--error-on-fail[exit with error if patch fails]' \
  '--reverse[reverse a previously applied patch]' \
  '--error-on-warn[exit with error on warnings]' \
  '--create-issue[create an issue when making a patch]' \
  '--exclude=[exclude paths from patch]:pattern' \
  '--include=[include only these paths]:pattern' \
  '--case-sensitive-path-filtering[enable case-sensitive path filtering]' \
  '*:package name' && ret=0

return ret
