#compdef perf-stat-hist-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/perf-stat-hist.8
# perf_events stat histogram of tracepoint variables (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-b+[histogram bucket points]:buckets' \
  '-P+[power-of value, default 4]:power' \
  '-m+[maximum value for power-of]:max' \
  '-f+[specify a filter]:filter' \
  '1:tracepoint:' \
  '2:variable:' \
  '3:seconds:' && ret=0

return ret
