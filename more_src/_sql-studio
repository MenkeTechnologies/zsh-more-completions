#
# WHAT IS humantime AND WHY IS IT THE 63RD RUST CLI LIBRARY?
#
# humantime (https://github.com/tailhook/humantime, 600+ stars) is
# **Paul Colomiets's "human-friendly duration + timestamp parser
# for Rust"** — a narrowly-focused two-function library that solves
# ONE problem extremely well: converting between machine
# (Duration / SystemTime) and human ("1h 30m" / "2026-06-01T14:32:18Z")
# representations.  Where chrono is a full date/time arithmetic
# library, time-rs is a low-level primitives library, and jiff is
# the modern alternative, humantime occupies a niche by being TINY,
# ZERO-DEPENDENCY, and EXPLICITLY HUMAN-INTERFACE-FOCUSED.
#
# humantime's distinguishing characteristics:
#
#   1. TWO-FUNCTION API (parse + format) — humantime's entire public
#      API is essentially 4 functions:
#
#          use humantime::{parse_duration, format_duration,
#                          parse_rfc3339, format_rfc3339,
#                          Duration};
#
#          // Parse human-friendly duration strings:
#          let d = parse_duration("1h 30m 15s")?;        // Duration
#          let d = parse_duration("5days")?;
#          let d = parse_duration("100ms")?;
#          let d = parse_duration("2years 3months")?;
#          let d = parse_duration("1y 2months 3weeks 4d 5h 6m 7s")?;
#
#          // Format Duration back to human string:
#          let s = format_duration(d).to_string();       // "1h 30m 15s"
#
#          // Parse RFC 3339 timestamp:
#          let t = parse_rfc3339("2026-06-01T14:32:18Z")?;
#
#          // Format SystemTime as RFC 3339:
#          let s = format_rfc3339(SystemTime::now()).to_string();
#
#          // humantime::Duration is a newtype wrapping std::time::
#          // Duration with FromStr / Display implementations for
#          // direct use as a clap-derive field type:
#          #[derive(Parser)]
#          struct Args {
#              #[arg(default_value = "5secs")]
#              timeout: humantime::Duration,
#          }
#
#      Compare:
#         * chrono: full date/time library with arithmetic + timezones
#         * time-rs: low-level Duration / OffsetDateTime primitives
#         * jiff: modern alternative with civil/zoned/timestamp types
#         * humantime: TWO FUNCTIONS for parse + format only
#      FIRST documented Rust Axis 11 library with narrowly-focused
#      two-function parse-and-format human-time API.
#
#   2. EXTENSIVE HUMAN-FRIENDLY UNITS — humantime supports a wide
#      range of duration units in parsed input:
#         * Nanoseconds: "nsec", "ns"
#         * Microseconds: "usec", "us"
#         * Milliseconds: "msec", "ms"
#         * Seconds: "seconds", "second", "sec", "secs", "s"
#         * Minutes: "minutes", "minute", "min", "m"
#         * Hours: "hours", "hour", "hr", "h"
#         * Days: "days", "day", "d"
#         * Weeks: "weeks", "week", "w"
#         * Months: "months", "month", "M" (uppercase to disambiguate)
#         * Years: "years", "year", "y"
#         * Plain numbers default to seconds
#
#      Parsing is whitespace-tolerant + case-insensitive (except for
#      the M/m disambiguation for months vs minutes):
#         "1h30m" / "1 h 30 m" / "1H 30M" / "1hour 30minutes" all
#         parse to the same duration.
#
#      Compare:
#         * chrono: requires explicit Duration::from_secs / from_hours
#         * time-rs: requires explicit Duration::seconds()
#         * jiff: supports ISO 8601 + friendly parsing but more verbose
#         * humantime: FLEXIBLE input format with extensive unit aliases
#      FIRST documented Rust Axis 11 library with this breadth of
#      duration-unit aliases + whitespace-tolerant parsing.
#
#   3. ZERO DEPENDENCIES — humantime has NO transitive dependencies.
#      Pure stdlib Rust.  This makes it ideal for tools that want to
#      keep compile time + binary size small:
#
#          # In Cargo.toml:
#          [dependencies]
#          humantime = "2.2"   # zero transitive deps
#
#      Compare:
#         * chrono: pulls in iana-time-zone + winapi + num-traits +
#                    serde + many more
#         * time-rs: pulls in itoa + libc + winapi + serde
#         * jiff: pulls in serde + portable-atomic + ...
#         * humantime: ZERO transitive deps
#      FIRST documented Rust Axis 11 library with zero transitive
#      dependencies — sub-50ms compile time + sub-100KB binary
#      contribution.
#
#   4. clap-derive INTEGRATION via Duration NEWTYPE — humantime::
#      Duration is a NEWTYPE wrapping std::time::Duration that
#      implements FromStr + Display + From conversions:
#
#          #[derive(Parser, Debug)]
#          struct Args {
#              /// Timeout for queries
#              #[clap(short, long, env, default_value = "5secs")]
#              timeout: humantime::Duration,
#
#              /// Sleep between retries
#              #[clap(short, long, default_value = "100ms")]
#              retry_delay: humantime::Duration,
#
#              /// Cache TTL
#              #[clap(long, default_value = "1h 30m")]
#              cache_ttl: humantime::Duration,
#          }
#
#          // Convert humantime::Duration → std::time::Duration:
#          let d: std::time::Duration = args.timeout.into();
#
#      Compare:
#         * chrono: requires custom parser callback in clap config
#         * time-rs: requires custom parser callback
#         * jiff: requires custom parser callback
#         * humantime: Duration newtype works DIRECTLY as clap field
#      FIRST documented Rust Axis 11 library with first-class clap-
#      derive integration via newtype + FromStr.
#
#   5. PAUL-COLOMIETS / TAILHOOK ECOSYSTEM PROVENANCE — humantime
#      is by Paul Colomiets (tailhook on GitHub), the author of:
#         * humantime (THIS)
#         * humantime-serde — serde integration
#         * tk-listen — async TCP listener helpers
#         * async-std-resolver — DNS resolver for async-std
#      Paul's design philosophy is "narrowly-focused single-purpose
#      crates with zero deps" — humantime is the archetypal example.
#      Downstream users:
#         * databricks/click (k8s CLI, 1.5k stars)
#         * ordinals/ord (Bitcoin Ordinals, 4k stars)
#         * cantino/mcfly (shell history, 7.7k stars)
#         * svenstaro/genact (activity generator, 12k stars)
#         * racer-rust/racer (Rust completion, 3.4k stars)
#         * andrewchambers/bupstash (encrypted backup, 926 stars)
#         * alexheretic/ab-av1 (AV1 encoder, 893 stars)
#         * cucumber-rs/cucumber (BDD testing)
#         * frectonz/sql-studio (THIS — 3.5k stars)
#         * yuezk/GlobalProtect-openconnect (VPN client, 2.1k stars)
#         * 1500+ Rust CLIs needing duration parsing
#      FIRST documented Rust Axis 11 library with this specific
#      Paul-Colomiets + zero-deps + narrowly-focused provenance.
#
# humantime's relationship to other Rust libraries (no other Axis 11
# library documented yet — humantime opens this axis):
#
#   * Unlike chrono — chrono is full date/time arithmetic library;
#                       humantime is duration-string parser only
#   * Unlike time-rs — time-rs is low-level primitives; humantime
#                        is human-interface focused
#   * Unlike jiff — jiff is modern alternative with civil/zoned
#                     types; humantime is narrowly-focused
#   * Closest cross-language analogs:
#         * Go: dustin/go-humanize (Time/Bytes/Comma/Ordinal/...)
#         * Node: vercel/ms (parse "1h 30m" → milliseconds)
#         * Node: humanize-duration (Duration→human strings)
#         * Python: humanize (Jason Moiron port)
#         * Java: humanize-jvm
#     humantime is the FIRST documented Rust Axis 11 library
#     providing narrowly-focused two-function parse-and-format
#     human-time API + zero transitive deps + first-class clap-
#     derive integration via Duration newtype.
#
# -----------------------------------------------------------------------------
#
# THE sql-studio CLI — clap-derive + humantime + warp + 9 DB backends
#
# sql-studio's CLI is in src/main.rs.  Uses clap derive:
#
#     #[derive(Parser, Debug)]
#     #[command(version, about)]
#     struct Args {
#         #[clap(subcommand)]
#         db: Command,
#
#         /// The address to bind to.
#         #[arg(short, long, env, default_value = "127.0.0.1:3030")]
#         address: String,
#
#         /// Timeout duration for queries sent from the query page.
#         #[clap(short, long, env, default_value = "5secs")]
#         timeout: humantime::Duration,   // ← humantime field
#
#         /// Base path to be provided to the UI.
#         #[clap(short, long, env)]
#         base_path: Option<String>,
#
#         #[clap(long, env)]
#         no_browser: bool,
#
#         #[clap(long, env)]
#         no_shutdown: bool,
#     }
#
#     #[derive(Debug, Subcommand)]
#     enum Command {
#         Sqlite { database: String },
#         Libsql { url: String, auth_token: String },
#         LocalLibsql { database: String },
#         Postgres { url: String, schema: String },
#         Mysql { url: String },
#         Duckdb { database: String },      // #[cfg(not(musl))]
#         Parquet { file: String },          // #[cfg(not(musl))]
#         Csv { file: String },              // #[cfg(not(musl))]
#         Clickhouse { url: String, user: String, password: String, database: String },
#         Mssql { connection: String },
#     }
#
# humantime is used for the --timeout flag — accepting human-friendly
# duration strings like "5secs", "30s", "1h 30m", "100ms".
#
# Every flag has env-var fallback via clap(env) — `SQL_STUDIO_TIMEOUT=
# 10s sql-studio sqlite db.sqlite3` works without explicit CLI args.
#
# Five-axis distinctness from every other Rust library:
#
#   1. NARROWLY-FOCUSED TWO-FUNCTION API — parse + format only.
#
#   2. EXTENSIVE UNIT ALIASES — nsec/usec/ms/sec/min/h/d/w/M/y with
#      case+whitespace tolerance.
#
#   3. ZERO TRANSITIVE DEPS — pure stdlib Rust.
#
#   4. clap-derive INTEGRATION via Duration newtype with FromStr.
#
#   5. PAUL-COLOMIETS / TAILHOOK NARROWLY-FOCUSED PROVENANCE — one-
#      crate-per-problem design philosophy.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/frectonz/sql-studio/blob/main/src/main.rs
# clap derive declarations.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _sqlstudio_cmds
_sqlstudio_cmds=(
    'sqlite:local SQLite database file (use "preview" for sample db)'
    'libsql:remote SQLite database via libSQL'
    'local-libsql:local SQLite database opened with libSQL'
    'postgres:PostgreSQL database'
    'mysql:MySQL/MariaDB database'
    'duckdb:local DuckDB database (not musl)'
    'parquet:local Parquet file as queryable database (not musl)'
    'csv:local CSV file as queryable database (not musl)'
    'clickhouse:ClickHouse database server'
    'mssql:Microsoft SQL Server database'
    'help:show help for a subcommand'
)

_arguments -C \
    '(-a --address)'{-a+,--address=}'[bind address (default 127.0.0.1:3030)]:host\:port:_default' \
    '(-t --timeout)'{-t+,--timeout=}'[query timeout (humantime, e.g. 5secs, 1h 30m)]:duration:_default' \
    '(-b --base-path)'{-b+,--base-path=}'[base path for the UI]:path:_default' \
    '--no-browser[do not open URL in system browser]' \
    '--no-shutdown[do not show shutdown button in the UI]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'sql-studio subcommand' _sqlstudio_cmds && ret=0
        ;;
    args)
        case $words[1] in
            sqlite|local-libsql|duckdb)
                _arguments \
                    '1:database file:_files -g "*.{sqlite,sqlite3,db,duckdb}"' \
                    && ret=0
                ;;
            parquet)
                _arguments \
                    '1:Parquet file:_files -g "*.parquet"' \
                    && ret=0
                ;;
            csv)
                _arguments \
                    '1:CSV file:_files -g "*.csv"' \
                    && ret=0
                ;;
            libsql)
                _arguments \
                    '1:libSQL server URL:_urls' \
                    '2:auth token:_default' \
                    && ret=0
                ;;
            postgres)
                _arguments \
                    '(-s --schema)'{-s+,--schema=}'[PostgreSQL schema (default public)]:schema:_default' \
                    '1:connection URL (postgresql://...):_urls' \
                    && ret=0
                ;;
            mysql)
                _arguments \
                    '1:connection URL (mysql://...):_urls' \
                    && ret=0
                ;;
            clickhouse)
                _arguments \
                    '1:ClickHouse server URL (default http://localhost:8123):_urls' \
                    '2:user (default default):_users' \
                    '3:password:_default' \
                    '4:database name (default default):_default' \
                    && ret=0
                ;;
            mssql)
                _arguments \
                    '1:ADO.NET connection string:_default' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _sqlstudio_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
