#compdef gpload

_arguments -s \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f=[YAML control file]:file:_files -g "*.(yaml|yml)"' \
  '-l=[log file path]:file:_files' \
  '-h=[coordinator host]:host:_hosts' \
  '-p=[coordinator port]:port:' \
  '-U=[database username]:user:_users' \
  '-d=[database to load into]:db:' \
  '-W[force password prompt]' \
  '--gpfdist_timeout=[gpfdist timeout in seconds]:secs:' \
  '--no_auto_trans[do not run load as a single transaction]' \
  '--max_retries=[max gpfdist reconnect attempts]:n:' \
  '-q[quiet mode]' \
  '-D[check only; do not execute the load]' \
  '-v[verbose]' \
  '-V[very verbose]'
