#compdef kak-tree-sitter

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon]' \
  '(-s --server)'{-s,--server}'[start as server]' \
  '(-k --kakoune)'{-k,--kakoune}'[start kakoune helper rc init]' \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.toml"' \
  '(-w --with-text-objects)'{-w,--with-text-objects}'[generate text-object mappings]' \
  '(-r --request)'{-r+,--request=}'[send a JSON request to server]:json:' \
  '--init=[init Kakoune session]:session:' \
  '--kakoune-session=[Kakoune session id]:session:' \
  '--client=[Kakoune client name]:client:' \
  '--buffer=[Kakoune buffer name]:buffer:' \
  '--log-file=[log file]:file:_files' \
  '--verbose[verbose logging]' \
  '--quiet[suppress logging]' \
  '--logger=[logging target]:dest:(stderr stdout file)' \
  '*::passthrough:' && ret=0

return ret
