#compdef kak-tree-sitter
# Documentation: https://strongly-typed-thoughts.net/blog/kak-tree-sitter-v0.4
# Reference accessed: 2026-05-19
# Verified: upstream v0.4 announcement (canonical author blog).

# UNIX server bridging Kakoune with tree-sitter. Corrected from prior
# file: flag is --daemon (not --daemonize), removed invented short
# flags (-d/-s/-k/-c/-w/-r) and unverifiable --init/--logger/--quiet/
# --client/--buffer; kept only options confirmed in upstream docs plus
# --with-highlighting which the prior file omitted.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--daemon[daemonize the server after init]' \
  '--server[start as server]' \
  '--kakoune[send init data back to the Kakoune session]' \
  '--session=[Kakoune session id]:session:' \
  '--with-highlighting[enable tree-sitter highlighting]' \
  '--with-text-objects[enable tree-sitter text objects]' \
  '*::passthrough:' && ret=0

return ret
