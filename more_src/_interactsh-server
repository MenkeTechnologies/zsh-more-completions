#compdef interactsh-server
# Documentation: https://man.archlinux.org/search?q=interactsh-server
# Reference accessed: 2026-05-16

_arguments -s \
  '(-d -domain)'{-d,-domain}'=[configured domain]:domain:' \
  '-ip=[public IP]:ip:' \
  '(-lip -listen-ip)'{-lip,-listen-ip}'=[listen IP]:ip:' \
  '(-e -eviction)'{-e,-eviction}'=[eviction days]:days:' \
  '(-ne -no-eviction)'{-ne,-no-eviction}'[disable eviction]' \
  '(-es -eviction-strategy)'{-es,-eviction-strategy}'=[eviction strategy]:strategy:(sliding fixed)' \
  '(-a -auth)'{-a,-auth}'[enable auth with random token]' \
  '(-t -token)'{-t,-token}'=[auth token]:token:' \
  '-acao-url=[ACAO origin URL]:url:' \
  '(-sa -skip-acme)'{-sa,-skip-acme}'[skip ACME]' \
  '(-se -scan-everywhere)'{-se,-scan-everywhere}'[scan canary everywhere]' \
  '(-cidl -correlation-id-length)'{-cidl,-correlation-id-length}'=[correlation id length]:n:' \
  '(-cidn -correlation-id-nonce-length)'{-cidn,-correlation-id-nonce-length}'=[nonce length]:n:' \
  '-cert=[cert path]:file:_files' \
  '-privkey=[private key path]:file:_files' \
  '(-oih -origin-ip-header)'{-oih,-origin-ip-header}'=[origin IP header]:header:' \
  '(-r -resolvers)'{-r,-resolvers}'=[resolvers list]:resolvers:_files' \
  '-config=[config file]:file:_files' \
  '(-dr -dynamic-resp)'{-dr,-dynamic-resp}'[enable arbitrary response]' \
  '(-cr -custom-records)'{-cr,-custom-records}'=[custom DNS records YAML]:file:_files' \
  '(-hi -http-index)'{-hi,-http-index}'=[HTTP index file]:file:_files' \
  '(-dhr -default-http-response)'{-dhr,-default-http-response}'=[default HTTP response file]:file:_files' \
  '(-hd -http-directory)'{-hd,-http-directory}'=[HTTP directory]:dir:_files -/' \
  '(-ds -disk)'{-ds,-disk}'[disk based storage]' \
  '(-dsp -disk-path)'{-dsp,-disk-path}'=[disk path]:dir:_files -/' \
  '(-csh -server-header)'{-csh,-server-header}'=[Server header]:value:' \
  '(-dv -disable-version)'{-dv,-disable-version}'[hide version header]' \
  '(-up -update)'{-up,-update}'[update to latest]' \
  '(-duc -disable-update-check)'{-duc,-disable-update-check}'[disable update check]' \
  '-dns-port=[DNS port]:port:' \
  '-http-port=[HTTP port]:port:' \
  '-https-port=[HTTPS port]:port:' \
  '-smtp-port=[SMTP port]:port:' \
  '-smtps-port=[SMTPS port]:port:' \
  '-smtp-autotls-port=[SMTP autoTLS port]:port:' \
  '-ldap-port=[LDAP port]:port:' \
  '-ldap[enable LDAP server]' \
  '(-wc -wildcard)'{-wc,-wildcard}'[enable wildcard]' \
  '-smb[start SMB agent]' \
  '-responder[start responder agent]' \
  '-ftp[start FTP agent]' \
  '-smb-port=[SMB port]:port:' \
  '-ftp-port=[FTP port]:port:' \
  '-ftps-port=[FTPS port]:port:' \
  '-ftp-dir=[FTP directory]:dir:_files -/' \
  '-version[show version]' \
  '-debug[debug]' \
  '(-ep -enable-pprof)'{-ep,-enable-pprof}'[enable pprof]' \
  '(-hc -health-check)'{-hc,-health-check}'[health check]' \
  '-metrics[expose metrics]' \
  '(-v -verbose)'{-v,-verbose}'[verbose]'
