#compdef pact

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'broker:Pact Broker client'
  'pactflow:PactFlow specific commands'
  'completions:generate shell completion scripts'
  'extension:manage Pact CLI extensions'
  'plugin:plugin management'
  'mock:mock server'
  'verifier:provider verification'
  'stub:stub server'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--enable-otel[enable OpenTelemetry]' \
  '--enable-otel-logs[enable OpenTelemetry logs]' \
  '--enable-otel-traces[enable OpenTelemetry traces]' \
  '--otel-exporter=[OpenTelemetry exporter]:exporter:(stdout otlp)' \
  '--otel-exporter-endpoint=[exporter endpoint]:url:' \
  '--otel-exporter-protocol=[exporter protocol]:protocol:(http http/protobuf grpc)' \
  '--log-level=[log level]:level:(off none error warn info debug trace)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pact subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (plugin)
        _values 'plugin action' \
          'list' 'env' 'install' 'remove' 'enable' 'disable' 'repository' && ret=0
        ;;
      (mock)
        _values 'mock action' \
          'start' 'list' 'create' 'verify' 'shutdown' 'shutdown-master' && ret=0
        ;;
      (broker)
        _values 'broker action' \
          'publish' 'list-latest-pact-versions' 'get-pacts' \
          'create-environment' 'update-environment' 'delete-environment' \
          'describe-environment' 'list-environments' \
          'record-deployment' 'record-undeployment' 'record-release' 'record-support-ended' \
          'can-i-deploy' 'can-i-merge' \
          'create-or-update-pacticipant' 'describe-pacticipant' 'list-pacticipants' \
          'create-webhook' 'create-or-update-webhook' 'delete-webhook' 'test-webhook' \
          'delete-branch' \
          'create-version-tag' 'delete-version-tag' \
          'describe-version' 'create-or-update-version' \
          'generate-uuid' 'provider-states' && ret=0
        ;;
      (pactflow)
        _values 'pactflow action' 'publish-provider-contract' && ret=0
        ;;
      (completions)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' 'elvish' && ret=0
        ;;
    esac
    ;;
esac

return ret
