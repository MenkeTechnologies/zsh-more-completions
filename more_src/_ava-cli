#compdef ava-cli
# _ava-cli — Sindre Sorhus AVA JavaScript testing framework CLI alias (Sindre Sorhus, JavaScript); meow
# upstream: https://github.com/avajs/ava

_ava-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--color[color]' \
        '--no-color[no color]' \
        '--concurrency=+[concurrency]:n:' \
        '-c+[concurrency]:n:' \
        '--config=+[config file]:file:_files -g "ava.config.* .ava.config.*"' \
        '--cwd=+[cwd]:dir:_files -/' \
        '--fail-fast[fail fast]' \
        '--match=+[match pattern]:list:' \
        '-m+[match pattern]:list:' \
        '--node-arguments=+[node arguments]:str:' \
        '--reporter=+[reporter]:r:(spec pretty min tap)' \
        '--serial[serial]' \
        '-s[serial]' \
        '--snapshot-mode=+[snapshot mode]:m:(strict auto update)' \
        '--tap[tap reporter]' \
        '-t[tap reporter]' \
        '--timeout=+[timeout]:str:' \
        '-T+[timeout]:str:' \
        '--update-snapshots[update snapshots]' \
        '-u[update snapshots]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--watch[watch]' \
        '-w[watch]' \
        '--workers=+[workers]:n:' \
        '--ignore-missing-imports[ignore missing imports]' \
        '*:file:_files'
}

_ava-cli "$@"
