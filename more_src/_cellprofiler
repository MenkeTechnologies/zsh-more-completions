#compdef cellprofiler
# Documentation: https://github.com/CellProfiler/CellProfiler/wiki/Getting-started-using-CellProfiler-from-the-command-line
# cellprofiler: image analysis pipeline runner

local ret=1

_arguments -s \
  '-c[run headless without a user interface]' \
  '-r[run the analysis with the supplied pipeline]' \
  '-p[pipeline (or batch) file to run]:pipeline:_files' \
  '-o[default output directory]:dir:_files -/' \
  '-i[default input directory]:dir:_files -/' \
  '-f[first image set number to process]:first:' \
  '-l[last image set number to process]:last:' \
  '-g[grouping variables for this job]:group:' \
  '--data-file=[alternate .csv file to LoadData]:file:_files' \
  '--file-list=[file of file names to load by the Images module]:file:_files' \
  '*:file:_files' && ret=0

return ret
