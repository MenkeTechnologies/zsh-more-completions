#compdef sa2
# _sa2 — sysstat sa2 shell script to summarize sar data CLI (Sebastien Godard / sysstat team, Bash); custom argparse
# upstream: https://github.com/sysstat/sysstat

_sa2() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-D[append date to default file name]' \
        '-A[show all stats]' \
        '-b[print I/O and transfer rate stats]' \
        '-B[print paging statistics]' \
        '-c[print task creation/context switching activity]' \
        '-d[print activity for block devices]' \
        '-H[show file headers]' \
        '-i+[interval]:n:' \
        '-I+[interrupt stats]:i:(CPU SCPU SUM ALL)' \
        '-m+[power management stats]:p:(CPU FAN FREQ IN TEMP USB ALL)' \
        '-n+[network stats]:n:(DEV EDEV NFS NFSD SOCK IP EIP ICMP EICMP TCP ETCP UDP SOCK6 IP6 EIP6 ICMP6 EICMP6 UDP6 FC SOFT ALL)' \
        '-o+[output file]:file:_files' \
        '-P+[cpu list]:list:' \
        '-q[print queue length/load averages]' \
        '-r[print memory utilization stats]' \
        '-R[print memory stats]' \
        '-s+[start time]:str:' \
        '-S+[swap utilization]:s:(SWAP IPC ALL)' \
        '-t[show timestamps using original locale]' \
        '-T+[show paging stats]:t:(CHILD SELF ALL)' \
        '-u+[CPU utilization]:str:' \
        '-v[print kernel tables stats]' \
        '-w[print task creation/switching stats]' \
        '-W[print swap stats]' \
        '-y[print TTY device stats]' \
        '*:arg:'
}

_sa2 "$@"
