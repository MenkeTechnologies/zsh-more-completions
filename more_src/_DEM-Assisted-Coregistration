#compdef DEM-Assisted-Coregistration
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/s1tbx-op-insar/src/main/java/org/esa/s1tbx/insar/gpf/coregistration/DEMAssistedCoregistrationOp.java
# ESA SNAP gpt DEM-Assisted-Coregistration operator - coregister using a digital elevation model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PdemName=[the digital elevation model]:dem' \
  '-PdemResamplingMethod=[DEM resampling method]:method' \
  '-PexternalDEMFile=[external DEM file]:file:_files' \
  '-PexternalDEMNoDataValue=[external DEM no data value]:value' \
  '-PresamplingType=[method for resampling slave onto master grid]:type' \
  '-PtileExtensionPercent=[tile extension percentage]:percent' \
  '-PmaskOutAreaWithoutElevation=[mask out areas without elevation]:flag:(true false)' \
  '-PoutputRangeAzimuthOffset=[output range and azimuth offset bands]:flag:(true false)' \
  '*:graph xml:_files' && ret=0

return ret
