#compdef kubectl-capture
# Documentation: https://github.com/sysdiglabs/kubectl-capture
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (kubectl-capture script source).

# kubectl-capture (sysdiglabs/kubectl-capture): trigger a Sysdig capture.
# Own flags -ns/--namespace and --ebpf; remaining flags pass to sysdig.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-ns --namespace)'{-ns+,--namespace=}'[namespace where the target pod lives]:namespace:' \
  '--ebpf[launch capture pod with eBPF probe instead of kernel module]' \
  '-M+[stop the capture after the given number of seconds]:seconds:' \
  '(-w --write)'{-w+,--write=}'[write captured events to file]:file:_files' \
  '(-z --compress)'{-z,--compress}'[compress the capture file]' \
  '(-S --summary)'{-S,--summary}'[print event summary when capture ends]' \
  '-pc[print container context]' \
  '-pk[print Kubernetes context]' \
  '-pm[print mesos context]' \
  '-print=[set the print format]:format:' \
  '*:pod:_default'
