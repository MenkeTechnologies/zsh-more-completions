#compdef bam-loader cg-load fastq-loader pacbio-load latf-load sra-sort vdb-lock vdb-unlock
# Documentation: upstream NCBI sra-tools loaders at
# github.com/ncbi/sra-tools/tree/master/tools/loaders
# Reference accessed: 2026-05-30 via gh api inspection of
# tools/loaders/bam-loader/bam-loader.c option_* string-constant
# declarations.
# NCBI SRA Toolkit loaders R107 — 8-stem multi-binary harvest
# completing the R106 SRA toolkit loaders deferral. Combined with
# R105 (_prefetch 10 stems) + R106 (_kar 9 stems), the NCBI SRA
# toolkit coverage is now 27 stems across 3 multi-stem files.

local curcontext="$curcontext" state line ret=1

# Shared KApp common flags (same helper as R105/R106).
local -a _common_kapp
_common_kapp=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-L --log-level)'{-L,--log-level}'=[log level]:level:(fatal sys int err warn info debug)'
  '(-v --verbose)*'{-v,--verbose}'[verbose mode (repeatable)]'
  '(-q --quiet)'{-q,--quiet}'[turn off all messages]'
  '--option-file=[read options from file]:file:_files'
)

case $service in

  bam-loader)
    # Load SAM/BAM files into a VDB / SRA archive.
    _arguments -s -S \
      $_common_kapp \
      '(-i --input)'{-i,--input}'=[input directory]:dir:_directories' \
      '(-o --output)'{-o,--output}'=[output VDB archive path]:path:_files' \
      '(-t --tmpfs)'{-t,--tmpfs}'=[temp filesystem dir]:dir:_directories' \
      '(-k --config)'{-k,--config}'=[config file]:file:_files' \
      '(-q --min-mapq)'{-q,--min-mapq}'=[minimum mapping quality]:N:' \
      '--qual-quant=[quality compression scheme]:scheme:' \
      '--cache-size=[memory size for read cache (MB)]:MB:' \
      '--force-sorted[treat input as already sorted (no sort check)]' \
      '--unsorted[input is unsorted]' \
      '--sorted[input is coordinate-sorted]' \
      '--max-err-count=[max parser errors before abort]:N:' \
      '--max-rec-count=[max records to process]:N:' \
      '--no-verify[skip reference verification]' \
      '--only-verify[only verify references, do not load]' \
      '--use-QUAL[use the QUAL field for quality scores]' \
      '--ref-filter=[only load records mapping to these references]:refs:' \
      '--ref-config=[references config file]:file:_files' \
      '--edit-aligned-qual=[edit aligned qualities]:value:' \
      '(-u --unaligned)'{-u,--unaligned}'=[load unaligned reads from file]:file:_files' \
      '--accept-dups[accept duplicate read records]' \
      '--accept-nomatch[accept reads with no matches]' \
      '--nomatch-log=[log file for no-match reads]:file:_files' \
      '(-m --min-match)'{-m,--min-match}'=[minimum match length]:N:' \
      '--header=[header file]:file:_files' \
      '--no-cs[disable color-space decoding]' \
      '--no-secondary[ignore secondary alignments]' \
      '*--ref-file=[external reference FASTA (repeatable)]:file:_files -g "*.(fa|fasta|fna)"' \
      '--TI[output TI tag]' \
      '--max-warn-dup-flag=[max duplicate-flag warnings]:N:' \
      '--accept-hard-clip[accept hard-clipped alignments]' \
      '--allow-multi-map[allow reads to multi-map]' \
      '--allow-secondary[allow secondary alignments]' \
      '--defer-secondary[load secondary alignments after primary]' \
      '--spot-batch-size=[number of spots per batch]:N:' \
      '--threads=[number of threads]:N:' \
      '--extra-logging[enable extra logging]' \
      '--min-batch-size=[minimum batch size]:N:' \
      '--telemetry=[telemetry config]:value:' \
      '*:SAM/BAM file:_files -g "*.(sam|bam)"' \
      && ret=0
    ;;

  cg-load)
    # Complete Genomics → VDB / SRA loader.
    _arguments -s -S \
      $_common_kapp \
      '(-i --input)'{-i,--input}'=[input CG directory]:dir:_directories' \
      '(-o --output)'{-o,--output}'=[output VDB path]:path:_files' \
      '(-m --map)'{-m,--map}'=[mapping/library file]:file:_files' \
      '(-l --library)'{-l,--library}'=[library name]:name:' \
      '--no-secondary[ignore secondary alignments]' \
      '--force[overwrite existing output]' \
      && ret=0
    ;;

  fastq-loader)
    # FASTQ → VDB / SRA loader.
    _arguments -s -S \
      $_common_kapp \
      '(-o --output)'{-o,--output}'=[output VDB path]:path:_files' \
      '--quality=[ASCII quality offset]:offset:(33 64)' \
      '--max-err-count=[max parser errors]:N:' \
      '--platform=[sequencing platform]:platform:(454 Illumina SOLiD HelicosBioSciences IonTorrent CompleteGenomics PacBio Nanopore Capillary)' \
      '--readLens=[read lengths CSV]:lengths:' \
      '--useAndDiscardFile=[file usage]:bool:(yes no)' \
      '--ignore-illumina-tags[ignore Illumina-format tags]' \
      '--allow-duplicates[allow duplicate spot names]' \
      '*:FASTQ file:_files -g "*.(fastq|fq|fastq.gz|fq.gz)"' \
      && ret=0
    ;;

  pacbio-load)
    # PacBio HDF5 → VDB / SRA loader.
    _arguments -s -S \
      $_common_kapp \
      '(-o --output)'{-o,--output}'=[output VDB path]:path:_files' \
      '(-t --tabs)'{-t,--tabs}'=[tab-separated input description]:file:_files' \
      '(-f --force)'{-f,--force}'[overwrite existing output]' \
      '(-c --check)'{-c,--check}'[check input only, do not load]' \
      '--with-progress[show progress]' \
      '*:PacBio HDF5 file:_files -g "*.(h5|hdf5|bas.h5|bax.h5)"' \
      && ret=0
    ;;

  latf-load)
    # Long Archive Tape Format loader (LATF → VDB / SRA).
    _arguments -s -S \
      $_common_kapp \
      '(-o --output)'{-o,--output}'=[output VDB path]:path:_files' \
      '--quality=[ASCII quality offset]:offset:(33 64)' \
      '--max-err-count=[max parser errors]:N:' \
      '--platform=[sequencing platform]:platform:(454 Illumina SOLiD)' \
      '*:LATF input file:_files' \
      && ret=0
    ;;

  sra-sort)
    # Sort SRA archive (typically by spot or by alignment position).
    _arguments -s -S \
      $_common_kapp \
      '(-o --output)'{-o,--output}'=[output sorted VDB path]:path:_files' \
      '--no-mt[disable multi-threading]' \
      '--no-secondary[ignore secondary alignments]' \
      '--force[overwrite existing output]' \
      '--map-file=[mapping file]:file:_files' \
      '--column-pause=[pause between column writes (ms)]:ms:' \
      '*:input SRA path:_files' \
      && ret=0
    ;;

  vdb-lock)
    # Acquire a write lock on a VDB / SRA archive.
    _arguments -s -S \
      $_common_kapp \
      '*:VDB / SRA archive:_files' \
      && ret=0
    ;;

  vdb-unlock)
    # Release a write lock on a VDB / SRA archive.
    _arguments -s -S \
      $_common_kapp \
      '*:VDB / SRA archive:_files' \
      && ret=0
    ;;

esac

return ret
