#compdef create-vue-medical
# Documentation: https://www.npmjs.com/package/create-vue-medical
# Reference accessed: 2026-05-24
# Verified: npm view create-vue-medical bin; npm readme Command Options section.

# Zsh completion for create-vue-medical - HIPAA-oriented Vue 3 medical scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[skip prompts; use defaults]' \
  '(-n --name)'{-n,--name=}'[project name]:name:' \
  '--no-typescript[disable TypeScript]' \
  '--no-pinia[disable Pinia state management]' \
  '--no-vitest[disable Vitest testing setup]' \
  '(-p --preset)'{-p,--preset=}'[preset configuration]:preset:(minimal standard full hipaa enterprise)' \
  '--list-presets[list available presets]' \
  '(-h --help)'{-h,--help}'[display help]' \
  ':project name:' && ret=0

return ret
