#compdef flink
# _flink-cli — Apache Flink CLI (job submission + cluster admin for Flink streaming/batch jobs; subcommands: run, run-application, info, list, stop, cancel, savepoint, checkpoint, classpath, jobs, history-server, queryable-state, sql-gateway; -m JobManager host:port, -p parallelism, -c entry-class, -d detached, -ynm name, -ys taskmanager.slots, -yjm/-ytm memory, -yqu YARN queue)
# upstream: https://github.com/apache/flink (flink-clients/bin/flink)
# Subcommands from Apache Flink flink-clients src/main/java/org/apache/flink/client/cli/CliFrontend.java on tip.

_flink-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '-m+[JobManager host:port]:host:port:' \
        '--target+[target deployment]:target:(local remote yarn-per-job yarn-session yarn-application kubernetes-session kubernetes-application)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'flink command' '(run run-application info list stop cancel savepoint checkpoint classpath jobs history-server queryable-state sql-gateway version)' ;;
        args)
            case $line[1] in
                run|run-application)
                    _arguments \
                        '-c+[entry-class]:class:' \
                        '--class+[entry-class]:class:' \
                        '-p+[parallelism]:n:' \
                        '--parallelism+[parallelism]:n:' \
                        '-d[detached]' \
                        '--detached[detached]' \
                        '-s+[savepoint path]:path:_files' \
                        '--fromSavepoint+[savepoint path]:path:_files' \
                        '-ynm+[YARN name]:name:' \
                        '-ys+[slots per TM]:n:' \
                        '-yjm+[JM memory]:mem:' \
                        '-ytm+[TM memory]:mem:' \
                        '-yqu+[YARN queue]:queue:' \
                        '*-D+[key=value]:property:' \
                        '*:jar args:_files -g "*.jar"' ;;
                list|stop|cancel) _arguments '-r[running]' '-s[scheduled]' '-a[all]' '*:job id:' ;;
                savepoint|checkpoint) _arguments '*:job id [target dir]:' ;;
            esac
            ;;
    esac
}

_flink-cli "$@"
