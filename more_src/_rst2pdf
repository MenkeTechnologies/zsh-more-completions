#compdef rst2pdf
# Documentation: https://man.archlinux.org/search?q=rst2pdf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-o --output)'{-o+,--output=}'[output PDF file]:file:_files -g "*.pdf"' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '*'{-s+,--stylesheets=}'[stylesheets csv]:list:' \
  '*'{--style-path,--stylesheet-path=}'[stylesheet search path]:dir:_files -/' \
  '(-b --break-level)'{-b+,--break-level=}'[break level]:n:' \
  '(-B --breakside)'{-B+,--breakside=}'[break side]:s:(any odd even)' \
  '(-C --custom-cover)'{-C+,--custom-cover=}'[custom cover]:file:_files' \
  '--no-cover[no cover]' \
  '(-d --date-invariant)'{-d,--date-invariant}'[date invariant]' \
  '(-D --debug-formatting)'{-D,--debug-formatting}'[debug formatting]' \
  '(-e --extension-modules)'{-e+,--extension-modules=}'[extensions csv]:list:' \
  '(-f --first-page-on-right)'{-f,--first-page-on-right}'[first page on right]' \
  '(-F --fit-background-mode)'{-F+,--fit-background-mode=}'[fit bg mode]:m:(scale center none)' \
  '(-l --language)'{-l+,--language=}'[language]:lang:' \
  '(-L --raw-html)'{-L,--raw-html}'[support raw html]' \
  '*'{-m+,--match-source=}'[match source]:s:' \
  '(--no-compressed-pdf)--no-compressed-pdf[no compression]' \
  '(--no-section-numbers)--no-section-numbers[no section numbers]' \
  '(-p --pdf-version)'{-p+,--pdf-version=}'[PDF version]:v:' \
  '(--use-floating-images)--use-floating-images[float images]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-r --resource-path)'{-r+,--resource-path=}'[resource path]:dir:_files -/' \
  '(-S --strip-elements-with-classes)'{-S+,--strip-elements-with-classes=}'[strip classes csv]:list:' \
  '(-t --strict)'{-t,--strict}'[strict mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--very-verbose)--very-verbose[very verbose]' \
  '(-w --raw-string)'{-w+,--raw-string=}'[raw string]:s:' \
  '*: :_files -g "*.rst *.txt"' && ret=0

return ret
