#compdef rst2pdf
# Documentation: https://github.com/rst2pdf/rst2pdf/blob/main/doc/rst2pdf.rst
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-o --output)'{-o+,--output=}'[output PDF file]:file:_files -g "*.pdf"' \
  '(-c --compressed)'{-c,--compressed}'[create compressed PDF]' \
  '--config=[config file]:file:_files' \
  '(-s --stylesheets)'{-s+,--stylesheets=}'[custom stylesheets (comma-separated)]:list:' \
  '--stylesheet-path=[stylesheet search folders (colon-separated)]:folderlist:' \
  '--print-stylesheet[display default stylesheet]' \
  '--font-folder=[font search folder (deprecated)]:dir:_files -/' \
  '--font-path=[font search folders (colon-separated)]:folderlist:' \
  '--baseurl=[base URL for relative links]:url:' \
  '(-l --language)'{-l+,--language=}'[language code]:lang:' \
  '--header=[page header]:str:' \
  '--footer=[page footer]:str:' \
  '--section-header-depth=[section depth for header/footer]:n:' \
  '--smart-quotes=[ASCII quote/dash conversion 0-3]:value:(0 1 2 3)' \
  '--fit-literal-mode=[handle wide literals]:mode:' \
  '--inline-links[show targets in parentheses]' \
  '--raw-html[support embedded HTML]' \
  '--repeat-table-rows[repeat header rows in split tables]' \
  '--fit-background-mode=[background image fitting]:mode:(scale center none)' \
  '--show-frame-boundary[show frame borders (debug)]' \
  '--disable-splittables[disable splittable flowables]' \
  '(-b --break-level)'{-b+,--break-level=}'[section break page level]:n:' \
  '--first-page-on-right[start on right page (book style)]' \
  '--blank-first-page[add blank opening page]' \
  '--break-side=[section break behavior]:value:(any odd even)' \
  '--use-floating-images[align images like rst2html]' \
  '--use-numbered-links[add section numbers to links]' \
  '--no-footnote-backlinks[disable footnote backlinks]' \
  '--inline-footnotes[display footnotes inline]' \
  '--default-dpi=[DPI for pixel-sized objects]:n:' \
  '(-e --extension-module)'{-e+,--extension-module=}'[helper modules (comma-separated)]:list:' \
  '--custom-cover=[cover page template]:file:_files' \
  '*--strip-elements-with-class=[remove elements by class]:cls:' \
  '--record-dependencies=[write file dependencies]:file:_files' \
  '--date-invariant[exclude current date from PDF]' \
  '(-q --quiet)'{-q,--quiet}'[reduce output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose debug]' \
  '--very-verbose[extensive debug]' \
  '*: :_files -g "*.rst *.txt"' && ret=0

return ret
