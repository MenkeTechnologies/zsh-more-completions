#compdef corkscrew
# Documentation: https://github.com/bryanpkc/corkscrew
# Reference accessed: 2026-05-17
# Verified: upstream README at the URL above (proxyhost proxyport targethost targetport [authfile]).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:proxy host:_hosts' \
  '2:proxy port' \
  '3:target host:_hosts' \
  '4:target port' \
  '5:auth file:_files' && ret=0

return ret
