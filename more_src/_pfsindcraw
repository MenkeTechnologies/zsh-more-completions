#compdef pfsindcraw
# Documentation: http://pfstools.sourceforge.net/man1/pfsindcraw.1.html
# pfstools: read RAW camera images into a pfs stream via dcraw/libraw

local ret=1

_arguments -s -S \
  '(-n --native)'{-n,--native}'[read images in native camera color space]' \
  '(-d --dcraw)'{-d,--dcraw}'[use original dcraw tool even if libraw is available]' \
  '*:raw file:_files' && ret=0

return ret
