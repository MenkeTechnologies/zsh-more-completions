#compdef tz

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --list)'{-l,--list}'[list configured time zones]' \
  '(-q --no-header)'{-q,--no-header}'[suppress header line]' \
  '*:timezone:_time_zone' && ret=0

return ret
