#compdef shopify
# Documentation: https://shopify.dev/docs/api/shopify-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (topics: app, theme, hydrogen; per-topic
# command lists at shopify.dev/docs/api/shopify-cli/app and /theme).
# Subcommand option flags vary across versions; descriptions only — flags not
# enumerated in CLI source are omitted.

local -a _shopify_commands
_shopify_commands=(
  'app:app development commands'
  'theme:theme development commands'
  'hydrogen:Hydrogen storefront commands'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'shopify commands' _shopify_commands
    ;;
  args)
    case "$words[1]" in
      app)
        local -a app_cmds=(
          'build:run the build script from the TOML file'
          'config:manage app configuration (link/pull/use/validate)'
          'deploy:deploy app configuration and extensions'
          'dev:build and preview app on a dev store'
          'env:manage environment variables (pull/show)'
          'function:work with app functions (build/run/replay/schema/typegen)'
          'generate:generate a new app extension'
          'info:show app details and metadata'
          'init:create a new app project'
          'logs:stream real-time app logs'
          'release:release an existing app version'
          'versions:list deployed versions'
          'webhook:trigger sample Admin API webhook payload'
        )
        _arguments -C '1:subcommand:->subcmds'
        case "$state" in
          subcmds) _describe -t commands 'app commands' app_cmds ;;
        esac
        ;;
      theme)
        local -a theme_cmds=(
          'check:run theme check on theme code'
          'console:start the Liquid REPL'
          'delete:delete a theme from your store'
          'dev:upload as dev theme and preview'
          'info:show theme environment info'
          'init:clone a Git repo as theme starter'
          'list:list themes with IDs and statuses'
          'open:get links to preview a theme'
          'package:package local theme files into ZIP'
          'publish:publish an unpublished theme'
          'pull:retrieve theme files from Shopify'
          'push:upload local theme files to Shopify'
          'rename:rename a theme'
          'share:upload as a new unpublished theme'
        )
        _arguments -C '1:subcommand:->subcmds'
        case "$state" in
          subcmds) _describe -t commands 'theme commands' theme_cmds ;;
        esac
        ;;
      hydrogen)
        local -a h2_cmds=(
          'build:build the Hydrogen project'
          'check:run checks on the project'
          'codegen:generate types from GraphQL'
          'debug:debug the project'
          'deploy:deploy the project'
          'dev:run the dev server'
          'env:manage environment variables'
          'generate:generate routes'
          'init:create a new Hydrogen project'
          'link:link to a Hydrogen storefront'
          'list:list storefronts'
          'preview:preview the project'
          'setup:set up project features'
          'shortcut:create terminal shortcut'
          'unlink:unlink from storefront'
          'upgrade:upgrade Hydrogen dependencies'
        )
        _arguments -C '1:subcommand:->subcmds'
        case "$state" in
          subcmds) _describe -t commands 'hydrogen commands' h2_cmds ;;
        esac
        ;;
    esac
    ;;
esac
