#compdef shopify

local -a _shopify_commands
_shopify_commands=(
  'app:app development commands'
  'auth:authentication commands'
  'hydrogen:Hydrogen storefront commands'
  'theme:theme development commands'
  'search:search Shopify resources'
  'store:store management'
  'upgrade:upgrade Shopify CLI'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--verbose[verbose output]' \
  '--no-color[disable color]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'shopify commands' _shopify_commands
    ;;
  args)
    case "$words[1]" in
      app)
        local -a app_cmds=(
          'build:build the app'
          'config:configure the app'
          'deploy:deploy the app'
          'dev:run in development mode'
          'env:manage environment'
          'function:manage functions'
          'generate:generate app components'
          'import:import an app'
          'info:show app info'
          'init:create a new app'
          'logs:view app logs'
          'release:release an app version'
          'versions:list app versions'
          'webhook:manage webhooks'
        )
        _arguments -C '1:subcommand:->subcmds' '*::arg:->subargs'
        case "$state" in
          subcmds) _describe -t commands 'app commands' app_cmds ;;
          subargs)
            case "$words[1]" in
              init)
                _arguments \
                  '--name[app name]:name' \
                  '--path[path]:dir:_directories' \
                  '--template[template URL]:url' \
                  '--package-manager[package manager]:pm:(npm yarn pnpm)'
                ;;
              dev)
                _arguments \
                  '--path[app path]:dir:_directories' \
                  '--store[dev store]:store' \
                  '--reset[reset config]' \
                  '--skip-dependencies-installation[skip deps install]' \
                  '--theme[theme ID]:id' \
                  '--theme-app-extension-port[theme extension port]:port'
                ;;
              deploy)
                _arguments \
                  '--path[app path]:dir:_directories' \
                  '--force[force deploy]' \
                  '--reset[reset config]' \
                  '--no-release[do not release after deploy]' \
                  '--message[version message]:message' \
                  '--source-control-url[source control URL]:url'
                ;;
              generate)
                _arguments '1:type:(extension)' '--path[app path]:dir:_directories'
                ;;
            esac
            ;;
        esac
        ;;
      theme)
        local -a theme_cmds=(
          'check:run theme checks'
          'console:start a console'
          'delete:delete a theme'
          'dev:run theme dev server'
          'info:show theme info'
          'init:create a new theme'
          'list:list themes'
          'open:open theme in browser'
          'package:package a theme'
          'publish:publish a theme'
          'pull:pull theme files'
          'push:push theme files'
          'rename:rename a theme'
          'share:share theme preview'
        )
        _arguments -C '1:subcommand:->subcmds' '*::arg:->subargs'
        case "$state" in
          subcmds) _describe -t commands 'theme commands' theme_cmds ;;
          subargs)
            case "$words[1]" in
              dev)
                _arguments \
                  '--path[theme path]:dir:_directories' \
                  '--store[dev store]:store' \
                  '--theme[theme ID]:id' \
                  '--host[host]:host' \
                  '--port[port]:port' \
                  '--live-reload[live reload]:mode:(hot-reload full-page off)' \
                  '--poll[poll for changes]' \
                  '--open[open in browser]'
                ;;
              push|pull)
                _arguments \
                  '--path[theme path]:dir:_directories' \
                  '--store[dev store]:store' \
                  '--theme[theme ID]:id' \
                  '--publish[publish after push]' \
                  '--nodelete[do not delete remote files]' \
                  '--json[output JSON]' \
                  '(-o --only)'{-o,--only}'[only these files]:pattern' \
                  '(-x --ignore)'{-x,--ignore}'[ignore these files]:pattern'
                ;;
              init)
                _arguments \
                  '--name[theme name]:name' \
                  '--path[path]:dir:_directories' \
                  '--clone-url[clone URL]:url'
                ;;
            esac
            ;;
        esac
        ;;
      hydrogen)
        local -a h2_cmds=(
          'build:build the project'
          'check:run checks'
          'codegen:generate types'
          'debug:debug the project'
          'deploy:deploy the project'
          'dev:run dev server'
          'env:manage environment variables'
          'generate:generate routes'
          'init:create a new project'
          'link:link to a storefront'
          'list:list storefronts'
          'preview:preview the project'
          'setup:setup project'
          'shortcut:create terminal shortcut'
          'unlink:unlink from storefront'
          'upgrade:upgrade Hydrogen'
        )
        _arguments -C '1:subcommand:->subcmds' '*::arg:->subargs'
        case "$state" in
          subcmds) _describe -t commands 'hydrogen commands' h2_cmds ;;
        esac
        ;;
    esac
    ;;
esac
