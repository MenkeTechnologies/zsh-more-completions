#compdef hhfilter
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# HHfilter: filter an MSA by maximum pairwise identity, coverage, or score per column

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i+[read input file in A3M/A2M or FASTA format]:input file:_files' \
  '-o+[write to output file in A3M format]:output file:_files' \
  '-a+[append to output file in A3M format]:output file:_files' \
  '-v+[verbose mode]:level:(0 1 2)' \
  '-id+[maximum pairwise sequence identity]:int' \
  '-diff+[filter MSA by selecting most diverse set]:int' \
  '-cov+[minimum coverage with query]:int' \
  '-qid+[minimum sequence identity with query]:int' \
  '-qsc+[minimum score per column with query]:num' \
  '-neff+[target diversity of alignment]:num' \
  '-M+[input alignment format: a2m/first/percentage]:mode' \
  '-maxseq+[max number of input rows]:int' \
  '-maxres+[max number of HMM columns]:int' && ret=0

return ret
