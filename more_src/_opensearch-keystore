#compdef opensearch-keystore
# Documentation: https://man.archlinux.org/search?q=opensearch-keystore
# Reference accessed: 2026-05-16

# opensearch-keystore: manage OpenSearch secure settings keystore
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a new keystore'
  'list:list settings'
  'add:add a setting'
  'add-file:add a file as setting'
  'remove:remove a setting'
  'upgrade:upgrade keystore version'
  'passwd:change keystore password'
  'show:show a setting value'
  'has-passwd:check if keystore has password'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-f[force]' \
  '--force[force]' \
  '-x[read setting from stdin]' \
  '--stdin[read setting from stdin]' \
  '-E[config setting key=value]:kv:' \
  '-p[prompt password]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'opensearch-keystore command' commands && ret=0 ;;
esac
return ret
