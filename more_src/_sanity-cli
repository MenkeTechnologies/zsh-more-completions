#compdef sanity-cli
# _sanity-cli — Sanity headless content platform CLI alias (sanity-io team, JavaScript); commander
# upstream: https://github.com/sanity-io/sanity

_sanity-cli() {
    local -a sub=(
        'init:initialize new project'
        'login:login to sanity'
        'logout:logout'
        'manage:open project in browser'
        'projects:list projects'
        'projects:create:create project'
        'projects:delete:delete project'
        'dataset:list:list datasets'
        'dataset:create:create dataset'
        'dataset:delete:delete dataset'
        'dataset:copy:copy dataset'
        'dataset:export:export dataset'
        'dataset:import:import dataset'
        'dataset:alias:list:list aliases'
        'dataset:alias:create:create alias'
        'dataset:alias:link:link alias'
        'dataset:alias:unlink:unlink alias'
        'dataset:alias:delete:delete alias'
        'cors:list:list cors origins'
        'cors:add:add cors origin'
        'cors:delete:delete cors origin'
        'documents:get:get document'
        'documents:query:query documents'
        'documents:create:create document'
        'documents:delete:delete document'
        'documents:validate:validate documents'
        'graphql:list:list graphql apis'
        'graphql:deploy:deploy graphql api'
        'graphql:undeploy:undeploy graphql api'
        'hook:list:list hooks'
        'hook:create:create hook'
        'hook:delete:delete hook'
        'hook:logs:show hook logs'
        'install:install plugin'
        'uninstall:uninstall plugin'
        'upgrade:upgrade dependencies'
        'dev:start dev server'
        'start:start production server'
        'build:build production bundle'
        'deploy:deploy studio'
        'undeploy:undeploy studio'
        'preview:preview build'
        'check:run checks'
        'codemod:run codemods'
        'schema:list:list schemas'
        'schema:extract:extract schema'
        'schema:store:store schema'
        'schema:validate:validate schema'
        'schema:delete:delete schema'
        'exec:execute script'
        'help:show help'
        'version:show version'
        'users:list:list users'
        'users:invite:invite user'
        'tokens:list:list tokens'
        'tokens:create:create token'
        'tokens:delete:delete token'
        'docs:open docs'
        'debug:show debug info'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[no color]' \
        '--project=+[project id]:str:' \
        '--dataset=+[dataset]:str:' \
        '--api-version=+[api version]:str:' \
        '--cwd=+[cwd]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sanity subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--project=+[project id]:str:' \
                    '--dataset=+[dataset]:str:' \
                    '--template=+[template]:t:(clean blog ecommerce moviedb landing-pages company-website portfolio)' \
                    '--output-path=+[output dir]:dir:_files -/' \
                    '--create-project=+[project name]:str:' \
                    '--dataset-default[use default dataset]' \
                    '-y[yes to defaults]' \
                    '--bare[bare project]' \
                    '--reconfigure[reconfigure]' \
                    '--env=+[env file]:str:' \
                    '--package-manager=+[pm]:pm:(npm pnpm yarn bun)' \
                    '--coupon=+[coupon]:str:' ;;
                deploy) _arguments \
                    '1:source dir:_files -/' \
                    '--source-maps[source maps]' \
                    '--auto-updates[auto updates]' \
                    '--no-auto-updates[no auto updates]' \
                    '--no-build[skip build]' ;;
                dataset:export) _arguments \
                    '1:dataset:' \
                    '2:output file:_files' \
                    '--asset-concurrency=+[n]:n:' \
                    '--raw[raw assets]' \
                    '--types=+[types]:str:' \
                    '--no-drafts[no drafts]' \
                    '--no-assets[no assets]' \
                    '--no-compress[no compress]' \
                    '--overwrite[overwrite]' \
                    '--mode=+[mode]:m:(stream cursor)' ;;
                dataset:import) _arguments \
                    '1:file:_files -g "*.{tar.gz,ndjson}"' \
                    '2:dataset:' \
                    '--missing[missing only]' \
                    '--replace[replace]' \
                    '--skip-cross-dataset-references[skip cross-dataset refs]' \
                    '--allow-failing-assets[allow failing assets]' \
                    '--replace-assets[replace assets]' \
                    '--asset-concurrency=+[n]:n:' ;;
            esac
            ;;
    esac
}

_sanity-cli "$@"
