#compdef aide

# Zsh completion for aide - Advanced Intrusion Detection Environment

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --init)'{-i,--init}'[initialize the database]' \
  '(-C --check)'{-C,--check}'[check the database]' \
  '(-u --update)'{-u,--update}'[check and update the database]' \
  '--compare[compare two databases]' \
  '(-D --config-check)'{-D,--config-check}'[check configuration and exit]' \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '--limit=[limit check to these entries]:expression' \
  '(-d --database)'{-d,--database}'[use this URL for database]:URL' \
  '--database-new=[use this URL for new database]:URL' \
  '--database-out=[write new database to this URL]:URL' \
  '(-l --log)'{-l,--log}'[set log level]:level:(error warning notice info debug trace)' \
  '--report-url=[report URL]:URL' \
  '--verbose=[verbosity level]:level' \
  '-V[increase verbosity]' \
  '-E[use stderr for errors]' \
  '-s[use syslog for errors]'
