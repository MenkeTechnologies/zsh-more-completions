#compdef aerospike-prometheus-exporter
# _aerospike-prometheus-exporter — Aerospike Prometheus exporter (aerospike/aerospike-prometheus-exporter)
# upstream: https://github.com/aerospike/aerospike-prometheus-exporter
# Flags from cmd/main.go (flag).

_aerospike-prometheus-exporter() {
    _arguments \
        '(- *)-u[show usage]' \
        '(- *)-version[show version]' \
        '-config=[config file path]:file:_files -g "*.toml"' \
        '-gauge-list=[gauge stats file path]:file:_files -g "*.toml"'
}

_aerospike-prometheus-exporter "$@"
