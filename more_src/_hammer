#compdef hammer
# Documentation: https://man.archlinux.org/search?q=hammer
# Reference accessed: 2026-05-16

# hammer: Foreman/Katello CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'activation-key:manipulate activation keys'
  'admin:Administrative commands'
  'architecture:manipulate architectures'
  'audit:audit operations'
  'auth:set credentials'
  'auth-source:manage auth sources'
  'bookmark:manipulate bookmarks'
  'capsule:manipulate capsules'
  'compute-profile:manage compute profiles'
  'compute-resource:manage compute resources'
  'config-report:browse config reports'
  'content-credentials:manage content credentials'
  'content-export:export content view versions'
  'content-import:import content view versions'
  'content-units:browse content units'
  'content-view:manipulate content views'
  'content-view-filter:manage content view filters'
  'csv:CSV import/export'
  'discovery:manage discovered hosts'
  'discovery-rule:manage discovery rules'
  'domain:manipulate domains'
  'erratum:browse errata'
  'fact:search facts'
  'file:manage files'
  'filter:manage permission filters'
  'foreign-input-set:manipulate foreign input sets'
  'global-parameter:manipulate global parameters'
  'host:manipulate hosts'
  'host-collection:manipulate host collections'
  'host-group:manipulate hostgroups'
  'host-registration:host registration command'
  'hostgroup:manipulate hostgroups'
  'http-proxy:manage HTTP proxies'
  'image:manage images'
  'job-invocation:manage job invocations'
  'job-template:manage job templates'
  'lifecycle-environment:manage lifecycle environments'
  'location:manage locations'
  'mail-notification:manage mail notifications'
  'medium:manipulate installation media'
  'model:manage hardware models'
  'module-stream:browse module streams'
  'organization:manipulate organizations'
  'os:manipulate operating systems'
  'package:manipulate packages'
  'package-group:manipulate package groups'
  'partition-table:manipulate partition tables'
  'ping:get the status of the server'
  'policy:manage compliance policies'
  'product:manipulate products'
  'proxy:manipulate smart-proxies'
  'puppet-class:manipulate puppet classes'
  'puppet-environment:manage puppet environments'
  'realm:manage realms'
  'recurring-logic:manage recurring logic'
  'remote-execution-feature:manage remote execution features'
  'report:browse reports'
  'report-template:manipulate report templates'
  'repository:manipulate repositories'
  'repository-set:manage repository sets'
  'role:manage user roles'
  'scap-content:manage SCAP contents'
  'scc-account:manage Suse Customer Center accounts'
  'settings:change Foreman settings'
  'shell:interactive shell'
  'simple-content-access:simple content access'
  'smart-class-parameter:manipulate smart class parameters'
  'smart-variable:manipulate smart variables (deprecated)'
  'srpm:manipulate source RPMs'
  'subnet:manipulate subnets'
  'subscription:manipulate subscriptions'
  'sync-plan:manage sync plans'
  'task:tasks related actions'
  'template:manage provisioning templates'
  'template-input:manage template inputs'
  'user:manipulate users'
  'user-group:manage user groups'
  'virt-who-config:manage virt-who configs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '--reload-cache[force API cache reload]' \
  '--no-headers[skip table headers]' \
  '--no-use-defaults[ignore defaults]' \
  '--csv[output as CSV]' \
  '--csv-separator=[CSV separator]:sep:' \
  '--output=[output format]:format:(base table silent csv json yaml)' \
  '-u[username]:user:' \
  '--username=[username]:user:' \
  '-p[password]:pass:' \
  '--password=[password]:pass:' \
  '-s[server URL]:url:' \
  '--server=[server URL]:url:' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--fetch-ca-cert=[fetch CA cert from server]:server:' \
  '--ssl-ca-file=[CA file]:file:_files' \
  '--show-ids[show IDs in output]' \
  '--interactive=[force interactive mode]:bool:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'hammer command' commands && ret=0 ;;
esac
return ret
