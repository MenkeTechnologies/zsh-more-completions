#compdef hammer

# Hammer: Foreman / Satellite command-line client
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'activation-key:manage activation keys'
  'admin:administrative commands'
  'architecture:manage architectures'
  'audit:show audit log'
  'auth:manage hammer authentication'
  'auth-source:manage authentication sources'
  'capsule:manage smart proxies / capsules'
  'compute-profile:manage compute profiles'
  'compute-resource:manage compute resources'
  'config-report:show config reports'
  'content-credentials:manage content credentials'
  'content-export:manage content exports'
  'content-import:manage content imports'
  'content-view:manage content views (Katello)'
  'defaults:set hammer defaults'
  'domain:manage DNS domains'
  'discovery:manage discovered hosts'
  'erratum:manage Katello errata'
  'export-templates:export Foreman templates'
  'fact:show facts'
  'filter:manage RBAC filters'
  'foreign-input-set:manage foreign input sets'
  'global-parameter:manage global parameters'
  'host:manage hosts'
  'host-collection:manage host collections'
  'hostgroup:manage host groups'
  'http-proxy:manage HTTP proxies'
  'job-invocation:run / view remote jobs'
  'job-template:manage job templates'
  'lifecycle-environment:manage lifecycle envs'
  'location:manage locations'
  'mail-notification:manage mail notifications'
  'medium:manage installation media'
  'model:manage hardware models'
  'organization:manage organizations'
  'os:manage operating systems'
  'package:manage packages'
  'package-group:manage package groups'
  'partition-table:manage partition tables'
  'permission:manage RBAC permissions'
  'ping:check Foreman/services health'
  'policies:manage SCAP policies'
  'product:manage Katello products'
  'proxy:manage smart proxies'
  'puppet-class:manage Puppet classes'
  'puppet-environment:manage Puppet environments'
  'puppet-module:show Puppet modules'
  'realm:manage realms'
  'remote-execution-feature:manage REX features'
  'report-template:manage report templates'
  'repository:manage repositories'
  'repository-set:manage repository sets'
  'role:manage RBAC roles'
  'sc-param:manage Smart Class parameters'
  'settings:manage Foreman settings'
  'shell:open interactive hammer shell'
  'sm-hammer-completion:install completion script'
  'srpm:manage source RPMs'
  'status:show service status'
  'subnet:manage subnets'
  'subscription:manage subscriptions'
  'sync-plan:manage sync plans'
  'tailoring-file:manage SCAP tailoring files'
  'task:manage Foreman tasks'
  'template:manage templates'
  'user:manage users'
  'user-group:manage user groups'
  'virt-who-config:manage virt-who configs'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--show-ids[show object IDs in output]' \
  '--csv[CSV output]' \
  '--csv-separator=[CSV field separator]:char:' \
  '--no-headers[skip headers]' \
  '--no-format[no formatting]' \
  '--output=[output format]:format:(table json yaml csv silent)' \
  '--server=[Foreman/Satellite URL]:url:' \
  '--username=[Foreman user]:user:' \
  '--password=[Foreman password]:pwd:' \
  '--ssl-ca-file=[CA file]:file:_files' \
  '--ssl-client-cert=[client cert]:file:_files' \
  '--ssl-client-key=[client key]:file:_files' \
  '--config=[config file]:file:_files' \
  '--reload-cache[reload command cache]' \
  '--interactive=[interactive prompts]:bool:(true false)' \
  '--fetch-ca-cert=[fetch CA cert from URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'hammer subcommand' commands && ret=0 ;;
esac
return ret
