#compdef kalix
# _kalix — Lightbend Kalix Akka-platform serverless services management CLI (lightbend team, Go); cobra
# upstream: https://docs.kalix.io/reference/kalix/

_kalix() {
    local -a sub=(
        'auth:authentication subcommands'
        'completion:generate shell completion'
        'config:configure CLI settings'
        'container-registry:manage container registries'
        'docker:docker integration'
        'docs:open docs'
        'help:show help'
        'logs:tail logs'
        'organizations:organization subcommands'
        'projects:project subcommands'
        'quickstart:quickstart wizard'
        'roles:role subcommands'
        'service:service subcommands'
        'services:services aliases'
        'tools:helper tools'
        'update:update CLI'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--cache-file=+[cache file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '--context=+[context]:str:' \
        '--organization=+[org]:str:' \
        '-o+[org]:str:' \
        '--project=+[project]:str:' \
        '-p+[project]:str:' \
        '--region=+[region]:str:' \
        '-r+[region]:str:' \
        '--url=+[api url]:url:_urls' \
        '--no-color[disable color]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kalix subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments '1:auth cmd:(login logout signup current-login show-config refresh-token tokens)' ;;
                projects) _arguments '1:projects cmd:(get list new delete update set-default get-default invites members regions)' ;;
                services) _arguments '1:services cmd:(deploy delete list logs get pause restart resume undeploy expose unexpose)' ;;
                service) _arguments '1:service cmd:(deploy delete logs get pause restart resume undeploy expose unexpose components data-export view-state)' ;;
                organizations) _arguments '1:orgs cmd:(get list new delete update invites members billing)' ;;
                roles) _arguments '1:roles cmd:(get list invitations bindings)' ;;
                container-registry) _arguments '1:registry cmd:(login logout list-images list-tags push delete-image delete-tag print-credentials config)' ;;
                docker) _arguments '1:docker cmd:(login logout)' ;;
                config) _arguments '1:config cmd:(get set list current-context use-context delete-context list-contexts get-context rename-context get-organization get-project)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kalix "$@"
