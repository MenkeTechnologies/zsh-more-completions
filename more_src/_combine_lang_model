#compdef combine_lang_model
# Documentation: combine_lang_model --help (Tesseract training)
# Source: combine word/punc/number lists + unicharset into a Tesseract LSTM lang model.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--lang_is_rtl=[language is right-to-left]:bool:(true false)' \
    '--pass_through_recoder=[recoder is pass-through]:bool:(true false)' \
    '--input_unicharset=[unicharset filename]:file:_files' \
    '--script_dir=[input script unicharsets directory]:dir:_files -/' \
    '--words=[word list file]:file:_files' \
    '--puncs=[punctuation patterns file]:file:_files' \
    '--numbers=[number patterns file]:file:_files' \
    '--output_dir=[root output directory]:dir:_files -/' \
    '--version_str=[version string for traineddata]:version:' \
    '--lang=[language name]:lang:' \
    && ret=0

return ret
