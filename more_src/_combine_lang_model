#compdef combine_lang_model

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--lang_is_rtl=[true if lang is written right-to-left]:flag:(true false)' \
  '--pass_through_recoder=[recoder is simple pass-through of unicharset]:flag:(true false)' \
  '--input_unicharset=[unicharset file to complete and use in encoding]:file:_files' \
  '--script_dir=[directory of input script unicharsets]:dir:_files -/' \
  '--words=[file listing words for system dictionary]:file:_files' \
  '--puncs=[file listing punctuation patterns]:file:_files' \
  '--numbers=[file listing number patterns]:file:_files' \
  '--output_dir=[root directory for output files]:dir:_files -/' \
  '--version_str=[version string to add to traineddata]:string:' \
  '--lang=[name of language being processed]:lang:' && ret=0

return ret
