#compdef maim

# Zsh completion for maim - screenshot utility for X11

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-u --hidecursor)'{-u,--hidecursor}'[hide the cursor]' \
  '(-s --select)'{-s,--select}'[interactively select a region]' \
  '-x+[set the x coordinate for the screenshot region]:x position:' \
  '-y+[set the y coordinate for the screenshot region]:y position:' \
  '-w+[set the width of the screenshot region]:width:' \
  '-h+[set the height of the screenshot region]:height:' \
  '(-g --geometry)'{-g,--geometry}'[set the region geometry]:geometry (WxH+X+Y):' \
  '(-d --delay)'{-d,--delay}'[delay before taking screenshot]:seconds:' \
  '(-i --window)'{-i,--window}'[capture a specific window by ID]:window id:' \
  '(-f --format)'{-f,--format}'[set the output format]:format:(png jpg bmp)' \
  '(-m --quality)'{-m,--quality}'[compression quality level]:level (1-10):' \
  '-b+[set the border size for selection]:border size:' \
  '-c+[set the selection highlight color]:color (R,G,B,A):' \
  '-l[highlight the selection area]' \
  '-n[do not display the selection rectangle]' \
  '-t+[set selection tolerance]:tolerance:' \
  '-o[with compositing, ensure correct capture]' \
  '--nodecorations[attempt to remove decorations from window]:level:(0 1 2)' \
  '--shader[use a custom GLSL shader]:shader file:_files' \
  ':output file:_files'
