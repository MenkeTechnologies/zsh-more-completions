#compdef hasura

# Zsh completion for Hasura CLI

_hasura() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'actions:manage Hasura actions'
    'completion:generate auto-completion scripts'
    'console:open the console to manage the database'
    'deploy:apply all metadata, migrations and seeds'
    'init:initialize a directory for Hasura GraphQL engine'
    'metadata:manage Hasura GraphQL engine metadata'
    'migrate:manage migrations on the database'
    'plugins:manage plugins for the CLI'
    'scripts:manage Hasura scripts'
    'seed:manage seed data'
    'update-cli:update the CLI to latest or a specific version'
    'version:print the CLI version'
  )

  _arguments -s -S \
    '--project=[directory where commands are executed]:directory:_files -/' \
    '--envfile=[.env filename to load]:env file:_files' \
    '--log-level=[log level]:level:(DEBUG INFO WARN ERROR FATAL)' \
    '--no-color[do not colorize output]' \
    '--skip-update-check[skip checking for CLI update]' \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'hasura command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        init)
          _arguments -s -S \
            '--endpoint=[Hasura GraphQL engine endpoint]:endpoint:' \
            '--admin-secret=[admin secret]:secret:' \
            '--version=[config version]:version:(2 3)' \
            '1:directory name:' \
            && ret=0
          ;;
        console)
          _arguments -s -S \
            '--address=[address to serve console]:address:' \
            '--api-port=[port for API]:port:' \
            '--browser=[browser to use]:browser:' \
            '--console-port=[port for console]:port:' \
            '--endpoint=[Hasura GraphQL engine endpoint]:endpoint:' \
            '--admin-secret=[admin secret]:secret:' \
            '--no-browser[do not open browser]' \
            '--static-dir=[directory of static assets]:directory:_files -/' \
            '--use-server-assets[use assets from the server]' \
            && ret=0
          ;;
        migrate)
          _arguments -s -S \
            '1:subcommand:(apply create delete squash status)' \
            '--database-name=[database name]:database:' \
            '--endpoint=[Hasura endpoint]:endpoint:' \
            '--admin-secret=[admin secret]:secret:' \
            && ret=0
          ;;
        metadata)
          _arguments -s -S \
            '1:subcommand:(apply clear diff export inconsistency reload)' \
            '--endpoint=[Hasura endpoint]:endpoint:' \
            '--admin-secret=[admin secret]:secret:' \
            && ret=0
          ;;
        seed)
          _arguments -s -S \
            '1:subcommand:(apply create)' \
            '--database-name=[database name]:database:' \
            '--endpoint=[Hasura endpoint]:endpoint:' \
            '--admin-secret=[admin secret]:secret:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--endpoint=[Hasura GraphQL engine endpoint]:endpoint:' \
            '--admin-secret=[admin secret]:secret:' \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_hasura "$@"
