#compdef mpvc
# _mpvc-cli — mpvc mpv IPC control client (Shell/C); send commands to a running mpv instance via JSON-IPC socket
# upstream: https://github.com/lwilletts/mpvc

_mpvc-cli() {
    local -a sub=(
        'add:add file/url to playlist'
        'play:resume playback'
        'pause:pause playback'
        'toggle:toggle play/pause'
        'next:next track'
        'prev:previous track'
        'stop:stop playback'
        'seek:seek'
        'remove:remove from playlist'
        'clear:clear playlist'
        'crop:crop playlist'
        'list:show playlist'
        'current:show current'
        'status:show status'
        'volume:get/set volume'
        'mute:toggle mute'
        'speed:get/set speed'
        'loop:set loop mode'
        'shuffle:shuffle playlist'
        'idle:wait for end of playback'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-S --socket)'{-S,--socket}'+[mpv IPC socket]:socket:_files' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mpvc subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments '*:file/url:_files' ;;
                seek|volume|speed) _arguments '1:value:' ;;
            esac
            ;;
    esac
}

_mpvc-cli "$@"
