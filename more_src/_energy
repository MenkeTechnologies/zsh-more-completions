#compdef energy
# Documentation: https://github.com/energye/energy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# energye/energy CLI: install/package/init/build/bindata/gen/update/cli subcommands.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'install:install toolchain pieces'
  'package:package app resources'
  'version:show versions'
  'env:print environment info'
  'init:init project'
  'build:build with optional Go passthrough args'
  'bindata:embed static assets'
  'gen:code generation helpers'
  'update:update energy components'
  'cli:CLI diagnostics'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'energy command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
