#compdef energy

# https://github.com/energye/energy — CEF/dev tooling (go-flags; cmd/energy/energy.go maps install package version env init build bindata gen update cli)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'install:install toolchain pieces'
  'package:package app resources'
  'version:show versions'
  'env:print environment info'
  'init:init project'
  'build:build with optional Go passthrough args'
  'bindata:embed static assets'
  'gen:code generation helpers'
  'update:update energy components'
  'cli:CLI diagnostics'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'energy command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
