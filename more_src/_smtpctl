#compdef smtpctl
# Documentation: https://man.archlinux.org/search?q=smtpctl
# Reference accessed: 2026-05-16

# smtpctl: control OpenSMTPD
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'show:show information'
  'show queue:show queue'
  'show envelope:show envelope by id'
  'show message:show full message'
  'show stats:show statistics'
  'show status:show daemon status'
  'show hoststats:show host stats'
  'show routes:show routes'
  'show envelopes:list envelopes'
  'pause:pause subsystem'
  'resume:resume subsystem'
  'remove:remove envelope from queue'
  'schedule:re-schedule envelope'
  'discover:discover queue messages on disk'
  'spf:test SPF'
  'log:log control'
  'verbose:set verbose level'
  'profile:enable/disable profiling'
  'trace:trace subsystem'
  'untrace:untrace subsystem'
  'monitor:monitor smtpd'
  'mta:MTA subcommands'
  'stop:stop daemon'
  'encrypt:encrypt a password'
  'makemap:make a map'
  'newaliases:rebuild aliases'
  'help:show help'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'smtpctl command' commands && ret=0 ;;
esac
return ret
