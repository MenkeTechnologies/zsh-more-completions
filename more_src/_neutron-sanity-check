#compdef neutron-sanity-check
# Documentation: https://docs.openstack.org/neutron/latest/cli/neutron-sanity-check.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# OpenStack Neutron sanity check
local curcontext="$curcontext" ret=1
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "(-d --debug)"{-d,--debug}"[set log level to debug]" \
  "(-v --verbose)"{-v,--verbose}"[set log level to INFO]" \
  "--state_path=[directory for state files]:dir:_files -/" \
  "--log-config-append=[log config file]:file:_files" \
  "--log-date-format=[log date format]:fmt:" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--nodebug[do not set log level to debug]" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  "--watch-log-file[watch log file]" \
  "--arp_header_match[verify ARP header match support]" \
  "--arp_responder[check ARP responder capability]" \
  "--bridge_firewalling[validate bridge firewalling]" \
  "--dhcp_release6[confirm dhcp_release6 installed]" \
  "--dnsmasq_version[check dnsmasq version]" \
  "--ebtables_installed[verify ebtables installation]" \
  "--icmpv6_header_match[confirm ICMPv6 header match]" \
  "--ip6tables_installed[verify ip6tables installation]" \
  "--ip_nonlocal_bind[test kernel option with netns]" \
  "--iproute2_vxlan[check iproute2 vxlan capability]" \
  "--ipset_installed[verify ipset installation]" \
  "--keepalived_ipv6_support[check keepalived IPv6 support]" \
  "--nova_notify[verify nova notification support]" \
  "--ovs_conntrack[check OVS connection tracking]" \
  "--ovs_geneve[verify OVS Geneve support]" \
  "--ovs_patch[confirm patch port support]" \
  "--ovs_vxlan[check OVS vxlan capability]" \
  "--ovsdb_native[verify native ovsdb interface]" \
  "--read_netns[check netns permission settings]" \
  '*::neutron-sanity-check args:_files' && ret=0
return ret
