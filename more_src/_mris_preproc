#compdef mris_preproc
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_preproc
# mris_preproc - assemble and resample surface data for group analysis

local ret=1

_arguments -s -S \
  '--out[output file]:file:_files' \
  '--target[common-space subject for resampling]:subject:' \
  '--hemi[hemisphere (lh or rh)]:hemi:(lh rh)' \
  '--meas[surface measure to use as input]:meas:' \
  '--area[extract vertex area from surface]:surf:' \
  '*--s[input subject (may be repeated)]:subject:' \
  '--fsgd[subject list from FSGD file]:file:_files' \
  '--f[subject list from text file]:file:_files' \
  '--is[full path to input surface measure file]:file:_files' \
  '--srcfmt[source format specification]:fmt:' \
  '--iv[volume file and registration matrix]:spec:' \
  '--projfrac[sampling fraction along surface normal]:frac:' \
  '--fwhm[smoothing on target surface (mm)]:fwhm:' \
  '--fwhm-src[smoothing on source surface (mm)]:fwhm:' \
  '--niters[smoothing iterations on target]:n:' \
  '--niters-src[smoothing iterations on source]:n:' \
  '--paired-diff[compute paired differences]' \
  '--paired-diff-norm[paired differences normalized by average]' \
  '--paired-diff-norm1[paired differences normalized by first input]' \
  '--paired-diff-norm2[paired differences normalized by second input]' \
  '--cache-out[save preprocessed data for reuse]:spec:' \
  '--cache-in[use cached preprocessed data]:spec:' \
  '--cache-out-only[cache without creating output]:spec:' \
  '--mean[compute mean of all inputs]' \
  '--synth[synthesize input with white Gaussian noise]' \
  '--surfreg[surface registration file (default sphere.reg)]:surf:' \
  '--reshape[reshape spatial dimensions]' \
  '--tmpdir[specify temporary directory]:dir:_files -/' \
  '--nocleanup[retain temporary files]' \
  '--cleanup[delete temporary files (default)]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
