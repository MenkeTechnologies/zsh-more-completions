#compdef megamerger
# Documentation: https://emboss.bioinformatics.nl/cgi-bin/emboss/help/megamerger
# Reference accessed: 2026-05-19
# Verified: upstream EMBOSS help page for megamerger.

# EMBOSS megamerger: merge two large overlapping nucleic-acid sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[first DNA sequence]:DNA USA:_files' \
  '-bsequence=[second DNA sequence]:DNA USA:_files' \
  '-wordsize=[word size for overlap match]:size:' \
  '-prefer[use mismatches from the more confidently identified sequence]' \
  '-outseq=[merged sequence output file]:file:_files' \
  '-outfile=[merge report file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
