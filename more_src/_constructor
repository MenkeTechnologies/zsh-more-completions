#compdef constructor
# Documentation: https://pypi.org/project/constructor/
# create installers from conda packages

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display the version being used and exit]' \
  '--help-construct[describe available construct.yaml configuration options and exit]' \
  '--debug[enable debug output]' \
  '--output-dir=[directory in which the output installer is written]:dir:_files -/' \
  '--cache-dir=[cache directory for downloading conda packages]:dir:_files -/' \
  '--clean[clean out the cache directory and exit]' \
  '--platform=[platform the installer is for]:platform' \
  '--dry-run[solve package specs but do not create installer]' \
  '--render[parse and render the construct.yaml file]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--conda-exe=[path to conda executable (conda-standalone, micromamba)]:exe:_files' \
  '--config-filename=[path to construct YAML file read by constructor]:file:_files' \
  '*:dir:_files -/' && ret=0

return ret
