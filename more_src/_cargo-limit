#compdef cargo-limit
# Documentation: https://github.com/alopatindev/cargo-limit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cargo-limit installs `cargo l<cmd>` wrappers (lbuild, lcheck, lrun, etc.).
# Configuration is via env vars (CARGO_MSG_LIMIT, CARGO_TIME_LIMIT, CARGO_ASC,
# CARGO_FORCE_WARN, CARGO_DEPS_WARN, CARGO_EDITOR). No native CLI flags.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::cargo_arguments:_default' && return 0
