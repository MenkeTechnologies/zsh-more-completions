#compdef cargo-limit
# Documentation: https://man.archlinux.org/search?q=cargo-limit
# Reference accessed: 2026-05-16

# https://github.com/cargo-limit/cargo-limit — cargo wrapper that suppresses warnings until errors are fixed

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::cargo_arguments:_default' && return 0
