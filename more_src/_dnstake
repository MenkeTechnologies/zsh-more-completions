#compdef dnstake

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-f --file)'{-f,--file}'[Input file containing list of domains]:file:_files' \
  '(-t --target)'{-t,--target}'[Single target domain]:domain:' \
  '(-c --concurrency)'{-c,--concurrency}'[Number of concurrent workers]:number:' \
  '(-s --silent)'{-s,--silent}'[Suppress output, only show vulnerable domains]' \
  '(-o --output)'{-o,--output}'[Output file to write results]:file:_files' \
  '--timeout[Timeout for DNS queries in seconds]:seconds:' \
  '--resolver[Custom DNS resolver to use]:resolver:' \
  '--fingerprint[Show only results matching specific fingerprint]:fingerprint:' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version information]' \
  && ret=0

return ret
