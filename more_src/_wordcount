#compdef wordcount

# EMBOSS wordcount: count words of specified size in sequence
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output instead of file]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug output to program.dbg]' \
  '-verbose[report verbose informational messages]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report current EMBOSS version]' \
  '-outfile=[output filename]:file:_files' \
  '-sequence=[input sequence(s)]:file:_files' \
  '-wordsize=[word size]:size:' \
  '-mincount=[minimum count to report]:count:' \
  '*:sequence file:_files' && ret=0

return ret
