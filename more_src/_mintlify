#compdef mintlify

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:start the development server'
  'install:install dependencies'
  'broken-links:check for broken links'
  'rename:rename a file or directory and update references'
  'build:build the documentation site'
  'help:show help for a command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      dev)
        _arguments \
          '--port=[port for dev server]:port' \
          '--host=[host for dev server]:host' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      broken-links)
        _arguments \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      rename)
        _arguments \
          '1:old path:_files' \
          '2:new path' && ret=0
        ;;
      install)
        _arguments \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      build)
        _arguments \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
