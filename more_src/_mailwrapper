#compdef mailwrapper
# Documentation: https://man.archlinux.org/search?q=mailwrapper
# Reference accessed: 2026-05-16

# mailwrapper: select the configured MTA at runtime
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::mailwrapper args:_files' && ret=0
return ret
