#compdef wipefs
# _wipefs-bin — util-linux wipefs filesystem signature wipe; remove FS/partition/RAID signatures from devices
# upstream: https://github.com/util-linux/util-linux

_wipefs-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[wipe all signatures]' \
        '(-b --backup)'{-b,--backup}'[create wipe backup file]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-i --noheadings)'{-i,--noheadings}'[no header in tabular output]' \
        '(-J --json)'{-J,--json}'[json output]' \
        '(-n --no-act)'{-n,--no-act}'[dry run]' \
        '(-o --offsets)'{-o,--offsets}'+[offsets]:offsets:' \
        '(-O --output)'{-O,--output}'+[columns]:cols:' \
        '(-p --parsable)'{-p,--parsable}'[parsable output]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-t --types)'{-t,--types}'+[fs types]:types:' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:device:_files'
}

_wipefs-bin "$@"
