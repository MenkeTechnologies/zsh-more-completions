#compdef kubeswitch
# Documentation: https://github.com/danielfoehrKn/kubeswitch
# kubectx for operators: switch between kubeconfig contexts across stores

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config-path=[path to switch config file]:file:_files' \
  '--kubeconfig-name=[name/pattern to match kubeconfig files]:name' \
  '--kubeconfig-path=[search path for kubeconfigs]:path:_files' \
  '--state-directory=[directory for internal state]:dir:_files -/' \
  '--store=[backing store type]:store:(filesystem vault)' \
  '--vault-api-address=[Vault API endpoint URL]:url' \
  '--no-index[skip index files and refresh the index]' \
  '--show-preview[show sanitized kubeconfig preview]' \
  '--debug[enable debug logging]' \
  '*:command:(alias clean completion exec gardener history hooks list-contexts namespace set-context set-last-context set-previous-context version)' && ret=0

return ret
