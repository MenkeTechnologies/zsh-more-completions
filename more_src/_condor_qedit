#compdef condor_qedit
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_qedit.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_qedit: edit a job attribute in the schedd.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-debug[send debug info to stderr]' \
  '-n[schedd name]:schedd-name:' \
  '-pool[pool containing the schedd]:pool-name:' \
  '-forward[forward modifications to shadow/gridmanager]' \
  '*:jobid attribute=value:' && ret=0
return ret
