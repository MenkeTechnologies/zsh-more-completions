#compdef condor_qedit

# condor_qedit: edit a job attribute in the schedd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-name[schedd name]:name:' \
  '-pool[pool]:pool:' \
  '-debug[debug]' \
  '-forall[apply to all owners]' \
  '*:jobid attribute=value:' && ret=0
return ret
