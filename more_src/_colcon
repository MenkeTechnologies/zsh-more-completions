#compdef colcon

local curcontext="$curcontext" state line ret=1

_colcon_commands() {
  local -a commands=(
    'build:Build a set of packages'
    'test:Test a set of packages'
    'test-result:Show test results'
    'list:List packages'
    'info:Show package information'
    'metadata:Manage metadata'
    'mixin:Manage mixins'
    'extension-points:List extension points'
    'extensions:List extensions'
    'graph:Generate a dependency graph'
  )
  _describe -t commands 'colcon command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '--log-base[Base path for log directories]:path:_files -/' \
  '--log-level[Set log level]:level:(debug info warn error critical)' \
  '1:command:_colcon_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--build-base[Base path for build directories]:path:_files -/' \
          '--install-base[Base path for install directories]:path:_files -/' \
          '--merge-install[Merge all install prefixes into a single location]' \
          '--symlink-install[Use symlinks instead of copying files]' \
          '--packages-select[Only process selected packages]:packages' \
          '--packages-skip[Skip specified packages]:packages' \
          '--packages-up-to[Only process packages up to listed packages]:packages' \
          '--packages-above[Only process packages above listed packages]:packages' \
          '--packages-select-by-dep[Select packages by dependency]:packages' \
          '--cmake-args[Extra arguments for CMake]:args' \
          '--cmake-target[Build specific CMake target]:target' \
          '--cmake-clean-cache[Remove CMake cache before build]' \
          '--cmake-clean-first[Build target clean first]' \
          '--cmake-force-configure[Force CMake configure step]' \
          '--event-handlers[Event handlers to enable]:handlers' \
          '--parallel-workers[Maximum number of parallel workers]:workers' \
          '--executor[Executor to use]:executor:(sequential parallel)' \
          '--continue-on-error[Continue building other packages on error]' \
          '*:path:_files -/' \
          && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--build-base[Base path for build directories]:path:_files -/' \
          '--install-base[Base path for install directories]:path:_files -/' \
          '--merge-install[Merge all install prefixes into a single location]' \
          '--packages-select[Only process selected packages]:packages' \
          '--packages-skip[Skip specified packages]:packages' \
          '--packages-up-to[Only process packages up to listed packages]:packages' \
          '--event-handlers[Event handlers to enable]:handlers' \
          '--parallel-workers[Maximum number of parallel workers]:workers' \
          '--executor[Executor to use]:executor:(sequential parallel)' \
          '--return-code-on-test-failure[Return non-zero exit code on test failure]' \
          '--ctest-args[Extra arguments for CTest]:args' \
          && ret=0
        ;;
      test-result)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--build-base[Base path for build directories]:path:_files -/' \
          '--all[Show all test results]' \
          '--verbose[Show verbose output]' \
          '--test-result-base[Base path for test results]:path:_files -/' \
          && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--topological-order[Order by topological sort]' \
          '--packages-up-to[Only list packages up to listed packages]:packages' \
          '--names-only[Only output package names]' \
          '--paths-only[Only output package paths]' \
          && ret=0
        ;;
      info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:package' \
          && ret=0
        ;;
      metadata)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:((add\:"Add metadata" remove\:"Remove metadata"))' \
          && ret=0
        ;;
      mixin)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:((add\:"Add mixin" remove\:"Remove mixin" show\:"Show mixin"))' \
          && ret=0
        ;;
      extension-points)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      extensions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      graph)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--dot[Output in dot format]' \
          '--legend[Include legend]' \
          '--packages-up-to[Only include packages up to listed packages]:packages' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
