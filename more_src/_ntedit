#compdef ntedit
# Documentation: https://github.com/bcgsc/ntEdit
# ntEdit: fast, lightweight genome assembly polishing and SNV detection

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--draft=[input draft genome assembly in FASTA]:file:_files' \
  '--reads=[prefix of reads file(s) for polishing]:prefix' \
  '-k+[k-mer size]:kmer' \
  '-i+[maximum insertion bases to try]:insertions:(0 1 2 3 4 5)' \
  '-d+[maximum deletion bases to try]:deletions' \
  '-x+[k/x ratio for missing k-mers]:ratio' \
  '-y+[k/y ratio for edited k-mers present]:ratio' \
  '-m+[editing mode]:mode:(0 1 2)' \
  '-j+[check every jth k-mer in subset]:j' \
  '-t+[number of threads]:threads' \
  '-z+[minimum contig length]:length' \
  '-a+[soft-mask missing k-mer positions]:mask:(0 1)' \
  '--cutoff=[minimum k-mer coverage threshold]:cutoff' \
  '--solid[output non-erroneous k-mers only]' \
  '(-v)-v[verbose mode]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-n --dry-run)'{-n,--dry-run}'[print commands without executing]' \
  '(-f --force)'{-f,--force}'[run all steps regardless of existing output]' && ret=0

return ret
