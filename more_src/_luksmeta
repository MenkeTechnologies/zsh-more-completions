#compdef luksmeta
# Documentation: https://manpages.debian.org/bookworm/luksmeta/luksmeta.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm luksmeta(8) manpage.

# luksmeta: store metadata in LUKSv1 header gap
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'test:test if LUKSmeta is initialized'
  'nuke:nuke header gap'
  'init:initialize LUKSmeta'
  'show:show slot info'
  'save:save metadata to slot'
  'load:load metadata from slot'
  'wipe:wipe metadata from slot'
)
_arguments -C \
  '(-d --device)'{-d,--device=}'[LUKS device]:device:_files -g "/dev/*"' \
  '(-s --slot)'{-s,--slot=}'[slot number]:slot:' \
  '(-u --uuid)'{-u,--uuid=}'[UUID for operation]:uuid:' \
  '(-f --force)'{-f,--force}'[suppress prompts]' \
  '-n[nuke LUKSv1 header gap before init (init only)]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'luksmeta command' commands && ret=0 ;;
esac
return ret
