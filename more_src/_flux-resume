#compdef flux-resume
# Documentation: https://fluxcd.io/flux/cmd/flux_resume/
# FluxCD resume: re-enable suspended resources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--all[resume all resources in that namespace]' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' \
  '*::subcommand:(alert alert-provider helmrelease image kustomization receiver source)' && ret=0

return ret
