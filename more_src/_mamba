#compdef mamba

# Zsh completion for mamba - fast conda package manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'activate:Activate an environment'
  'deactivate:Deactivate current environment'
  'install:Install a list of packages into a specified conda environment'
  'update:Updates conda packages to the latest compatible version'
  'upgrade:Alias for update'
  'remove:Remove a list of packages from a specified conda environment'
  'uninstall:Alias for remove'
  'create:Create a new conda environment from a list of specified packages'
  'list:List linked packages in a conda environment'
  'package:Low-level conda package utility'
  'clean:Remove unused packages and caches'
  'config:Modify configuration values in .condarc'
  'info:Display information about current mamba install'
  'init:Initialize shell for use with mamba/conda'
  'run:Run an executable in a conda environment'
  'search:Search for packages and display associated information'
  'shell:Generate shell functions for conda'
  'env:Tools for managing mamba environments'
  'repoquery:Query package repositories'
  'help:Displays a list of available conda commands'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--no-plugins[disable all plugins]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install|update|upgrade)
        _arguments \
          '(-n --name)'{-n,--name}'[name of environment]:name:' \
          '(-p --prefix)'{-p,--prefix}'[full path to environment location]:path:_files -/' \
          '(-c --channel)'{-c,--channel}'[additional channel to search]:channel:' \
          '--override-channels[do not search default or .condarc channels]' \
          '-y[do not ask for confirmation]' \
          '--yes[do not ask for confirmation]' \
          '--dry-run[only display what would have been done]' \
          '--quiet[do not display progress bar]' \
          '(-q --quiet)'{-q,--quiet}'[do not display progress bar]' \
          '*:package:' && ret=0
        ;;
      create)
        _arguments \
          '(-n --name)'{-n,--name}'[name of environment]:name:' \
          '(-p --prefix)'{-p,--prefix}'[full path to environment location]:path:_files -/' \
          '(-c --channel)'{-c,--channel}'[additional channel to search]:channel:' \
          '--clone[path to (or name of) existing local environment]:env:' \
          '-f[environment definition file]:file:_files' \
          '--file[environment definition file]:file:_files' \
          '-y[do not ask for confirmation]' \
          '--yes[do not ask for confirmation]' \
          '--dry-run[only display what would have been done]' \
          '*:package:' && ret=0
        ;;
      remove|uninstall)
        _arguments \
          '(-n --name)'{-n,--name}'[name of environment]:name:' \
          '(-p --prefix)'{-p,--prefix}'[full path to environment location]:path:_files -/' \
          '--all[remove all packages, i.e., the entire environment]' \
          '-y[do not ask for confirmation]' \
          '--yes[do not ask for confirmation]' \
          '*:package:' && ret=0
        ;;
      activate)
        _arguments ':environment:' && ret=0
        ;;
      search)
        _arguments \
          '(-c --channel)'{-c,--channel}'[additional channel to search]:channel:' \
          '--override-channels[do not search default or .condarc channels]' \
          ':package:' && ret=0
        ;;
    esac
    ;;
esac

return ret
