#compdef setext
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss179.html
# KAPPA: manipulates the contents of a specified NDF extension

local ret=1

_arguments -s \
  'NDF=[NDF to modify or examine]:ndf:_files -g "*.sdf"' \
  'XNAME=[name of the extension]:name' \
  'XTYPE=[data type of the extension]:type' \
  'OPTION=[operation to perform]:opt:(Delete Erase Exit Get Put Rename Select)' \
  'CNAME=[component name within the extension]:name' \
  'CTYPE=[data type of the component]:type' \
  'CVALUE=[value(s) for the component]:value' \
  'NEWNAME=[new name for a renamed component]:name' \
  'SHAPE=[dimensions of the component]:shape' \
  'LOOP=[allow multiple operations per run]:bool:(TRUE FALSE)' \
  'OK=[confirm erasure or overwrite]:bool:(TRUE FALSE)' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
