#compdef wormhole

# Zsh completion for Magic Wormhole - secure file transfer

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--relay-url=[override the relay server URL]:url' \
  '--transit-helper=[override the transit relay]:url' \
  '--appid=[override the application ID]:appid' \
  '--tor[use Tor for the connection]' \
  '--no-listen[do not use direct connections]' \
  '--hide-progress[suppress progress bar display]' \
  '--verify[display verification string]' \
  '--code=[use a pre-generated code]:code' \
  '--code-length=[length of the short code]:length' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'send:send a text message, file, or directory'
      'receive:receive a text message, file, or directory'
      'ssh:facilitate SSH key exchange'
    )
    _describe -t commands 'wormhole command' commands && ret=0
    ;;
  args)
    case $line[1] in
      send)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--relay-url=[override the relay server URL]:url' \
          '--transit-helper=[override the transit relay]:url' \
          '--tor[use Tor for the connection]' \
          '--no-listen[do not use direct connections]' \
          '--hide-progress[suppress progress bar display]' \
          '--verify[display verification string]' \
          '--code=[use a pre-generated code]:code' \
          '--code-length=[length of the short code]:length' \
          '--text=[send a text message]:text' \
          '*:file or directory:_files' && ret=0
        ;;
      receive)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--relay-url=[override the relay server URL]:url' \
          '--transit-helper=[override the transit relay]:url' \
          '--tor[use Tor for the connection]' \
          '--no-listen[do not use direct connections]' \
          '--hide-progress[suppress progress bar display]' \
          '--verify[display verification string]' \
          '--output-file=[write to this file or directory]:file:_files' \
          '--accept-file[accept file transfer without prompting]' \
          '1:code' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(invite accept)' && ret=0
        ;;
    esac
    ;;
esac

return ret
