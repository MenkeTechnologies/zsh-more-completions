#compdef tgswitch

_tgswitch() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments \
        '(-b --bin)'{-b,--bin}'[Custom binary path for Terragrunt]:path:_files' \
        '(-d --default)'{-d,--default}'[Default Terragrunt version]:version:' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-l --list-all)'{-l,--list-all}'[List all available Terragrunt versions]' \
        '(-s --show)'{-s,--show}'[Show current Terragrunt version]' \
        '(-u --latest)'{-u,--latest}'[Use latest stable Terragrunt version]' \
        '(-v --version)'{-v,--version}'[Show tgswitch version]' \
        '1:version:'
}

_tgswitch "$@"
