#compdef tarsnap-cli
# _tarsnap-cli — Colin Percival Tarsnap secure online backup service CLI alias (tarsnap team, C); custom argparse
# upstream: https://www.tarsnap.com

_tarsnap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--archive-names[list archives]' \
        '--cachedir=+[cache dir]:dir:_files -/' \
        '--check-blocks[check blocks before storing]' \
        '--checkpoint-bytes=+[bytes]:n:' \
        '--configfile=+[config file]:file:_files -g "tarsnap.conf"' \
        '--creationtime=+[creation time]:str:' \
        '--csv-file=+[csv file]:file:_files' \
        '--dry-run[dry run]' \
        '--exclude=+[pattern]:str:' \
        '--fsck[check archives]' \
        '--fsck-prune[fsck and prune]' \
        '--humanize-numbers[humanize numbers]' \
        '--include=+[pattern]:str:' \
        '--insane-filesystems[ignore filesystem warnings]' \
        '--initialize-cachedir[initialize cache dir]' \
        '--iso-dates[ISO 8601 dates]' \
        '--keyfile=+[key file]:file:_files' \
        '--keep-going[continue on error]' \
        '--list-archives[list archives]' \
        '--lowmem[low memory]' \
        '--maxbw=+[bytes]:n:' \
        '--maxbw-rate=+[bytes/s]:n:' \
        '--maxbw-rate-down=+[bytes/s]:n:' \
        '--maxbw-rate-up=+[bytes/s]:n:' \
        '--newer=+[date]:str:' \
        '--newer-mtime=+[date]:str:' \
        '--newer-than=+[file]:file:_files' \
        '--newer-mtime-than=+[file]:file:_files' \
        '--no-aggressive-networking[no aggressive networking]' \
        '--nodump[skip files with nodump]' \
        '--no-config-include[no config include]' \
        '--no-config-exclude[no config exclude]' \
        '--no-default-config[no default config]' \
        '--no-disk-pause[no disk pause]' \
        '--no-humanize-numbers[no humanize]' \
        '--no-insane-filesystems[no insane filesystems]' \
        '--no-iso-dates[no ISO dates]' \
        '--no-print-stats[no print stats]' \
        '--no-quiet-deletes[verbose deletes]' \
        '--no-retry-forever[do not retry forever]' \
        '--no-snaptime[no snaptime]' \
        '--no-store-atime[no atime]' \
        '--null[null delimiter]' \
        '--nuke[delete all archives]' \
        '--one-file-system[stay on one fs]' \
        '--passphrase[use passphrase]' \
        '--print-stats[print stats]' \
        '--quiet-deletes[quiet deletes]' \
        '--recover[recover]' \
        '--retry-forever[retry forever]' \
        '--snaptime=+[time]:str:' \
        '--store-atime[store atime]' \
        '--strict-passphrase[strict passphrase]' \
        '--totals[totals]' \
        '--verify-config[verify config]' \
        '-c[create archive]' \
        '-d[delete archive]' \
        '-x[extract archive]' \
        '-t[list archive contents]' \
        '-r[restore]' \
        '-f+[archive name]:str:' \
        '-C+[change dir]:dir:_files -/' \
        '-v[verbose]' \
        '-O[output to stdout]' \
        '-T+[files from]:file:_files' \
        '-X+[exclude from]:file:_files' \
        '*:files:_files'
}

_tarsnap-cli "$@"
