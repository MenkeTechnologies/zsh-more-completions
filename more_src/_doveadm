#compdef doveadm

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'acl:manage ACLs'
  'altmove:move mails to alternate storage'
  'auth:authenticate as a user'
  'backup:incremental backup of mails'
  'batch:run multiple commands per user'
  'config:dump configuration'
  'copy:copy messages between mailboxes'
  'deduplicate:remove duplicate messages'
  'director:director administration'
  'dump:dump Dovecot internal state'
  'exec:run a Dovecot binary'
  'expunge:expunge messages'
  'fetch:fetch mail data'
  'flags:manage IMAP flags'
  'force-resync:force resync of mailbox state'
  'fs:filesystem operations'
  'fts:full-text search admin'
  'import:import mailboxes'
  'index:index mailboxes'
  'instance:list/manage instances'
  'kick:disconnect users'
  'log:log operations'
  'mailbox:mailbox operations'
  'move:move messages between mailboxes'
  'oauth2:OAuth2 operations'
  'penalty:show authentication penalties'
  'proxy:proxy admin'
  'purge:purge mail storage'
  'pw:password generation/verification'
  'quota:quota operations'
  'rebuild:rebuild indexes'
  'reload:reload configuration'
  'replicator:replicator admin'
  'save:save mail to a mailbox'
  'search:search mailboxes'
  'sieve:Sieve script management'
  'stats:server statistics'
  'stop:stop server'
  'sync:sync mailboxes'
  'user:user lookup'
  'who:list logged-in users'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '-D[debug logging]' \
  '-f=[output formatter]:fmt:(flow pager tab table)' \
  '*-o=[Dovecot setting=value]:setting:' \
  '-v[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'doveadm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (mailbox)
        _values 'mailbox action' \
          'create' 'delete' 'list' 'rename' 'status' 'subscribe' 'unsubscribe' \
          'update' 'cryptokey' 'cache' && ret=0
        ;;
      (log)
        _values 'log action' 'errors' 'find' 'reopen' 'test' && ret=0
        ;;
      (stats)
        _values 'stats action' 'dump' 'top' 'reset' 'add' 'remove' && ret=0
        ;;
      (fts)
        _values 'fts action' 'optimize' 'rescan' 'check' && ret=0
        ;;
      (replicator)
        _values 'replicator action' \
          'add' 'dsync-status' 'remove' 'replicate' 'status' && ret=0
        ;;
      (instance)
        _values 'instance action' 'list' 'remove' && ret=0
        ;;
      (proxy)
        _values 'proxy action' 'kick' 'list' && ret=0
        ;;
      (sieve)
        _values 'sieve action' \
          'put' 'get' 'delete' 'list' 'rename' 'activate' 'deactivate' && ret=0
        ;;
      (acl)
        _values 'acl action' 'add' 'delete' 'get' 'remove' 'set' && ret=0
        ;;
      (quota)
        _values 'quota action' 'get' 'recalc' 'set' && ret=0
        ;;
      (pw)
        _arguments \
          '-l[list available schemes]' \
          '-p=[password]:password:' \
          '-r=[rounds]:n:' \
          '-s=[scheme]:scheme:' \
          '-t=[hash to verify]:hash:' \
          '-u=[user]:user:_users' \
          '-V[verbose]' && ret=0
        ;;
      (fs)
        _values 'fs action' 'get' 'put' 'copy' 'delete' 'iter' 'iter-dirs' 'metaset' && ret=0
        ;;
      (oauth2)
        _values 'oauth2 action' 'token' && ret=0
        ;;
    esac
    ;;
esac

return ret
