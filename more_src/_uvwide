#compdef uvwide
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvwide.html
# MIRIAD uvwide - recompute or flag wideband channels

local ret=1

_arguments -s -S \
  'vis=[input visibility dataset name]:vis:_files' \
  'out=[output visibility dataset]:out:_files' \
  'reset=[recompute all wideband data when true]:reset' \
  'narrow=[reflag narrow band from wideband flags]:narrow' \
  '*:visibility data:_files' && ret=0

return ret
