#compdef openmw-bulletobjecttool
# _openmw-bulletobjecttool — pre-generate Bullet shape cache for OpenMW (OpenMW/openmw)
# upstream: https://github.com/OpenMW/openmw
# Flags from apps/bulletobjecttool/main.cpp (boost::program_options).

_openmw-bulletobjecttool() {
    _arguments \
        '--help[print help message]' \
        '--version[print version information and quit]' \
        '*--data=[set data directories]:dir:_files -/' \
        '--data-local=[set local data directory (highest priority)]:dir:_files -/' \
        '*--fallback-archive=[fallback archive (bsa)]:archive:' \
        '*--content=[content file(s): esm/esp/omwgame/omwaddon/omwscripts]:file:_files' \
        '--encoding=[character encoding]:enc:(win1250 win1251 win1252)' \
        '*--fallback=[fallback config entries]:kv:'
}

_openmw-bulletobjecttool "$@"
