#compdef grub-mkfont
# _grub-mkfont — GRUB grub-mkfont (rasterise a TrueType / OpenType font to a GRUB .pf2 bitmap font usable by the early-boot console; -o output, -i index inside .ttc, -n name override, -s size points, -d desc, -b bold, -a force ascii-only, -c char range comma list, -r range hex-hex, --no-bitmap, --no-hinting, -V version, -h help; positional argument is the font file)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mkfont.c on tip.

_grub-mkfont() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "*.pf2"' \
        '-i+[ttc index]:n:' \
        '-n+[name]:name:' \
        '-s+[size]:size:' \
        '-d+[desc]:desc:' \
        '-b[bold]' \
        '-a[ascii only]' \
        '-c+[char range csv]:csv:' \
        '-r+[hex-hex range]:range:' \
        '--no-bitmap[no bitmap]' \
        '--no-hinting[no hinting]' \
        '*:font file:_files -g "*.(ttf|otf|ttc)"'
}

_grub-mkfont "$@"
