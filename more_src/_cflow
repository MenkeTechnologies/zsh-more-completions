#compdef cflow

# Zsh completion for cflow (C call graph analyzer)

_cflow() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-d --depth)'{-d,--depth}'[set depth limit]:depth:' \
    '(-r --reverse)'{-r,--reverse}'[produce reverse call graph]' \
    '(-x --xref)'{-x,--xref}'[produce cross-reference listing]' \
    '(-T --tree)'{-T,--tree}'[draw tree using ASCII art]' \
    '(-b --brief)'{-b,--brief}'[brief output]' \
    '--debug=[set debug level]:level:' \
    '(-f --format)'{-f,--format}'[use GNU-style format for printing]' \
    '(-l --print-level)'{-l,--print-level}'[print nesting level along with call tree]' \
    '(-n --number)'{-n,--number}'[print line numbers]' \
    '(-o --output)'{-o,--output}'[output file]:output file:_files' \
    '(-m --main)'{-m,--main}'[set entry point name]:function name:' \
    '--no-main[do not assume main as entry point]' \
    '(-p --pushdown)'{-p,--pushdown}'[emulate pushdown automaton]:count:' \
    '(-i --include)'{-i,--include}'[include specified symbol classes]:class:(x s t _)' \
    '(-e --exclude)'{-e,--exclude}'[exclude specified symbol classes]:class:(x s t _)' \
    '--omit-arguments[do not print argument lists]' \
    '--omit-symbol-names[do not print symbol names]' \
    '-I+[add include directory]:include dir:_files -/' \
    '-D+[define preprocessor symbol]:name=value:' \
    '-U+[undefine preprocessor symbol]:name:' \
    '--cpp=[preprocessor command]:command:_command_names' \
    '--no-cpp[do not run preprocessor]' \
    '(-S --use-indentation)'{-S,--use-indentation}'[use indentation to determine scope]' \
    '--ansi[accept only ANSI C syntax]' \
    '--level-indent=[set indentation per level]:string:' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-V --version)'{-V,--version}'[display version]' \
    '*:source files:_files -g "*.{c,h,i,y,l}"' \
    && ret=0

  return ret
}

_cflow "$@"
