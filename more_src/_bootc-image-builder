#compdef bootc-image-builder
# _bootc-image-builder — build disk images from a bootc container (osbuild/bootc-image-builder)
# upstream: https://github.com/osbuild/bootc-image-builder
# Subcommands + flags from bib/cmd/bootc-image-builder/main.go (cobra).

_bootc-image-builder() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--log-level=[logging level]:level:(debug info error)' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_bootc-image-builder_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                build|manifest)
                    _arguments \
                        '*--type=[image type to build]:type:(qcow2 ami iso raw vhd vmdk gce anaconda-iso)' \
                        '--rpmmd=[rpm metadata cache directory]:dir:_files -/' \
                        '--target-arch=[target architecture]:arch:(amd64 arm64 x86_64 aarch64 ppc64le s390x)' \
                        '--build-container=[custom container for the image build]:ref:' \
                        '--installer-payload-ref=[bootc installer payload ref]:ref:' \
                        '--rootfs=[root filesystem type]:fs:(ext4 xfs btrfs)' \
                        '--in-vm[run osbuild in a virtual machine]' \
                        '--use-librepo[use librepo for package download]' \
                        '--no-default-kernel-args[skip the default kernel cmdline args]' \
                        '--config=[build config file (default: /config.json)]:file:_files -g "*.{json,toml,yaml}"' \
                        '--aws-ami-name=[AWS AMI name (type=ami)]:name:' \
                        '--aws-bucket=[S3 bucket for AMI staging]:bucket:' \
                        '--aws-region=[AWS region for AMI upload]:region:' \
                        '--chown=[chown output dir to UID:GID]:uid\:gid:' \
                        '--output=[artifact output directory]:dir:_files -/' \
                        '--store=[osbuild store for intermediate trees]:dir:_files -/' \
                        '--progress=[progress bar style]:style:(auto verbose term)' \
                        '1:bootc container ref:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_bootc-image-builder_commands] )) ||
_bootc-image-builder_commands() {
    local -a commands
    commands=(
        'build:build a disk image from a bootc container (default)'
        'manifest:generate the osbuild manifest for a bootc container'
        'version:print bootc-image-builder version'
    )
    _describe -t commands 'bootc-image-builder command' commands
}

_bootc-image-builder "$@"
