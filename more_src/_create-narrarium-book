#compdef create-narrarium-book
# Documentation: https://www.npmjs.com/package/create-narrarium-book
# Reference accessed: 2026-05-24
# Verified: npm view create-narrarium-book bin; dist/index.js flags and npm readme.

# Zsh completion for create-narrarium-book - Narrarium book repository scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--title=[book title]:title:' \
  '--language=[book language code]:language:' \
  '--lang=[alias for --language]:language:' \
  '--author=[book author name]:author:' \
  '--sample[include sample content]' \
  '--with-reader[include reader app scaffold]' \
  '--no-reader[omit reader app scaffold]' \
  '--reader-dir=[reader directory name]:directory:' \
  '--pages-domain=[GitHub Pages custom domain]:domain:' \
  '--no-install[skip dependency installation]' \
  '--skip-install[alias for --no-install]' \
  '--upgrade[upgrade an existing Narrarium book repository]' \
  '--quiet[reduce CLI output]' \
  ':book directory:_directories' && ret=0

return ret
