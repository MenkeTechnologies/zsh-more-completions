#compdef faFilter
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# filter fa records, selecting ones that match the specified conditions

local ret=1

_arguments -s -S \
  '-name=[only pass records where name matches wildcard]:wildcard' \
  '-namePatList=[file of regular expressions applied to the fasta name]:file:_files' \
  '-v[invert match, select non-matching records]' \
  '-minSize=[only pass sequences at least this big]:n' \
  '-maxSize=[only pass sequences this size or smaller]:n' \
  '-maxN=[only pass sequences with fewer than this number of Ns]:n' \
  '-uniq[remove duplicate sequence ids, keeping the first]' \
  '-i[make -uniq ignore case]' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:out fa:_files' && ret=0

return ret
