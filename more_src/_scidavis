#compdef scidavis
# Documentation: https://scidavis.sourceforge.net/manual/x94.html
# scidavis - Scientific Data Analysis and Visualization

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show command line options]' \
  '(-a --about)'{-a,--about}'[show about dialog and exit]' \
  '--lang=[start SciDAVis in language XX (en, fr, de, ...)]:lang' \
  '(-m --manual)'{-m,--manual}'[show SciDAVis manual in a standalone window]' \
  '(-v --version)'{-v,--version}'[print SciDAVis version and release date]' \
  '(-x --execute)'{-x,--execute}'[execute the script file given as argument]:file:_files' \
  '*:file:_files' && ret=0

return ret
