#compdef canvas-downloader
# Source: cargo binstall canvas-downloader@0.4.1
# Probed via: completions zsh
# Repository: https://github.com/aik2mlj/canvas-downloader

autoload -U is-at-least

_canvas-downloader() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--config=[Path to config file (default\: platform-specific config locations)]:FILE:_files' \
'-d+[Download location]:FOLDER:_files' \
'--destination-folder=[Download location]:FOLDER:_files' \
'*-t+[Term IDs to download]:ID:_default' \
'*--term-ids=[Term IDs to download]:ID:_default' \
'*-c+[Course names or codes to download - exact match]:NAME:_default' \
'*--course-names=[Course names or codes to download - exact match]:NAME:_default' \
'-i+[Path to ignore patterns file]:FILE:_files' \
'--ignore-file=[Path to ignore patterns file]:FILE:_files' \
'-n[Overwrite local files with newer Canvas versions]' \
'--download-newer[Overwrite local files with newer Canvas versions]' \
'--dry-run[Preview downloads without executing]' \
'--no-raw[Do not save raw JSON responses]' \
'--no-submissions[Do not download assignment submission files]' \
'-v[Enable debug logging]' \
'--verbose[Enable debug logging]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_canvas-downloader_commands" \
"*::: :->Canvas Downloader" \
&& ret=0
    case $state in
    (Canvas Downloader)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:canvas-downloader-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_canvas-downloader__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:canvas-downloader-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_canvas-downloader_commands] )) ||
_canvas-downloader_commands() {
    local commands; commands=(
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'canvas-downloader commands' commands "$@"
}
(( $+functions[_canvas-downloader__completions_commands] )) ||
_canvas-downloader__completions_commands() {
    local commands; commands=()
    _describe -t commands 'canvas-downloader completions commands' commands "$@"
}
(( $+functions[_canvas-downloader__help_commands] )) ||
_canvas-downloader__help_commands() {
    local commands; commands=(
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'canvas-downloader help commands' commands "$@"
}
(( $+functions[_canvas-downloader__help__completions_commands] )) ||
_canvas-downloader__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'canvas-downloader help completions commands' commands "$@"
}
(( $+functions[_canvas-downloader__help__help_commands] )) ||
_canvas-downloader__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'canvas-downloader help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_canvas-downloader" ]; then
    _canvas-downloader "$@"
else
    compdef _canvas-downloader canvas-downloader
fi
