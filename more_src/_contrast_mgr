#compdef contrast_mgr
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/task_fmri/feat/user_guide.html
# FSL: compute contrasts of parameter estimates from a FILM stats directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-cope[only compute the named cope]:cope:' \
  '-suffix[add suffix to output filenames]:suffix:' \
  '-f[F-test contrast matrix file]:fcon:_files' \
  '*:statsdir:_files -/' && ret=0

return ret
