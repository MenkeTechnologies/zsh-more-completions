#compdef prepfold
# Documentation: https://github.com/scottransom/presto/blob/master/docs/prepfold.1
# PRESTO: prepare and fold raw radio data, time series, or events.

local ret=1

_arguments -s -S \
  '-ncpus=[number of OpenMP processors]:n:' \
  '-o+[root of output file names]:root:' \
  '-filterbank[raw data in SIGPROC filterbank format]' \
  '-psrfits[raw data in PSRFITS format]' \
  '-noweights[do not apply PSRFITS weights]' \
  '-noscales[do not apply PSRFITS scales]' \
  '-nooffsets[do not apply PSRFITS offsets]' \
  '-wapp[raw data in WAPP format]' \
  '-window[window correlator lags with Hamming window]' \
  '-topo[fold the data topocentrically]' \
  '-invert[flip (invert) the band]' \
  '-zerodm[subtract mean of all channels from each sample]' \
  '-absphase[use absolute phase associated with polycos]' \
  '-barypolycos[force polycos for barycentered events]' \
  '-debug[show debugging output when calling TEMPO]' \
  '-samples[treat data as samples not integrated data]' \
  '-normalize[bandpass flatten by normalizing subbands]' \
  '-numwapps=[number of WAPPs with contiguous freqs]:n:' \
  '-if=[a specific IF to use]:if:' \
  '-clip=[time-domain sigma for clipping]:sigma:' \
  '-noclip[do not clip the data]' \
  '-noxwin[do not show result plots on-screen]' \
  '-runavg[subtract each blocks average as read]' \
  '-fine[finer gridding in p/pdot plane]' \
  '-coarse[coarser gridding in p/pdot plane]' \
  '-slow[set useful flags for slow pulsars]' \
  '-searchpdd[search p-dotdots too]' \
  '-searchfdd[search f-dotdots too]' \
  '-nosearch[show but do not search p/pdot/DM space]' \
  '-nopsearch[do not search over period]' \
  '-nopdsearch[do not search over p-dot]' \
  '-nodmsearch[do not search over DM]' \
  '-scaleparts[scale part profiles independently]' \
  '-allgrey[greyscale images instead of color]' \
  '-fixchi[adjust reduced chi^2 for off-pulse cal]' \
  '-justprofs[only output profile portions of plot]' \
  '-dm=[central DM of search (cm^-3 pc)]:dm:' \
  '-n+[number of bins in the profile]:proflen:' \
  '-nsub=[number of sub-bands for DM search]:nsub:' \
  '-npart=[number of sub-integrations for period search]:npart:' \
  '-pstep=[minimum period stepsize]:pstep:' \
  '-pdstep=[minimum P-dot stepsize]:pdstep:' \
  '-dmstep=[minimum DM stepsize]:dmstep:' \
  '-npfact=[periods and p-dots search parameter]:npfact:' \
  '-ndmfact=[DMs search parameter]:ndmfact:' \
  '-p+[nominative folding period (s)]:p:' \
  '-pd=[nominative period derivative]:pd:' \
  '-pdd=[nominative period 2nd derivative]:pdd:' \
  '-f+[nominative folding frequency (Hz)]:f:' \
  '-fd=[nominative frequency derivative]:fd:' \
  '-fdd=[nominative frequency 2nd derivative]:fdd:' \
  '-pfact=[factor to multiply candidate p and p-dot]:pfact:' \
  '-ffact=[factor to multiply candidate f and f-dot]:ffact:' \
  '-phs=[offset phase for the profile]:phs:' \
  '-start=[folding start time as fraction of obs]:startT:' \
  '-end=[folding end time as fraction of obs]:endT:' \
  '-psr=[name of pulsar to fold]:psrname:' \
  '-par=[name of a TEMPO par file]:parname:_files' \
  '-polycos=[file with TEMPO polycos]:polycofile:_files' \
  '-timing=[set useful flags for TOA generation]:timing:' \
  '-rzwcand=[candidate number from rzw.cand]:rzwcand:' \
  '-rzwfile=[rzw search .cand file]:rzwfile:_files' \
  '-accelcand=[candidate number from accel .cand]:accelcand:' \
  '-accelfile=[accel search .cand file]:accelfile:_files' \
  '-bin[fold a binary pulsar]' \
  '-pb=[orbital period (s)]:pb:' \
  '-x+[projected orbital semi-major axis (lt-s)]:asinic:' \
  '-e+[orbital eccentricity]:e:' \
  '-To=[time of periastron passage (MJD)]:To:' \
  '-w+[longitude of periastron (deg)]:w:' \
  '-wdot=[rate of advance of periastron (deg/yr)]:wdot:' \
  '-mask=[file containing masking information]:maskfile:_files' \
  '-ignorechan=[comma separated channels to ignore]:chans:' \
  '-events[use an event file instead of time series]' \
  '-days[events in days since EPOCH in .inf file]' \
  '-mjds[events are in MJDs]' \
  '-double[events in binary double precision]' \
  '-offset=[time offset to add to 1st event]:offset:' \
  '*:input data file:_files' && ret=0

return ret
