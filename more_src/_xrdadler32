#compdef xrdadler32
# Documentation: https://man.archlinux.org/man/xrdadler32.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrdadler32: compute ADLER32 of a file (local or xrootd URL).
# Upstream manpage only documents -h; other flags would be fabrication.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[display usage synopsis]' \
  '*:file:_files' && ret=0
return ret
