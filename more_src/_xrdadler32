#compdef xrdadler32
# Documentation: https://man.archlinux.org/search?q=xrdadler32
# Reference accessed: 2026-05-16

# xrdadler32: compute ADLER32 of a file (local or xrootd URL)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '*:file:_files' && ret=0
return ret
