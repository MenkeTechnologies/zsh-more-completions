#compdef nmstatectl

# Zsh completion for nmstatectl - NetworkManager state management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'show:show network state'
  'apply:apply network state from file'
  'commit:commit pending changes'
  'rollback:rollback pending changes'
  'edit:edit network state interactively'
  'gc:clean up unused profiles'
  'version:show version'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nmstatectl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (show)
        _arguments -s -S \
          '--json[output in JSON format]' \
          '--yaml[output in YAML format]' \
          '--running-config[show running configuration only]' \
          '1:interface name' && ret=0
        ;;
      (apply)
        _arguments -s -S \
          '--no-verify[skip verification]' \
          '--no-commit[do not auto-commit]' \
          '--timeout=[set timeout for auto-rollback]:seconds' \
          '--kernel-only[apply to kernel only]' \
          '--json[input is JSON format]' \
          '--yaml[input is YAML format]' \
          '1:state file:_files -g "*.{yml,yaml,json}"' && ret=0
        ;;
      (edit)
        _arguments -s -S \
          '--no-verify[skip verification]' \
          '--json[edit in JSON format]' \
          '--yaml[edit in YAML format]' \
          '1:interface name' && ret=0
        ;;
    esac
    ;;
esac

return ret
