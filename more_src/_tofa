#compdef tofa
# Documentation: https://man.archlinux.org/search?q=tofa
# Reference accessed: 2026-05-16
# Source: cargo binstall tofa@0.11.0
# Probed via: completions zsh
# Repository: https://github.com/stratif-io/tofa

autoload -U is-at-least

_tofa() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tofa_commands" \
"*::: :->tofa" \
&& ret=0
    case $state in
    (tofa)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tofa-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(destroy)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'--codes[Also display current codes and time remaining]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(code)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'--raw[Output bare digits without space (for scripting)]' \
'--copy[Copy to clipboard (the code by default; the otpauth\:// URI when --uri is set)]' \
'--watch[Refresh every second until Ctrl+C]' \
'--uri[Print/copy the entry'\''s \`otpauth\://\` URI instead of the current code. Useful for moving an account to another authenticator app or piping into \`tofa add --uri\`]' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Entry id or name (partial match):_default' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'--name=[Account name (required when using --secret)]:NAME:_default' \
'--secret=[Base32-encoded TOTP secret]:BASE32:_default' \
'--uri=[otpauth\:// URI]:URI:_default' \
'--qr=[Path to a QR code image]:PATH:_files' \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':id:_default' \
&& ret=0
;;
(rename)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':id:_default' \
':new_name:_default' \
&& ret=0
;;
(qr)
_arguments "${_arguments_options[@]}" : \
'(--output-dir)--output=[Save QR as PNG instead of displaying in terminal (single-QR modes)]:PATH:_files' \
'--output-dir=[Directory to write per-entry PNGs into when using \`--multi\`]:DIR:_files' \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'()--all[Export all accounts as a migration QR]' \
'--multi[Emit one otpauth\:// QR per entry instead of a single migration QR. Requires \`--all\` and \`--output-dir\`. Preserves period/algorithm/digits for every entry — use this when the migration format would refuse because the selection mixes 30s and non-30s entries]' \
'-h[Print help]' \
'--help[Print help]' \
'::name -- Entry id or name (partial match):_default' \
&& ret=0
;;
(rekey)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
'--output=[Write to a file instead of stdout]:PATH:_files' \
'--format=[Output format. Defaults to \`json\` for backwards compatibility]:FORMAT:((json\:"Native tofa JSON (re-importable, preserves all metadata)"
uris\:"Plain-text list of \`otpauth\://\` URIs, one per line. Round-trips through \`tofa import <file>.txt\` and is what other apps tend to accept (Ente Auth, Aegis "scan from text", etc.)"))' \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':file:_files' \
&& ret=0
;;
(scan)
_arguments "${_arguments_options[@]}" : \
'--name=[Override the account name (only applied when exactly one entry is found)]:NAME:_default' \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(cam)
_arguments "${_arguments_options[@]}" : \
'--camera=[Camera index passed to the browser (default\: 0)]:INDEX:_default' \
'--name=[Override the account name (default\: derived from QR metadata)]:NAME:_default' \
'--vault=[Path to the vault file (overrides TOFA_VAULT env var)]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tofa__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tofa-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(destroy)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(code)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(rename)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(qr)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(rekey)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(export)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(import)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(scan)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(cam)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tofa_commands] )) ||
_tofa_commands() {
    local commands; commands=(
'init:Create a new encrypted vault' \
'destroy:Permanently delete the vault' \
'list:List all accounts' \
'code:Show the current TOTP code for an account' \
'add:Add a new account' \
'remove:Remove an account' \
'rename:Rename an account' \
'qr:Export a QR code for one or all accounts' \
'rekey:Change the vault passphrase' \
'completions:Print shell completions' \
'export:Export all accounts as plain-text JSON' \
'import:Import accounts from JSON or a migration QR image' \
'scan:Scan screen for a QR code and add the account' \
'cam:Open camera and wait for a QR code to add an account' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tofa commands' commands "$@"
}
