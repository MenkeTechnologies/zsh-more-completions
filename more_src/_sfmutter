#compdef sfmutter
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/generic/Mmutter.c
# Madagascar: smoothly weight data inside a mute zone

local ret=1

_arguments -s \
  'half=[if y second axis is half-offset instead of full offset]:half:(y n)' \
  'nan=[if y put nans instead of zeros]:nan:(y n)' \
  'offset=[input file specifying offset values]:offset file:_files' \
  'tp=[end time]:tp' \
  't0=[starting time]:t0' \
  'v0=[velocity]:v0' \
  'slope0=[slope]:slope0' \
  'slopep=[end slope]:slopep' \
  'x0=[starting space]:x0' \
  'abs=[if y use absolute value of x-x0]:abs:(y n)' \
  'inner=[if y do inner muter]:inner:(y n)' \
  'hyper=[if y do hyperbolic mute]:hyper:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
