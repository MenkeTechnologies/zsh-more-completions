#compdef cloud-node-manager
# _cloud-node-manager — Azure cloud-node-manager (per-node CCM helper)
# upstream: https://github.com/kubernetes-sigs/cloud-provider-azure
# Flags from cmd/cloud-node-manager/app/options/options.go on tip.

_cloud-node-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[Kubernetes API server URL]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--node-name=[node name (default: hostname)]:name:' \
        '--node-status-update-frequency=[how often to update node status]:dur:' \
        '--min-resync-period=[informer min resync period]:dur:' \
        '--kube-api-content-type=[content type for apiserver requests]:type:' \
        '--kube-api-qps=[QPS to apiserver]:f:' \
        '--kube-api-burst=[burst to apiserver]:n:' \
        '--wait-routes=[wait for Azure route-table routes (kubenet)]:bool:(true false)' \
        '--use-instance-metadata=[use IMDS for node info (else ARM)]:bool:(true false)' \
        '--cloud-config=[cloud config file (used when ARM is the source)]:file:_files' \
        '--enable-deprecated-beta-topology-labels=[DEPRECATED: apply beta topology labels]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_cloud-node-manager "$@"
