#compdef jid
# Documentation: https://man.archlinux.org/search?q=jid
# Reference accessed: 2026-05-16

# Zsh completion for jid (JSON incremental digger)

_arguments -s -S \
  '(-q --query)'{-q,--query}'[initial query]:query:' \
  '(-M --monochrome)'{-M,--monochrome}'[monochrome output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:json file:_files -g "*.json"' && return 0
