#compdef purs
# _purs-bin — PureScript compiler CLI (PureScript team, Haskell); strongly-typed functional language compiled to JS
# upstream: https://github.com/purescript/purescript

_purs-bin() {
    local -a sub=(
        'compile:compile PureScript modules'
        'docs:generate docs'
        'graph:print module graph'
        'hierarchy:print class hierarchy'
        'ide:run IDE server'
        'publish:publish package'
        'repl:interactive REPL'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'purs subcommand' sub ;;
        args)
            case $words[1] in
                compile) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--output+[output dir]:dir:_files -/' \
                    '--codegen+[codegen targets]:targets:(js corefn sourcemaps docs)' \
                    '--include+[search path]:dir:_files -/' \
                    '-I+[search path]:dir:_files -/' \
                    '--source-globs-file+[source globs file]:file:_files' \
                    '--verbose-errors[verbose errors]' \
                    '-v[verbose errors]' \
                    '--no-prefix[no prefix]' \
                    '-N[no prefix]' \
                    '--json-errors[json errors]' \
                    '--censor-codes+[censor codes]:codes:' \
                    '--censor-stats[censor stats]' \
                    '--censor-lib[censor lib]' \
                    '--censor-src[censor src]' \
                    '--censor-warnings[censor warnings]' \
                    '--strict[strict]' \
                    '--debug-bundle[debug bundle]' \
                    '*:file:_files -g "*.purs"' ;;
                docs) _arguments \
                    '--format+[format]:format:(markdown html ctags etags)' \
                    '--output+[output dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' \
                    '*:file:_files' ;;
                repl) _arguments \
                    '--include+[search path]:dir:_files -/' \
                    '-I+[search path]:dir:_files -/' \
                    '--node-flags+[node flags]:flags:' \
                    '--port+[port]:port:' ;;
                ide) _arguments \
                    '1:ide cmd:(server client)' \
                    '--port+[port]:port:' ;;
            esac
            ;;
    esac
}

_purs-bin "$@"
