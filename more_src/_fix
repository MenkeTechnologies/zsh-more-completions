#compdef fix

local curcontext="$curcontext" state line ret=1

local -a global_flags
global_flags=(
  '(- *)--help[Show help]'
  '--psk[Pre-shared key for authentication]:key:'
  '--resotocore-uri[Resoto Core URI]:uri:'
  '--format[Output format]:format:(json yaml table csv)'
  '--verbose[Verbose output]'
  '--debug[Debug output]'
)

_arguments -s -S -C \
  $global_flags \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcmds
    subcmds=(
      'collect:Collect cloud resources'
      'search:Search the inventory'
      'tag:Manage resource tags'
      'clean:Clean up resources'
      'protect:Protect resources from cleanup'
      'metrics:Show metrics'
      'system:System management'
      'configs:Manage configurations'
      'workflows:Manage workflows'
      'jobs:Manage jobs'
      'apps:Manage apps'
      'help:Show help'
    )
    _describe -t commands 'fix subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          $global_flags \
          '1:search query:' && ret=0
        ;;
      tag)
        _arguments -s -S -C \
          $global_flags \
          '1: :->tagcmd' \
          '*:: :->tagargs' && ret=0
        case $state in
          tagcmd)
            local -a tag_subcmds
            tag_subcmds=(
              'update:Update a tag'
              'delete:Delete a tag'
            )
            _describe -t commands 'tag subcommand' tag_subcmds && ret=0
            ;;
          tagargs)
            _arguments -s -S \
              '--tag-name[Tag name]:name:' \
              '--tag-value[Tag value]:value:' && ret=0
            ;;
        esac
        ;;
      collect|clean|protect|metrics|system|configs|workflows|jobs|apps)
        _arguments -s -S \
          $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
