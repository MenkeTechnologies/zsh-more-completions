#compdef cargo-msrv-prep
# Documentation: https://github.com/clechasseur/msrv-prep
# Source: clechasseur/msrv-prep src/main.rs + src/common_args.rs — prepare manifests for MSRV verification.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--pins-file-name=[TOML file containing pinned dependencies]:file:_files -g "*.toml"' \
    '--no-remove-rust-version[skip removing the rust-version field]' \
    '--no-merge-pinned-dependencies[skip merging pinned MSRV dependencies]' \
    '(-f --force)'{-f,--force}'[overwrite existing manifest backup files]' \
    '(-n --dry-run)'{-n,--dry-run}'[determine if preparation is required without persisting changes]' \
    '--manifest-backup-suffix=[suffix used for manifest backup files]:suffix:_default' \
    '--backup-root-manifest[always back up the root manifest]' \
    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '(-p --package)*'{-p+,--package=}'[package(s) to operate on]:package:_default' \
    '--workspace[operate on all packages in the workspace]' \
    '--exclude=[exclude packages from the operation]:package:_default' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '(-q --quiet)*'{-q,--quiet}'[decrease verbosity]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
