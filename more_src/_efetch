#compdef efetch

# NCBI EDirect efetch: fetch Entrez records in chosen format
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-db=[Entrez database]:db:(pubmed protein nucleotide nuccore nucest nucgss popset gene structure pmc taxonomy snp dbvar gds homologene mesh assembly bioproject biosample biosystems books pccompound pcsubstance pcassay sra)' \
  '-id=[UID list or accession list]:ids:' \
  '-format=[record format]:format:(uid acc xml json gb gbc gbwithparts ft fasta seqid medline pubmed abstract bibtex docsum native ipg gp gpc ipgu csv tsv ssr rsr asn1 native+xml gene_table)' \
  '-mode=[output mode]:mode:(xml json text asn1)' \
  '-style=[output style]:style:(withparts)' \
  '-WebEnv=[reuse WebEnv]:env:' \
  '-query_key=[reuse query_key]:key:' \
  '-input=[input file with UIDs]:file:_files' \
  '-start=[starting position in sequence record]:n:' \
  '-stop=[ending position in sequence record]:n:' \
  '-strand=[1=forward, 2=reverse]:strand:(1 2)' \
  '-complexity=[record complexity]:n:(0 1 2 3 4)' \
  '-seq_start=[seq start coord]:n:' \
  '-seq_stop=[seq stop coord]:n:' \
  '-chr_start=[chromosome start]:n:' \
  '-chr_stop=[chromosome stop]:n:' \
  '-target=[target db for cross-db]:db:' \
  '*::ids:' && ret=0
return ret
