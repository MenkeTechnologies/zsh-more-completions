#compdef hash_password
# _hash_password — hash a password for Synapse via bcrypt (element-hq/synapse)
# upstream: https://github.com/element-hq/synapse
# Flags from synapse/_scripts/hash_password.py (argparse).

_hash_password() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --password)'{-p+,--password=}'[password to hash (interactive prompt if omitted)]:password:' \
        '(-c --config)'{-c+,--config=}'[Synapse config file]:file:_files -g "*.{yml,yaml}"'
}

_hash_password "$@"
