#compdef couchbase-exporter couchbase_exporter
# _couchbase-exporter — Couchbase Prometheus exporter (couchbase/couchbase-exporter)
# upstream: https://github.com/couchbase/couchbase-exporter
# Flags from main.go (flag).

_couchbase-exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '-couchbase-address=[Couchbase server address]:addr:' \
        '-couchbase-port=[Couchbase server port]:port:' \
        '-couchbase-username=[Couchbase server username]:user:' \
        '-couchbase-password=[Couchbase server plaintext password]:pass:' \
        '-server-address=[exporter bind address]:addr:' \
        '-server-port=[exporter bind port]:port:' \
        '-per-node-refresh=[per-node refresh interval (s)]:secs:' \
        '-token=[bearer token guarding /metrics]:token:' \
        '-cert=[exporter TLS cert file]:file:_files -g "*.(pem|crt)"' \
        '-key=[exporter TLS key file]:file:_files -g "*.(pem|key)"' \
        '-ca=[CA cert file]:file:_files -g "*.(pem|crt)"' \
        '-client-cert=[client cert to authenticate w/ Couchbase]:file:_files -g "*.(pem|crt)"' \
        '-client-key=[client key to authenticate w/ Couchbase]:file:_files -g "*.(pem|key)"' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-log-json=[log as JSON]:bool:(true false)' \
        '-backofflimit=[panic-retry count before exit]:n:' \
        '-config=[exporter config file]:file:_files -g "*.(yml|yaml)"' \
        '-print-config[dump config with overrides to stdout]'
}

_couchbase-exporter "$@"
