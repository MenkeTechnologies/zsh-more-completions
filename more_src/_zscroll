#compdef zscroll
# Documentation: https://github.com/noctuid/zscroll/blob/master/zscroll.1
# zscroll - a text scroller for panels or terminals

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text]' \
  '(-l --length)'{-l,--length}'[character length for the text to be scrolled in]:length:' \
  '(-r --reverse)'{-r,--reverse}'[scroll the text in reverse order]:bool:(true false)' \
  '(-b --before-text)'{-b,--before-text}'[static padding text displayed to the left]:padding:' \
  '(-a --after-text)'{-a,--after-text}'[static padding text displayed to the right]:padding:' \
  '(-p --scroll-padding)'{-p,--scroll-padding}'[padding text between end and start while scrolling]:padding:' \
  '(-s --scroll)'{-s,--scroll}'[whether the text should be scrolled]:bool:(true false)' \
  '(-m --match-text)'{-m,--match-text}'[regexp search term to look for in match-command output]:regexp:' \
  '(-M --match-command)'{-M,--match-command}'[command to search the output of]:command:' \
  '(-d --delay)'{-d,--delay}'[delay between scroll steps]:time:' \
  '(-u --update-check)'{-u,--update-check}'[positional argument is a command to run for the text]:bool:(true false)' \
  '(-U --update-interval)'{-U,--update-interval}'[seconds to wait between update checking commands]:time:' \
  '(-e --eval-in-shell)'{-e,--eval-in-shell}'[execute match-command and positional argument in the shell]:bool:(true false)' \
  '(-n --newline)'{-n,--newline}'[add a newline after every update/step]:bool:(true false)' \
  '(-t --timeout)'{-t,--timeout}'[time in seconds to run before closing]:time:' \
  '--always-reprint=[reprint unchanged text after the specified delay]:bool:(true false)' \
  '*:text:' && ret=0

return ret
