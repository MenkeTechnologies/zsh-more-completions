#compdef bd_info
# Documentation: https://manpages.debian.org/testing/libbluray-bin/bd_info.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bd_info: libbluray utility to identify encryption/DRM on a Blu-Ray

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:Blu-Ray base directory:_files -/' \
  '2:AACS key file:_files' && ret=0

return ret
