#compdef gh-gei
# Documentation: https://github.com/github/gh-gei
# gh-gei - GitHub Enterprise Importer migration CLI for GitHub to GitHub migrations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:(generate-script migrate-repo migrate-org wait-for-migration abort-migration download-logs grant-migrator-role revoke-migrator-role)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      generate-script)
        _arguments -s -S \
          '--github-source-org=[source organization name]:org:' \
          '--github-target-org=[target organization name]:org:' \
          '--output=[output filename for the script]:file:_files' \
          '--download-migration-logs[download migration logs for each repo]' \
          '--all[migrate all repositories]' \
          '--verbose[display more information to the console]' && ret=0
        ;;
      migrate-repo)
        _arguments -s -S \
          '--github-source-org=[source organization name]:org:' \
          '--source-repo=[name of the source repository]:repo:' \
          '--github-target-org=[target organization name]:org:' \
          '--target-repo=[name of the target repository]:repo:' \
          '--target-repo-visibility=[visibility of the new repository]:visibility:(private public internal)' \
          '--skip-releases[skip migrating releases]' \
          '--github-source-pat=[source personal access token]:pat:' \
          '--github-target-pat=[target personal access token]:pat:' \
          '--verbose[display more information to the console]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '--github-source-org=[source organization name]:org:' \
          '--github-target-org=[target organization name]:org:' \
          '--verbose[display more information to the console]' && ret=0
        ;;
    esac
    ;;
esac

return ret
