#compdef mri_concat
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_concat
# FreeSurfer concatenate volumes and apply voxel-wise operations

local ret=1

_arguments -s -S \
  '--o[output]:out:_files' \
  '*--i[input]:invol:_files' \
  '--f[list file of inputs]:listfile:_files' \
  '--paired-sum[computes paired sum]' \
  '--paired-avg[computes paired average]' \
  '--paired-diff[computes paired difference]' \
  '--paired-diff-norm[paired difference scaled by TP1,2 average]' \
  '--paired-diff-norm1[paired difference scaled by TP1]' \
  '--paired-diff-norm2[paired difference scaled by TP2]' \
  '--norm-mean[normalize frames by mean of all TP]' \
  '--norm1[normalize frames by TP1]' \
  '--mtx[multiply by matrix in ascii file]:matrix.asc:_files' \
  '--gmean[average Ng groups]:Ng:' \
  '--combine[average frames from non-zero voxels]' \
  '--keep-datatype[write output in same datatype as input]' \
  '--mul[multiply by mulvar]:mulvar:' \
  '--add[add addval]:addval:' \
  '--abs[take absolute value of input]' \
  '--pos[set input negatives to 0]' \
  '--neg[set input positives to 0]' \
  '--prune[set vox to 0 unless all frames non-zero]' \
  '--mean[compute mean]' \
  '--median[compute median]' \
  '--mean-div-n[compute mean per nframes]' \
  '--sum[compute sum]' \
  '--var[compute variance]' \
  '--std[compute standard deviation]' \
  '--rms[root mean square]' \
  '--max[compute maximum]' \
  '--max-index[compute index of maximum (1-based)]' \
  '--max-index-prune[max index, 0 where all frames 0]' \
  '--max-index-add[add value to non-zero matrix indices]:val:' \
  '--min[compute minimum]' \
  '--rep[replicate N times over frame]:N:' \
  '--fnorm[normalize time series at each voxel]' \
  '--conjunct[voxel-wise conjunction]' \
  '--vote[most frequent value at each voxel]' \
  '--sort[sort each voxel by ascending frame value]' \
  '--tar1[compute temporal ar1]:dofadjust:' \
  '--pca[output is pca]' \
  '--pca-mask[only use voxels whose mask > 0.5]:mask:_files' \
  '--scm[compute spatial covariance matrix]' \
  '--max-bonfcor[compute max and bonferroni correct]' \
  '--mask[mask used with --vote or --sort]:maskfile:_files' \
  '--no-check[do not check inputs (faster)]' \
  '--help[print help]' \
  '--version[print version]' && ret=0

return ret
