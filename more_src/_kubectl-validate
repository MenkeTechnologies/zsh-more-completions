#compdef kubectl-validate
# Documentation: https://github.com/kubernetes-sigs/kubectl-validate
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version=[kubernetes version to validate against]:version:' \
  '--kube-context=[kubeconfig context for cluster-installed CRDs]:context:' \
  '--local-crds=[directory of CRD definitions to use as search path]:dir:_directories' \
  '--local-schemas=[directory of OpenAPI schemas to use as search path]:dir:_directories' \
  '--output=[output format]:format:(human json)' \
  '*:manifest:_files'
