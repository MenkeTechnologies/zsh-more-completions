#compdef kubectl-validate
# Documentation: https://man.archlinux.org/search?q=kubectl-validate
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Namespace]:namespace:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '--schema-cache-dir=[Schema cache directory]:dir:_files -/' \
  '--openapi-schema=[OpenAPI schema path]:file:_files' \
  '*:manifests or stdin:_files'
