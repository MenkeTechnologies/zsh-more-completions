#compdef proto-loader proto-loader-gen-types
# _proto-loader — gRPC Node.js proto-loader TypeScript types generator CLI alias (gRPC team / Google, JavaScript); yargs
# upstream: https://github.com/grpc/grpc-node/tree/master/packages/proto-loader

_proto-loader() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--keepCase=+[keep field case]:b:(true false)' \
        '-k+[keep field case]:b:(true false)' \
        '--longs=+[long handling]:t:(String Number)' \
        '-l+[long handling]:t:(String Number)' \
        '--enums=+[enum handling]:t:(String Number)' \
        '-e+[enum handling]:t:(String Number)' \
        '--bytes=+[bytes handling]:t:(Array String Buffer)' \
        '-b+[bytes handling]:t:(Array String Buffer)' \
        '--defaults=+[populate defaults]:b:(true false)' \
        '-d+[populate defaults]:b:(true false)' \
        '--arrays=+[populate empty arrays]:b:(true false)' \
        '-a+[populate empty arrays]:b:(true false)' \
        '--objects=+[populate empty objects]:b:(true false)' \
        '-o+[populate empty objects]:b:(true false)' \
        '--oneofs=+[oneof virtual fields]:b:(true false)' \
        '-O+[oneof virtual fields]:b:(true false)' \
        '--json=+[json conformance]:b:(true false)' \
        '-j+[json conformance]:b:(true false)' \
        '--inputTemplate=+[input template]:str:' \
        '-i+[input template]:str:' \
        '--outputTemplate=+[output template]:str:' \
        '-u+[output template]:str:' \
        '--outDir=+[output dir]:dir:_files -/' \
        '--includeDirs=+[include dir]:list:_files -/' \
        '-I+[include dir]:list:_files -/' \
        '--grpcLib=+[gRPC lib]:str:' \
        '--targetFileExtension=+[target file extension]:e:(ts js)' \
        '--noPrefix[no protobuf prefix]' \
        '--includeComments[include comments]' \
        '--inputBranded[include input branded types]' \
        '--outputBranded[include output branded types]' \
        '*:proto:_files -g "*.proto"'
}

_proto-loader "$@"
