#compdef distance gmx-distance
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-distance.html
# Calculate distances between pairs of positions as a function of time

local ret=1

_arguments -s -S \
  '-f+[input trajectory or configuration]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[input structure]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[extra index groups]:index file:_files -g "*.ndx"' \
  '-oav+[average distances vs time]:xvg file:_files -g "*.xvg"' \
  '-oall+[all distances vs time]:xvg file:_files -g "*.xvg"' \
  '-oxyz+[distance components vs time]:xvg file:_files -g "*.xvg"' \
  '-oh+[histogram of the distances]:xvg file:_files -g "*.xvg"' \
  '-oallstat+[statistics for individual distances]:xvg file:_files -g "*.xvg"' \
  '-b+[first frame ps]:time:' \
  '-e+[last frame ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-fgroup+[atoms stored in trajectory file]:selection:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-sf+[selections from file]:file:_files' \
  '-selrpos+[selection reference positions]:position:' \
  '-seltype+[default selection output positions]:position:' \
  '-select+[position pairs to calculate distances for]:selection:' \
  '-len+[mean distance for histogramming]:value:' \
  '-tol+[width of distribution as fraction of len]:value:' \
  '-binw+[bin width for histogramming]:value:' \
  '-rmpbc[make molecules whole for each frame]' \
  '-pbc[use periodic boundary conditions]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
