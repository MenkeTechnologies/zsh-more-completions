#compdef flatcc
# _flatcc — FlatBuffers compiler in C (dvidelabs/flatcc)
# upstream: https://github.com/dvidelabs/flatcc
# Flags from src/cli/flatcc_cli.c.

_flatcc() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '(- *)--help[show help]'
        '(- *)--version[show version]'
        '(-c --common)'{-c,--common}'[generate the common header (flatcc_builder etc.)]'
        '--common_reader[generate the common reader header only]'
        '--common_builder[generate the common builder header only]'
        '(-w --builder)'{-w,--builder}'[generate a builder file per schema]'
        '(-r --reader)'{-r,--reader}'[generate a reader file per schema (default)]'
        '(-v --verifier)'{-v,--verifier}'[generate a verifier file per schema]'
        '(-R --recursive)'{-R,--recursive}'[also process recursively included schemas]'
        '-g[only add _get suffix to reader accessors]'
        '-s[silence warnings about potential conflicts]'
        '(-a --all)'{-a,--all}'[generate everything (reader, builder, verifier, common)]'
        '(-o --outfile)'{-o+,--outfile=}'[write all output to FILE (in dependency order)]:file:_files'
        '-I+[add INCLUDE_DIR to the schema include search path]:dir:_files -/'
        '--prefix=[prefix added to global symbols]:prefix:'
        '(-d --depfile)'{-d+,--depfile=}'[emit a Make-style dependency file (implies -d if used as flag)]:file:_files'
        '--deptarget=[override the dependency target name (like gcc -MT)]:target:'
        '--schema[emit a binary .bfbs schema for each top-level file]'
        '--schema-length[prefix binary schema with a uoffset_t length]'
        '--schema-namespace=[override the namespace for binary schemas]:ns:'
        '--json-parser[emit a typed JSON parser per schema]'
        '--json-printer[emit a typed JSON printer per schema]'
        '--json[emit both JSON parser and printer]'
        '--stdout[write all output to stdout]'
        '-P+[output directory prefix (mirrors --outfile-prefix)]:prefix:_files -/'
        '*:FlatBuffers schema file:_files -g "*.fbs"'
    )
    _arguments -s -S $args
}

_flatcc "$@"
