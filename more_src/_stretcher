#compdef stretcher

# EMBOSS stretcher: produce a global Needleman-Wunsch style alignment of
# two sequences in linear memory (suitable for very long sequences
# where the standard "needle" would exhaust RAM).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[first sequence (any length)]:sequence USA:_files' \
  '-bsequence=[second sequence(s)]:sequence USA:_files' \
  '-datafile=[scoring matrix]:matrix:_files' \
  '-gapopen=[gap opening penalty]:penalty:' \
  '-gapextend=[gap extension penalty]:penalty:' \
  '-aformat=[alignment output format]:format:(simple srspair pair markx0 markx1 markx2 markx3 markx10 srs score multiple)' \
  '-outfile=[alignment output file]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
