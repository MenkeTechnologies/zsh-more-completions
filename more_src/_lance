#compdef lance
# Documentation: https://lance.org/
# Reference accessed: 2026-05-17
# Verified: lancedb/lance columnar data format. NOTE: upstream
# provides Python (`pylance`), TypeScript, and Rust SDKs; there
# is no first-party `lance` CLI binary as of 2026-05. This
# completion targets third-party `lance` CLI wrappers and Python
# entry-point shims that may be installed alongside.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new Lance dataset'
  'version:show Lance version / dataset version info'
  'info:show dataset info'
  'append:append rows to a dataset'
  'overwrite:overwrite a dataset'
  'delete:delete rows or a dataset'
  'compact:compact dataset files'
  'index:create or list indices'
  'optimize:optimize indices/storage'
  'restore:restore an earlier dataset version'
  'fragments:list/manage fragments'
  'list:list dataset versions'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--storage-options=[storage option key=value]:kv:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'lance command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create|append|overwrite)
        _arguments \
          '--mode=[write mode]:mode:(create append overwrite)' \
          '--input=[input source]:source:_files' \
          '--input-format=[input format]:format:(parquet csv json jsonl arrow)' \
          '*::dataset_uri:' && ret=0 ;;
      (info|list|version)
        _arguments '*::dataset_uri:' && ret=0 ;;
      (index)
        _arguments \
          '*::sub:(create list drop)' \
          '--type=[index type]:type:(vector scalar fts btree bitmap label_list)' \
          '--column=[column name]:col:' \
          '--metric=[distance metric (vector)]:metric:(l2 cosine dot)' \
          '--num-partitions=[IVF partitions]:n:' \
          '--num-sub-vectors=[PQ sub-vectors]:n:' && ret=0 ;;
      (compact|optimize)
        _arguments \
          '--target-rows-per-fragment=[target rows/fragment]:n:' \
          '--max-rows-per-group=[max rows/group]:n:' \
          '*::dataset_uri:' && ret=0 ;;
    esac ;;
esac

return ret
