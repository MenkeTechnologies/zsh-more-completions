#compdef numb
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss129.html
# KAPPA: count the number of elements of an NDF with values above or below a threshold

local ret=1

_arguments -s \
  'ABS=[compare absolute value with the threshold]:abs:(TRUE FALSE)' \
  'ABOVE=[test greater than vs less than]:above:(TRUE FALSE)' \
  'COMP=[NDF array component to analyse]:comp:(Data Error Variance Quality)' \
  'IN=[input NDF to be tested]:NDF:_files' \
  'VALUE=[threshold value]:value' \
  '*:NDF:_files' && ret=0

return ret
