#compdef subctl

# Zsh completion for subctl - Submariner CLI for multi-cluster networking

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig[path to kubeconfig]:file:_files' \
  '--kubecontext[kubeconfig context]:context:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'deploy-broker:deploy the Submariner broker'
      'join:join a cluster to the broker'
      'cloud:cloud infrastructure preparation'
      'diagnose:diagnose Submariner issues'
      'export:export a resource for cross-cluster access'
      'unexport:remove cross-cluster export'
      'gather:gather troubleshooting info'
      'benchmark:run benchmarks'
      'show:show Submariner resources'
      'uninstall:uninstall Submariner'
      'verify:verify connectivity'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (join)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--broker-rest[broker REST API URL]:url:' \
          '--clusterid[cluster ID]:id:' \
          '--cable-driver[cable driver]:driver:(libreswan wireguard vxlan)' \
          '--natt[enable NAT traversal]' \
          '--globalnet[enable globalnet]' \
          '*:broker-info.subm file:_files' \
          && ret=0
        ;;
      (show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:resource:(all connections endpoints gateways networks versions)' \
          && ret=0
        ;;
      (export|unexport)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:resource:(service)' \
          '2:name:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
