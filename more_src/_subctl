#compdef subctl
# Documentation: https://submariner.io/operations/deployment/subctl/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for subctl - Submariner CLI for multi-cluster networking

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig[path to kubeconfig]:file:_files' \
  '--context[kubeconfig context]:context:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'deploy-broker:deploy the Submariner broker'
      'join:join a cluster to the broker'
      'cloud:cloud infrastructure preparation'
      'diagnose:diagnose Submariner issues'
      'export:export a resource for cross-cluster access'
      'unexport:remove cross-cluster export'
      'gather:gather troubleshooting info'
      'benchmark:run benchmarks'
      'show:show Submariner resources'
      'uninstall:uninstall Submariner'
      'upgrade:upgrade subctl and Submariner components'
      'verify:verify connectivity'
      'recover-broker-info:restore lost broker-info.subm file'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (join)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--broker-url[broker API endpoint URL]:url:' \
          '--clusterid[cluster ID for tunnel identification]:id:' \
          '--cable-driver[cable driver]:driver:(libreswan wireguard vxlan)' \
          '--natt[enable NAT traversal for IPsec]' \
          '--globalnet[enable/disable Globalnet for this cluster]' \
          '*:broker-info.subm file:_files' \
          && ret=0
        ;;
      (show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:resource:(all brokers connections endpoints gateways networks versions)' \
          && ret=0
        ;;
      (export|unexport)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:resource:(service)' \
          '2:name:' \
          && ret=0
        ;;
      (benchmark)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(throughput latency)' \
          && ret=0
        ;;
      (cloud)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:action:(prepare cleanup)' \
          '2:provider:(aws gcp rhos generic)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
