#compdef redwood rw

# Zsh completion for RedwoodJS framework CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_redwood_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '--cwd=[working directory]:directory:_directories'
)

_arguments -s -S -C \
  "${_redwood_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'build:Build for production'
      'check:Structural diagnostics for a Redwood project'
      'console:Launch an interactive Redwood shell (alias: c)'
      'data-migrate:Data migration tools'
      'deploy:Deploy your Redwood project'
      'destroy:Rollback changes made by generate command (alias: d)'
      'dev:Start development servers'
      'exec:Run scripts generated with yarn generate script'
      'experimental:Enable and disable experimental features (alias: exp)'
      'generate:Generate boilerplate code and type definitions (alias: g)'
      'info:Print environment information'
      'lint:Lint source files'
      'prerender:Prerender pages of your Redwood app'
      'prisma:Run Prisma CLI'
      'record:Setup RedwoodRecord for your project'
      'serve:Run a production server'
      'setup:Initialize project config and install packages'
      'storybook:Launch Storybook'
      'test:Run tests'
      'ts-to-js:Convert TypeScript files to JavaScript'
      'type-check:Run TypeScript type checking (alias: tsc)'
      'upgrade:Upgrade all @redwoodjs packages'
    )
    _describe -t commands 'redwood commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--side[which side to build]:side:(api web)' \
          '--stats[use Webpack Bundle Analyzer]' \
          '--verbose[print more]' \
          '--prerender[prerender after building web]' && ret=0
        ;;
      dev)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--side[which side to develop]:side:(api web)' \
          '--forward=[forward CLI args to the api or web side]:args:' && ret=0
        ;;
      generate|g)
        _arguments -s -S -C \
          "${_redwood_global_flags[@]}" \
          '1:generator:(cell component function layout page scaffold sdl service)' \
          '2:name:' \
          '--force[overwrite existing files]' \
          '--typescript[generate TypeScript files]' \
          '--tests[generate test files]' \
          '--stories[generate Storybook stories]' && ret=0
        ;;
      destroy|d)
        _arguments -s -S -C \
          "${_redwood_global_flags[@]}" \
          '1:generator:(cell component function layout page scaffold sdl service)' \
          '2:name:' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '1:target:(aws baremetal flightcontrol netlify render vercel)' && ret=0
        ;;
      test)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--watch[watch files for changes]' \
          '1:side:(api web)' && ret=0
        ;;
      serve)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--port[port to listen on]:port:' \
          '--host[host to bind to]:host:' \
          '--side[which side to serve]:side:(api web)' && ret=0
        ;;
      prisma)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '1:prisma command:(db generate migrate studio)' && ret=0
        ;;
      setup)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '1:setup target:(auth cache custom-web-index deploy generator graphql middleware monitoring realtime tsconfig ui webpack)' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--tag[semver tag to upgrade to]:tag:' \
          '--dry-run[check for outdated packages without upgrading]' && ret=0
        ;;
      type-check|tsc)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--side[which side to type check]:side:(api web)' && ret=0
        ;;
      lint)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--fix[try to fix linting errors]' && ret=0
        ;;
      storybook)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '--open[open Storybook in browser]' \
          '--port[port to start Storybook on]:port:' \
          '--build[build Storybook]' && ret=0
        ;;
      data-migrate)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" \
          '1:action:(install up)' && ret=0
        ;;
      *)
        _arguments -s -S \
          "${_redwood_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
