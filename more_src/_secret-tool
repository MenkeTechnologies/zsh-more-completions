#compdef secret-tool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'store:store a password in the keyring'
  'lookup:retrieve a password from the keyring'
  'clear:remove a password from the keyring'
  'search:search the keyring'
  'lock:lock a collection'
)

_arguments -C \
  '(- *)'{-h,-?,--help}'[show help]' \
  '--help-all[show all help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'secret-tool subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (store)
        _arguments \
          '(-l --label)'{-l,--label=}'[label for stored item]:label:' \
          '(-c --collection)'{-c,--collection=}'[collection name]:collection:' \
          '*:attribute:' && ret=0
        ;;
      (search)
        _arguments \
          '(-a --all)'{-a,--all}'[return all results]' \
          '(-u --unlock)--unlock[unlock items if needed]' \
          '*:attribute:' && ret=0
        ;;
      (lock)
        _arguments \
          '(-c --collection)'{-c,--collection=}'[collection name]:collection:' && ret=0
        ;;
    esac
    ;;
esac

return ret
