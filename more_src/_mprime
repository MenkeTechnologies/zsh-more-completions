local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '-d[daemon mode]' \
  '-m[show menu]' \
  '-t[run torture test]' \
  '-s[show status]' \
  '-c+[contact]:email:' \
  '-w+[working dir]:dir:_files -/' \
  '-p+[program type]:type:' \
  '-A+[CPU affinity]:n:' && ret=0

return ret
