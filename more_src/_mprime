#compdef mprime prime95
# Documentation: https://github.com/rudimeier/mprime/blob/master/prime95/hlp/CommandLine.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Real flags: -c (contact
# PrimeNet then exit), -d (verbose stdout), -m (menus), -t (torture
# test), -v (version), -Wdirectory (working dir, no space), -An
# (instance ID for multi-copy operation).
# Removed from prior file: fabricated -h/-s/-c email/-p type/-A n
# with values, -w with separate dir arg.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c[contact PrimeNet server then exit]' \
  '-d[print detailed info to stdout]' \
  '-m[bring up the menus to set preferences]' \
  '-t[run the torture test]' \
  '-v[print version number]' \
  '-W-[set working directory (no space)]:dir:_files -/' \
  '-A-[instance ID for running multiple copies]:n:' && ret=0

return ret
