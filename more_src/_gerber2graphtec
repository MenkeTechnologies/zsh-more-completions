#compdef gerber2graphtec
# Documentation: https://github.com/pmonta/gerber2graphtec
# gerber2graphtec - cut SMT stencils from gerber files using a Graphtec cutter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--offset=[translate to device coordinates x,y (inches)]:x,y' \
  '--border=[leave a border around the gerber bounding box]:bx,by' \
  '--matrix=[transform coordinates by linear map a,b,c,d]:a,b,c,d' \
  '--speed=[cutting speed in device units per pass]:s[,s2[,s3]]' \
  '--force=[cutting force in device units per pass]:f[,f2[,f3]]' \
  '--cut_mode=[0 for highest accuracy, 1 for highest speed]:mode:(0 1)' \
  '*:gerber file:_files' && ret=0

return ret
