#compdef banana
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/banana.html
# Reference accessed: 2026-05-17
# Verified: EMBOSS 6.6 banana(1e) — bending/curvature plot for
# B-DNA. EMBOSS-standard flags (-help, -auto, -stdout, -filter,
# -options, -debug, -verbose, -warning, -error, -fatal, -die,
# -version, -outfile, -sequence, -graph, -residuesperline).
# Removed from prior file: bogus man.archlinux.org search URL.
# NOTE: there is a separate MonashBI/banana neuroimaging Python
# library — that one is library-only with no `banana` CLI surface,
# so this completion targets the EMBOSS banana binary.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output filename]:file:_files' \
  '-sequence=[DNA sequence(s)]:file:_files' \
  '-graph=[output graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-residuesperline=[residues per output line]:n:' \
  '*:DNA sequence:_files' && ret=0

return ret
