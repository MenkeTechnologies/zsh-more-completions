#compdef fontbakery
# Documentation: upstream Lib/fontbakery/cli.py at
# github.com/fonttools/fontbakery
# Reference accessed: 2026-05-30 via gh api inspection of every
# argument_parser.add_argument call plus the CLI_PROFILES list.
# fontbakery R114 — font QA tool (fontTools). Runs check suites
# against font binaries with multiple foundry-specific profiles
# (Adobe / Font Bureau / Fontwerk / Google Fonts / ISO 15008 /
# Microsoft / Noto / OpenType / Type Network / Universal).

local curcontext="$curcontext" state line ret=1

local -a _subcmds _profiles _gather_by _log_levels
_profiles=( adobefonts fontbureau fontval fontwerk googlefonts iso15008 microsoft notofonts opentype typenetwork universal )
_subcmds=(
  'check-profile:run a check profile by name (most flexible)'
  'check_adobefonts:Adobe Fonts profile'
  'check_fontbureau:Font Bureau profile'
  'check_fontval:FontValidator profile (Microsoft FontVal wrapper)'
  'check_fontwerk:Fontwerk profile'
  'check_googlefonts:Google Fonts profile (most-used)'
  'check_iso15008:ISO 15008 in-vehicle display profile'
  'check_microsoft:Microsoft profile'
  'check_notofonts:Google Noto Fonts profile'
  'check_opentype:OpenType profile (vendor-agnostic spec)'
  'check_typenetwork:Type Network profile'
  'check_universal:Universal profile (foundry-agnostic)'
)
_gather_by=( font family glyph iso15008_section )
_log_levels=( DEBUG INFO WARN PASS SKIP FAIL ERROR FATAL )

# Shared per-subcommand flags (every check_* + check-profile inherits
# the same flag set).
local -a _check_flags
_check_flags=(
  '--configuration=[load configuration TOML/JSON file]:file:_files'
  '*-c+[run only the named check IDs (repeatable)]:check id:'
  '*--checkid=[run only the named check IDs (repeatable)]:check id:'
  '*-x+[exclude check IDs (repeatable)]:check id:'
  '*--exclude-checkid=[exclude check IDs (repeatable)]:check id:'
  '(-v --verbose)'{-v,--verbose}'[verbose mode (shortcut for -l PASS)]'
  '(-l --loglevel)*'{-l,--loglevel}'=[report checks with this status or higher (repeatable)]:level:($_log_levels)'
  '(-m --loglevel-messages)'{-m,--loglevel-messages}'=[report log messages of this status or higher]:level:($_log_levels)'
  '--succinct[succinct output]'
  '(-F --full-lists)'{-F,--full-lists}'[show full lists in output]'
  '(-S --show-sections)'{-S,--show-sections}'[show profile section headers]'
  '(-g --gather-by)'{-g,--gather-by}'=[collect results by]:iter:($_gather_by)'
  '(-o --order)'{-o,--order}'=[order results]:iter:($_gather_by)'
  '(-q --quiet)'{-q,--quiet}'[quiet mode]'
  '(-n --no-progress)'{-n,--no-progress}'[disable progress bar]'
  '(-C --no-colors)'{-C,--no-colors}'[disable colored output]'
  '--dark-theme[use dark theme]'
  '--light-theme[use light theme]'
  '--timeout=[per-check timeout in seconds]:sec:'
  '--skip-network[skip network-dependent checks]'
  '--json=[write JSON report to file]:file:_files'
  '--badges=[write SVG badges to directory]:dir:_directories'
  '--ghmarkdown=[write GitHub-flavored markdown report to file]:file:_files'
  '--html=[write HTML report to file]:file:_files'
  '(-J --jobs)'{-J,--jobs}'=[parallel jobs (default 1, 0 = auto)]:N:'
  '(-j --auto-jobs)'{-j,--auto-jobs}'[shortcut for --jobs=0 (auto)]'
  '(-e --error-code-on)'{-e,--error-code-on}'=[exit code on status]:status:($_log_levels)'
  '(- *)--help[show help]'
  '(- *)--version[show version]'
)

_arguments -C \
  '(- *)--list-subcommands[list available subcommands]' \
  '(-L --list-checks)'{-L,--list-checks}'[list available checks]' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'fontbakery subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      check-profile)
        _arguments -s -S \
          $_check_flags \
          '1:profile module:($_profiles)' \
          '*:font file or directory:_files -g "*.(ttf|otf|woff|woff2)"' \
          && ret=0
        ;;
      check_*)
        _arguments -s -S \
          $_check_flags \
          '*:font file or directory:_files -g "*.(ttf|otf|woff|woff2)"' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
