#compdef FindMendelianViolations
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/vcf/MendelianViolations/FindMendelianViolations.java
# Picard: finds mendelian violations of all types within a VCF using trio information

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input VCF or BCF with genotypes]:file:_files' \
  '(-PED --TRIOS)'{-PED,--TRIOS}'=[trio information in PED format]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '(-GQ --MIN_GQ)'{-GQ,--MIN_GQ}'=[min genotyping quality to perform tests]:n:' \
  '(-DP --MIN_DP)'{-DP,--MIN_DP}'=[min depth in each sample]:n:' \
  '(-MINHET --MIN_HET_FRACTION)'{-MINHET,--MIN_HET_FRACTION}'=[min allele balance at offspring het sites]:n:' \
  '--VCF_DIR=[directory for per-family violation VCFs]:dir:_files -/' \
  '*--SKIP_CHROMS=[chromosome names to skip entirely]:s:' \
  '*--MALE_CHROMS=[possible names for male sex chromosomes]:s:' \
  '*--FEMALE_CHROMS=[possible names for female sex chromosomes]:s:' \
  '*'{-PAR,--PSEUDO_AUTOSOMAL_REGIONS}'=[pseudo-autosomal regions chr:start-end]:s:' \
  '--THREAD_COUNT=[number of threads to collect metrics]:n:' \
  '--TAB_MODE=[treat PED file as tab-delimited]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
