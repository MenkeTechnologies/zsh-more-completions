#compdef tox

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run tox environments (default)'
  'r:run tox environments'
  'run-parallel:run environments in parallel'
  'p:run environments in parallel'
  'depends:show dependency graph for an env'
  'de:show dependency graph for an env'
  'list:list defined environments'
  'l:list defined environments'
  'devenv:create a development environment'
  'd:create a development environment'
  'config:show resolved configuration'
  'c:show resolved configuration'
  'quickstart:create a basic tox.ini'
  'q:create a basic tox.ini'
  'exec:execute a command in an environment'
  'e:execute a command in an environment'
  'legacy:run in legacy mode'
  'le:run in legacy mode'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --conf)'{-c,--conf=}'[config file]:file:_files -g "*.(ini|toml|cfg)"' \
  '--root=[project root directory]:dir:_files -/' \
  '--workdir=[work directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-r --recreate)'{-r,--recreate}'[recreate environments]' \
  '*'{-x,--override=}'[override config name=value]:override:' \
  '--result-json=[write result JSON]:file:_files' \
  '--list-dependencies[list dependencies]' \
  '--no-list-dependencies[do not list dependencies]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tox subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run|r|run-parallel|p)
        _arguments \
          '(-e)*-e[run a specific environment]:env:' \
          '(-m)*-m[run environments matching label]:label:' \
          '(-f)*-f[run environments matching factor]:factor:' \
          '(-p --parallel)'{-p,--parallel=}'[parallel environments]:n:' \
          '(-s --skip-missing-interpreters)'{-s,--skip-missing-interpreters=}'[skip missing interpreters]:flag:(true false config)' \
          '(-n --notest)'{-n,--notest}'[skip tests, only setup]' \
          '(-b --pkg-only)'{-b,--pkg-only}'[only build package]' \
          '--skip-pkg-install[skip package install]' && ret=0
        ;;
      (devenv|d)
        _arguments \
          '-e[environment to use]:env:' \
          ':directory:_files -/' && ret=0
        ;;
      (depends|de|list|l|config|c)
        _arguments \
          '-e[environment]:env:' && ret=0
        ;;
    esac
    ;;
esac

return ret
