#compdef apt-extracttemplates
# Documentation: man apt-extracttemplates(1)
# Source: Debian apt apt-extracttemplates (man) — extract debconf templates from .deb (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --tempdir)'{-t+,--tempdir=}'[temporary directory for extracted files]:dir:_files -/' \
    '(-c --config-file)'{-c+,--config-file=}'[apt config file]:file:_files' \
    '(-o --option)*'{-o+,--option=}'[set option=value]:opt:_default' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '*:deb file:_files -g "*.deb"' \
    && ret=0

return ret
