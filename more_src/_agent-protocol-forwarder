#compdef agent-protocol-forwarder
# _agent-protocol-forwarder — Confidential Containers PodVM-side daemon that forwards the host's kata-agent ttRPC into the guest
# upstream: https://github.com/confidential-containers/cloud-api-adaptor
# Flags from src/cloud-api-adaptor/cmd/agent-protocol-forwarder/main.go on tip.

_agent-protocol-forwarder() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '-config=[path to a daemon config file]:file:_files' \
        '-listen=[address to listen on]:addr:' \
        '-kata-agent-socket=[path to the kata-agent socket]:socket:_files' \
        '-pod-namespace=[network namespace where the pod runs]:ns:' \
        '-host-interface=[network interface for tunnel traffic]:iface:' \
        '-ca-cert-file=[CA cert file]:file:_files' \
        '-cert-file=[TLS cert file]:file:_files' \
        '-cert-key=[TLS private key file]:file:_files' \
        '-tls-skip-verify[skip TLS certificate verification (testing only)]' \
        '-disable-tls[disable TLS (testing only)]'
}

_agent-protocol-forwarder "$@"
