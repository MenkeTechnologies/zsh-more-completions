#compdef deltalake
# _deltalake — Delta Lake Python convenience CLI (delta-io, Python); typer
# upstream: https://github.com/delta-io/delta-rs

_deltalake() {
    local -a sub=(
        'create:create new delta table'
        'append:append parquet to delta table'
        'overwrite:overwrite delta table'
        'merge:merge upsert into delta table'
        'history:show commit history'
        'schema:show table schema'
        'metadata:show table metadata'
        'files:list files'
        'vacuum:vacuum unused files'
        'optimize:optimize small files'
        'restore:restore to version/timestamp'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'deltalake subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:table-path:_files -/' \
                    '--schema=+[schema json]:file:_files' \
                    '--partition-by=+[partition columns]:cols:' ;;
                append|overwrite) _arguments \
                    '1:table-path:_files -/' \
                    '--source=+[source parquet]:file:_files -g "*.parquet"' ;;
                merge) _arguments \
                    '1:table-path:_files -/' \
                    '--source=+[source]:file:_files' \
                    '--predicate=+[merge predicate]:str:' ;;
                history|schema|metadata|files) _arguments \
                    '1:table-path:_files -/' \
                    '--limit=+[limit]:n:' ;;
                vacuum) _arguments \
                    '1:table-path:_files -/' \
                    '--retention-hours=+[retention hours]:n:' \
                    '--dry-run[dry run]' ;;
                optimize) _arguments \
                    '1:table-path:_files -/' \
                    '--target-size=+[target size]:n:' \
                    '--z-order=+[z order columns]:cols:' ;;
                restore) _arguments \
                    '1:table-path:_files -/' \
                    '--version=+[version]:n:' \
                    '--timestamp=+[timestamp]:str:' ;;
            esac
            ;;
    esac
}

_deltalake "$@"
