#compdef respgen
# generate input files for the RESP charge-fitting program

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-i[input file name (ac format)]:file:_files' \
  '-o[output file name]:file:_files' \
  '-f[output file format]:format:(resp0 resp1 resp2 resp3 resp4 resp5 iresp0 iresp1 iresp2)' \
  '-e[equalizing atomic charge]:level:(0 1 2)' \
  '-a[additional input data file]:file:_files' \
  '-n[number of conformations]:number:' \
  '-l[maximum path length]:length:' \
  '-w[weight of charge constraint]:weight:' && ret=0

return ret
