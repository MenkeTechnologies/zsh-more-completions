#compdef amoverview
# _amoverview — Zmanda Amanda amoverview CLI for displaying a matrix summary of dumps per host and date level from the curinfo database showing missing or extra dumps for verification and reporting (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amoverview() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-num[show level only]' \
        '--num0[show 0 level only]' \
        '-skipmissed[skip missed dumps]' \
        '-last[only show last date column]' \
        '-verbose[verbose output]' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-host=+[hostname pattern]:str:' \
        '--host=+[hostname pattern]:str:' \
        '-disk=+[diskname pattern]:str:' \
        '--disk=+[diskname pattern]:str:' \
        '-o+[option]:str:' \
        '*:config:'
}

_amoverview "$@"
