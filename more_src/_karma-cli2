#compdef karma-cli2 karma2
# _karma-cli2 — Google AngularJS Karma karma-cli2 CLI command-line frontend wrapping the Karma open-source spectacular test runner for JavaScript originally part of Angular Google now JavaScript test runner that runs real browsers and devices written in JavaScript Node spectacular Test Runner for JavaScript The main goal for Karma is to bring a productive testing environment to developers start run init stop completion config single-run browsers reporter port log-level no-colors auto-watch capture-timeout browser-no-activity-timeout client-args no-single-run urlRoot files preprocessors plugins frameworks proxies hostname (Karma team Vojta Jina, JavaScript); commander
# upstream: https://karma-runner.github.io/

_karma-cli2() {
    local -a sub=(
        'start:start the server'
        'init:create a karma.conf.js'
        'run:trigger a test run'
        'stop:stop the server'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--auto-watch[auto watch]' \
        '--no-auto-watch[no auto watch]' \
        '--detached[run in background]' \
        '--no-colors[no colors]' \
        '--colors[colors]' \
        '--single-run[single run]' \
        '--no-single-run[no single run]' \
        '--browsers=+[name]:str:' \
        '*--browsers=+[name]:str:' \
        '--reporters=+[name]:str:' \
        '*--reporters=+[name]:n:(progress dots junit html teamcity coverage spec growl notify nyan mocha tap)' \
        '--capture-timeout=+[ms]:n:' \
        '--browser-no-activity-timeout=+[ms]:n:' \
        '--browser-disconnect-timeout=+[ms]:n:' \
        '--browser-disconnect-tolerance=+[N]:n:' \
        '--log-level=+[l]:l:(disable error warn info debug)' \
        '-l+[log level]:l:(disable error warn info debug)' \
        '--client-args=+[args]:str:' \
        '--protocol=+[p]:p:(http https)' \
        '--hostname=+[host]:_hosts' \
        '--url-root=+[path]:str:' \
        '--upstream-proxy=+[url]:str:' \
        '--frameworks=+[name]:str:' \
        '*--frameworks=+[name]:n:(jasmine mocha qunit chai sinon)' \
        '--files=+[pattern]:str:' \
        '*--files=+[pattern]:str:' \
        '--preprocessors=+[k=v]:str:' \
        '*--preprocessors=+[k=v]:str:' \
        '--plugins=+[name]:str:' \
        '*--plugins=+[name]:str:' \
        '--proxies=+[k=v]:str:' \
        '*--proxies=+[k=v]:str:' \
        '--listen-address=+[host]:_hosts' \
        '--proxy-validate-ssl[validate proxy SSL]' \
        '--exclude=+[pattern]:str:' \
        '*--exclude=+[pattern]:str:' \
        '--basePath=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "karma.conf.* *.js *.ts"' \
        '-c+[config]:file:_files -g "karma.conf.* *.js *.ts"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'karma subcommand' sub ;;
        args)
            case $words[1] in
                start|run) _arguments '*:config:_files -g "karma.conf.* *.js *.ts"' ;;
                init) _arguments '*:file:_files -g "*.conf.js"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_karma-cli2 "$@"
