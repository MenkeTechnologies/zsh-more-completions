#compdef svnsync

local -a subcommands
subcommands=(
    'init:Initialize a destination repository for sync'
    'initialize:Initialize a destination repository for sync'
    'sync:Transfer revisions to destination'
    'synchronize:Transfer revisions to destination'
    'copy-revprops:Copy revision properties'
    'info:Print sync information'
    'help:Show help'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'svnsync subcommand' subcommands
        ;;
    args)
        _arguments \
            '--source-username[Source username]:username' \
            '--source-password[Source password]:password' \
            '--sync-username[Sync username]:username' \
            '--sync-password[Sync password]:password' \
            '--source-prop-encoding[Source property encoding]:encoding' \
            '--disable-locking[Disable exclusive access locking]' \
            '--steal-lock[Steal exclusive access lock]' \
            '--config-dir[Config directory]:dir:_directories' \
            '--config-option[Config option]:option' \
            '--no-auth-cache[Do not cache authentication]' \
            '--non-interactive[Non-interactive mode]' \
            '--trust-server-cert[Trust server certificate]' \
            '--trust-server-cert-failures[Trust specific failures]:failures' \
            '-q[Quiet mode]' \
            '--quiet[Quiet mode]' \
            '*:URL'
        ;;
esac
