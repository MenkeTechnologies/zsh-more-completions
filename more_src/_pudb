#compdef pudb pudb3

# Zsh completion for pudb - Python TUI debugger

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--pre-run=[command to run before debugging]:command' \
  '--steal-output[steal stdout and stderr from script]' \
  '--log-errors=[log internal errors to file]:file:_files' \
  '--run[run script without stopping at first line]' \
  '1:script:_files -g "*.py"'
