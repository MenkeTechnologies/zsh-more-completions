#compdef pudb pudb3
# Documentation: https://github.com/inducer/pudb/blob/main/pudb/run.py
# Reference accessed: 2026-05-20
# Verified: upstream argparse definitions in run.py.

# pudb: Python TUI debugger
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --continue)'{-c,--continue}'[run until exception or breakpoint]' \
  '(-s --steal-output)'{-s,--steal-output}'[steal stdout and stderr from script]' \
  '(-m --module)'{-m,--module}'[debug as module or package instead of script]' \
  '(-le --log-errors)'{-le+,--log-errors=}'[log internal errors to file]:file:_files' \
  '--pre-run=[command to run before each program run]:command:' \
  '*:script:_files -g "*.py"'
