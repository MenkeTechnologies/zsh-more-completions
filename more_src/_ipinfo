#compdef ipinfo

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'myip:lookup details of your own IP'
  'bulk:bulk process multiple IPs'
  'summarize:summarize details of up to 1000 IPs'
  'map:generate shareable geolocation map URL'
  'prips:expand CIDR or IP ranges'
  'grepip:filter IPs from input'
  'grepdomain:filter domain data'
  'matchip:match IP patterns'
  'cidr2range:convert CIDR to range'
  'cidr2ip:convert CIDR to individual IPs'
  'range2cidr:convert range to CIDR'
  'range2ip:convert range to individual IPs'
  'splitcidr:divide CIDR blocks'
  'randip:generate random IPs'
  'mmdb:manage MMDB database files'
  'asn:ASN lookup'
  'cache:caching control'
  'tools:utility tools group'
  'tokens:manage API tokens'
  'login:authenticate with token'
  'init:authenticate with token'
  'logout:remove stored credentials'
  'completion:setup shell completion'
  'version:show CLI version'
)

_arguments -C \
  '--nocolor[disable color output]' \
  '(- *)'{-h,--help}'[show help]' \
  '--token=[API token]:token:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ipinfo subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
      (mmdb)
        _values 'mmdb action' 'read' 'metadata' 'export' 'import' 'verify' && ret=0
        ;;
      (tokens)
        _values 'tokens action' 'list' 'create' 'remove' 'edit' 'view' && ret=0
        ;;
    esac
    ;;
esac

return ret
