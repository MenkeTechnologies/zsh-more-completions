#compdef iwconfig
# _iwconfig — Linux wireless-tools iwconfig (legacy Wireless Extension (WE) frontend; sets essid/mode/channel/freq/ap/rate/txpower/sens/retry/rts/frag/key/power/nick on the named wireless interface)
# upstream: https://hewlettpackard.github.io/wireless-tools/ (jt@hpl.hp.com)
# Subcommands from wireless-tools iwconfig.c on tip.

_iwconfig() {
    _arguments \
        '1:interface:_net_interfaces' \
        '*::config:(essid mode freq channel sens nick rate bit txpower retry rts frag key enc power modulation commit ap)'
}

_iwconfig "$@"
