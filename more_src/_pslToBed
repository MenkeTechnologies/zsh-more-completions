#compdef pslToBed
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: transform a psl format file to a bed format file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-cds=[input cds tab-separated file]:file:_files' \
  '-posName[change qName field to qName:qStart-qEnd]' \
  ':psl:_files' \
  ':bed:_files' && ret=0

return ret
