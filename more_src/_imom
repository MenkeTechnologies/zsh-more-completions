#compdef imom
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imom.html
# MIRIAD imom - calculate intensity-weighted moments of an image

local ret=1

_arguments -s -S \
  'in=[input image name (no default)]:in:_files' \
  'options=[skew,clipmean,clip1sigma]:options' \
  'region=[region of interest for moment calculation]:region' \
  'min=[lower threshold for pixel values]:min' \
  'max=[upper threshold for pixel values]:max' \
  'log=[output destination for results]:log:_files' \
  '*:image:_files' && ret=0

return ret
