#compdef alr
# Documentation: https://alire.ada.dev/docs/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Alire (Ada) — https://github.com/alire-project/alire — CLI binary is `alr`; topic commands from `alr --help`.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'version:show tool version'
  'help:show help for topics'
  'settings:configure alr'
  'toolchain:manage compiler toolchains'
  'dev:add development dependencies'
  'init:create new crate'
  'with:add dependency to current crate'
  'update:update dependencies'
  'get:fetch sources'
  'build:compile workspace'
  'run:build and run main'
  'test:run tests'
  'publish:prepare release'
  'exec:spawn in environment'
  'search:search index'
  'pin:pin dependency revisions'
  'index:index management'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--verbose}'[verbose]' \
  '(- *)'{-q,--quiet}'[quiet]' \
  '(-d --debug)'{-d,--debug}'[debug traces]' \
  '(-f --force)'{-f,--force}'[force]' \
  '(-n --no-color)'{-n,--no-color}'[no ANSI color]' \
  '--timezone=[TZ for logs]:timezone' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'alr command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
