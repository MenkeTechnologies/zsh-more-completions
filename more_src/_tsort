#compdef tsort
# Documentation: tsort usage (BSD)
# Source: BSD tsort — topological sort.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug; print on cycles]' \
    '-l[print longest cycle on cycles]' \
    '-q[do not print cycles to stderr]' \
    '1:file:_files' \
    && ret=0

return ret
