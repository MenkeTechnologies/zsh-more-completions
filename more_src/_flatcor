#compdef flatcor
# Documentation: http://www.starlink.ac.uk/docs/sun139.htx/sun139.html
# CCDPACK: Flatfield correct a list of images

local ret=1

_arguments -s -S \
  'IN=[input images to be flatfielded]:in:_files' \
  'OUT=[output corrected images]:out:_files' \
  'FLAT=[flatfield calibration image]:flat:_files' \
  'KEEPIN=[retain input NDFs]:keepin:(TRUE FALSE)' \
  'LOGFILE=[log file name]:logfile:_files' \
  'LOGTO=[where to write log information]:logto:(TERMINAL LOGFILE BOTH NEITHER)' \
  'PRESERVE=[preserve input data type]:preserve:(TRUE FALSE)' \
  'SATURATION=[saturation value]:saturation:' \
  'SETSAT=[flag saturated pixels]:setsat:(TRUE FALSE)' \
  'TITLE=[output NDF title]:title:' \
  'USESET=[use Set header grouping]:useset:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
