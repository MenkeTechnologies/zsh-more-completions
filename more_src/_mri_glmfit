#compdef mri_glmfit
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_glmfit
# FreeSurfer general linear model fit

local ret=1

_arguments -s -S \
  '--glmdir[save outputs to dir]:dir:_files -/' \
  '--y[input file with frames for each input]:inputfile:_files' \
  '--fsgd[freesurfer descriptor file]:FSGDF:_files' \
  '--X[design matrix file]:matrix:_files' \
  '*--C[specify one or more contrasts to test]:contrast.mat:_files' \
  '--osgm[construct X and C as a one-sample group mean]' \
  '--no-contrasts-ok[do not fail if no contrasts specified]' \
  '*--pvr[per-voxel regressor]:pvr:_files' \
  '--selfreg[self-regressor from col row slice]:selfreg:' \
  '--wls[weighted least squares]:yffxvar:_files' \
  '--yffxvar[fixed effects variance]:yffxvar:_files' \
  '--ffxdof[fixed effects degrees of freedom]:DOF:' \
  '--w[weight file]:weightfile:_files' \
  '--w-inv[invert weights]' \
  '--w-sqrt[apply square root to weights]' \
  '--fwhm[smoothing kernel]:fwhm:' \
  '--var-fwhm[variance smoothing]:fwhm:' \
  '--mask[binary mask file]:maskfile:_files' \
  '--label[label as mask for surfaces]:labelfile:_files' \
  '--sim[simulation for multiple comparison correction]:sim:' \
  '--sim-sign[test direction (abs pos neg)]:signstring:(abs pos neg)' \
  '--seed[random number generator seed]:seed:' \
  '--surf[surface geometry subject hemi]:surf:' \
  '--pca[PCA/SVD analysis on residuals]' \
  '--save-yhat[save signal estimate]' \
  '--save-cond[save design matrix condition values]' \
  '--help[display usage]' \
  '--version[display version]' && ret=0

return ret
