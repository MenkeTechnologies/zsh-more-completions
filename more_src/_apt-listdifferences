#compdef apt-listdifferences
# Documentation: https://manpages.debian.org/testing/apt-listdifferences/apt-listdifferences.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--apt[read packages from stdin]' \
  '--initialize[download source database]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:deb file:_files -g "*.deb"'
