#compdef apt-listdifferences
# Documentation: https://man.archlinux.org/search?q=apt-listdifferences
# Reference accessed: 2026-05-16

_arguments -s \
  '--apt[read packages from stdin]' \
  '--initialize[download source database]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:deb file:_files -g "*.deb"'
