#compdef incusd lxd-agent lxd-benchmark lxd-doc lxd-migrate lxd-user firectl
# Documentation: https://github.com/lxc/incus
# Reference accessed: 2026-05-19
# Verified: upstream cmd/incusd/main.go for incusd subcommands;
#           https://github.com/firecracker-microvm/firectl for firectl flags.

local curcontext="$curcontext" state line ret=1

case $service in
  (incusd)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '--debug[debug]' \
      '--verbose[verbose]' \
      '--logfile=[log file]:file:_files' \
      '--syslog[log to syslog]' \
      '--group=[unix group]:g:' \
      '1:command:(activateifneeded admin callhook cluster forkbpf forkconsole forkcoresched forkexec forkfile forklimits forkmigrate forkmount forknet forkproxy forkstart forksyscall forkuevent forkzfs manpage migratedumpsuccess netcat shutdown version waitready)' \
      '*: :' && ret=0 ;;
  (lxd-agent)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--debug[debug]' \
      '--logfile=[log file]:file:_files' \
      '*: :' && ret=0 ;;
  (lxd-benchmark)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '1:command:(launch start stop delete init)' \
      '--count=[count]:n:' \
      '--parallel=[parallel]:n:' \
      '--image=[image]:i:' \
      '--privileged[privileged]' \
      '--report-file=[report file]:file:_files' \
      '*: :' && ret=0 ;;
  (lxd-doc)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :_files' && ret=0 ;;
  (lxd-migrate)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :' && ret=0 ;;
  (lxd-user)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :' && ret=0 ;;
  (firectl)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--firecracker-binary=[firecracker binary]:file:_files' \
      '--kernel=[kernel image]:file:_files' \
      '--kernel-opts=[kernel opts]:opts:' \
      '--root-drive=[root drive]:file:_files' \
      '--root-partition=[root partition]:p:' \
      '*--add-drive=[additional drive]:d:' \
      '*--tap-device=[tap device]:t:' \
      '--vsock-device=[vsock device]:d:' \
      '(-c --ncpus)'{-c+,--ncpus=}'[vcpus]:n:' \
      '(-m --memory)'{-m+,--memory=}'[memory MB]:m:' \
      '--metadata=[metadata file]:file:_files' \
      '(-s --socket-path)'{-s+,--socket-path=}'[socket path]:file:_files' \
      '(-d --debug)'{-d,--debug}'[debug]' \
      '(-t --disable-smt)'{-t,--disable-smt}'[disable SMT]' \
      '--cpu-template=[CPU template]:template:' \
      '--vmm-log-fifo=[VMM log fifo]:file:_files' \
      '--metrics-fifo=[metrics fifo]:file:_files' \
      '--log-level=[log level]:level:' \
      '*: :' && ret=0 ;;
esac

return ret
