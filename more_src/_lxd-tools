#compdef incusd lxd-agent lxd-benchmark lxd-doc lxd-migrate lxd-user firectl
# Documentation: https://man.archlinux.org/search?q=incusd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (incusd)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(--version)--version[show version]' \
      '*--debug[debug]' \
      '*--verbose[verbose]' \
      '*--logfile=[log file]:file:_files' \
      '*--syslog[log to syslog]' \
      '*--group=[unix group]:g:' \
      '1:command:(activateifneeded callhook cluster forkconsole forkdns forkexec forkfile forkmigrate forkmount forkproxy forknet forkstart forkstop forkzfs init recover redrelease shutdown sql waitready)' \
      '*: :' && ret=0 ;;
  (lxd-agent)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*--debug[debug]' \
      '*--logfile=[log file]:file:_files' \
      '*: :' && ret=0 ;;
  (lxd-benchmark)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '1:command:(launch start stop delete init)' \
      '*--count=[count]:n:' \
      '*--parallel=[parallel]:n:' \
      '*--image=[image]:i:' \
      '*--privileged[privileged]' \
      '*--report-file=[report file]:file:_files' \
      '*: :' && ret=0 ;;
  (lxd-doc)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :_files' && ret=0 ;;
  (lxd-migrate)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :' && ret=0 ;;
  (lxd-user)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :' && ret=0 ;;
  (firectl)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--firecracker-binary=[firecracker binary]:file:_files' \
      '--kernel=[kernel image]:file:_files' \
      '--kernel-opts=[kernel opts]:opts:' \
      '--root-drive=[root drive]:file:_files' \
      '--root-partition=[root partition]:p:' \
      '--add-drive=[additional drive]:d:' \
      '--vsock-device=[vsock device]:d:' \
      '--ncpus=[vcpus]:n:' \
      '--memory=[memory MB]:m:' \
      '--metadata=[metadata file]:file:_files' \
      '--socket-path=[socket]:file:_files' \
      '--id=[VM id]:id:' \
      '--debug[debug]' \
      '*--tap-device=[tap device]:t:' \
      '*--fifo=[fifo]:file:_files' \
      '*: :' && ret=0 ;;
esac

return ret
