#compdef cutechess
# Documentation: https://github.com/cutechess/cutechess
# Reference accessed: 2026-05-16
# Verified: upstream cutechess/cutechess. Qt GUI binary; standard Qt
# options plus optional PGN file positional. No app-specific CLI.
# Removed from prior file: bogus man.archlinux.org search URL.

# cutechess: Qt chess GUI (sibling: cutechess-cli)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--style=[Qt widget style]:style:' \
  '--display=[X display]:display:' \
  '-geometry[window geometry]:geom:' \
  '*:PGN file:_files -g "*.pgn(-.)"' && ret=0
return ret
