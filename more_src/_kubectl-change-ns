#compdef kubectl-change-ns
# kubectl-change-ns (krew plugin): change/move a resource to a different namespace
# https://github.com/juanvallejo/kubectl-ns

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[source namespace]:namespace:_guard "^-*" namespace' \
  '--to=[target namespace]:namespace:_guard "^-*" namespace' \
  '1:resource type' \
  '2:resource name'
