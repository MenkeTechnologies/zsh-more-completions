#compdef ocb otelcol-builder
# Documentation: https://github.com/open-telemetry/opentelemetry-collector (cmd/builder/internal/command.go)
# Reference accessed: 2026-05-29
# OpenTelemetry Collector Builder — assembles custom distributions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[build configuration file]:file:_files -g "*.(yaml|yml)"' \
  '--skip-generate[skip generating Go code]' \
  '--skip-compilation[generate code only without compiling]' \
  '--skip-get-modules[skip updating go.mod and fetching modules]' \
  '--skip-strict-versioning[skip strict version checking (default true)]' \
  '--ldflags=[linker flags passed to go build]:flags:' \
  '--gcflags=[compiler flags passed to go build]:flags:' \
  '--output-path=[destination directory (deprecated; use config)]:dir:_directories' \
  '--verbose[verbose builder output]' && ret=0

return ret
