#compdef mri_vol2vol
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_vol2vol
# mri_vol2vol - resample a volume into another field-of-view using a registration

local ret=1

_arguments -s -S \
  '--mov[input (moveable) volume]:file:_files' \
  '--targ[output template volume]:file:_files' \
  '--o[output volume]:file:_files' \
  '--disp[displacement volume]:file:_files' \
  '--reg[tkRAS-to-tkRAS matrix (tkregister2 format)]:file:_files' \
  '--lta[Linear Transform Array registration]:file:_files' \
  '--fsl[fslRAS-to-fslRAS matrix (FSL format)]:file:_files' \
  '--xfm[scannerRAS-to-scannerRAS matrix (MNI format)]:file:_files' \
  '--regheader[use header geometry as registration]' \
  '--mni152reg[target MNI152 space (requires FSL)]' \
  '--s[subject for templates with identity matrix]:subject:' \
  '--inv[sample from target to source]' \
  '--tal[map to MNI305 sub-FOV (with --reg)]' \
  '--talres[talairach resolution (1 or 2 mm)]:res:(1 2)' \
  '--talxfm[talairach transform file]:file:_files' \
  '--m3z[non-linear morph in m3z format]:file:_files' \
  '--noDefM3zPath[do not search default morph location]' \
  '--inv-morph[compute inverse of m3z morph]' \
  '--fstarg[use subject volume as target]' \
  '--crop[crop and change voxel size]' \
  '--slice-crop[crop output slices within range]' \
  '--slice-reverse[reverse slice order]' \
  '--trilin[trilinear interpolation (default)]' \
  '--nearest[nearest neighbor interpolation]' \
  '--cubic[cubic B-spline interpolation]' \
  '--interp[interpolation type (nearest/trilin/cubic)]:interp:(nearest trilin cubic)' \
  '--mul[multiply output by value]:val:' \
  '--precision[output precision]:prec:(uchar short int long float)' \
  '--keep-precision[match output precision to input]' \
  '--no-resample[change vox2ras matrix only, do not resample]' \
  '--rot[apply rotation angles (degrees)]:angles:' \
  '--trans[apply translation (mm)]:trans:' \
  '--shear[apply shear transform]:shear:' \
  '--save-reg[write output registration matrix]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
