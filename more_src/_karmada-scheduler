#compdef karmada-scheduler
# Documentation: https://karmada.io/docs/reference/components/karmada-scheduler/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# --karmada-kubeconfig/--bind-address/--secure-port/--cert-dir/--tls-*/
# --leader-elect-resource-name; added real --master and estimator flags.

# karmada-scheduler: Karmada scheduler
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[path to karmada control plane kubeconfig file]:file:_files' \
  '--master=[address of the Kubernetes API server]:url:' \
  '--leader-elect[enable leader election]' \
  '--leader-elect-lease-duration=[lease duration]:duration:' \
  '--leader-elect-renew-deadline=[renew deadline]:duration:' \
  '--leader-elect-retry-period=[retry period]:duration:' \
  '--scheduler-name=[name of the scheduler]:name:' \
  '--scheduler-estimator-port=[secure port to connect the accurate scheduler estimator]:port:' \
  '--enable-scheduler-estimator[enable calling cluster scheduler estimator]' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '--logtostderr[log to stderr]' \
  '*::karmada-scheduler args:_files' && ret=0
return ret
