#compdef rmaxima
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/maxima.1.html
# Maxima computer algebra system with readline support

local ret=1

_arguments -s -S \
  '(-b --batch)'{-b,--batch=}'[process file in noninteractive mode]:file:_files' \
  '--batch-lisp=[process Lisp file in noninteractive mode]:file:_files' \
  '--batch-string=[process string in noninteractive mode]:string' \
  '(-d --directories)'{-d,--directories}'[display Maxima directory information]' \
  '--disable-readline[disable readline support]' \
  '(-g --enable-lisp-debugger)'{-g,--enable-lisp-debugger}'[enable Lisp debugger]' \
  '(-h --help)'{-h,--help}'[display a brief usage summary]' \
  '--init=[load init files string.mac and string.lisp at startup]:string' \
  '--init-mac=[load the Maxima initialization file at startup]:file:_files' \
  '--init-lisp=[load the Lisp initialization file at startup]:file:_files' \
  '(-l --lisp)'{-l,--lisp=}'[use Lisp implementation]:lisp' \
  '--list-avail[list the available Lisp and Maxima versions]' \
  '(-p --preload-lisp)'{-p,--preload-lisp=}'[preload Lisp file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress Maxima start-up message]' \
  '(-r --run-string)'{-r,--run-string=}'[process string in interactive mode]:string' \
  '(-s --server)'{-s,--server=}'[connect Maxima to server on port]:port' \
  '(-u --use-version)'{-u,--use-version=}'[launch a specific Maxima version]:version' \
  '--userdir=[configure user directory location]:dir:_directories' \
  '(-v --verbose)'{-v,--verbose}'[print extra information from the wrapper script]' \
  '--version[print the default installed version]' \
  '--very-quiet[suppress expression labels and start-up message]' \
  '(-X --lisp-options)'{-X,--lisp-options=}'[options to be given to the underlying Lisp]:options' && ret=0

return ret
