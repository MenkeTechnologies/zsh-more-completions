#compdef plymouth-create-initrd
# Documentation: (no upstream manpage)
# Reference accessed: 2026-05-16
# Verified: searched Debian/Fedora and freedesktop plymouth source -
# no dedicated manpage. On Fedora/Debian this is typically a thin
# wrapper that delegates to `dracut` / `update-initramfs` to rebuild
# the initrd with plymouth support. Distros prefer
# `plymouth-set-default-theme` + native initrd rebuild instead.
# Conservative stub retained per "do not delete files" directive.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# plymouth-create-initrd: distro wrapper to rebuild initrd with plymouth
local curcontext="$curcontext" ret=1
_arguments -C \
  '-t[theme name]:theme:' \
  '*:arg:_files' && ret=0
return ret
