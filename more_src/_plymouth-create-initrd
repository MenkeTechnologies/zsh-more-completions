#compdef plymouth-create-initrd
# Documentation: https://www.freedesktop.org/wiki/Software/Plymouth/
# Reference accessed: 2026-05-20
# Verified: searched Debian/Fedora and freedesktop Plymouth source -
# no dedicated upstream manpage for `plymouth-create-initrd`. On
# Fedora/Debian this is typically a thin wrapper that delegates to
# `dracut` / `update-initramfs` to rebuild the initrd with plymouth
# support. STUB
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# plymouth-create-initrd: distro wrapper to rebuild initrd with plymouth
local curcontext="$curcontext" ret=1
_arguments -C \
  '-t[theme name]:theme:' \
  '*:arg:_files' && ret=0
return ret
