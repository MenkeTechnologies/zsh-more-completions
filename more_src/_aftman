#compdef aftman
# Documentation: https://man.archlinux.org/search?q=aftman
# Reference accessed: 2026-05-16

# Zsh completion for aftman
# Upstream: Toolchain manager for Roblox, the prodigal sequel to Foreman
# Conservative fallback — run `aftman --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
