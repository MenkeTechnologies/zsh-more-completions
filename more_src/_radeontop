#compdef radeontop
# Documentation: https://github.com/clbr/radeontop
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --bus)'{-b,--bus}'[PCI bus number]:bus' \
  '(-c --color)'{-c,--color}'[enable color output]' \
  '(-d --dump)'{-d,--dump}'[dump output to file]:file:_files' \
  '(-i --dump-interval)'{-i,--dump-interval}'[seconds between data outputs]:seconds' \
  '(-l --limit)'{-l,--limit}'[limit dump to N lines]:lines' \
  '(-m --mem)'{-m,--mem}'[force /dev/mem path for device access]' \
  '(-p --path)'{-p,--path}'[DRM device node path]:path:_files' \
  '(-t --ticks)'{-t,--ticks}'[samples per second]:ticks' && ret=0

return ret
