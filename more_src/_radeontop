#compdef radeontop

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b[PCI bus number]:bus' \
  '--bus[PCI bus number]:bus' \
  '-c[enable color output]' \
  '--color[enable color output]' \
  '-d[dump file path]:file:_files' \
  '--dump[dump file path]:file:_files' \
  '-i[refresh interval in seconds]:seconds' \
  '--interval[refresh interval in seconds]:seconds' \
  '-l[limit to N lines for dump]:lines' \
  '--limit[limit to N lines for dump]:lines' \
  '-t[ticks per update]:ticks' \
  '--ticks[ticks per update]:ticks' && ret=0

return ret