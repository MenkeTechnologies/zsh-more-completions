#compdef makecomfile
# Documentation: https://bio3d.colorado.edu/imod/doc/man/makecomfile.html
# makecomfile - make a command file for a tomographic processing step

local ret=1

_arguments -s -S \
  '(-i --input)'{-i,-input}'[input command file to copy commands from]:file:_files' \
  '(-ou --output)'{-ou,-output}'[output file for commands (required)]:file:_files' \
  '(-ro --root)'{-ro,-root}'[root name of data files including axis letter]:name' \
  '(-sty --style)'{-sty,-style}'[naming style of image files]:value' \
  '(-sta --stackext)'{-sta,-stackext}'[extension of raw stack excluding the period]:ext' \
  '(-si --single)'{-si,-single}'[indicate the dataset is single-axis]' \
  '(-bi --binning)'{-bi,-binning}'[binning value to place in the command file]:binning' \
  '(-be --bead)'{-be,-bead}'[bead size in pixels]:size' \
  '-use[change input file to setname_3dfind.ali if needed]' \
  '(-sh --shift)'{-sh,-shift}'[amount to shift reconstruction in Y]:shift' \
  '(-ha --halffloat)'{-ha,-halffloat}'[value of -halffloat option to add]:value' \
  '(-t --thickness)'{-t,-thickness}'[thickness of reconstruction in unbinned pixels]:thickness' \
  '(-f --find)'{-f,-find}'[value to set for -find in cryoposition]:value' \
  '(-g --gpu)'{-g,-gpu}'[value to set for -gpu in cryoposition]:value' \
  '(-p --procs)'{-p,-procs}'[expected number of CPUs or GPUs]:count' \
  '(-l --local)'{-l,-local}'[value for testing local areas]:value' \
  '(-ra --ratios)'{-ra,-ratios}'[values for the -target and -minimum options]:target,min' \
  '(-sk --skipbeam)'{-sk,-skipbeam}'[value for the -skipbeam option]' \
  '(-re --replace)'{-re,-replace}'[value for the -replace option]:angle' \
  '(-c --change)'{-c,-change}'[file with directives for changing parameters]:file:_files' \
  '(-on --one)'{-on,-one}'[one directive for changing parameters]:directive' \
  '(-he --help)'{-he,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
