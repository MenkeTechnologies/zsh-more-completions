#compdef amtape
# _amtape — Zmanda Amanda amtape CLI for managing Amanda backup tape carousel changer operations show current slot reset eject mark unlabeled tapes load by label inventory taper-status reuse retry (zmanda team, C); getopt
# upstream: https://github.com/zmanda/amanda

_amtape() {
    local -a sub=(
        'reset:reset changer to known state'
        'eject:eject current tape'
        'clean:clean drive'
        'show:show contents of all slots'
        'inventory:inventory slot/labels'
        'label:load tape with label'
        'load:load tape by slot or label'
        'taper:taper-style operations'
        'slot:slot operations'
        'current:show current tape'
        'update:update tape information'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--no-confirm[no confirm]' \
        '--no-update[no update]' \
        '--no-changer[no changer]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amtape subcommand' sub ;;
        args)
            case $words[1] in
                load) _arguments \
                    '--slot=+[N]:n:' \
                    '--label=+[name]:str:' \
                    '*:slot or label:' ;;
                label) _arguments \
                    '*:label name:' ;;
                slot) _arguments \
                    '1:action:(advance current next prev first last)' ;;
                show|inventory|taper) _arguments \
                    '--changer=+[name]:str:' \
                    '*:config:' ;;
            esac
            ;;
    esac
}

_amtape "$@"
