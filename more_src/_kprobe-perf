#compdef kprobe-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/kprobe.8
# trace a given kprobe definition, kernel dynamic tracing (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-F[force, trace despite warnings]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-p+[PID to match on events]:pid:_pids' \
  '-L+[thread ID to match on events]:tid' \
  '-v[view format file, do not trace]' \
  '-H[include column headers]' \
  '-s[show kernel stack traces]' \
  '1:kprobe definition:' \
  '2:filter:' && ret=0

return ret
