#compdef terraform-tui
# terraform-tui — Terraform textual UI for managing state and resources (Python/Textual)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --dir)'{-d,--dir}'[Terraform working directory]:directory:_files -/' \
  '--state=[path to state file]:state file:_files -g "*.tfstate"'
