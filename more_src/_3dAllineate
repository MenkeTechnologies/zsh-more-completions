#compdef 3dAllineate
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dAllineate.html
# AFNI align (register) one dataset to a base via affine transform

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-base[base dataset]:dataset:_files' \
  '(-source -input)'{-source,-input}'[source dataset to transform]:dataset:_files' \
  '(-prefix -out)'{-prefix,-out}'[output aligned dataset]:prefix' \
  '-master[write output on grid of dataset]:dataset:_files' \
  '-1Dparam_save[save warp parameters in ASCII]:file:_files' \
  '-1Dparam_apply[apply pre-computed warp parameters]:file:_files' \
  '-1Dmatrix_save[save transform matrix per sub-brick]:file:_files' \
  '-1Dmatrix_apply[apply pre-computed transform matrices]:file:_files' \
  '-cost[matching cost function]:cost:(ls mi crM nmi hel crA crU lpc lpa)' \
  '-lpc[Local Pearson Correlation (signed)]' \
  '-lpa[Local Pearson Correlation (absolute)]' \
  '-check[re-optimize with alternative cost to verify]:cost' \
  '-interp[interpolation during matching]:interp:(NN linear cubic quintic)' \
  '-final[interpolation for output]:interp:(NN linear cubic quintic wsinc5)' \
  '-warp[transformation complexity]:warp:(shift_only shift_rotate shift_rotate_scale affine_general)' \
  '-EPI[restrict warping for echo-planar images]' \
  '-onepass[use only fine resolution pass]' \
  '-twopass[coarse then fine passes for all sub-bricks]' \
  '-twofirst[two-pass on first image, single-pass thereafter]' \
  '-twobest[keep best N candidates from coarse pass]:bb' \
  '-twoblur[blurring radius for first pass]:rr' \
  '-fineblur[blurring radius for fine pass]:x' \
  '-conv[convergence threshold in mm]:mmm' \
  '-nmatch[maximum scattered points for matching]:nnn' \
  '-automask[compute binary mask from base image]' \
  '-autoweight[compute weighted mask]' \
  '-weight[provide external weight dataset]:dataset:_files' \
  '-source_mask[mask the source dataset]:dataset:_files' \
  '-source_automask[automatically mask source]' \
  '-emask[exclude specified voxels from analysis]:dataset:_files' \
  '-wtprefix[save computed weight volume]:prefix' \
  '-parfix[fix parameter n to value v]:n' \
  '-parang[constrain parameter n to range]:n' \
  '-parini[initialize parameter n to value]:n' \
  '-maxrot[maximum rotation in degrees]:dd' \
  '-maxshf[maximum shift in mm]:dd' \
  '-maxscl[maximum scaling factor]:dd' \
  '-maxshr[maximum shearing factor]:dd' \
  '(-mast_dxyz -newgrid)'{-mast_dxyz,-newgrid}'[output grid spacing]:del' \
  '(-floatize -float)'{-floatize,-float}'[output as floating-point]' \
  '-cmass[use center-of-mass for initial alignment]' \
  '-nocmass[disable center-of-mass calculation]' \
  '(-zclip -noneg)'{-zclip,-noneg}'[replace negatives with zero]' \
  '-nopad[disable zero-padding]' \
  '-usetemp[write intermediate data to disk]' \
  '-nousetemp[keep data in memory]' \
  '-verb[print verbose progress reports]' \
  '-VERB[extra verbose output]' \
  '-quiet[suppress verbose output]' \
  '-blok[local neighborhood shape for lpc/lpa]:bbb' \
  '-allcost[compute all available cost functionals]' \
  '-allcostX[evaluate costs on unwarped inputs and exit]' \
  '*:dataset:_files' && ret=0

return ret
