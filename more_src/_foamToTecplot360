#compdef foamToTecplot360
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/postProcessing/dataConversion/foamToTecplot360 — convert OpenFOAM case to Tecplot 360 binary format (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-time+[restrict to selected times]:times:_default' \
    '-latestTime[use latest time]' \
    '-newTimes[only new times]' \
    '-fields+[wordReList of fields to write]:list:_default' \
    '-cellSet+[write data for named cellSet]:name:_default' \
    '-faceSet+[write data for named faceSet]:name:_default' \
    '-nearCellValue[use cell value on boundary instead of patch value]' \
    '-noInternal[skip internal mesh]' \
    '-noFaceZones[skip face zones]' \
    '-noLinks[do not create time-step symlinks]' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
