#compdef maldet
# Documentation: https://man.archlinux.org/search?q=maldet
# Reference accessed: 2026-05-16

_arguments -s \
  '(-b --background)'{-b,--background}'[run in background]' \
  '(-u --update --update-sigs)'{-u,--update,--update-sigs}'[update signatures]' \
  '(-d --update-ver --update-version)'{-d,--update-ver,--update-version}'[update version]' \
  '(-m --monitor)'{-m,--monitor}'=[monitor target]:target:' \
  '(-k --kill-monitor)'{-k,--kill-monitor,-kill}'[kill running monitor]' \
  '(-c --checkout)'{-c,--checkout}'=[checkout file as malware]:file:_files' \
  '(-r --scan-recent)'{-r,--scan-recent}'=[scan recent days]:path days:' \
  '(-a --scan-all)'{-a,--scan-all}'=[scan all under path]:path:_files -/' \
  '(-f --file-list)'{-f,--file-list}'=[scan file list]:file:_files' \
  '(-i --include-regex)'{-i,--include-regex}'=[include regex]:regex:' \
  '(-x --exclude-regex)'{-x,--exclude-regex}'=[exclude regex]:regex:' \
  '(-l --log)'{-l,--log}'[show event log]' \
  '(-e --report)'{-e,--report}'=[report SCANID]:id:' \
  '(-E --dump-report)'{-E,--dump-report}'=[dump report SCANID]:id:' \
  '(-s --restore)'{-s,--restore}'=[restore file or SCANID]:target:' \
  '(-q --quarantine)'{-q,--quarantine}'=[quarantine SCANID]:id:' \
  '(-n --clean)'{-n,--clean}'=[clean SCANID]:id:' \
  '(-p --purge)'{-p,--purge}'[clear logs/quarantine]' \
  '(-U --user)'{-U,--user}'=[user]:user:_users' \
  '*'{-co,--config-option}'=[config option]:VAR=VAL:' \
  '(- *)'{-h,--help}'[show help]'
