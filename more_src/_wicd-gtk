#compdef wicd-gtk
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/wicd-client.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (wicd-gtk shares manpage with wicd-client).

local curcontext="$curcontext" state line ret=1
_arguments -C \
  '(- *)'{-h,--help}'[print this help information]' \
  '(-t --tray)'{-t,--tray}'[run the wicd tray icon only]' \
  '(-n --no-tray)'{-n,--no-tray}'[run wicd without the tray icon]' \
  '(-a --no-animate)'{-a,--no-animate}'[disable network traffic tray animations]' && ret=0

return ret
