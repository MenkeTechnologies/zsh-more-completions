#compdef wicd-gtk wicd-client
# Documentation: https://man.archlinux.org/search?q=wicd-gtk
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-tray[disable system tray]' \
  '--no-animate[disable tray animations]' \
  '--no-notifications[disable notifications]' \
  '--quiet[suppress messages]' \
  '-t[show tray icon]' \
  '--display=[X display]:display:' && ret=0

return ret
