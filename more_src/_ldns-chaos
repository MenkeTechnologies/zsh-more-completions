#compdef ldns-chaos
# Documentation: https://man.archlinux.org/man/core/ldns/ldns-chaos.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (ldns-chaos has no options).

# ldns-chaos: query CHAOS class info from a DNS server
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:nameserver:_hosts' && ret=0
return ret
