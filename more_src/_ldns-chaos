#compdef ldns-chaos
# Documentation: https://manpages.debian.org/bookworm/ldnsutils/ldns-chaos.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ldns-chaos(1) manpage - no options.

# ldns-chaos: query CHAOS class info from a DNS server
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:nameserver:_hosts' && ret=0
return ret
