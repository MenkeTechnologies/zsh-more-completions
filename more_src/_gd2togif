#compdef gd2togif
# Documentation: https://manpages.debian.org/unstable/libgd-tools/gd2togif.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gd2togif - convert a GD2 image file to a GIF image
# Usage: gd2togif input.gd2 output.gif

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input GD2:_files -g "*.gd2"' \
  '2:output GIF:_files -g "*.gif"' && ret=0

return ret
