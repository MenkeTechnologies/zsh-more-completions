#compdef owncloudcmd
# Documentation: https://manpages.debian.org/testing/owncloud-client-cmd/owncloudcmd.1.en.html
# owncloudcmd: command line ownCloud/Nextcloud client tool

local ret=1

_arguments -s -S \
  '(-u --user)'{-u,--user}'=[use as the login name]:user' \
  '(-p --password)'{-p,--password}'=[use as the password]:password' \
  '-n[use netrc(5) for login]' \
  '--non-interactive[do not prompt for questions]' \
  '(-s --silent)'{-s,--silent}'[inhibit verbose log output]' \
  '--trust[trust any SSL certificate, including invalid ones]' \
  '--httpproxy=[use server as HTTP proxy]:proxy' \
  '--nonshib[use non-Shibboleth WebDAV authentication]' \
  '--davpath=[override the WebDAV path]:path' \
  '--exclude=[exclude list file]:file:_files' \
  '--unsyncedfolders=[file listing unsynced folders for selective sync]:file:_files' \
  '--max-sync-retries=[retry at most n times (default 3)]:count' \
  '-h[sync hidden files, do not ignore them]' \
  '1:source directory:_files -/' \
  '2:server URL:_urls' && ret=0

return ret
