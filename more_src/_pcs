#compdef pcs

# Zsh completion for pcs - Pacemaker/Corosync cluster management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cluster:configure cluster options and nodes'
  'resource:manage cluster resources'
  'stonith:manage fence devices'
  'constraint:manage resource constraints'
  'property:manage pacemaker properties'
  'acl:manage pacemaker access control lists'
  'quorum:manage cluster quorum settings'
  'status:view cluster status'
  'config:view and manage cluster configuration'
  'pcsd:manage pcsd daemon'
  'node:manage cluster nodes'
  'alert:manage pacemaker alerts'
  'booth:manage booth (cluster ticket manager)'
  'client:manage pcsd client'
  'dr:manage disaster recovery'
  'host:manage cluster hosts'
  'tag:manage pacemaker tags'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f,--file}'[perform actions on file instead of active CIB]:file:_files' \
  '--force[override checks]' \
  '--request-timeout=[set request timeout]:seconds' \
  '--debug[print debug information]' \
  '--version[display version]' \
  '--wait=[wait up to N seconds for changes]:seconds' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pcs command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (cluster)
        local -a cluster_commands=(
          'auth:authenticate cluster nodes'
          'setup:set up a new cluster'
          'start:start cluster services'
          'stop:stop cluster services'
          'kill:force stop cluster services'
          'enable:enable cluster services on boot'
          'disable:disable cluster services on boot'
          'destroy:destroy cluster configuration'
          'status:show cluster status'
          'config:show cluster configuration'
          'node:manage cluster nodes'
          'cib:manage the cluster information base'
          'cib-push:push CIB to the cluster'
          'cib-upgrade:upgrade CIB schema'
          'verify:verify cluster configuration'
          'report:generate cluster report'
        )
        _arguments '1:cluster command:->cluster_cmd' && ret=0
        if [[ $state == cluster_cmd ]]; then
          _describe -t commands 'cluster command' cluster_commands && ret=0
        fi
        ;;
      (resource)
        local -a resource_commands=(
          'create:create a new resource'
          'delete:delete a resource'
          'remove:remove a resource'
          'enable:enable a resource'
          'disable:disable a resource'
          'restart:restart a resource'
          'cleanup:clean up resource state'
          'refresh:refresh resource state'
          'move:move a resource to a different node'
          'ban:ban a resource from a node'
          'clear:clear resource constraints'
          'failcount:manage resource fail counts'
          'relocate:relocate resources'
          'config:show resource configuration'
          'show:show resource configuration'
          'status:show resource status'
          'group:manage resource groups'
          'clone:manage resource clones'
          'bundle:manage resource bundles'
          'manage:set resource to managed mode'
          'unmanage:set resource to unmanaged mode'
          'meta:manage resource meta attributes'
          'update:update resource configuration'
          'op:manage resource operations'
          'defaults:set resource defaults'
          'agents:list available resource agents'
          'describe:show resource agent information'
          'list:list all resources'
          'debug-start:start resource in debug mode'
          'debug-stop:stop resource in debug mode'
          'debug-promote:promote resource in debug mode'
          'debug-demote:demote resource in debug mode'
          'debug-monitor:monitor resource in debug mode'
          'utilization:manage resource utilization'
          'relations:show resource relations'
        )
        _arguments '1:resource command:->resource_cmd' && ret=0
        if [[ $state == resource_cmd ]]; then
          _describe -t commands 'resource command' resource_commands && ret=0
        fi
        ;;
      (status)
        local -a status_commands=(
          'resources:show resource status'
          'cluster:show cluster status'
          'nodes:show node status'
          'corosync:show corosync status'
          'quorum:show quorum status'
          'xml:show CIB as XML'
        )
        _arguments '1:status command:->status_cmd' && ret=0
        if [[ $state == status_cmd ]]; then
          _describe -t commands 'status command' status_commands && ret=0
        fi
        ;;
      (stonith)
        local -a stonith_commands=(
          'create:create a fence device'
          'delete:delete a fence device'
          'enable:enable a fence device'
          'disable:disable a fence device'
          'cleanup:clean up fence device state'
          'refresh:refresh fence device state'
          'config:show fence device configuration'
          'show:show fence device configuration'
          'status:show fence device status'
          'list:list available fence agents'
          'describe:describe a fence agent'
          'update:update fence device configuration'
          'fence:fence a node'
          'confirm:confirm a node has been fenced'
          'level:manage fencing levels'
          'history:show fencing history'
          'sbd:manage SBD configuration'
        )
        _arguments '1:stonith command:->stonith_cmd' && ret=0
        if [[ $state == stonith_cmd ]]; then
          _describe -t commands 'stonith command' stonith_commands && ret=0
        fi
        ;;
      (constraint)
        local -a constraint_commands=(
          'location:manage location constraints'
          'order:manage ordering constraints'
          'colocation:manage colocation constraints'
          'ticket:manage ticket constraints'
          'config:show constraint configuration'
          'show:show constraint configuration'
          'remove:remove a constraint'
          'ref:show constraint references'
          'rule:manage constraint rules'
        )
        _arguments '1:constraint command:->constraint_cmd' && ret=0
        if [[ $state == constraint_cmd ]]; then
          _describe -t commands 'constraint command' constraint_commands && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
