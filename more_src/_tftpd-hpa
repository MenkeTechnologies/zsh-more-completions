#compdef tftpd-hpa in.tftpd
# Documentation: https://man.archlinux.org/search?q=tftpd-hpa
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-a+[bind address]:addr:' \
  '-B+[block size]:n:' \
  '-c[create new files]' \
  '-d+[debug level]:lvl:' \
  '-F+[fork off]:file:_files' \
  '-l[standalone]' \
  '-L[do not daemonize]' \
  '-m+[remap rules]:file:_files' \
  '-O+[port mode]:mode:' \
  '-p[permissive]' \
  '-P+[pid file]:file:_files' \
  '-r+[refuse opt]:opt:' \
  '-R+[port range]:range:' \
  '-s+[secure dir]:dir:_files -/' \
  '-T+[retransmit timeout]:sec:' \
  '-t+[idle timeout]:sec:' \
  '-u+[user]:user:_users' \
  '-U+[umask]:mode:' \
  '-v[verbose]' \
  '*:dir:_files -/' && ret=0

return ret
