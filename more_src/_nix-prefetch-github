#compdef nix-prefetch-github

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--rev[git revision to fetch]:rev:' \
  '--branch-name[branch name]:branch:' \
  '--hash-type[hash type]:type:(sha256)' \
  '--fetch-submodules[fetch submodules]' \
  '--leave-dot-git[keep .git directory]' \
  '--deep-clone[perform a deep clone]' \
  '--nix[output as Nix expression]' \
  '--json[output as JSON]' \
  '--prefetch[output prefetch hash only]' \
  '--remote[use specific remote]:remote:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:owner:' \
  '2:repo:' && ret=0

return ret
