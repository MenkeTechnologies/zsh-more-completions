#compdef bcecmd
# Documentation: https://github.com/baidubce/bce-cmd
# Baidu BCE CMD command line tool for Baidu Object Storage (BOS)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[interactive configuration of credentials]' \
  '*:command:((bos\:"Baidu Object Storage operations" bosprobe\:"diagnose BOS upload and download errors" config\:"manage configuration"))' && ret=0

return ret
