#compdef dblab

# Zsh completion for dblab - interactive database client TUI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--host=[database host]:host' \
  '--port=[database port]:port' \
  '--user=[database user]:user' \
  '-u+[database user]:user' \
  '--pass=[database password]:password' \
  '--db=[database name]:database' \
  '--driver=[database driver]:driver:(postgres mysql sqlite3 oracle mssql)' \
  '--url=[connection URL]:url' \
  '--ssl=[SSL mode]:mode:(disable require verify-ca verify-full)' \
  '--sslCert=[SSL certificate]:cert:_files' \
  '--sslKey=[SSL key]:key:_files' \
  '--sslRootcert=[SSL root certificate]:cert:_files' \
  '--schema=[database schema]:schema' \
  '--socket=[Unix socket path]:socket:_files' \
  '--limit=[default result limit]:limit' \
  '--cfg=[config file path]:config:_files -g "*.{yaml,yml}"' \
  '--encrypt[encrypt connection]' && ret=0

return ret
