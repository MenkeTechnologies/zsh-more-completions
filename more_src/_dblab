#compdef dblab
# Documentation: https://github.com/danvergara/dblab
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Interactive database client TUI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-k[load keybindings configuration]' \
  '-u+[database connection URL]:url:' \
  '--url=[connection URL]:url:' \
  '--host=[server hostname/IP]:host:' \
  '--port=[server port]:port:' \
  '--user=[database user]:user:' \
  '--pass=[database password]:password:' \
  '--db=[database name]:database:' \
  '--driver=[database driver]:driver:(postgres mysql sqlite oracle sqlserver)' \
  '--socket=[path to Unix socket file]:socket:_files' \
  '--ssl=[SSL mode]:mode:(disable require verify-ca verify-full)' \
  '--ssl-verify=[enable/disable SSL verification]:mode:(true false)' \
  '--sslcert=[client SSL certificate file]:cert:_files' \
  '--sslkey=[client SSL key file]:key:_files' \
  '--sslpassword=[password for SSL key]:password:' \
  '--sslrootcert=[CA certificate file]:cert:_files' \
  '--ssh-host=[SSH server hostname/IP]:host:' \
  '--ssh-port=[SSH port]:port:' \
  '--ssh-user=[SSH username]:user:' \
  '--ssh-pass=[SSH password]:password:' \
  '--ssh-key=[SSH private key file]:key:_files' \
  '--ssh-key-pass=[passphrase for SSH private key]:passphrase:' \
  '--config=[use configuration file]:config:_files' \
  '--cfg-name=[database config section name]:name:' \
  '--schema=[database schema (Postgres/Oracle)]:schema:' \
  '--limit=[result set size limit]:limit:' \
  '--encrypt=[data encryption setting]:value:' \
  '--timeout=[connection timeout seconds]:secs:' \
  '--trace-file=[trace log file]:file:_files' \
  '--wallet=[Oracle wallet path]:path:_files -/' \
  && ret=0

return ret
