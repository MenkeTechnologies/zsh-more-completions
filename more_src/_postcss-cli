#compdef postcss-cli postcss

# Zsh completion for postcss-cli - CSS processor CLI

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --version)'{-V,--version}'[show postcss-cli version]'
  '(-o --output)'{-o,--output}'[output file]:file:_files'
  '(-d --dir)'{-d,--dir}'[output directory]:directory:_files -/'
  '(-r --replace)'{-r,--replace}'[overwrite source files]'
  '--ext[extension for output files (with --dir)]:extension:'
  '(-b --base)'{-b,--base}'[mirror directory structure from this base]:path:_files -/'
  '(-s --syntax)'{-s,--syntax}'[custom postcss syntax]:module:'
  '(-p --parser)'{-p,--parser}'[custom postcss parser]:module:'
  '(-t --stringifier)'{-t,--stringifier}'[custom postcss stringifier]:module:'
  '(-w --watch)'{-w,--watch}'[watch input files and rebuild]'
  '--poll[use polling for watch mode]:interval:'
  '(-x --ext)'{-x,--ext}'[extension for output files]:ext:'
  '--verbose[be verbose]'
  '--include-dotfiles[include dotfiles in input glob]'
  '(-u --use)'{-u,--use}'[plugins to use]:plugin:'
  '(-m --map)'{-m,--map}'[generate source map]'
  '--no-map[disable source map generation]'
  '--env[NODE_ENV for config loading]:env:(development production test)'
  '(-c --config)'{-c,--config}'[config file or directory]:path:_files'
  '*:css file:_files -g "*.(css|pcss|scss|sass)"'
)

_arguments -s -S $arguments
