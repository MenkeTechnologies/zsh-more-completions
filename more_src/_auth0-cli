#compdef auth0-cli auth0
# _auth0-cli — Okta Auth0 IDaaS CLI alias (auth0 team, Go); cobra
# upstream: https://github.com/auth0/auth0-cli

_auth0-cli() {
    local -a sub=(
        'actions:manage actions'
        'actions:create:create action'
        'actions:list:list actions'
        'actions:show:show action'
        'actions:update:update action'
        'actions:delete:delete action'
        'actions:deploy:deploy action'
        'actions:test:test action'
        'api:make API request'
        'apis:manage APIs'
        'apis:create:create API'
        'apis:list:list APIs'
        'apis:show:show API'
        'apis:update:update API'
        'apis:delete:delete API'
        'apis:scopes:list:list scopes'
        'apps:manage applications'
        'apps:create:create app'
        'apps:list:list apps'
        'apps:show:show app'
        'apps:update:update app'
        'apps:delete:delete app'
        'apps:use:set default app'
        'apps:open:open app dashboard'
        'attack-protection:show:show settings'
        'attack-protection:breached-password-detection:show:show settings'
        'branding:show:show branding'
        'branding:update:update branding'
        'branding:templates:show:show template'
        'branding:templates:update:update template'
        'branding:domains:list:list custom domains'
        'completion:generate completion'
        'config:init:initialize config'
        'help:show help'
        'login:login to tenant'
        'logout:logout'
        'orgs:list:list organizations'
        'orgs:create:create organization'
        'orgs:delete:delete organization'
        'orgs:show:show organization'
        'orgs:update:update organization'
        'quickstarts:download:download quickstart'
        'quickstarts:list:list quickstarts'
        'roles:create:create role'
        'roles:delete:delete role'
        'roles:list:list roles'
        'roles:show:show role'
        'roles:update:update role'
        'roles:permissions:add:add permission'
        'roles:permissions:list:list permissions'
        'roles:permissions:remove:remove permission'
        'rules:create:create rule'
        'rules:delete:delete rule'
        'rules:disable:disable rule'
        'rules:enable:enable rule'
        'rules:list:list rules'
        'rules:show:show rule'
        'rules:update:update rule'
        'tenants:add:add tenant'
        'tenants:list:list tenants'
        'tenants:open:open tenant'
        'tenants:settings:show:show settings'
        'tenants:settings:update:update settings'
        'tenants:use:switch tenant'
        'test:token:get test token'
        'test:login:test login flow'
        'universal-login:show:show universal login'
        'universal-login:update:update universal login'
        'users:create:create user'
        'users:delete:delete user'
        'users:list:list users'
        'users:show:show user'
        'users:update:update user'
        'users:import:import users'
        'users:open:open user'
        'users:search:search users'
        'users:roles:assign:assign role'
        'users:roles:remove:remove role'
        'users:roles:show:show roles'
        'logs:list:list logs'
        'logs:streams:create:create stream'
        'logs:streams:delete:delete stream'
        'logs:streams:list:list streams'
        'logs:streams:open:open stream'
        'logs:streams:show:show stream'
        'logs:streams:update:update stream'
        'logs:tail:tail logs'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--tenant=+[tenant subdomain]:str:' \
        '--json[json output]' \
        '--force[skip confirmation]' \
        '--no-input[no interactive]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'auth0 subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--domain=+[tenant domain]:str:' \
                    '--client-id=+[client id]:str:' \
                    '--client-secret=+[client secret]:str:' \
                    '--audience=+[audience]:str:' \
                    '--no-input[no interactive]' \
                    '--scopes=+[scopes csv]:str:' ;;
                api) _arguments \
                    '1:method:(GET POST PUT PATCH DELETE)' \
                    '2:path:' \
                    '--data=+[json body]:str:' \
                    '-d+[json body]:str:' \
                    '--query=+[query string]:str:' \
                    '-q+[query string]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_auth0-cli "$@"
