#compdef cloudlist
# Documentation: https://github.com/projectdiscovery/cloudlist
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-config=[cloudlist config file]:file:_files' \
  '-pc=[provider config file]:file:_files' \
  '-provider-config=[provider config file]:file:_files' \
  '-p=[display results for given providers (comma-separated)]:provider' \
  '-provider=[display results for given providers]:provider' \
  '-id=[display results for given IDs]:ids' \
  '-host[show only hostnames]' \
  '-ip[show only IPs]' \
  '-s=[query/display results for given service]:service' \
  '-service=[query/display results for given service]:service' \
  '-ep[exclude private IPs from output]' \
  '-exclude-private[exclude private IPs from output]' \
  '-up[update cloudlist]' \
  '-update[update cloudlist]' \
  '-duc[disable automatic update check]' \
  '-disable-update-check[disable automatic update check]' \
  '-o=[output file]:file:_files' \
  '-output=[output file]:file:_files' \
  '-json[output as JSON]' \
  '-version[show version]' \
  '-v[verbose output]' \
  '-silent[silent output]' \
  '*: : _default'
