#compdef cloudlist
# Documentation: https://man.archlinux.org/search?q=cloudlist
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-silent[silent output]' \
  '-o=[output format]:(stdout json csv)' \
  '-provider=[cloud provider]:provider' \
  '-config=[config file]:file:_files' \
  '*: : _default'
