#compdef ascii-image-converter

# Zsh completion for ascii-image-converter - convert images to ASCII art

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-C,--color}'[display with color]' \
  {-c,--complex}'[use complex character set]' \
  {-d,--dimensions}'+[set dimensions (WxH)]:dimensions' \
  {-W,--width}'+[set width]:width' \
  {-H,--height}'+[set height]:height' \
  {-m,--map}'+[custom character map]:characters' \
  {-f,--full}'[use full terminal width]' \
  {-b,--braille}'[use braille characters]' \
  '--threshold+[braille threshold (0-255)]:threshold' \
  {-n,--negative}'[invert colors]' \
  '--dither[apply dithering]' \
  '--font-file+[custom font for image saving]:font file:_files' \
  '--font-color+[RGB font color]:color (R,G,B)' \
  '--save-txt+[save as text file]:output file:_files' \
  '--save-img+[save as image]:output file:_files' \
  '--save-gif+[save GIF as ASCII GIF]:output file:_files' \
  '--save-bg+[background color for saved image]:color (R,G,B)' \
  '--only-save[only save, do not display]' \
  '--flipX[flip horizontally]' \
  '--flipY[flip vertically]' \
  '--grayscale[force grayscale]' \
  '1:image:_files -g "*.{png,jpg,jpeg,gif,bmp,webp,tiff,svg}"'
