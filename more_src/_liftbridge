#compdef liftbridge
# Documentation: https://github.com/liftbridge-io/liftbridge
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# liftbridge: Liftbridge server (streaming on NATS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--id=[server id]:id:' \
  '--nats-server=[NATS servers]:servers:' \
  '--namespace=[Liftbridge namespace]:ns:' \
  '--port=[gRPC port]:port:' \
  '--host=[gRPC host]:host:' \
  '--data-dir=[data dir]:dir:_files -/' \
  '--embedded-nats[embed a NATS server]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-recovery[log Raft recovery progress]' \
  '*::liftbridge args:_files' && ret=0
return ret
