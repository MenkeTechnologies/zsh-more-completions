#compdef pglobal
# _pglobal — dwarves pglobal helper (Arnaldo Carvalho de Melo); list global variables + functions from DWARF
# upstream: https://github.com/acmel/dwarves

_pglobal() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-f[functions only]' \
        '-v[variables only]' \
        '*:file:_files'
}

_pglobal "$@"
