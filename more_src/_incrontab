#compdef incrontab

# Zsh completion for incrontab - inotify cron table manipulator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-l --list)'{-l,--list}'[list the current incrontab]' \
  '(-r --remove)'{-r,--remove}'[remove the current incrontab]' \
  '(-e --edit)'{-e,--edit}'[edit the current incrontab]' \
  '(-t --types)'{-t,--types}'[list supported event types]' \
  '(-d --reload)'{-d,--reload}'[reload the current incrontab]' \
  '(-u --user)'{-u,--user}'[specify user]:user:_users' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '(-h --help)'{-h,--help}'[display help message]' \
  '1:incrontab file:_files' && ret=0

return ret
