#compdef milter-regex

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-l+[log facility]:facility:(daemon mail local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-p+[milter socket]:socket:_files' \
  '-t+[timeout sec]:sec:' \
  '-u+[user]:user:_users' \
  '-v[verbose]' && ret=0

return ret
