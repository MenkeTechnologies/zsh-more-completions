#compdef 3dGenFeatureDist
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dGenFeatureDist.html
# Generate feature probability distributions for segmentation

local ret=1

_arguments -s \
  '-classes[semicolon-delimited class labels]:classes' \
  '-OTHER[include OTHER class with uniform distribution]' \
  '-no_OTHER[disable the OTHER class]' \
  '-features[semicolon-delimited feature names]:features' \
  '-sig[feature volumes, one per sub-brick]:dataset:_files' \
  '-samp[voxel volumes with class membership keys]:dataset:_files' \
  '-hspec[histogram parameters MIN MAX NBINS]:spec' \
  '-prefix[output prefix]:prefix' \
  '-ShowTheseHists[display .niml.hist files and exit]:file:_files' \
  '-labeltable[label table for class definitions]:file:_files' \
  '-overwrite[allow overwriting output]' \
  '-debug[debugging verbosity level]:level' && ret=0

return ret
