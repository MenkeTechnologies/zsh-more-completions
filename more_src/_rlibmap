#compdef rlibmap
# Documentation: https://manned.org/rlibmap/dcb60e04
# ROOT utility to create class-to-library maps

local ret=1

_arguments -s -S \
  '(- *)--help[show short list of options and exit]' \
  '-f[force flag]' \
  '(-o)-r[read map file]:mapfile:_files' \
  '(-r)-o[output on map file]:mapfile:_files' \
  '*-l[library to inspect]:sofile:_files' \
  '*-d[dependency library]:depsofile:_files' \
  '*-c[CINT linkdef to use]:linkdef:_files' && ret=0

return ret
