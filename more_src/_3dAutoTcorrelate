#compdef 3dAutoTcorrelate
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dAutoTcorrelate.html
# AFNI: all-pairs voxel correlation matrix from a 3D+time dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-pearson -spearman -quadrant -eta2)-pearson[Pearson correlation (default)]' \
  '(-pearson -spearman -quadrant -eta2)-spearman[Spearman correlation]' \
  '(-pearson -spearman -quadrant -eta2)-quadrant[quadrant correlation]' \
  '(-pearson -spearman -quadrant -eta2)-eta2[eta-squared similarity]' \
  '-polort[polynomial detrend order]:m:' \
  '-autoclip[clip out non-brain voxels automatically]' \
  '-automask[create mask from input]' \
  '-mask[mask dataset]:mask:_files' \
  '-mask_only_targets[mask only target voxels]' \
  '-mask_source[separate source mask dataset]:mask:_files' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-out1D[save correlations to 1D file]:file:_files' \
  '-time[mark output as 3D+time]' \
  '-mmap[use memory mapping for output]' \
  '*:dataset:_files' && ret=0

return ret
