#compdef fmtutil fmtutil-sys fmtutil-user mktexfmt
# Documentation: fmtutil --help (TeX Live 2026)
# Source: TeX fmtutil — rebuild / manage TeX .fmt and Metafont .base files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    '--all:recreate all format files'
    '--missing:create all missing format files'
    '--refresh:recreate only existing format files'
    '--byengine:create all formats for given engine'
    '--byfmt:(re)create format file for FMTNAME'
    '--byhyphen:rebuild all formats using given hyphenation file'
    '--enablefmt:enable a format'
    '--disablefmt:disable a format'
    '--showhyphen:show hyphenation file for FMTNAME'
    '--catcfg:(no-op)'
    '--listcfg:list all format definitions'
    '--list:list all format files'
    '--help:show help'
    '--version:show version'
)

_arguments -C \
    '--sys[use TEXMFSYS{VAR,CONFIG}]' \
    '--user[use TEXMF{VAR,CONFIG}]' \
    '*--cnffile=[fmtutil configuration file]:file:_files' \
    '(-n --dry-run)'{-n,--dry-run}'[do not actually build]' \
    '--fmtdir=[write formats under DIR]:dir:_files -/' \
    '--no-engine-subdir[do not use engine subdir]' \
    '--no-error-if-no-format[ok if no format selected]' \
    '--no-error-if-no-engine=[ok even if listed engines missing]:engine list:' \
    '--no-strict[ok even if a format fails to build]' \
    '--nohash[do not update ls-R]' \
    '--recorder[pass -recorder; save .fls]' \
    '--refresh[recreate only existing formats]' \
    '--status-file=[append status to FILE]:file:_files' \
    '--quiet[silent]' \
    '--dolinks[no-op]' \
    '--force[no-op]' \
    '--test[no-op]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd) _describe -t fmtutil-verbs 'fmtutil command' verbs && ret=0 ;;
    args) _files && ret=0 ;;
esac

return ret
