#compdef moshi moshi-server moshi-cli
# _moshi — Kyutai Labs Moshi full-duplex speech-text foundation model and real-time chatbot framework (kyutai-labs team, Python); argparse
# upstream: https://github.com/kyutai-labs/moshi

_moshi() {
    local -a sub=(
        'serve:start the Moshi server'
        'chat:start interactive chat client'
        'pcm:run on PCM streams'
        'audio:audio subcommands'
        'mlx:Apple MLX inference subcommands'
        'rust:Rust inference subcommands'
        'download:download model checkpoints'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--device=+[device]:d:(cpu cuda mps auto)' \
        '--dtype=+[dtype]:t:(float16 float32 bfloat16 auto)' \
        '--seed=+[N]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug]' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'moshi subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--ssl-cert=+[cert]:file:_files' \
                    '--ssl-key=+[key]:file:_files' \
                    '--no-stream[disable streaming]' ;;
                chat) _arguments \
                    '--server=+[server URL]:url:_urls' \
                    '--input-device=+[device id]:n:' \
                    '--output-device=+[device id]:n:' \
                    '--sample-rate=+[Hz]:n:' \
                    '--vad-threshold=+[F]:f:' ;;
                pcm) _arguments \
                    '--input=+[input pcm]:file:_files' \
                    '--output=+[output pcm]:file:_files' \
                    '--sample-rate=+[Hz]:n:' ;;
                download) _arguments \
                    '--model=+[model id]:str:' \
                    '--cache-dir=+[cache dir]:dir:_files -/' \
                    '--force[force redownload]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_moshi "$@"
