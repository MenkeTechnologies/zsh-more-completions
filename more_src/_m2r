#compdef m2r
# Documentation: https://github.com/miyakogi/m2r
# Markdown to reStructuredText converter

_arguments -s -S \
  '--overwrite[overwrite existing output file]' \
  '--dry-run[print output without writing to file]' \
  '--no-underscore-emphasis[disable underscore emphasis]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:markdown file:_files -g "*.md"' \
  && return 0
