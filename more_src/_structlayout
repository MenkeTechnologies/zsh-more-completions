#compdef structlayout
# Documentation: https://man.archlinux.org/search?q=structlayout
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-json)'--json'[Output JSON]' \
  '(-cpuprofile)'--cpuprofile+'[Write CPU profile to file]:file:_files' \
  '1:package import path:' \
  '2:type name:' \
  '*::args: _default'
