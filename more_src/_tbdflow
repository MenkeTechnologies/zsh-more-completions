'--verbose[Enable verbose output for debugging]' \
'--dry-run[Simulate the command without making any changes]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tbdflow_commands" \
"*::: :->tbdflow" \
&& ret=0
