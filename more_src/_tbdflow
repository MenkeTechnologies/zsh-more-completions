(( $+functions[_tbdflow_commands] )) ||
_tbdflow_commands() {
    local commands; commands=(
'init:Initialises the repository for Trunk-Based Development' \
'info:Shows the current tbdflow configuration' \
'update:Checks for a new version of tbdflow and updates it if available' \
'commit:Commits changes to the current branch or '\''main'\'' if no branch is checked out' \
'branch:Creates and pushes a new short-lived branch' \
'complete:Merges a short-lived branch into '\''main'\'' and deletes it' \
'sync:Syncs with the remote, shows recent history, and checks for stale branches. When ci_check is enabled, checks trunk CI status before pulling' \
'radar:Scans active remote branches for overlapping work that may cause merge conflicts' \
'status:Shows the current git status' \
'current-branch:Shows the current git branch name' \
'check-branches:Checks for stale branches (older than 1 day)' \
'generate-man-page:Generates a man page for the CLI' \
'generate-completion:Generates shell completion scripts' \
'changelog:Generates a changelog from Conventional Commits' \
'config:Internal commands for configuration' \
'head-sha:Prints the short SHA of the current HEAD commit' \
'undo:Reverts a commit on the trunk by its SHA. The panic button for trunk-based development' \
'note:Logs an intent note (breadcrumb) during development. Notes are captured in a local .tbdflow-intent.json and included in the next commit message as an Intent Log' \
'task:Manages the current task context for the intent log' \
'recover:Recovers a WIP snapshot from the safety log. Snapshots are captured automatically during notes and syncs' \
'review:Manages non-blocking post-commit reviews for trunk-based development' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tbdflow commands' commands "$@"
}
