#compdef av98
# _av-98 — AV-98 Gemini protocol client (CLI/TUI); navigates gemini:// URLs with bookmark/cache/MIME-handler hooks
# upstream: https://tildegit.org/solderpunk/AV-98

_av-98() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--bookmarks[load bookmarks at startup]' \
        '--tls-cert+[client cert]:file:_files' \
        '--tls-key+[client key]:file:_files' \
        '--no-cache[disable cache]' \
        '--debug[enable debug log]' \
        '*:gemini URL:_urls'
}

_av-98 "$@"
