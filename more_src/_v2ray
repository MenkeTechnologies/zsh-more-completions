#compdef v2ray

# Zsh completion for v2ray (network proxy platform)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:Run V2Ray with the specified config'
  'test:Test configuration'
  'convert:Convert configuration between formats'
  'uuid:Generate a new UUID'
  'tls:TLS certificate utilities'
  'version:Print version'
  'api:Call V2Ray API'
)

_arguments -s -S -C \
  '(-c --config)'{-c,--config}'=[Specify config file]:config file:_files -g "*.{json,toml,yaml,yml}"' \
  '--format=[Config format]:format:(json toml yaml)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'v2ray command' commands && ret=0
    ;;
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[Config file]:config:_files -g "*.{json,toml,yaml,yml}"' \
          '--format=[Config format]:format:(json toml yaml)' \
          '-d+[Config directory]:dir:_files -/' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'=[Config file to test]:config:_files -g "*.{json,toml,yaml,yml}"' \
          '--format=[Config format]:format:(json toml yaml)' && ret=0
        ;;
      tls)
        local -a tls_cmds=(
          'cert:Generate TLS certificate'
          'ping:Ping the specified server via TLS'
        )
        _describe -t tls_cmds 'tls subcommand' tls_cmds && ret=0
        ;;
      api)
        local -a api_cmds=(
          'restartlogger:Restart the logger'
          'stats:Get statistics'
          'statsquery:Query statistics'
          'adi:Add inbound'
          'ado:Add outbound'
          'rmi:Remove inbound'
          'rmo:Remove outbound'
        )
        _describe -t api_cmds 'api subcommand' api_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
