#compdef memslap
# Documentation: https://man.archlinux.org/man/memslap.1.en
# Generate testing loads on a memcached cluster (libmemcached)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-q --quiet)'{-q,--quiet}'[operate quietly]' \
  '(-v --verbose)'{-v,--verbose}'[operate more verbosely]' \
  '(-d --debug)'{-d,--debug}'[enable debug/verbose mode]' \
  '(-s --servers)'{-s,--servers}'=[server list as hostname[:port][,...]]:servers' \
  '(-n --non-blocking)'{-n,--non-blocking}'[enable non-blocking operations]' \
  '(-N --tcp-nodelay)'{-N,--tcp-nodelay}'[disable Nagle'\''s algorithm]' \
  '(-b --binary)'{-b,--binary}'[enable binary protocol]' \
  '(-B --buffer)'{-B,--buffer}'[buffer requests]' \
  '(-u --username)'{-u,--username}'=[SASL username]:username' \
  '(-p --password)'{-p,--password}'=[SASL password]:password' \
  '(-H --hash)'{-H,--hash}'=[key hash algorithm]:algorithm' \
  '(-U --udp)'{-U,--udp}'[enable UDP operation mode]' \
  '(-R --noreply)'{-R,--noreply}'[enable NOREPLY behavior for storage commands]' \
  '(-F --flush)'{-F,--flush}'[flush all servers prior test]' \
  '(-t --test)'{-t,--test}'=[test to perform]:test:(get mget set)' \
  '(-c --concurrency)'{-c,--concurrency}'=[number of threads to start (default 1)]:threads' \
  '(-e --execute-number)'{-e,--execute-number}'=[times to execute tests (default 10000)]:count' \
  '(-l --initial-load)'{-l,--initial-load}'=[keys to load before tests (default 10000)]:count' && ret=0

return ret
