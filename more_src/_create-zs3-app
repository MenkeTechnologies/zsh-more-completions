#compdef create-zs3-app
# Documentation: https://www.npmjs.com/package/create-zs3-app
# Reference accessed: 2026-05-23
# Verified: npm view create-zs3-app bin; npm readme Arguments CLI table.

# Zsh completion for create-zs3-app - ZS3 backend/frontend/fullstack scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--type=[project type]:type:(backend frontend fullstack)' \
  '--name=[project name]:name:' \
  '--variant=[language variant]:variant:(ts vanilla)' \
  '--framework=[additional framework]:framework:(express zs3 express-zs3 none)' \
  '--description=[project description]:description:' \
  '--author=[project author]:author:' \
  '--git[initialize git repository]' \
  '--no-git[skip git initialization]' \
  '--dry-run[show files without creating project]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
