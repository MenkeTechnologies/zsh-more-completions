#compdef orca-build
# Documentation: https://github.com/cyphar/orca-build
# build OCI images from Dockerfiles using umoci, runc and skopeo

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--clean[remove all intermediate image tags after successful build]' \
  '--gc[run a final garbage collection on output image]' \
  '--output=[path of OCI image to output to]:path:_files' \
  '--verbose[output debugging information]' \
  '--rootless[enable rootless containers mode]' \
  '*--build-arg=[build-time argument used with ARG]:name=value:' \
  '*'{-t,--tag}'=[tag(s) of the output image]:tag:' \
  '*:build context:_files -/' && ret=0

return ret
