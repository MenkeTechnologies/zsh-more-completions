#compdef zellij-cli2 zellij2
# _zellij-cli2 — Aram Drevekenin Zellij zellij-cli2 CLI command-line frontend wrapping the Zellij terminal workspace and multiplexer with batteries included open-source written in Rust originally Aram Drevekenin now Zellij community alternative to tmux screen WebAssembly-based-plugin-system-WASI mouse-support-out-of-the-box panes tabs floating-panes scrollback sessions theming layouts KDL-based-configuration session-resurrection-search Discord-style attach kill-all-sessions kill-session list-sessions delete-session run options edit dump-screen plugin-development-WASI launch session-name layout-file config-file new-tab focus-pane edit-scrollback go-to-tab close-pane previous-tab next-tab move-pane resize move-focus rename-pane query-tab-names list-clients kill-clients web (Aram Drevekenin Zellij community team, Rust); clap
# upstream: https://zellij.dev/

_zellij-cli2() {
    local -a sub=(
        'action:Issue an action to a running session'
        'attach:Attach to a session'
        'completion:Generate shell completions'
        'convert-config:Convert old yaml config to new kdl format'
        'convert-layout:Convert old yaml layout to new kdl format'
        'convert-theme:Convert old yaml theme to new kdl format'
        'delete-all-sessions:Delete all sessions'
        'delete-session:Delete a specific session'
        'edit:Edit a file with default editor'
        'help:show help'
        'kill-all-sessions:Kill all sessions'
        'kill-session:Kill specific session'
        'list-aliases:List aliases'
        'list-sessions:List active sessions'
        'options:Configure tab and pane options'
        'pipe:Send data to a plugin'
        'plugin:Load a plugin'
        'run:Run a command in a new pane'
        'setup:Generate setup files'
        'web:Run the web server'
        'version:Show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--max-panes=+[N]:n:' \
        '-s+[session name]:str:' \
        '--session=+[name]:str:' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--server[run server]' \
        '--config=+[file]:file:_files -g "*.kdl"' \
        '-c+[config]:file:_files -g "*.kdl"' \
        '--config-dir=+[dir]:dir:_files -/' \
        '-l+[layout]:file:_files -g "*.kdl"' \
        '--layout=+[file]:file:_files -g "*.kdl"' \
        '--debug[debug mode]' \
        '--no-pane-frames[no pane frames]' \
        '--pane-frames[pane frames]' \
        '--default-mode=+[m]:m:(normal locked resize pane tab scroll renamepane rename session move prompt tmux entersearch search)' \
        '-i+[input mode]:m:(normal locked resize pane tab scroll renamepane rename session move prompt tmux entersearch search)' \
        '--copy-command=+[cmd]:str:' \
        '--copy-clipboard=+[c]:c:(system primary)' \
        '--copy-on-select[copy on select]' \
        '--simplified-ui[simplified UI]' \
        '--theme=+[name]:str:' \
        '--theme-dir=+[dir]:dir:_files -/' \
        '--mouse-mode[mouse mode]' \
        '--scroll-buffer-size=+[N]:n:' \
        '--show-startup-tips=+[v]:v:(true false)' \
        '--show-release-notes=+[v]:v:(true false)' \
        '--create[create new session]' \
        '-b+[background]' \
        '--background[background]' \
        '--force-run-commands[force run commands]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zellij subcommand' sub ;;
        args)
            case $words[1] in
                action) _arguments '1:op:(close-pane new-pane new-tab close-tab move-focus move-pane resize switch-focus toggle-floating-panes toggle-fullscreen page-scroll-up page-scroll-down scroll-up scroll-down scroll-to-bottom scroll-to-top clear-screen go-to-next-tab go-to-previous-tab go-to-tab rename-pane rename-tab rename-session move-tab undo-rename-pane undo-rename-tab edit edit-scrollback dump-screen dump-layout copy launch-or-focus-plugin pipe pipe-to-plugin)' '*:arg:' ;;
                attach|kill-session|delete-session) _arguments '1:session:' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
                setup) _arguments '*:arg:' ;;
                run|edit) _arguments '*:cmd:_command_names' ;;
                plugin) _arguments '*:plugin:' ;;
            esac
            ;;
    esac
}

_zellij-cli2 "$@"
