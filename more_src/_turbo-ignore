#compdef turbo-ignore
# Documentation: https://man.archlinux.org/search?q=turbo-ignore
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-t --task)'{-t,--task}'=[turbo task name]:task:' \
  '(-f --fallback)'{-f,--fallback}'=[compare to git ref when sha missing]:ref:' \
  '(-d --directory)'{-d,--directory}'=[working directory]:directory:_directories' \
  '--turbo-version=[turbo semver to invoke]:ver:' \
  '(-b --max-buffer)'{-b,--max-buffer}'=[child stdout buffer KiB]:kb:' \
  '(-v --version)'{-v,--version}'[version]' \
  '(-h --help)'{-h,--help}'[help]' \
  '::workspace package name:_default'
