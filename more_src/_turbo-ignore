#compdef turbo-ignore
# Documentation: https://github.com/vercel/turborepo/tree/main/packages/turbo-ignore
# Reference accessed: 2026-05-21
# Verified: upstream turbo-ignore README. Removed unverified flags
# (--task, --directory, --turbo-version, --max-buffer) that weren't in docs.

_arguments -s -S \
  '--fallback=[fall back to comparing against ref when no SHA available]:ref:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '::workspace package name:_default'
