#compdef cram
# Documentation: https://bitheap.org/cram/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# brodie/cram — cram/_main.py optparse (0.8+)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-q -i --interactive --debug)'{-q,--quiet}'[omit diffs]' \
  '(-q)'{-v,--verbose}'[show filenames and status]' \
  '(-q --debug)'{-i,--interactive}'[merge changed output with patch(1)]' \
  '(-q --interactive --verbose)'{-d,--debug}'[write script output to terminal]' \
  '(-n)'{-y,--yes}'[answer yes to merge prompts]' \
  '(-y)'{-n,--no}'[answer no to merge prompts]' \
  {-E,--preserve-env}'[do not reset common env vars]' \
  --keep-tmpdir'[keep temp directories]' \
  '--shell=[shell for tests]:shell:_files' \
  '--shell-opts=[extra shell arguments]:opts:' \
  '--indent=[heredoc indent spaces]:count:' \
  '--xunit-file=[write xUnit XML]:file:_files' \
  '(- *)'{-h,--help}'[usage]' \
  '*:Cram test file:_files' && ret=0

return ret
