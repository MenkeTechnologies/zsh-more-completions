#compdef dnsname
# _dnsname — djbdns dnsname (reverse-DNS lookup: print the PTR name for one or more IPv4 addresses)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from dnsname.c on tip.

_dnsname() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-n --new)'{-n,--new}'[new output style]' \
        '*:ip-address:'
}

_dnsname "$@"
