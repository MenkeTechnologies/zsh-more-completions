#compdef conduktor
# Documentation: https://man.archlinux.org/search?q=conduktor
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apply:deploy resources declaratively'
  'completion:generate shell completion'
  'delete:remove resources'
  'get:retrieve and list resources'
  'login:authenticate and get a JWT token'
  'run:execute actions on resources'
  'sql:SQL-related functionality'
  'template:get a YAML example for a kind'
  'token:manage API keys and tokens'
  'help:show help for a command'
  'version:show conduktor version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--permissive[allow undefined env vars]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'conduktor command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apply)
        _arguments \
          '*'{-f+,--file=}'[file or folder to apply]:file:_files' \
          '--dry-run[do not apply, just preview]' \
          '(-r --recursive)'{-r,--recursive}'[recurse into folders]' \
          '--parallelism=[max parallel applies]:n:' && ret=0 ;;
      (delete)
        _arguments \
          '*'{-f+,--file=}'[file or folder]:file:_files' \
          '(-r --recursive)'{-r,--recursive}'[recurse]' && ret=0 ;;
      (get)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml name)' \
          '*::resource:' && ret=0 ;;
      (run)
        local -a run_subs=(
          'generateServiceAccountToken:generate token for virtual cluster service account'
          'partnerZoneGenerateCredentials:generate token for partner zone service account'
          'whoami:show configured credentials info'
        )
        _describe -t rcmds 'run subcommand' run_subs && ret=0 ;;
      (template)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '*::kind:' && ret=0 ;;
      (token)
        local -a token_subs=(
          'create:create an API key'
          'list:list API keys'
          'delete:delete an API key'
        )
        _describe -t tcmds 'token subcommand' token_subs && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
