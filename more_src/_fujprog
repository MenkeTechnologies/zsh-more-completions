#compdef fujprog
# Documentation: https://github.com/kost/fujprog
# FPGA JTAG programmer for ULX2/3S boards

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-p[select USB JTAG / UART port]:port' \
  '-P[select TTY port (valid only with -t or -a)]:tty:_files' \
  '-T[select type of input]:type:(svf img bit jed)' \
  '-i[identify device and exit]' \
  '-j[select bitstream target]:target:(sram flash)' \
  '-f[start writing to SPI flash at ADDR]:addr' \
  '-s[convert bitstream to SVF file and exit]:file:_files' \
  '-r[reload FPGA configuration from flash]' \
  '-t[enter terminal emulation mode after JTAG]' \
  '-b[set baudrate]:speed' \
  '-e[send and execute an f32c binary file]:file:_files' \
  '-x[set binary transfer speed]:speed' \
  '-a[send a raw file]:file:_files' \
  '-d[enable debug/verbose output]' \
  '-D[delay each byte by ms]:delay' \
  '-V[display version information]' \
  '-z[force action]' \
  '-l[display messages in log fashion every X times]:x' \
  '-S[select FTDI device by serial number]:serial' \
  '-q[suppress console messages]' \
  '*:bitstream:_files' && ret=0

return ret
