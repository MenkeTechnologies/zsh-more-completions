#compdef bareos-btape
# Documentation: https://docs.bareos.org/Appendix/BareosPrograms.html
# Reference accessed: 2026-05-16
# Verified: Bareos docs Appendix - btape program reference.
# Removed from prior file: bogus man.archlinux.org search URL.

# bareos-btape: interactive tape-drive test tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '(-b --parse-bootstrap)'{-b+,--parse-bootstrap=}'[bootstrap file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[configuration file]:file:_files' \
  '(-D --director)'{-D+,--director=}'[specify director]:director:' \
  '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
  '(--dt --debug-timestamps)'{--dt,--debug-timestamps}'[print timestamps in debug output]' \
  '(-p --proceed-io)'{-p,--proceed-io}'[proceed despite IO errors]' \
  '(-s --no-signals)'{-s,--no-signals}'[disable signal handlers]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:tape device:_files' && ret=0
return ret
