#compdef cxl
# Documentation: man cxl(1)
# Source: pmem/ndctl cxl/cxl.c (main) — CXL device management (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'version:show cxl-cli version'
    'list:list CXL components'
    'help:show command help'
    'zero-labels:zero memdev label area'
    'read-labels:read memdev labels'
    'write-labels:write memdev labels'
    'disable-memdev:disable a memory device'
    'enable-memdev:enable a memory device'
    'reserve-dpa:reserve device-physical address'
    'free-dpa:free reserved DPA'
    'update-firmware:update memdev firmware'
    'set-alert-config:configure SMART alerts'
    'wait-sanitize:wait for sanitize to complete'
    'disable-port:disable a CXL port'
    'enable-port:enable a CXL port'
    'set-partition:set device partition'
    'disable-bus:disable a CXL bus'
    'create-region:create a new CXL region'
    'enable-region:enable a CXL region'
    'disable-region:disable a CXL region'
    'destroy-region:destroy a CXL region'
    'monitor:monitor CXL events'
    'inject-protocol-error:inject protocol error'
    'inject-media-poison:inject media poison'
    'clear-media-poison:clear media poison'
)

_arguments -s -C \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'cxl command' cmds && ret=0 ;;
esac

return ret
