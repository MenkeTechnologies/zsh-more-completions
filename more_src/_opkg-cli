#compdef opkg-cli opkg
# _opkg-cli — Yocto Project OpenEmbedded opkg-cli CLI command-line frontend wrapping the opkg lightweight package management system based on ipkg used by OpenWrt OpenEmbedded Yocto Project written in C originally Ian Pratt now Yocto Project resolves dependencies and runs maintainer scripts ipk format embedded Linux distributions LEDE update upgrade install configure remove flag info status download list list-installed list-upgradable list-changed-conffiles files search find depends whatdepends whatdependsrec whatprovides whatreplaces whatconflicts whatsuggests print-architecture cache clean clean-all (Yocto Project OpenEmbedded team Ian Pratt, C); custom argparse
# upstream: https://openwrt.org/docs/guide-user/additional-software/opkg

_opkg-cli() {
    local -a sub=(
        'update:update repository indexes'
        'upgrade:upgrade packages'
        'install:install packages'
        'configure:configure packages'
        'remove:remove packages'
        'flag:flag packages'
        'list:list available packages'
        'list-installed:list installed packages'
        'list-upgradable:list upgradable packages'
        'list-changed-conffiles:list changed conffiles'
        'files:list files of a package'
        'search:search for package containing file'
        'find:find packages'
        'info:show package info'
        'status:show package status'
        'download:download packages'
        'compare-versions:compare version strings'
        'print-architecture:print architectures'
        'depends:show package dependencies'
        'whatdepends:show what depends on package'
        'whatdependsrec:show recursive depends'
        'whatprovides:show what provides'
        'whatreplaces:show what replaces'
        'whatconflicts:show what conflicts'
        'whatsuggests:show what suggests'
        'whatrecommends:show what recommends'
        'clean:clean cache'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-A[query all]' \
        '-V+[verbosity]:n:' \
        '-d+[dest]:str:' \
        '--dest=+[name]:str:' \
        '-f+[config file]:file:_files -g "opkg.conf *.conf"' \
        '--conf=+[file]:file:_files -g "opkg.conf *.conf"' \
        '-o+[offline root]:dir:_files -/' \
        '--offline=+[dir]:dir:_files -/' \
        '--noaction[no action]' \
        '--download-only[download only]' \
        '--nodeps[no deps]' \
        '--strip-abi[strip ABI]' \
        '--force-depends[force depends]' \
        '--force-maintainer[force maintainer]' \
        '--force-reinstall[force reinstall]' \
        '--force-overwrite[force overwrite]' \
        '--force-downgrade[force downgrade]' \
        '--force-space[force space]' \
        '--force-postinstall[force postinstall]' \
        '--force-remove[force remove]' \
        '--force-checksum[force checksum]' \
        '--force-signature[force signature]' \
        '--no-check-certificate[no check cert]' \
        '--no-install-recommends[no install recommends]' \
        '--add-arch=+[arch:N]:str:' \
        '--add-dest=+[name:path]:str:' \
        '--add-exclude=+[name]:str:' \
        '--add-ignore-recommends=+[name]:str:' \
        '--prefer-arch-to-version[prefer arch to version]' \
        '--add-list=+[name]:str:' \
        '--cache=+[dir]:dir:_files -/' \
        '--lists-dir=+[dir]:dir:_files -/' \
        '--volatile-cache[volatile cache]' \
        '--combine[combine ops]' \
        '--size[show size]' \
        '--exclude-installed[exclude installed]' \
        '--available[show available]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opkg subcommand' sub ;;
        args) _arguments '*:package:' ;;
    esac
}

_opkg-cli "$@"
