#compdef seqxref
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/seqxref.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS seqxref: retrieve sequence cross-reference data from drcat
# and produce a report of the database/identifier pairs.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-xrefoutfile=[xref report output file]:file:_files' \
  '-rxformat=[xref report format]:format:(drcat list text excel feattable gff3 listfile pir simple swiss tagseq)' \
  '*:sequence USA:_files' && ret=0

return ret
