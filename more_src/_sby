#compdef sby
# Documentation: https://symbiyosys.readthedocs.io/en/latest/
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d+[set work directory]:directory:_files -/' \
  '-f[remove work directory if it already exists]' \
  '-b+[backup work directory]:backup directory:_files -/' \
  '-t[add timestamps to log output]' \
  '--prefix=[filename prefix for output]:prefix:' \
  '--setup[run in setup mode only]' \
  '--execute[run in execute mode only]' \
  '*-T+[specify task name]:task name:' \
  '--status[print task status]' \
  '--dumpcfg[dump configuration]' \
  '--dumptasks[dump task list]' \
  '--dumpfiles[dump file list]' \
  '--dumpdefaults[dump default settings]' \
  '--init-config-file=[create example configuration file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:job file:_files -g "*.sby"' && ret=0

return ret
