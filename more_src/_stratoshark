#compdef stratoshark
# Documentation: https://www.wireshark.org/docs/man-pages/stratoshark.html
# Reference accessed: 2026-05-17
# Verified: wireshark.org stratoshark(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --time-stamp-type/--list-time-stamp-types (these are
# Wireshark capture flags, not Stratoshark — Stratoshark targets
# system calls not packets).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r+[read capture file]:file:_files -g "*.scap"' \
  '-i+[interface to capture from]:iface:' \
  '-w+[write to file]:file:_files' \
  '-Y+[display filter]:filter:' \
  '-f+[capture filter]:filter:' \
  '-c+[stop after N packets]:count:' \
  '-a+[autostop condition]:condition:(duration\: filesize\: files\:)' \
  '-b+[ringbuffer condition]:condition:(duration\: filesize\: files\: interval\:)' \
  '-s+[snapshot length]:bytes:' \
  '-D[print interface list]' \
  '-L[print supported link layer types]' \
  '-k[start capture immediately]' \
  '-Q[quit after capture]' \
  '-S[update list of packets in real time]' \
  '-l[turn on auto-scroll on packet capture]' \
  '-o+[override preference]:pref=value:' \
  '-X+[extension option]:opt:' \
  '--time-stamp-type=[set timestamp type]:type:' \
  '--list-time-stamp-types[list timestamp types]' \
  '*:file:_files -g "*.scap"' && ret=0

return ret
