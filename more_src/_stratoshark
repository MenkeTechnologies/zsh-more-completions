#compdef stratoshark
# Documentation: https://www.wireshark.org/docs/man-pages/stratoshark.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --read-file)'{-r,--read-file=}'[read capture file]:file:_files -g "*.scap"' \
  '(-R --read-filter)'{-R,--read-filter=}'[display filter applied when reading file]:filter:' \
  '(-i --source)'{-i,--source=}'[capture source or pipe]:source:' \
  '-w+[write to file]:file:_files' \
  '(-Y --display-filter)'{-Y,--display-filter=}'[initial display filter]:filter:' \
  '-f+[capture filter expression]:filter:' \
  '-c+[stop after N events]:count:' \
  '(-a --autostop)*'{-a,--autostop=}'[autostop condition]:condition:' \
  '(-b --ring-buffer)*'{-b,--ring-buffer=}'[ringbuffer condition]:condition:' \
  '-C+[start with configuration profile]:profile:' \
  '(-D --list-sources)'{-D,--list-sources}'[list available capture sources]' \
  '(-L --list-data-link-types)'{-L,--list-data-link-types}'[list supported data link types]' \
  '-k[start capture immediately]' \
  '-S[update event display in real time]' \
  '-l[turn on auto-scroll on capture]' \
  '-g+[jump to event number]:event:' \
  '-J+[jump to event matching filter]:filter:' \
  '-j[search before with -J]' \
  '-H[hide capture info dialog]' \
  '-o+[override preference]:pref=value:' \
  '-P+[path setting]:setting:' \
  '*-X+[extension option]:opt:' \
  '-z+[collect statistics]:statistic:' \
  '-d+[decode as protocol]:proto:' \
  '--disable-all-protocols[disable all protocol dissection]' \
  '*--disable-protocol=[disable specific protocols]:proto:' \
  '*--enable-protocol=[enable specific protocols]:proto:' \
  '*--disable-heuristic=[disable heuristic dissector]:proto:' \
  '*--enable-heuristic=[enable heuristic dissector]:proto:' \
  '--only-protocols=[enable only specific protocols]:proto:' \
  '-K+[Kerberos keytab file]:file:_files' \
  '-n[disable network object name resolution]' \
  '-N+[enable name resolution types]:types:' \
  '-t+[timestamp display format]:format:' \
  '-u+[relative time display format]:format:(s hms)' \
  '--capture-comment=[add capture comment]:comment:' \
  '--display=[X display]:display:' \
  '--fullscreen[start in fullscreen]' \
  '--temp-dir=[temporary directory]:dir:_directories' \
  '--time-stamp-type=[set timestamp method]:type:' \
  '--update-interval=[event report interval]:ms:' \
  '--list-time-stamp-types[list timestamp types]' \
  '--log-level=[set active log level]:level:' \
  '--log-fatal=[set fatal log level]:level:' \
  '--log-domains=[filter by log domains]:domains:' \
  '--log-debug=[force debug level for domains]:domains:' \
  '--log-noisy=[force noisy level for domains]:domains:' \
  '--log-fatal-domains=[abort on specific domains]:domains:' \
  '--log-file=[write logs to file]:file:_files' \
  '*:file:_files -g "*.scap"' && ret=0

return ret
