        '(--quantisationTable --quantizationTable)'{--quantisationTable,--quantizationTable}'=[JPEG quantisation table]:table:' \
        '(--reuse --reoptimise --reoptimize)'{--reuse,--reoptimise,--reoptimize}'[GIF regenerate palettes (slow)]' \
        '--resolutionUnit=[resolution unit (default inch)]:unit:(cm inch)' \
        '--smartDeblock[WebP smart deblock filter]' \
        '--smartSubsample[WebP smart chroma subsampling]' \
        '--tileBackground=[tile background colour]:rgba:' \
        '--tileHeight=[TIFF vertical tile size]:pixels:' \
        '--tileWidth=[TIFF horizontal tile size]:pixels:' \
        '--trellisQuantisation[apply JPEG trellis quantisation]' \
        '--xres=[TIFF horizontal resolution]:dpi:' \
        '--yres=[TIFF vertical resolution]:dpi:' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'sharp subcommand' subcmds && ret=0
            ;;
        args)
            ret=0
            ;;
    esac
    return ret
}

_sharp "$@"
