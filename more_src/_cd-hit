#compdef cd-hit
# _cd-hit — Weizhong Li cd-hit CLI ultra-fast protein sequence clustering tool removing redundancy at chosen identity threshold producing representative clusters greedy incremental short-word filter heuristic for downstream BLAST search reduction Swiss-Prot UniRef NCBI nr collection deduplication (Weizhong Li team, C++); getopt
# upstream: https://github.com/weizhongli/cdhit

_cd-hit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-i+[input fasta]:file:_files -g "*.fa *.fasta *.faa"' \
        '-o+[output prefix]:str:' \
        '-c+[identity threshold]:n:' \
        '-G+[global identity]:n:(0 1)' \
        '-b+[band width]:n:' \
        '-M+[memory MB]:n:' \
        '-T+[threads]:n:' \
        '-n+[word size]:n:(2 3 4 5)' \
        '-l+[max length difference]:n:' \
        '-t+[tolerance redundance]:n:' \
        '-d+[length description]:n:' \
        '-s+[length difference cutoff]:n:' \
        '-S+[length difference cutoff in aa]:n:' \
        '-aL+[align coverage long]:n:' \
        '-AL+[align coverage long aa]:n:' \
        '-aS+[align coverage short]:n:' \
        '-AS+[align coverage short aa]:n:' \
        '-A+[min align region]:n:' \
        '-uL+[max unmatched long]:n:' \
        '-uS+[max unmatched short]:n:' \
        '-U+[max unmatched]:n:' \
        '-B+[long input on disk]:n:(0 1)' \
        '-g+[accurate but slow mode]:n:(0 1)' \
        '-p+[print alignments]:n:(0 1)' \
        '-mask+[mask letters]:str:' \
        '*::'
}

_cd-hit "$@"
