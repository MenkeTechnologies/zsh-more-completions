#compdef stepci
# Documentation: https://docs.stepci.com/reference/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_stepci_commands() {
  local -a commands=(
    'run:Execute a workflow file'
    'generate:Generate a workflow from an OpenAPI spec'
    'init:Initialize a new workflow file'
  )
  _describe 'command' commands
}

_stepci() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(--help)--help[Display help]' \
    '(--version)--version[Show installed version]' \
    '1:command:_stepci_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        run)
          _arguments \
            '1:workflow file:_files -g "*.(yml|yaml|json|js)"' \
            '*'{-e,--env}'[Pass environment variables]:env var:' \
            '*'{-s,--secret}'[Pass secret variables]:secret var:' \
            '(-v --verbose)'{-v,--verbose}'[Display all requests/responses]' \
            '(-load --loadtest)'{-load,--loadtest}'[Enable load-testing mode]' \
            '--concurrency[Set concurrency level]:concurrency:'
          ;;
        generate)
          _arguments \
            '1:OpenAPI spec:_files -g "*.(yml|yaml|json)"' \
            '2:output path:_files'
          ;;
        init)
          _arguments \
            '1:path:_files'
          ;;
      esac
      ;;
  esac
}

_stepci "$@"
