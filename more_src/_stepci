#compdef stepci
# _stepci — Step CI API testing and monitoring (stepci/stepci)
# upstream: https://github.com/stepci/stepci

_stepci() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_stepci_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(-e --env)'{-e,--env}'=[environment variables file]:file:_files' \
                        '(-s --secret)'{-s,--secret}'=[secrets file]:file:_files' \
                        '--loadtest[run as load test]' \
                        '--concurrency=[concurrent workers]:count:' \
                        '--iterations=[number of iterations]:count:' \
                        '--duration=[test duration]:duration:' \
                        '--verbose[verbose output]' \
                        '--help[show help]' \
                        '1:workflow file:_files -g "*.yml(|.yaml)"' && ret=0 ;;
                generate)
                    _arguments \
                        '--help[show help]' \
                        '1:spec file:_files -g "*.(json|yml|yaml)"' && ret=0 ;;
                init)
                    _arguments \
                        '--help[show help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_stepci_commands] )) ||
_stepci_commands() {
    local -a commands
    commands=(
        'run:run a test workflow'
        'generate:generate a workflow from OpenAPI spec'
        'init:initialize a new workflow'
    )
    _describe -t commands 'stepci command' commands
}

_stepci "$@"
