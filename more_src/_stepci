#compdef stepci

_stepci_commands() {
  local -a commands=(
    'run:Run a workflow'
    'generate:Generate a workflow from an OpenAPI spec'
    'init:Initialize a new workflow'
  )
  _describe 'command' commands
}

_stepci() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '1:command:_stepci_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        run)
          _arguments \
            '1:workflow file:_files -g "*.yml *.yaml"' \
            '--env[Environment variables file]:env file:_files' \
            '--secret[Secret variables file]:secret file:_files' \
            '--loadtest[Run as load test]' \
            '--verbose[Verbose output]' \
            '*:extra args:'
          ;;
        generate)
          _arguments \
            '1:OpenAPI spec:_files -g "*.yml *.yaml *.json"' \
            '--output[Output file]:output file:_files' \
            '--path[Filter by path]:path:' \
            '--method[Filter by method]:method:(get post put patch delete)' \
          ;;
        init)
          _arguments \
            '--template[Template to use]:template:'
          ;;
      esac
      ;;
  esac
}

_stepci "$@"
