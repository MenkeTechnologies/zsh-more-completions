#compdef typedb-console
# Documentation: https://typedb.com/docs/tools/console/
# TypeDB Console - command-line client for TypeDB

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '--address=[server address (IP:port) to connect to]:address' \
  '--username=[user name for authentication]:username' \
  '--password=[password for authentication]:password' \
  '--tls-disabled[disable TLS encryption for connections]' \
  '--tls-root-ca=[path to the TLS root CA file]:ca:_files' \
  '*--command=[execute a command without entering interactive mode]:command' \
  '--script=[script with commands to run, without interactive mode]:script:_files' \
  '--diagnostics-disable=[disable anonymous error reporting]:flag:(true false)' && ret=0

return ret
