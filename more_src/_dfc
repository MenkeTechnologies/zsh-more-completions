#compdef dfc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '-a[show all filesystems]' \
  '-b[do not show the gauge bar]' \
  '-c+[choose color mode]:color mode:(always auto never)' \
  '-d+[export to specified format]:format' \
  '-e[display size in SI units (powers of 1000)]' \
  '-f[show filesystem type]' \
  '-i[show inodes information]' \
  '-l[only show local filesystems]' \
  '-m+[max width of mount point column]:width' \
  '-M+[max width of filesystem name column]:width' \
  '-n[do not show header]' \
  '-o+[display options]:option:(header bar fslabel)' \
  '-p+[filter by filesystem type]:filesystem type' \
  '-q+[sort by column]:column' \
  '-s[show sum of total usage]' \
  '-t+[filter by mount point]:mount point:_directories' \
  '-T[do not show total]' \
  '-u+[unit to use]:unit:(h H k m g t p e)' \
  '-w[use wider columns]' \
  '-W[wide output (no column width limit)]' \
  && ret=0

return ret
