#compdef stwolame
# Documentation: https://github.com/njh/twolame/blob/master/simplefrontend/simplefrontend.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# stwolame: simple twolame frontend. Usage: stwolame <input wavefile> <output mp2 file>

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input WAV:_files -g "*.wav"' \
  '2:output MP2:_files -g "*.mp2"' && ret=0

return ret
