#compdef archey3

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(--version)--version[show version and exit]' \
  '(-c --color)'{-c,--color}'[change header color (0-7)]:color index:(0 1 2 3 4 5 6 7)' \
  '(--config)--config[specify config file]:config file:_files' \
  '(-d --distribution)'{-d,--distribution}'[manually set distribution]' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-s --screenshot)'{-s,--screenshot}'[take a screenshot after displaying]' \
  '(--no-color)--no-color[disable colored output]' \
  '(--logos-list)--logos-list[list available logos]' \
  && ret=0

return ret
