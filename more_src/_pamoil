#compdef pamoil
# Documentation: man pamoil (Netpbm)
# Source: Netpbm pamoil — turn a PAM image into an oil painting (mode-filter smearing).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-n+[neighborhood size (pixels in each of 4 directions)]:N:' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
