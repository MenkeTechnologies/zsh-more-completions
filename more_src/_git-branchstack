#compdef git-branchstack
# Documentation: https://github.com/krobelus/git-branchstack
# git branchstack — create topic branches from tagged commits without leaving your branch.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[overwrite branches even if modified since last run]' \
  '(-k --keep-tags)'{-k+,--keep-tags=}'[keep topic tag on created commits]:scope:(dependencies all)' \
  '(-r --range)'{-r+,--range=}'[use commits from the given range instead of @{upstream}..]:range:' \
  '*:topic:' && ret=0

return ret
