#compdef aiomixer
# Documentation: man aiomixer(1)
# Source: netbsd/src usr.bin/aiomixer — curses mixer frontend (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[alternative mixer device]:device:_files' \
    '-u[unlock channels at startup]' \
    && ret=0

return ret
