#compdef fantomas

# Zsh completion for fantomas - F# source code formatter

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show fantomas version]'
  '--recurse[process files recursively]'
  '--force[print the output even if it is not valid F# code]'
  '--check[check if the source files need formatting]'
  '--verbosity[verbosity level]:level:(n normal d detailed)'
  '--parallel[format files in parallel]'
  '--out[output file or directory]:path:_files'
  '--stdin[format F# code from standard input]'
  '--stdout[write output to standard output]'
  '--profile[print performance profiling]'
  '*:path:_files -g "*.(fs|fsi|fsx)"'
)

_arguments -s $arguments
