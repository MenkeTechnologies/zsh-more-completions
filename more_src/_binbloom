#compdef binbloom
# Documentation: https://github.com/quarkslab/binbloom
# Reference accessed: 2026-05-30
# binbloom — Quarkslab's raw-firmware analyzer. Auto-detects endianness and
# the loading base address of an unstructured firmware blob (no ELF/PE headers
# present). Used in reverse-engineering of embedded firmware before loading
# into Ghidra/IDA.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-a+[architecture word size (default 32)]:bits:(32 64)' \
  '-e+[force endianness (skip auto-detect)]:endian:(le be)' \
  '-b+[supplied base address (skip auto-detect)]:hex-address:' \
  '-t+[thread count for parallel address search]:N:' \
  '-d[enable deep search (slower; finds rare-case addresses)]' \
  '*-v[increase verbosity (repeatable)]' \
  '1:firmware blob:_files' \
  && ret=0

return ret
