#compdef poetry

# Zsh completion for Poetry - Python dependency management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'about:show information about Poetry'
  'add:add a new dependency'
  'build:build the project'
  'cache:manage caches'
  'check:check the validity of pyproject.toml'
  'config:manage configuration settings'
  'env:manage environments'
  'export:export the lock file to other formats'
  'help:show help for a command'
  'init:create a pyproject.toml interactively'
  'install:install the project dependencies'
  'list:list available commands'
  'lock:lock the project dependencies'
  'new:create a new Python project'
  'publish:publish the package to a remote repository'
  'remove:remove a dependency'
  'run:run a command in the project environment'
  'search:search for packages on PyPI'
  'self:manage Poetry itself'
  'shell:spawn a shell within the virtual environment'
  'show:show package information'
  'source:manage sources'
  'update:update dependencies'
  'version:show or bump the project version'
)

_arguments -s -S \
  '(-q --quiet)'{-q,--quiet}'[do not output any message]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '(-n --no-interaction)'{-n,--no-interaction}'[do not ask interactive questions]' \
  '--no-plugins[disable plugins]' \
  '--no-cache[disable cache]' \
  '(-C --directory)'{-C+,--directory=}'[working directory]:directory:_files -/' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'poetry command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      add)
        _arguments \
          '(-D --dev)'{-D,--dev}'[add as development dependency]' \
          '(-G --group)'{-G+,--group=}'[add to a dependency group]:group:' \
          '(-e --editable)'{-e,--editable}'[add as editable]' \
          '--extras=[extras to activate]:extras:' \
          '--optional[add as optional]' \
          '--python=[Python version constraint]:version:' \
          '--platform=[platforms]:platforms:' \
          '--source=[source to use]:source:' \
          '--allow-prereleases[accept prerelease versions]' \
          '--dry-run[output operations without executing]' \
          '--lock[only update the lock file]' \
          '*:packages:'
        ;;
      install)
        _arguments \
          '--without=[exclude dependency groups]:groups:' \
          '--with=[include dependency groups]:groups:' \
          '--only=[only install specific groups]:groups:' \
          '--no-dev[do not install dev dependencies]' \
          '--no-root[do not install the root package]' \
          '--no-directory[do not install directory dependencies]' \
          '--dry-run[output operations without executing]' \
          '--extras=[extras to install]:extras:' \
          '--all-extras[install all extras]' \
          '--sync[synchronize the environment]' \
          '(-E --extras)'{-E+,--extras=}'[extras to install]:extras:' \
          '--compile[compile Python source files to bytecode]'
        ;;
      remove)
        _arguments \
          '(-D --dev)'{-D,--dev}'[remove from development dependencies]' \
          '(-G --group)'{-G+,--group=}'[remove from a dependency group]:group:' \
          '--dry-run[output operations without executing]' \
          '--lock[only update the lock file]' \
          '*:packages:'
        ;;
      update)
        _arguments \
          '--without=[exclude dependency groups]:groups:' \
          '--with=[include dependency groups]:groups:' \
          '--only=[only update specific groups]:groups:' \
          '--dry-run[output operations without executing]' \
          '--lock[only update the lock file]' \
          '*:packages:'
        ;;
      show)
        _arguments \
          '--without=[exclude dependency groups]:groups:' \
          '--with=[include dependency groups]:groups:' \
          '--only=[only show specific groups]:groups:' \
          '--no-dev[do not show dev dependencies]' \
          '(-l --latest)'{-l,--latest}'[show latest version]' \
          '(-o --outdated)'{-o,--outdated}'[show outdated packages]' \
          '(-a --all)'{-a,--all}'[show all packages]' \
          '(-t --tree)'{-t,--tree}'[list as a tree]' \
          '--top-level[show only top-level dependencies]' \
          '1:package:'
        ;;
      run)
        _arguments '*:command:_command_names -e'
        ;;
      build)
        _arguments \
          '(-f --format)'{-f+,--format=}'[build format]:format:(sdist wheel)' \
          '(-o --output)'{-o+,--output=}'[output directory]:directory:_files -/'
        ;;
      publish)
        _arguments \
          '(-r --repository)'{-r+,--repository=}'[repository]:repository:' \
          '(-u --username)'{-u+,--username=}'[username]:username:' \
          '(-p --password)'{-p+,--password=}'[password]:password:' \
          '--cert=[CA bundle]:cert file:_files' \
          '--client-cert=[client certificate]:cert file:_files' \
          '--build[build before publishing]' \
          '--dry-run[perform a dry run]' \
          '--skip-existing[skip already published packages]'
        ;;
      version)
        _arguments \
          '(-s --short)'{-s,--short}'[short version output]' \
          '--dry-run[do not update pyproject.toml]' \
          '--next-phase[increment the release phase]' \
          '1:version rule:(patch minor major prepatch preminor premajor prerelease)'
        ;;
      config)
        _arguments \
          '--list[list configuration]' \
          '--unset[unset configuration]' \
          '--local[set for local project only]' \
          '1:key:' \
          '2:value:'
        ;;
      env)
        local -a env_cmds=(
          'info:display information about the current environment'
          'list:list all virtual environments'
          'remove:remove virtual environments'
          'use:activate or create a virtual environment'
        )
        _describe -t commands 'env command' env_cmds && ret=0
        ;;
      source)
        local -a source_cmds=(
          'add:add a new source'
          'remove:remove a source'
          'show:show configured sources'
        )
        _describe -t commands 'source command' source_cmds && ret=0
        ;;
      self)
        local -a self_cmds=(
          'add:add a Poetry plugin'
          'install:install Poetry plugins'
          'lock:lock Poetry dependencies'
          'remove:remove a Poetry plugin'
          'show:show Poetry plugins'
          'update:update Poetry'
        )
        _describe -t commands 'self command' self_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
