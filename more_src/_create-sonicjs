#compdef create-sonicjs
# Documentation: https://www.npmjs.com/package/create-sonicjs
# Reference accessed: 2026-05-24
# Verified: npm view create-sonicjs bin; npm readme Command Line Options section.

# Zsh completion for create-sonicjs - SonicJS Cloudflare CMS scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--template=[CMS template]:template:(starter)' \
  '--database=[D1 database name]:name:' \
  '--bucket=[R2 bucket name]:name:' \
  '--include-example[include example blog collection]' \
  '--skip-example[skip example blog collection]' \
  '--skip-install[do not install dependencies]' \
  '--skip-git[do not initialize git]' \
  '--skip-cloudflare[skip Cloudflare resource creation prompts]' \
  ':project name:' && ret=0

return ret
