#compdef age-plugin-fido2-hmac
# Documentation: source-direct extraction from upstream
# olastor/age-plugin-fido2-hmac cmd/age-plugin-fido2-hmac/
# main.go —
#   USAGE const at lines 86-119 (the 3 invocation patterns +
#     flag table + ENV var documentation)
#   main() at lines 121-165 (the flag declarations + parse +
#     dispatch)
#   identityToRecipient flow at lines 11-84 (the -y verb's
#     implementation)
# Reference accessed: 2026-05-30 via gh api.
#
# age-plugin-fido2-hmac is the **FIDO2 hmac-secret extension
# age plugin** — uses a hardware FIDO2 token (YubiKey 5,
# SoloKey 2, NitroKey 3, etc.) to encrypt/decrypt age payloads
# via the hmac-secret extension with non-discoverable
# credentials.  The token must be PHYSICALLY PRESENT for every
# encrypt+decrypt operation, providing strong defense against
# remote attackers stealing keys.  Sister to the existing
# _age-plugin-yubikey (PIV-based; YubiKey-only) in the corpus,
# but supports a wider range of FIDO2 tokens.
#
# Critical extraction note: like R227's ssh-tpm-* family,
# age-plugin-fido2-hmac uses **Go's standard `flag` package**
# (NOT cobra/argh/cmdr/clap).  All 9 unique options are
# registered via TWO flag calls each (short + long form):
#   pluginFlag           --age-plugin              (hidden;
#                                                   called by
#                                                   age client)
#   algorithmFlag        -a / --algorithm
#   generateFlag         -g / --generate (also -n)
#   deprecatedMagicFlag  -m / --magic-identity (DEPRECATED)
#   symmetricFlag        -s / --symmetric
#   postQuantumFlag      -pq / --post-quantum
#   identityToRecipient  -y FILE
#   versionFlag          -v / --version
#   helpFlag             -h / --help
#
# Critical extraction note: the `--age-plugin STATE_MACHINE`
# flag is INVOKED BY age ITSELF (the main `age` binary) when
# a user specifies `age --plugin fido2-hmac` — NOT directly by
# the user.  This is the **standard age-plugin protocol**
# established by str4d/age — every age plugin must accept
# `--age-plugin STATE_MACHINE` and dispatch to a state-machine
# run loop.  Completion documents this in the description but
# doesn't recommend users invoke it directly.
#
# Critical extraction note: the `-g`/`--generate` flag has an
# UNDOCUMENTED short-only alias `-n` at main.go:143
# (`flag.BoolVar(&generateFlag, "n", false, "")`).  Likely a
# vestige of a previous version's "new identity" naming.
# Completion lists it as well for forward compatibility.
#
# Critical extraction note: the `-m`/`--magic-identity` flag
# is marked as `deprecatedMagicFlag` at main.go:145 — kept for
# backward compatibility but should not be used in new
# scripts.  Documented in the completion description.
#
# Critical extraction note: 2 environment variables documented
# in USAGE block (lines 111-119):
#   FIDO2_TOKEN     — force a specific device path (e.g.
#                     /dev/hidraw0); NOT RECOMMENDED since
#                     /dev/hid* paths are ephemeral
#   FIDO2_HMAC_PQ   — force post-quantum mode (1/true/yes) or
#                     disable (0/false/no); interactive prompt
#                     if not set

local -a algorithms=(
  'es256:ES256 / ECDSA-P256 (default)'
  'eddsa:Ed25519 / EdDSA'
  'rs256:RS256 / RSA-2048'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-g --generate -n)'{-g,--generate}'[generate new credentials interactively (the primary workflow)]' \
  '(-g --generate -n)-n[short-only alias for --generate (undocumented vestige)]' \
  '(-s --symmetric)'{-s,--symmetric}'[symmetric encryption with new salt per encryption (token required for every op)]' \
  '(-pq --post-quantum)'{-pq,--post-quantum}'[use post-quantum MLKEM768-X25519 hybrid encryption instead of X25519]' \
  '(-a --algorithm)'{-a+,--algorithm=}'[FIDO2 credential algorithm (default es256)]:alg:(es256 eddsa rs256)' \
  '-y+[read identity FILE and output corresponding recipient(s); "-" for stdin]:file:_files' \
  '(-m --magic-identity)'{-m,--magic-identity}'[DEPRECATED: print the magic identity for no-identity-required mode]' \
  '--age-plugin=[plugin state machine (called by age itself; users should NOT invoke directly)]:state-machine:'
