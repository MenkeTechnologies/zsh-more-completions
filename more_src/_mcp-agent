#compdef mcp-agent mcpc mcp-cloud silsila
# Documentation: https://docs.mcp-agent.com/reference/cli
# Reference accessed: 2026-05-22
# Verified: mcp-agent --help and subcommand help (mcp-agent 0.x Typer CLI).

# Zsh completion for mcp-agent - MCP Agent framework and cloud CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '--format[output format]:format:(text json)' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mcp-agent command' \
      'init[scaffold mcp-agent project]' \
      'login[authenticate to MCP Agent Cloud]' \
      'deploy[deploy MCP agent]' \
      'install[install MCP server to clients]' \
      'config[manage configuration]' \
      'doctor[run diagnostics]' \
      'dev[local development and runtime]' \
      'cloud[MCP Agent Cloud commands]' && ret=0
    ;;
  args)
    case $line[1] in
      cloud)
        if (( CURRENT == 2 )); then
          _values 'cloud command' \
            'configure[configure MCP app]' \
            'deploy[deploy MCP agent]' \
            'login[authenticate to cloud API]' \
            'whoami[print identity and orgs]' \
            'logout[clear credentials]' \
            'apps[manage MCP app]' \
            'servers[manage MCP servers]' \
            'auth[authentication commands]' \
            'logger[logging and observability]' \
            'workflows[workflow management]' \
            'env[manage environment variables]' && ret=0
        fi
        ;;
      dev)
        if (( CURRENT == 2 )); then
          _values 'dev command' \
            'start[run app locally with reload]' \
            'chat[ephemeral REPL]' \
            'invoke[invoke agent or workflow]' \
            'serve[serve app as MCP server]' \
            'server[local server helpers]' \
            'build[preflight and bundle for deploy]' \
            'logs[tail local logs]' \
            'check[check configuration]' \
            'go[quick interactive agent]' \
            'keys[manage provider API keys]' \
            'models[list and manage models]' \
            'client[client integration helpers]' && ret=0
        fi
        ;;
      config)
        if (( CURRENT == 2 )); then
          _values 'config command' \
            'show[display config or secrets]' \
            'check[check configuration status]' \
            'edit[open config in editor]' \
            'builder[interactive config builder]' \
            'validate[validate config against schema]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
