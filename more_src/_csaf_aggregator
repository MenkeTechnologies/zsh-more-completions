#compdef csaf_aggregator csaf_checker csaf_downloader csaf_provider csaf_uploader csaf_validator
# ============================================================================
# gocsaf/csaf tools - CSAF (Common Security Advisory Framework) toolkit (Go, Apache-2.0)
#
# Author : German Federal Office for Information Security (BSI) / Intevation
# Upstream: https://github.com/gocsaf/csaf
#
# Six related Go binaries that implement OASIS CSAF 2.0 (Common Security
# Advisory Framework) tooling - a standardized JSON document format for
# distributing machine-readable security advisories between vendors and
# downstream consumers. The toolkit covers the full advisory lifecycle:
#
#   csaf_provider   - HTTP service that hosts CSAF advisories from a
#                     vendor (RFC 9116-style provider-metadata.json
#                     + canonical URL layout per CSAF 2.0 sec 7.1)
#   csaf_uploader   - upload CSAF JSON to a provider; sign with OpenPGP
#   csaf_downloader - pull CSAF advisories from upstream providers
#                     (single domain or aggregator-listed federation)
#   csaf_aggregator - lister/aggregator (full + interim modes); rolls
#                     up upstream provider catalogs into one feed
#   csaf_checker    - audit a provider's RFC 9116 + CSAF 2.0 compliance
#                     (TLS / provider-metadata / signing / hashing)
#   csaf_validator  - validate local CSAF JSON against the schema, with
#                     optional remote validator backend for "presets"
#
# The JSON-Schema validation lane is built on `github.com/santhosh-tekuri/jsonschema/v6 v6.0.2`,
# verified verbatim against go.mod on HEAD. Per the CSAF 2.0 spec, all
# valid advisories must conform to the JSON Schema published by OASIS
# at https://docs.oasis-open.org/csaf/csaf/v2.0/csaf_json_schema.json,
# and these tools (especially csaf_validator and csaf_provider) enforce
# that schema locally before any document is accepted, transmitted, or
# stored. santhosh-tekuri/jsonschema is the canonical Go validator
# library (Draft 4 - 2020-12).
#
# ----------------------------------------------------------------------------
# AXIS 197 :: JSON SCHEMA VALIDATION (DRAFT 4 - 2020-12)
# Round 1290 :: Go slot 2 of 4 :: continues Axis 197
#
# Cross-language canonical library family for this axis:
#   Rust    : Stranger6667/jsonschema     [R1289 _ironclaw]
#   Go      : santhosh-tekuri/jsonschema  [R1290 THIS FILE]
#   TS/Node : ajv-validator/ajv           [R1291 closing]
#
# Of the three lanes, the Go library here pulls in the cleanest external
# dependency story - it has no transitive C deps and is self-contained.
# CSAF tooling is also an unusually pure consumer: the CSAF 2.0 spec
# is itself a JSON Schema, the documents-in-flight are JSON, and the
# validation step IS the load-bearing operation of the toolchain. This
# is the "spec drives schema" usage pattern at its purest.
# ============================================================================

_csaf_aggregator() {
    local context state state_descr line
    typeset -A opt_args

    case "$service" in
        csaf_aggregator)  _csaf_aggregator_args ;;
        csaf_checker)     _csaf_checker_args ;;
        csaf_downloader)  _csaf_downloader_args ;;
        csaf_provider)    _csaf_provider_args ;;
        csaf_uploader)    _csaf_uploader_args ;;
        csaf_validator)   _csaf_validator_args ;;
    esac
}

_csaf_aggregator_args() {
    _arguments -s -S \
        '(-c --config)'{-c,--config}'[path to config TOML file]:file:_files -g "*.toml"' \
        '(-i --interim)'{-i,--interim}'[perform an interim scan rather than a full one]' \
        '--version[display version and exit]' \
        '(- *)'{-h,--help}'[print help]'
}

_csaf_checker() { _csaf_checker_args; }
_csaf_checker_args() {
    _arguments -s -S \
        '(-o --output)'{-o,--output}'[file name of the generated report]:report file:_files' \
        '(-f --format)'{-f,--format}'[format of report]:format:(json html)' \
        '--insecure[do not check TLS certificates from provider]' \
        '--client_cert[TLS client certificate file (PEM)]:cert file:_files -g "*.(crt|pem)"' \
        '--client_key[TLS client private key file (PEM)]:key file:_files -g "*.(key|pem)"' \
        '--client_passphrase[passphrase for the client cert (experimental)]:passphrase:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-r --rate)'{-r,--rate}'[upper limit of HTTPS ops per second]:rate:' \
        '(-t --time_range)'{-t,--time_range}'[time RANGE of advisories to download]:range:' \
        '*'{-i,--ignore_pattern}'[skip download if URL matches PATTERN]:pattern:' \
        '*'{-H,--header}'[extra HTTP header field]:header:' \
        '--validator[URL to validate documents remotely]:url:' \
        '--validator_cache[FILE to cache remote validations]:file:_files' \
        '*--validator_preset[remote validator preset]:preset:' \
        '(-c --config)'{-c,--config}'[path to config TOML file]:file:_files -g "*.toml"' \
        '--version[display version and exit]' \
        '(- *)'{-h,--help}'[print help]' \
        '*:domain or url:'
}

_csaf_downloader() { _csaf_downloader_args; }
_csaf_downloader_args() {
    _arguments -s -S \
        '(-d --directory)'{-d,--directory}'[directory to store downloaded files]:directory:_files -/' \
        '--insecure[do not check TLS certificates from provider]' \
        '--ignore_sigcheck[ignore signature check results; warn on mismatch]' \
        '--client_cert[TLS client certificate (PEM)]:cert:_files -g "*.(crt|pem)"' \
        '--client_key[TLS client private key (PEM)]:key:_files -g "*.(key|pem)"' \
        '--client_passphrase[passphrase for the client cert]:passphrase:' \
        '--version[display version and exit]' \
        '(-n --no_store)'{-n,--no_store}'[do not store downloaded files]' \
        '(-r --rate)'{-r,--rate}'[upper limit of HTTPS ops per second]:rate:' \
        '(-w --worker)'{-w,--worker}'[number of concurrent downloads]:number:' \
        '(-t --time_range)'{-t,--time_range}'[time RANGE of advisories to download]:range:' \
        '(-f --folder)'{-f,--folder}'[download into a given subfolder]:folder:' \
        '*'{-i,--ignore_pattern}'[skip download if URL matches PATTERN]:pattern:' \
        '*'{-H,--header}'[extra HTTP header field]:header:' \
        '--enumerate_pmd_only[enumerate provider-metadata only; skip downloads]' \
        '--validator[URL to validate documents remotely]:url:' \
        '--validator_cache[FILE to cache remote validations]:file:_files' \
        '*--validator_preset[remote validator preset]:preset:' \
        '(-m --validation_mode)'{-m,--validation_mode}'[how strict to validate]:mode:(strict unsafe)' \
        '--forward_url[HTTP endpoint URL to forward downloads to]:url:' \
        '*--forward_header[extra HTTP header for forwarding]:header:' \
        '--forward_queue[max queue length before forwarder]:length:' \
        '--forward_insecure[skip TLS checks for forwarding endpoint]' \
        '--log_file[file to log downloading to]:file:_files' \
        '--log_level[log level]:level:(debug info warn error)' \
        '(-c --config)'{-c,--config}'[path to config TOML file]:file:_files -g "*.toml"' \
        '--preferred_hash[preferred hash algorithm]:hash:(sha256 sha512)' \
        '*:domain or url:'
}

_csaf_provider() { _csaf_provider_args; }
_csaf_provider_args() {
    _arguments -s -S \
        '(-c --config)'{-c,--config}'[path to config TOML file]:file:_files -g "*.toml"' \
        '--version[display version and exit]' \
        '(- *)'{-h,--help}'[print help]'
}

_csaf_uploader() { _csaf_uploader_args; }
_csaf_uploader_args() {
    _arguments -s -S \
        '(-a --action)'{-a,--action}'[action to perform]:action:(upload create)' \
        '(-u --url)'{-u,--url}'[URL of the CSAF provider]:url:' \
        '(-t --tlp)'{-t,--tlp}'[TLP marking of the feed]:tlp:(csaf white green amber red)' \
        '(-x --external_signed)'{-x,--external_signed}'[CSAF files signed externally (.asc beside files)]' \
        '(-s --no_schema_check)'{-s,--no_schema_check}'[skip local JSON-schema check]' \
        '(-k --key)'{-k,--key}'[OpenPGP key to sign CSAF files]:key file:_files' \
        '(-p --password)'{-p,--password}'[auth password for the provider]:password:' \
        '(-P --passphrase)'{-P,--passphrase}'[passphrase to unlock OpenPGP key]:passphrase:' \
        '--client_cert[TLS client cert (PEM)]:cert:_files -g "*.(crt|pem)"' \
        '--client_key[TLS client key (PEM)]:key:_files -g "*.(key|pem)"' \
        '(-c --config)'{-c,--config}'[path to config TOML file]:file:_files -g "*.toml"' \
        '--version[display version and exit]' \
        '(- *)'{-h,--help}'[print help]' \
        '*:CSAF JSON file:_files -g "*.json"'
}

_csaf_validator() { _csaf_validator_args; }
_csaf_validator_args() {
    _arguments -s -S \
        '--version[display version and exit]' \
        '--validator[URL to validate documents remotely]:url:' \
        '--validator_cache[FILE to cache remote validations]:file:_files' \
        '*--validator_preset[remote validator preset (default mandatory)]:preset:' \
        '(-o --output)'{-o,--output}'[amount of remote validator results to display]:amount:(all important short)' \
        '(- *)'{-h,--help}'[print help]' \
        '*:CSAF JSON file:_files -g "*.json"'
}

_csaf_aggregator "$@"
