#compdef convertwarp
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fnirt/utils.html
# FSL: combine multiple transforms (affine and warps) into a single warp field

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --ref)'{-r,--ref=}'[filename of reference (target) image]:ref:_files' \
  '(-o --out)'{-o,--out=}'[filename of output warpfield]:output:_files' \
  '(-m --premat)'{-m,--premat=}'[filename of pre-affine transform]:premat:_files' \
  '(-w --warp1)'{-w,--warp1=}'[filename of initial warp]:warp1:_files' \
  '--midmat=[filename of middle affine transform]:midmat:_files' \
  '--warp2=[filename of secondary warp]:warp2:_files' \
  '--postmat=[filename of post-affine transform]:postmat:_files' \
  '(-s --shiftmap)'{-s,--shiftmap=}'[filename of a shiftmap]:shiftmap:_files' \
  '(-d --shiftdir)'{-d,--shiftdir=}'[direction of shiftmap distortions]:dir:(x y z x- y- z-)' \
  '(-j --jacobian)'{-j,--jacobian=}'[calculate and save Jacobian of final warp]:jac:_files' \
  '--jstats[print Jacobian statistics of the warpfield]' \
  '--constrainj[constrain Jacobian to specified min/max]' \
  '--jmin=[minimum acceptable Jacobian value]:jmin:' \
  '--jmax=[maximum acceptable Jacobian value]:jmax:' \
  '--rel[treat input warp fields as relative]' \
  '--abs[treat input warp fields as absolute]' \
  '--relout[output warp field as relative]' \
  '--absout[output warp field as absolute]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:image:_files' && ret=0

return ret
