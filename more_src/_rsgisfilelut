#compdef rsgisfilelut
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisfilelut RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --lutfile)'{-i,--lutfile}'[Input LUT vector file.]:value:_files' \
  '--lutlyr[Input LUT vector file layer.]:value:_files' \
  '--roifile[Input vector file defining the region of interest.]:value:_files' \
  '--roilyr[Input vector file layer defining the region of interest.]:value:_files' \
  '--dest[Output destination (file or folder) depending on the option specified.]:value:_files' \
  '(-o --outputfile)'{-o,--outputfile}'[Output file for commands.]:value:_files' \
  '--targz[Create tar command to archive the list of files.]' \
  '--copy[Create copy command for the list of files.]' \
  '*:file:_files' && ret=0

return ret
