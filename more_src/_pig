#compdef pig

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-x+[execution mode]:mode:(local mapreduce tez tez_local spark spark_local)' \
  '-e+[execute single command]:command:' \
  '-execute+[execute single command]:command:' \
  '-f+[script file]:file:_files -g "*.pig"' \
  '-h+[help on a Pig command]:command:(properties)' \
  '-help_properties[show all Pig properties]' \
  '-i[Pig version]' \
  '-version[show Pig version]' \
  '-l+[log file directory]:dir:_files -/' \
  '-m+[parameter map file]:file:_files' \
  '-param_file+[parameter map file]:file:_files' \
  '*-param+[script parameter]:name=value:' \
  '*-p+[script parameter]:name=value:' \
  '-r[dry run only - print expanded script]' \
  '-dryrun[dry run]' \
  '-c[syntax check only]' \
  '-check[check syntax]' \
  '-debug[debug level]' \
  '-d+[debug level]:level:(OFF FATAL ERROR WARN INFO DEBUG TRACE)' \
  '-w[warning behavior]' \
  '-warning[warn instead of fail]' \
  '-4+[log4j config file]:file:_files' \
  '-log4jconf+[log4j config file]:file:_files' \
  '-verbose[verbose]' \
  '-stop_on_failure[stop on first failure]' \
  '-secretDebugCmd[debug command]' \
  '-no_multiquery[disable multiquery optimization]' \
  '-brief[brief log format]' \
  '-print_cmd_for_local[print command for local mode]' \
  '-printCmdDebug[print debug commands]' \
  '-useHCatalog[use HCatalog]' \
  '-property_file+[properties file]:file:_files' \
  '-propertyFile+[properties file]:file:_files' \
  '-P+[properties file]:file:_files' \
  '-optimizer_off+[disable optimization]:rule:' \
  '*:Pig script:_files -g "*.pig"' && ret=0

return ret
