#compdef gsar
# Documentation: https://man.archlinux.org/search?q=gsar
# Reference accessed: 2026-05-16

# Zsh completion for gsar binary search-and-replace

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '1:search pattern:' \
  '2:replacement:' \
  '3:input file:_files' \
  '4:output file:_files' && ret=0

return ret
