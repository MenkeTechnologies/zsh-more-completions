#compdef pd-analysis
# _pd-analysis — TiKV PD log analyzer (scheduler/operator counters)
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-analysis/main.go on tip.

_pd-analysis() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-input=[PD log file to analyze (required)]:file:_files' \
        '-output=[output file (default stdout)]:file:_files' \
        '-logLevel=[log level]:level:(debug info warn error)' \
        '-style=[analysis style]:style:(transfer-counter)' \
        '-operator=[operator style]:operator:(balance-region balance-leader transfer-hot-read-leader move-hot-read-region transfer-hot-write-leader move-hot-write-region)' \
        '-start=[start time (YYYY/MM/DD HH\:MM\:SS)]:time:' \
        '-end=[end time (YYYY/MM/DD HH\:MM\:SS)]:time:'
}

_pd-analysis "$@"
