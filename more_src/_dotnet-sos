#compdef dotnet-sos
# Documentation: https://github.com/dotnet/diagnostics/tree/main/src/Tools/dotnet-sos
# Reference accessed: 2026-05-27
# Verified: upstream src/Tools/dotnet-sos/Program.cs System.CommandLine RootCommand definition

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'install:install SOS and configure LLDB to load it on startup'
  'uninstall:uninstall SOS and revert LLDB configuration changes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotnet-sos subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '(-a --arch --architecture)'{-a+,--arch=,--architecture=}'[processor architecture to install]:arch:(x64 x86 arm arm64)' && ret=0
        ;;
      (uninstall)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
