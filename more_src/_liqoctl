#compdef liqoctl
# Documentation: https://github.com/liqotech/liqo/blob/master/cmd/liqoctl/cmd/cmd.go
# Reference accessed: 2026-05-19
# Verified: liqotech/liqo cmd/liqoctl/cmd/cmd.go NewRootCommand registrations.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install Liqo (wraps Helm)'
  'uninstall:uninstall Liqo'
  'peer:establish peering with a remote cluster'
  'unpeer:revoke peering with a remote cluster'
  'network:manage Liqo networking'
  'authenticate:authenticate towards a remote cluster'
  'unauthenticate:revoke authentication towards a remote cluster'
  'offload:enable workload offloading on a namespace'
  'unoffload:disable workload offloading on a namespace'
  'move:move a stateful workload'
  'version:show liqoctl version'
  'activate:activate a Liqo resource'
  'cordon:mark a resource as cordoned'
  'uncordon:remove cordon from a resource'
  'drain:drain a remote cluster'
  'create:create a Liqo resource'
  'generate:generate Liqo configuration'
  'get:get Liqo resources'
  'delete:delete a Liqo resource'
  'info:show status of Liqo and peerings'
  'test:run Liqo end-to-end tests'
  'force:force operations bypassing safety checks'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--context=[Kubernetes context]:context' \
  '--namespace=[Liqo namespace]:namespace' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'liqoctl command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
