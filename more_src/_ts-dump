#compdef ts-dump
# Documentation: https://github.com/timescale/timescaledb-backup
# Dump a TimescaleDB database (pg_dump wrapper)

local ret=1

_arguments -s -S \
  '-db-URI=[PostgreSQL URI to connect to]:uri' \
  '-dump-dir=[directory to place the dump in]:dump dir:_files -/' \
  '-jobs=[number of parallel jobs (0 to disable parallelism)]:jobs' \
  '-verbose=[whether verbose output is requested]:bool:(true false)' \
  '-dump-roles=[use pg_dumpall to dump roles to a file]:bool:(true false)' \
  '-dump-tablespaces=[use pg_dumpall to dump tablespaces to a file]:bool:(true false)' \
  '-dump-pause-jobs=[pause background jobs that could disrupt a parallel dump]:bool:(true false)' \
  '-dump-job-finish-timeout=[seconds to wait for jobs to finish before timing out]:seconds' \
  '-dump-pause-UDAs=[pause user defined actions when pausing jobs (Timescale 2.0+)]:bool:(true false)' && ret=0

return ret
