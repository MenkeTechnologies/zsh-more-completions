#compdef hx

# Zsh completion for hx (helix) - post-modern text editor

_arguments -s -S \
  '(-c --config)'{-c,--config}'[specify a custom configuration file]:file:_files' \
  '--log[specify a custom log file]:file:_files' \
  '(-t --tutor)'{-t,--tutor}'[start the tutorial]' \
  '(-g --grammar)'{-g,--grammar}'[fetch and compile grammar]:action:(fetch build)' \
  '--health[check for potential errors in editor setup]:lang:' \
  '(-v --verbose)'{-v,--verbose}'[increases logging verbosity each use]' \
  '(-V --version)'{-V,--version}'[print version info and exit]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '*:file:_files'
