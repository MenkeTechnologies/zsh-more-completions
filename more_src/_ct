#compdef ct

# Helm chart-testing CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install and test Helm charts'
  'lint:lint Helm charts'
  'lint-and-install:lint and install Helm charts'
  'list-changed:list changed charts'
  'version:display version'
  'help:show help'
)

_arguments -s -S \
  '--config=[config file]:config file:_files' \
  '--charts=[specific charts to test]:chart directories' \
  '--chart-dirs=[directories containing Helm charts]:directories' \
  '--chart-repos=[additional chart repositories]:repos' \
  '--excluded-charts=[charts to skip]:charts' \
  '--remote=[remote to compare against]:remote' \
  '--since=[git reference for comparison]:ref' \
  '--target-branch=[target branch for comparison]:branch' \
  '--all[run on all charts]' \
  '--debug[enable debug output]' \
  '--print-config[print effective config]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      lint)
        _arguments \
          '--config=[config file]:config file:_files' \
          '--charts=[specific charts]:charts' \
          '--chart-dirs=[chart directories]:directories' \
          '--all[lint all charts]' \
          '--validate-maintainers[validate chart maintainers]' \
          '--check-version-increment[check version increment]' \
          '--debug[enable debug output]' && ret=0
        ;;
      install)
        _arguments \
          '--config=[config file]:config file:_files' \
          '--charts=[specific charts]:charts' \
          '--chart-dirs=[chart directories]:directories' \
          '--all[install all charts]' \
          '--namespace=[namespace for install]:namespace' \
          '--release-label=[label for identifying test releases]:label' \
          '--upgrade[test chart upgrade]' \
          '--skip-missing-values[skip missing values files]' \
          '--helm-extra-args=[extra arguments for Helm]:args' \
          '--helm-extra-set-args=[extra --set args for Helm]:args' \
          '--debug[enable debug output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
