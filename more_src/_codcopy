#compdef codcopy

# EMBOSS codcopy: copy a codon usage table between formats / locations
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-infile=[input codon usage table]:file:_files' \
  '-outcodon=[output codon usage table file]:file:_files' \
  '-format=[output codon usage format]:format:(emboss cutg gcg staden)' \
  '*:codon usage file:_files' && ret=0
return ret
