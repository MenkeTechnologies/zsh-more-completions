#compdef exifgrep

# exifgrep: grep-like search of EXIF metadata (Perl Image::ExifTool wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[case-insensitive match]' \
  '-l[only print filenames]' \
  '-L[only print filenames without matches]' \
  '-q[quiet (exit status only)]' \
  '-r[recurse into directories]' \
  '-v[invert match]' \
  '-e[regex pattern]:pattern:' \
  '-t[tag name pattern]:tag:' \
  '*:pattern files...:_files' && ret=0
return ret
