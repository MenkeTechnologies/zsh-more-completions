#compdef exifgrep
# Documentation: https://manpages.debian.org/testing/exifprobe/exifgrep.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exifgrep: shell script over exifprobe -L output, applies egrep selection.
# Usage: exifgrep [options] [egrep_options] pattern [NOT pattern] files...
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage]' \
  '-var[report in variable format (sourceable by Bourne shell)]' \
  '-export[report in variable format with export command]' \
  '-num[report numerical values rather than interpreted strings]' \
  '-r[recurse into directories using find]' \
  '-t[force exifprobe to print tag numbers]' \
  '-n[force exifprobe to print filename per line]' \
  '-c[turn on color output from exifprobe]' \
  '1:pattern:' \
  '*:images:_files -g "*.(jpg|jpeg|tif|tiff|cr2|nef|arw|raf|orf|dng|raw)"' && ret=0
return ret
