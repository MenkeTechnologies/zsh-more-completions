#compdef bitbucket-cli bb-cloud
# _bitbucket-cli — Atlassian Bitbucket Cloud CLI alias (Atlassian, Go); spf13/cobra
# upstream: https://bitbucket.org/atlassian/bitbucket-cli

_bitbucket-cli() {
    local -a sub=(
        'api:make Bitbucket API calls'
        'auth:authenticate'
        'browse:open in browser'
        'completion:generate shell completion'
        'config:configure CLI'
        'environment:manage environments'
        'help:show help'
        'pipeline:pipeline commands'
        'pipelines:pipelines (alias)'
        'pr:pull request commands'
        'repo:repository commands'
        'snippet:snippet commands'
        'team:team/workspace commands'
        'user:user commands'
        'version:show version'
        'workspace:workspace commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--workspace=+[workspace]:str:' \
        '-W+[workspace]:str:' \
        '--repo=+[repository]:str:' \
        '-R+[repository]:str:' \
        '--username=+[bitbucket username]:str:_users' \
        '--app-password=+[app password]:str:' \
        '--api-url=+[API URL]:url:_urls' \
        '--output=+[output format]:fmt:(json yaml table)' \
        '-o+[output format]:fmt:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bitbucket subcommand' sub ;;
        args)
            case $words[1] in
                pr) _arguments \
                    '1:cmd:(approve create decline delete list merge update view comment unapprove diff)' \
                    '*:arg:' ;;
                pipeline|pipelines) _arguments \
                    '1:cmd:(list run stop view log retry pause resume create)' \
                    '*:arg:' ;;
                repo) _arguments \
                    '1:cmd:(create delete list view clone fork update)' \
                    '*:arg:' ;;
                snippet) _arguments \
                    '1:cmd:(create delete list view)' \
                    '*:arg:' ;;
                auth) _arguments \
                    '1:cmd:(login logout status)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                environment) _arguments \
                    '1:cmd:(create delete list view update)' \
                    '*:arg:' ;;
                workspace|team) _arguments \
                    '1:cmd:(list view)' \
                    '*:arg:' ;;
                user) _arguments \
                    '1:cmd:(view current)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                api) _arguments \
                    '--method=+[method]:m:(GET POST PUT PATCH DELETE)' \
                    '-X+[method]:m:(GET POST PUT PATCH DELETE)' \
                    '--header=+[header]:list:' \
                    '-H+[header]:list:' \
                    '--data=+[data]:str:' \
                    '-d+[data]:str:' \
                    '*:endpoint:' ;;
            esac
            ;;
    esac
}

_bitbucket-cli "$@"
