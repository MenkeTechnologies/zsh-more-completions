#compdef qrcp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'send:send files'
      'receive:receive files'
      'config:manage configuration'
      'version:print version'
      'help:show help'
    )
    _describe -t commands 'qrcp command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (send)
        _arguments -s -S \
          '--port=[port to use]:port' \
          '--path=[URL path]:path' \
          '--interface=[network interface]:interface:_net_interfaces' \
          '--fqdn=[fully qualified domain name]:fqdn' \
          '--keep-alive[keep server alive after transfer]' \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '--zip[compress files before sending]' \
          '--browser[open browser automatically]' \
          '--tls-cert=[TLS certificate file]:cert file:_files' \
          '--tls-key=[TLS key file]:key file:_files' \
          '--output=[output format]:format:(text json)' \
          '*:file:_files' && ret=0
        ;;
      (receive)
        _arguments -s -S \
          '--port=[port to use]:port' \
          '--path=[URL path]:path' \
          '--interface=[network interface]:interface:_net_interfaces' \
          '--fqdn=[fully qualified domain name]:fqdn' \
          '--keep-alive[keep server alive after transfer]' \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '--tls-cert=[TLS certificate file]:cert file:_files' \
          '--tls-key=[TLS key file]:key file:_files' \
          '--output=[output directory]:output dir:_directories' && ret=0
        ;;
      (config)
        _arguments -s -S \
          '1:action:(show edit)' && ret=0
        ;;
    esac
    ;;
esac

return ret
