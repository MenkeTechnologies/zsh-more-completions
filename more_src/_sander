#compdef sander sander.MPI
# Documentation: https://ambermd.org/tutorials/basic/tutorial1/section5.php
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Amber sander: classical molecular dynamics with NMR-style restraints.
# Only the file-flag subset that appears in published Amber tutorial command
# lines is included; less-common flags from the full Amber reference manual
# (PDF-only, not webfetchable) are omitted to avoid fabrication.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-O[overwrite output files]' \
  '-i[input file (mdin)]:file:_files' \
  '-o[output file (mdout)]:file:_files' \
  '-p[topology/parmtop file]:file:_files' \
  '-c[coordinate input file (inpcrd/rst7)]:file:_files' \
  '-r[restart output file]:file:_files' \
  '-ref[reference coordinates for positional restraints]:file:_files' \
  '-x[trajectory output (mdcrd/NetCDF)]:file:_files' \
  '*::sander args:_files' && ret=0
return ret
