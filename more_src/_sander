#compdef sander sander.MPI

# Amber sander: classical MD with NMR-style restraints
local curcontext="$curcontext" ret=1
_arguments -C \
  '-O[overwrite output files]' \
  '-A[append to existing output files]' \
  '-i[input file (mdin)]:file:_files' \
  '-o[output file (mdout)]:file:_files' \
  '-p[topology/parmtop file]:file:_files' \
  '-c[coordinate file (inpcrd/restrt)]:file:_files' \
  '-r[restart output file]:file:_files' \
  '-ref[reference coordinates]:file:_files' \
  '-x[trajectory output (mdcrd)]:file:_files' \
  '-v[velocity output (mdvel)]:file:_files' \
  '-frc[force output (mdfrc)]:file:_files' \
  '-e[energy output (mden)]:file:_files' \
  '-inf[runtime info file (mdinfo)]:file:_files' \
  '-l[log file]:file:_files' \
  '-radii[radii info file]:file:_files' \
  '-y[input trajectory for IMIN=5/6]:file:_files' \
  '-cpin[constant pH state file]:file:_files' \
  '-cpout[constant pH state output]:file:_files' \
  '-cprestrt[constant pH restart]:file:_files' \
  '-rem[replica exchange method]:n:' \
  '-remlog[replica exchange log]:file:_files' \
  '-mdfrc[force output]:file:_files' \
  '*::sander args:_files' && ret=0
return ret
