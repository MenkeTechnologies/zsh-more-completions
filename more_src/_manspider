#compdef manspider
# Documentation: https://github.com/blacklanternsecurity/MANSPIDER
# Crawl SMB shares for sensitive files matching name, extension or content

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --username)'{-u,--username}'+[username]:user:' \
  '(-p --password)'{-p,--password}'+[password]:password:' \
  '(-d --domain)'{-d,--domain}'+[domain]:domain:' \
  '(-H --hash)'{-H,--hash}'+[NTLM hash]:hash:' \
  '(-k --kerberos)'{-k,--kerberos}'[use Kerberos authentication]' \
  '(-aesKey --aes-key)'{-aesKey,--aes-key}'+[AES key]:hex:' \
  '--dc-ip+[domain controller IP]:ip:' \
  '(-f --filenames)'{-f,--filenames}'+[filename regexes]:regex:' \
  '(-e --extensions)'{-e,--extensions}'+[file extensions]:ext:' \
  '--exclude-extensions+[extensions to exclude]:ext:' \
  '(-c --content)'{-c,--content}'+[content regexes]:regex:' \
  '--sharenames+[share names to spider]:share:' \
  '--exclude-sharenames+[share names to exclude]:share:' \
  '--dirnames+[directory names to spider]:dir:' \
  '--exclude-dirnames+[directory names to exclude]:dir:' \
  '(-l --loot-dir)'{-l,--loot-dir}'+[loot directory]:dir:_files -/' \
  '(-m --maxdepth)'{-m,--maxdepth}'+[maximum spider depth]:depth:' \
  '(-t --threads)'{-t,--threads}'+[number of threads]:threads:' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-n --no-download)'{-n,--no-download}'[do not download matching files]' \
  '(-s --max-filesize)'{-s,--max-filesize}'+[maximum file size]:size:' \
  '(-o --or-logic)'{-o,--or-logic}'[match any filter rather than all]' \
  '(-mfail --max-failed-logons)'{-mfail,--max-failed-logons}'+[max failed logons before giving up]:int:' \
  '--modified-after+[only files modified after date]:date:' \
  '--modified-before+[only files modified before date]:date:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:targets:' && ret=0

return ret
