#compdef belay
# Documentation: https://belay.readthedocs.io/en/latest/
# belay - rapid development for MicroPython-compatible boards via CPython

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:(add cache clean exec info install latency new init run select sync terminal update)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      install)
        _arguments -s \
          '--with=[include an optional dependency group]:group:' \
          '-f[force]' \
          '*:port:_files -g "/dev/tty* /dev/cu*"' && ret=0
        ;;
      add)
        _arguments -s \
          '--develop[install local path as editable]' \
          '*:dependency:' && ret=0
        ;;
      latency)
        _arguments -s \
          '(-t --with-timing)'{-t,--with-timing}'[include timing in output]' \
          '--no-with-timing[disable timing]' \
          '*:port:_files -g "/dev/tty* /dev/cu*"' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
