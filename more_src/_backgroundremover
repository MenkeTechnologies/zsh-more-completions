#compdef backgroundremover
# Documentation: https://github.com/nadermx/backgroundremover
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for backgroundremover
# Upstream: Remove background from images and video using AI
# Conservative fallback — run `backgroundremover --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
