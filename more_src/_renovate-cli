#compdef renovate-cli
# _renovate-cli — Renovate dependency-update bot CLI alias (Mend.io, TypeScript); commander
# upstream: https://github.com/renovatebot/renovate

_renovate-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config-file=+[config file]:file:_files -g "*.(json|js|json5)"' \
        '--platform=+[platform]:p:(github gitlab bitbucket-server bitbucket azure gitea forgejo codecommit local)' \
        '--endpoint=+[platform endpoint]:url:_urls' \
        '--token=+[platform token]:str:' \
        '--username=+[username]:str:_users' \
        '--password=+[password]:str:' \
        '--repositories=+[repositories csv]:list:' \
        '--autodiscover[autodiscover repositories]' \
        '--autodiscover-filter=+[autodiscover filter]:list:' \
        '--autodiscover-topics=+[autodiscover topics csv]:list:' \
        '--allowed-post-upgrade-commands=+[allowed post-upgrade commands]:list:' \
        '--allowed-managers=+[allowed managers]:list:' \
        '--enabled-managers=+[enabled managers]:list:' \
        '--dry-run=+[dry run]:t:(extract lookup full)' \
        '--print-config[print resolved config]' \
        '--log-context=+[log context]:str:' \
        '--log-level=+[log level]:level:(trace debug info warn error fatal)' \
        '--log-file=+[log file]:file:_files' \
        '--log-file-level=+[log file level]:level:(trace debug info warn error fatal)' \
        '--log-format=+[log format]:fmt:(json pretty)' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--persist-repo-data[persist repo data]' \
        '--require-config=+[require config]:r:(required ignored optional)' \
        '--onboarding=+[onboarding]:b:(true false)' \
        '--onboarding-config-file-name=+[onboarding config filename]:str:' \
        '--onboarding-pr-title=+[onboarding pr title]:str:' \
        '--onboarding-rebase-checkbox[onboarding rebase checkbox]' \
        '--force=+[force JSON]:str:' \
        '--force-cli=+[force CLI options]:b:(true false)' \
        '--git-author=+[git author]:str:' \
        '--git-private-key=+[git private key]:file:_files' \
        '--git-fs=+[git fs]:f:(http https ssh)' \
        '--git-no-verify=+[git no verify]:list:(commit push)' \
        '--http-cache-ttl-days=+[http cache ttl days]:n:' \
        '--secrets=+[secrets json]:str:' \
        '--use-cloud-metadata-services=+[use cloud metadata]:b:(true false)' \
        '--draft-pr=+[draft pr]:b:(true false)' \
        '--write-discovered-repos=+[write discovered repos]:file:_files' \
        '--include-mirrors[include mirrors]' \
        '--include-forks[include forks]' \
        '--exec-providers=+[exec providers]:list:' \
        '*:repo:'
}

_renovate-cli "$@"
