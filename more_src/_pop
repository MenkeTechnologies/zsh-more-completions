#compdef pop

# Zsh completion for Charm Pop - email sender

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--from=[sender email address]:email' \
  '--to=[recipient email address]:email' \
  '--subject=[email subject]:subject' \
  '--body=[email body]:body' \
  '*--attachments=[file attachments]:file:_files' \
  '--host=[SMTP server host]:host' \
  '--port=[SMTP server port]:port' \
  '--username=[SMTP username]:username' \
  '--password=[SMTP password]:password' \
  '--tls[use TLS encryption]' \
  && ret=0

return ret
