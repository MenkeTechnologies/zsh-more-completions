#compdef dipy_track_pft
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_track_pft.html
# DIPY: particle filtering tractography (PFT)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--step_size=[step size in mm for tracking]:size' \
  '--seed_density=[seeds per voxel dimension]:n' \
  '--pmf_threshold=[ODF function threshold]:thr' \
  '--max_angle=[maximum streamline segment angle in degrees]:angle' \
  '--sphere_name=[sphere for tracking]:sphere' \
  '--pft_back=[backtrack distance in mm]:dist' \
  '--pft_front=[forward tracking distance in mm]:dist' \
  '--pft_count=[number of particles in filter]:n' \
  '--pft_max_trial=[maximum particle filter trials]:n' \
  '--min_wm_pve_before_stopping=[minimum white matter threshold]:thr' \
  '--nbr_threads=[thread count]:n' \
  '--random_seed=[random number generator seed]:seed' \
  '--seed_buffer_fraction=[seed buffer usage fraction]:frac' \
  '--save_seeds[save seeds with streamlines]' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_tractogram=[output file name]:file:_files' \
  '*:input (pam wm gm csf seeding):_files' && ret=0

return ret
