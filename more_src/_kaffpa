#compdef kaffpa
# Documentation: https://arxiv.org/pdf/1311.1714
# KaHIP: multilevel graph partitioning program

local ret=1

_arguments -s \
  '--help[print help]' \
  '--k=[number of blocks to partition into]:int' \
  '--seed=[seed for the random number generator]:int' \
  '--preconfiguration=[use a preconfiguration]:variant:(strong eco fast fastsocial ecosocial strongsocial)' \
  '--imbalance=[desired balance in percent (default 3)]:double' \
  '--time_limit=[time limit in seconds]:double' \
  '--enforce_balance[guarantee the output partition is feasible]' \
  '--balance_edges[balance edges among the blocks as well as nodes]' \
  '--input_partition=[improve a given input partition]:file:_files' \
  '--enable_mapping[enable mapping onto a processor graph]' \
  '--hierarchy_parameter_string=[processor hierarchy spec (e.g. 4:8:8)]:string' \
  '--distance_parameter_string=[processor distance spec (e.g. 1:10:100)]:string' \
  '--online_distances[recompute processor distances instead of storing them]' \
  '--output_filename=[output filename (default tmppartition$k)]:file:_files' \
  '*:graph file:_files' && ret=0

return ret
