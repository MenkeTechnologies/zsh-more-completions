        '--tls-cert=[TLS certificate path (env TLS_CERT)]:cert:_files -g "*.(crt|pem)"' \
        '--tls-key=[TLS private key path (env TLS_KEY)]:key:_files -g "*.(key|pem)"' \
        '--strip-prefix=[URL prefix to strip (env WEBDAV_STRIP_PREFIX)]:prefix:' \
        '--debug[enable debug logging]' \
        '--no-self-upgrade[disable auto-upgrade check]' \
        '--skip-upload-same-size[skip upload if same byte size remote]' \
        '--prefer-http-download[prefer HTTP download (vs CDN)]' \
        '--redirect[enable 302 redirect to CDN when possible]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _aw_cmds=(
                'qr:QR-code login flow'
            )
            _describe -t commands 'aliyundrive-webdav command' _aw_cmds && ret=0
            ;;
        args)
            case $words[1] in
                qr)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'qr sub-command' '(login generate query)' && ret=0
                    else
                        case $words[2] in
                            query)
                                _arguments \
                                    '--sid=[QR-login session id]:sid:' && ret=0
                                ;;
                        esac
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_aliyundrive-webdav "$@"
