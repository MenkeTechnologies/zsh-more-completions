#compdef anjuta
# _anjuta — Anjuta DevStudio GNOME IDE (C/C++/Vala); GTK-based IDE for GNOME ecosystem
# upstream: https://gitlab.gnome.org/Archive/anjuta

_anjuta() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-p --proper-shutdown)'{-p,--proper-shutdown}'[proper shutdown]' \
        '(-g --geometry)'{-g,--geometry}'+[geometry]:wxh+x+y:' \
        '(-n --no-splash)'{-n,--no-splash}'[no splash]' \
        '(-s --no-session)'{-s,--no-session}'[no session restore]' \
        '(-f --no-files)'{-f,--no-files}'[no last opened files]' \
        '(--enable-rebuild)--enable-rebuild[force rebuild]' \
        '--display+[X display]:display:' \
        '*:project or file:_files'
}

_anjuta "$@"
