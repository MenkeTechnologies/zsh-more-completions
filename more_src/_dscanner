#compdef dscanner

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-S --styleCheck)'{-S,--styleCheck}'[check for style issues]' \
  '(-s --syntaxCheck)'{-s,--syntaxCheck}'[check for syntax errors]' \
  '(-i --imports)'{-i,--imports}'[print import paths]' \
  '--ast-dump[dump the AST]' \
  '--sloc[count source lines of code]' \
  '--tokenCount[count tokens]' \
  '--ctags[generate ctags output]' \
  '--etags[generate etags output]' \
  '--highlight[highlight syntax]' \
  '--mixin[expand mixin templates]' \
  '--report[generate a report]' \
  '--config[configuration file]:config file:_files' \
  '--errorFormat[error message format]:format:' \
  '--resolveMessage[resolve error message]:message:' \
  '*:file:_files' && ret=0

return ret
