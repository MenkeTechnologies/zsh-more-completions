#compdef arangosh

# Zsh completion for arangosh - ArangoDB JavaScript shell

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--server.endpoint=[server endpoint]:endpoint' \
  '--server.database=[database name]:database' \
  '--server.username=[username]:user' \
  '--server.password=[password]:password' \
  '--server.authentication=[enable authentication]:enable:(true false)' \
  '--server.connection-timeout=[connection timeout in seconds]:seconds' \
  '--server.request-timeout=[request timeout in seconds]:seconds' \
  '--server.max-packet-size=[maximum packet size]:bytes' \
  '--ssl.protocol=[SSL protocol]:protocol:(1 2 3 4 5 6 9)' \
  '--ssl.cafile=[CA certificate file]:file:_files' \
  '--ssl.keyfile=[client certificate file]:file:_files' \
  '--javascript.execute=[execute a JavaScript file]:file:_files -g "*.js"' \
  '--javascript.execute-string=[execute a JavaScript string]:code' \
  '--javascript.check-syntax=[check syntax of a JavaScript file]:file:_files -g "*.js"' \
  '--javascript.startup-directory=[startup module directory]:directory:_files -/' \
  '--javascript.module-directory=[module directory]:directory:_files -/' \
  '--javascript.unit-tests=[run unit tests]:file:_files' \
  '--javascript.unit-test-filter=[filter unit tests]:pattern' \
  '--console.colors=[enable colors]:enable:(true false)' \
  '--console.auto-complete=[enable auto completion]:enable:(true false)' \
  '--console.pretty-print=[enable pretty printing]:enable:(true false)' \
  '--console.pager=[enable pager]:enable:(true false)' \
  '--console.history=[enable command history]:enable:(true false)' \
  '--console.prompt=[custom prompt string]:prompt' \
  '--log.level=[log level]:level:(fatal error warning info debug trace)' \
  '--log.output=[log output]:output' \
  '--quiet[suppress info messages]' \
  '--no-auto-complete[disable auto completion]' \
  '--temp.path=[path for temporary files]:directory:_files -/' \
  '--configuration=[configuration file]:file:_files' \
  '*:JavaScript file:_files -g "*.js"'
