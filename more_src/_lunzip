#compdef lunzip
# Documentation: https://www.nongnu.org/lzip/lunzip.html
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --stdout)'{-c,--stdout}'[write to standard output]' \
  '(-d --decompress)'{-d,--decompress}'[decompress (default)]' \
  '(-f --force)'{-f,--force}'[force overwrite of output files]' \
  '(-k --keep)'{-k,--keep}'[keep input files]' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet operation]' \
  '(-t --test)'{-t,--test}'[test integrity of compressed files]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:file:_files'
