#compdef funky

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --add)'{-a,--add}'[add a new function]' \
  '(-e --edit)'{-e,--edit}'[edit an existing function]' \
  '(-r --remove)'{-r,--remove}'[remove a function]' \
  '(-R --rename)'{-R,--rename}'[rename a function]' \
  '(-c --copy)'{-c,--copy}'[copy a function]' \
  '(-C --color-when)'{-C,--color-when}'[when to use color output]:when:(always auto never)' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-g --global)'{-g,--global}'[operate on global functions]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '1:function name' && ret=0

return ret
