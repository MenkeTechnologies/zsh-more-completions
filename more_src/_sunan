#compdef sunan
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/amplitudes/sunan.c
# remove NaNs and Infs from the input stream

local ret=1

_arguments -s -S \
  'verbose=[echo locations of NaNs or Infs to stderr]:verbose' \
  'value=[NaNs and Inf replacement value]:value' \
  'interp=[replace by interpolating neighboring finite values]:interp' \
  '*:file:_files' && ret=0


return ret
