#compdef typst-lsp
# Documentation: https://github.com/nvarner/typst-lsp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log-level=[log level]:level:(off error warn info debug trace)' \
  '--log-file=[log file]:file:_files' \
  '*::passthrough:' && ret=0

return ret
