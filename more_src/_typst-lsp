#compdef typst-lsp

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log-level=[log level]:level:(off error warn info debug trace)' \
  '--log-file=[log file]:file:_files' \
  '*::passthrough:' && ret=0

return ret
