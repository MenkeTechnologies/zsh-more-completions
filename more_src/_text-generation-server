#compdef text-generation-server
# Documentation: https://man.archlinux.org/search?q=text-generation-server
# Reference accessed: 2026-05-16

# HuggingFace text-generation-inference (TGI) server
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:run the TGI server'
  'download-weights:download model weights'
  'quantize:quantize a model'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'text-generation-server command' commands && ret=0 ;;
esac
return ret
