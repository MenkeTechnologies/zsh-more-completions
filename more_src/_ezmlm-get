#compdef ezmlm-get
# Documentation: https://man.archlinux.org/search?q=ezmlm-get
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-b[mass digest]' \
  '-c[copy to subscriber]' \
  '-d[digest list]' \
  '1:dir:_files -/' && ret=0

return ret
