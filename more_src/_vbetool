#compdef vbetool
# Documentation: https://manpages.debian.org/bookworm/vbetool/vbetool.8.en.html
# Run real-mode video BIOS code to alter hardware state

local ret=1

_arguments -s \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'vbetool command' \
      'vbestate[save or restore video card hardware state]' \
      'vbemode[get or set the video mode]' \
      'vgamode[get or set the vga mode]' \
      'dpms[alter display power management state]' \
      'post[attempt to initialise the video card from scratch]' \
      'vgastate[enable or disable VGA output]' \
      'vbefp[query or alter flat panel state]' && ret=0
    ;;
  args)
    case $line[1] in
      vbestate) _values 'subcommand' 'save[save state to stdout]' 'restore[restore state from stdin]' && ret=0 ;;
      vbemode|vgamode) _values 'subcommand' 'get[print current mode]' 'set[set the mode]' && ret=0 ;;
      dpms) _values 'state' 'on' 'off' 'standby' 'suspend' 'reduced' && ret=0 ;;
      vgastate) _values 'state' 'on' 'off' && ret=0 ;;
      vbefp) _values 'subcommand' 'panelid' 'panelsize' 'getbrightness' 'setbrightness' 'invert' && ret=0 ;;
    esac
    ;;
esac

return ret
