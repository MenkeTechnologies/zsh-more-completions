#compdef datadogctl ddctl
# _datadogctl — Datadog datadogctl ddctl CLI alternative command-line frontend to the Datadog REST API providing dashboards metrics events monitors downtimes-SLO-incidents-AWS-integrations-RBAC-roles-users-services synthetics-tests-logs-search-pipelines-saved-views-CI-tests admin operations for the Datadog SaaS observability platform (Datadog team, Go); cobra
# upstream: https://docs.datadoghq.com/api/

_datadogctl() {
    local -a sub=(
        'auth:authenticate'
        'dashboards:dashboard management'
        'monitors:monitor management'
        'events:event operations'
        'metrics:metric operations'
        'logs:log operations'
        'spans:span operations'
        'incidents:incident management'
        'slos:SLO management'
        'downtime:downtime management'
        'synthetics:synthetic tests'
        'rum:RUM applications'
        'ci-tests:CI test results'
        'pipelines:pipeline management'
        'role:role management'
        'user:user management'
        'tag:tag management'
        'integration:integration management'
        'service:service catalog'
        'apm:APM operations'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--app-key=+[key]:str:' \
        '--site=+[s]:s:(datadoghq.com datadoghq.eu us3.datadoghq.com us5.datadoghq.com ap1.datadoghq.com ddog-gov.com)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datadogctl subcommand' sub ;;
        args)
            case $words[1] in
                dashboards|monitors|incidents|slos|downtime|user|role|tag|integration|service) _arguments '1:op:(list show create update delete)' '*:id:' ;;
                logs|spans|events|metrics) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_datadogctl "$@"
