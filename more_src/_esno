#compdef esno esmo
# Documentation: https://github.com/antfu/esno
# Reference accessed: 2026-05-17
# Verified: antfu/esno README. Since v0.15+, esno is a thin alias for
# tsx; the CLI surface inherits all tsx flags + Node passthrough.
# Removed from prior file: bogus man.archlinux.org search URL.

# esno/esmo: TypeScript/ESNext node runtime (tsx alias)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--tsconfig=[tsconfig path]:file:_files -g "tsconfig*.json(-.)"' \
  '--no-cache[disable cache]' \
  '--clear-screen[clear screen on rerun]' \
  '(-r --require)'{-r+,--require=}'[require module]:module:' \
  '--conditions=[Node resolve conditions]:list:' \
  '--env-file=[load .env file]:file:_files' \
  '--watch[watch mode]' \
  '--inspect[Node inspector]' \
  '--inspect-brk[break on first line]' \
  '1:file:_files -g "*.(ts|mts|cts|tsx|js|mjs|cjs|jsx)(-.)"' \
  '*::args: _normal' && ret=0
return ret
