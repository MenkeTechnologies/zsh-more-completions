#compdef cd-hit-454
# Documentation: https://github.com/weizhongli/cdhit/blob/master/cdhit-454.c++
# CD-HIT-454 - identify duplicated reads from 454 pyrosequencing

local ret=1

_arguments -s \
  '-h[print help]' \
  '-i[input filename in fasta format, required, can be in .gz format]:input:_files' \
  '-o[output filename, required]:output:_files' \
  '-c[clustering threshold (sequence identity)]:threshold' \
  '-b[band_width of alignment, default 10]:width' \
  '-M[memory limit (in MB), default 800; 0 for unlimited]:mb' \
  '-T[number of threads, default 1; 0 uses all CPUs]:threads' \
  '-n[word_length, default 10]:length' \
  '-aL[alignment coverage for the longer sequence]:coverage' \
  '-AL[alignment coverage control for the longer sequence]:control' \
  '-aS[alignment coverage for the shorter sequence]:coverage' \
  '-AS[alignment coverage control for the shorter sequence]:control' \
  '-B[store sequences in disk (1) or RAM (0)]:flag:(0 1)' \
  '-g[cluster into most similar (1) vs first (0) cluster]:mode:(0 1)' \
  '-D[max size per indel, default 1]:size' \
  '-match[matching score, default 2]:score' \
  '-mismatch[mismatching score, default -1]:score' \
  '-gap[gap opening score, default -3]:score' \
  '-gap-ext[gap extension score, default -1]:score' \
  '-bak[write backup cluster file (1 or 0)]:flag:(0 1)' \
  '*:file:_files' && ret=0

return ret
