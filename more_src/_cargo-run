#compdef cargo-run

# Zsh completion for cargo run (run a binary or example of the local package)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--bin=[Name of the bin target to run]:bin' \
  '--example=[Name of the example target to run]:example' \
  '(-p --package)'{-p,--package}'=[Package with the target to run]:package' \
  '(-j --jobs)'{-j,--jobs}'=[Number of parallel jobs]:jobs' \
  '--keep-going[Do not abort the build on first error]' \
  '(-r --release)'{-r,--release}'[Build artifacts in release mode]' \
  '--profile=[Build artifacts with the specified profile]:profile' \
  '(-F --features)'{-F,--features}'=[Space or comma separated list of features to activate]:features' \
  '--all-features[Activate all available features]' \
  '--no-default-features[Do not activate the default feature]' \
  '--target=[Build for the target triple]:target' \
  '--target-dir=[Directory for all generated artifacts]:dir:_files -/' \
  '--manifest-path=[Path to Cargo.toml]:path:_files -g "*.toml"' \
  '--message-format=[Error format]:format:(human json short)' \
  '--unit-graph[Output build graph in JSON]' \
  '--ignore-rust-version[Ignore rust-version specification in packages]' \
  '--timings=[Timing output formats]:format:(html json)' \
  '(-v --verbose)'{-v,--verbose}'[Use verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[Do not print cargo log messages]' \
  '--color=[Control when colored output is used]:when:(auto always never)' \
  '--config=[Override a configuration value]:key=value' \
  '-Z+[Unstable (nightly-only) flags]:flag' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '*:args' && ret=0

return ret
