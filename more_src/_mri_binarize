#compdef mri_binarize
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_binarize
# mri_binarize - binarize a volume (or volume-encoded surface) based on thresholds

local ret=1

_arguments -s -S \
  '--i[input volume to be binarized]:file:_files' \
  '--o[output volume path]:file:_files' \
  '--min[minimum threshold (default -infinity)]:min:' \
  '--max[maximum threshold (default infinity)]:max:' \
  '--pct[set threshold to capture top P percent of voxels]:P:' \
  '--rmin[minimum based on rmin times globalmean]:r:' \
  '--rmax[maximum based on rmax times globalmean]:r:' \
  '--fdr[min threshold via FDR (input is -log10(p))]:fdr:' \
  '--match[binarize matching specific values]:value:' \
  '--replace[replace every occurrence of V1 with V2]:V1V2:' \
  '--replaceonly[replace V1 with V2, propagate other voxels]:V1V2:' \
  '--ctx-wm[match cerebral white matter values]' \
  '--all-wm[match all white matter values]' \
  '--ventricles[match aseg ventricles and choroid plexus]' \
  '--wm+vcsf[match white matter and ventricular CSF]' \
  '--gm[match gray matter (inverted mask)]' \
  '--subcort-gm[match subcortical gray matter]' \
  '--binval[value for voxels within threshold (default 1)]:val:' \
  '--binvalnot[value for voxels outside range (default 0)]:val:' \
  '--inv[set binval=0, binvalnot=1]' \
  '--frame[use 0-based frame (default 0)]:n:' \
  '--frame-sum[sum frames before binarizing]' \
  '--frame-and[take intersection of frames]' \
  '--mask[mask input with maskvol]:file:_files' \
  '--mask-thresh[threshold for mask (default 0.5)]:thresh:' \
  '--merge[merge with mergevolume]:file:_files' \
  '--dilate[dilate binarization Ntimes in 3D]:n:' \
  '--erode[erode binarization Ntimes in 3D]:n:' \
  '--erode2d[erode binarization Ntimes in 2D]:n:' \
  '--abs[take abs of input first (make unsigned)]' \
  '--bincol[set binarized voxel value to column number]' \
  '--zero-edges[set edge voxels to zero]' \
  '--zero-slice-edges[set edge slice voxels to zero]' \
  '--count[save voxel count to ascii file]:file:_files' \
  '--uchar[save output in uchar format]' \
  '--noverbose[disable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
