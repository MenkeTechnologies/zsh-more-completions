#compdef electron
# _electron — Electron runtime CLI (electron/electron)
# upstream: https://github.com/electron/electron
# Flags from docs/api/command-line-switches.md.

_electron() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--auth-server-whitelist=[integrated-auth server list]:urls:' \
        '--auth-negotiate-delegate-whitelist=[credential-delegation server list]:urls:' \
        '--disable-ntlm-v2[disable NTLMv2 on POSIX]' \
        '--disable-http-cache[disable HTTP disk cache]' \
        '--disable-http2[disable HTTP/2 and SPDY/3.1]' \
        '--disable-geolocation[disable geolocation (macOS)]' \
        '--disable-renderer-backgrounding[do not throttle background renderers]' \
        '--disk-cache-size=[max disk cache (bytes)]:bytes:' \
        '--enable-logging=[enable Chromium logging]:dest:(file stderr)' \
        '--force-fieldtrials=[force fieldtrials]:trials:' \
        '--host-rules=[host rules (deprecated)]:rules:' \
        '--host-resolver-rules=[host resolver rules]:rules:' \
        '--ignore-certificate-errors[skip TLS cert validation]' \
        '--ignore-connections-limit=[domains to ignore conn limit]:domains:' \
        '--js-flags=[V8 flags]:flags:' \
        '--lang=[UI language]:lang:' \
        '--log-file=[log file path]:file:_files' \
        '--log-net-log=[net-log output path]:file:_files -g "*.json"' \
        '--log-level=[verbosity level]:n:' \
        '--no-proxy-server[disable proxy]' \
        '--no-sandbox[disable Chromium sandbox]' \
        '--no-stdio-init[do not initialize stdio]' \
        '--proxy-bypass-list=[hosts to bypass proxy]:hosts:' \
        '--proxy-pac-url=[PAC file URL]:url:' \
        '--proxy-server=[proxy address:port]:addr:' \
        '--remote-debugging-port=[remote debugging port]:port:' \
        '--v=[Chromium VLOG level]:n:' \
        '--vmodule=[VLOG pattern]:pattern:' \
        '--force_high_performance_gpu[force discrete GPU on macOS]' \
        '--force_low_power_gpu[force integrated GPU on macOS]' \
        '--xdg-portal-required-version=[XDG portal version]:ver:' \
        '*:app path or JS file:_files'
}

_electron "$@"
