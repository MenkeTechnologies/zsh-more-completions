#compdef neon_local
# _neon_local — Neon local-dev CLI (boots a full pageserver + safekeeper + storage_controller + storage_broker + endpoint stack on the local machine)
# upstream: https://github.com/neondatabase/neon
# Top-level subcommands from control_plane/src/bin/neon_local.rs on tip (clap-derive).

_neon_local() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'init:initialize a new Neon local repository'
                'tenant:manage tenants (list|create|set-default|config|import)'
                'timeline:manage timelines (list|branch|create|import)'
                'pageserver:manage local pageservers'
                'storage-controller:manage the local storage controller (alias storage_controller)'
                'storage-broker:manage the local storage broker (alias storage_broker)'
                'safekeeper:manage local safekeepers'
                'endpoint-storage:manage endpoint storage'
                'endpoint:manage compute endpoints'
                'mappings:manage local node mappings'
                'start:start all services'
                'stop:stop all services'
            )
            _describe -t commands 'neon_local command' subs
            ;;
        args)
            case $line[1] in
                init)
                    _arguments \
                        '--num-pageservers=[number of pageservers to create]:n:' \
                        '--config=[path to repo config TOML]:file:_files' \
                        '--force=[init even if repo is not empty]:mode:(must-not-exist empty-dir-ok any)'
                    ;;
                start)
                    _arguments '--start-timeout=[start timeout]:dur:'
                    ;;
                stop)
                    _arguments '--mode=[stop mode]:mode:(fast immediate)'
                    ;;
                tenant)
                    _arguments '1: :->tcmd'
                    case $state in
                        tcmd) _describe -t commands 'tenant subcommand' '(list create set-default config import)' ;;
                    esac
                    ;;
                timeline)
                    _arguments '1: :->ticmd'
                    case $state in
                        ticmd) _describe -t commands 'timeline subcommand' '(list branch create import)' ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_neon_local "$@"
