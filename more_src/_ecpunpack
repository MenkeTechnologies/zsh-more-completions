#compdef ecpunpack
# Documentation: https://man.archlinux.org/search?q=ecpunpack
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--input=[input bitstream]:file:_files -g "*.bit"' \
  '--textcfg=[output text config]:file:_files -g "*.config"' \
  '--db=[chip database file]:file:_files' \
  '--idcode=[force IDCODE]:idcode:' && ret=0

return ret
