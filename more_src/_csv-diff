#compdef csv-diff

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--key[column to use as unique key]:key column:' \
  '--json[output as JSON]' \
  '--human[output human-readable diff]' \
  '--singular[singular noun for records]:singular noun:' \
  '--plural[plural noun for records]:plural noun:' \
  '--show-unchanged[show unchanged rows]' \
  '--format[input file format]:format:(csv json tsv)' \
  '1:first file:_files' \
  '2:second file:_files' && ret=0

return ret
