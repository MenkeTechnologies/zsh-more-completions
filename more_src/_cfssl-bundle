#compdef cfssl-bundle

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-cert[certificate file]:file:_files -g "*.pem(|.crt|.cer)"' \
  '-key[private key file]:file:_files -g "*.key(|.pem)"' \
  '-ca-bundle[CA bundle file]:file:_files' \
  '-int-bundle[intermediate bundle file]:file:_files' \
  '-flavor[bundle flavor]:flavor:(ubiquitous optimal force)' \
  '-metadata[metadata file]:file:_files' \
  '-domain[domain to verify]:domain:' \
  '-ip[IP to verify]:ip:' \
  && ret=0

return ret
