#compdef wolfictl
# _wolfictl — CLI for working with the Wolfi distro / Chainguard apk packages (wolfi-dev/wolfictl)
# upstream: https://github.com/wolfi-dev/wolfictl
# Subcommands from pkg/cli/commands.go (cobra).

_wolfictl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--log-level=[log level]:level:(debug info warn error)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_wolfictl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                apk)
                    _arguments \
                        '1: :(extract index ls show)' \
                        '*:apk arg:_files' && ret=0 ;;
                bump)
                    _arguments \
                        '--commit[commit the bumped melange config]' \
                        '*:package yaml:_files -g "*.(yaml|yml)"' && ret=0 ;;
                check)
                    _arguments \
                        '1: :(diff so-name update-deps)' \
                        '*:arg:_files' && ret=0 ;;
                gh)
                    _arguments \
                        '1: :(gc release issues)' \
                        '*:arg:' && ret=0 ;;
                image)
                    _arguments \
                        '1: :(apk vex)' \
                        '*:arg:_files' && ret=0 ;;
                lint)
                    _arguments \
                        '--fix[apply suggested fixes]' \
                        '*:melange yaml:_files -g "*.(yaml|yml)"' && ret=0 ;;
                ls)
                    _arguments \
                        '--dir=[directory to scan]:dir:_files -/' && ret=0 ;;
                ruby)
                    _arguments \
                        '1: :(check-upgrade code-search)' \
                        '*:ruby arg:' && ret=0 ;;
                vex)
                    _arguments \
                        '1: :(generate apply rich-attestation)' \
                        '*:vex arg:_files' && ret=0 ;;
                withdraw)
                    _arguments \
                        '--repo=[upstream apk repo]:url:' \
                        '*:package@version:' && ret=0 ;;
                svg|text|version|help) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_wolfictl_commands] )) ||
_wolfictl_commands() {
    local -a commands
    commands=(
        'apk:inspect / extract / index an apk package'
        'bump:bump the version field of a melange config'
        'check:run consistency checks (diff / so-name / update-deps)'
        'gh:GitHub helpers (garbage-collect branches / issues, release helpers)'
        'image:image-level operations (apks-in-image, VEX scans)'
        'lint:lint melange / Wolfi YAML configurations'
        'ls:list packages / dependencies'
        'ruby:Ruby-specific helpers (gem upgrade / code search)'
        'svg:emit a dependency-graph SVG'
        'text:emit a textual dependency graph'
        'vex:work with VEX / OpenVEX advisories'
        'withdraw:withdraw a published apk package'
        'version:print wolfictl version'
        'help:show help for a subcommand'
    )
    _describe -t commands 'wolfictl command' commands
}

_wolfictl "$@"
