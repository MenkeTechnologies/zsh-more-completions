#compdef pe-tree-ghidra
# Documentation: https://github.com/blackberry/pe_tree
# PE Tree (Ghidra) - PE Tree connected to a Ghidra bridge server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--server[Ghidra bridge server IP]:ip' \
  '--port[Ghidra bridge server port]:port' && ret=0

return ret
