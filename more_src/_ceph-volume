#compdef ceph-volume
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-volume/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-volume: deploy and manage OSDs (lvm / raw / simple / inventory)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'lvm:LVM-backed OSD operations'
  'simple:legacy ceph-disk OSD operations'
  'raw:raw block device OSD operations'
  'inventory:list host disk inventory'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--cluster=[cluster name]:name:' \
  '--log-level=[logging verbosity]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--log-path=[log file location]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ceph-volume command' commands && ret=0 ;;
esac
return ret
