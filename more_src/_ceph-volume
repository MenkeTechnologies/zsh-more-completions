#compdef ceph-volume

# ceph-volume: deploy and manage OSDs (lvm / raw / simple / inventory / activate)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'lvm:LVM-backed OSD operations'
  'simple:legacy simple OSD operations'
  'raw:raw block device OSD operations'
  'inventory:list devices'
  'activate:activate (start) an OSD'
  'list:list OSDs'
  'zap:zap an OSD device'
  'prepare:prepare an OSD'
  'batch:batch OSD creation'
  'create:full OSD create'
  'trigger:internal udev trigger'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--cluster=[cluster name]:name:' \
  '--log-path=[log path]:dir:_files -/' \
  '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ceph-volume command' commands && ret=0 ;;
esac
return ret
