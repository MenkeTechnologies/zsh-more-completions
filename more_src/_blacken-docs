#compdef blacken-docs
# Documentation: https://github.com/adamchainz/blacken-docs
# Run black on python code blocks in documentation files

local ret=1

_arguments -s -S \
  '(-l --line-length)'{-l+,--line-length=}'[set maximum line length]:int' \
  '--preview[enable preview mode features]' \
  '--pyi[format as Python stub file]' \
  '(-S --skip-string-normalization)'{-S,--skip-string-normalization}'[disable string normalization]' \
  '(-t --target-version)'{-t+,--target-version=}'[specify target Python version(s)]:version' \
  '--check[do not modify files but indicate when changes are necessary]' \
  '(-E --skip-errors)'{-E,--skip-errors}'[do not exit non-zero for errors from Black]' \
  '--rst-literal-blocks[format literal blocks in reStructuredText files]' \
  '*:file:_files' && ret=0

return ret
