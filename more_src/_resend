#compdef resend

_resend() {
    local line state
    local -a commands
    commands=(
        'login:Authenticate and store API key'
        'logout:Remove saved API key'
        'doctor:Run diagnostics'
        'emails:Manage and send emails'
        'webhooks:Manage webhooks'
        'domains:Manage domains'
        'api-keys:Manage API keys'
    )

    _arguments -C \
        '--api-key[Override API key]:key:' \
        '(-p --profile)'{-p,--profile}'[Specify a profile]:profile:' \
        '--json[Force JSON output]' \
        '(-q --quiet)'{-q,--quiet}'[Suppress status output]' \
        '--version[Print version]' \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'resend command' commands
            ;;
        args)
            case $line[1] in
                emails)
                    _arguments '1:subcommand:(send)' '2: :->args'
                    ;;
                webhooks)
                    _arguments '1:subcommand:(listen create list delete)' '2: :->args'
                    ;;
                domains)
                    _arguments '1:subcommand:(list get create delete verify)' '2: :->args'
                    ;;
                api-keys)
                    _arguments '1:subcommand:(list create delete)' '2: :->args'
                    ;;
            esac
            ;;
    esac
}

_resend "$@"
