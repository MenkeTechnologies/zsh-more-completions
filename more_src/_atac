#compdef atac

# Zsh completion for atac (API client TUI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-d+[Directory to store collections]:dir:_directories' \
  '--directory=[Directory to store collections]:dir:_directories' \
  '--dry-run[Do not persist data]' \
  '--no-ansi[Disable ANSI colors]' \
  '-v[Verbose output]' \
  '--verbose[Verbose output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'import:Import a collection from Postman or other formats'
      'completions:Generate shell completions'
    )
    _describe -t commands 'atac command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      import)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--format=[Import format]:format:(postman curl openapi)' \
          '*:file:_files' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
