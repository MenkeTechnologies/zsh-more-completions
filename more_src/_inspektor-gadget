#compdef ig kubectl-gadget

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'trace:trace system events'
      'snapshot:take snapshots of system state'
      'top:show top processes/connections'
      'profile:profile system performance'
      'advise:provide security advice'
      'audit:audit security'
      'list-columns:list available columns'
      'run:run a gadget'
      'version:show version'
      'completion:generate shell completion'
    )
    _describe -t commands 'inspektor-gadget command' commands && ret=0
    ;;
  args)
    case $line[1] in
      trace)
        local -a trace_commands=(
          'bind:trace bind calls'
          'capabilities:trace security capability checks'
          'dns:trace DNS requests'
          'exec:trace process execution'
          'fsslower:trace slow filesystem operations'
          'mount:trace mount/unmount calls'
          'network:trace network events'
          'oomkill:trace OOM kills'
          'open:trace file opens'
          'signal:trace signal delivery'
          'sni:trace SNI from TLS connections'
          'tcp:trace TCP events'
          'tcpconnect:trace TCP connections'
          'tcpdrop:trace TCP drops'
          'tcpretrans:trace TCP retransmissions'
        )
        _describe -t commands 'trace command' trace_commands && ret=0
        ;;
      snapshot)
        local -a snapshot_commands=(
          'process:snapshot running processes'
          'socket:snapshot open sockets'
        )
        _describe -t commands 'snapshot command' snapshot_commands && ret=0
        ;;
      top)
        local -a top_commands=(
          'block-io:top block I/O'
          'ebpf:top eBPF programs'
          'file:top file operations'
          'tcp:top TCP connections'
        )
        _describe -t commands 'top command' top_commands && ret=0
        ;;
      profile)
        local -a profile_commands=(
          'block-io:profile block I/O'
          'cpu:profile CPU usage'
          'tcprtt:profile TCP round-trip time'
        )
        _describe -t commands 'profile command' profile_commands && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
