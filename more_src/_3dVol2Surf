#compdef 3dVol2Surf
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dVol2Surf.html
# Map data from a volume domain to a surface domain

local ret=1

_arguments -s \
  '-spec[SUMA spec file]:spec file:_files' \
  '-surf_A[primary surface name]:surface' \
  '-surf_B[optional second surface name]:surface' \
  '-sv[surface volume dataset]:dataset:_files' \
  '-grid_parent[volume dataset with output values]:dataset:_files' \
  '-map_func[filter function (ave, max, median)]:func' \
  '-f_steps[points along segments]:num' \
  '-f_index[index by nodes or voxels]:type:(nodes voxels)' \
  '-f_p1_mm[first endpoint offset mm]:dist' \
  '-f_pn_mm[second endpoint offset mm]:dist' \
  '-f_p1_fr[first endpoint fractional offset]:frac' \
  '-f_pn_fr[second endpoint fractional offset]:frac' \
  '-use_norms[use surface normals for segments]' \
  '-norm_len[directed distance along normals]:len' \
  '-keep_norm_dir[preserve normal directions]' \
  '-reverse_norm_dir[reverse normal directions]' \
  '-out_1D[write ASCII column output]:file:_files' \
  '-out_niml[write NIML output]:file:_files' \
  '-first_node[restrict output min node]:node' \
  '-last_node[restrict output max node]:node' \
  '-dnode[debug output for a node]:node' \
  '-no_headers[suppress column headers]' \
  '-cmask[apply mask command]:mask' \
  '-oob_index[default index for out-of-bounds nodes]:index' \
  '-oob_value[default value for out-of-bounds nodes]:value' \
  '-oom_value[default value for out-of-mask nodes]:value' \
  '-skip_col_nodes[omit node index column]' \
  '-skip_col_1dindex[omit 1D voxel index column]' \
  '-skip_col_i[omit i column]' \
  '-skip_col_j[omit j column]' \
  '-skip_col_k[omit k column]' \
  '-skip_col_vals[omit value count column]' \
  '-outcols_NSD_format[output NI_SURF_DSET format]' \
  '-debug[verbose status level 0-5]:level' \
  '-gp_index[select grid_parent sub-brick]:brick' \
  '-save_seg_coords[save segment coordinates]:file:_files' \
  '-version[version info]' \
  '-help[display help]' \
  '-hist[revision history]' && ret=0

return ret
