#compdef cargo-rustc
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-rustc.html

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --package)'{-p+,--package=}'[package to build]:package' \
  '--lib[build only library]' \
  '*--bin=[build only specified binary]:binary' \
  '--bins[build all binaries]' \
  '*--example=[build only specified example]:example' \
  '--examples[build all examples]' \
  '*--test=[build only specified test target]:test' \
  '--tests[build all test targets]' \
  '*--bench=[build only specified bench target]:bench' \
  '--benches[build all bench targets]' \
  '--all-targets[build all targets]' \
  '(-F --features)'{-F+,--features=}'[features to activate]:features' \
  '--all-features[activate all available features]' \
  '--no-default-features[do not activate default feature]' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:jobs' \
  '--keep-going[do not abort on first error]' \
  '(-r --release)'{-r,--release}'[build in release mode]' \
  '--profile=[build with specified profile]:profile' \
  '*--target=[build for target triple]:target' \
  '--target-dir=[directory for generated artifacts]:directory:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
  '--ignore-rust-version[ignore rust-version specification]' \
  '--message-format=[diagnostic format]:format:(human short json json-diagnostic-short json-diagnostic-rendered-ansi json-render-diagnostics)' \
  '--future-incompat-report[output future incompatibility report]' \
  '--print=[output compiler information without compiling]:info' \
  '--crate-type=[comma separated list of crate types]:crate-type' \
  '--timings=[output build timing info]:format:(html json)' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '*'{-v,--verbose}'[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[--locked + --offline]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
  '*-Z+[unstable cargo flag]:flag' \
  '*:extra rustc flags'
