#compdef cbstats
# Documentation: https://docs.couchbase.com/server/current/cli/cbstats-intro.html
# Couchbase per-node, per-bucket statistics retrieval tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --username)'{-u,--username}'+[REST username]:username:' \
  '(-p --password)'{-p,--password}'+[REST password]:password:' \
  '(-b --bucket)'{-b,--bucket}'+[bucket name]:bucket:' \
  '-S[read password from stdin]' \
  '-j[output result in JSON format]' \
  '-a[iterate over all buckets]' \
  '-8[use UTF8 symbols]' \
  '1:host\:port:_hosts' \
  '*:command:((all\:"memory, queue, persistence and vBucket stats" allocator\:"allocator stats" checkpoint\:"checkpoint data structure" config\:"bucket configuration stats" dcp\:"DCP stats" dcpagg\:"aggregated DCP stats" diskinfo\:"disk usage stats" hash\:"hash table stats" items\:"item stats" kvstore\:"kvstore stats" kvtimings\:"kvstore timing stats" memory\:"memory stats" prev-vbucket\:"previous vBucket state" raw\:"raw stat group" reset\:"reset stat counters" runtimes\:"runtime stats" scheduler\:"scheduler stats" slabs\:"slab allocator stats" tap\:"TAP stats" tapagg\:"aggregated TAP stats" timings\:"histogram timing stats" uuid\:"bucket UUID" vbucket\:"vBucket states" vbucket-details\:"detailed vBucket stats" vbucket-seqno\:"vBucket sequence numbers" vkey\:"single key stats" warmup\:"warmup stats" workload\:"workload stats"))' && ret=0

return ret
