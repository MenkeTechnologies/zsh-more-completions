#compdef sfgazdag
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mgazdag.c
# Madagascar: post-stack 2-D/3-D v(z) time modeling/migration with Gazdag phase-shift

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'inv=[if y, modeling; if n, migration]:flag:(y n)' \
  'eps=[stabilization parameter]:value' \
  'verb=[verbosity flag]:flag:(y n)' \
  'depth=[if true, depth migration]:flag:(y n)' \
  'nt=[length of time axis (for modeling)]:count' \
  'dt=[sampling of time axis (for modeling)]:value' \
  'nz=[length of depth axis (for migration)]:count' \
  'dz=[sampling of depth axis (for migration)]:value' \
  'rule=[phase-shift interpolation rule]:rule:(simple midpoint linear)' \
  'vel=[constant velocity (if no velocity file)]:velocity' \
  'vz=[constant vertical velocity (if no velocity file)]:velocity' \
  'n=[constant eta (if no velocity file)]:value' \
  'pad=[frequency sampling padding]:samples' \
  '*:RSF file:_files' && ret=0

return ret
