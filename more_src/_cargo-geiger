#compdef cargo-geiger

# Zsh completion for cargo-geiger (Rust unsafe code counter)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[package to inspect]:package' \
  '--package=[package to inspect]:package' \
  '--all[inspect all packages in workspace]' \
  '--workspace[inspect all packages in workspace]' \
  '--exclude=[exclude packages]:package' \
  '--all-deps[include all dependencies]' \
  '--build-deps[include build dependencies]' \
  '--dev-deps[include dev dependencies]' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '--features=[space-separated list of features]:features' \
  '--target=[filter dependencies for target triple]:target' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--forbid-only[only scan for forbid attributes]' \
  '--include-tests[include test code in metrics]' \
  '--update-readme[update README with safety report]' \
  '--readme-path=[path to README]:file:_files' \
  '--output-format=[output format]:format:(ascii json ratio)' \
  '--charset=[character set for output]:charset:(ascii utf8)' \
  '--color=[coloring]:when:(auto always never)' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '--frozen[require Cargo.lock is up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]'
