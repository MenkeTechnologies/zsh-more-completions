#compdef dmimgthresh
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmimgthresh.html
# Threshold the pixel values of an image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input image]:infile:_files' \
  'outfile=[output thresholded image]:outfile:_files' \
  'expfile=[exposure image]:expfile:_files' \
  'cut=[threshold value]:cut:' \
  'value=[value to set thresholded pixels]:value:' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
