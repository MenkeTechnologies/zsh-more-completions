#compdef eix-update
# Gentoo eix cache update tool

local ret=1

_arguments -s -S \
  '-q[quiet mode]' \
  '-o[output cache file]:file:_files' \
  '-x[exclude overlay]:overlay:' \
  '-A[add overlay]:directory:_files -/' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
