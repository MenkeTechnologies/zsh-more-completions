#compdef obsidian-export
# ============================================================================
#  _obsidian-export — obsidian-export: Obsidian vault → Markdown
#                     exporter (Nick Groenen, zoni/obsidian-export)
#
#  Source-direct extraction from
#    https://github.com/zoni/obsidian-export/blob/main/src/main.rs
#    https://github.com/murarth/gumdrop (the gumdrop library by
#    Murarth — author of ketos Lisp dialect for Rust)
#
#  Maintained by Nick "zoni" Groenen.  1,317 GH stars.  obsidian-
#  export is a Rust library AND CLI that converts an Obsidian
#  knowledge-vault into REGULAR MARKDOWN by resolving Obsidian's
#  [[wikilinks]], !embeds, %%comments%%, and frontmatter into
#  vanilla CommonMark/GFM-compatible Markdown suitable for hosting
#  on Hugo/Zola/Jekyll/Eleventy or feeding into any non-Obsidian
#  Markdown pipeline.  Handles recursive embed resolution, gitignore
#  honoring, tag-based filtering (--skip-tags / --only-tags), and
#  frontmatter strategy modes (always/never/auto).  Sister tools:
#  pandoc (in corpus via _pandoc + STOCK), obsidiantools (Python
#  Obsidian vault analyzer), foam (VS Code knowledge graph), dendron
#  (VS Code knowledge graph), logseq (Obsidian-like outliner), zola
#  (Rust static site gen — in corpus via _zola), hugo (in corpus
#  via _hugo), mdbook (Rust mdbook — in corpus via _mdbook).
#
#  CLI library taxonomy update: 12th Rust CLI library — Murarth's
#  **gumdrop** (murarth/gumdrop).  Rust ecosystem now has 12
#  documented CLI libraries — RE-TAKING THE SOLO LEAD as the MOST-
#  DOCUMENTED CLI LANGUAGE in the cross-language taxonomy ahead of
#  Go (11) and TypeScript-Node (11).  🎉 Rust BREAKS the THREE-WAY
#  TIE.
#
#  gumdrop (murarth/gumdrop) is Murarth's DERIVE-MACRO Rust arg
#  parser — designed as a LIGHTER alternative to clap_derive with
#  a SIMILAR `#[derive(Options)]` proc-macro API but ZERO
#  DEPENDENCIES on clap's heavy regex/textwrap/atty/strsim tree.
#  gumdrop's compiled size is ~150KB vs clap's ~600KB+ (per
#  `cargo bloat` measurements).  Used by zoni/obsidian-export
#  (Obsidian vault exporter, 1317 stars), tag1consulting/goose
#  (Rust load-testing framework inspired by Python's locust, 976
#  stars — IN CORPUS via _goose), murarth/ketos (Rust-embedded
#  Lisp dialect by gumdrop's same author, 768 stars), anp/moxie
#  (Adam Perry's reactive UI framework, 831 stars), NeroReflex/
#  asusctl (ASUS ROG laptop daemon, 391 stars), SpikeHD/Dorion
#  (lightweight Discord client in Tauri), cometbft/tendermint-rs
#  (Tendermint Rust impl), cometbft/cometbft-rs (CometBFT Rust),
#  zcash/zcash (Zcash node — uses gumdrop in wallet_tool.rs),
#  openmultiplayer/launcher (Open Multiplayer launcher), sylt-lang/
#  sylt-lang (Sylt language), Hirtol/Rustyboi (Rust Game Boy
#  emulator), Eraden/amdgpud (AMD GPU daemon), iamd3vil/hermes
#  (message broker), fooker/qd (queue daemon), and many other
#  Rust binaries that prefer derive-based parsing without clap's
#  weight.
#
#  gumdrop API:
#    use gumdrop::Options;
#
#    #[derive(Debug, Options)]
#    struct Opts {
#      #[options(help = "Display program help")]
#      help: bool,
#
#      #[options(help = "Display version information")]
#      version: bool,
#
#      // `free` marks this as a positional argument
#      // `required` marks it must be provided
#      #[options(help = "Read notes from this source",
#                free, required)]
#      source: Option<PathBuf>,
#
#      // `no_short` disables auto-generated short flag from
#      // first letter — only --start-at, no -s
#      #[options(no_short, help = "Only export under this sub-path")]
#      start_at: Option<PathBuf>,
#
#      // Custom parser function via `parse(try_from_str = "fn")`
#      // and per-flag default via `default = "auto"`
#      #[options(help = "Frontmatter strategy",
#                no_short,
#                long = "frontmatter",
#                parse(try_from_str = "frontmatter_strategy_from_str"),
#                default = "auto")]
#      frontmatter_strategy: FrontmatterStrategy,
#
#      // Vec<T> fields automatically become REPEATABLE flags
#      #[options(no_short, help = "Exclude files with this tag")]
#      skip_tags: Vec<String>,
#
#      #[options(no_short, help = "Export only files with this tag")]
#      only_tags: Vec<String>,
#    }
#
#    fn main() {
#      let args = Opts::parse_args_default_or_exit();
#      // args.source, args.start_at, etc.
#    }
#
#  gumdrop distinctive features:
#    - `#[derive(Options)]` proc-macro on a STRUCT — fields become
#      flags automatically; field NAMES become long flag names with
#      snake_case → kebab-case conversion (`frontmatter_strategy` →
#      `--frontmatter-strategy`)
#    - `#[options(help = "...")]` — required help text per field
#    - `#[options(short = 'X')]` — explicit short flag char
#    - `#[options(no_short)]` — disable auto-generated short flag
#      (default behavior is to use the first letter of the field
#      name as short flag, which causes conflicts; `no_short` opts
#      out)
#    - `#[options(long = "...")]` — explicit long flag name
#      override (otherwise field-name kebab-cased)
#    - `#[options(free)]` — positional (free) argument; `free,
#      required` makes it mandatory
#    - `#[options(default = "VALUE")]` — default value when flag
#      not provided
#    - `#[options(parse(try_from_str = "fn"))]` — custom parser
#      function for the field's value (must be a `&str -> Result<T,
#      E>`)
#    - `Vec<T>` field — automatically REPEATABLE (`--skip-tags foo
#      --skip-tags bar`); each occurrence appends
#    - `Option<T>` field — optional flag (gumdrop doesn't error if
#      not provided)
#    - `bool` field — boolean flag (presence = true)
#    - `#[derive(Options)] enum` — SUBCOMMAND dispatch; each variant
#      is a subcommand with its own nested `#[derive(Options)]`
#      struct
#    - `Opts::parse_args_default_or_exit()` — convenience: parse,
#      auto-print help on --help, exit with usage on error
#    - `Opts::parse_args_default(&args)?` — explicit parsing for
#      custom error handling
#    - `<Opts as Options>::usage()` — render help string from
#      derive metadata
#    - `ParsingStyle::AllOptions` / `ParsingStyle::StopAtFirstFree`
#      — option-vs-positional interleaving behavior (StopAtFirstFree
#      mimics getopt's POSIX_CORRECT mode)
#    - INSPIRED BY rustc's getopts internal style — Murarth wrote
#      gumdrop after writing ketos (Lisp dialect for Rust) and
#      finding clap_derive too heavy for ketos's CLI
#  Distinct from R275 Rust clap-derive (Kevin K.'s clap_derive proc-
#  macro — `#[derive(Parser)]` with attribute config; HEAVIER ~600KB
#  vs gumdrop's ~150KB compiled; full ANSI color rendering, suggest-
#  similar-flag, shell completion gen; powers ripgrep/bat/exa/fd/
#  etc.), R330 Rust bpaf (functional applicative combinator style —
#  no proc-macros, builder-style `Bpaf<T>` combinators), R344 Rust
#  google/argh (Google's Fuchsia-OS derive-on-struct — similar
#  philosophy to gumdrop but Google-maintained, used by Mozilla
#  glean, etc.), R347 Rust RazrFalcon/pico-args (LOW-LEVEL imperative
#  pull parser — `args.value_from_str("--flag")?`), R404 Rust
#  matklad/xflags (DECLARATIVE MACRO BLOCK SYNTAX with `cmd NAME {
#  ... }` blocks), R407 Rust blyxxyz/lexopt (MINIMAL iterator-based
#  pull parser — `while let Some(arg) = parser.next()?`).  Rust
#  documented libraries so far: clap-derive, bpaf, argh, pico-args,
#  xflags, lexopt, gumdrop... plus older clap-builder, getopts,
#  structopt (deprecated, now clap_derive)... gumdrop's
#  distinguishing feature vs other derive-based libs (clap_derive
#  & argh): gumdrop is ZERO-DEPENDENCY (clap brings 20+ transitive
#  deps; argh brings ~6) and AUTO-GENERATES SHORT FLAGS from field
#  names (caller opts out per-field with `no_short` — opposite of
#  clap_derive which auto-generates ONLY long flags and requires
#  explicit `#[arg(short)]`).  gumdrop's approach: DERIVE-MACRO
#  `#[derive(Options)]` proc-macro on struct + `#[options(help/
#  short/long/no_short/free/required/default/parse(try_from_str)/
#  count)]` per-field attributes + `Vec<T>` auto-repeatable + enum
#  derive for subcommand dispatch + `parse_args_default_or_exit()`
#  convenience entry + `ParsingStyle::AllOptions/StopAtFirstFree`
#  for POSIX interleaving + AUTO short-flag-from-field-name (opt
#  out with no_short) + ZERO transitive deps + ~150KB compiled size
#  — corpus's **first documented zero-dependency-derive-macro Rust
#  CLI library**.  Brings cross-language CLI library taxonomy
#  variant count to 149; Rust ecosystem now has 12 documented CLI
#  libraries — RE-TAKING THE SOLO LEAD as the MOST-DOCUMENTED CLI
#  LANGUAGE in the cross-language taxonomy ahead of Go (11) and
#  TypeScript-Node (11).
#
#  Surface (verbatim from `src/main.rs` `#[derive(Options)]` struct):
#
#  Usage:
#    obsidian-export [options] <source> <destination>
#
#  Positional (REQUIRED):
#    <source>                       Read notes from this Obsidian
#                                   vault directory
#    <destination>                  Write notes to this output
#                                   directory (will be created if
#                                   absent)
#
#  Options:
#    -h, --help                     Display program help
#    -v, --version                  Display version information
#                                   (BYPASS NOTE: special-cased in
#                                   main() with std::env::args
#                                   manual scan since `free,
#                                   required` source/destination
#                                   would otherwise error before
#                                   gumdrop sees --version)
#        --start-at <PATH>          Only export notes under this
#                                   sub-path of the source vault
#                                   (relative to source root)
#        --frontmatter <STRATEGY>   Frontmatter strategy — choices:
#                                   auto (default), always, never.
#                                   auto = preserve only existing
#                                   frontmatter; always = inject
#                                   empty frontmatter if absent;
#                                   never = strip all frontmatter
#        --ignore-file <NAME>       Read ignore patterns from files
#                                   with this name (Default:
#                                   .export-ignore)
#        --skip-tags <TAG>          Exclude files with this tag from
#                                   the export (repeatable —
#                                   accepts multiple --skip-tags
#                                   tag1 --skip-tags tag2)
#        --only-tags <TAG>          Export only files with this tag
#                                   (repeatable; mutex-ish with
#                                   --skip-tags)
#        --hidden                   Export hidden files (default:
#                                   skipped)
#        --no-git                   Disable git integration
#                                   (default: respect .gitignore in
#                                   vault root)
#        --no-recursive-embeds      Don't process embeds recursively
#                                   (breaks ![[note]] cycle
#                                   detection — use when you have
#                                   intentionally-circular embeds)
#        --preserve-mtime           Preserve the mtime of exported
#                                   files (default: mtime is set to
#                                   export time)
#        --hard-linebreaks          Convert soft line breaks to hard
#                                   line breaks (mimics Obsidian's
#                                   'Strict line breaks' setting —
#                                   adds `softbreaks_to_hardbreaks`
#                                   postprocessor)
#
#  Examples:
#    obsidian-export ~/Vault ~/output                                # Basic export
#    obsidian-export --start-at notes/blog ~/Vault ~/output          # Export subdirectory only
#    obsidian-export --frontmatter never ~/Vault ~/output            # Strip all frontmatter
#    obsidian-export --skip-tags private --skip-tags draft ~/V ~/o   # Exclude tagged notes
#    obsidian-export --only-tags published ~/V ~/o                   # Only export tagged notes
#    obsidian-export --hidden --no-git ~/V ~/o                       # Export everything
#    obsidian-export --hard-linebreaks ~/V ~/o                       # Strict line breaks
#    obsidian-export --no-recursive-embeds ~/V ~/o                   # Break embed cycles
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also gumdrop users):
#    - goose (IN CORPUS via _goose — Rust load-testing framework
#      976 stars; uses gumdrop in client.rs; already in corpus)
#    - hermes (IN CORPUS via _hermes — different `hermes` tool; the
#      gumdrop one is a niche message broker)
#    - ketos (murarth/ketos 768 stars — Rust-embedded Lisp dialect;
#      gumdrop's same-author project; FUTURE candidate)
#    - moxie (anp/moxie 831 stars — declarative UI; uses gumdrop in
#      ofl/website.rs build tool, not main moxie crate)
#    - asusctl (NeroReflex/asusctl 391 stars — ASUS ROG daemon;
#      FUTURE candidate but daemon flags)
#    - rsmodules (fretn/rsmodules — Rust port of environment-
#      modules; FUTURE candidate)
#    - dorion (SpikeHD/Dorion — lightweight Discord client in Tauri;
#      FUTURE candidate)
# ============================================================================

_obsidian-export() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[display program help]' \
    '(-v --version)'{-v,--version}'[display version information]' \
    '--start-at[only export notes under this sub-path]:path:_files -/' \
    '--frontmatter[frontmatter strategy]:strategy:(auto always never)' \
    '--ignore-file[read ignore patterns from files with this name]:filename:' \
    '*--skip-tags[exclude files with this tag from the export]:tag:' \
    '*--only-tags[export only files with this tag]:tag:' \
    '--hidden[export hidden files]' \
    '--no-git[disable git integration]' \
    '--no-recursive-embeds[do not process embeds recursively]' \
    '--preserve-mtime[preserve the mtime of exported files]' \
    '--hard-linebreaks[convert soft line breaks to hard line breaks]' \
    ':source:_files -/' \
    ':destination:_files -/'
}

_obsidian-export "$@"
