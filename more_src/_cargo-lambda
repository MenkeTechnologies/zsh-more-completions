#compdef cargo-lambda

_cargo-lambda_subcommands() {
  local -a subcmds=(
    'build:Compile a Lambda function'
    'deploy:Deploy a Lambda function'
    'init:Create a new Lambda project'
    'invoke:Invoke a Lambda function'
    'new:Create a new Lambda function'
    'start:Start a local Lambda emulator'
    'watch:Watch for changes and rebuild'
  )
  _describe -t commands 'cargo-lambda subcommand' subcmds
}

_cargo-lambda() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '--color[Coloring]:color:(auto always never)' \
    '1:subcommand:_cargo-lambda_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        build)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--release[Build in release mode]' \
            '--arm64[Build for ARM64 architecture]' \
            '--x86-64[Build for x86-64 architecture]' \
            '--output-format[Output format]:format:(zip binary)' \
            '--lambda-dir[Output directory for Lambda artifacts]:dir:_directories' \
            {-p,--package}'[Package to build]:package:' \
            '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
            '--target[Target triple]:target:' \
            '--features[Space-separated list of features]:features:' \
            '--all-features[Activate all features]' \
            '--no-default-features[Disable default features]' \
            '--profile[Build profile]:profile:' \
            '--extension[Include file extension in binary]:ext:' \
            '--flatten[Flatten binary into a single directory]' \
            '--internal[Build for internal extensions]' \
            '--compiler[Compiler to use]:compiler:(cargo cross cargo-zigbuild)' \
            '*:args:'
          ;;
        deploy)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--name[Function name]:name:' \
            '--region[AWS region]:region:' \
            '--iam-role[IAM role ARN]:role:' \
            '--memory[Memory size in MB]:memory:' \
            '--timeout[Timeout in seconds]:seconds:' \
            '--env-var[Environment variable]:var:' \
            '--env-file[Environment file]:file:_files' \
            '--runtime[Lambda runtime]:runtime:' \
            '--layer[Layer ARN to attach]:arn:' \
            '--s3-bucket[S3 bucket for code]:bucket:' \
            '--s3-key[S3 key for code]:key:' \
            '--tag[Tag for the function]:tag:' \
            '--tracing[Tracing mode]:mode:(Active PassThrough)' \
            '--binary-name[Binary name]:name:' \
            '--lambda-dir[Lambda artifacts directory]:dir:_directories' \
            '--enable-function-url[Enable Lambda function URL]' \
            '*:args:'
          ;;
        invoke)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--name[Function name]:name:' \
            '--region[AWS region]:region:' \
            '--data-file[Input data file]:file:_files' \
            '--data-ascii[Input data as string]:data:' \
            '--data-example[Use example event]:example:(api-gateway-v1 api-gateway-v2 sqs sns s3 cloudwatch-events)' \
            '--output-format[Output format]:format:(json)' \
            '--remote[Invoke remote function]'
          ;;
        start)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--host[Host to bind]:host:' \
            '--port[Port to listen on]:port:' \
            '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
            '--env-file[Environment file]:file:_files'
          ;;
        watch)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
            {-p,--package}'[Package to watch]:package:' \
            '--features[Features to enable]:features:' \
            '--all-features[Activate all features]' \
            '--no-default-features[Disable default features]'
          ;;
        new|init)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--http[Create an HTTP function]' \
            '--event-type[Type of event]:type:' \
            '--no-interactive[Skip interactive prompts]' \
            '1:name:'
          ;;
      esac
      ;;
  esac
}

_cargo-lambda "$@"
