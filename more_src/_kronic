#compdef kronic

# Zsh completion for kronic - simple Kubernetes CronJob Admin UI (CLI serving mode)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--port[HTTP port to listen on]:port' \
  '--host[bind host]:host' \
  '--namespace[namespace to operate in]:namespace' \
  '--kubeconfig[kubeconfig file path]:file:_files' \
  '--allow-namespaces[comma-separated list of allowed namespaces]:namespaces' \
  '--log-level[log level]:level:(debug info warn error)' && ret=0

return ret
