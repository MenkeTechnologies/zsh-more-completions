#compdef inferno-collapse-dtrace
# Documentation: https://man.archlinux.org/search?q=inferno-collapse-dtrace
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--includeoffset[include function offsets]' \
  '--skip-after=[skip frames after matching]:pattern' \
  '*:dtrace output:_files' && ret=0

return ret
