#compdef inferno-collapse-dtrace
# Documentation: https://github.com/jonhoo/inferno
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--includeoffset[include function offsets]' \
  '--skip-after=[skip frames after matching]:pattern' \
  '*:dtrace output:_files' && ret=0

return ret
