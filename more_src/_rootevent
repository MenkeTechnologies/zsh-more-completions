#compdef rootevent rooteventselector
# Documentation: https://github.com/root-project/root/blob/master/main/python/rooteventselector.py
# Reference accessed: 2026-05-27
# Verified: upstream main/python/rooteventselector.py argparse flag list and
# main/CMakeLists.txt — no standalone `rootevent` executable ships with ROOT.
# The canonical event-range copy tool is `rooteventselector`; this completion
# is bound to both names so an aliased `rootevent` still completes.

# rooteventselector — copy a range of events from one ROOT file/tree to another.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-c --compress)'{-c+,--compress=}'[change compression factor of destination file]:level:' \
  '--recreate[recreate the destination file]' \
  '(-f --first)'{-f+,--first=}'[first event to copy]:event:' \
  '(-l --last)'{-l+,--last=}'[last event to copy]:event:' \
  '(-s --selection)'{-s+,--selection=}'[filter expression applied to the output tree]:expression:' \
  '(-i --branchinclude)'{-i+,--branchinclude=}'[only write branches matching pattern]:pattern:' \
  '(-e --branchexclude)'{-e+,--branchexclude=}'[exclude branches matching pattern]:pattern:' \
  '*:source/destination:_files -g "*.root"' && ret=0

return ret
