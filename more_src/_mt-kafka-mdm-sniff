#compdef mt-kafka-mdm-sniff
# Inspect metrictank MetricData messages flowing through kafka

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-config=[configuration file path]:_files' \
  '-format-md=[template to render MetricData with]:template' \
  '-format-point=[template to render MetricPoint data with]:template' \
  '-invalid[show only invalid metrics]' \
  '-prefix=[show only metrics with this prefix]:prefix' \
  '-substr=[show only metrics with this substring]:substr' && ret=0

return ret
