#compdef f3fix
# Documentation: https://man.archlinux.org/search?q=f3fix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--disk-type=+[disk type]:type:' \
  '--fs-type=+[fs type]:type:(fat32 ext4 ntfs exfat)' \
  '--boot-type=+[boot type]:type:' \
  '--last-sec=+[last sector]:n:' \
  '--first-sec=+[first sector]:n:' \
  '*:device:_files' && ret=0

return ret
