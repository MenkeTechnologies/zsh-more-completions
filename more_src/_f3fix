#compdef f3fix
# Documentation: https://manpages.debian.org/testing/f3/f3fix.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--usage[show usage]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '(-a --first-sec)'{-a+,--first-sec=}'[first sector of the partition]:sec-num:' \
  '(-l --last-sec)'{-l+,--last-sec=}'[last sector of the partition]:sec-num:' \
  '(-d --disk-type)'{-d+,--disk-type=}'[disk type of partition table]:type:' \
  '(-f --fs-type)'{-f+,--fs-type=}'[file system type]:type:' \
  '(-b --boot -n --no-boot)'{-b,--boot}'[mark partition for boot]' \
  '(-b --boot -n --no-boot)'{-n,--no-boot}'[do not mark partition for boot]' \
  '(-k --list-disk-types)'{-k,--list-disk-types}'[list supported disk types]' \
  '(-s --list-fs-types)'{-s,--list-fs-types}'[list supported file system types]' \
  '*:device:_files' && ret=0

return ret
