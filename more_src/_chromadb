#compdef chromadb
# Documentation: https://docs.trychroma.com/docs/cli/install
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:start a Chroma server locally'
  'install:install a sample app'
  'update:update the CLI'
  'login:authenticate with Chroma Cloud'
  'browse:browse a Chroma database'
  'copy:copy data between databases'
  'db:Chroma Cloud database management'
  'profile:profile management'
  'vacuum:vacuum the database'
  'env:show environment info'
  'docs:open docs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chromadb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--path=[data persistence path]:dir:_files -/' \
          '--host=[hostname (default localhost)]:host:_hosts' \
          '--port=[port (default 8000)]:port:' \
          '--config_path=[config file]:file:_files -g "*.{yaml,yml}"' && ret=0 ;;
      (db)
        _arguments '*::sub:(list connect create delete)' && ret=0 ;;
      (profile)
        _arguments '*::sub:(list rename use show delete)' && ret=0 ;;
    esac ;;
esac

return ret
