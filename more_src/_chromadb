#compdef chromadb

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:start a Chroma server'
  'install:install Chroma components'
  'update:update Chroma'
  'login:authenticate with Chroma Cloud'
  'browse:browse a Chroma database'
  'copy:copy data between databases'
  'db:database management (list/create/connect/delete)'
  'profile:profile management'
  'vacuum:vacuum the database'
  'collections:collection management'
  'items:item-level operations'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chromadb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--path=[data directory]:dir:_files -/' \
          '--host=[bind host]:host:_hosts' \
          '--port=[bind port]:port:' \
          '--log-path=[log file]:file:_files' \
          '--config-path=[config file]:file:_files -g "*.{yaml,yml,json}"' \
          '--persist-directory=[persistence dir]:dir:_files -/' \
          '--workers=[worker count]:n:' \
          '--anonymized-telemetry=[telemetry]:bool:(true false)' \
          '--allow-reset=[allow client reset()]:bool:(true false)' && ret=0 ;;
      (db)
        _arguments '*::sub:(list connect create delete)' && ret=0 ;;
      (collections)
        _arguments '*::sub:(list count peek query create delete describe rename)' && ret=0 ;;
      (items)
        _arguments '*::sub:(count get peek query add update delete)' && ret=0 ;;
      (profile)
        _arguments '*::sub:(list create use show delete)' && ret=0 ;;
    esac ;;
esac

return ret
