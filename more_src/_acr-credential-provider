#compdef acr-credential-provider
# _acr-credential-provider — Azure Container Registry credential provider for Kubelet
# upstream: https://github.com/kubernetes-sigs/cloud-provider-azure
# Flags from cmd/acr-credential-provider/main.go on tip.

_acr-credential-provider() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-r --registry-mirror)'{-r,--registry-mirror=}'[mirror source registry host to target]:spec:' \
        '--ib-sni-name=[Identity Binding SNI server name]:name:' \
        '--ib-default-client=[Identity Binding default client]:id:' \
        '--ib-default-tenant=[Identity Binding default tenant]:id:' \
        '--ib-api-ip=[Identity Binding API IP]:ip:' \
        '--version[print version and exit]' \
        '*: :_files'
}

_acr-credential-provider "$@"
