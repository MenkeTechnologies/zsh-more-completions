#compdef xpquery
# Documentation: https://github.com/dmytro/zsh-compdef/blob/5b2c600c509cda1fb0a05a6055fdcb035c886616/_xpquery
# Reference accessed: 2026-05-21
# Verified: upstream completion source at the URL above. No public manpage
# exists; flags (-h, -n, -p) are taken from the original dmytro/zsh-compdef
# completion which itself was derived from xpquery --help output.

local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C -s \
  '(- *)-h[display help]' \
  '*-n[custom namespace]:namespace:->xmlns' \
  '-p[parse method]:method:(XML HTML SGML)' \
  '1: :->xpath' \
  '*: :_urls' \
  && return 0

case "$state" in
  xpath)
    _message -e xpath 'xpath expression'
  ;;
  xmlns)
    if compset -P '*[:]'; then
      _urls
    else
      if compset -S '[:]*'; then
        suf=()
      else
        suf=( -qS ':' )
      fi
      _message -e xmlns 'xmlns prefix'
    fi
  ;;
esac
