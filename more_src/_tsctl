#compdef tsctl
# Documentation: https://timesketch.org/guides/admin/admin-cli/
# Timesketch admin CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'tsctl command' \
      'list-users[list all users]' \
      'create-user[create or update a user]' \
      'enable-user[enable a user]' \
      'disable-user[disable a user]' \
      'make-admin[grant admin role]' \
      'revoke-admin[remove admin role]' \
      'grant-user[grant sketch access to a user]' \
      'grant-group[grant sketch access to a group]' \
      'help[show help]' \
      'version[show Timesketch and OpenSearch versions]' \
      'drop-db[remove all database tables]' \
      'list-sketches[list sketches]' \
      'show-mappings[show OpenSearch mappings]' \
      'list-groups[list all groups]' \
      'create-group[create a group]' \
      'delete-group[delete a group]' \
      'list-group-members[list group members]' \
      'add-group-member[add user to group]' \
      'remove-group-member[remove user from group]' \
      'import-search-templates[import search templates]' \
      'import-sigma-rules[import sigma rules]' \
      'list-sigma-rules[list sigma rules]' \
      'remove-sigma-rule[delete a sigma rule]' \
      'remove-all-sigma-rules[delete all sigma rules]' \
      'export-sigma-rules[export sigma rules]' \
      'info[show environment and dependency versions]' \
      'sketch-info[show sketch information]' \
      'sketch-label-stats[show label statistics]' \
      'event-details[show event data]' \
      'timeline-status[get/set timeline status]' \
      'validate-context-links-conf[validate context link YAML]' \
      'searchindex-info[show searchindex info]' \
      'searchindex-status[get/set searchindex status]' \
      'analyzer-stats[show analyzer statistics]' \
      'list-analyzer-runs[list analyzer runs]' \
      'manage-analyzer-run[manage analyzer runs]' \
      'celery-tasks-redis[check Celery tasks in Redis]' \
      'celery-tasks[show Celery tasks]' \
      'celery-revoke-task[revoke a Celery task]' \
      'list-config[list Flask configuration]' \
      'db[database migration commands]' && ret=0
    ;;
esac

return ret
