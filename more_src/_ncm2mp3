#compdef ncm2mp3
# Documentation: https://man.archlinux.org/search?q=ncm2mp3
# Reference accessed: 2026-05-16
# Source: cargo binstall ncm2mp3@0.3.1
# Probed via: completion zsh
# Repository: https://github.com/Johnserf-Seed/ncm2mp3

autoload -U is-at-least

_ncm2mp3() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--from-file=[Read additional input paths from a text file (one path per line; # comments and blank lines ignored)]:PATH:_files' \
'-o+[Output directory (defaults to the input'\''s parent directory)]:DIR:_files' \
'--output=[Output directory (defaults to the input'\''s parent directory)]:DIR:_files' \
'-t+[Filename template. When omitted, the original input filename is preserved (only the extension changes). Placeholders\: {artist} {album} {title} {format} {bitrate}. Forward slashes create subdirectories; the extension is appended automatically based on the detected audio format.]:TEMPLATE:_default' \
'--template=[Filename template. When omitted, the original input filename is preserved (only the extension changes). Placeholders\: {artist} {album} {title} {format} {bitrate}. Forward slashes create subdirectories; the extension is appended automatically based on the detected audio format.]:TEMPLATE:_default' \
'*--format=[Only process files whose internal format matches (e.g. mp3,flac). Can be repeated or comma-separated.]:FMT:_default' \
'*--exclude=[Glob pattern(s) for files to skip during directory collection. Can be repeated. Matches against the full path (e.g. --exclude '\''**/tmp/**'\'' --exclude '\''*.partial.ncm'\'').]:GLOB:_default' \
'--limit=[Stop after processing this many files (applied after --exclude and dedup; useful for smoke-testing a large library)]:N:_default' \
'-j+[Number of parallel workers (default\: number of CPU cores)]:N:_default' \
'--jobs=[Number of parallel workers (default\: number of CPU cores)]:N:_default' \
'(--overwrite)--on-conflict=[What to do when an output file already exists\: skip (default) / overwrite / rename (append -1, -2, ... until free)]:STRATEGY:(skip overwrite rename)' \
'--config=[Load defaults from this TOML file instead of the platform default (~/.config/ncm2mp3/config.toml or %APPDATA%\\ncm2mp3\\config.toml)]:PATH:_files' \
'--color=[When to emit ANSI color in per-file status lines\: auto (default; color when stderr is a TTY) / always / never. The NO_COLOR env var, if set, forces never.]:WHEN:(auto always never)' \
'-L+[UI language\: en or zh (default\: auto-detect from LANG/LC_ALL)]:LANG:(en zh)' \
'--lang=[UI language\: en or zh (default\: auto-detect from LANG/LC_ALL)]:LANG:(en zh)' \
'-r[Recurse into subdirectories when INPUT is a directory]' \
'--recursive[Recurse into subdirectories when INPUT is a directory]' \
'--no-tag[Do not write ID3/Vorbis tags or embed cover art]' \
'-F[Wrap each decrypted song in its own folder, and also drop the cover art as a separate cover.jpg/cover.png file inside it]' \
'--folder[Wrap each decrypted song in its own folder, and also drop the cover art as a separate cover.jpg/cover.png file inside it]' \
'--overwrite[Overwrite existing output files instead of skipping them (alias for --on-conflict overwrite)]' \
'(--config)--no-config[Skip loading any config file; use only command-line arguments and built-in defaults]' \
'--dry-run[Print what would be done without writing any output files]' \
'*-v[Increase log verbosity (-v for info, -vv for debug)]' \
'*--verbose[Increase log verbosity (-v for info, -vv for debug)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input .ncm file or a directory of .ncm files:_files' \
":: :_ncm2mp3_commands" \
"*::: :->ncm2mp3" \
&& ret=0
    case $state in
    (ncm2mp3)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:ncm2mp3-command-$line[2]:"
        case $line[2] in
            (info)
_arguments "${_arguments_options[@]}" : \
'-r[Recurse into subdirectories when INPUT is a directory]' \
'--recursive[Recurse into subdirectories when INPUT is a directory]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input .ncm file or a directory of .ncm files to inspect:_files' \
&& ret=0
;;
(cover)
_arguments "${_arguments_options[@]}" : \
'-o+[Output directory (defaults to the input'\''s parent directory)]:DIR:_files' \
'--output=[Output directory (defaults to the input'\''s parent directory)]:DIR:_files' \
'-r[Recurse into subdirectories when INPUT is a directory]' \
'--recursive[Recurse into subdirectories when INPUT is a directory]' \
'--overwrite[Overwrite existing output files instead of skipping them (alias for --on-conflict overwrite)]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input .ncm file or a directory of .ncm files whose covers should be extracted:_files' \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
'-o+[Output directory (defaults to the input'\''s parent directory)]:DIR:_files' \
'--output=[Output directory (defaults to the input'\''s parent directory)]:DIR:_files' \
'-t+[Filename template. When omitted, the original input filename is preserved (only the extension changes). Placeholders\: {artist} {album} {title} {format} {bitrate}. Forward slashes create subdirectories; the extension is appended automatically based on the detected audio format.]:TEMPLATE:_default' \
'--template=[Filename template. When omitted, the original input filename is preserved (only the extension changes). Placeholders\: {artist} {album} {title} {format} {bitrate}. Forward slashes create subdirectories; the extension is appended automatically based on the detected audio format.]:TEMPLATE:_default' \
'*--format=[Only process files whose internal format matches (e.g. mp3,flac). Can be repeated or comma-separated.]:FMT:_default' \
'--on-conflict=[What to do when an output file already exists\: skip (default) / overwrite / rename (append -1, -2, ... until free)]:STRATEGY:(skip overwrite rename)' \
'--no-tag[Do not write ID3/Vorbis tags or embed cover art]' \
'-F[Wrap each decrypted song in its own folder, and also drop the cover art as a separate cover.jpg/cover.png file inside it]' \
'--folder[Wrap each decrypted song in its own folder, and also drop the cover art as a separate cover.jpg/cover.png file inside it]' \
'-h[Print help]' \
'--help[Print help]' \
':dir -- Directory to watch (new .ncm files dropped here will be decrypted automatically):_files' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_ncm2mp3__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:ncm2mp3-help-command-$line[1]:"
        case $line[1] in
            (info)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(cover)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_ncm2mp3_commands] )) ||
_ncm2mp3_commands() {
    local commands; commands=(
'info:Inspect NCM file metadata without decrypting the audio' \
'cover:Extract the embedded cover image (cover.jpg/cover.png) without decrypting the audio' \
'watch:Watch a directory and auto-decrypt new .ncm files as they appear' \
'completion:Print a shell completion script to stdout (bash / zsh / fish / powershell / elvish)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'ncm2mp3 commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__completion_commands] )) ||
_ncm2mp3__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 completion commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__cover_commands] )) ||
_ncm2mp3__subcmd__cover_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 cover commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__help_commands] )) ||
_ncm2mp3__subcmd__help_commands() {
    local commands; commands=(
'info:Inspect NCM file metadata without decrypting the audio' \
'cover:Extract the embedded cover image (cover.jpg/cover.png) without decrypting the audio' \
'watch:Watch a directory and auto-decrypt new .ncm files as they appear' \
'completion:Print a shell completion script to stdout (bash / zsh / fish / powershell / elvish)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'ncm2mp3 help commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__help__subcmd__completion_commands] )) ||
_ncm2mp3__subcmd__help__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 help completion commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__help__subcmd__cover_commands] )) ||
_ncm2mp3__subcmd__help__subcmd__cover_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 help cover commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__help__subcmd__help_commands] )) ||
_ncm2mp3__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 help help commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__help__subcmd__info_commands] )) ||
_ncm2mp3__subcmd__help__subcmd__info_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 help info commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__help__subcmd__watch_commands] )) ||
_ncm2mp3__subcmd__help__subcmd__watch_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 help watch commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__info_commands] )) ||
_ncm2mp3__subcmd__info_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 info commands' commands "$@"
}
(( $+functions[_ncm2mp3__subcmd__watch_commands] )) ||
_ncm2mp3__subcmd__watch_commands() {
    local commands; commands=()
    _describe -t commands 'ncm2mp3 watch commands' commands "$@"
}

if [ "$funcstack[1]" = "_ncm2mp3" ]; then
    _ncm2mp3 "$@"
else
    compdef _ncm2mp3 ncm2mp3
fi
