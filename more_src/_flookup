#compdef flookup
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/flookup.txt
# Create a new FITS file from selection based on a lookup table

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "lookup=[lookup table file]:file:_files" \
  "tcolumn=[column in input table]:" \
  "lcolumn=[column in lookup table]:" \
  "lbcol=[lower bound column]:" \
  "ubcol=[upper bound column]:" \
  "column=[column to test]:" \
  "bounds=[bounds for selection]:" \
  "history=[add HISTORY keywords]:bool:(yes no)" \
  "copyall=[copy all other extensions]:bool:(yes no)" \
  "copyprime=[copy primary array]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
