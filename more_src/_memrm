#compdef memrm
# Documentation: https://man.archlinux.org/man/memrm.1.en
# Remove a key(s) from the server (libmemcached)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-q --quiet)'{-q,--quiet}'[operate quietly]' \
  '(-v --verbose)'{-v,--verbose}'[operate more verbosely]' \
  '(-d --debug)'{-d,--debug}'[enable debug/verbose mode]' \
  '(-e --expire)'{-e,--expire}'=[expiration seconds or UNIX timestamp]:expiration' \
  '(-H --hash)'{-H,--hash}'=[key hash algorithm]:algorithm' \
  '(-s --servers)'{-s,--servers}'=[server list as hostname[:port][,...]]:servers' \
  '(-n --non-blocking)'{-n,--non-blocking}'[enable non-blocking operations]' \
  '(-N --tcp-nodelay)'{-N,--tcp-nodelay}'[disable Nagle'\''s algorithm]' \
  '(-b --binary)'{-b,--binary}'[enable binary protocol]' \
  '(-B --buffer)'{-B,--buffer}'[buffer requests]' \
  '(-u --username)'{-u,--username}'=[SASL username]:username' \
  '(-p --password)'{-p,--password}'=[SASL password]:password' \
  '*:key:_default' && ret=0

return ret
