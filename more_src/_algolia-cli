#compdef algolia-cli
# _algolia-cli — Algolia search platform CLI (Algolia, Go); spf13/cobra
# upstream: https://github.com/algolia/cli

_algolia-cli() {
    local -a sub=(
        'apikeys:manage API keys'
        'application:manage applications'
        'config:manage CLI config'
        'dictionary:manage dictionaries'
        'events:tail/explore events'
        'indices:manage indices'
        'objects:manage records'
        'profile:manage profiles'
        'rules:manage query rules'
        'search:search an index'
        'settings:manage index settings'
        'synonyms:manage synonyms'
        'transformations:manage transformations'
        'completion:generate shell completion'
        'open:open dashboard'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--profile=+[profile]:profile:' \
        '--config=+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'algolia subcommand' sub ;;
        args)
            case $words[1] in
                apikeys) _arguments '1:cmd:(create delete list update restore)' '*:arg:' ;;
                application) _arguments '1:cmd:(list show)' '*:arg:' ;;
                config) _arguments '1:cmd:(get set list reset)' '*:arg:' ;;
                dictionary) _arguments '1:cmd:(import export search replace)' '*:arg:' ;;
                events) _arguments '1:cmd:(tail explore validate)' '*:arg:' ;;
                indices) _arguments \
                    '1:cmd:(list delete clear copy move config browse import export configdiff configimport configexport)' \
                    '*:arg:' ;;
                objects) _arguments \
                    '1:cmd:(browse delete get import partial-update partial-update-by replace)' \
                    '*:arg:' ;;
                profile) _arguments '1:cmd:(add list remove default)' '*:arg:' ;;
                rules) _arguments '1:cmd:(browse delete import save search)' '*:arg:' ;;
                settings) _arguments '1:cmd:(get import set)' '*:arg:' ;;
                synonyms) _arguments '1:cmd:(browse delete import save search)' '*:arg:' ;;
                transformations) _arguments '1:cmd:(list create delete try update)' '*:arg:' ;;
                search) _arguments \
                    '1:index:' \
                    '--query=+[query]:str:' \
                    '--filters=+[filters]:str:' \
                    '--facets=+[facets]:list:' \
                    '--hits-per-page=+[hits per page]:n:' \
                    '--params=+[params]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                open) _arguments '1:item:(dashboard docs)' ;;
            esac
            ;;
    esac
}

_algolia-cli "$@"
