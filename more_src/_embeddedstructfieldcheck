#compdef embeddedstructfieldcheck
# Documentation: https://github.com/manuelarte/embeddedstructfieldcheck
# checks for embedded struct fields conventions in Go source

local ret=1

_arguments -s -S \
  '-V[print version and exit]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-debug=[debug flags, any subset of fpstv]:flags:' \
  '-empty-line=[check empty line between embedded and regular fields]:bool:(true false)' \
  '-fix[fix missing empty line between embedded and regular fields]' \
  '-flags[print analyzer flags in JSON]' \
  '-forbid-mutex=[check that sync.Mutex/RWMutex are not used as embedded fields]:bool:(true false)' \
  '-json[emit JSON output]' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-trace=[write trace log to file]:file:_files' \
  '*:packages:_files' && ret=0

return ret
