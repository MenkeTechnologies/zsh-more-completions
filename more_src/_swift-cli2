#compdef swift-cli2
# _swift-cli2 — Apple Swift language top-level CLI alias (Apple, Swift); custom argparse
# upstream: https://github.com/apple/swift

_swift-cli2() {
    local -a sub=(
        'build:build Swift package'
        'run:run an executable'
        'test:run Swift package tests'
        'package:Swift package manager commands'
        'repl:start Swift REPL'
        'demangle:demangle Swift symbols'
        'inspect:inspect Swift package'
        'sdk:Swift SDK commands'
        'driver:Swift compiler driver'
        'frontend:Swift compiler frontend'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--toolchain=+[toolchain]:str:' \
        '--sdk=+[SDK]:str:' \
        '--triple=+[triple]:str:' \
        '--swift-version=+[swift version]:str:' \
        '-Xfrontend=+[frontend flag]:str:' \
        '-Xlinker=+[linker flag]:str:' \
        '-Xcc=+[cc flag]:str:' \
        '-Xcxx=+[cxx flag]:str:' \
        '-Xllvm=+[llvm flag]:str:' \
        '-Xswiftc=+[swiftc flag]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swift subcommand' sub
            _files -g "*.swift" ;;
        args)
            case $words[1] in
                build|run|test) _arguments \
                    '-c+[configuration]:c:(debug release)' \
                    '--configuration=+[configuration]:c:(debug release)' \
                    '--product=+[product]:str:' \
                    '--target=+[target]:str:' \
                    '--jobs=+[parallel jobs]:n:' \
                    '-j+[parallel jobs]:n:' \
                    '--enable-test-discovery[enable test discovery]' \
                    '--enable-code-coverage[enable code coverage]' \
                    '--show-bin-path[show bin path]' \
                    '--build-tests[build tests]' \
                    '--parallel[parallel tests]' \
                    '--num-workers=+[num workers]:n:' \
                    '--filter=+[test filter]:str:' \
                    '--skip=+[test skip]:str:' \
                    '*:arg:' ;;
                package) _arguments \
                    '1:cmd:(add-dependency add-product add-target archive-source clean compute-checksum config describe diagnose-api-breaking-changes dump-package dump-symbol-graph edit experimental-install experimental-uninstall generate-documentation init install plugin purge-cache reset resolve show-dependencies show-executables tools-version unedit update list-installed)' \
                    '*:arg:' ;;
                demangle) _arguments \
                    '--simplified[simplified]' \
                    '--remangle[remangle]' \
                    '--remangle-objc[remangle objc]' \
                    '--remangle-rust[remangle rust]' \
                    '--no-simplify[no simplify]' \
                    '--qualified[qualified]' \
                    '*:symbol:' ;;
                inspect) _arguments \
                    '--type=+[type]:t:(text json yaml)' \
                    '*:target:' ;;
                repl) _arguments \
                    '-I+[include path]:dir:_files -/' \
                    '-L+[library path]:dir:_files -/' \
                    '-l+[library]:str:' \
                    '-D+[define]:str:' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_swift-cli2 "$@"
