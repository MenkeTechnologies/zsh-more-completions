#compdef rz-asm rzasm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-hh[show extended help]' \
  '(- *)-v[show version]' \
  '-a+[set architecture]:arch:(x86 arm arm64 mips ppc sparc avr msp430 8051 m68k riscv java z80 z8a 6502 cris dalvik gb h8300 lh5801 lm32 m680x mcore mips_simple null_arch)' \
  '-A[show analysis info from hexpairs]' \
  '-b+[register/word size]:bits:(8 16 32 64)' \
  '-B[binary input/output (use with -l)]' \
  '-c+[select specific CPU]:cpu:' \
  '-C[output in C format]' \
  '-d[disassemble hexpair bytes]' \
  '-D[disassemble (show hexpairs)]' \
  '-e[use big endian]' \
  '-E[display ESIL expression]' \
  '-I[display lifted RzIL code]' \
  '-f+[read data from file]:file:_files' \
  '-F+[input/output filters]:filter (in\:out):' \
  '-i+[ignore N input bytes]:n:' \
  '-j[JSON output]' \
  '-k+[select operating system kernel]:kernel:' \
  '-l+[input/output length]:len:' \
  '-L[list asm plugins]' \
  '-m+[list CPUs for plugin]:plugin:' \
  '-o+[start address for code]:addr:' \
  '-@+[start address (alias)]:addr:' \
  '-p[show position-independent encoding]' \
  '-q[quiet]' \
  '-R[output relocatable]' \
  '-s+[syntax]:syntax:(intel att masm jz)' \
  '-w[show what it does]' \
  '*::code:' && ret=0

return ret
