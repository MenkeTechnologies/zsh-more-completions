#compdef uvindex
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvindex.html
# MIRIAD uvindex - summarize contents of a uv dataset

local ret=1

_arguments -s -S \
  'vis=[input visibility file to scan]:vis:_files' \
  'interval=[interval in minutes to reissue source info]:interval' \
  'log=[destination for output messages]:log:_files' \
  'options=[mosaic]:options' \
  '*:visibility data:_files' && ret=0

return ret
