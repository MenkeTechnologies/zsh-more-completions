#compdef hostnamectl-cli
# _hostnamectl-cli — systemd hostnamectl query and set system hostname CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_hostnamectl-cli() {
    local -a sub=(
        'status:show system hostname/info'
        'hostname:get/set static hostname'
        'icon-name:get/set icon name'
        'chassis:get/set chassis type'
        'deployment:get/set deployment'
        'location:get/set location'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--no-ask-password[no ask password]' \
        '--static[set static hostname only]' \
        '--transient[set transient hostname only]' \
        '--pretty[set pretty hostname]' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '--no-pager[no pager]' \
        '--json=+[mode]:m:(short pretty off)' \
        '-j[json short]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hostnamectl subcommand' sub ;;
        args)
            case $words[1] in
                chassis) _arguments '1:type:(desktop laptop convertible server tablet handset watch embedded vm container)' ;;
            esac
            ;;
    esac
}

_hostnamectl-cli "$@"
