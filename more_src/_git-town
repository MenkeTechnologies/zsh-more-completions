#compdef git-town

_git-town() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-h,--help}'[Print help information]'
        {-v,--verbose}'[Display all Git commands run under the hood]'
        '--dry-run[Print but do not run Git commands]'
        {-V,--version}'[Print version information]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'append:Create a new feature branch as a child of the current branch'
                'completions:Generate shell completion scripts'
                'config:Display or update your Git Town configuration'
                'contribute:Mark a branch as a contribution branch'
                'diff-parent:Show the diff between a branch and its parent'
                'hack:Create a new feature branch off the main branch'
                'kill:Remove a feature branch'
                'new-pull-request:Create a new pull request'
                'observe:Mark a branch as an observed branch'
                'offline:Toggle offline mode'
                'park:Mark a branch as parked'
                'prepend:Create a new feature branch between the current branch and its parent'
                'propose:Create a proposal for the current branch'
                'rename-branch:Rename a branch'
                'repo:Open the repository homepage in the browser'
                'set-parent:Set the parent branch of the current branch'
                'ship:Deliver a completed feature branch'
                'switch:Switch to another branch'
                'sync:Synchronize the current branch with its tracking and parent branches'
                'undo:Undo the most recent Git Town command'
                'version:Display the installed version of Git Town'
            )
            _describe -t commands 'git-town command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:git-town-$words[1]:
            case $words[1] in
                (hack)
                    _arguments -s -S \
                        $global_opts \
                        '--prototype[Create a prototype branch]' \
                        {-d,--detached}'[Do not sync before creating the branch]' \
                        ':branch name:' && ret=0
                    ;;
                (ship)
                    _arguments -s -S \
                        $global_opts \
                        {-m,--message}'[Specify the commit message]:message:' \
                        '--to-parent[Ship to the parent branch]' \
                        ':branch:' && ret=0
                    ;;
                (sync)
                    _arguments -s -S \
                        $global_opts \
                        '--all[Sync all local branches]' \
                        '--dry-run[Print but do not run Git commands]' \
                        '--stack[Sync the entire branch stack]' \
                        '--no-push[Do not push updated branches to the remote]' && ret=0
                    ;;
                (propose)
                    _arguments -s -S \
                        $global_opts \
                        '--body[Body for the proposal]:body:' \
                        '--body-file[Path to a file containing the proposal body]:file:_files' \
                        '--title[Title for the proposal]:title:' \
                        '--draft[Create a draft proposal]' \
                        '--no-push[Do not push the branch before creating the proposal]' && ret=0
                    ;;
                (config)
                    _arguments -s -S \
                        $global_opts \
                        '1:subcommand:->config_cmd' && ret=0
                    case $state in
                        (config_cmd)
                            local -a subcmds=(
                                'setup:Run the interactive configuration wizard'
                            )
                            _describe -t commands 'config subcommand' subcmds && ret=0
                            ;;
                    esac
                    ;;
                (append|prepend)
                    _arguments -s -S \
                        $global_opts \
                        ':branch name:' && ret=0
                    ;;
                (rename-branch)
                    _arguments -s -S \
                        $global_opts \
                        '--force[Rename even if a branch with the new name already exists]' \
                        ':old name:' \
                        ':new name:' && ret=0
                    ;;
                (kill)
                    _arguments -s -S \
                        $global_opts \
                        ':branch:' && ret=0
                    ;;
                (set-parent)
                    _arguments -s -S \
                        $global_opts \
                        ':parent branch:' && ret=0
                    ;;
                (diff-parent)
                    _arguments -s -S \
                        $global_opts \
                        ':branch:' && ret=0
                    ;;
                (completions|contribute|observe|offline|park|repo|switch|undo|version|new-pull-request)
                    _arguments -s -S $global_opts && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_git-town "$@"
