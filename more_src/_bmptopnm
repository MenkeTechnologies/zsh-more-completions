#compdef bmptopnm
# Documentation: man bmptopnm (Netpbm)
# Source: convert a Windows / OS-2 BMP file to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:bmp file:_files -g "*.bmp"' \
    && ret=0

return ret
