#compdef sftools
# sftools — interactive structure factor manipulation toolkit (CCP4)

local ret=1

_arguments -s -S \
  'READ[load structure factor file]' \
  'WRITE[save structure factor file]' \
  'MAPIN[read electron density map]' \
  'MAPOUT[write electron density map]' \
  'LIST[display database contents]' \
  'CHECKHKL[verify indices and report statistics]' \
  'COMPLETE[assess data completeness]' \
  'CORREL[correlation between columns]' \
  'PHASHFT[measure phase differences]' \
  'MAPSTAT[analyze map properties]' \
  'SELECT[filter reflections by criteria]' \
  'CALC[arithmetic on columns]' \
  'ABSENT[flag missing data]' \
  'DELETE[remove columns or maps]' \
  'PURGE[remove reflections]' \
  'SORT[reorder reflections]' \
  'MERGE[combine identical reflections]' \
  'FFT[generate maps from structure factors]' \
  'MAP2SF[structure factors from maps]' \
  'REINDEX[transform reflection indices]' \
  'REDUCE[enforce asymmetric unit]' \
  'EXPAND[reduce symmetry]' \
  'RFREE[create test set flags]' \
  'SET[modify header information]' \
  'PLOT[prepare data for graphing]' \
  'STOP[exit program]' \
  '*:argument:_files' && ret=0

return ret
