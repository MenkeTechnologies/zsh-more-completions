#compdef djview djview4

# Completion for djview - DjVu document viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-page=[start at page]:page number' \
  '-zoom=[zoom level]:zoom:(fit width page 50 75 100 150 200 300)' \
  '-continuous[continuous mode]' \
  '-sidebyside[side-by-side mode]' \
  '-fullscreen[start fullscreen]' \
  '-geometry=[window geometry]:geometry (WxH+X+Y)' \
  '-display=[X display]:display:_x_display' \
  '1:file:_files -g "*.{djvu,djv}"' && ret=0

return ret
