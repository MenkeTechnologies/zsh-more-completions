#compdef sequelize sequelize-cli

# Zsh completion for Sequelize CLI

_sequelize-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'db\:migrate:run pending migrations'
    'db\:migrate\:schema\:timestamps\:add:update migration table to have timestamps'
    'db\:migrate\:status:list the status of all migrations'
    'db\:migrate\:undo:reverts a migration'
    'db\:migrate\:undo\:all:revert all migrations'
    'db\:seed:run specified seeder'
    'db\:seed\:undo:deletes data from the database'
    'db\:seed\:all:run every seeder'
    'db\:seed\:undo\:all:deletes data from the database'
    'db\:create:create database specified by configuration'
    'db\:drop:drop database specified by configuration'
    'init:initializes project'
    'init\:config:initializes configuration'
    'init\:migrations:initializes migrations'
    'init\:models:initializes models'
    'init\:seeders:initializes seeders'
    'migration\:generate:generates a new migration file'
    'model\:generate:generates a model and its migration'
    'seed\:generate:generates a new seed file'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'sequelize command' commands && ret=0
      ;;
    (args)
      _arguments -s -S \
        '--name=[name]:name:' \
        '--attributes=[model attributes]:attributes:' \
        '--env=[environment]:environment:(development test production)' \
        '--config=[config file]:config file:_files -g "*.{json,js}"' \
        '--options-path=[options path]:file:_files' \
        '--migrations-path=[migrations directory]:directory:_files -/' \
        '--seeders-path=[seeders directory]:directory:_files -/' \
        '--models-path=[models directory]:directory:_files -/' \
        '--url=[database URL]:URL:' \
        '--debug[show debug messages]' \
        '--underscored[use snake_case for timestamps]' \
        '--force[overwrite files]' \
        '--to=[migration to run to]:migration name:' \
        '--from=[migration to start from]:migration name:' \
        '--seed=[specific seeder to run]:seeder name:' \
        '--charset=[database charset]:charset:' \
        '--collate=[database collation]:collation:' \
        '--encoding=[database encoding]:encoding:' \
        '--help[display help]' \
        '--version[display version]' \
        && ret=0
      ;;
  esac

  return ret
}

_sequelize-cli "$@"
