#compdef packcc
# Documentation: https://github.com/arithy/packcc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'+[output base name]:name:' \
  '(-I --import)'{-I,--import}'+[import search path]:dir:_files -/' \
  '(-a --ascii)'{-a,--ascii}'[ASCII input]' \
  '(-u --utf8)'{-u,--utf8}'[UTF-8 input]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-l --lines)'{-l,--lines}'[generate line directives]' \
  '*:peg_file:_files -g "*.peg"' && ret=0

return ret
