#compdef packcc
# Documentation: https://github.com/arithy/packcc
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output base name]:name:' \
  '(-I --import)'{-I+,--import=}'[import search directory]:dir:_files -/' \
  '(-a --ascii)'{-a,--ascii}'[disable UTF-8, ASCII only]' \
  '(-l --lines)'{-l,--lines}'[generate line directives]' \
  '*:peg_file:_files -g "*.peg"' && ret=0

return ret
