#compdef languagetool

# Completion for languagetool - Grammar and style checker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--list[list supported languages]' \
  {-l,--language}'=[language code]:language:(en-US en-GB de-DE fr es pt-BR nl pl ru it ca uk zh ja ko)' \
  {-m,--mothertongue}'=[mother tongue language]:language:(en-US en-GB de-DE fr es pt-BR nl pl ru it)' \
  {-d,--disable}'=[comma-separated rule IDs to disable]:rules' \
  {-e,--enable}'=[comma-separated rule IDs to enable]:rules' \
  '--enabledonly[only check enabled rules]' \
  {-c,--encoding}'=[input encoding]:encoding:(utf-8 iso-8859-1 iso-8859-15 ascii)' \
  {-a,--apply}'[auto-apply suggestions]' \
  '--autoDetect[auto-detect language]' \
  {-b,--bitext}'[bitext mode]' \
  '--api[output as XML]' \
  '--json[output as JSON]' \
  {-p,--port}'=[start as HTTP server on port]:port' \
  '--allow-origin=[allow origin for HTTP server]:origin' \
  {-v,--verbose}'[verbose output]' \
  '*:files:_files' && ret=0

return ret
