#compdef endbasic
# ============================================================================
# _endbasic — zsh completion for Julio Merino's EndBASIC, a modern
#              BASIC environment with REPL + graphical console + RPi
#              GPIO support (157th language entry — triple-900 commit
#              landmark on R900)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/endbasic/endbasic
#   Website    : https://www.endbasic.dev
#   Author     : Julio Merino  <jmmv@endbasic.dev>
#   License    : AGPL-3.0-or-later
#   Stars      : 369
#   Language   : Rust (interpreter) / EndBASIC (.bas source files)
#   Crate      : endbasic v0.13.99  (workspace member under cli/)
#   Binary     : endbasic  (cli/Cargo.toml [package] name =
#                "endbasic", built from cli/src/main.rs)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   EndBASIC is "a BASIC environment with a REPL, a web interface, a
#   graphical console, and Raspberry Pi support" — Julio Merino's
#   modern dialect of the early-1980s home-computer BASIC, designed
#   for learning programming.  The same binary runs as a terminal
#   REPL, as a script-runner, as an SDL2-driven graphical console
#   (full-screen or windowed, with custom resolution / fonts /
#   colors), as a low-power ST7735S LCD console on a Raspberry Pi,
#   and through a separate web build.  GPIO pins are exposed
#   directly to BASIC programs through `mock` / `noop` / `rppal`
#   backends, so an EndBASIC program can blink an LED on a Pi
#   without leaving the language.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cli/src/main.rs `app_build`
#                       getoptsargs Builder + `app_main` arg_trail
#                       dispatcher)
#   endbasic [OPTIONS] [<program-file>]
#
#   Options:
#     -i, --interactive           Force interactive mode when running
#                                 a script (load the script, then
#                                 drop into the REPL)
#         --console <SPEC>        Type and properties of the console.
#                                 CONSOLE-SPEC syntax:
#                                   text                  Text-based
#                                                         (default)
#                                   sdl[:SPEC]            Graphical
#                                                         console.
#                                     SPEC =
#                                       resolution=RES,
#                                       fg_color=COLOR,
#                                       bg_color=COLOR,
#                                       font_path=TTF,
#                                       font_size=SIZE
#                                     RES = `fs` |
#                                           `WIDTHxHEIGHT` |
#                                           `WIDTHxHEIGHTfs`
#                                   st7735s[:SPEC]        ST7735S LCD
#                                                         (RPi feature)
#                                     SPEC =
#                                       fg_color=COLOR,
#                                       bg_color=COLOR,
#                                       font=NAME
#         --gpio-pins <SPEC>      GPIO pins backend:
#                                   mock                  Test mock
#                                   noop                  No-op (default
#                                                         off-RPi)
#                                   rppal                 Raspberry Pi
#                                                         hardware
#                                                         (default on
#                                                         RPi)
#         --local-drive <URI>     Location of the drive to mount as
#                                 LOCAL (defaults to
#                                 file://$XDG_DOCUMENTS_DIR/endbasic
#                                 or ~/Documents/endbasic)
#         --service-url <URL>     Base URL of the EndBASIC cloud
#                                 service for LOAD/SAVE
#                                 (default: production cloud)
#
#   Positional:
#     <program-file>              Script to execute without entering
#                                 interactive mode (when absent,
#                                 starts the REPL directly).  Combine
#                                 with `--interactive` to load the
#                                 script then drop into the REPL.
#
#   Standard getoptsargs auto-flags (from the `tokio_app!` macro):
#     -h, --help                  Show help (with the CONSOLE-SPEC and
#                                 GPIO-PINS-SPEC extra-help block from
#                                 `app_extra_help`)
#         --version               Show version
#
# LANGUAGE-CORPUS POSITION
#   EndBASIC is the 157th programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R897 (_vigil
#   / lettre 0.11 Rust=132 OPENS Axis 77 SMTP / Email Client Library)
#   and continued through R898 (_paperboy / wneessen/go-mail v0.7.2
#   Go=132) and R899 (_bulkmail / nodemailer ^6.4.2 TS-Node=132
#   CLOSES Axis 77 at 1/1/1 three-language symmetry — triple-132
#   landmark and 70th axis closed).  R900 is the TRIPLE-900 COMMIT
#   LANDMARK — round-number triple-nine milestone.  EndBASIC joins
#   goboscript (R896 156th), Alan (R892 155th), Mech (R888 154th —
#   triple-8 landmark), Lisette (R884 153rd), Bril (R880 152nd),
#   Vyxal (R876 151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th), Mochi
#   (R860 147th), Oden (R856 146th), Hop (R852 145th), Lustre via
#   Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ (R840 142nd),
#   Granule (R836 141st), Sixten (R832 140th), Imba (R828 139th),
#   Tao (R824 138th), Dada (R820 137th), Acton (R816 136th), and
#   Stanza (R812 135th).
#
#   No completion for `endbasic` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_endbasic() {
    _arguments -s \
        '(-i --interactive)'{-i,--interactive}'[force interactive mode when running a script]' \
        '--console=[type and properties of the console]:console spec:(text sdl st7735s)' \
        '--gpio-pins=[GPIO pins backend]:backend:(mock noop rppal)' \
        '--local-drive=[location of drive to mount as LOCAL]:URI:' \
        '--service-url=[base URL of the EndBASIC cloud service]:URL:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*:script to execute:_files -g "*.bas"'
}

_endbasic "$@"
