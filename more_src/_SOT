#compdef SOT
# Documentation: https://github.com/NiklasJavier/SOT
# Reference accessed: 2026-05-16
# Verified: NiklasJavier/SOT lib/cli/registry.sh + lib/cli/aliases.sh.
# This is "Server Operation Toolkit" (capital SOT) — not the lowercase
# `sot` Python observability tool on PyPI.
# Removed from prior file: bogus man.archlinux.org search URL;
# the entire prior file was the upstream registry.sh script embedded
# verbatim (a generator bug — not a zsh completion at all).

# SOT: Server Operation Toolkit (bash CLI registry)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'setup:run server configuration (--check, --tags)'
  'vault:edit vault interactively'
  'runner:run ansible/terraform'
  'maintenance:maintenance subcommands (update/delete/cleanup_old_users)'
  'integrations:AAT/TID sync (aat_sync/tid_sync/validate)'
  'extensions:manage extensions (install etc.)'
  'plugins:manage plugins'
  'update:update SOT'
  'doctor:run health checks'
  'aliases:show all aliases'
  'help:show help on a command'
  'u:alias for update'
  'd:alias for doctor'
  'ex:alias for extensions'
  'v:alias for vault edit'
)

_arguments -C \
  '(- *)--interactive[start interactive menu]' \
  '--completion=[generate shell completion]:shell:(bash zsh)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'SOT command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup) _arguments '--check[dry run]' '--tags=[comma-separated tags]:tags:' && ret=0 ;;
      (maintenance) _values 'maintenance subcommand' 'update' 'delete' 'cleanup_old_users' && ret=0 ;;
      (integrations) _values 'integrations subcommand' 'aat_sync' 'tid_sync' 'validate' && ret=0 ;;
      (runner) _values 'runner backend' 'ansible' 'terraform' && ret=0 ;;
      (extensions|ex) _values 'extensions subcommand' 'install' && ret=0 ;;
      (help) _describe -t cmds 'help on command' commands && ret=0 ;;
    esac
    ;;
esac
return ret
