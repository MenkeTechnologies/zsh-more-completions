#compdef cosign-conformance
# _cosign-conformance — sigstore conformance test driver for cosign (sigstore/cosign)
# upstream: https://github.com/sigstore/cosign
# Flags from cmd/conformance/main.go.

_cosign-conformance() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                sign-bundle:'create a sigstore bundle for a file'
                verify-bundle:'verify a sigstore bundle for a file'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                sign-bundle)
                    _arguments \
                        '--staging[use the public staging instance]' \
                        '--in-toto[produce an in-toto bundle]' \
                        '--identity-token=[OIDC identity token]:token:' \
                        '--signing-config=[signing config file]:file:_files' \
                        '--trusted-root=[trusted root file]:file:_files' \
                        '--bundle=[output bundle path]:file:_files' \
                        '1:input file:_files' ;;
                verify-bundle)
                    _arguments \
                        '--staging[use the public staging instance]' \
                        '--bundle=[bundle file to verify]:file:_files' \
                        '--certificate-identity=[expected certificate identity]:identity:' \
                        '--certificate-oidc-issuer=[expected OIDC issuer URL]:url:_urls' \
                        '--key=[verification public key]:file:_files' \
                        '--trusted-root=[trusted root file]:file:_files' \
                        '1:signed file:_files' ;;
            esac
            ;;
    esac
}

_cosign-conformance "$@"
