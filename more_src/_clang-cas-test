#compdef clang-cas-test
# Documentation: https://man.archlinux.org/search?q=clang-cas-test
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--color[use colors in output]' \
  '*:input file:_files' && ret=0

return ret
