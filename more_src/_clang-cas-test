#compdef clang-cas-test
# Documentation: https://github.com/swiftlang/llvm-project/tree/next/clang/tools/clang-cas-test
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '-cas=[on-disk CAS path]:path:_files -/' \
  '-fcas-plugin-path=[path to plugin CAS library]:path:_files' \
  '*-fcas-plugin-option=[plugin CAS option]:option' \
  '1:action:(print-compile-job-cache-key print-include-tree)' \
  '*:input:_files' && ret=0

return ret
