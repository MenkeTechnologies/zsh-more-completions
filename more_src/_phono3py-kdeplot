#compdef phono3py-kdeplot
# Documentation: https://phonopy.github.io/phono3py/auxiliary-tools.html
# phono3py: kernel density estimation plot of phonon lifetimes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--temperature=[select a specific temperature point in K]:temperature' \
  '--nbins=[density plot resolution]:bins' \
  '--cutoff=[maximum lifetime/frequency for data inclusion]:cutoff' \
  '--fmax=[maximum frequency for data inclusion]:fmax' \
  '--xmax=[drawing region x boundary]:xmax' \
  '--ymax=[drawing region y boundary]:ymax' \
  '--zmax=[maximum density value for color saturation]:zmax' \
  '--dr=[density threshold ratio]:ratio' \
  '--density-ratio=[density threshold ratio]:ratio' \
  '--cmap=[matplotlib colormap name]:cmap' \
  '*:file:_files -g "*.hdf5"' && ret=0

return ret
