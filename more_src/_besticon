# -----------------------------------------------------------------------------
#
# THE besticon CLI
#
# besticon is a single-command CLI built on Go's
# standard `flag` package (NOT cobra/urfave/kong —
# bare-stdlib argv parsing).  Invocation:
#   besticon [--all] <URL>
#
# Note: the URL must come AS THE LAST positional
# argument (the CLI code reads os.Args[len-1] not
# flag.Args()[0]), so flag ordering matters.
#
# Arguments:
#   <URL>                          target URL whose
#                                  favicon(s) to find
#                                  (last positional)
#
# Options:
#   --all                          display all icons,
#                                  not just the best
#                                  (one per line)
#   -h, --help                     show help
#
# Exit codes:
#   0                              success (icon found)
#   1                              network/parse error
#   2                              no icons found at target
#   100                            no URL argument provided
#
# Common invocations:
#   # Get the single best favicon for a site
#   besticon https://github.com
#
#   # List all favicons declared by the site
#   besticon --all https://github.com
#
#   # Pipe into curl to download the best favicon
#   besticon https://news.ycombinator.com \
#     | awk -F': ' '{print $2}' \
#     | xargs curl -O
#
#   # Loop over a list of domains
#   while read dom; do
#     besticon "https://$dom"
#   done < domains.txt
#
#   # Use with a bookmark manager (extract icon URLs)
#   jq -r '.bookmarks[] | .url' bookmarks.json \
#     | xargs -I{} besticon {}
#
# COMPANION BINARY: iconserver
#
# The same mat/besticon repo also ships an `iconserver`
# binary that exposes the besticon functionality as an
# HTTP service.  iconserver is configured via env
# variables ONLY (no CLI flags):
#   PORT                           HTTP listen port
#                                  (default ":8080")
#   ADDRESS                        bind address
#                                  (default "")
#   CACHE_SIZE_MB                  in-memory cache
#                                  size in MB
#                                  (default 32)
#   HOST_ONLY_DOMAINS              comma-separated list
#                                  of host-only allow-
#                                  list domains; if set,
#                                  iconserver only
#                                  serves icons for
#                                  these domains
#   SERVER_MODE                    "download" or
#                                  "redirect" (default
#                                  download); "download"
#                                  proxies the icon
#                                  binary through
#                                  iconserver; "redirect"
#                                  emits HTTP 302 to the
#                                  upstream icon URL
#
# Iconserver endpoints:
#   GET /                          HTML demo page
#   GET /icon?url=<URL>&size=<N>   icon for URL at size N
#   GET /allicons.json?url=<URL>   JSON array of all icons
#   GET /lettericon/<letter>.png   letter-icon fallback
#   GET /metrics                   Prometheus metrics
#
# OPTIONS (sourced directly from
# https://github.com/mat/besticon/blob/master/besticon/besticon/cmd.go):
#
#   --all                          display all icons (not just best)
#   <URL>                          target URL (positional, last argv)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,-help,--help}'[show help]' \
    '--all[display all icons, not just the best one]' \
    '*:target URL: ' \
    && ret=0

return ret
