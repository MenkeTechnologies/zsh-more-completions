#compdef minipolish
# _minipolish — Ryan Wick rrwick minipolish CLI tool that polishes a miniasm-produced GFA unitig assembly with racon polishing iterations against original raw Oxford Nanopore PacBio long reads multiple polishing rounds repairing miniasm overlap-trimming artifacts producing high-quality consensus GFA (Ryan Wick team, Python); argparse
# upstream: https://github.com/rrwick/Minipolish

_minipolish() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '--rounds=+[N]:n:' \
        '--pacbio[PacBio reads]' \
        '--nanopore[Nanopore reads]' \
        '--racon=+[path]:file:_files' \
        '--minimap2=+[path]:file:_files' \
        '--skip_initial[skip initial polishing]' \
        '--inplace[modify input in place]' \
        '--keep=+[N]:n:' \
        '*:reads and gfa:_files -g "*.fa *.fasta *.fq *.fastq *.gz *.gfa"'
}

_minipolish "$@"
