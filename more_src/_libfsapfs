#compdef fsapfsinfo fsapfsmount
# _libfsapfs — libfsapfs tools (Joachim Metz libyal family parsing Apple's APFS filesystem on Linux; fsapfsinfo dumps metadata + per-snapshot info, fsapfsmount FUSE-mounts an APFS image read-only; -h help, -V version, -v verbose, -d device offset, -e show extents, -F sub-block, -o image offset, -p password, -r recovery key, -X exclusive, -X extended)
# upstream: https://github.com/libyal/libfsapfs
# Flags from libyal/libfsapfs fsapfstools/fsapfsinfo.c on tip.

_libfsapfs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d+[device offset]:bytes:' \
        '-e[show extents]' \
        '-F+[sub-block]:n:' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-r+[recovery key]:key:' \
        '*:APFS image:_files'
}

_libfsapfs "$@"
