#compdef DtriosCombine
# Documentation: https://github.com/millanek/Dsuite
# Dsuite DtriosCombine: merge Dtrios results across genomic regions.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --out-prefix)'{-o+,--out-prefix=}'[output file prefix]:prefix:' \
  '(-n --run-name)'{-n+,--run-name=}'[run name suffix]:name:' \
  '(-t --tree)'{-t+,--tree=}'[Newick tree file]:file:_files' \
  '(-s --subset)'{-s+,--subset=}'[process trio subset start,length]:start,length:' \
  '*:file:_files' && ret=0

return ret
