#compdef timetrace
# Documentation: https://github.com/dominikbraun/timetrace
# timetrace - a simple CLI for tracking your working time

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    start:"start tracking time for a project"
    stop:"stop tracking the current record"
    status:"show the current tracking status"
    create:"create a project or record"
    get:"display a project or record"
    list:"list projects or records"
    edit:"edit a project or record"
    delete:"delete a project or record"
    report:"generate a report of tracked time"
    version:"show the timetrace version"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-b --billable)'{-b,--billable}'[mark record as billable]' \
      '--non-billable[mark record as non-billable]' \
      '(-p --project)'{-p,--project}'=[filter by project key]:project:' \
      '(-s --start)'{-s,--start}'=[report start date]:date:' \
      '(-e --end)'{-e,--end}'=[report end date]:date:' \
      '(-f --format)'{-f,--format}'=[output format]:format:' \
      '(-o --output)'{-o,--output}'=[output format such as json]:format:(json)' \
      '(-m --minus)'{-m,--minus}'=[subtract duration when editing]:duration:' \
      '(-r --revert)'{-r,--revert}'[restore the previous state]' \
      '--yes[skip confirmation prompt]' \
      '(-h --help)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
