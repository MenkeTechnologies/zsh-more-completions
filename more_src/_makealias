#compdef makealias
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--minimize-diff[only emit aliases that differ from old file]:old file (without extension):_files' \
  '1:dic file:_files -g "*.dic"' \
  '2:aff file:_files -g "*.aff"' && ret=0

return ret
