#compdef CollectInsertSizeMetricsSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/pipelines/metrics/CollectInsertSizeMetricsSpark.java
# GATK Spark: collect insert size metrics and histogram from a SAM/BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  {-O,--output=}'[output metrics file]:file:_files' \
  {-H,--histogram-plot-file=}'[insert size histogram plot PDF]:pdf:_files -g "*.pdf"' \
  {-TOL,--histogram-plot-deviations-tolerance=}'[histogram plot deviations tolerance]:float:' \
  {-W,--width=}'[explicit histogram x-axis width]:int:' \
  {-M,--min-category-reads-percentage=}'[minimum percentage of reads for a category]:float:' \
  '--produce-plot[produce the histogram plot]' \
  '*:argument:_files' && ret=0

return ret
