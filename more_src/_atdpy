#compdef atdpy
# _atdpy — generate Python JSON serializers from ATD definitions (ahrefs/atd)
# upstream: https://github.com/ahrefs/atd
# Flags from atdpy/src/bin/Atdpy_main.ml (cmdliner).

_atdpy() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '*:atd file:_files -g "*.atd"'
}

_atdpy "$@"
