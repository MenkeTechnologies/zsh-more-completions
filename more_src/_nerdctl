_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--address[containerd address]:address' \
  '-a[alias for --address]:address' \
  '-H[alias for --address]:address' \
  '--host[alias for --address]:address' \
  '--namespace[containerd namespace]:namespace' \
  '-n[alias for --namespace]:namespace' \
  '--snapshotter[containerd snapshotter]:snapshotter:(overlayfs native)' \
  '--storage-driver[alias for --snapshotter]:driver' \
  '--cni-path[CNI binary path]:dir:_directories' \
  '--cni-netconfpath[CNI config path]:dir:_directories' \
  '--data-root[data root]:dir:_directories' \
  '--cgroup-manager[cgroup manager]:manager:(cgroupfs systemd none)' \
  '--insecure-registry[allow communication with insecure registries]' \
  '--hosts-dir[hosts directory]:dir:_directories' \
  '--experimental[enable experimental features]' \
  '--host-gateway-ip[IP address of the host gateway]:ip' \
  '--debug[debug mode]' \
  '--debug-full[debug mode with full output]' \
  '1: :_nerdctl_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)        _nerdctl_run_create_flags ;;
      create)     _nerdctl_run_create_flags ;;
      container)  _nerdctl_container ;;
      image)      _nerdctl_image ;;
      volume)     _nerdctl_volume ;;
      network)    _nerdctl_network ;;
      namespace)  _nerdctl_namespace ;;
      compose)    _nerdctl_compose ;;
      builder)    _nerdctl_builder ;;
      system)     _nerdctl_system ;;
      exec)
        _arguments -s -S \
          '(-d --detach)'{-d,--detach}'[run in background]' \
          '--detach-keys[override detach key sequence]:keys' \
          '(-e --env)'{-e,--env}'[set environment variables]:key=value' \
          '--env-file[read environment variables from file]:file:_files' \
          '(-i --interactive)'{-i,--interactive}'[keep STDIN open]' \
          '--privileged[give extended privileges]' \
          '(-t --tty)'{-t,--tty}'[allocate a pseudo-TTY]' \
          '(-u --user)'{-u,--user}'[username or UID]:user' \
          '(-w --workdir)'{-w,--workdir}'[working directory]:dir' \
          '1:container:' '*:command:' && ret=0
        ;;
      ps)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[show all containers]' \
          '(-f --filter)'{-f,--filter}'[filter output]:filter' \
          '--format[Go template format]:format' \
          '(-n --last)'{-n,--last}'[show n last created containers]:num' \
          '--no-trunc[do not truncate output]' \
          '(-q --quiet)'{-q,--quiet}'[only display container IDs]' \
          '(-s --size)'{-s,--size}'[display total file sizes]' && ret=0
        ;;
      images)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[show all images]' \
          '--digests[show digests]' \
          '(-f --filter)'{-f,--filter}'[filter output]:filter' \
          '--format[Go template format]:format' \
          '--names[show image names]' \
          '--no-trunc[do not truncate output]' \
          '(-q --quiet)'{-q,--quiet}'[only show image IDs]' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '--all-platforms[pull for all platforms]' \
          '--cosign-key[path to cosign public key]:file:_files' \
          '--ipfs-address[multiaddr of IPFS API]:address' \
          '--platform[set platform]:platform' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--unpack[unpack the image for the current snapshotter]' \
          '--verify[verify the image]:verify:(none cosign notation)' \
          '1:image:' && ret=0
        ;;
      push)
        _arguments -s -S \
          '--all-platforms[push for all platforms]' \
          '--allow-nondistributable-artifacts[allow pushing non-distributable layers]' \
          '--cosign-key[path to cosign private key]:file:_files' \
          '--estargz[convert layers to eStargz]' \
          '--ipfs-address[multiaddr of IPFS API]:address' \
          '--ipfs-ensure-image[ensure image is pulled for IPFS]' \
          '--platform[push a specific platform]:platform' \
          '--sign[sign the image]:sign:(none cosign notation)' \
          '--soci-min-layer-size[minimum layer size for SOCI index]:size' \
          '--soci-span-size[span size for SOCI index]:size' \
          '1:image:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--build-arg[build-time variables]:key=value' \
          '--buildkit-host[BuildKit host]:host' \
          '--cache-from[external cache source]:source' \
          '--cache-to[external cache destination]:dest' \
          '(-f --file)'{-f,--file}'[Dockerfile path]:file:_files' \
          '--iidfile[write the image ID to file]:file:_files' \
          '--ipfs[build image with pulling base images from IPFS]' \
          '--label[set metadata for an image]:key=value' \
          '--network[set the networking mode]:mode:(default host none)' \
          '--no-cache[do not use cache]' \
          '--output[output destination]:output' \
          '--platform[set target platform]:platform' \
          '--progress[set type of progress output]:progress:(auto plain tty)' \
          '--provenance[shorthand for --attest=type=provenance]:provenance' \
          '(-q --quiet)'{-q,--quiet}'[suppress build output]' \
          '--rm[remove intermediate containers after build]' \
          '--sbom[shorthand for --attest=type=sbom]:sbom' \
          '--secret[secret to expose to build]:secret' \
          '--ssh[SSH agent socket or keys]:ssh' \
          '(-t --tag)'{-t,--tag}'[name and optionally a tag]:tag' \
          '--target[set the target build stage]:stage' \
          '1:context:_directories' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '--since[show logs since timestamp]:timestamp' \
          '--tail[number of lines to show]:lines' \
          '(-t --timestamps)'{-t,--timestamps}'[show timestamps]' \
          '--until[show logs until timestamp]:timestamp' \
          '1:container:' && ret=0
        ;;
      stop)
        _arguments -s -S \
          '(-t --time)'{-t,--time}'[seconds to wait before killing]:seconds' \
          '*:container:' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force the removal]' \
          '(-v --volumes)'{-v,--volumes}'[remove anonymous volumes]' \
          '*:container:' && ret=0
        ;;
      rmi)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force removal]' \
          '--async[asynchronous removal]' \
          '*:image:' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[Go template format]:format' \
          '--mode[inspect mode]:mode:(dockercompat native)' \
          '--type[type of object]:type:(container image network volume)' \
          '*:object:' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(-p --password)'{-p,--password}'[password]:password' \
          '--password-stdin[read password from stdin]' \
          '(-u --username)'{-u,--username}'[username]:username' \
          '1:registry:' && ret=0
        ;;
      logout)
        _arguments '1:registry:' && ret=0
        ;;
      tag)
        _arguments '1:source image:' '2:target image:' && ret=0
        ;;
      save)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[write to a file]:file:_files' \
          '--platform[save for specific platform]:platform' \
          '*:image:' && ret=0
        ;;
      load)
        _arguments -s -S \
          '(-i --input)'{-i,--input}'[read from tar archive file]:file:_files' \
          '--all-platforms[load for all platforms]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      apparmor)
        local -a apparmor_commands=(
          'inspect:display the default AppArmor profile'
          'list:list the loaded AppArmor profiles'
          'load:load the default AppArmor profile'
          'unload:unload the default AppArmor profile'
        )
        _describe -t apparmor-commands 'apparmor command' apparmor_commands
        ;;
    esac
    ;;
esac

return ret
