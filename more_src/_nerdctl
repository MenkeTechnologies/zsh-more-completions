#compdef nerdctl

# Zsh completion for nerdctl - contaiNERD CTL - Docker-compatible CLI for containerd

local curcontext="$curcontext" state line ret=1

_nerdctl_commands() {
  local -a commands=(
    'run:run a command in a new container'
    'exec:run a command in a running container'
    'create:create a new container'
    'ps:list containers'
    'logs:fetch the logs of a container'
    'port:list port mappings or a specific mapping'
    'stop:stop one or more running containers'
    'start:start one or more stopped containers'
    'restart:restart one or more containers'
    'kill:kill one or more running containers'
    'rm:remove one or more containers'
    'pause:pause all processes within one or more containers'
    'unpause:unpause all processes within one or more containers'
    'wait:block until one or more containers stop'
    'rename:rename a container'
    'attach:attach to a running container'
    'cp:copy files between containers and host'
    'diff:inspect changes to files or dirs on a container filesystem'
    'inspect:return low-level information on objects'
    'top:display the running processes of a container'
    'stats:display a live stream of container resource usage'
    'update:update configuration of one or more containers'
    'commit:create a new image from a container changes'
    'build:build an image from a Dockerfile'
    'images:list images'
    'pull:pull an image from a registry'
    'push:push an image to a registry'
    'load:load an image from a tar archive or STDIN'
    'save:save one or more images to a tar archive'
    'tag:create a tag TARGET_IMAGE that refers to SOURCE_IMAGE'
    'rmi:remove one or more images'
    'image:manage images'
    'container:manage containers'
    'volume:manage volumes'
    'network:manage networks'
    'namespace:manage containerd namespaces'
    'builder:manage builds'
    'system:manage nerdctl'
    'compose:compose'
    'login:log in to a container registry'
    'logout:log out from a container registry'
    'apparmor:manage AppArmor profiles'
    'completion:generate the autocompletion script'
    'info:display system-wide information'
    'events:get real time events from the server'
    'version:show the nerdctl version information'
    'internal:internal commands for debugging'
    'ipfs:distribute images via IPFS'
  )
  _describe -t commands 'nerdctl command' commands
}

_nerdctl_run_create_flags() {
  _arguments -s -S \
    '--add-host[add a custom host-to-IP mapping]:host\:ip' \
    '--blkio-weight[block IO weight]:weight' \
    '--cap-add[add Linux capabilities]:capability' \
    '--cap-drop[drop Linux capabilities]:capability' \
    '--cgroup-parent[optional parent cgroup]:cgroup' \
    '--cgroupns[cgroup namespace mode]:mode:(host private)' \
    '--cidfile[write the container ID to file]:file:_files' \
    '--cosign-key[path to cosign public key for verification]:file:_files' \
    '--cpu-period[limit CPU CFS period]:period' \
    '--cpu-quota[limit CPU CFS quota]:quota' \
    '--cpu-shares[CPU shares]:shares' \
    '--cpus[number of CPUs]:cpus' \
    '--cpuset-cpus[CPUs in which to allow execution]:cpus' \
    '--cpuset-mems[memory nodes in which to allow execution]:mems' \
    '(-d --detach)'{-d,--detach}'[run container in background]' \
    '--detach-keys[override the key sequence for detaching]:keys' \
    '--device[add a host device to the container]:device:_files' \
    '--dns[set custom DNS servers]:dns' \
    '--dns-option[set custom DNS options]:option' \
    '--dns-search[set custom DNS search domains]:domain' \
    '--entrypoint[override the default ENTRYPOINT]:entrypoint' \
    '(-e --env)'{-e,--env}'[set environment variables]:key=value' \
    '--env-file[read in a file of environment variables]:file:_files' \
    '--gpus[GPU devices to add]:gpus:(all)' \
    '--group-add[add additional groups]:group' \
    '--health-cmd[command to run for healthcheck]:command' \
    '--health-interval[time between running the check]:interval' \
    '--health-retries[consecutive failures needed to report unhealthy]:retries' \
    '--health-start-period[start period for health check]:period' \
    '--health-timeout[maximum time for a check]:timeout' \
    '(-h --hostname)'{-h,--hostname}'[container host name]:hostname' \
    '--init[run an init inside the container]' \
    '(-i --interactive)'{-i,--interactive}'[keep STDIN open]' \
    '--ip[IPv4 address]:ip' \
    '--ip6[IPv6 address]:ip' \
    '--ipc[IPC mode]:ipc:(host private shareable none)' \
    '--isolation[container isolation technology]:isolation' \
    '--kernel-memory[kernel memory limit]:limit' \
    '(-l --label)'{-l,--label}'[set meta data on a container]:key=value' \
    '--label-file[read in a file of labels]:file:_files' \
    '--log-driver[logging driver]:driver:(json-file journald fluentd syslog none)' \
    '--log-opt[log driver options]:option' \
    '--mac-address[container MAC address]:address' \
    '(-m --memory)'{-m,--memory}'[memory limit]:limit' \
    '--memory-reservation[memory soft limit]:limit' \
    '--memory-swap[swap limit]:limit' \
    '--memory-swappiness[tune container memory swappiness]:value' \
    '--mount[attach a filesystem mount]:mount' \
    '--name[assign a name to the container]:name' \
    '--net[connect to a network]:network:(bridge host none)' \
    '--network[connect to a network]:network:(bridge host none)' \
    '--no-healthcheck[disable any defined healthchecks]' \
    '--oom-kill-disable[disable OOM killer]' \
    '--oom-score-adj[tune OOM preferences]:adj' \
    '--pid[PID namespace to use]:pid:(host)' \
    '--pids-limit[tune container pids limit]:limit' \
    '--platform[set platform]:platform:(linux/amd64 linux/arm64 linux/arm/v7)' \
    '--privileged[give extended privileges]' \
    '(-p --publish)'{-p,--publish}'[publish container port]:port' \
    '(-P --publish-all)'{-P,--publish-all}'[publish all exposed ports]' \
    '--pull[pull image before running]:policy:(always missing never)' \
    '(-q --quiet)'{-q,--quiet}'[suppress the pull output]' \
    '--read-only[mount the container root filesystem as read only]' \
    '--restart[restart policy]:policy:(no on-failure always unless-stopped)' \
    '--rm[automatically remove the container when it exits]' \
    '--rootfs[the first argument is not an image but the rootfs]' \
    '--runtime[runtime to use]:runtime:(io.containerd.runc.v2 io.containerd.runtime.v1.linux)' \
    '--security-opt[security options]:option' \
    '--shm-size[size of /dev/shm]:size' \
    '--sig-proxy[proxy received signals to the process]' \
    '--stop-signal[signal to stop container]:signal' \
    '--stop-timeout[timeout to stop container]:timeout' \
    '--sysctl[sysctl options]:sysctl' \
    '--tmpfs[mount a tmpfs directory]:tmpfs' \
    '(-t --tty)'{-t,--tty}'[allocate a pseudo-TTY]' \
    '--ulimit[ulimit options]:ulimit' \
    '(-u --user)'{-u,--user}'[username or UID]:user' \
    '--uts[UTS namespace to use]:uts:(host)' \
    '(-v --volume)'{-v,--volume}'[bind mount a volume]:volume:_directories' \
    '--volumes-from[mount volumes from the specified container]:container' \
    '(-w --workdir)'{-w,--workdir}'[working directory]:dir' \
    '--verify[verify the image]:verify:(none cosign notation)' \
    '1:image:' \
    '*:command:' && ret=0
}

_nerdctl_container() {
  local -a container_commands=(
    'attach:attach to a running container'
    'commit:create a new image from container changes'
    'cp:copy files between containers and host'
    'create:create a new container'
    'diff:inspect changes to files'
    'exec:run a command in a running container'
    'inspect:display detailed information'
    'kill:kill one or more running containers'
    'logs:fetch the logs of a container'
    'ls:list containers'
    'pause:pause all processes in containers'
    'port:list port mappings'
    'prune:remove all stopped containers'
    'rename:rename a container'
    'restart:restart containers'
    'rm:remove containers'
    'run:run a command in a new container'
    'start:start stopped containers'
    'stats:display resource usage statistics'
    'stop:stop running containers'
    'top:display the running processes'
    'unpause:unpause all processes in containers'
    'update:update container configuration'
    'wait:block until containers stop'
  )
  _describe -t container-commands 'container command' container_commands
}

