#compdef genhomedircon
# _genhomedircon — SELinux genhomedircon (regenerate /etc/selinux/<policy>/contexts/files/file_contexts.homedirs from passwd(5) so newly created users inherit their per-user SELinux home-directory context; -V version, -h help, -n no-reload (just write the file); needs root because it walks NSS sources)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libsemanage genhomedircon on tip.

_genhomedircon() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-n[no reload]'
}

_genhomedircon "$@"
