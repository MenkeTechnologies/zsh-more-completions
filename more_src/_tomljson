#compdef tomljson jsontoml tomll
# Documentation: https://github.com/pelletier/go-toml (v2)
# Source: cmd/{tomljson,jsontoml,tomll}/main.go + internal/cli/cli.go
# Reference accessed: 2026-05-30
# Pelletier go-toml v2 ships 3 cmd binaries:
#   tomljson   converts TOML → JSON (stdin or positional file)
#   jsontoml   converts JSON → TOML (+ optional --use-json-number flag)
#   tomll      lints/reformats TOML files in-place
# All three share internal/cli/cli.go for argv handling: bare flag.Parse() +
# files-as-positional pattern, so the only real flag is jsontoml's
# --use-json-number boolean.

local curcontext="$curcontext" state line ret=1

case $service in
  tomljson)
    _arguments -s -S \
      '(- *)--help[show usage]' \
      '*:TOML file (stdin if omitted):_files -g "*.(toml|tml)"' \
      && ret=0
    ;;

  jsontoml)
    _arguments -s -S \
      '(- *)--help[show usage]' \
      '-use-json-number[unmarshal numbers as json.Number (preserves int/float precision)]' \
      '*:JSON file (stdin if omitted):_files -g "*.json"' \
      && ret=0
    ;;

  tomll)
    _arguments -s -S \
      '(- *)--help[show usage]' \
      '*:TOML file (lint + reformat in-place):_files -g "*.(toml|tml)"' \
      && ret=0
    ;;
esac

return ret
