#compdef ixIxx
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: create indices for a simple line-oriented <symbol> <free text> file

local ret=1

_arguments -s -S \
  '-prefixSize=[size of prefix to index on in ixx (default 5)]:n' \
  '-binSize=[size of bins in ixx (default 64k)]:n' \
  '-maxWordLength=[maximum allowed word length (default 31)]:n' \
  '1:input text:_files' \
  '2:output ix:_files' \
  '3:output ixx:_files' && ret=0

return ret
