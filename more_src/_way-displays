#compdef way-displays

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get:get the current display state'
  'set:set display properties'
  'del:delete display configuration'
  'write:write current config to file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-L[set log level]:level:(DEBUG INFO WARNING ERROR)' \
  '-y[answer yes to all prompts]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'way-displays command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (set|del)
        _arguments \
          'SCALE[set scale]:name scale:' \
          'MODE[set mode]:name WxH:' \
          'TRANSFORM[set transform]:name transform:(NONE 90 180 270 FLIPPED FLIPPED-90 FLIPPED-180 FLIPPED-270)' \
          'ORDER[set order]:names:' \
          'AUTO_SCALE[set auto scale]:mode:(ON OFF)' \
          'DISABLED[disable display]:name:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
