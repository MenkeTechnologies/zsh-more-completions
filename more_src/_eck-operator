#compdef eck-operator elastic-operator
# _eck-operator — Elastic Cloud on Kubernetes (ECK) manager
# upstream: https://github.com/elastic/cloud-on-k8s
# Flag names from pkg/controller/common/operator/flags.go (cmd/manager/main.go BindPFlags) on tip.

_eck-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--auto-port-forward[auto port-forward Elasticsearch endpoint]' \
        '--ca-dir=[CA certificate directory]:dir:_files -/' \
        '--ca-cert-rotate-before=[rotate CA before expiry]:dur:' \
        '--ca-cert-validity=[CA cert validity period]:dur:' \
        '--cert-rotate-before=[rotate certs before expiry]:dur:' \
        '--cert-validity=[certificate validity period]:dur:' \
        '--config=[operator config file]:file:_files' \
        '--container-registry=[default container registry]:registry:' \
        '--container-repository=[default container repository]:repo:' \
        '--container-suffix=[default container image suffix]:suffix:' \
        '--debug-http-listen=[debug HTTP listen host\:port]:host\:port:' \
        '--disable-telemetry=[disable telemetry reporting]:bool:(true false)' \
        '--distribution-channel=[distribution channel name]:name:' \
        '--elasticsearch-observation-interval=[Elasticsearch health observation interval]:dur:' \
        '--enable-tracing[enable APM tracing]' \
        '--enable-webhook[enable admission webhook server]' \
        '--enforce-rbac-on-refs[enforce RBAC checks on cross-namespace refs]' \
        '--ip-family=[IP family]:family:(ipv4 ipv6 dual)' \
        '--manage-webhook-certs=[manage webhook CA/certs]:bool:(true false)' \
        '--max-concurrent-reconciles=[max concurrent reconciles per controller]:n:' \
        '--metrics-port=[metrics endpoint port]:port:' \
        '--metrics-host=[metrics endpoint bind host]:host:' \
        '--metrics-secure=[enable TLS for metrics endpoint]:bool:(true false)' \
        '--metrics-cert-dir=[metrics TLS cert directory]:dir:_files -/' \
        '*--namespaces=[namespaces to watch (csv, empty=all)]:csv:' \
        '--operator-namespace=[namespace the operator runs in]:ns:' \
        '--password-length=[generated password length]:n:' \
        '--set-default-security-context=[apply restricted PodSecurityContext]:bool:(true false)' \
        '--telemetry-interval=[telemetry report interval]:dur:' \
        '--ubi-only[only use UBI-based images]' \
        '--validate-storage-class=[validate StorageClass support]:bool:(true false)' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--webhook-name=[ValidatingWebhookConfiguration name]:name:' \
        '--webhook-secret=[webhook serving cert Secret name]:name:' \
        '--webhook-port=[webhook bind port]:port:'
}

_eck-operator "$@"
