#compdef jconvolver
# _jconvolver — JACK convolution engine (Fons Adriaensen)
# upstream: https://kokkinizita.linuxaudio.org/linuxaudio/index.html
# Flags from jconvolver(1) man page.

_jconvolver() {
    _arguments \
        '(- *)-h[show help]' \
        '-v[print partition list to stdout]' \
        '-L[compensate N frames of latency]:nframes:' \
        '-M[use FFTW_MEASURE option]' \
        '-N[JACK client name]:name:' \
        '*:configuration file:_files'
}

_jconvolver "$@"
