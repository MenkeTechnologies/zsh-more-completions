#compdef android-app-bundle
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/tree/master/docs/android-app-bundle
# Codemagic CLI tools - manage Android App Bundles using Bundletool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(build-apks build-universal-apk dump is-signed sign validate bundletool)' \
  '*::args:->args' && ret=0

return ret
