#compdef opencti opencti-cli pycti
# _opencti — Filigran OpenCTI opencti CLI client to the OpenCTI graphql API the open-source cyber-threat-intelligence platform consuming STIX 2.1 entities ingestion connectors observations indicators reports campaigns intrusion-sets threat-actors malware vulnerabilities course-of-action knowledge-graph manipulation (Filigran team, Python); click
# upstream: https://www.opencti.io/

_opencti() {
    local -a sub=(
        'config:configure connection'
        'entity:entity operations'
        'observable:observable operations'
        'indicator:indicator operations'
        'report:report operations'
        'campaign:campaign operations'
        'intrusion-set:intrusion-set operations'
        'threat-actor:threat-actor operations'
        'malware:malware operations'
        'vulnerability:vulnerability operations'
        'course-of-action:course-of-action operations'
        'attack-pattern:attack-pattern operations'
        'tool:tool operations'
        'connector:connector management'
        'workflow:workflow management'
        'stix:STIX import/export'
        'taxii:TAXII server operations'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '-k+[token]:str:' \
        '--token=+[token]:str:' \
        '-f+[format]:f:(json yaml table stix2 stix2.1 stix1 misp openioc)' \
        '--format=+[format]:f:(json yaml table stix2 stix2.1 stix1 misp openioc)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opencti subcommand' sub ;;
        args)
            case $words[1] in
                entity|observable|indicator|report|campaign|intrusion-set|threat-actor|malware|vulnerability|tool|attack-pattern|course-of-action) _arguments \
                    '1:op:(list create read update delete relationship export search)' \
                    '*:id:' ;;
            esac
            ;;
    esac
}

_opencti "$@"
