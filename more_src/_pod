#compdef pod

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cache:manage pod cache'
  'deintegrate:remove CocoaPods traces from project'
  'env:display pod environment'
  'init:generate Podfile for current directory'
  'install:install dependencies'
  'ipc:inter-process communication'
  'lib:develop pods'
  'list:list available pods'
  'outdated:show outdated pods in Podfile.lock'
  'plugins:manage CocoaPods plugins'
  'repo:manage spec-repos'
  'search:search for pods'
  'setup:setup CocoaPods environment'
  'spec:manage podspecs'
  'trunk:interact with trunk service'
  'try:open demo project for a pod'
  'update:update outdated dependencies'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--silent[suppress all output]' \
  '--verbose[show debugging info]' \
  '--no-ansi[disable ANSI color codes]' \
  '--no-repo-update[skip repo update]' \
  '--allow-root[allow running as root]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pod subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cache)
        _values 'cache action' 'list' 'clean' && ret=0
        ;;
      (ipc)
        _values 'ipc action' 'repl' 'spec' 'podfile' 'podfile-json' 'list' 'update-search-index' && ret=0
        ;;
      (lib)
        _values 'lib action' 'create' 'lint' && ret=0
        ;;
      (plugins)
        _values 'plugins action' 'list' 'search' 'installed' 'create' 'publish' && ret=0
        ;;
      (repo)
        _values 'repo action' 'add' 'add-cdn' 'update' 'lint' 'list' 'remove' 'push' && ret=0
        ;;
      (spec)
        _values 'spec action' 'create' 'lint' 'cat' 'which' 'edit' && ret=0
        ;;
      (trunk)
        _values 'trunk action' \
          'add-owner' 'info' 'me' 'push' 'register' 'remove-owner' 'deprecate' 'delete' && ret=0
        ;;
      (install|update)
        _arguments \
          '--no-repo-update[skip repo update]' \
          '--no-integrate[do not integrate with project]' \
          '--clean-install[force clean install]' \
          '--repo-update[force repo update]' \
          '--deployment[deployment mode]' \
          '--no-clean[do not clean]' && ret=0
        ;;
    esac
    ;;
esac

return ret
