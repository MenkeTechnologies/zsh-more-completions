#compdef magic-vlsi
# Documentation: https://man.archlinux.org/search?q=magic-vlsi
# Reference accessed: 2026-05-16

# magic-vlsi: alternative name for Magic VLSI layout editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-dnull[no display]' \
  '-d[display type]:dtype:(NULL OGL X11 XR)' \
  '-T[technology file]:tech:' \
  '-rcfile[rcfile]:file:_files' \
  '-noconsole[no console]' \
  '-wrapper[Tk wrapper]' \
  '-nowrapper[no Tk wrapper]' \
  '*:Magic file:_files -g "*.(mag|gz)"' && ret=0
return ret
