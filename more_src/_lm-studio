#compdef lms
# _lm-studio — LM Studio CLI (lmstudio-ai)
# upstream: https://github.com/lmstudio-ai/lms

_lm-studio() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'server:manage the local LM Studio server'
        'load:load a model'
        'unload:unload a model'
        'ls:list downloaded models'
        'ps:list currently loaded models'
        'get:download a model'
        'create:create a new project'
        'log:manage logs'
        'import:import a model file'
        'bootstrap:bootstrap LM Studio CLI'
        'version:print version'
        'help:show help for a command'
    )

    _arguments -C \
        '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
        '(-q --quiet)'{-q,--quiet}'[suppress output]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'lms command' commands && ret=0 ;;
        args)
            case $line[1] in
                server)
                    local -a server_cmds=(
                        'start:start the local server'
                        'stop:stop the local server'
                        'status:show server status'
                    )
                    _describe -t commands 'server subcommand' server_cmds && ret=0 ;;
                load)
                    _arguments \
                        '1:model:' \
                        '--gpu[GPU acceleration]:mode:(auto off max)' && ret=0 ;;
                unload)
                    _arguments '1:model:' && ret=0 ;;
                get)
                    _arguments '1:model:' && ret=0 ;;
                import)
                    _arguments '1:model file:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_lm-studio "$@"
