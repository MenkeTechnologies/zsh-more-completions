#compdef phinx
# Zsh completion for phinx - PHP database migrations
# https://github.com/cakephp/phinx

local -a commands=(
  'breakpoint:manage breakpoints'
  'create:create a new migration'
  'init:initialize phinx'
  'list:list available commands'
  'migrate:run database migrations'
  'rollback:rollback database migrations'
  'seed\:create:create a new database seeder'
  'seed\:run:run database seeders'
  'status:show migration status'
  'test:verify configuration file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-q[quiet mode]' \
  '-v[increase verbosity]' \
  '--ansi[force ANSI output]' \
  '--no-ansi[disable ANSI output]' \
  '-n[do not ask interactive questions]' \
  '1:command:->cmds' \
  '*::args:->args'

case $state in
  cmds)
    _describe -t commands 'phinx command' commands
    ;;
  args)
    case $words[1] in
      create)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '-p+[parser format]:parser:(yaml yml json php)' \
          '--template=[migration template]:file:_files -g "*.php(-.)"' \
          '--class=[template class name]:class:' \
          '1:migration name:'
        ;;
      migrate)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '-e+[target environment]:environment:' \
          '-t+[migrate to specific version]:version:' \
          '-d+[migrate to date]:date:' \
          '--dry-run[print queries without executing]' \
          '--fake[mark migrations as run without executing]' \
          '-x[seed data after migration]'
        ;;
      rollback)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '-e+[target environment]:environment:' \
          '-t+[rollback to specific version]:version:' \
          '-d+[rollback to date]:date:' \
          '-f[force rollback ignoring breakpoints]' \
          '--dry-run[print queries without executing]' \
          '--fake[mark rollbacks without executing]'
        ;;
      status)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '-e+[target environment]:environment:' \
          '--format=[output format]:format:(text json)'
        ;;
      seed:run)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '-e+[target environment]:environment:' \
          '-s+[seeder class name]:seeder class:'
        ;;
      seed:create)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '1:seeder name:'
        ;;
      init)
        _arguments \
          '--format=[config file format]:format:(yaml yml json php)' \
          '1:path:_files -/'
        ;;
      breakpoint)
        _arguments \
          '-c+[config file]:file:_files -g "*.{yml,yaml,php,json}(-.)"' \
          '-e+[target environment]:environment:' \
          '-t+[specific version]:version:' \
          '--remove-all[remove all breakpoints]'
        ;;
    esac
    ;;
esac
