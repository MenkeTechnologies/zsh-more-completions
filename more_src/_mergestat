#compdef mergestat
# Documentation: https://man.archlinux.org/search?q=mergestat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --db)'{-d,--db}'=[SQLite DB file path]:file:_files' \
  '(-r --repo)'{-r,--repo}'=[default git repo path]:path:_directories' \
  '(-c --clone-dir)'{-c,--clone-dir}'=[clone directory for remote repos]:path:_directories' \
  '--skip-mailmap[ignore .mailmap for commits]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs to stderr]' \
  '(-x --codex)'{-x,--codex}'[natural language to SQL via codex]' \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd)
    _alternative \
      'subcommands:mergestat command:(export serve summarize summary)' \
      'sql:SQL query:_default' && ret=0
    ;;
  (args)
    case $line[1] in
      (export)
        _arguments -s -S \
          '(-d --db)'{-d,--db}'=[SQLite DB file path]:file:_files' \
          '(-r --repo)'{-r,--repo}'=[default git repo path]:path:_directories' \
          '(-c --clone-dir)'{-c,--clone-dir}'=[clone directory for remote repos]:path:_directories' \
          '--skip-mailmap[ignore .mailmap for commits]' \
          '(-v --verbose)'{-v,--verbose}'[verbose logs to stderr]' \
          '(-x --codex)'{-x,--codex}'[natural language to SQL]' \
          '(-a --append)'{-a,--append}'[append instead of recreate tables]' \
          '*'{-e,--exports}'+[table name and SQL query pairs]:pair:' \
          '1:sqlite db path:_files' && ret=0
        ;;
      (serve)
        _arguments -s -S \
          '(-d --db)'{-d,--db}'=[SQLite DB file path]:file:_files' \
          '(-r --repo)'{-r,--repo}'=[default git repo path]:path:_directories' \
          '(-c --clone-dir)'{-c,--clone-dir}'=[clone directory for remote repos]:path:_directories' \
          '--skip-mailmap[ignore .mailmap for commits]' \
          '(-v --verbose)'{-v,--verbose}'[verbose logs to stderr]' \
          '(-x --codex)'{-x,--codex}'[natural language to SQL]' \
          '(-p --port)'{-p,--port}'[HTTP port]:port:' && ret=0
        ;;
      (summarize|summary)
        _arguments -s -S \
          '(-d --db)'{-d,--db}'=[SQLite DB file path]:file:_files' \
          '(-r --repo)'{-r,--repo}'=[default git repo path]:path:_directories' \
          '(-c --clone-dir)'{-c,--clone-dir}'=[clone directory for remote repos]:path:_directories' \
          '--skip-mailmap[ignore .mailmap for commits]' \
          '(-v --verbose)'{-v,--verbose}'[verbose logs to stderr]' \
          '(-x --codex)'{-x,--codex}'[natural language to SQL]' \
          '1:subcommand:(commits blame)' \
          '*::rest: _default' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'=[result format]:format:(csv csv-noheader tsv tsv-noheader table single ndjson json)' \
          '(-p --preset)'{-p,--preset}'=[named preset SQL query]:name:' \
          '*::SQL query: _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
