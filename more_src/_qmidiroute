#compdef qmidiroute
# _qmidiroute — versatile MIDI event router/filter for ALSA (aschmie/qmidiroute)
# upstream: http://alsamodular.sourceforge.net/
# Flags from qmidiroute(1) man page.

_qmidiroute() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '--portCount[number of ALSA output ports (default 2)]:num:' \
        '*:.qmr project file:_files -g "*.qmr"'
}

_qmidiroute "$@"
