#compdef famsa
# Documentation: https://github.com/refresh-bio/FAMSA
# FAMSA - progressive algorithm for large-scale multiple sequence alignments

local ret=1

_arguments -s -S \
  '-help[display advanced options]' \
  '-t[number of threads (0 = half of logical cores)]:threads' \
  '-v[enable verbose mode with timing information]' \
  '-gt[guide tree method]:method:(sl upgma nj import)' \
  '-medoidtree[use medoid tree for fast approximated guide trees]' \
  '-medoid_seeds[number of seeds k in medoid trees]:seeds' \
  '-medoid_threshold[minimum subset size to apply medoid tree heuristic]:size' \
  '-gt_export[export guide tree to output file in Newick format]' \
  '-dist_export[export distance matrix to output file in CSV format]' \
  '-square_matrix[generate square matrix instead of triangular]' \
  '-pid[calculate percent identity instead of distance]' \
  '-keep_duplicates[keep duplicated sequences during alignment]' \
  '-gz[enable gzipped output]' \
  '-gz_lev[gzip compression level 0-9]:level' \
  '-trim_columns[remove columns with insufficient non-gap characters]:fraction' \
  '-refine_mode[refinement mode]:mode:(on off auto)' \
  '*:file:_files' && ret=0

return ret
