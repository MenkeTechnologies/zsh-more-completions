#compdef kxdpgun
# Documentation: source-direct extraction from upstream
# CZ-NIC/knot src/utils/kxdpgun/main.c
#   opts_str = "hV::t:Q:b:rp:T::U::F:I:i:Bl:L:R:v:e:m:G:jS:"
#   long_options table (22 entries) decoded from struct option
#   opts[] array.
#   Sub-enums:
#     -m/--mode: set_mode() -> auto|copy|generic
#     -T/--tcp=, -U/--quic=: sending_mode() switch arm -> 0|1|2|3|5|7|8|9|R
# Reference accessed: 2026-05-30 via gh api.
# CZ-NIC knot R170 — kxdpgun is the Knot DNS XDP-based DNS
# stress tester / traffic generator.  Drives high-throughput
# UDP/TCP/QUIC DNS query load against a target nameserver from
# a queries-file (text or binary format).  Sister tool to the
# heavily-covered Knot DNS family (kdig/khost/knotc/knotd +
# kzonecheck/kzonesign/kjournalprint/kcatalogprint/knsupdate/
# knsec3hash/keymgr/keymgr offline-KSK pipeline) already in the
# corpus.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-V --version)'{-V-,--version=-}'[print version and exit]::detail:' \
  '(-t --duration)'{-t+,--duration=}'[duration of traffic generation in seconds]:sec:' \
  '(-T --tcp)'{-T-,--tcp=-}'[send queries over TCP (optional debug mode)]::debug:(0 1 2 3 5 7 8 9 R)' \
  '(-U --quic)'{-U-,--quic=-}'[send queries over QUIC (optional debug mode)]::debug:(0 1 2 3 5 7 8 9 R)' \
  '(-Q --qps)'{-Q+,--qps=}'[approximate queries-per-second target]:qps:' \
  '(-b --batch)'{-b+,--batch=}'[send queries in batches of given size]:size:' \
  '(-r --drop)'{-r,--drop}'[drop incoming responses (disables response statistics)]' \
  '(-p --port)'{-p+,--port=}'[remote destination port]:port:' \
  '(-F --affinity)'{-F+,--affinity=}'[CPU affinity ([<cpu_start>][s<cpu_step>])]:spec:' \
  '(-I --interface)'{-I+,--interface=}'[override auto-detected outgoing interface]:ifname:_net_interfaces' \
  '(-i --infile)'{-i+,--infile=}'[path to a file with query templates]:file:_files' \
  '(-B --binary)'{-B,--binary}'[input file is binary (<length:2><wire:length>)]' \
  '(-l --local)'{-l+,--local=}'[override auto-detected source IP / subnet]:ip[/prefix]:' \
  '(-L --local-mac)'{-L+,--local-mac=}'[override auto-detected local MAC]:mac:' \
  '(-R --remote-mac)'{-R+,--remote-mac=}'[override auto-detected remote MAC]:mac:' \
  '(-v --vlan)'{-v+,--vlan=}'[add VLAN 802.1Q header with given id]:id:' \
  '(-e --edns-size)'{-e+,--edns-size=}'[EDNS UDP payload size (512-4096, default 1232)]:bytes:' \
  '(-m --mode)'{-m+,--mode=}'[XDP mode]:mode:(auto copy generic)' \
  '(-G --qlog)'{-G+,--qlog=}'[qlog output directory (QUIC only)]:dir:_files -/' \
  '(-j --json)'{-j,--json}'[output statistics in JSON]' \
  '(-S --stats-period)'{-S+,--stats-period=}'[periodic stats printout interval in milliseconds]:ms:' \
  ':dest IP (IPv4 or IPv6):_hosts'
