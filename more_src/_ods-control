#compdef ods-control
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/ods-control.8.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy ods-control(8) manpage. Subcommand dispatcher.

# ods-control: OpenDNSSEC control script
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'hsm:pass remaining args to ods-hsmutil'
  'enforcer:pass remaining args to ods-enforcer'
  'signer:pass remaining args to ods-signer'
  'start:start ods-enforcerd and ods-signerd'
  'stop:stop ods-enforcerd and ods-signerd'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'ods-control command' commands && ret=0 ;;
esac
return ret
