#compdef clamsmtp clamsmtpd
# Documentation: https://man.archlinux.org/search?q=clamsmtp
# Reference accessed: 2026-05-16

# clamsmtpd: simple SMTP filter that virus-scans via clamd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug level]:n:' \
  '-D[daemonize]' \
  '-f[config file]:file:_files' \
  '-l[listen address]:addr:' \
  '-o[outgoing address]:addr:' \
  '-p[PID file]:file:_files' \
  '-q[quarantine dir]:dir:_files -/' \
  '-s[clamd socket]:path:_files' \
  '-t[timeout (s)]:s:' \
  '-T[work dir]:dir:_files -/' \
  '-u[run as user]:user:_users' \
  '-v[verbose]' \
  '*::clamsmtpd args:_files' && ret=0
return ret
