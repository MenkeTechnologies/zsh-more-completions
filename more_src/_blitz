#compdef blitz

# Zsh completion for blitz - Full-stack React framework CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_blitz_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
)

_arguments -s -S -C \
  "${_blitz_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'new:Create a new Blitz project'
      'dev:Start a development server'
      'build:Create a production build'
      'start:Start a production server'
      'export:Export the application as static HTML'
      'db:Run database commands'
      'generate:Generate new files for your Blitz project (alias: g)'
      'codegen:Run the blitz codegen'
      'routes:Display all Blitz URL routes'
      'console:Open the Blitz console (alias: c)'
      'install:Install a Blitz recipe'
      'autocomplete:Display autocomplete installation instructions'
      'help:Display help'
    )
    _describe -t commands 'blitz commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      new)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '--template[template to use]:template:' \
          '--language[language to use]:language:(typescript javascript)' \
          '--npm[use npm as the package manager]' \
          '--yarn[use yarn as the package manager]' \
          '--pnpm[use pnpm as the package manager]' \
          '--skip-install[skip installing dependencies]' \
          '--dry-run[show what would be generated]' \
          '--skip-upgrade[skip checking for newer version]' \
          '1:project name:' && ret=0
        ;;
      dev)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '(-p --port)'{-p,--port}'[set port number]:port:' \
          '(-H --hostname)'{-H,--hostname}'[set hostname]:hostname:' \
          '(-e --env)'{-e,--env}'[set app environment]:env:' \
          '--inspect[enable the Node.js inspector]' && ret=0
        ;;
      build)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '(-e --env)'{-e,--env}'[set app environment]:env:' && ret=0
        ;;
      start)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '(-p --port)'{-p,--port}'[set port number]:port:' \
          '(-H --hostname)'{-H,--hostname}'[set hostname]:hostname:' \
          '(-e --env)'{-e,--env}'[set app environment]:env:' && ret=0
        ;;
      export)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '--outdir[output directory]:directory:_directories' && ret=0
        ;;
      db)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '1:db command:(migrate seed studio)' && ret=0
        ;;
      generate|g)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '1:type:(all resource model queries mutations)' \
          '2:model name:' \
          '*:attributes:' && ret=0
        ;;
      install)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" \
          '1:recipe:' && ret=0
        ;;
      console|c)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" && ret=0
        ;;
      *)
        _arguments -s -S \
          "${_blitz_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
