#compdef cartographer_pbstream_to_ros_map
# Documentation: https://github.com/cartographer-project/cartographer_ros/blob/master/cartographer_ros/cartographer_ros/pbstream_to_ros_map_main.cc
# Draw a ROS map from a Cartographer pbstream file

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '-pbstream_filename=[filename of a pbstream to draw a map from]:file:_files -g "*.pbstream"' \
  '-map_filestem=[stem of the output files]:stem' \
  '-resolution=[resolution of a grid cell in the drawn map]:m' && ret=0

return ret
