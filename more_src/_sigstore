#compdef sigstore

local curcontext="$curcontext" state line ret=1
local -a commands verify_subs

commands=(
  'sign:create signatures for files'
  'attest:sign using DSSE envelopes (in-toto attestations)'
  'verify:verify signatures'
  'get-identity-token:retrieve an OpenID Connect token'
  'trust-instance:initialize Sigstore instance trust'
  'plumbing:developer-only operations'
)

verify_subs=(
  'identity:verify against expected identities'
  'github:verify against GitHub Actions workflow context'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--staging[use Sigstore staging instance]' \
  '--trust-config=[trust config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

_sigstore_oidc_args() {
  _arguments \
    '--rekor-version=[transparency log version]:version:(1 2)' \
    '--identity-token=[use specific OIDC token]:token:' \
    '--oidc-client-id=[custom OIDC client id]:id:' \
    '--oidc-client-secret=[custom OIDC client secret]:secret:' \
    '--oidc-disable-ambient-providers[disable ambient credential detection]' \
    '--oidc-issuer=[custom OIDC issuer URL]:url:' \
    '--oauth-force-oob[force out-of-band OAuth flow]' \
    '--signature=[write signature to file]:file:_files' \
    '--certificate=[write certificate to file]:file:_files' \
    '--bundle=[write Sigstore bundle to file]:file:_files' \
    '--output-directory=[write outputs to directory]:dir:_files -/' \
    '--overwrite[replace existing outputs]' \
    '*::file:_files'
}

case $state in
  (cmd) _describe -t cmds 'sigstore command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sign)
        _sigstore_oidc_args && ret=0 ;;
      (attest)
        _arguments \
          '--predicate=[path to predicate file]:file:_files' \
          '--predicate-type=[predicate type]:type:' \
          '--rekor-version=[transparency log version]:version:(1 2)' \
          '--identity-token=[use specific OIDC token]:token:' \
          '--oidc-client-id=[custom OIDC client id]:id:' \
          '--oidc-issuer=[custom OIDC issuer URL]:url:' \
          '--oidc-disable-ambient-providers[disable ambient detection]' \
          '--bundle=[write bundle to file]:file:_files' \
          '*::file:_files' && ret=0 ;;
      (verify)
        _arguments -C \
          '1: :->vcmd' \
          '*::varg:->vargs' && ret=0
        case $state in
          (vcmd) _describe -t vcmds 'verify subcommand' verify_subs && ret=0 ;;
          (vargs)
            case $line[1] in
              (identity)
                _arguments \
                  '--certificate=[PEM-encoded certificate]:file:_files' \
                  '--signature=[signature file]:file:_files' \
                  '--bundle=[Sigstore bundle file]:file:_files' \
                  '--offline[skip network verification]' \
                  '--cert-identity=[expected identity]:identity:' \
                  '--cert-oidc-issuer=[expected issuer URL]:url:' \
                  '*::file:_files' && ret=0 ;;
              (github)
                _arguments \
                  '--certificate=[PEM-encoded certificate]:file:_files' \
                  '--signature=[signature file]:file:_files' \
                  '--bundle=[Sigstore bundle file]:file:_files' \
                  '--offline[skip network verification]' \
                  '--cert-identity=[expected identity]:identity:' \
                  '--cert-oidc-issuer=[expected issuer URL]:url:' \
                  '--trigger=[workflow event name]:event:' \
                  '--sha=[git commit SHA]:sha:' \
                  '--name=[workflow name]:name:' \
                  '--repository=[repository slug]:repo:' \
                  '--ref=[git reference]:ref:' \
                  '*::file:_files' && ret=0 ;;
            esac ;;
        esac ;;
      (get-identity-token)
        _arguments \
          '--oidc-client-id=[OIDC client id]:id:' \
          '--oidc-issuer=[OIDC issuer URL]:url:' \
          '--oidc-disable-ambient-providers[disable ambient detection]' \
          '--oauth-force-oob[force OOB flow]' && ret=0 ;;
    esac ;;
esac

return ret
