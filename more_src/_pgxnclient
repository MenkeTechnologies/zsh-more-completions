#compdef pgxnclient pgxn
# _pgxnclient — PGXN client for PostgreSQL extensions (pgxn/pgxnclient)
# upstream: https://github.com/pgxn/pgxnclient
# Subcommand names from pgxnclient/commands/*.py (Command.name).

_pgxnclient() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-y --yes)'{-y,--yes}'[assume yes for confirmations]' \
        '--mirror=[PGXN mirror URL]:url:' \
        '--proxy=[HTTP proxy URL]:url:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'help:show help for a command'
                'mirror:list known PGXN mirrors'
                'search:search the PGXN index'
                'info:show distribution info'
                'download:download a distribution archive'
                'install:download, build and install a distribution'
                'uninstall:uninstall a previously-installed distribution'
                'check:run distribution test suite'
                'load:LOAD EXTENSION into a database'
                'unload:DROP EXTENSION from a database'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                install|uninstall|check)
                    _arguments \
                        '--stable[choose stable releases (default)]' \
                        '--testing[allow testing releases]' \
                        '--unstable[allow unstable releases]' \
                        '--pg_config=[pg_config binary]:file:_files' \
                        '--make=[make program]:make:_command_names -e' \
                        ':distribution spec or path:'
                    ;;
                load|unload)
                    _arguments \
                        '(-d --dbname)'{-d+,--dbname=}'[database name]:db:' \
                        '(-h --host)'{-h+,--host=}'[Postgres host]:host:_hosts' \
                        '(-p --port)'{-p+,--port=}'[Postgres port]:port:' \
                        '(-U --username)'{-U+,--username=}'[Postgres user]:user:_users' \
                        '--pg_config=[pg_config binary]:file:_files' \
                        ':distribution spec or path:'
                    ;;
                download)
                    _arguments \
                        '--target=[output directory]:dir:_files -/' \
                        ':distribution spec:'
                    ;;
            esac
            ;;
    esac
}

_pgxnclient "$@"
