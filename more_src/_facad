#compdef facad

# yellow-footed-honeyguide/facad src/args_parser.c; Homebrew: Formula/f/facad.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '(-l)'{-l,--long}'[detailed listing]' \
  '(-a)'{-a,--analytics}'[directory analytics]' \
  '*::directory:_files -/' && ret=0
return ret
