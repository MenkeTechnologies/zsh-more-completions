# Zsh completion for create-nuxt-app - Nuxt app scaffolder (create-nuxt-app)

local curcontext="$curcontext" state line ret=1

_arguments -C   '--cwd=[working directory]:dir:_directories'   '--logLevel=[log level]:level:(silent info verbose)'   '-t[template name]:template:'   '--template=[template name]:template:'   '-f[force overwrite existing directory]'   '--force[force overwrite existing directory]'   '--offline[force offline mode]'   '--preferOffline[prefer offline mode]'   '--install[install dependencies]'   '--no-install[skip installing dependencies]'   '--gitInit[initialize git repository]'   '--shell[start shell after installation]'   '--packageManager=[package manager]:manager:(npm pnpm yarn bun)'   ':directory:_directories' && ret=0

return ret
