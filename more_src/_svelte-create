#compdef svelte-create
# Documentation: https://www.npmjs.com/package/svelte-create
# Reference accessed: 2026-05-23
# Verified: npx svelte-create --help.

# Zsh completion for svelte-create - scaffold Svelte projects

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '(-f --force)'{-f,--force}'[force overwrite existing files]'   '(-c --cache)'{-c,--cache}'[use cached Svelte template]'   ':directory:_directories' && ret=0

return ret
