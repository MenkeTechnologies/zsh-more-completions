#compdef rspec

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*-I+[add to load path]:dir:_files -/' \
  '*'{-r,--require=}'[require file]:file:_files' \
  '(-O --options)'{-O,--options=}'[custom options file]:file:_files' \
  '--order=[run order]:type:(defined random recently-modified)' \
  '--seed=[random seed]:seed:' \
  '--bisect=[bisect failures]:mode:(verbose)' \
  '--fail-fast=[abort after N failures]:n:' \
  '--no-fail-fast[do not abort on failures]' \
  '--failure-exit-code=[exit code on failure]:n:' \
  '--error-exit-code=[exit code on error]:n:' \
  '(-X --drb)'{-X,--drb}'[run via DRb server]' \
  '--no-drb[do not use DRb]' \
  '--drb-port=[DRb port]:port:' \
  '(-f --format)'{-f,--format=}'[formatter]:fmt:(progress documentation html json failures)' \
  '(-o --out)'{-o,--out=}'[output file]:file:_files' \
  '--deprecation-out=[deprecation output file]:file:_files' \
  '(-b --backtrace)'{-b,--backtrace}'[full backtrace]' \
  '(-c --color --colour)'{-c,--color,--colour}'[colorize output]' \
  '--force-color[force color]' \
  '(--no-color --no-colour)'{--no-color,--no-colour}'[no color]' \
  '(-p --profile)'{-p,--profile=}'[show slowest examples]:count:' \
  '--no-profile[disable profile]' \
  '--dry-run[print plan without running]' \
  '(-w --warnings)'{-w,--warnings}'[enable Ruby warnings]' \
  '--only-failures[run only previously failed examples]' \
  '(-n --next-failure)'{-n,--next-failure}'[run next failure]' \
  '(-P --pattern)'{-P,--pattern=}'[file pattern]:pattern:' \
  '--exclude-pattern=[exclude pattern]:pattern:' \
  '*'{-e,--example=}'[run examples matching string]:str:' \
  '*'{-E,--example-matches=}'[run examples matching regex]:regex:' \
  '*'{-t,--tag=}'[run examples with tag]:tag:' \
  '--default-path=[default path]:path:_files -/' \
  '--init[initialize spec dir + .rspec file]' \
  '*:spec:_files -g "*_spec.rb"'
