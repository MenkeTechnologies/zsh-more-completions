#compdef bit
# Documentation: https://github.com/chriswalz/bit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bit - modern Git CLI helper (chriswalz/bit)

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[show insight into how bit works]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'save:commit (or amend if ahead of origin)'
      'sync:pull with rebase, then push'
      'switch:switch branches with prompt'
      'sw:alias for switch'
      'co:alias for switch'
      'checkout:alias for switch'
      'info:show repository info / git stats'
      'complete:install shell completions'
      'release:bump tag and release'
      'merge:merge branches with suggestions'
      'update:update bit'
      'pr:view or checkout GitHub pull requests'
    )
    _describe -t commands 'bit command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      save)
        _arguments -s \
          '--all[save all changes]' \
          '*:message' && ret=0
        ;;
      switch|sw|co|checkout)
        __git_branch_names() {
          local -a branches
          branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
          _describe -t branches 'branch' branches
        }
        _arguments ':branch:__git_branch_names' && ret=0
        ;;
      release)
        _arguments ':version' && ret=0
        ;;
    esac
    ;;
esac

return ret
