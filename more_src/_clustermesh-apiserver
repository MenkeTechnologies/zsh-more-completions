#compdef clustermesh-apiserver
# _clustermesh-apiserver — Cilium ClusterMesh API server multi-mode binary
# upstream: https://github.com/cilium/cilium
# Subcommands from clustermesh-apiserver/cmd/root.go on tip.

_clustermesh-apiserver() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'clustermesh:run the ClusterMesh apiserver'
                'kvstoremesh:run the KVStoreMesh syncer'
                'etcdinit:one-shot initialize the embedded etcd data directory'
                'clustermesh-dbg:run clustermesh debug subcommands'
                'kvstoremesh-dbg:run kvstoremesh debug subcommands'
                'mcsapi-coredns-cfg:generate MCS API CoreDNS config'
                'shell:open the Cilium hive shell'
                'version:print version'
                'cmdref:generate command-line reference docs'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_clustermesh-apiserver "$@"
