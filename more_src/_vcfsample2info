#compdef vcfsample2info
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfsample2info.md
# vcflib: aggregate a per-sample FORMAT field into a site-level INFO statistic

local ret=1

_arguments -s -S \
  '(-f --field)'{-f,--field}'[add info about this sample field to INFO column]:field' \
  '(-i --info)'{-i,--info}'[store the computed statistic in this info field]:info' \
  '(-a --average)'{-a,--average}'[take the mean of samples for field (default)]' \
  '(-m --median)'{-m,--median}'[use the median]' \
  '(-n --min)'{-n,--min}'[use the min]' \
  '(-x --max)'{-x,--max}'[use the max]' \
  '*:vcf file:_files' && ret=0

return ret
