#compdef ansible-doc-cli
# _ansible-doc-cli — Red Hat Ansible plugin/module documentation viewer CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/ansible

_ansible-doc-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-vvv[more verbose]' \
        '--module-path=+[paths colon-separated]:str:' \
        '-M+[paths colon-separated]:str:' \
        '--list[list modules]' \
        '-l[list modules]' \
        '--list-files[list module files]' \
        '-F[list module files]' \
        '--metadata-dump[dump metadata]' \
        '--no-fail-on-errors[no fail on errors]' \
        '--snippet[snippet mode]' \
        '-s[snippet mode]' \
        '--json[json output]' \
        '-j[json output]' \
        '--playbook-dir=+[dir]:dir:_files -/' \
        '--roles-path=+[paths]:str:' \
        '--type=+[type]:t:(become cache callback cliconf connection httpapi inventory lookup netconf shell vars module strategy test filter role keyword)' \
        '-t+[type]:t:(become cache callback cliconf connection httpapi inventory lookup netconf shell vars module strategy test filter role keyword)' \
        '--entry-point=+[role entry]:str:' \
        '-e+[role entry]:str:' \
        '--show-snippet[show snippet]' \
        '*:plugin name:'
}

_ansible-doc-cli "$@"
