#compdef subinxxcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/subinxxcsv.c
# SUBINXXCSV - expand size and exchange corners of 3D grid definition

local ret=1

_arguments -s -S \
  'rfile=[read a K-file with grid definition]:f:_files' \
  'wfile=[write a K-file with grid definition]:f:_files' \
  'iflip=[exchange grid corners option]:i:' \
  'igilow=[low igi index value]:i:' \
  'igihigh=[high igi index value]:i:' \
  'igclow=[low igc index value]:i:' \
  'igchigh=[high igc index value]:i:' \
  '*:SU file:_files' && ret=0

return ret
