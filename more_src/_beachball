#compdef beachball

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'change:create a change file'
  'check:check if change files are needed'
  'bump:bump package versions'
  'publish:publish packages'
  'sync:sync versions to git tags'
  'canary:publish canary versions'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--branch[target branch]:branch name' \
  '--registry[npm registry to use]:registry url' \
  '--tag[dist-tag for published packages]:tag' \
  '--message[commit message for version bumps]:message' \
  '--scope[only apply to packages matching scope]:scope pattern' \
  '--no-push[skip pushing to remote]' \
  '--yes[skip confirmation prompts]' \
  '--verbose[enable verbose logging]' \
  '--config-path[path to beachball config file]:config file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'beachball command' commands && ret=0
    ;;
  args)
    case $line[1] in
      change)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--type[change type]:change type:(patch minor major none)' \
          '--message[description of the change]:message' \
          '--package[target package name]:package name' \
          '--dependent-change-type[change type for dependents]:change type:(patch minor major none)' && ret=0
        ;;
      check)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--branch[target branch to compare against]:branch name' \
          '--changehint[hint message when change files are missing]:hint message' && ret=0
        ;;
      bump)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--keep-change-files[do not delete change files after bumping]' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--registry[npm registry to use]:registry url' \
          '--tag[dist-tag for published packages]:tag' \
          '--token[npm token for authentication]:token' \
          '--branch[target branch]:branch name' \
          '--message[commit message for version bumps]:message' \
          '--no-push[skip pushing to remote]' \
          '--yes[skip confirmation prompts]' \
          '--bump[bump versions before publishing]' \
          '--publish[publish packages to registry]' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--tag[git tag to sync versions from]:tag' && ret=0
        ;;
      canary)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--tag[dist-tag for canary packages]:tag' \
          '--canary-name[name suffix for canary versions]:canary name' && ret=0
        ;;
    esac
    ;;
esac

return ret
