#compdef pspg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-a[force 8bit encoding]' \
  '-b[bold labels]' \
  '--bold-labels[bold labels]' \
  '--bold-cursor[bold cursor]' \
  '-s[set color theme]:theme number' \
  '--style[set color theme]:theme number' \
  '-c[freeze columns]:columns' \
  '--freezecols[freeze columns]:columns' \
  '-f[input file]:file:_files' \
  '--file[input file]:file:_files' \
  '-X[use tabular cursor]' \
  '--tabular-cursor[use tabular cursor]' \
  '--force-uniborder[use single lines for table borders]' \
  '--double-header[double header line]' \
  '--no-mouse[disable mouse support]' \
  '--no-sound[disable sound]' \
  '--less-status-bar[use less-style status bar]' \
  '--no-highlight-search[disable search highlighting]' \
  '--no-highlight-lines[disable line highlighting]' \
  '--highlight-odd-rec[highlight odd rows]' \
  '--hide-header-line[hide header line]' \
  '--on-sigint-exit[exit on SIGINT]' \
  '--no-sigint-search-reset[do not reset search on SIGINT]' \
  '--ni[not interactive, quit if input fits screen]' \
  '--no-interactive[not interactive, quit if input fits screen]' \
  '--no-last-row-frame[hide last row frame]' \
  '--vertical-cursor[enable vertical cursor]' \
  '--line-numbers[show line numbers]' \
  '--border[table border type]:type:(0 1 2)' \
  '--csv[input is CSV]' \
  '--csv-separator[CSV separator character]:char' \
  '--csv-header[CSV has header line]:mode:(on off)' \
  '--tsv[input is TSV]' \
  '--skip-columns-like[skip columns matching pattern]:pattern' \
  '--ignore-case[ignore case in search]' \
  '--quit-if-one-screen[quit if content fits in one screen]' \
  '-q[quiet mode]' \
  '--query=[initial search string]:string' \
  '-g[go to line]:line number' \
  '--watch=[watch interval in seconds]:seconds' \
  '--stream[streaming mode]' \
  '--progressive-load[progressive data loading]' \
  '*:file:_files' && ret=0

return ret