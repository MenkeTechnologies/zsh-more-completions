#compdef pspg
# Documentation: https://github.com/okbob/pspg/blob/master/src/args.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--about[show author info]' \
  '--info[show library/system info]' \
  '(-a --ascii)'{-a,--ascii}'[force ASCII output]' \
  '(-b --blackwhite)'{-b,--blackwhite}'[black-and-white style]' \
  '--bold-labels[bold row/column labels]' \
  '--bold-cursor[bold cursor]' \
  '(-s --style)'{-s,--style}'=[set color style number]:style number (0-22)' \
  '(-c --freezecols)'{-c,--freezecols}'=[freeze first N columns]:columns' \
  '(-f --file)'{-f,--file}'=[input file]:file:_files' \
  '(-X --reprint-on-exit)'{-X,--reprint-on-exit}'[preserve content after exit]' \
  '--tabular-cursor[show cursor only in table format]' \
  '--force-uniborder[force single-line Unicode borders]' \
  '--double-header[double header line]' \
  '--no-mouse[disable mouse]' \
  '--no-sound[disable sound]' \
  '--less-status-bar[less-style status bar]' \
  '(-g --hlite-search)'{-g,--hlite-search}'[do not highlight lines after search]' \
  '(-G --HILITE-SEARCH)'{-G,--HILITE-SEARCH}'[do not highlight lines after any search]' \
  '--highlight-odd-rec[highlight odd records]' \
  '--hide-header-line[hide header line]' \
  '--on-sigint-exit[exit on SIGINT]' \
  '--no-sigint-search-reset[do not reset search on SIGINT]' \
  '--ni[non-interactive, quit if input fits screen]' \
  '--interactive[force interactive mode]' \
  '--vertical-cursor[enable vertical column cursor]' \
  '--line-numbers[show line numbers]' \
  '--border=[table border type]:type:(0 1 2)' \
  '--csv[input is CSV]' \
  '--csv-separator=[CSV separator character]:char' \
  '--csv-header=[CSV header line]:mode:(on off)' \
  '--csv-trim-width=[trim values after N chars]:n' \
  '--csv-trim-rows=[trim after N rows]:n' \
  '--tsv[input is TSV]' \
  '--skip-columns-like=[skip columns matching substring]:pattern' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive search (smart-case)]' \
  '(-I --IGNORE-CASE)'{-I,--IGNORE-CASE}'[case-insensitive for all searches]' \
  '(-F --quit-if-one-screen)'{-F,--quit-if-one-screen}'[quit if content fits one screen]' \
  '(-q --query)'{-q,--query}'=[SQL query to execute]:query' \
  '(-w --watch)'{-w,--watch}'=[refresh query every N seconds]:seconds' \
  '--stream[streaming input mode]' \
  '--querystream[read queries from stream]' \
  '--no-progressive-load[disable progressive load]' \
  '--no-watch-file[disable file change monitoring]' \
  '--no-last-row-search[do not reuse previous search pattern]' \
  '--no-bars[hide bottom bar]' \
  '--no-commandbar[hide command bar]' \
  '--no-topbar[hide top bar]' \
  '--no-cursor[hide row cursor]' \
  '--no-scrollbar[hide scrollbar]' \
  '--no-sleep[remove anti-flicker delays]' \
  '--menu-always[always show top menu]' \
  '--only-for-tables[use standard pager for non-table content]' \
  '--ignore_file_suffix[ignore file format detection]' \
  '--ignore-short-rows[ignore rows with incorrect column count]' \
  '--direct-color[force direct-color terminal mode]' \
  '--null=[string for NULL]:string' \
  '--esc-delay=[escape key delay in ms]:ms' \
  '--clipboard-app=[clipboard application]:num:(1 2 3 4)' \
  '--pgcli-fix[fix pgcli-related issues]' \
  '--quit-on-f3[exit on F3 key]' \
  '--rr=[reserve N rows]:rownum' \
  '--on-exit-reset[send reset terminal sequence on exit]' \
  '--on-exit-clean[send clean terminal sequence on exit]' \
  '--on-exit-erase-line[send erase line sequence on exit]' \
  '--on-exit-sgr0[send SGR0 terminal sequence on exit]' \
  '--log=[log file]:file:_files' \
  '--wait=[wait N seconds for debugger]:seconds' \
  '(-d --dbname)'{-d,--dbname}'=[database name]:dbname' \
  '(-h --host)'{-h,--host}'=[database host]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[database port]:port' \
  '(-U --username)'{-U,--username}'=[database username]:user' \
  '(-W --password)'{-W,--password}'[prompt for password]' \
  '*:file:_files' && ret=0

return ret
