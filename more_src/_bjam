#compdef bjam
# Documentation: https://www.bfgroup.xyz/b2/manual/release/index.html
# Boost.Build build engine (legacy name for b2)

local ret=1

_arguments -s -S \
  '--help[invoke the online help system]' \
  '--version[print B2 and Boost.Jam version information]' \
  '--clean[clean targets in current directory and sub-projects]' \
  '--clean-all[clean all targets wherever defined]' \
  '--build-dir=[change build directory for project roots]:dir:_files -/' \
  '--abbreviate-paths[compress target paths by abbreviating components]' \
  '--hash[compress target paths using an MD5 hash]' \
  '-a[rebuild all files]' \
  '-n[print commands without executing them]' \
  '-q[stop at the first error]' \
  '-j+[run up to N commands in parallel]:jobs:' \
  '--config=[override all configuration files]:file:_files' \
  '--site-config=[override the default site configuration file]:file:_files' \
  '--user-config=[override the default user configuration file]:file:_files' \
  '--project-config=[override the default project configuration file]:file:_files' \
  '--debug-configuration[debug loading of B2 and toolset files]' \
  '--debug-building[print targets being built and their properties]' \
  '--debug-generators[produce debugging output from generator search]' \
  '-d+[set debugging level (0-13)]:level:' \
  '-o+[write updating actions to file instead of executing]:file:_files' \
  '-s+[set a global-scope variable]:var=value:' \
  '--command-database=[output a compile commands database]:format:(json)' \
  '--command-database-out=[file path for commands database output]:file:_files' \
  '*:target:' && ret=0

return ret
