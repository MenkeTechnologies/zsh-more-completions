#compdef pmiestatus
# _pmiestatus — report the status of a pmie inference engine (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flag from src/pmiestatus/pmiestatus.c (custom strcmp -v).

_pmiestatus() {
    _arguments \
        '-v[print stats structure size and version info]' \
        '*:pmie stats file:_files'
}

_pmiestatus "$@"
