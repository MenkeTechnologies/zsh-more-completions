#compdef tide
# _tide — Prow merge-queue controller (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/tide/main.go (flag).

_tide() {
    _arguments \
        '-port=[listen port]:port:' \
        '-dry-run=[mutate real-world state]:val:(true false)' \
        '-run-once[run once then exit]' \
        '-sync-hourly-tokens=[max GitHub tokens per hour for sync controller]:n:' \
        '-status-hourly-tokens=[max GitHub tokens per hour for status controller]:n:' \
        '-max-records-per-pool=[max history records per pool]:n:' \
        '-history-uri=[history URI (local/gs:///s3://)]:uri:' \
        '-status-path=[status URI (local/gs:///s3://)]:uri:' \
        '-cookiefile=[path to git http.cookiefile]:file:_files' \
        '-provider=[source code provider]:provider:(github gerrit)' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_tide "$@"
