#compdef mfsmakesnapshot
# Documentation: https://manpages.debian.org/bookworm/moosefs-client/mfsmakesnapshot.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfsmakesnapshot: snapshot a MooseFS file/dir
local curcontext="$curcontext" ret=1
_arguments -C \
  '-o[overwrite existing destination]' \
  '-c[cp-like attributes (no preservation)]' \
  '-p[preserve hardlinks]' \
  '*:src dst:_files' && ret=0
return ret
