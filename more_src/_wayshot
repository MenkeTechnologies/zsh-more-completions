#compdef wayshot
# Documentation: https://man.archlinux.org/search?q=wayshot
# Reference accessed: 2026-05-16

# Zsh completion for wayshot (Wayland native screenshot tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --list-outputs)'{-l,--list-outputs}'[list available outputs]' \
  '(-o --output)'{-o,--output=}'[specify output/display to screenshot]:output:' \
  '(-f --file)'{-f,--file=}'[output file path]:file:_files' \
  '(-e --extension)'{-e,--extension=}'[image encoder]:format:(png jpg jpeg ppm qoi)' \
  '(-s --slurp)'{-s,--slurp=}'[region to capture (x,y WxH)]:geometry:' \
  '(-c --cursor)'{-c,--cursor}'[include cursor in screenshot]' \
  '--stdout[output to stdout]' \
  '--clipboard[copy screenshot to clipboard]' && ret=0

return ret
