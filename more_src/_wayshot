#compdef wayshot
# Documentation: https://github.com/waycrate/wayshot
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--list-outputs[list available outputs]' \
  '(-o --output)'{-o,--output=}'[capture a specific output]:output:' \
  '(-f --file)'{-f,--file=}'[output file path]:file:_files' \
  '--encoding=[image encoder]:format:(jpg ppm qoi webp avif jxl)' \
  '(-g --geometry)'{-g,--geometry=}'[region to capture / interactive selector]:geometry:' \
  '--clipboard[copy screenshot to Wayland clipboard]' \
  '--color[freeze screen and pick a pixel color]' \
  '--choose-toplevel[interactively choose a window to capture]' \
  '--geometry-background-color=[selector background color]:color:' \
  '--geometry-foreground-color=[selector foreground color]:color:' \
  '--log-level=[tracing output level]:level:(error warn info debug trace)' \
  '--completions=[generate shell completions]:shell:(bash zsh fish elvish powershell)' && ret=0

return ret
