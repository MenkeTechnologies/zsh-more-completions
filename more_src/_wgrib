#compdef wgrib
# wgrib — decode and manipulate GRIB1 weather data files

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-s[short inventory]' \
  '-v[verbose inventory]' \
  '-V[very verbose inventory]' \
  '-d+[dump record number]:record number:' \
  '-p+[PDS dump]' \
  '-g[GDS dump]' \
  '-o+[set output file]:output file:_files' \
  '-text[text output]' \
  '-bin[binary output]' \
  '-ieee[IEEE output]' \
  '-grib[GRIB output]' \
  '-4yr[use 4-digit year]' \
  '-ncep_opn[use NCEP operational names]' \
  '-ncep_rean[use NCEP reanalysis names]' \
  '-nh[no header on output]' \
  '-h[include header on output]' \
  '-H[include full header on output]' \
  '-append[append to output file]' \
  '-dwb[use Dale-Baker table 2]' \
  '-PDS[print PDS in hex]' \
  '-GDS[print GDS in hex]' \
  '-PDS10[print PDS in decimal]' \
  '-GDS10[print GDS in decimal]' \
  '-verf[use verification time]' \
  '-min[print minimum value]' \
  '-max[print maximum value]' \
  '*:GRIB file:_files' && ret=0

return ret
