#compdef pfshdrcalibrate
# Documentation: http://pfstools.sourceforge.net/man1/pfshdrcalibrate.1.html
# pfstools: recover camera response and merge exposures into an HDR image

local ret=1

_arguments -s -S \
  '(-r --response)'{-r,--response}'=[predefined response curve]:type:(linear gamma log)' \
  '(-c --calibration)'{-c,--calibration}'=[self-calibration / merging method]:type:(robertson mitsunaga)' \
  '(-g --gauss)'{-g,--gauss}'=[sigma for Gaussian weighting function (default 0.2)]:val' \
  '(-f --response-file)'{-f,--response-file}'=[use response curve from matlab file]:file:_files' \
  '(-s --save-response)'{-s,--save-response}'=[save calculated response curve to file]:file:_files' \
  '(-m --multiplier)'{-m,--multiplier}'=[multiplier value]:val' \
  '(-b --bpp)'{-b,--bpp}'=[bits per pixel of input data (default 8)]:val' \
  '(-p --samples)'{-p,--samples}'=[number of self-calibration samples (Mitsunaga)]:val' \
  '(-o --saturation-offset)'{-o,--saturation-offset}'=[saturation offset (default 0.01)]:val' \
  '(-n --noise-parameters)'{-n,--noise-parameters}'=[noise values or camera preset]:val' \
  '(-d --deghosting)'{-d,--deghosting}'=[reduce ghosting artifacts (experimental)]:val' \
  '(-Y --luminance)'{-Y,--luminance}'[recover response for luminance channel only]' \
  '--verbose[print additional information]' \
  '--help[print list of command line options]' && ret=0

return ret
