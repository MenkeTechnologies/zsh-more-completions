#compdef beegfs-mgmtd
# Documentation: https://doc.beegfs.io/latest/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# beegfs-mgmtd: BeeGFS management service daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  'cfgFile=[config file]:file:_files' \
  'logStdFile=[stdout log file]:file:_files' \
  'logErrFile=[stderr log file]:file:_files' \
  'runDaemonized=[run as daemon]:bool:(true false)' \
  '1:config file:_files -g "*.conf"' \
  '*::beegfs-mgmtd args:_files' && ret=0
return ret
