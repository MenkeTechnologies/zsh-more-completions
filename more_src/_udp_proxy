#compdef udp_proxy

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'server_addr=:server address'
  'server_port=:server port'
  'listen_addr=:listen address'
  'listen_port=:listen port'
  'duplicate=:duplicate every Nth packet'
  'delay=:delay every Nth packet'
  'delay_ccs=:delay every Nth ChangeCipherSpec'
  'delay_cli=:delay packets matching client side prefix'
  'delay_srv=:delay packets matching server side prefix'
  'drop=:drop every Nth packet'
  'mtu=:MTU size'
  'bad_ad=:tamper authentication tag every Nth packet'
  'pack=:pack N records into one datagram'
  'protect_hvr=:randomize hello verify request'
  'protect_len=:protect this much data length'
  'seed=:RNG seed'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    _describe -t params 'param' params -S '' && ret=0
    ;;
esac

return ret
