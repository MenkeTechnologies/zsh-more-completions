#compdef cdi-importer
# _cdi-importer — CDI importer pod (downloads/converts disk images into a PVC)
# upstream: https://github.com/kubevirt/containerized-data-importer
# Flags from cmd/cdi-importer/importer.go on tip; main configuration via env vars (IMPORTER_SOURCE, ENDPOINT, CONTENT_TYPE, IMAGE_SIZE, OWNER_UID, CERT_DIR, FILESYSTEM_OVERHEAD, INSECURE_TLS, DISK_IMAGE_FILENAME, READY_FILE, DONE_FILE).

_cdi-importer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_cdi-importer "$@"
