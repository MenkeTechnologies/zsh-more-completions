#compdef sfpwsmooth
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: 2-D structure-enhancing filtering

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'ns=[spray radius]:ns:' \
  'order=[accuracy order]:order:' \
  'eps=[regularization]:eps:' \
  'adj=[adjoint flag (y/n)]:adj:(y n)' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
