#compdef kramdown-man
# Documentation: https://github.com/postmodern/kramdown-man/blob/main/lib/kramdown/man/cli.rb
# Convert a Markdown document into a roff man page

local ret=1

_arguments -s -S \
  '(-o --output)'{-o+,--output=}'[write the man page output to the file]:file:_files' \
  '(-V --version)'{-V,--version}'[print the version]' \
  '(-h --help)'{-h,--help}'[print the help output]' \
  '*:markdown file:_files' && ret=0

return ret
