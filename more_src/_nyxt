#compdef nyxt

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose debugging]' \
  '(- *)--version[show version]' \
  '--system-information[print system info]' \
  '(-i --config)'{-i,--config=}'[configuration file]:file:_files' \
  '(-I --no-config)'{-I,--no-config}'[do not load config]' \
  '(-c --auto-config)'{-c,--auto-config=}'[auto-configuration file]:file:_files' \
  '(-C --no-auto-config)'{-C,--no-auto-config}'[do not load auto-config]' \
  '(-s --socket)'{-s,--socket=}'[socket path]:path:_files' \
  '(-S --no-socket)'{-S,--no-socket}'[no socket]' \
  '*'{-e,--eval=}'[Lisp expression]:expr:' \
  '*'{-l,--load=}'[load Lisp file]:file:_files -g "*.lisp"' \
  '(-q --quit)'{-q,--quit}'[quit after load/eval]' \
  '--script=[load Lisp script then exit]:file:_files' \
  '(-r --remote)'{-r,--remote}'[send to running instance]' \
  '--headless[no GUI]' \
  '(-p --profile)'{-p,--profile=}'[profile name]:name:' \
  '--list-profiles[list profiles]' \
  '*--with-file=[set path reference]:ref=path:' \
  '--failsafe[start vanilla]' \
  '--electron-opts=[Electron options]:opts:' \
  '*:url:'
