#compdef system-override
# Documentation: man system-override (macOS) — `system-override` with no args
# prints: "system-override <command>" with `reset`, `<key>`, `<key>=on/off`
# Reference accessed: 2026-05-21
# Verified: locally on macOS 25.4 (/usr/bin/system-override).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command (key, key=on/off, or reset):(reset)' && ret=0

return ret
