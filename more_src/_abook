#compdef abook
# Documentation: https://man.archlinux.org/search?q=abook
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--datafile=[use specified address book file]:file:_files' \
  '--config=[use specified config file]:file:_files' \
  '--outformat=[specify output format]:format:(abook ldif mutt html pine csv allcsv palmcsv vcard custom)' \
  '--informat=[specify input format]:format:(abook ldif mutt pine csv vcard)' \
  '--outformatstr=[format string for custom output]:format string' \
  '--add-email[read email message from stdin and add sender]' \
  '--add-email-quiet[same as --add-email but less strident]' \
  '--convert[convert address book between formats]' \
  '*:file:_files'
