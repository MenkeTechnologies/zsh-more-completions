#compdef kubetest2-kind
# _kubetest2-kind — kubetest2 deployer for kind clusters (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from kubetest2-kind/deployer/deployer.go (gpflag).

_kubetest2-kind() {
    _arguments \
        '--build[build kubernetes]' \
        '--up[provision the test cluster]' \
        '--down[tear down the test cluster]' \
        '--test=[tester to run after deployer up]:tester:(ginkgo exec node clusterloader2)' \
        '--image-name=[image name for build and up]:name:' \
        '--base-image=[base image name for the build]:name:' \
        '--cluster-name=[kind cluster name]:name:' \
        '--build-type=[--type for kind build node-image]:type:' \
        '--config=[--config for kind create cluster]:file:_files' \
        '--kubeconfig=[--kubeconfig for kind create cluster]:file:_files' \
        '--kube-root=[Kubernetes source for kind build node-image]:dir:_files -/' \
        '*::tester args:_normal'
}

_kubetest2-kind "$@"
