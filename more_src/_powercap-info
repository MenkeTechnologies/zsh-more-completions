#compdef powercap-info

# powercap-info: print Linux powercap subsystem hierarchy info
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --control-type)'{-c,--control-type=}'[control type]:type:(intel-rapl)' \
  '(-z --zone)'{-z,--zone=}'[zone path (e.g. 0:0)]:zone:' \
  '(-p --constraint)'{-p,--constraint=}'[constraint id]:n:' \
  '*::powercap-info args:_files' && ret=0
return ret
