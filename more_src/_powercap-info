#compdef powercap-info
# Documentation: https://man.archlinux.org/search?q=powercap-info
# Reference accessed: 2026-05-16

# powercap-info: query Linux powercap subsystem
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p[control type (e.g. intel-rapl)]:type:(intel-rapl intel-rapl-mmio dtpm)' \
  '--control-type=[control type]:type:(intel-rapl intel-rapl-mmio dtpm)' \
  '-z[zone (comma separated levels)]:zone:' \
  '--zone=[zone (comma separated levels)]:zone:' \
  '-c[constraint id]:n:' \
  '--constraint=[constraint id]:n:' \
  '-j[JSON output]' \
  '--json[JSON output]' \
  '*::powercap-info args:_files' && ret=0
return ret
