#compdef s3-pit-restore
# Documentation: https://github.com/angeloc/s3-pit-restore
# s3-pit-restore - point in time restore tool for Amazon S3

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bucket)'{-b,--bucket=}'[s3 bucket to restore from]:bucket' \
  '(-B --dest-bucket)'{-B,--dest-bucket=}'[s3 bucket where recovering to]:bucket' \
  '(-d --dest)'{-d,--dest=}'[path where recovering to on local]:dest:_files -/' \
  '(-p --prefix)'{-p,--prefix=}'[s3 path to restore from]:prefix' \
  '(-P --dest-prefix)'{-P,--dest-prefix=}'[s3 path to restore to]:prefix' \
  '(-t --timestamp)'{-t,--timestamp=}'[final point in time to restore at]:timestamp' \
  '(-f --from-timestamp)'{-f,--from-timestamp=}'[starting point in time to restore from]:timestamp' \
  '(-e --enable-glacier)'{-e,--enable-glacier}'[enable recovering from glacier]' \
  '(-v --verbose)'{-v,--verbose}'[print verbose informations from s3 objects]' \
  '(-u --endpoint-url)'{-u,--endpoint-url=}'[use another endpoint URL for s3 service]:url' \
  '--dry-run[execute query without transferring files]' \
  '--debug[enable debug output]' \
  '--test[s3 pit restore testing]' \
  '--max-workers=[max number of concurrent download requests]:workers' \
  '--sse=[specify server-side encryption]:sse:(AES256 aws\:kms)' && ret=0

return ret
