#compdef racket-cli2 racket2 raco2
# _racket-cli2 — PLT Racket racket-cli2 CLI command-line frontend wrapping the Racket general-purpose multi-paradigm programming language based on the Scheme dialect of Lisp open-source written in Racket originally Matthias Felleisen at Rice University Northeastern University now PLT Racket designed to be a platform for programming language design and implementation Racket-on-Chez backend Scheme Lisp DrRacket IDE typed-racket lazy-racket racketcs racketbc raco pkg make exe distribute setup test docs profile cover doxygen docs decompile expand setup setup pkg-action raco-pkg-install (PLT Racket team Matthias Felleisen Matthew Flatt Robby Findler, Racket); custom argparse
# upstream: https://racket-lang.org/

_racket-cli2() {
    local -a sub=(
        'pkg:Package management'
        'setup:Set up installed packages'
        'docs:Show installed documentation'
        'make:Compile Racket files'
        'compile:Compile to zo'
        'exe:Create an executable'
        'distribute:Bundle binaries for distribution'
        'demodularize:Combine modules into one file'
        'expand:Expand a module'
        'decompile:Decompile from bytecode'
        'cover:Code coverage'
        'profile:Run with statistical profiler'
        'plt:Pack into PLT'
        'unpack:Unpack a PLT'
        'test:Run tests'
        'check-requires:Check require statements'
        'scribble:Render Scribble documentation'
        'plot:Plot data'
        'planet:Manage Planet packages'
        'tools:Show available raco tools'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-e+[eval expression]:str:' \
        '*-e+[eval expression]:str:' \
        '--eval=+[expr]:str:' \
        '*--eval=+[expr]:str:' \
        '-l+[require library]:str:' \
        '*-l+[require library]:str:' \
        '--lib=+[library]:str:' \
        '*--lib=+[library]:str:' \
        '-t+[require module]:_files' \
        '*-t+[require module]:_files' \
        '--require=+[module]:_files' \
        '*--require=+[module]:_files' \
        '-u+[require user-specific]:str:' \
        '*-u+[require]:str:' \
        '-r+[load file]:_files' \
        '*-r+[load file]:_files' \
        '--load=+[file]:_files' \
        '*--load=+[file]:_files' \
        '-f+[load file]:_files' \
        '*-f+[load file]:_files' \
        '--script=+[file]:_files' \
        '*--script=+[file]:_files' \
        '-A+[addon dir]:dir:_files -/' \
        '--addon=+[dir]:dir:_files -/' \
        '-N+[name]:str:' \
        '--name=+[name]:str:' \
        '-X+[collects dir]:dir:_files -/' \
        '--collects=+[dir]:dir:_files -/' \
        '-S+[link dir]:dir:_files -/' \
        '*-S+[link dir]:dir:_files -/' \
        '--search=+[dir]:dir:_files -/' \
        '-G+[config dir]:dir:_files -/' \
        '--config=+[dir]:dir:_files -/' \
        '-U+[no-user-info dir]:dir:_files -/' \
        '--no-user-path[no user path]' \
        '-i+[init module]:str:' \
        '--init=+[module]:str:' \
        '-c[no clobber]' \
        '-d[disable check]' \
        '-D+[def]:str:' \
        '*-D+[def]:str:' \
        '-W+[warnings]:str:' \
        '--warnings=+[w]:str:' \
        '-y[set as default]' \
        '-z[memory limit]' \
        '-K+[memory limit]:n:' \
        '--memory=+[N]:n:' \
        '-j+[jobs]:n:' \
        '--jobs=+[N]:n:' \
        '--quiet[quiet]' \
        '--init-stack=+[N]:n:' \
        '-n[no init]' \
        '--no-init[no init]' \
        '-m+[no init module]:str:' \
        '--module=+[mod]:str:' \
        '-a[no startup file]' \
        '--no-rc[no startup file]' \
        '--clean[clean cache]' \
        '--no-prompt[no prompt]' \
        '--no-init-stack[no init stack]' \
        '--main[run main module]' \
        '--repl[REPL]' \
        '-I+[init module]:str:' \
        '--make[make]' \
        '--no-make[no make]' \
        '--no-zo[no zo]' \
        '--no-doc[no doc]' \
        '--no-launch[no launch]' \
        '--no-pkg-deps[no pkg deps]' \
        '--no-cc-cache[no cc cache]' \
        '--no-zo-recompile[no zo recompile]' \
        '--no-foreign-libs[no foreign libs]' \
        '--no-install-deps[no install deps]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'raco subcommand' sub ;;
        args)
            case $words[1] in
                pkg) _arguments '1:op:(install update remove show new search create config catalog-show migrate empty-trash uninstall config archive)' '*:pkg:' ;;
                make|compile|exe|distribute|demodularize|expand|decompile|cover|profile|test|setup|check-requires|scribble) _arguments '*:source:_files -g "*.rkt *.ss *.scm"' ;;
                docs) _arguments '*:topic:' ;;
                planet) _arguments '1:op:(install remove fetch unlink urpe)' '*:arg:' ;;
            esac
            ;;
    esac
}

_racket-cli2 "$@"
