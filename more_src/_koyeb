#compdef koyeb

local curcontext="$curcontext" state line ret=1

_koyeb_commands() {
  local -a commands=(
    'apps:Manage applications'
    'services:Manage services'
    'deployments:Manage deployments'
    'domains:Manage domains'
    'secrets:Manage secrets'
    'instances:Manage instances'
    'databases:Manage databases'
    'login:Login to Koyeb'
    'logout:Logout from Koyeb'
    'organizations:Manage organizations'
    'completion:Generate shell completions'
    'version:Show version'
  )
  _describe -t commands 'koyeb command' commands
}

_koyeb_resource_subcommands() {
  local -a subcmds=(
    'create:Create a resource'
    'get:Get a resource'
    'list:List resources'
    'update:Update a resource'
    'delete:Delete a resource'
    'describe:Describe a resource'
  )
  _describe -t commands 'subcommand' subcmds
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '--app[Application name]:app' \
  '--organization[Organization name]:org' \
  {-o,--output}'[Output format]:format:(full table yaml json id)' \
  '--token[API token]:token' \
  '--url[API URL]:url' \
  {-d,--debug}'[Enable debug mode]' \
  '1:command:_koyeb_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      apps)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      services)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '--app[Application name]:app' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      deployments)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '--app[Application name]:app' \
          '--service[Service name]:service' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      domains)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      secrets)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      instances)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '--app[Application name]:app' \
          '--service[Service name]:service' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      databases)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      organizations)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_koyeb_resource_subcommands' \
          '*:name' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:shell:(bash zsh fish powershell)' \
          && ret=0
        ;;
      version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
