#compdef json-tui
# Documentation: https://github.com/ArthurSonzogni/json-tui
# Interactive JSON terminal UI viewer

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display this help menu]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1:JSON file (omit to read from stdin):_files' && ret=0

return ret
