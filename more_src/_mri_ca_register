#compdef mri_ca_register
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_ca_register
# FreeSurfer nonlinear registration of a volume to a GCA template

local ret=1

_arguments -s -S \
  '-tol[defines convergence of registration]:tol:' \
  '-mask[volume to use as a mask]:mask:_files' \
  '-T[transform in lta format]:transform:_files' \
  '-level[surrounding voxels used in interpolation (def 6)]:level:' \
  '-ri[read multiple intensity normalization]:ri:' \
  '1:input volume:_files' \
  '2:template (gca format):_files' \
  '3:output volume (m3d format):_files' && ret=0

return ret
