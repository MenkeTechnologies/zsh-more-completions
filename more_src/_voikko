#compdef voikkospell voikko voikkogc voikkohyphenate
# _voikko — Voikko voikkospell CLI Finnish-language morphological spell-checker grammar-checker hyphenator wrapping libvoikko Malaga-based finite-state-machine analyzer producing suggestions hyphenation grammar warnings parser-trees morpho-syntactic tags for Finnish input text (Hatapainen Voikko team, C++); getopt
# upstream: https://voikko.puimula.org/

_voikko() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[dict variant]:str:' \
        '--dictionary=+[variant]:str:' \
        '-p+[dict path]:dir:_files -/' \
        '--path=+[dir]:dir:_files -/' \
        '-e+[encoding]:e:(UTF-8 ISO-8859-1 ISO-8859-15)' \
        '--encoding=+[enc]:e:(UTF-8 ISO-8859-1 ISO-8859-15)' \
        '-x[XML output]' \
        '-s+[suggest]:str:' \
        '--suggest[print suggestions]' \
        '-W+[word list]:file:_files' \
        '-c[print correct words only]' \
        '-m[morphological analysis]' \
        '--analyze[morphological analysis]' \
        '-t[tokenize]' \
        '--tokenize[tokenize]' \
        '-T+[token type]:t:(WORD PUNCTUATION WHITESPACE UNKNOWN)' \
        '-o+[option=value]:str:' \
        '*:input file:_files'
}

_voikko "$@"
