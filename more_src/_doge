#compdef doge
# Documentation: https://man.archlinux.org/search?q=doge
# Reference accessed: 2026-05-16

# Dj-Codeman/dog_community — getopts per src/options.rs (v0.2.x)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '*'{-q+,--query=}'[host or domain]:host:_hosts' \
  '*'{-p+,--port=}'[non-standard port]:port:' \
  '*'{-t+,--type=}'[record type]:type:(A AAAA CAA CERT CNAME DNAME HINFO HTTPS LOC MX NAPTR NS PTR SOA SRV SSHFP TLSA TSIG TXT ANY)' \
  '*'{-n+,--nameserver=}'[nameserver address]:addr:_hosts' \
  '*'--class='[query class]:class:(IN CH HS)' \
  '--edns=[EDNS option]:setting:(disable hide show)' \
  '--txid=[force transaction ID]:number:' \
  '*'{-Z+}'[protocol tweak]:tweak:' \
  {-U,--udp}'[DNS over UDP]' \
  {-T,--tcp}'[DNS over TCP]' \
  {-S,--tls}'[DNS-over-TLS]' \
  {-H,--https}'[DNS-over-HTTPS]' \
  '--color=[when to colorize output]:when:(always auto never)' \
  '--colour=[when to colour output]:when:(always auto never)' \
  '(-J --json)'{-J,--json}'[JSON output]' \
  '--seconds[show durations as seconds]' \
  '(-1)-1 --short[only first result]' \
  '--time[print query timing]' \
  '(- ? *)'{-v,--version}'[print version]' \
  '(- *)-'{-\?,--help}'[print help]' \
  '*:domain:_hosts' && ret=0

return ret
