#compdef i3cset
# _i3cset — i3c-tools i3cset CLI writer issuing private-write or in-band-interrupt-aware writes to an I3C device on a Linux /dev/i3c-* character device taking byte word block data and slave dynamic address selecting CCC ENEC DISEC SETMWL SETMRL command codes (Boris Brezillon team, C); getopt
# upstream: https://github.com/i3c-tools/i3c-tools

_i3cset() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-y[non-interactive]' \
        '-v[verbose]' \
        '-m+[mode]:m:(b w l s i p I3C_PRIV_XFER CCC_BROADCAST CCC_DIRECT)' \
        '-r[raw]' \
        '-f[force]' \
        '1:i3c-bus:_files -g "/dev/i3c-*"' \
        '2:address:' \
        '3:data-address:' \
        '*:value:'
}

_i3cset "$@"
