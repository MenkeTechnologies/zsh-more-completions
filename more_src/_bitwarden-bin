#compdef bw bitwarden
# _bitwarden-bin — Bitwarden CLI (Node.js); manage Bitwarden vault items, send, organizations from terminal
# upstream: https://github.com/bitwarden/clients

_bitwarden-bin() {
    local -a sub=(
        'login:login to a Bitwarden server'
        'logout:logout'
        'lock:lock the vault'
        'unlock:unlock the vault'
        'sync:pull changes from server'
        'list:list items/folders/collections/orgs'
        'get:get an item/attachment/folder/collection/etc'
        'create:create an item/folder/attachment'
        'edit:edit item/folder/etc'
        'delete:delete item/folder'
        'restore:restore from trash'
        'share:share an item with an org'
        'confirm:confirm org user invite'
        'import:import vault from file'
        'export:export vault to file'
        'generate:generate a password/passphrase'
        'encode:base64 encode stdin'
        'config:show or set config'
        'update:check for updates'
        'completion:print shell completion'
        'status:show vault/server status'
        'serve:start local Vault management REST API'
        'send:create/list/edit/delete sends'
        'receive:receive a Send'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--raw[unformatted output]' \
        '--response[machine-readable response object]' \
        '--cleanexit[suppress exit code 1 on user cancel]' \
        '--quiet[silent]' \
        '--nointeraction[no interactive prompts]' \
        '--session+[session key]:key:' \
        '--pretty[pretty print output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bw subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments '1:object:(items folders collections organizations org-collections org-members)' ;;
                get) _arguments '1:object:(item username password uri totp notes exposed attachment folder collection org-collection organization template fingerprint)' '2:name or id:' ;;
                generate) _arguments \
                    '(-l --lowercase)'{-l,--lowercase}'[include lowercase]' \
                    '(-u --uppercase)'{-u,--uppercase}'[include uppercase]' \
                    '(-n --number)'{-n,--number}'[include digits]' \
                    '(-s --special)'{-s,--special}'[include symbols]' \
                    '(-p --passphrase)'{-p,--passphrase}'[generate passphrase]' \
                    '--length+[length]:n:' \
                    '--words+[word count]:n:' \
                    '--separator+[separator]:str:' \
                    '--capitalize[capitalize words]' \
                    '--includeNumber[include digit in passphrase]' \
                    '--minNumber+[min digits]:n:' \
                    '--minSpecial+[min specials]:n:' \
                    '--ambiguous[allow ambiguous chars]' ;;
            esac
            ;;
    esac
}

_bitwarden-bin "$@"
