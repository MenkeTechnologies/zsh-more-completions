#compdef risor

local -a _risor_commands
_risor_commands=(
  'run:run a Risor script'
  'fmt:format source code'
  'repl:start interactive REPL'
  'eval:evaluate an expression'
  'version:print version'
  'help:help about any command'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--cpu-profile[write CPU profile]:file:_files' \
  '--mem-profile[write memory profile]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'risor commands' _risor_commands
    ;;
  args)
    case "$words[1]" in
      run)
        _arguments \
          '--code[code to execute]:code' \
          '--modules-dir[modules directory]:dir:_directories' \
          '--timeout[execution timeout]:timeout' \
          '*:script file:_files -g "*.risor"'
        ;;
      eval)
        _arguments '*:expression'
        ;;
      fmt)
        _arguments \
          '--write[write result to source file]' \
          '--diff[display diff]' \
          '*:file:_files -g "*.risor"'
        ;;
    esac
    ;;
esac
