#compdef prqlc

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'compile:compile PRQL to SQL'
      'resolve:resolve PRQL'
      'debug:debug commands'
      'collect:collect a PRQL project'
      'experimental:experimental commands'
    )
    _describe -t commands 'prqlc command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      compile)
        _arguments -s -S \
          '(-t --target)'{-t,--target}'[target SQL dialect]:target:(sql.any sql.clickhouse sql.duckdb sql.generic sql.mssql sql.mysql sql.postgres sql.sqlite sql.ansi)' \
          '(-f --format)'{-f,--format}'[output format]:format:(json yaml)' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac
return ret
