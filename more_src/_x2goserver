#compdef x2goserver

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start server'
  'stop:stop server'
  'restart:restart server'
  'reload:reload config'
  'status:show status'
  'sessions:list sessions'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'x2goserver command' commands && ret=0 ;;
esac

return ret
