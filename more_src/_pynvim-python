#compdef pynvim-python
# Documentation: https://man.archlinux.org/search?q=pynvim-python
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[program passed in as string]:cmd:' \
  '-m+[run library module as script]:module:' \
  '-V[print version]' \
  '*:script:_files -g "*.py"' && ret=0

return ret
