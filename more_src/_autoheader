#compdef autoheader
# Documentation: autoheader --help (GNU Autoconf)
# Source: build a C #define template scanned from configure.ac.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-v,--verbose}'[verbosely report processing]' \
    {-d,--debug}'[do not remove temporary files]' \
    {-f,--force}'[consider all files obsolete]' \
    {-R,--replace-handwritten}'[overwrite handwritten template]' \
    '*'{-W+,--warnings=}'[report warnings in CATEGORY]:category:(cross gnu obsolete override portability portability-recursive extra-portability syntax unsupported all none error)' \
    '*'{-B+,--prepend-include=}'[prepend directory to search path]:dir:_files -/' \
    '*'{-I+,--include=}'[append directory to search path]:dir:_files -/' \
    ':template file:_files -g "configure.(ac|in)"' \
    && ret=0

return ret
