#compdef apache_exporter
# Documentation: https://github.com/Lusitaniae/apache_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--scrape_uri=[URI to Apache status page]:uri:' \
  '--host_override=[override host header]:host:' \
  '--insecure[ignore server certificate errors]' \
  '--telemetry.address=[address to listen on]:address:' \
  '--telemetry.endpoint=[path for metrics]:path:' \
  '*--custom_headers=[custom headers for scraping]:header:' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
