#compdef kismetdb_strip_packet_content
# Documentation: https://www.kismetwireless.net/docs/readme/kismetdb/kismetdb_strip_packets/
# kismetdb_strip_packet_content — strip stored packet contents from a kismetdb log, keeping metadata

local ret=1

_arguments -s -S \
  '--in=[input kismetdb file to process]:file:_files' \
  '--out=[output destination file for stripped database]:file:_files' \
  '--verbose[increase console status output]' \
  '--force[overwrite target file if it already exists]' \
  '--skip-clean[skip SQL optimization to save time on larger captures]' && ret=0

return ret
