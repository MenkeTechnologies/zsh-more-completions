#compdef slumber

# Zsh completion for slumber - terminal-based HTTP/REST client

local curcontext="$curcontext" state line ret=1

_slumber_commands() {
  local -a commands=(
    'request:execute a request directly from the command line'
    'collections:manage collections'
    'generate:generate code (curl etc.) from a recipe'
    'history:view request history'
    'show:show meta info about slumber'
    'import:import a collection from another format (e.g. Insomnia)'
    'new:create a new empty collection file'
    'help:print help'
  )
  _describe -t commands 'slumber command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[collection file]:file:_files' \
  '(-l --log)'{-l,--log}'[log file]:file:_files' \
  '1: :_slumber_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      request|req|rq)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --profile)'{-p,--profile}'[profile to use]:profile' \
          '--override[override field value (e.g. .field=value)]:override' \
          '(-o --output)'{-o,--output}'[output format]:format:(body headers status request)' \
          '(-c --collection)'{-c,--collection}'[collection file]:file:_files' \
          '--dry-run[print request without sending]' \
          '1:recipe id' && ret=0
        ;;
      generate)
        _arguments \
          '(-p --profile)'{-p,--profile}'[profile to use]:profile' \
          '1:format:(curl)' \
          '2:recipe id' && ret=0
        ;;
      import)
        _arguments \
          '1:format:(insomnia openapi)' \
          '2:input file:_files' \
          '3:output file:_files' && ret=0
        ;;
      new)
        _arguments '1:output file:_files' && ret=0
        ;;
      show)
        _arguments '1:target:(paths config collection dir)' && ret=0
        ;;
    esac
    ;;
esac

return ret
