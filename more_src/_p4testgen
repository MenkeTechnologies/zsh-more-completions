#compdef p4testgen
# Documentation: https://github.com/p4lang/p4c/blob/main/backends/p4tools/modules/testgen/README.md
# P4Tools test case generator for P4 programs

local ret=1

_arguments -s -S \
  '--help[show documentation of supported command line options]' \
  '--target=[specify the targeted network device]:target:(bmv2 pna dpdk)' \
  '--arch=[specify the P4 architecture]:arch:(v1model psa pna)' \
  '--max-tests=[number of tests to generate (0 for exhaustive)]:N' \
  '--out-dir=[output directory for generated tests]:dir:_files -/' \
  '--test-backend=[select the test output backend]:backend:(PTF STF PROTOBUF METADATA)' \
  '--track-coverage=[track program coverage]:node:(STATEMENTS TABLE_ENTRIES)' \
  '--stop-metric=[halt generation at metric]:metric:(MAX_NODE_COVERAGE)' \
  '--print-coverage[emit nodes that cannot be covered]' \
  '--disable-assumption-mode[disable testgen_assume constraints]' \
  '--assertion-mode[generate tests violating testgen_assert conditions]' \
  '--strict[fail on unrecoverable tainted behavior]' \
  '--packet-size-range=[set the packet size range in bits]:min\:max' \
  '--port-ranges=[set the valid port ranges]:ranges' \
  '--path-selection=[set the path selection strategy]:strategy' \
  '--test-name=[base name for the generated tests]:name' \
  '--output-packet-only[only generate tests with output packets]' \
  '--dropped-packet-only[only generate tests with dropped packets]' \
  '--only-covering-tests[only output tests that increase coverage]' \
  '--print-traces[print execution traces]' \
  '--print-steps[print the executed steps]' \
  '*:P4 source:_files -g "*.p4"' && ret=0

return ret
