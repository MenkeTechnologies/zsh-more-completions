#compdef swhkd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[config file]:config file:_files' \
  '-C[check config syntax]' \
  '-d[enable debug mode]' \
  '-D[specify device to use]:device:_files -W /dev/input' \
  '--device[specify device]:device:_files -W /dev/input' && ret=0

return ret
