#compdef fdelrow
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fdelrow.txt
# Delete specified rows in a FITS table

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "firstrow=[first row to delete]:" \
  "confirm=[prompt for confirmation]:bool:(yes no)" \
  "proceed=[proceed with deletion]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
