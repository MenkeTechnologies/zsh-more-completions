#compdef capo-controller-manager
# _capo-controller-manager — Cluster API OpenStack provider controller manager (CAPO)
# upstream: https://github.com/kubernetes-sigs/cluster-api-provider-openstack
# Flags from main.go (pflag) on tip.

_capo-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show current version and exit]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--namespace=[restrict CAPO to a single namespace]:ns:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--profiler-address=[pprof bind address]:host\:port:' \
        '--openstackcluster-concurrency=[OpenStackCluster concurrent reconciles]:n:' \
        '--openstackmachine-concurrency=[OpenStackMachine concurrent reconciles]:n:' \
        '--openstackmachinetemplate-concurrency=[OpenStackMachineTemplate concurrent reconciles]:n:' \
        '--sync-period=[informer resync period]:dur:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--webhook-port=[webhook server port]:port:' \
        '--webhook-cert-dir=[webhook serving cert dir]:dir:_files -/' \
        '--health-addr=[health probe bind address]:host\:port:' \
        '--lb-provider=[Octavia load-balancer provider]:provider:(amphora ovn)' \
        '--ca-certs=[default CA certs file (PEM)]:file:_files' \
        '--scope-cache-max-size=[max credential cache entries (0=disable)]:n:' \
        '*--skip-crd-migration-phases=[CRD migration phases to skip]:list:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capo-controller-manager "$@"
