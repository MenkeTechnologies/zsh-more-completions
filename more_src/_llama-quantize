#compdef llama-quantize

local curcontext="$curcontext" state line ret=1

local -a quant_types=(
  'Q4_0:4-bit quantization method 0'
  'Q4_1:4-bit quantization method 1'
  'Q5_0:5-bit quantization method 0'
  'Q5_1:5-bit quantization method 1'
  'Q8_0:8-bit quantization method 0'
  'Q2_K:2-bit quantization (K-quants)'
  'Q3_K_S:3-bit quantization K small'
  'Q3_K_M:3-bit quantization K medium'
  'Q3_K_L:3-bit quantization K large'
  'Q4_K_S:4-bit quantization K small'
  'Q4_K_M:4-bit quantization K medium'
  'Q5_K_S:5-bit quantization K small'
  'Q5_K_M:5-bit quantization K medium'
  'Q6_K:6-bit quantization K'
  'IQ2_XXS:2-bit importance quantization extra-extra-small'
  'IQ2_XS:2-bit importance quantization extra-small'
  'IQ2_S:2-bit importance quantization small'
  'IQ2_M:2-bit importance quantization medium'
  'IQ3_XXS:3-bit importance quantization extra-extra-small'
  'IQ3_XS:3-bit importance quantization extra-small'
  'IQ3_S:3-bit importance quantization small'
  'IQ3_M:3-bit importance quantization medium'
  'IQ4_NL:4-bit importance quantization non-linear'
  'IQ4_XS:4-bit importance quantization extra-small'
  'IQ1_S:1-bit importance quantization small'
  'IQ1_M:1-bit importance quantization medium'
  'F16:16-bit float'
  'BF16:16-bit bfloat'
  'F32:32-bit float'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '--allow-requantize[allow requantizing already quantized tensors]' \
  '--leave-output-tensor[do not quantize the output tensor]' \
  '--pure[disable k-quant mixtures, quantize all tensors]' \
  '--imatrix=[importance matrix file]:imatrix file:_files' \
  '--include-weights=[include specific tensor names]:tensor patterns' \
  '--exclude-weights=[exclude specific tensor names]:tensor patterns' \
  '--output-tensor-type=[output tensor type]:type' \
  '--token-embedding-type=[token embedding type]:type' \
  '--override-kv=[override key-value metadata]:key=value' \
  '-t+[number of threads]:threads' \
  '--nthread=[number of threads]:threads' \
  '1:input model:_files -g "*.gguf"' \
  '2:output model:_files -g "*.gguf"' \
  '3:quantization type:->quant_type' && ret=0

case "$state" in
  quant_type)
    _describe -t quant-types 'quantization type' quant_types && ret=0
    ;;
esac

return ret
