#compdef whereabouts
# _whereabouts — Network Plumbing Working Group whereabouts CLI cluster-wide IP-address management IPAM CNI plugin for Kubernetes multi-cluster reservation-aware allocation across multiple worker nodes supporting IPv4 IPv6 dual-stack range-exclusion sticky-IP-leader-election cluster-wide-IPPool-CRD reclaim-policy command management (NPWG team, Go); cobra
# upstream: https://github.com/k8snetworkplumbingwg/whereabouts

_whereabouts() {
    local -a sub=(
        'install:install whereabouts'
        'reconcile:reconcile leaked IP addresses'
        'list-ips:list allocated IPs'
        'release-ip:release allocated IP'
        'audit:audit IP allocations'
        'ip-overlap:check overlapping ranges'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--ippool-cidr=+[cidr]:str:' \
        '--exclude-cidrs=+[list]:str:' \
        '--log-level=+[l]:l:(debug info warn error fatal)' \
        '--reconcile-interval=+[duration]:str:' \
        '--ipv6=+[bool]:s:(true false)' \
        '-o+[output]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'whereabouts subcommand' sub ;;
        args)
            case $words[1] in
                list-ips) _arguments '*:pool name:' ;;
                release-ip) _arguments '*:ip:' ;;
            esac
            ;;
    esac
}

_whereabouts "$@"
