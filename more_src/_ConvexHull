#compdef ConvexHull
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/ConvexHull.html
# AFNI/SUMA convex hull or delaunay triangulation of a set of points

local ret=1

_arguments -s -S \
  '-input[input AFNI-readable volume]:dataset:_files' \
  '-isoval[isosurface where volume equals V]:v:' \
  '-isorange[isosurface where V0 <= volume < V1]:v0:' \
  '-isocmask[isosurface where MASK_COM is nonzero]:mask:' \
  '-xform[transform on volume values]:xform:(mask shift none)' \
  '-i_TYPE[use surface model nodes as input]:surface:_files' \
  '-sv[surface volume with transform for coordinates]:dataset:_files' \
  '-input_1D[build triangulation from points in 1D file]:file:_files' \
  '-q_opt[meshing option]:opt:(convex_hull triangulate_xy)' \
  '-proj_xy[project points onto plane aligned with Z axis]' \
  '-orig_coord[use original coordinates when writing surface]' \
  '-these_coords[use specific coordinates when writing surface]:file:_files' \
  '-o_TYPE[output surface format and prefix]:prefix:' \
  '-onestate[all input surfaces appear simultaneously]' \
  '-anatomical[label input surfaces as anatomical]' \
  '(-novolreg -noxform)-novolreg[ignore transforms in surface volume]' \
  '(-novolreg -noxform)-noxform[ignore transforms in surface volume]' \
  '-setenv[set environment variable]:env:' \
  '*:input:_files' && ret=0

return ret
