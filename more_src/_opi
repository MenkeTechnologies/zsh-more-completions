#compdef opi

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-n[non-interactive mode]' \
  '-P[no plugins - only search repos, OBS, Packman]' \
  '-m[treat args as space-separated package queries]' \
  '*:package query:' && ret=0

return ret
