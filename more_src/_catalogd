#compdef catalogd
# _catalogd — OLMv1 file-based catalog content server (operator-framework/operator-controller)
# upstream: https://github.com/operator-framework/operator-controller
# Flags from cmd/catalogd/main.go on tip.

_catalogd() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port (requires --tls-cert/--tls-key)]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--pprof-bind-address=[pprof bind host\:port (0/empty disables)]:host\:port:' \
        '--leader-elect[enable leader election]' \
        '--system-namespace=[namespace for internal catalogd state]:ns:' \
        '--catalogs-server-addr=[bind host\:port for the catalog content HTTPS server]:host\:port:' \
        '--external-address=[advertised hostname for the catalog HTTPS server]:host:_hosts' \
        '--cache-dir=[file-based cache directory]:dir:_files -/' \
        '--gc-interval=[garbage-collection interval]:dur:' \
        '--tls-cert=[TLS cert file]:file:_files' \
        '--tls-key=[TLS key file]:file:_files' \
        '--webhook-server-port=[webhook server port]:port:' \
        '--pull-cas-dir=[CA bundle dir for verifying image-registry HTTPS]:dir:_files -/' \
        '--global-pull-secret=[global pull secret in <namespace>/<name>]:secret:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_catalogd "$@"
