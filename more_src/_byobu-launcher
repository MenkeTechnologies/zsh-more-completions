#compdef byobu-launcher
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/byobu-launcher.1.html
# byobu: launch byobu at login, reconnecting to an existing session

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
