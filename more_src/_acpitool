#compdef acpitool
# Documentation: man acpitool(1)
# Source: tesuji/acpitool src/acpitool.cpp (master) — display ACPI info, suspend system (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --ac_adapter)'{-a,--ac_adapter}'[AC adapter information]' \
    '(-A --Asus)'{-A,--Asus}'[show Asus ACPI extensions]' \
    '-b[battery status (available only)]' \
    '(-B --battery)'{-B,--battery}'[all battery info]' \
    '(-c --cpu)'{-c,--cpu}'[CPU info]' \
    '-e[show everything]' \
    '(-f --fan)'{-f,--fan}'[fan status]' \
    '-F+[force fan on (1) or auto (0) - Toshiba]:val:(0 1)' \
    '(-h --help)'{-h,--help}'[show help]' \
    '-j[eject ultrabay device (Thinkpad)]' \
    '-l+[set LCD brightness 0..7 (Toshiba/Thinkpad)]:level:(0 1 2 3 4 5 6 7)' \
    '-m+[mail LED 1=on 0=off (Asus)]:val:(0 1)' \
    '-n+[wireless LED 1=on 0=off (Asus)]:val:(0 1)' \
    '-o+[LCD 1=on 0=off (Asus)]:val:(0 1)' \
    '(-s --suspend)'{-s,--suspend}'[suspend to RAM (S3)]' \
    '-S[suspend to disk (S4)]' \
    '(-t --thermal)'{-t,--thermal}'[thermal info incl. trip_points]' \
    '(-T --Toshiba)'{-T,--Toshiba}'[show Toshiba ACPI extensions]' \
    '-v[verbose]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-w --wakeup)'{-w,--wakeup}'[show wakeup-capable devices]' \
    '-W+[toggle wakeup-capable device]:device:_default' \
    '-z+[Asus LCD brightness 0..15]:level:_default' \
    && ret=0

return ret
