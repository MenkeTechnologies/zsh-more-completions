#compdef skipredundant
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/skipredundant.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.

# EMBOSS skipredundant: filter a sequence set to a non-redundant subset
# using either a single identity threshold or a banded range. Output
# the unique set and (optionally) the redundant set separately.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[input sequence set]:sequence USA:_files' \
  '-mode=[redundancy mode (1=single threshold, 2=range)]:mode:(1 2)' \
  '-threshold=[identity threshold (mode 1) as percent]:pct:' \
  '-minthreshold=[lower identity bound (mode 2) as percent]:pct:' \
  '-maxthreshold=[upper identity bound (mode 2) as percent]:pct:' \
  '-gapopen=[gap-opening penalty for alignment]:penalty:' \
  '-gapextend=[gap-extension penalty for alignment]:penalty:' \
  '-datafile=[scoring matrix file]:matrix:_files' \
  '-outseq=[non-redundant output sequence file]:file:_files' \
  '-redundantoutseq=[redundant output sequence file]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
