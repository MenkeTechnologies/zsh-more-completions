#compdef suresamp
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stretching_moveout_resamp/suresamp.c
# SURESAMP - resample in time

local ret=1

_arguments -s -S \
  'nt=[number of time samples on output]:n:' \
  'dt=[time sampling interval on output]:d:' \
  'tmin=[time of first sample in output]:t:' \
  'rf=[resampling factor]:r:' \
  'verbose=[=1 for advisory messages]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
