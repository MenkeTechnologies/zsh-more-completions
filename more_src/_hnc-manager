#compdef hnc-manager
# _hnc-manager — Kubernetes Hierarchical Namespace Controller (kubernetes-sigs/hierarchical-namespaces)
# upstream: https://github.com/kubernetes-sigs/hierarchical-namespaces
# Flags from cmd/manager/main.go on tip.

_hnc-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--health-probe-bind-address=[health probe bind address]:host\:port:' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--enable-stackdriver=[export metrics to Stackdriver]:bool:(true false)' \
        '--enable-leader-election[enable leader election]' \
        '--leader-election-id=[leader election lock name]:name:' \
        '--no-webhooks[disable admission webhooks]' \
        '--debug-logs[enable verbose logs]' \
        '--enable-test-log[enable test log]' \
        '--enable-internal-cert-management[enable internal cert management]' \
        '--max-reconciles=[concurrent reconciles]:n:' \
        '--apiserver-qps-throttle=[max QPS to apiserver]:n:' \
        '--suppress-object-tags=[reduce metric cardinality]:bool:(true false)' \
        '--webhook-server-port=[webhook server port]:port:' \
        '*--unpropagated-label=[label key not to propagate]:key:' \
        '*--unpropagated-annotation=[annotation key not to propagate]:key:' \
        '*--excluded-namespace=[namespace to exclude from HNC]:ns:' \
        '--included-namespace-regex=[regex of namespaces to include]:re:' \
        '--cert-restart-on-secret-refresh[restart on TLS secret refresh]' \
        '*--managed-namespace-label=[regex of HNC-managed namespace labels]:re:' \
        '*--managed-namespace-annotation=[regex of HNC-managed namespace annotations]:re:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_hnc-manager "$@"
