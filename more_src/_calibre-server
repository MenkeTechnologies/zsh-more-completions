#compdef calibre-server
# calibre-server - Calibre content server (OPDS + web interface)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--port=[port to listen on]:port:' \
  '--listen-on=[network interface to listen on]:interface:' \
  '--auth[require username/password to access the server]' \
  '--userdb=[path to user database]:file:_files' \
  '--manage-users[manage the user database]' \
  '--username=[username for authenticated access]:username:' \
  '--password=[password for authenticated access]:password:' \
  '--log=[path to log file]:file:_files' \
  '--access-log=[path to access log]:file:_files' \
  '--daemonize[run as a daemon (Unix only)]' \
  '--pidfile=[write PID to file]:file:_files' \
  '--max-jobs=[max number of worker processes]:jobs:' \
  '--max-opds-items=[max items in OPDS feeds]:count:' \
  '--max-opds-ungrouped-items=[max ungrouped items in OPDS feeds]:count:' \
  '--url-prefix=[URL prefix for the server]:prefix:' \
  '--enable-local-write[allow local connections to make changes]' \
  '--ban-for=[ban an IP for specified time after failures]:minutes:' \
  '--ban-after=[number of failures before banning IP]:count:' \
  '--ssl-certfile=[path to SSL certificate]:file:_files' \
  '--ssl-keyfile=[path to SSL private key]:file:_files' \
  '--trusted-ips=[comma-separated list of trusted IPs]:ips:' \
  '--enable-auth[enable user authentication]' \
  '--disable-auth[disable user authentication]' \
  '--custom-list-template=[path to custom list template]:file:_files' \
  '--ajax-timeout=[timeout for AJAX requests in seconds]:seconds:' \
  '*:library path:_files -/' \
  && ret=0

return ret
