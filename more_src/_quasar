#compdef quasar

# Zsh completion for quasar - Quasar Framework CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a project folder from one of the official starter kits'
  'dev:start a dev server for your App'
  'build:build your app for production'
  'clean:clean all build artifacts'
  'new:quickly scaffold a page/layout/component/store module'
  'mode:add/remove Quasar modes for your App'
  'inspect:inspect Quasar generated webpack config'
  'ext:manage Quasar app extensions'
  'run:run specific command on a Quasar app extension'
  'describe:describe a Quasar API'
  'test:run tests (requires @quasar/testing app extension)'
  'info:display info about your machine and your App'
  'serve:start a HTTP(S) server on a folder'
  'help:display help information for a specific command'
  'upgrade:check (and optionally) upgrade Quasar packages'
  'prepare:run prepare scripts'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'quasar command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (dev)
        _arguments -s -S \
          '(-m --mode)'{-m,--mode}'[App mode]:mode:(spa ssr pwa cordova capacitor electron bex)' \
          '(-T --target)'{-T,--target}'[app target]:target:' \
          '(-e --emulator)'{-e,--emulator}'[emulator name (for cordova/capacitor)]:name:' \
          '(-p --port)'{-p,--port}'[a port number on which to start the application]:port:' \
          '(-H --hostname)'{-H,--hostname}'[hostname for the application]:hostname:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-m --mode)'{-m,--mode}'[App mode]:mode:(spa ssr pwa cordova capacitor electron bex)' \
          '(-T --target)'{-T,--target}'[app target]:target:' \
          '(-d --debug)'{-d,--debug}'[build for debugging purposes]' \
          '(-s --skip-pkg)'{-s,--skip-pkg}'[skip packaging]' \
          '(-I --ide)'{-I,--ide}'[open IDE after build for native apps]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (mode)
        _arguments -s -S \
          '1:subcommand:(add remove)' \
          '2:mode:(pwa ssr cordova capacitor electron bex)' && ret=0
        ;;
      (new)
        _arguments -s -S \
          '1:type:(page p layout l component c store s ssrmiddleware bootfile b)' \
          '2:name' && ret=0
        ;;
    esac
    ;;
esac

return ret
