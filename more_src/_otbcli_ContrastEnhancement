#compdef otbcli_ContrastEnhancement
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ContrastEnhancement.html
# Orfeo ToolBox: enhance image contrast via histogram equalization

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image]:image:_files' \
  '-out[output image]:output:_files' \
  '-bins[number of bins in the histogram]:value:' \
  '-hfact[max bin height as multiple of flat height]:value:' \
  '-nodata[value to ignore during processing]:value:' \
  '-spatial[histogram computation scope]:scope:(local global)' \
  '-spatial.local.h[thumbnail height for local histogram]:value:' \
  '-spatial.local.w[thumbnail width for local histogram]:value:' \
  '-minmax[min/max computed automatically or manually]:mode:(auto manual)' \
  '-minmax.auto.global[apply min/max uniformly across bands]:bool:(true false)' \
  '-minmax.manual.min[user-specified minimum value]:value:' \
  '-minmax.manual.max[user-specified maximum value]:value:' \
  '-mode[equalization method]:mode:(each lum)' \
  '-mode.lum.red.ch[red channel index]:value:' \
  '-mode.lum.red.coef[red channel luminance weight]:value:' \
  '-mode.lum.green.ch[green channel index]:value:' \
  '-mode.lum.green.coef[green channel luminance weight]:value:' \
  '-mode.lum.blue.ch[blue channel index]:value:' \
  '-mode.lum.blue.coef[blue channel luminance weight]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
