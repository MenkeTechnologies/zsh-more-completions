#compdef mupdate
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/mupdate.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mupdate: Cyrus IMAP mailbox state aggregator daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[configuration file]:file:_files' \
  '-m[operate as MUPDATE master]' \
  '-a[autoselect master/slave from imapd.conf]' \
  '*::mupdate args:_files' && ret=0
return ret
