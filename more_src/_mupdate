#compdef mupdate
# Documentation: https://man.archlinux.org/search?q=mupdate
# Reference accessed: 2026-05-16

# mupdate: Cyrus IMAP mailbox state aggregator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-C[config file]:file:_files' \
  '-D[run in foreground (debug)]' \
  '*::mupdate args:_files' && ret=0
return ret
