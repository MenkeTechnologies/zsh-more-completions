#compdef phoneinfoga
# Documentation: https://sundowndev.github.io/phoneinfoga/getting-started/usage/
# OSINT: information gathering and scanning of phone numbers.

local ret=1
local -a subcmds

subcmds=(
  'scan:scan a phone number'
  'serve:serve the web client and REST API'
  'version:print the version and exit'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'phoneinfoga command' subcmds && ret=0 ;;
  args)
    case $line[1] in
      scan)
        _arguments -s \
          '(-n --number)'{-n+,--number=}'[phone number to scan (E164 or international format)]:number:' \
          '*'{-D,--disable}'[scanner to skip for this scan]:scanner:' \
          '*--plugin=[extra scanner plugin to use for the scan]:file:_files' \
          '*--env-file=[env files to parse environment variables from]:file:_files' && ret=0 ;;
      serve)
        _arguments -s \
          '(-p --port)'{-p+,--port=}'[HTTP port (default 5000)]:port:' \
          '--no-client[disable web client (REST API only)]' \
          '*'{-D,--disable}'[scanner to skip for the scans]:scanner:' \
          '*--plugin=[extra scanner plugin to use for the scans]:file:_files' \
          '*--env-file=[env files to parse environment variables from]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
