#compdef grpcurl

# Zsh completion for grpcurl (gRPC curl-like tool)

_grpcurl() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -s -S \
        '-plaintext[use plain-text HTTP/2 when connecting to server (no TLS)]' \
        '-insecure[skip server certificate and domain verification]' \
        '-cacert=[file containing trusted root certificates]:ca cert file:_files' \
        '-cert=[file containing client certificate (public key)]:cert file:_files' \
        '-key=[file containing client private key]:key file:_files' \
        '-authority=[value of :authority pseudo-header]:authority' \
        '-user-agent=[value of User-Agent request header]:user agent' \
        '-connect-timeout=[timeout for establishing connection]:seconds' \
        '-keepalive-time=[amount of time before client sends keepalive ping]:seconds' \
        '-max-time=[maximum time for the entire operation]:seconds' \
        '-max-msg-sz=[maximum encoded size of a response message]:bytes' \
        '*-proto=[proto source file]:proto file:_files -g "*.proto"' \
        '*-protoset=[proto descriptor set file]:protoset file:_files' \
        '*-import-path=[path for proto file imports]:import path:_directories' \
        '-d=[request data in JSON format]:data' \
        '-format=[format of request data]:format:(json text)' \
        '*-H=[additional request header]:header' \
        '*-rpc-header=[additional RPC header]:header' \
        '*-reflect-header=[additional reflection header]:header' \
        '-v[enable verbose output]' \
        '-vv[enable very verbose output]' \
        '-emit-defaults[emit default values for JSON-encoded responses]' \
        '-allow-unknown-fields[allow unknown fields in JSON input]' \
        '-servername=[override server name when verifying TLS]:server name' \
        '-unix[indicates that the server address is a Unix domain socket]' \
        '-use-reflection[use server reflection to determine service and method]' \
        '1:server address:' \
        '2:symbol/method (list or describe for discovery):->action' \
        && return 0

    case $state in
        action)
            local -a actions=(
                'list:list services or methods'
                'describe:describe services or methods'
            )
            _describe -t actions 'action or service/method' actions
            ;;
    esac
}

_grpcurl "$@"
