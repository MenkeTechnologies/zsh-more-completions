#compdef beeline

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '-u+[JDBC URL]:url:' \
  '-r[reconnect to last saved URL]' \
  '-n+[username]:user:_users' \
  '-p+[password]:password:' \
  '-d+[driver class]:class:' \
  '-i+[init script]:file:_files -g "*.(sql|hql)"' \
  '-e+[query to execute]:query:' \
  '-f+[script file]:file:_files -g "*.(sql|hql)"' \
  {-w+,--password-file=}'[password file]:file:_files' \
  '*--hiveconf=[Hive config]:property=value:' \
  '*--hivevar=[Hive variable]:name=value:' \
  '--property-file=[connection properties file]:file:_files' \
  '--color=[use color]:flag:(true false)' \
  '--showHeader=[show column headers]:flag:(true false)' \
  '--headerInterval=[header interval rows]:n:' \
  '--fastConnect=[skip table list]:flag:(true false)' \
  '--autoCommit=[autocommit]:flag:(true false)' \
  '--verbose=[verbose]:flag:(true false)' \
  '--showWarnings=[show warnings]:flag:(true false)' \
  '--showDbInPrompt=[show DB in prompt]:flag:(true false)' \
  '--showNestedErrs=[show nested errors]:flag:(true false)' \
  '--numberFormat=[number format pattern]:pattern:' \
  '--force=[continue on errors]:flag:(true false)' \
  '--maxWidth=[max terminal width]:n:' \
  '--maxColumnWidth=[max column width]:n:' \
  '--silent=[silent mode]:flag:(true false)' \
  '--autosave=[autosave preferences]:flag:(true false)' \
  '--outputformat=[output format]:format:(table vertical csv2 tsv2 dsv csv tsv)' \
  '--incremental=[incremental fetch]:flag:(true false)' \
  '--incrementalBufferRows=[buffer rows]:n:' \
  '--truncateTable=[truncate table when wide]:flag:(true false)' \
  '--delimiterForDSV=[DSV delimiter]:delim:' \
  '--isolation=[transaction isolation]:level:' \
  '--nullemptystring=[null as empty string]:flag:(true false)' \
  '--maxHistoryRows=[max history rows]:n:' \
  '--addlocaldriver=[load local driver class]:class:' \
  '--addlocaldriverjar=[load local driver jar]:file:_files -g "*.jar"' \
  '--convertBinaryArrayToString=[convert binary]:flag:(true false)' && ret=0

return ret
