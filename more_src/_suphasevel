#compdef suphasevel
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suphasevel.c
# Multi-mode PHASE VELocity dispersion map

local ret=1

_arguments -s -S \
  'fv=[fv]:fv:' \
  'nv=[nv]:nv:' \
  'dv=[dv]:dv:' \
  'fmax=[fmax]:fmax:' \
  'norm=[norm]:norm:' \
  'verbose=[verbose]:verbose:' \
  'key=[key]:key:' \
  '*:file:_files' && ret=0

return ret
