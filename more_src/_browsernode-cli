#compdef browsernode-cli
# Documentation: https://docs.browsernode.com/cli
# Reference accessed: 2026-05-23
# Verified: upstream CLI docs (browsernode npm package bin).

# Zsh completion for browsernode-cli - browser automation agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --prompt)'{-p+,--prompt=}'[one-shot task prompt]:prompt:' \
  '--headless[run browser in headless mode]' \
  '--model=[LLM model to use]:model:(gpt-4o gpt-4-turbo claude-3-opus claude-3-sonnet)' \
  '*::args:' && ret=0

return ret
