#compdef herd

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'status:show service status'
  'start:start a service'
  'stop:stop a service'
  'restart:restart a service'
  'enable:enable a service'
  'disable:disable a service'
  'doc:show service documentation'
  'eval:evaluate a Guile expression'
  'schedule:schedule an action'
)

_arguments -s -S \
  '(-s --socket)'{-s,--socket}'[socket file path]:socket file:_files' \
  '(-l --log-file)'{-l,--log-file}'[log file path]:log file:_files' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'herd subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (start|stop|restart|enable|disable|doc|status)
        _arguments -s -S '*:service name:' && ret=0
        ;;
      (eval)
        _arguments -s -S '*:expression:' && ret=0
        ;;
      (schedule)
        _arguments -s -S '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
