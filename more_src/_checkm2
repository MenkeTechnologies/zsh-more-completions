#compdef checkm2
# Documentation: https://github.com/chklovski/CheckM2
# CheckM2: rapid assessment of genome bin quality using machine learning

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    if (( CURRENT == 1 )); then
      _values 'checkm2 subcommand' \
        'predict[predict the completeness and contamination of bins]' \
        'testrun[test the installation on internal genomes]' \
        'database[download and manage the reference database]' && ret=0
    else
      case $words[1] in
        predict)
          _arguments -s -S \
            '--input=[folder with bins or list of files]:path:_files' \
            '--output-directory=[output directory]:dir:_files -/' \
            '--threads=[number of threads]:threads' \
            '--genes[input is pre-predicted protein files]' \
            '(-x --extension)'{-x+,--extension=}'[input file extension]:ext' \
            '--stdout[print results to standard output]' \
            '--lowmem[reduce DIAMOND RAM usage]' \
            '--database_path=[custom database location]:file:_files' && ret=0
          ;;
        database)
          _arguments -s -S \
            '--download[download the reference database]' \
            '--setdblocation=[set the database location]:file:_files' \
            '--current[print the current database location]' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
