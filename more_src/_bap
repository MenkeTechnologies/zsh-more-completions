#compdef bap
# _bap — Binary Analysis Platform frontend (BinaryAnalysisPlatform/bap)
# upstream: https://github.com/BinaryAnalysisPlatform/bap
# Flags from src/bap_frontend.ml.

_bap() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '--plugin-path=[add directory to plugin search path]:dir:_files -/' \
        '--logdir=[directory for log file]:dir:_files -/' \
        '--recipe=[extract command line arguments from recipe]:recipe:' \
        '1:command:(disassemble dis byteweight mc print compare list-plugins list-commands . help)' \
        '*::args:_normal'
}

_bap "$@"
