#compdef xeol

_xeol() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-o --output)'{-o,--output}'=[output format]:format:(table json cyclonedx-json cyclonedx-xml)' \
        '(-f --file)'{-f,--file}'=[output file]:file:_files' \
        '--fail-on-eol-found[set exit code on EOL found]' \
        '--sbom=[SBOM file to scan]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[suppress output]' \
        '--platform=[platform to scan]:platform' \
        '--by-cve[orient results by CVE]' \
        '--vex=[VEX document]:file:_files' \
        '--eol-match-date=[match EOL by date]:date' \
        '--lookahead=[EOL lookahead period]:duration' \
        '--db-cache-dir=[database cache directory]:dir:_directories' \
        '--db-update-url=[database update URL]:url' \
        '--db-auto-update[automatically update database]' \
        '--no-db-auto-update[do not auto update database]' \
        '--config=[config file]:file:_files' \
        '1:image-or-path:_files'
}

_xeol "$@"
