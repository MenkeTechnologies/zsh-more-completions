#compdef doggo
# Zsh completion for doggo - DNS client for humans
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-q --query)'{-q,--query}'[specify query domain]:domain:' \
  '(-t --type)'{-t,--type}'[specify query type]:type:(A AAAA MX NS TXT CNAME SOA PTR SRV CAA ANY)' \
  '--class[specify query class]:class:(IN CH HS ANY)' \
  '--nameserver[specify nameserver address]:address:' \
  '--timeout[specify timeout duration]:duration:' \
  '--ndots[number of dots to consider name absolute]:number:' \
  '--search[use search list from resolv.conf]' \
  '--reverse[perform reverse DNS lookup]' \
  '(-J --json)'{-J,--json}'[output as JSON]' \
  '--short[short output]' \
  '--color[control color output]:when:(auto always never)' \
  '--debug[enable debug logging]' \
  '--time[display query time]' \
  '(-4 --ipv4)'{-4,--ipv4}'[use IPv4 only]' \
  '(-6 --ipv6)'{-6,--ipv6}'[use IPv6 only]' \
  '--strategy[nameserver strategy]:strategy:(all random first)' \
  '--tls-hostname[hostname for TLS certificate verification]:hostname:' \
  '--udp[use UDP transport]' \
  '--tcp[use TCP transport]' \
  '--dot[use DNS over TLS]' \
  '--doh[use DNS over HTTPS]' \
  '--dnscrypt[use DNSCrypt]' \
  '--quic[use DNS over QUIC]' \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '*:domain:' && ret=0
return ret
