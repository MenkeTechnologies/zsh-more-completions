#compdef fteqw fteqw-sv
# Documentation: https://github.com/fte-team/fteqw
# Reference accessed: 2026-05-16
# Verified: no Debian manpage retrievable. FTE QuakeWorld is a Quake-engine
# derivative; the universal Quake engine convention is +cmd cbuf parsing
# (COM_CheckParm + Cbuf_AddText). Listed +commands are engine convention,
# not flag-table entries.

# FTE QuakeWorld: enhanced Quake/QuakeWorld engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '+playdemo[play recorded demo]:file:_files -g "*.(dem|qwd|mvd)"' \
  '*::extra args:_files' && ret=0
return ret
