#compdef comparefamily
# _comparefamily — Adobe afdko comparefamily CLI for cross-comparing OTF font family members validating glyph set kerning name records OS/2 metrics weight class width class panose for family consistency (adobe-type-tools team, Python); argparse
# upstream: https://github.com/adobe-type-tools/afdko

_comparefamily() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[font dir]:dir:_files -/' \
        '--directory=+[font dir]:dir:_files -/' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-r+[report file]:file:_files -g "*.txt *.html *.json"' \
        '--report=+[report file]:file:_files -g "*.txt *.html *.json"' \
        '-t+[test list]:t:(SCRIPT NAME COMPATIBLE BAD WEIGHT WIDTH OS_2 HHEA STYLE METRICS CMAP STAT KERNING GLYPHSET BBOX HINTS PANOSE)' \
        '--test=+[test list]:t:(SCRIPT NAME COMPATIBLE BAD WEIGHT WIDTH OS_2 HHEA STYLE METRICS CMAP STAT KERNING GLYPHSET BBOX HINTS PANOSE)' \
        '-x+[exclude test]:str:' \
        '--exclude=+[exclude test]:str:' \
        '--all-tests[run all tests]' \
        '--single-master[allow single master]' \
        '--ignore-info-files[ignore info files]' \
        '*:font files:_files -g "*.otf *.ttf *.ufo"'
}

_comparefamily "$@"
