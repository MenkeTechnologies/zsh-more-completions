#compdef 3dDegreeCentrality
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDegreeCentrality.html
# AFNI: degree centrality mapping of voxelwise connectivity

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-pearson -spearman -quadrant)-pearson[Pearson correlation (default)]' \
  '(-pearson -spearman -quadrant)-spearman[Spearman correlation]' \
  '(-pearson -spearman -quadrant)-quadrant[quadrant correlation]' \
  '-thresh[correlation threshold]:r:' \
  '-sparsity[keep only top s% of connections]:s:' \
  '-polort[polynomial detrend order]:m:' \
  '-autoclip[clip out non-brain voxels]' \
  '-automask[create mask from input]' \
  '-mask[mask dataset]:mmm:_files' \
  '-prefix[output dataset prefix]:p:_files' \
  '-out1D[save histogram to 1D file]:f:_files' \
  '*:dataset:_files' && ret=0

return ret
