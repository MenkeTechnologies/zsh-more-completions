#compdef randomise
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/statistics/randomise.html
# randomise - permutation-based nonparametric GLM inference

local ret=1

_arguments -s -S \
  '-i[4D input image]:file:_files' \
  '-o[output rootname]:rootname:_files' \
  '-d[design matrix .mat file]:file:_files' \
  '-t[t contrasts .con file]:file:_files' \
  '-f[F contrasts .fts file]:file:_files' \
  '-m[mask image]:file:_files' \
  '-e[exchangeability blocks .grp file]:file:_files' \
  '-n[number of permutations (default 5000)]:n:' \
  '-D[demean data temporally before analysis]' \
  '-v[variance smoothing spatial extent in mm]:sigma:' \
  '-1[perform 1-sample group-mean test (no design/contrast)]' \
  '-T[carry out TFCE for 3D data]' \
  '--T2[carry out TFCE for 2D (TBSS) data]' \
  '-x[output voxelwise corrected/uncorrected p maps]' \
  '-c[cluster-based thresholding by extent for t contrasts]:thresh:' \
  '-C[cluster-based thresholding by mass for t contrasts]:thresh:' \
  '-F[cluster-based thresholding by extent for F contrasts]:thresh:' \
  '-S[cluster-based thresholding by mass for F contrasts]:thresh:' \
  '--vxl=[list of numbers indicating voxelwise EVs]:list:' \
  '--vxf=[list of files for voxelwise EVs]:files:_files' \
  '--uncorrp[output uncorrected p-value images]' \
  '--seed=[specific random number seed]:seed:' \
  '--twopass[run with two-pass permutation]' \
  '-P[output permutation vector/matrix]' \
  '--quiet[suppress output (except errors)]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
