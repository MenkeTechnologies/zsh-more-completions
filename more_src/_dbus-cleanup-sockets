#compdef dbus-cleanup-sockets
# Documentation: https://man.archlinux.org/search?q=dbus-cleanup-sockets
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '1::socket directory:_files -/' && ret=0

return ret
