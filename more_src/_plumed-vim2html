#compdef plumed-vim2html
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/vim2html.html
# PLUMED vim2html: convert a PLUMED input file to colored HTML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--annotate-syntax[report annotated syntax on output]' \
  '--pdf[generate PDF output with syntax highlighting]' \
  '--crop[crop the pdf file to the only written part]' \
  '--fs=[set the font size for PDF output]:fontsize' \
  '--colors=[specify the color palette]:palette:(default ac)' \
  '*:input file:_files' && ret=0

return ret
