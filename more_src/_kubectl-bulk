#compdef kubectl-bulk
# Documentation: https://man.archlinux.org/search?q=kubectl-bulk
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '1:action:(get list create update delete remove rollout scale help)' \
  '*:args:_default'
