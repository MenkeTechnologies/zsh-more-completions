#compdef grdmask
# Documentation: https://docs.generic-mapping-tools.org/latest/grdmask.html
# Source: GenericMappingTools/gmt classic-mode grdmask — rasterize polygons or buffered points as a mask grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A+[polygon-side approximation (great-circle vs straight)]:opts:_default' \
    '-C+[which polygon value when multiple overlap]:opts:_default' \
    '-N+[values for outside / edge / inside]:opts:_default' \
    '-S+[operate on points (distance mask)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-j+[distance computation mode]:mode:_default' \
    '-n+[interpolation boundary conditions]:opts:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-r[pixel registration (default gridline)]' \
    '-w+[cyclical coord conversion]:opts:_default' \
    '-x+[CPU cores limit]:n:_default' \
    '*:input polygon/point table:_files' \
    && ret=0

return ret
