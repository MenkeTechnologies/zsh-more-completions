#compdef deweb
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/deweb.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# deweb strips C/CWEB commands from CWEB sources.
# Per manpage: "No options are currently accepted."

local -a arguments

arguments=(
    '*:WEB/CWEB file:_files -g "*.{web,w}"'
)

_arguments -s -S $arguments
