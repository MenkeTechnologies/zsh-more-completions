#compdef exomizer
# Documentation: https://man.archlinux.org/search?q=exomizer
# Reference accessed: 2026-05-16

# Zsh completion for exomizer cruncher

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:mode:(raw sfx basic sfxlink level link crun)' \
  '*:args:{ _files }' && ret=0

return ret
