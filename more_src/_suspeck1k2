#compdef suspeck1k2
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suspeck1k2.c
# 2D (K1,K2) Fourier SPECtrum of (x1,x2) data set

local ret=1

_arguments -s -S \
  'd1=[d1]:d1:' \
  'd2=[d2]:d2:' \
  'verbose=[verbose]:verbose:' \
  'tmpdir=[tmpdir]:tmpdir:' \
  '*:file:_files' && ret=0

return ret
