#compdef uu-uptime
# Documentation: https://man.archlinux.org/search?q=uu-uptime
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-uptime() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s[system up since]' \
'--since[system up since]' \
'-p[show uptime in pretty format]' \
'--pretty[show uptime in pretty format]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::path -- file to search boot time from:_files' \
&& ret=0
}

(( $+functions[_uu-uptime_commands] )) ||
_uu-uptime_commands() {
    local commands; commands=()
    _describe -t commands 'uu-uptime commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-uptime" ]; then
    _uu-uptime "$@"
else
    compdef _uu-uptime uu-uptime
fi
