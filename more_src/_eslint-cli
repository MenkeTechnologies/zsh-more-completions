#compdef eslint-cli
# _eslint-cli — ESLint JavaScript linter CLI alias (Nicholas C. Zakas / ESLint Foundation, JavaScript); custom argparse
# upstream: https://github.com/eslint/eslint

_eslint-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--no-eslintrc[no eslintrc]' \
        '--config=+[config file]:file:_files -g "*.eslintrc.* *.json *.js *.yml"' \
        '-c+[config file]:file:_files -g "*.eslintrc.* *.json *.js *.yml"' \
        '--env=+[environment]:list:(browser node es6 es2017 es2020 es2021 es2022 es2023 jest jasmine mocha qunit jquery prototypejs shelljs meteor mongo applescript serviceworker atomtest embertest webextensions greasemonkey nashorn protractor)' \
        '--ext=+[file extensions]:list:' \
        '--global=+[global variable]:list:' \
        '--parser=+[parser]:str:' \
        '--parser-options=+[parser options]:list:' \
        '--resolve-plugins-relative-to=+[plugin resolution dir]:dir:_files -/' \
        '--rulesdir=+[rules dir]:list:_files -/' \
        '--plugin=+[plugin]:list:' \
        '--rule=+[rule]:list:' \
        '--fix[fix problems]' \
        '--fix-dry-run[fix dry run]' \
        '--fix-type=+[fix type]:list:(problem suggestion layout directive)' \
        '--stdin[read from stdin]' \
        '--stdin-filename=+[stdin filename]:str:' \
        '--quiet[only show errors]' \
        '--max-warnings=+[max warnings]:n:' \
        '--output-file=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--format=+[output format]:f:(checkstyle compact html jslint-xml json json-with-metadata junit stylish table tap unix visualstudio)' \
        '-f+[output format]:f:(checkstyle compact html jslint-xml json json-with-metadata junit stylish table tap unix visualstudio)' \
        '--color[color]' \
        '--no-color[no color]' \
        '--inline-config[allow inline config]' \
        '--no-inline-config[no inline config]' \
        '--report-unused-disable-directives[report unused disable directives]' \
        '--report-unused-disable-directives-severity=+[severity]:s:(off warn error 0 1 2)' \
        '--cache[use cache]' \
        '--cache-location=+[cache location]:file:_files' \
        '--cache-strategy=+[cache strategy]:s:(metadata content)' \
        '--cache-file=+[cache file]:file:_files' \
        '--init[init config]' \
        '--debug[debug]' \
        '--print-config=+[print config]:file:_files' \
        '--exit-on-fatal-error[exit on fatal error]' \
        '--no-warn-ignored[no warn ignored]' \
        '--pass-on-no-patterns[pass on no patterns]' \
        '--errors-only[errors only]' \
        '--no-error-on-unmatched-pattern[no error on unmatched pattern]' \
        '--ignore[use ignore]' \
        '--no-ignore[no ignore]' \
        '--ignore-path=+[ignore file path]:file:_files' \
        '--ignore-pattern=+[ignore pattern]:list:' \
        '--flag=+[experimental flag]:list:' \
        '--concurrency=+[concurrency]:str:' \
        '*:file:_files'
}

_eslint-cli "$@"
