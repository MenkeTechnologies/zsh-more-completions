#compdef mathpha
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/mathpha.txt
# Performs mathematical operations on PHA spectral files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'expr=[input expression to be evaluated]:expression:' \
  'units=[physical units for algebraic evaluation]:units:(C R F)' \
  'outfil=[output filename for the derived PHA dataset]:output file:_files' \
  'exposure=[how to calculate exposure time]:exposure:(NULL CALC)' \
  'areascal=[how AREASCAL keyword is determined]:areascal:' \
  'ncomments=[number of comment strings to add (0-4)]:count:(0 1 2 3 4)' \
  'properr=[propagate errors during algebra]:flag:(yes no)' \
  'errmeth=[error calculation method]:method:(POISS-0 POISS-1 POISS-2 POISS-3 Gauss)' \
  'auxfiles=[copy auxiliary file keywords from input file]:file:_files' \
  'phaversn=[PHA FITS format version]:version:' \
  'divzero=[value for divide-by-zero channels]:value:' \
  'chatter=[verbosity level]:level:' \
  'clobber=[overwrite existing output files]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
