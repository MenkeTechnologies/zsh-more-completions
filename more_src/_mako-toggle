#compdef mako-toggle
# Documentation: https://man.archlinux.org/search?q=mako-toggle
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--on[turn notifications on]' \
  '--off[turn notifications off]' \
  '--toggle[toggle notification mode]' \
  '--status[print current state]' && ret=0

return ret
