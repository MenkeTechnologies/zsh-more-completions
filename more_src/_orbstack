#compdef orbstack orb

# Zsh completion for OrbStack CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:Start a machine'
      'stop:Stop a machine'
      'create:Create a new machine'
      'delete:Delete a machine'
      'list:List machines'
      'ssh:SSH into a machine'
      'run:Run a command in a machine'
      'push:Push a file to a machine'
      'pull:Pull a file from a machine'
    )
    _describe -t commands 'orbstack command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '(-a --arch)'{-a,--arch}'[architecture]:arch:(amd64 arm64)' \
          '-h[show help]' \
          '--help[show help]' \
          '1:distro:(ubuntu debian fedora alpine arch)' \
          '2:machine name' && ret=0
        ;;
      start|stop|delete|ssh)
        _arguments -s -S \
          '-h[show help]' \
          '--help[show help]' \
          '1:machine name' && ret=0
        ;;
      run)
        _arguments -s -S \
          '-u+[user to run as]:user' \
          '--user=[user to run as]:user' \
          '-h[show help]' \
          '--help[show help]' \
          '1:machine name' \
          '*:command' && ret=0
        ;;
      push|pull)
        _arguments -s -S \
          '-h[show help]' \
          '--help[show help]' \
          '1:source:_files' \
          '2:destination:_files' && ret=0
        ;;
      list)
        _arguments -s -S \
          '--format=[output format]:format:(json table)' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
