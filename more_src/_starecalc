#compdef starecalc
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss64.html
# SMURF: calculate image for SCUBA-2 STARE observations.

local ret=1

_arguments -s -S \
  'IN=[input data files]:ndf:_files' \
  'OUT=[output file with STARE images]:ndf:_files' \
  'OUTFILES=[text file listing output NDFs]:file:_files' \
  'NAVER=[number of frames to average]:n:' \
  'BBM=[bad bolometer mask files]:ndf:_files' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
