#compdef hcxdumptool hcxpcapngtool hcxhashtool hcxwltool hcxhash2cap hcxpsktool hcxpmktool hcxpottool hcxeiutool
# Documentation: https://github.com/ZerBea/hcxdumptool
# Documentation: https://github.com/ZerBea/hcxtools
# Reference accessed: 2026-05-27
# Verified: upstream long_options[] tables in
#   ZerBea/hcxdumptool/hcxdumptool.c,
#   ZerBea/hcxtools/{hcxpcapngtool,hcxhashtool,hcxwltool,hcxhash2cap,hcxpsktool,hcxpmktool}.c
#
# Coverage note: the binaries `hcxessidtool` and `hcxpmkidtool` mentioned in
# some older docs do not exist in current upstream; ZerBea/hcxtools ships
# hcxpcapngtool, hcxhashtool, hcxwltool, hcxhash2cap, hcxpsktool, hcxpmktool,
# hcxpottool, hcxeiutool. Per task brief, hcxdumptool and hcxpcapngtool have
# the deepest flag coverage; hcxhashtool, hcxwltool and the smaller binaries
# carry their core flag set. hcxpottool and hcxeiutool fall back to file
# completion (small option surface, mostly positional file args).

local curcontext="$curcontext" state line ret=1
local cmd=${words[1]}

case $cmd in
  hcxdumptool)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-H)-H[show extended help with all long options]' \
      '--help[show extended help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '-i+[interface name]:interface:_net_interfaces' \
      '-I[show interface info]' \
      '-L[list available interfaces (long)]' \
      '-l[list available interfaces (short)]' \
      '-w+[output pcapng file]:file:_files' \
      '-c+[scan channel list (e.g. 1,6,11)]:channels:' \
      '-f+[scan frequency list]:frequencies:' \
      '-F[set scanlist from interface supported frequencies]' \
      '-m+[set monitor mode (passive)]:interface:_net_interfaces' \
      '-A[set monitor mode (active)]' \
      '-t+[hold time on each channel in seconds]:seconds:' \
      '--bpf=[load BPF code from file]:file:_files' \
      '--bpfc=[compile pcap-filter expression to BPF]:expression:' \
      '--bpfd=[BPF debug mode 0-4]:mode:(0 1 2 3 4)' \
      '--ftc[fast tear-down: send disassociation/deauth]' \
      '--disable_disassociation[disable disassociation/deauth attack]' \
      '--m2max=[max M1/M2 ROGUE attempts]:n:' \
      '--associationmax=[max association attempts]:n:' \
      '--proberesponsetx=[max probe-response transmissions]:n:' \
      '--tot=[time-out for entire run in minutes]:minutes:' \
      '--essidlist=[file with ESSIDs to attack]:file:_files' \
      '--errormax=[max errors before abort]:n:' \
      '--watchdogmax=[watchdog max idle seconds]:n:' \
      '--onsigterm=[action on SIGTERM]:action:(reboot poweroff)' \
      '--ongpiobutton=[action on GPIO button]:action:(reboot poweroff)' \
      '--ontot=[action on TOT timeout]:action:(reboot poweroff)' \
      '--onwatchdog=[action on watchdog]:action:(reboot poweroff)' \
      '--exitoneapol=[exit on first EAPOL message]:mask:' \
      '--onerror=[action on error]:action:(reboot poweroff)' \
      '--gpio_button=[GPIO pin for exit button]:pin:' \
      '--gpio_statusled=[GPIO pin for status LED]:pin:' \
      '--rds=[radio data system sort order]:n:' \
      '--rdt[disable real-time data display]' \
      '--daemonize[run as daemon]' \
      '--rcascan=[remote channel scan mode]:mode:(active passive)' && ret=0
    ;;

  hcxpcapngtool)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '-o+[output PMKID/EAPOL hashline file (22000 format)]:file:_files' \
      '-O+[output PMKID/EAPOL hashline file (client only)]:file:_files' \
      '-E+[output ESSID list]:file:_files' \
      '-R+[output raw probe-request ESSID list]:file:_files' \
      '-I+[output identity list]:file:_files' \
      '-U+[output username list]:file:_files' \
      '-D+[output device-info list]:file:_files' \
      '--all[do not strip cleanup candidates - convert everything]' \
      '--eapoltimeout=[EAPOL timeout in seconds]:seconds:' \
      '--nonce-error-corrections=[max nonce error corrections]:n:' \
      '--ignore-ie[ignore information element mismatch]' \
      '--max-essids=[max number of ESSIDs]:n:' \
      '--nmea-in=[input NMEA GPS log file]:file:_files' \
      '--nmea-out=[output NMEA GPS log file]:file:_files' \
      '--csv=[output CSV file]:file:_files' \
      '--raw-out=[output raw 802.11 packets]:file:_files' \
      '--raw-in=[input raw 802.11 packets]:file:_files' \
      '--lts=[output long timestamp file]:file:_files' \
      '--log=[log file]:file:_files' \
      '--pmkid-client=[output client-only PMKID file]:file:_files' \
      '--pmkid=[output deprecated PMKID file]:file:_files' \
      '--eapmd5=[output EAP-MD5 hashes]:file:_files' \
      '--eapmd5-john=[output EAP-MD5 hashes (john format)]:file:_files' \
      '--eapleap=[output EAP-LEAP hashes]:file:_files' \
      '--tacacs-plus=[output TACACS+ hashes]:file:_files' \
      '--hccapx=[output deprecated hccapx file]:file:_files' \
      '--hccap=[output deprecated hccap file]:file:_files' \
      '--john=[output deprecated john format]:file:_files' \
      '--prefix=[prefix for all output filenames]:prefix:' \
      '--add-timestamp[prefix output lines with timestamp]' \
      '--version[show version]' \
      '--help[show help]' \
      '*:pcapng-file:_files' && ret=0
    ;;

  hcxhashtool)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '-i+[input hashline file (22000)]:file:_files' \
      '-o+[output hashline file]:file:_files' \
      '-E+[output ESSID list]:file:_files' \
      '-L+[load filter list]:file:_files' \
      '-d[detect/print vendor information]' \
      '-p+[max passes when filtering]:n:' \
      '--type=[hash type to filter (1=PMKID,2=EAPOL)]:type:(1 2)' \
      '--hcx-min=[minimum hashline length]:n:' \
      '--hcx-max=[maximum hashline length]:n:' \
      '--essid-min=[minimum ESSID length]:n:' \
      '--essid-max=[maximum ESSID length]:n:' \
      '--essid-len=[exact ESSID length]:n:' \
      '--essid-group[group output by ESSID]' \
      '--essid=[filter by exact ESSID]:essid:' \
      '--essid-part=[filter by substring of ESSID]:part:' \
      '--essid-partx=[filter by case-sensitive substring]:part:' \
      '--essid-list=[filter by ESSID list file]:file:_files' \
      '--essid-regex=[filter by ESSID regex]:regex:' \
      '--mac-ap=[filter by AP MAC]:mac:' \
      '--mac-client=[filter by client MAC]:mac:' \
      '--mac-list=[filter by MAC include list]:file:_files' \
      '--mac-skiplist=[filter by MAC skip list]:file:_files' \
      '--mac-group-ap[group output by AP MAC]' \
      '--mac-group-client[group output by client MAC]' \
      '--oui-group[group output by OUI]' \
      '--oui-ap=[filter by AP OUI]:oui:' \
      '--oui-client=[filter by client OUI]:oui:' \
      '--vendor=[filter by vendor name]:vendor:' \
      '--vendor-ap=[filter by AP vendor]:vendor:' \
      '--vendor-client=[filter by client vendor]:vendor:' \
      '--rc[only entries with valid replaycount]' \
      '--rc-not[only entries with invalid replaycount]' \
      '--authorized[only authorized handshakes (M1/M2)]' \
      '--challenge[only full 4-way handshakes (M1-M4)]' \
      '--apless[only AP-less M1/M2 ROGUE handshakes]' \
      '--psk=[test handshakes against PSK]:psk:' \
      '--pmk=[test handshakes against PMK]:pmk:' \
      '--info=[print info to file]:file:_files' \
      '--info-vendor=[print vendor info to file]:file:_files' \
      '--info-vendor-ap=[print AP vendor info to file]:file:_files' \
      '--info-vendor-client=[print client vendor info to file]:file:_files' \
      '--hccapx-in=[convert from hccapx file]:file:_files' \
      '--hccapx-out=[output hccapx file]:file:_files' \
      '--hccap-in=[convert from hccap file]:file:_files' \
      '--hccap-out=[output hccap file]:file:_files' \
      '--hccap-single[write one hccap per file]' \
      '--john=[output john-format file]:file:_files' \
      '--vendorlist[print built-in vendor list]' \
      '--version[show version]' \
      '--help[show help]' && ret=0
    ;;

  hcxwltool)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '-i+[input wordlist]:file:_files' \
      '-o+[output wordlist]:file:_files' \
      '--straight[no manipulation, passthrough only]' \
      '--digit[only digits]' \
      '--xdigit[only hex digits]' \
      '--lower[only lowercase]' \
      '--upper[only uppercase]' \
      '--capital[only capitalised words]' \
      '--length=[exact password length 8-32]:n:' \
      '--version[show version]' \
      '--help[show help]' && ret=0
    ;;

  hcxhash2cap)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '-c+[output pcapng file]:file:_files' \
      '--pmkid-eapol=[input combined PMKID+EAPOL hashline file]:file:_files' \
      '--pmkid=[input PMKID file]:file:_files' \
      '--hccapx=[input hccapx file]:file:_files' \
      '--hccap=[input hccap file]:file:_files' \
      '--john=[input john format file]:file:_files' \
      '--version[show version]' \
      '--help[show help]' && ret=0
    ;;

  hcxpsktool)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '-c+[input hashline file]:file:_files' \
      '-i+[input PMKID+EAPOL file]:file:_files' \
      '-j+[input john file]:file:_files' \
      '-z+[input combined wordlist]:file:_files' \
      '-o+[output candidate wordlist]:file:_files' \
      '-e+[ESSID for generation]:essid:' \
      '-b+[BSSID for generation]:bssid:' \
      '--alticeoptimum[Altice Optimum candidate generator]' \
      '--asus[ASUS router candidate generator]' \
      '--digit10[10-digit candidates]' \
      '--ee[EE router candidates]' \
      '--eeupper[EE upper-case router candidates]' \
      '--egn[EGN candidates (Bulgarian ID)]' \
      '--eudate[EU date candidates DDMMYYYY]' \
      '--maconly[generate from MAC only]' \
      '--netgear[Netgear router candidates]' \
      '--noessidcombination[disable ESSID combination output]' \
      '--phome[phone-number style candidates]' \
      '--simple[simple/common password candidates]' \
      '--spectrum[Spectrum router candidates]' \
      '--tenda[Tenda router candidates]' \
      '--usdate[US date candidates MMDDYYYY]' \
      '--weakpass[weak/known-bad password list]' \
      '--wpskeys[WPS PIN derived keys]' && ret=0
    ;;

  hcxpmktool)
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '-l+[hashline string]:line:' \
      '-e+[ESSID string]:essid:' \
      '-p+[PSK string]:psk:' \
      '-m+[PMK string (hex)]:pmk:' \
      '-a+[MAC AP]:mac:' \
      '-c+[MAC client]:mac:' && ret=0
    ;;

  hcxpottool|hcxeiutool)
    _arguments \
      '(-h)-h[show help]' \
      '(-v)-v[show version]' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
