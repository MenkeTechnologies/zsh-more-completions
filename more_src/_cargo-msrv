#compdef cargo-msrv

local -a subcommands
subcommands=(
  'find:Find the MSRV for the current project'
  'list:List available Rust versions'
  'set:Set the MSRV in Cargo.toml'
  'show:Show the current MSRV'
  'verify:Verify the MSRV of the current project'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '--log-level=[Log level]:level:(trace debug info warn error)' \
  '--log-target=[Log target]:target:(stdout stderr)' \
  '--no-log[Disable logging]' \
  '(-p --path)'{-p,--path}'[Path to Cargo project]:path:_directories' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      find)
        _arguments \
          '--min=[Minimum Rust version to consider]:version:' \
          '--max=[Maximum Rust version to consider]:version:' \
          '--edition=[Rust edition]:edition:(2015 2018 2021 2024)' \
          '--bisect[Use binary search]' \
          '--linear[Use linear search]' \
          '--include-all-patch-releases[Check all patch releases]' \
          '--ignore-lockfile[Ignore Cargo.lock]' \
          '--no-check-feedback[Disable check feedback]' \
          '--write-msrv[Write found MSRV to Cargo.toml]' \
          '--component=[Required components]:component:' \
          '--target=[Target triple]:target:' \
          '--release-source=[Release source]:source:(rust-changelog rust-dist)' \
          '*:custom check command:'
        ;;
      verify)
        _arguments \
          '--rust-version=[Rust version to verify]:version:' \
          '--ignore-lockfile[Ignore Cargo.lock]' \
          '--target=[Target triple]:target:' \
          '*:custom check command:'
        ;;
      list)
        _arguments \
          '--min=[Minimum version]:version:' \
          '--max=[Maximum version]:version:' \
          '--include-all-patch-releases[Include all patch releases]' \
          '--release-source=[Release source]:source:(rust-changelog rust-dist)'
        ;;
      set)
        _arguments '1:version:'
        ;;
    esac
    ;;
esac
