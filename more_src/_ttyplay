#compdef ttyplay
# Documentation: https://manpages.debian.org/bookworm/ttyrec/ttyplay.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ttyplay - terminal session player

_arguments -s -S \
  '-s+[playback speed multiplier]:speed:' \
  '-n[no wait mode]' \
  '-p[peek mode (stdout passthrough)]' \
  '*:ttyrec file:_files -g "*.ttyrec"'
