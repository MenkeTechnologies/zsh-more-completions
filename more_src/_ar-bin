#compdef ar
# _ar-bin — GNU binutils ar; create, modify, extract from static archives
# upstream: https://sourceware.org/binutils

_ar-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--plugin+[load plugin]:plugin:' \
        '--target+[BFD target]:target:' \
        '--output+[extract dest dir]:dir:_files -/' \
        '--record-libdeps+[lib deps]:str:' \
        '--thin[create thin archive]' \
        '*:operation and files:_files'
}

_ar-bin "$@"
