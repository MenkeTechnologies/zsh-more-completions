# hp-fab: HPLIP fax address book GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' && ret=0
return ret
