#compdef rollouts-controller argo-rollouts-controller
# _rollouts-controller — Argo Rollouts progressive-delivery controller
# upstream: https://github.com/argoproj/argo-rollouts
# Flags from cmd/rollouts-controller/main.go on tip.

_rollouts-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version]' \
        '--rollout-resync=[rollout resync period in seconds]:s:' \
        '--namespaced[run controller in namespaced mode]' \
        '--loglevel=[log level]:level:(debug info warn error)' \
        '--logformat=[log format]:fmt:(text json)' \
        '--kloglevel=[klog verbosity level]:n:' \
        '--metricsPort=[metrics endpoint port]:port:' \
        '--healthzPort=[healthz endpoint port]:port:' \
        '--instance-id=[Rollouts instance id to operate on]:id:' \
        '--qps=[max QPS to API server]:f:' \
        '--burst=[max burst for throttle]:n:' \
        '--rollout-threads=[Rollout worker threads]:n:' \
        '--experiment-threads=[Experiment worker threads]:n:' \
        '--analysis-threads=[Analysis worker threads]:n:' \
        '--service-threads=[Service worker threads]:n:' \
        '--ingress-threads=[Ingress worker threads]:n:' \
        '--ephemeral-metadata-threads=[Ephemeral metadata reconciler threads]:n:' \
        '--ephemeral-metadata-update-pod-retries=[pod metadata update retries]:n:' \
        '--aws-target-group-binding-api-version=[AWS TargetGroupBinding apiVersion]:ver:' \
        '--alb-tag-key-resource-id=[ALB tag key for resource ID]:key:' \
        '--istio-api-version=[Istio VirtualService apiVersion]:ver:' \
        '--ambassador-api-version=[Ambassador apiVersion]:ver:' \
        '--traffic-split-api-version=[SMI TrafficSplit apiVersion]:ver:' \
        '--traefik-api-group=[Traefik apiGroup]:group:' \
        '--traefik-api-version=[Traefik apiVersion]:ver:' \
        '--ingress-api-version=[Ingress apiVersion]:ver:' \
        '--appmesh-crd-version=[AppMesh CRD version]:ver:' \
        '*--alb-ingress-classes=[ALB ingress class annotations]:class:' \
        '*--nginx-ingress-classes=[NGINX ingress class annotations]:class:' \
        '--aws-verify-target-group[verify ALB target group before progressing]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-lease-duration=[leader lease duration]:dur:' \
        '--leader-election-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-election-retry-period=[leader retry period]:dur:' \
        '--self-service-notification-enabled[allow per-namespace notification config]' \
        '*--controllers=[explicit controller list (e.g. analysis)]:name:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_rollouts-controller "$@"
