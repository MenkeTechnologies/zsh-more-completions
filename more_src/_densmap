#compdef densmap gmx-densmap
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-densmap.html
# gmx densmap: calculate 2D planar or axial-radial density maps

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-od[generic data file]:file:_files' \
  '-o[X PixMap matrix file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[frame selection criterion]:time:' \
  '-w[view output files]' \
  '-bin[grid spacing in nm]:real:' \
  '-aver[averaging direction]:dir:(z y x)' \
  '-xmin[minimum coordinate for averaging]:real:' \
  '-xmax[maximum coordinate for averaging]:real:' \
  '-n1[grid cells in first direction]:int:' \
  '-n2[grid cells in second direction]:int:' \
  '-amax[maximum axial distance from center]:real:' \
  '-rmax[maximum radial distance]:real:' \
  '-mirror[include mirror image below axial axis]' \
  '-sums[print 1D density sums to stdout]' \
  '-unit[output units]:unit:(nm-3 nm-2 count)' \
  '-dmin[minimum density in output]:real:' \
  '-dmax[maximum density in output]:real:' && ret=0

return ret
