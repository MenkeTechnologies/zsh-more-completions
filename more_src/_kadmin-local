#compdef kadmin.local kadmin-local
# _kadmin-local — MIT Kerberos kadmin.local CLI direct-access Kerberos administration program operating on the local KDC database file bypassing the kadmin RPC server for emergency principal policy keytab modify add delete change_password get_principal list_principals operations with master key required (MIT team, C); getopt
# upstream: https://web.mit.edu/kerberos/

_kadmin-local() {
    _arguments \
        '-h[show help]' \
        '-r+[realm]:str:' \
        '-c+[ccache]:file:_files' \
        '-d+[database name]:file:_files' \
        '-k+[stash file]:file:_files' \
        '-m[read master key from keyboard]' \
        '-x+[db-arg]:str:' \
        '-w+[password]:str:' \
        '-p+[principal]:str:' \
        '-q+[query]:str:' \
        '-s[stop on error]' \
        '*:command:(add_principal addprinc ank delete_principal delprinc cancel cpw change_password get_principal getprinc list_principals listprincs get_policy getpol list_policies listpols add_policy addpol modify_principal modprinc modify_policy modpol delete_policy delpol ktadd ktremove ktrem get_strings getstrs set_string setstr del_string delstr renew_principal lock unlock purgekeys getpwn lockstats)'
}

_kadmin-local "$@"
