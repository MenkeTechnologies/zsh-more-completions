#compdef krop
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/krop.1.html
# krop - tool to crop PDF files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files -g "*.pdf"' \
  '--whichpages=[pages to include e.g. 1-5 or 1,3-]:pages' \
  '--rotate=[rotate clockwise]:degrees:(0 90 180 270)' \
  '--optimize=[optimize with ghostscript]:opt:(gs no)' \
  '--grid=[grid of selections e.g. 2x3]:grid' \
  '--initialpage=[starting page]:page' \
  '--selections=[apply selections to]:sel:(all evenodd individual)' \
  '--exceptions=[pages requiring individual selections]:pages' \
  '--trim[auto-trim initial selections]' \
  '--trim-use=[inspection scope]:scope:(initial all)' \
  '--trim-padding=[padding for auto-trimming]:padding' \
  '--go[generate PDF without opening GUI]' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
