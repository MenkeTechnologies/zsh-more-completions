#compdef kgctl
# _kgctl — manage a Kilo WireGuard mesh on Kubernetes (squat/kilo)
# upstream: https://github.com/squat/kilo
# Flags from cmd/kgctl/main.go (cobra/spf13).

_kgctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--backend=[backend for the mesh]:backend:(kubernetes)' \
        '--mesh-granularity=[granularity of the mesh]:gran:(logical full auto)' \
        '--kubeconfig=[path to kubeconfig]:file:_files' \
        '--port=[WireGuard port]:port:' \
        '--topology-label=[node label for grouping]:label:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'graph:produce graphviz output of mesh topology'
                'showconf:print the WireGuard config for a node or peer'
                'connect:connect the local host to the mesh as a peer'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                graph)
                    _arguments \
                        '--layout=[graphviz layout]:layout:(dot neato fdp sfdp circo twopi)'
                    ;;
                showconf)
                    _arguments \
                        ':resource:(node peer)' \
                        ':name:' \
                        '--as-peer[output config as a WireGuard peer]' \
                        '--allowed-ips=[restrict allowed IPs]:cidr:' \
                        '--output=[output format]:fmt:(yaml json wireguard)'
                    ;;
                connect)
                    _arguments \
                        ':peer name:' \
                        '--allowed-ips=[allowed IPs (CIDR list)]:cidrs:' \
                        '--interface=[WireGuard interface name]:iface:_net_interfaces' \
                        '--mtu=[WireGuard interface MTU]:mtu:' \
                        '--persistent-keepalive=[keepalive seconds]:secs:' \
                        '--clean-up[clean up created interface/routes on exit]'
                    ;;
            esac
            ;;
    esac
}

_kgctl "$@"
