#compdef ovirt-engine-cli ovirt-shell
# Documentation: https://www.ovirt.org/develop/release-management/features/infra/cli.html
# Reference accessed: 2026-05-16
# Verified: oVirt CLI design page. The CLI is implemented as `ovirt-shell`
# and is interactive by default. Repository was archived 2021-05-14 and
# only supports the deprecated v3 REST API; modern oVirt usage is via
# ansible modules.
# Removed from prior file: fabricated -V flag (uses --version only) and
# bogus man.archlinux.org search URL.

# ovirt-engine-cli: oVirt/RHV admin shell (deprecated; archived 2021)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --url)'{-l+,--url=}'[API entry point URL]:url:_urls' \
  '(-u --username)'{-u+,--username=}'[username]:user:' \
  '(-K --key-file)'{-K+,--key-file=}'[private key file]:file:_files' \
  '(-C --cert-file)'{-C+,--cert-file=}'[client certificate]:file:_files' \
  '(-A --ca-file)'{-A+,--ca-file=}'[CA certificate]:file:_files' \
  '(-I --insecure)'{-I,--insecure}'[do not verify server certificate]' \
  '(-P --port)'{-P+,--port=}'[server port]:port:' \
  '(-T --timeout)'{-T+,--timeout=}'[connection timeout]:seconds:' \
  '(-c --connect)'{-c,--connect}'[auto-connect on startup]' \
  '(-F --filter)'{-F,--filter}'[apply user permission-based filtering]' \
  '(-f --file)'{-f+,--file=}'[read commands from file]:file:_files' && ret=0
return ret
