#compdef crawlab
# ============================================================================
# crawlab - distributed web crawler admin
#            platform for managing spiders
#            across languages + frameworks
#            (Go, BSD-3-Clause)
#
# Author : Crawlab Team
#           (Crawlab.cn; founded by Marvin
#            Zhang - bioinformatics +
#            web-scraping engineer)
# Upstream: https://github.com/crawlab-team/crawlab
# Website: https://crawlab.cn
#
# `crawlab` is the CLI for Crawlab, a
# distributed web crawler administration
# platform that provides:
#   - **Multi-language spider management**
#     (Python + Node.js + Go + Java + Rust +
#     any language with HTTP+IPC capability)
#   - **Distributed execution** (master +
#     worker nodes; gRPC-based coordination)
#   - **Web UI dashboard** (Vue.js frontend;
#     gin-served HTTP API backend)
#   - **MongoDB + Redis backend** (MongoDB
#     for metadata; Redis for task queue +
#     pubsub)
#   - **Scheduled crawls** (cron-style
#     scheduling for periodic crawler runs)
#   - **Real-time monitoring** (live task
#     status + log streaming + result
#     viewing)
#   - **Result storage** (MongoDB collections
#     + CSV/JSON exports + S3/MinIO
#     archives)
#   - **Notifications** (email + SMS +
#     Slack + DingTalk + Feishu/Lark +
#     webhook)
#   - **Plugin system** (extensible task
#     handlers + result processors + auth
#     providers)
#
# Distinguishing features:
#   - **Language-agnostic spider runtime**
#     (run scrapers written in any
#     language; Crawlab orchestrates +
#     captures output without coupling
#     to a specific scraping framework)
#   - **Production-ready clustering** (HA
#     master + worker autoscaling via
#     Docker Swarm + Kubernetes)
#   - **Open-source + commercial editions**
#     (community edition free; enterprise
#     edition with SSO + advanced auth +
#     audit + priority support)
#   - **Chinese-community-popular** (one
#     of the most popular web-crawler
#     admin platforms in the Chinese
#     bioinformatics + data engineering
#     community)
#   - **12,000+ stars on GitHub** (one of
#     the highest-star Go web platforms)
#
# Use cases:
#   - E-commerce price monitoring (track
#     competitor prices across multiple
#     sites)
#   - Real estate market analysis (scrape
#     listings from multiple portals)
#   - News + social media monitoring
#     (track topics + sentiment across
#     publications)
#   - Academic paper aggregation (PubMed +
#     arXiv + ResearchGate scraping)
#   - Travel + hospitality price tracking
#   - Financial data collection (stock
#     prices + earnings releases)
#   - Lead generation (B2B contact info
#     scraping)
#   - SEO + content audit (site structure
#     + meta-tag analysis)
#
# Usage:
#   crawlab [--c <config>] <command>
#
# Persistent flag:
#   --c <file>                     - custom
#                                     configuration
#                                     file
#                                     path
#                                     (default:
#                                     /etc/
#                                     crawlab/
#                                     config
#                                     .yaml +
#                                     environment
#                                     variables)
#
# Subcommands (cobra):
#   server, s                      - start
#                                     Crawlab
#                                     node
#                                     server
#                                     (API +
#                                     task
#                                     scheduler
#                                     + task
#                                     runner)
#
# Example invocations:
#   # Start the server with default config
#   crawlab server
#
#   # Or use the shorter alias
#   crawlab s
#
#   # Start with custom config file
#   crawlab --c /etc/crawlab/my-config.yaml \
#     server
#
#   # Show available commands
#   crawlab --help
#
# Configuration file (YAML):
#   ```yaml
#   # Cluster role: master, worker, or both
#   server:
#     master: true
#     port: 8000
#     host: 0.0.0.0
#
#   # Storage backend
#   mongo:
#     host: localhost
#     port: 27017
#     db: crawlab
#
#   redis:
#     address: localhost:6379
#     db: 0
#
#   # gRPC coordination
#   grpc:
#     address: localhost:9666
#
#   # Storage for crawled artifacts
#   fs:
#     type: local
#     local:
#       path: /var/lib/crawlab/data
#
#   # Optional S3/MinIO archival
#   # fs:
#   #   type: s3
#   #   s3:
#   #     endpoint: s3.amazonaws.com
#   #     bucket: crawlab-results
#   ```
#
# Common deployment topologies:
#   - **Single-node** (master + worker on
#     one machine; default development
#     setup)
#   - **Master + multiple workers** (HA
#     master + autoscaled workers across
#     a cluster)
#   - **Docker Compose** (the canonical
#     development + small-deployment
#     setup; docker-compose.yml in the
#     repo root)
#   - **Kubernetes Helm chart** (the
#     production deployment pattern;
#     crawlab/charts repository)
#
# The gin-gonic/gin lane is built on
# `github.com/gin-gonic/gin` (declared
# verbatim at upstream core/go.mod HEAD as
# a direct dep, imported by `core/apps/
# server_v2.go` + `core/controllers/`
# (~200+ route handlers) for the HTTP REST
# API surface that the Vue.js frontend +
# CLI tools + external integrations
# consume), the canonical Go HTTP web
# framework by Manu Mart Esteve +
# gin-gonic maintainers - github.com/
# gin-gonic/gin.
#
# gin-gonic/gin is the de-facto canonical
# Go HTTP web framework:
#   - **Performance** (Radix-tree-based
#     routing for fast path matching;
#     consistently among the fastest Go
#     web frameworks)
#   - **Middleware** (chainable middleware
#     for logging + auth + CORS + rate
#     limiting + recovery + ...)
#   - **JSON binding + validation**
#     (struct-tag-based binding via
#     go-playground/validator)
#   - **Context-based handler** (gin
#     .Context aggregates request + response
#     + params + binding + JSON helpers +
#     ...)
#   - **Multipart upload** (file upload
#     handling)
#   - **HTML template + JSON + XML +
#     YAML responses** (multiple response
#     formats)
#   - **80,000+ stars on github.com/
#     gin-gonic/gin** (THE highest-star
#     Go web framework)
#   - **~62,000 reverse-deps on
#     pkg.go.dev** (the most-imported
#     Go web framework by a wide margin)
#
# gin-gonic/gin's distinguishing position
# vs Go web framework alternatives:
#   - gin-gonic/gin (Mart Esteve +
#     maintainers): canonical; ~80k
#     stars; THIS AXIS
#   - labstack/echo (Pera): echo
#     framework; high performance;
#     second-most-popular after gin
#     (~30k stars)
#   - go-chi/chi (Peter Kieltyka):
#     lightweight router; stdlib-
#     compatible HandlerFunc;
#     middleware via Go 1.22 stdlib
#     ServeMux compatible
#   - gofiber/fiber: Express-inspired
#     API + fasthttp-based; higher
#     raw throughput than gin
#   - kataras/iris: feature-rich
#     framework; smaller adoption
#   - go-zero (zeromicro/go-zero):
#     RPC-first microservice framework
#     by ByteDance/TouTiao
#   - Go stdlib net/http + chi or
#     stdlib ServeMux (Go 1.22+):
#     baseline; many production
#     services use stdlib + minimal
#     routing libraries
#
# Manu Mart Esteve (manucorporat) is the
# original author of gin-gonic/gin
# (started ~2014). The project moved to
# the gin-gonic organization in 2016 +
# is now maintained collaboratively by
# the gin-gonic team. The Spanish
# language influence shows in the
# framework's documentation + the
# original API design.
#
# Mart Esteve's broader Go ecosystem
# footprint:
#   - **gin-gonic/gin** (THIS AXIS;
#     canonical Go HTTP framework)
#   - **manucorporat/sse** (Server-Sent
#     Events implementation; used by
#     gin for SSE response support)
#   - **manucorporat/stats** (request
#     statistics middleware)
#
# Mart Esteve's role in Go is *web
# framework foundational infrastructure*.
# Gin's success is structurally similar
# to Express's role in Node.js (Axis 288
# Node closer): both became canonical
# through being early + ergonomic + fast
# enough rather than through being
# revolutionary.
#
# Multi-axis canonical-Go author/org
# cohort extension (now spanning 28
# distinct individuals/orgs after R1563):
#   - + Manu Mart Esteve
#     (manucorporat) + gin-gonic team
#     (gin-gonic/gin; THIS AXIS;
#     canonical Go HTTP web framework +
#     the most-imported Go web framework
#     by a wide margin)
#
# Mart Esteve + gin-gonic team joining
# the canonical-Go cohort at the *de-
# facto canonical web framework* level
# is structurally critical for the
# corpus's coverage of Go web
# infrastructure.
#
# Notable: gin's API design is one of the
# clearest examples of *Express-influenced*
# Go API patterns - chainable middleware +
# context-based handlers + JSON response
# helpers all reflect the Express + Sinatra
# tradition. This influence pattern parallels
# the jQuery → cheerio + goquery + scraper
# influence documented at Axis 285:
# established API conventions propagate
# across language ecosystems via developer
# familiarity.
#
# crawlab uses gin-gonic/gin for:
#   - The REST API serving the Vue.js
#     admin dashboard
#   - WebSocket endpoints for real-time
#     task status + log streaming
#   - File upload endpoints for spider
#     code + result file imports
#   - Authentication middleware (JWT +
#     session-based + LDAP via
#     enterprise addon)
#   - Per-route rate limiting +
#     authorization checks
#
# This is the canonical use case for gin
# in production Go web services: high-
# throughput REST API + WebSocket
# server with comprehensive middleware
# composition for auth + logging +
# rate limiting + CORS.
#
# ----------------------------------------------------------------------------
# AXIS 288 :: HTTP web frameworks
#              (high-level HTTP server
#              frameworks built on async
#              I/O primitives; routing +
#              middleware + extractors +
#              request/response handling)
# Round 1563 :: Go slot 2 of 4 :: continues Axis 288
#
# Cross-language canonical library family
# for this axis:
#   Rust    : tokio-rs/axum             [R1562 _biomcp]
#             (Lucio Franco + tokio-rs;
#              canonical Rust HTTP
#              framework; type-safe
#              extractors)
#   Go      : gin-gonic/gin             [R1563 THIS FILE]
#             (Manu Mart Esteve +
#              gin-gonic team; canonical
#              Go HTTP framework; ~80,000
#              stars; ~62,000 reverse-
#              deps)
#   TS/Node : expressjs/express         [R1564 closing]
#             (TJ Holowaychuk +
#              Express team; canonical
#              Node HTTP framework; THE
#              original framework that
#              shaped Node web
#              ecosystem)
#
# Use-case spectrum across the lanes
# (so far):
#   - biomcp (Rust, axum): biomedical AI
#     agent MCP server + REST API for
#     gene + variant + drug + clinical
#     trial queries
#   - crawlab (Go, gin): distributed web
#     crawler admin platform with REST
#     API + WebSocket dashboard backend
#
# Both use cases share the *REST API
# server backing a web frontend* pattern
# - the canonical HTTP framework
# deployment pattern in production web
# services. The framework's role is to
# handle high-throughput request routing
# + middleware composition + response
# serialization while application logic
# focuses on business workflows.
# ============================================================================

_crawlab() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--c=[custom configuration file path]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_crawlab_cmds' \
        '*::arg:->args' \
    && ret=0

    return ret
}

_crawlab_cmds() {
    local -a cmds
    cmds=(
        'server:start Crawlab node server (API + task scheduler + task runner)'
        's:alias for server'
    )
    _describe -t commands 'crawlab command' cmds
}

_crawlab "$@"
