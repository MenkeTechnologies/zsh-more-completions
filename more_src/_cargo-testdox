#compdef cargo-testdox
# Documentation: https://github.com/bitfield/cargo-testdox
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Pretty-prints `cargo test` names as sentences. Extra arguments are passed through to `cargo test`.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::cargo_test_arguments:_default' && return 0
