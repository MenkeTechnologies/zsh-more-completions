#compdef cargo-testdox
# Documentation: https://man.archlinux.org/search?q=cargo-testdox
# Reference accessed: 2026-05-16

# https://github.com/bitfield/cargo-testdox — pretty-print `cargo test` names as sentences

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::cargo_test_arguments:_default' && return 0
