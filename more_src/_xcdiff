#compdef xcdiff
# Documentation: https://man.archlinux.org/search?q=xcdiff
# Reference accessed: 2026-05-16

# Zsh completion for xcdiff Xcode project differ

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-p[include linked dependency diffs]' \
  '-v[verbose output]' \
  '-c[compare nested objects]' \
  '-g[generic differences only]' \
  '-d+[derived data path]:dir:_directories' \
  '1:left project:_files -g "*.xcodeproj"' \
  '2:right project:_files -g "*.xcodeproj"' && ret=0

return ret
