#compdef ya
# Documentation: https://github.com/sxyazi/yazi/blob/main/yazi-cli/src/args.rs
# Reference accessed: 2026-05-21
# Verified: upstream clap Args/Subcommand definitions in yazi-cli at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'emit:emit an action to the current instance'
  'emit-to:emit an action to the specified instance'
  'exec:execute an action and print its result'
  'pkg:manage packages'
  'pub:publish a message to the current instance'
  'pub-to:publish a message to the specified instance'
  'sub:subscribe to messages from all remote instances'
)

_arguments -C \
  '(-V --version)'{-V,--version}'[print version]' \
  '(- *)'{-h,--help}'[print help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ya subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (pkg)
        local -a pkg_sub=(
          'add:install packages'
          'delete:remove packages'
          'install:install all packages from package.toml'
          'list:list all packages'
          'upgrade:upgrade packages'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'ya pkg subcommand' pkg_sub && ret=0
        else
          case $words[2] in
            (delete|install|upgrade)
              _arguments '--discard[discard local changes]' '*:package id:' && ret=0 ;;
            (add)
              _arguments '*:package id:' && ret=0 ;;
            (list)
              ret=0 ;;
          esac
        fi
        ;;
      (pub|pub-to)
        _arguments \
          '--str=[message body as string]:body:' \
          '--json=[message body as JSON]:json:' \
          '*--list=[message body as list of strings]:item:' \
          '*:positional:' && ret=0
        ;;
      (emit|emit-to|exec|sub)
        _arguments '*:positional:' && ret=0
        ;;
    esac
    ;;
esac

return ret
