#compdef yazi

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--cwd-file=[file to write cwd on exit]:file:_files' \
  '--chooser-file=[file to write chosen path]:file:_files' \
  '--clear-cache[clear cache then exit]' \
  '--debug[print debug info and exit]' \
  '--local-events=[local events csv]:list:' \
  '--remote-events=[remote events csv]:list:' \
  '*: :_files' && ret=0

return ret
