#compdef rfluxmtx

# Radiance rfluxmtx: compute flux transfer matrix
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose output]' \
  '-x[output ray cell x]:n:' \
  '-y[output ray cell y]:n:' \
  '-c[ray count per cell]:n:' \
  '-d[direct only mode]' \
  '-fa[ASCII float output]' \
  '-fd[double-precision binary output]' \
  '-ff[single-precision binary output]' \
  '-fc[colour binary output]' \
  '-n[number of processes]:n:' \
  '-h[no header in output]' \
  '-I[treat as irradiance mode]' \
  '-V[output secondary contributions]' \
  '-o[output filename template]:file:_files' \
  '-b[per-bin expression]:expr:' \
  '-bn[bin count expression]:expr:' \
  '-m[modifier list]:list:' \
  '-M[modifier file]:file:_files' \
  '-T[treat as transparent]' \
  '*:scene .oct file:_files -g "*.oct"' && ret=0
return ret
