#compdef clazy
# Documentation: https://github.com/KDE/clazy
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-checks=[comma-separated list of checks]:checks:' \
  '-extra-arg=[extra argument to pass to the compiler]:arg:' \
  '-p+[path to compilation database]:build path:_files -/' \
  '-export-fixes=[export fix-it hints to YAML file]:yaml file:_files -g "*.yaml"' \
  '-list[list available checks]' \
  '-explain+[explain a specific check]:check name:' \
  '-no-inplace-fixits[do not modify source files in-place]' \
  '-header-filter=[regex for headers to display diagnostics from]:regex:' \
  '-ignore-dirs=[directories to ignore]:dirs:' \
  '-only-qt[only check Qt-related issues]' \
  '-qt-developer[enable Qt developer checks]' \
  '-version[show version]' \
  '-help[show help]' \
  '*:source file:_files -g "*.(cpp|cxx|cc|c|h|hpp|hxx)"' && ret=0

return ret
