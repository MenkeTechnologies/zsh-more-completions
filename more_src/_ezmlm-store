#compdef ezmlm-store
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-store.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-b[send headers and body in moderation requests (default)]' \
  '-B[send headers only]' \
  '-c[passed to ezmlm-send]' \
  '-C[passed to ezmlm-send]' \
  '-m[post sent as MIME enclosure (default)]' \
  '-M[post appended to message]' \
  '-r[passed to ezmlm-send]' \
  '-R[passed to ezmlm-send]' \
  '-s[separate self-approving users from moderators]' \
  '-S[use modpost dir for all moderator functions (default)]' \
  '-p[anyone can post (default)]' \
  '-P[only moderators can post]' \
  '-y[enable post confirmation without confirmpost file]' \
  '-Y[ignore confirmpost file]' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' && ret=0

return ret
