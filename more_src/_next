#compdef next
# Documentation: https://github.com/vercel/next.js (packages/next/src/bin/next.ts)
# Reference accessed: 2026-05-29
# Next.js React framework CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'build:create an optimized production build of your application'
  'dev:start Next.js in development mode with hot-code reloading'
  'start:start Next.js in production mode (build first)'
  'export:export the application to static HTML (deprecated; use output: export in config)'
  'experimental-analyze:bundle analysis with interactive web UI (Turbopack only)'
  'info:print relevant details about the system for bug reports'
  'telemetry:toggle anonymous telemetry collection or check status'
  'typegen:generate TypeScript definitions for routes/pages/layouts'
  'upgrade:upgrade a Next.js app to the desired version'
  'experimental-test:execute tests using a specified test runner'
  'internal:internal debugging commands (trace/query-trace/post-build/upload-trace/static-routes-info)'
  'lint:run ESLint on the project (deprecated as of Next 16; use eslint directly)'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show Next.js version]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'next subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      dev|start)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --port)'{-p,--port=}'[port (default 3000)]:port:' \
          '(-H --hostname)'{-H,--hostname=}'[hostname (default 0.0.0.0)]:host:_hosts' \
          '--turbo[use Turbopack bundler]' \
          '--turbopack[use Turbopack bundler]' \
          '--webpack[use webpack bundler]' \
          '--inspect=-[enable server-side code inspection]::host:port:' \
          '--experimental-https[serve over HTTPS in development]' \
          '--experimental-https-key=[path to HTTPS key file]:file:_files' \
          '--experimental-https-cert=[path to HTTPS cert file]:file:_files' \
          ':directory:_directories' && ret=0
        ;;
      build)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-d --debug)'{-d,--debug}'[enable detailed build output]' \
          '--profile[enable React profiling in production]' \
          '--turbo[use Turbopack bundler]' \
          '--turbopack[use Turbopack bundler]' \
          '--webpack[use webpack bundler]' \
          '--no-mangling[disable mangling]' \
          '--experimental-build-mode=[build mode]:mode:(default compile generate)' \
          '--experimental-app-only[only build app/]' \
          '--experimental-debug-memory-usage[debug memory usage]' \
          '--experimental-upload-trace=[trace upload endpoint]:url:_urls' \
          ':directory:_directories' && ret=0
        ;;
      telemetry)
        _arguments \
          '1:action:(enable disable status)' && ret=0
        ;;
      upgrade)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--codemods=[run codemods]:codemods:' \
          ':version:(latest canary rc next)' && ret=0
        ;;
    esac
    ;;
esac

return ret
