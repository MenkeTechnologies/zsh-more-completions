#compdef kwalletmanager

# kwalletmanager: KDE wallet manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--show[start visible]' \
  '--kwl[open .kwl wallet]:file:_files -g "*.kwl"' \
  '--encrypt[encrypt a wallet]:file:_files -g "*.kwl"' \
  '*:wallet file:_files -g "*.kwl"' && ret=0
return ret
