#compdef tsv-uniq

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[fields for uniqueness]:fields' \
  '--fields=[fields for uniqueness]:fields' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '--header[input has header]' \
  '--number[add unique number column]' \
  '--equiv[add equivalence class number]' \
  '--ignore-case[case insensitive]' \
  '--max=[max unique values]:count' \
  '*:file:_files' && return 0
