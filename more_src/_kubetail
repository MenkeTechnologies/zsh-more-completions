#compdef kubetail
# Documentation: https://github.com/johanhaleby/kubetail
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubetail - Kubernetes pod log tailer (bash script).
# Flags derived from the upstream kubetail script in the repo.

local curcontext="$curcontext" state line ret=1

_kubetail_namespaces() {
  local -a ns
  ns=(${(f)"$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null)"})
  _describe -t namespaces 'namespace' ns
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print kubetail version]' \
  '(-c --container)'{-c+,--container=}'[name of the container to tail]:container:' \
  '(-t --context)'{-t+,--context=}'[Kubernetes context to use]:context:' \
  '(-l --selector)'{-l+,--selector=}'[label selector (pod name is ignored if set)]:selector:' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:_kubetail_namespaces' \
  '(-f --follow)'{-f+,--follow=}'[stream logs (true|false)]:bool:(true false)' \
  '(-d --dry-run)'{-d,--dry-run}'[print matched pods/containers and exit]' \
  '(-P --prefix)'{-P+,--prefix=}'[prepend pod name prefix to each line]:bool:(true false)' \
  '(-p --previous)'{-p+,--previous=}'[return logs from previous pod instances]:bool:(true false)' \
  '(-s --since)'{-s+,--since=}'[only return logs newer than a relative duration]:since:(1s 1m 5m 15m 1h)' \
  '(-b --line-buffered)'{-b+,--line-buffered=}'[control line buffering (true|false)]:bool:(true false)' \
  '(-e --regex)'{-e+,--regex=}'[name matching type]:mode:(regex substring)' \
  '(-j --jq)'{-j+,--jq=}'[jq selector for JSON output]:jq selector:' \
  '(-k --colored-output)'{-k+,--colored-output=}'[colored output mode]:mode:(pod line loglevel false)' \
  '(-z --skip-colors)'{-z+,--skip-colors=}'[comma-separated list of colors to skip]:colors:' \
  '--timestamps=[show timestamps for each log line]:bool:(true false)' \
  '--tail=[lines of recent log file to display]:lines:' \
  '(-r --cluster)'{-r+,--cluster=}'[kubeconfig cluster name]:cluster:' \
  '(-i --show-color-index)'{-i,--show-color-index}'[show the color index before pod name prefix]' \
  '*:pod name pattern:' && ret=0

return ret
