#compdef kubetail

# Zsh completion for kubetail - Kubernetes pod log tailer

local curcontext="$curcontext" state line ret=1

_kubetail_namespaces() {
  local -a ns
  ns=(${(f)"$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null)"})
  _describe -t namespaces 'namespace' ns
}

_arguments -s -S \
  '(- *)--help[show help]' \
  '-c+[container name]:container' \
  '-t+[template to use for log output]:template:(default stderr)' \
  '-s+[return logs newer than a relative duration]:since:(1s 1m 5m 15m 1h)' \
  '-n+[namespace]:namespace:_kubetail_namespaces' \
  '-f[follow the log output]' \
  '-l+[label selector]:label selector' \
  '-k[use kail instead of kubectl]' \
  '--context=[Kubernetes context to use]:context' \
  '*:pod name pattern:' && ret=0

return ret
