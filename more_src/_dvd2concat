#compdef dvd2concat
# Documentation: https://github.com/FFmpeg/FFmpeg/blob/master/tools/dvd2concat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dvd2concat - Perl tool that builds an FFmpeg concat script for a DVD title

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-\?,--help,--usage}'[show usage]' \
  '(- *)'{-m,--manpage}'[show full manpage]' \
  '(-t --title)'{-t+,--title=}'[DVD title number]:title:' \
  '1:DVD structure path:_files -/' && ret=0

return ret
