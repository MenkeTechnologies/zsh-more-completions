#compdef AssayGeneratorMetabo
# Documentation: https://www.openms.org/documentation/html/TOPP_AssayGeneratorMetabo.html
# OpenMS: generates an assay library from metabolomics DDA data

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '*-in[mzML input file(s)]:file:_files -g "*.mzML"' \
  '*-in_featureinfo[featureXML input with identification info]:file:_files -g "*.featureXML"' \
  '-out[assay library output file]:file:_files' \
  '-ambiguity_resolution_mz_tolerance[m/z tolerance for ambiguity resolution]:double:' \
  '-ambiguity_resolution_rt_tolerance[RT tolerance in seconds]:double:' \
  '-total_occurrence_filter[filter compounds by occurrence]:double:' \
  '-method[spectrum selection method]:method:(highest_intensity consensus_spectrum)' \
  '-exclude_ms2_precursor[exclude precursor from transition list]' \
  '-use_known_unknowns[include unidentified features]' \
  '-min_transitions[minimum transitions required]:int:' \
  '-max_transitions[maximum transitions allowed]:int:' \
  '-cosine_similarity_threshold[similarity threshold for consensus]:double:' \
  '-transition_threshold[minimum intensity percentage for transitions]:double:' \
  '-precursor_mz_distance[max m/z distance for spectrum merging]:double:' \
  '-precursor_mz_tolerance[precursor selection tolerance]:double:' \
  '-precursor_mz_tolerance_unit[tolerance unit]:unit:(ppm Da)' \
  '-precursor_rt_tolerance[precursor RT tolerance in seconds]:double:' \
  '-feature_only[restrict to feature-associated MS2 spectra]' \
  '-deisotoping_use_deisotoper[enable deisotoper]' \
  '-deisotoping_fragment_tolerance[isotopic peak matching tolerance]:double:' \
  '-deisotoping_fragment_unit[tolerance unit]:unit:(ppm Da)' \
  '-deisotoping_min_charge[minimum charge state]:int:' \
  '-deisotoping_max_charge[maximum charge state]:int:' \
  '-deisotoping_min_isopeaks[minimum isotopic peaks required]:int:' \
  '-deisotoping_max_isopeaks[maximum isotopic peaks considered]:int:' \
  '-filter_by_num_masstraces[mass traces per feature threshold]:int:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
