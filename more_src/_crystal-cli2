#compdef crystal-cli2 crystal2
# _crystal-cli2 — Manas Crystal Team crystal-cli2 CLI command-line frontend wrapping the Crystal general-purpose object-oriented programming language inspired by Ruby with static type checking and compilation to native code open-source written in Crystal originally Ary Borenszweig at Manas now Crystal Team Ruby-like syntax compiled to native via LLVM Channel CSP concurrency build clear-cache deps docs env eval init inspect i interactive play run spec tool types env play LLVM crystal-shards shards crystal-tool format hierarchy implementations context expand unreachable flags emit static define error single-module no-codegen progress (Manas Ary Borenszweig Crystal Team, Crystal); custom argparse
# upstream: https://crystal-lang.org/

_crystal-cli2() {
    local -a sub=(
        'build:Build an executable'
        'clear-cache:Clear the compiler cache'
        'deps:Manage dependencies (shards)'
        'docs:Generate documentation'
        'env:Print Crystal environment'
        'eval:Eval Crystal code from args/stdin'
        'i:Starts crystal interpreter (alias)'
        'init:Generate a new project'
        'inspect:Print info about a Crystal source'
        'interactive:Starts crystal interpreter'
        'play:Crystal playground server'
        'run:Build and run a program'
        'spec:Build and run specs'
        'tool:Run a tool'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--cross-compile[cross compile]' \
        '-D+[flag]:str:' \
        '*-D+[flag]:str:' \
        '--define=+[flag]:str:' \
        '--emit=+[items]:str:' \
        '*--emit=+[items]:str:' \
        '-f+[format]:f:(text json)' \
        '--format=+[fmt]:f:(text json)' \
        '--error-trace[error trace]' \
        '--exclude-warnings=+[paths]:str:' \
        '--ll[dump LLVM IR]' \
        '--link-flags=+[flags]:str:' \
        '--mcpu=+[cpu]:str:' \
        '--mattr=+[attrs]:str:' \
        '--mcmodel=+[m]:m:(default tiny small kernel medium large)' \
        '--no-color[no color]' \
        '--no-codegen[no codegen]' \
        '-o+[out]:file:_files' \
        '--output=+[file]:file:_files' \
        '--prelude=+[file]:file:_files' \
        '--release[release mode]' \
        '--single-module[single module]' \
        '--threads=+[N]:n:' \
        '--target=+[triple]:str:' \
        '--time[show timing]' \
        '-s[stats]' \
        '--stats[stats]' \
        '-p[progress]' \
        '--progress[progress]' \
        '--debug[debug info]' \
        '--no-debug[no debug info]' \
        '--static[static link]' \
        '-Werror[warnings as errors]' \
        '-Wno-error=+[ws]:str:' \
        '--warnings=+[w]:w:(none all)' \
        '--error-on-warnings[error on warnings]' \
        '--list-targets[list targets]' \
        '--frame-pointers=+[v]:v:(auto always non-leaf)' \
        '--show-asm[show asm]' \
        '--define-flag=+[name]:str:' \
        '--dump-llvm[dump LLVM]' \
        '--dump-debug[dump debug]' \
        '-O+[optimization]:n:(0 1 2 3 z s)' \
        '-i+[include]:dir:_files -/' \
        '*-i+[include]:dir:_files -/' \
        '--include=+[dir]:dir:_files -/' \
        '*--include=+[dir]:dir:_files -/' \
        '--example=+[name]:str:' \
        '--dir=+[dir]:dir:_files -/' \
        '--ignore-flags-file[ignore flags file]' \
        '--source-map[source map]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'crystal subcommand' sub ;;
        args)
            case $words[1] in
                build|run|spec|docs|i|interactive|inspect) _arguments '*:source:_files -g "*.cr"' ;;
                init) _arguments '1:type:(app lib)' '*:name:' ;;
                tool) _arguments '1:op:(context expand format hierarchy implementations types unreachable flags dependencies)' '*:arg:' ;;
                deps) _arguments '1:op:(install update build check init outdated prune remove version)' '*:arg:' ;;
            esac
            ;;
    esac
}

_crystal-cli2 "$@"
