#compdef 3dDeconvolve
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDeconvolve.html
# AFNI multiple linear regression / deconvolution for fMRI time series

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '*-input[input 3D+time dataset]:dataset:_files' \
  '-input1D[single fMRI .1D time series file]:file:_files' \
  '-TR_1D[TR value for .1D time series]:tr' \
  '-force_TR[override TR from input dataset]:tr' \
  '-nodata[evaluate design only, no input data]:NT' \
  '-mask[3D mask dataset for analysis]:dataset:_files' \
  '-automask[build mask automatically from data]' \
  '-STATmask[mask for stat reporting and FDR]:dataset:_files' \
  '-censor[.1D file of timepoints to include/exclude]:file:_files' \
  '-CENSORTR[time indexes to remove]:clist' \
  '-concat[file listing concatenated run start indices]:file:_files' \
  '-nfirst[first dataset image to use]:fnum' \
  '-nlast[last dataset image to use]:lnum' \
  '-noblock[treat multiple inputs as single run]' \
  '-polort[polynomial degree for baseline]:pnum' \
  '-legendre[use Legendre polynomials (default)]' \
  '-nolegendre[use power polynomials]' \
  '-nodmbase[do not de-mean baseline]' \
  '-dmbase[de-mean baseline time series]' \
  '-svd[use SVD (default)]' \
  '-nosvd[use Gaussian elimination]' \
  '-rmsmin[minimum RMS error threshold]:r' \
  '-nocond[do not calculate condition number]' \
  '-singvals[print matrix singular values]' \
  '-GOFORIT[proceed despite matrix problems]:g' \
  '-allzero_OK[allow all-zero matrix columns]' \
  '-num_stimts[number of input stimulus time series]:num' \
  '-stim_file[time series file for kth stimulus]:k' \
  '-stim_label[label for kth stimulus]:k' \
  '-stim_base[mark kth stimulus as baseline]:k' \
  '-ortvec[input baseline vectors from file]:file:_files' \
  '-stim_minlag[minimum time lag for kth stimulus]:k' \
  '-stim_maxlag[maximum time lag for kth stimulus]:k' \
  '-stim_nptr[stimulus points per TR]:k' \
  '-stim_times[response model from stimulus times]:k' \
  '-stim_times_AM1[amplitude-modulated response model]:k' \
  '-stim_times_AM2[AM response with mean and deviations]:k' \
  '-stim_times_FSL[FSL-style 3-column timing]:k' \
  '-stim_times_IM[individual amplitude per event]:k' \
  '-global_times[times relative to start of run 1]' \
  '-local_times[times relative to start of each run]' \
  '-stim_times_millisec[input times in milliseconds]' \
  '-stim_times_subtract[subtract SS seconds from times]:SS' \
  '-basis_normall[normalize basis functions to amplitude]:a' \
  '-num_glt[number of GLTs]:num' \
  '-glt[perform s simultaneous linear tests]:s' \
  '-glt_label[label for kth GLT]:k' \
  '-gltsym[read GLT with symbolic names from file]:file:_files' \
  '-iresp[prefix for kth impulse response dataset]:k' \
  '-sresp[prefix for std dev of IRF parameters]:k' \
  '-fitts[prefix for fitted model time series]:prefix' \
  '-errts[prefix for residual error time series]:prefix' \
  '-tshift[time-shift estimated IRF]' \
  '-TR_times[stepsize for -iresp/-sresp output]:dt' \
  '-bucket[create bucket dataset with results]:prefix' \
  '-nobucket[suppress bucket dataset output]' \
  '-cbucket[save regression coefficients only]:prefix' \
  '-xrestore[restore X matrix from previous run]:file:_files' \
  '-fout[output F-statistics]' \
  '-tout[output t-statistics]' \
  '-rout[output R-squared statistics]' \
  '-vout[output sample variance map]' \
  '-bout[output baseline coefficients and stats]' \
  '-nobout[suppress baseline coefficient output]' \
  '-nocout[suppress regression coefficient output]' \
  '-full_first[full model statistics first (default)]' \
  '-nofull_first[full model statistics last]' \
  '-nofullf_atall[turn off full model F-statistic]' \
  '-noFDR[do not compute FDR curves]' \
  '-x1D[save X matrix to ASCII .xmat.1D file]:file:_files' \
  '-nox1D[do not save X matrix]' \
  '-x1D_uncensored[save X matrix without censoring]:file:_files' \
  '-x1D_stop[stop after writing .xmat.1D files]' \
  '-xsave[save X matrix to .xsave]' \
  '-noxsave[do not save X matrix]' \
  '-xout[write X and inv(XtX) to screen]' \
  '-xjpeg[write JPEG/PNG graph of X matrix]:file:_files' \
  '-float[write output in float format]' \
  '-short[write output as scaled shorts]' \
  '-quiet[suppress most screen output]' \
  '-progress[write results for every nth voxel]:n' \
  '-fdisp[display results for voxels F > fval]:fval' \
  '-jobs[run with J parallel processes]:J' \
  '-virtvec[write input to temp file for memory savings]' \
  '*:dataset:_files' && ret=0

return ret
