#compdef headsetcontrol

# Zsh completion for headsetcontrol (headset settings controller)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --sidetone)'{-s,--sidetone}'[set sidetone level (0-128)]:level' \
  '(-b --battery)'{-b,--battery}'[show battery status]' \
  '(-n --notificate)'{-n,--notificate}'[set notification sound]:sound:(0 1)' \
  '(-l --light)'{-l,--light}'[set LED light]:state:(0 1)' \
  '(-i --inactive-time)'{-i,--inactive-time}'[set inactive time]:minutes' \
  '(-m --chatmix)'{-m,--chatmix}'[show chatmix level]' \
  '(-v --voice-prompts)'{-v,--voice-prompts}'[set voice prompts]:state:(0 1)' \
  '(-r --rotate-to-mute)'{-r,--rotate-to-mute}'[set rotate to mute]:state:(0 1)' \
  '(-e --equalizer)'{-e,--equalizer}'[set equalizer values]:values' \
  '(-p --equalizer-preset)'{-p,--equalizer-preset}'[set equalizer preset]:preset' \
  '--volume-limiter[set volume limiter]:state:(0 1)' \
  '--bt-when-powered-on[Bluetooth when powered on]:state:(0 1)' \
  '--bt-call-volume[Bluetooth call volume]:level' \
  '(-o --output)'{-o,--output}'[output format]:format:(normal short json json-pretty)' \
  '(-c --capabilities)'{-c,--capabilities}'[show device capabilities]' \
  '(-d --device)'{-d,--device}'[select device]:device number' \
  '(-f --follow)'{-f,--follow}'[continuously output status]' \
  '--timeout[timeout in milliseconds]:ms' \
  '(-? --help)'{'-?',--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
