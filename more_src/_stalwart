#compdef stalwart
# Documentation: https://github.com/stalwartlabs/cli (src/cli/mod.rs clap derive)
# Reference accessed: 2026-05-29
# Stalwart Mail Server CLI (JMAP/IMAP/SMTP/CalDAV admin).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'get:retrieve a single object by its identifier'
  'query:search objects using optional filter criteria'
  'create:generate a new object'
  'update:modify an existing object by id'
  'delete:remove one or more objects by id'
  'describe:display schema information for objects and enums'
  'apply:execute bulk operations from a JSON plan file'
  'snapshot:export object types to a plan file for use with apply'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '--url=[server endpoint URL (env STALWART_URL)]:url:_urls'
  '--user=[basic auth username (env STALWART_USER)]:user:'
  '--password=[basic auth password (env STALWART_PASSWORD)]:password:'
  '--api-key=[bearer token, mutually exclusive with --user (env STALWART_TOKEN)]:token:'
  '(-k --insecure)'{-k,--insecure}'[bypass TLS certificate validation]'
  '--no-color[disable ANSI color formatting]'
  '--debug[output HTTP request/response diagnostics to stderr]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
)

local -a _object_types
_object_types=(
  'account' 'principal' 'group' 'domain' 'config' 'queue' 'report'
  'spam-rule' 'webhook' 'tracer' 'role' 'tenant' 'mailbox' 'identity'
  'sieve-script' 'individual' 'list' 'other' 'apipassword' 'oauth'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'stalwart subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      get|update|delete)
        _arguments \
          $_global \
          '--format=[output format]:format:(json yaml table)' \
          ':object type:($_object_types)' \
          '*:object id:' && ret=0
        ;;
      query)
        _arguments \
          $_global \
          '--format=[output format]:format:(json yaml table csv)' \
          '*--filter=[filter expression (field=value)]:filter:' \
          '--limit=[max results]:n:' \
          '--offset=[result offset]:n:' \
          '--sort=[sort field]:field:' \
          ':object type:($_object_types)' && ret=0
        ;;
      create)
        _arguments \
          $_global \
          '--file=[JSON/YAML file with object payload]:file:_files -g "*.(json|yaml|yml)"' \
          '--from-stdin[read object payload from stdin]' \
          ':object type:($_object_types)' && ret=0
        ;;
      describe)
        _arguments \
          $_global \
          '--format=[output format]:format:(json yaml text)' \
          '*:object or enum type:' && ret=0
        ;;
      apply)
        _arguments \
          $_global \
          '--dry-run[show what would change without applying]' \
          '--continue-on-error[continue past failed operations]' \
          ':plan file:_files -g "*.(json|yaml|yml)"' && ret=0
        ;;
      snapshot)
        _arguments \
          $_global \
          '--output=[output plan file]:file:_files -g "*.(json|yaml|yml)"' \
          '*--include=[object type to include (repeatable)]:type:($_object_types)' && ret=0
        ;;
    esac
    ;;
esac

return ret
