#compdef yaml-merge
# _yaml-merge — merge YAML/JSON/compatible files (wwkimball/yamlpath)
# upstream: https://github.com/wwkimball/yamlpath
# Flags from yamlpath/commands/yaml_merge.py (argparse).

_yaml-merge() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[INI config file]:file:_files' \
        '(-a --anchors)'{-a+,--anchors=}'[anchor conflict resolution]:mode:(stop left right rename)' \
        '(-A --arrays)'{-A+,--arrays=}'[array merge strategy]:mode:(all left right unique)' \
        '(-H --hashes)'{-H+,--hashes=}'[hash merge strategy]:mode:(deep left right)' \
        '(-O --aoh)'{-O+,--aoh=}'[array-of-hashes merge strategy]:mode:(all left right unique deep)' \
        '(-E --sets)'{-E+,--sets=}'[set merge strategy]:mode:(left right unique)' \
        '(-w --overwrite)'{-w+,--overwrite=}'[overwrite YAML Path with rhs]:path:' \
        '(-m --mergeat)'{-m+,--mergeat=}'[merge rhs at YAML Path]:path:' \
        '(-o --output)'{-o+,--output=}'[output to file (default STDOUT)]:file:_files' \
        '(-b --backup)'{-b,--backup}'[save backup .bak]' \
        '(-l --preserve-lhs-comments)'{-l,--preserve-lhs-comments}'[preserve lhs comments]' \
        '(-D --document-format)'{-D+,--document-format=}'[output document format]:fmt:(auto yaml json)' \
        '(-J --json-indent)'{-J+,--json-indent=}'[JSON output indent spaces]:n:' \
        '(-j --json-multi-doc)'{-j,--json-multi-doc}'[treat JSON as multi-document]' \
        '(-M --multi-doc-mode)'{-M+,--multi-doc-mode=}'[multi-doc handling]:mode:(condense_all merge_across matrix_merge)' \
        '(-S --nostdin)'{-S,--nostdin}'[do not implicitly read STDIN]' \
        '--frontmatter[parse Markdown frontmatter]' \
        '(-d --debug)'{-d,--debug}'[debug output]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
        '*:YAML file:_files -g "*.{yml,yaml,json}"'
}

_yaml-merge "$@"
