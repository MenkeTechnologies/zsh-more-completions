#compdef thedarkmod
# Documentation: https://wiki.thedarkmod.com/index.php?title=Command_Line_Arguments
# Reference accessed: 2026-05-16
# Verified by analogy: id Tech 3/4 family (TDM is built on id Tech 4) parses
# argv by joining args and splitting on '+'. Confirmed in iortcw SP/code/
# qcommon/common.c Com_ParseCommandLine (line 462) - same engine family.
# Each '+token' is appended to the console command buffer at startup.
# Removed from prior file: -h (no getopt-style help flag in id Tech engines;
# id Tech 4 only handles macOS -psn... and the +cmd cbuf tokens).

# The Dark Mod: stand-alone stealth game (id Tech 4 engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+disconnect[disconnect]' \
  '+condump[dump console to file]:file:_files' \
  '+vid_restart[restart video]' \
  '+quit[quit]' \
  '*::extra args:_files' && ret=0
return ret
