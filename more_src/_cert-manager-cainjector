#compdef cert-manager-cainjector
# Documentation: https://cert-manager.io/docs/cli/cainjector/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cert-manager-cainjector: CA injection controller (CRDs, webhooks, APIService)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[path to CAInjectorConfiguration file]:file:_files' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--namespace=[limit to a single namespace]:ns:' \
  '--enable-apiservices-injectable[inject CA into APIServices]' \
  '--enable-certificates-data-source[use Certificate CRDs as CA sources]' \
  '--enable-customresourcedefinitions-injectable[inject CA into CRDs]' \
  '--enable-mutatingwebhookconfigurations-injectable[inject CA into MutatingWebhookConfigurations]' \
  '--enable-validatingwebhookconfigurations-injectable[inject CA into ValidatingWebhookConfigurations]' \
  '--leader-elect[enable leader election]' \
  '--leader-election-namespace=[leader election namespace]:ns:' \
  '--leader-election-lease-duration=[lease duration]:duration:' \
  '--leader-election-renew-deadline=[renew deadline]:duration:' \
  '--leader-election-retry-period=[retry period]:duration:' \
  '--metrics-listen-address=[metrics endpoint address]:addr:' \
  '--metrics-tls-cert-file=[metrics TLS cert file]:file:_files' \
  '--metrics-tls-private-key-file=[metrics TLS key file]:file:_files' \
  '--metrics-tls-min-version=[metrics TLS min version]:version:' \
  '--metrics-tls-cipher-suites=[metrics cipher suites]:list:' \
  '--enable-profiling[enable controller profiling]' \
  '--profiler-address=[go profiler listen address]:addr:' \
  '--logging-format=[log format]:fmt:(text json)' \
  '--log-flush-frequency=[max seconds between log flushes]:duration:' \
  '(-v --v)'{-v+,--v=}'[log verbosity level]:n:' \
  '--vmodule=[file-filtered logging patterns]:patterns:' \
  '--feature-gates=[alpha/experimental feature toggles]:gates:' \
  '*::cert-manager-cainjector args:_files' && ret=0
return ret
