#compdef pt-upgrade
# Documentation: https://docs.percona.com/percona-toolkit/pt-upgrade.html
# Verify that query results are identical on different servers

local ret=1

_arguments -s -S \
  '(--help)--help[show help and exit]' \
  '(--version)--version[show version and exit]' \
  '--ask-pass[prompt for password when connecting to MySQL]' \
  '--buffer-stdout[enable STDOUT buffering]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '(-A --charset)'{-A,--charset=}'[set default character set]:charset' \
  '--config=[read this comma-separated list of config files]:files:_files' \
  '--continue-on-error[continue parsing after errors]' \
  '--no-continue-on-error[stop parsing on errors]' \
  '--create-upgrade-table[create upgrade table]' \
  '--no-create-upgrade-table[do not create upgrade table]' \
  '--daemonize[fork to background and detach from shell]' \
  '(-D --database)'{-D,--database=}'[default database when connecting]:database' \
  '(-F --defaults-file)'{-F,--defaults-file=}'[read MySQL options from specified file]:file:_files' \
  '--disable-query-cache[disable query cache]' \
  '--no-disable-query-cache[do not disable query cache]' \
  '--dry-run[run without executing or comparing queries]' \
  '--filter=[Perl code to allow/filter events]:code' \
  '(-h --host)'{-h,--host=}'[MySQL hostname or IP]:host:_hosts' \
  '--ignore-warnings=[ignore specified MySQL warning codes]:codes' \
  '--log=[print output to file when daemonized]:file:_files' \
  '--max-class-size=[max unique queries per class]:n' \
  '--max-examples=[max examples per difference type]:n' \
  '(-s --mysql_ssl)'{-s,--mysql_ssl=}'[create SSL MySQL connection]:value' \
  '(-p --password)'{-p,--password=}'[MySQL password]:password' \
  '--pid=[create PID file at specified path]:file:_files' \
  '(-P --port)'{-P,--port=}'[MySQL port number]:port' \
  '--progress=[print progress reports to STDERR]:spec' \
  '--read-only[execute only SELECT/SET statements]' \
  '--no-read-only[allow non read-only statements]' \
  '--report=[print specified report sections]:sections' \
  '--run-time=[duration to run before exiting]:time' \
  '--save-results=[save reference results to directory]:dir:_files -/' \
  '--set-vars=[set MySQL variables as comma-separated pairs]:vars' \
  '(-S --socket)'{-S,--socket=}'[socket file for connection]:socket:_files' \
  '--type=[log file type]:type:(slowlog genlog binlog tcpdump rawlog)' \
  '--upgrade-table=[table for clearing warnings]:table' \
  '(-u --user)'{-u,--user=}'[MySQL user for login]:user:_users' \
  '--version-check[check for latest versions]' \
  '--no-version-check[do not check for latest versions]' \
  '--watch-server=[parse events for specified IP:port]:server' \
  '*:log file:_files' && ret=0

return ret
