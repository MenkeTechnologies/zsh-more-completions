#compdef cargo-generate

_cargo-generate() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        '--git[Git repository to use as template]:url:' \
        '--branch[Branch to use from the git repository]:branch:' \
        '--tag[Tag to use from the git repository]:tag:' \
        '--path[Local path to use as template]:path:_directories' \
        '--subfolder[Subfolder within the template repository]:subfolder:' \
        {-n,--name}'[Name of the project to generate]:name:' \
        '--force[Force generation even if target directory exists]' \
        '--verbose[Enable verbose output]' \
        '--template-values-file[Path to a file with template values]:file:_files' \
        {-s,--silent}'[Suppress all output]' \
        '--list-favorites[List configured favorite templates]' \
        '--favorite[Use a configured favorite template]:favorite:' \
        {-d,--define}'[Define a template value]:key=value:' \
        '--init[Initialize in the current directory]' \
        '--destination[Destination directory for the generated project]:dir:_directories' \
        '--allow-commands[Allow running template-defined commands]' \
        '--overwrite[Overwrite existing files]' \
        '--skip-if-file-exists[Skip files that already exist]' \
        '--other-branch[Specify an alternative branch]:branch:' \
        '--vcs[Version control system to initialize]:vcs:(none git)' \
        '--lib[Generate a library project instead of binary]' \
        {-h,--help}'[Print help information]' \
        {-V,--version}'[Print version information]' && ret=0

    return ret
}

_cargo-generate "$@"
