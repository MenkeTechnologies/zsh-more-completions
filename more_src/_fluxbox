#compdef fluxbox
# Documentation: https://man.archlinux.org/man/fluxbox.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fluxbox - lightweight window manager

_arguments -s -S \
  '-display[X display name to use]:display:' \
  '-rc[alternate resource/init file]:rc file:_files' \
  '-no-slit[disable DockApp slit]' \
  '-no-toolbar[disable toolbar]' \
  '-log[log output to file]:log file:_files' \
  '-screen[run on screens (csv) or all]:screens:' \
  '(- *)'{-h,-help}'[show help and exit]' \
  '(- *)'{-v,-version}'[display version and exit]' \
  '(- *)'{-i,-info}'[display build info and exit]' \
  '-list-commands[list internal commands]' \
  '-sync[synchronize with X server for debugging]' \
  '-verbose[increase verbosity]'
