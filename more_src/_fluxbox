#compdef fluxbox

# Zsh completion for fluxbox - lightweight window manager

_arguments -s -S \
  '(-display)-display[use display as X display name]:display:' \
  '(-rc)-rc+[use alternate resource file]:rc file:_files' \
  '(-version)-version[display version and exit]' \
  '(-info)-info[display build info and exit]' \
  '(-log)-log+[log output to file]:log file:_files' \
  '(-screen)-screen+[run on specified screens only]:screens:' \
  '(-sync)-sync[synchronize with X server for debugging]' \
  '(-verbose)-verbose[increase verbosity]' \
  '(-help)-help[show help and exit]'
