_lean-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output]:file:_files -g "*.olean"' \
        '--output=+[file]:file:_files' \
        '--server[start LSP server]' \
        '--memory=+[MB]:n:' \
        '-M+[memory]:n:' \
        '--timeout=+[ms]:n:' \
        '-T+[timeout]:n:' \
        '--threads=+[N]:n:' \
        '-j+[threads]:n:' \
        '--trust=+[level]:n:' \
        '-t+[trust]:n:' \
        '--print[print options]' \
        '-p[print options]' \
        '--root=+[dir]:dir:_files -/' \
        '-r+[root]:dir:_files -/' \
        '--load-dynlib=+[name]:str:' \
        '*--load-dynlib=+[name]:str:' \
