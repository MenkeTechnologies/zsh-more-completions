#compdef faFrag
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# extract a piece of DNA from a .fa file

local ret=1

_arguments -s -S \
  '-mixed[preserve mixed-case in FASTA file]' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:start' \
  '3:end' \
  '4:out fa:_files' && ret=0

return ret
