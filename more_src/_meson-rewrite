#compdef meson-rewrite
# _meson-rewrite — Meson build system meson-rewrite source code rewriter CLI alias (Meson team, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-rewrite() {
    local -a sub=(
        'target:add/remove sources to a target'
        'kwargs:modify keyword arguments'
        'default-options:modify default options'
        'command:run rewriter commands from a file'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-s+[source dir]:dir:_files -/' \
        '--sourcedir=+[source dir]:dir:_files -/' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '--skip-errors[skip errors]' \
        '-S[skip errors]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meson-rewrite subcommand' sub ;;
        args)
            case $words[1] in
                target) _arguments \
                    '1:target-name:' \
                    '2:operation:(add rm add_target rm_target add_extra_files rm_extra_files info src_add src_rm)' \
                    '*:src:_files' ;;
                kwargs) _arguments \
                    '1:operation:(set delete add remove info)' \
                    '2:function:(target dependency project)' \
                    '*:arg:' ;;
                default-options) _arguments \
                    '1:operation:(set delete)' \
                    '*:key=value:' ;;
                command) _arguments '*:json-file:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_meson-rewrite "$@"
