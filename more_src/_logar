#compdef logar
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss87.html
# KAPPA: takes the logarithm to a specified base of each pixel of an NDF

local ret=1

_arguments -s \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'BASE=[base of the logarithm (or Natural)]:base' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
