#compdef bondtype
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools bondtype: assign AM1-BCC bond types from an ac or mol2 file

local ret=1

_arguments -s -S \
  '-i[input file name]:file:_files' \
  '-o[output file name]:file:_files' \
  '-f[input file format]:format:(ac mol2)' \
  '-j[judge bond type level]:level:(full part)' \
  '*:file:_files' && ret=0

return ret
