#compdef macptopbm
# Documentation: man macptopbm (Netpbm)
# Source: convert a MacPaint image to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-extraskip+[extra header bytes to skip]:N:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:macp file:_files -g "*.(mac|macp|pntg)"' \
    && ret=0

return ret
