#compdef lambroll
# Documentation: https://github.com/fujiwara/lambroll
# lambroll - minimal deployment tool for AWS Lambda functions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--option=[option file path]:file:_files' \
  '--function=[function file path]:file:_files' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--log-format=[log format]:format:(text json)' \
  '--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '--region=[AWS region]:region:' \
  '--profile=[AWS credential profile name]:profile:' \
  '--tfstate=[URL to terraform.tfstate]:url:' \
  '--prefixed-tfstate=[prefix template name to tfstate URL]:kv:' \
  '--endpoint=[AWS API Lambda endpoint]:url:' \
  '--envfile=[environment files]:file:_files' \
  '--ext-str=[external string values for Jsonnet]:kv:' \
  '--ext-code=[external code values for Jsonnet]:kv:' \
  '1:command:(deploy init list rollback invoke archive logs diff render status versions delete)' \
  '*::arg:->args' && ret=0

return ret
