#compdef MapRTTransformer
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: apply a retention time transformation to a data file

local ret=1

_arguments -s -S \
  '-in[input file to transform]:input file:_files' \
  '-out[output file]:output file:_files' \
  '-trafo_in[transformation file to apply (trafoXML)]:file:_files' \
  '-trafo_out[transformation output file (trafoXML)]:file:_files' \
  '-invert[invert transformation before applying]' \
  '-store_original_rt[keep original retention times as metadata]' \
  '-model:type[transformation model type]:type:(none linear b_spline lowess interpolated)' \
  '-model:linear:symmetric_regression[use symmetric regression]' \
  '-model:b_spline:wavelength[smoothing cutoff wavelength]:value:' \
  '-model:b_spline:num_nodes[number of spline nodes]:n:' \
  '-model:lowess:span[fraction of datapoints for regression]:value:' \
  '-model:lowess:num_iterations[robustifying iterations]:n:' \
  '-model:interpolated:interpolation_type[interpolation type]:type:(linear cspline akima)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
