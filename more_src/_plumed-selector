#compdef plumed-selector
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/selector.html
# PLUMED selector: generate lists of serial atom numbers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--pdb=[reference PDB file]:file:_files' \
  '*:args:' && ret=0

return ret
