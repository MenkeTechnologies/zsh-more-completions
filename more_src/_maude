#compdef maude
# Documentation: https://maude.cs.illinois.edu/w/index.php/The_Maude_System
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-no-prelude[do not load prelude.maude]' \
  '-no-banner[suppress banner]' \
  '-no-mixfix[disable mixfix display]' \
  '-no-wrap[disable line wrap]' \
  '-no-ansi-color[disable ansi color]' \
  '-no-tecla[disable tecla input]' \
  '-print-to-stderr[print output to stderr]' \
  '-random-seed=[seed]:n:' \
  '-show-pid[show process id]' \
  '-show-stats[show stats after rewriting]' \
  '-show-timing[show timing info]' \
  '-show-advisories[show advisories]' \
  '-show-loop-stats[show loop stats]' \
  '-allow-files[allow file commands]' \
  '-allow-processes[allow process commands]' \
  '-trust[trust prelude even without verification]' \
  '-batch[batch mode]' \
  '-erewrite-loop-mode[use erewrite for loop]' \
  '*:file:_files -g "*.{maude,fm}"' && ret=0

return ret
