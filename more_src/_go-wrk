#compdef go-wrk
# HTTP benchmarking tool written in Go

_arguments -s -S \
  '-H[add custom header]:header:' \
  '-M[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-T[content type]:type:' \
  '-body[request body]:body:' \
  '-c[number of concurrent connections]:connections:' \
  '-ca[TLS CA certificate file]:file:_files' \
  '-cert[TLS client certificate file]:file:_files' \
  '-d[duration of test]:duration:' \
  '-f[playback file]:file:_files' \
  '-help[show help]' \
  '-http[use HTTP/2]' \
  '-key[TLS client key file]:file:_files' \
  '-no-c[disable compression]' \
  '-no-ka[disable keep-alives]' \
  '-no-vr[skip TLS verification]' \
  '-redir[follow redirects]' \
  '-t[request timeout]:timeout:' \
  '*:url:' \
  && return 0
