#compdef xfinverse
# Documentation: https://bio3d.colorado.edu/imod/doc/man/xfinverse.html
# Compute inverse of transforms

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -InputFile)'{-input,-InputFile}'[File with transforms to be inverted. If this option is ]:file:_files' \
  '(-output -OutputFile)'{-output,-OutputFile}'[Output file for inverse transforms. If this option is n]:file:_files' \
  '(-zero -ZeroShifts)'{-zero,-ZeroShifts}'[Set shifts to zero when taking inverse of linear transf]' \
  '*:file:_files' && ret=0

return ret
