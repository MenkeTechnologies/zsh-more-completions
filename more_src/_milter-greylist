#compdef milter-greylist

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A[output sendmail access file]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-D[dump database and exit]' \
  '-f[do not fork]' \
  '-l+[log facility]:facility:(LOG_MAIL LOG_DAEMON LOG_LOCAL0 LOG_LOCAL1 LOG_LOCAL2 LOG_LOCAL3 LOG_LOCAL4 LOG_LOCAL5 LOG_LOCAL6 LOG_LOCAL7)' \
  '-p+[milter socket]:socket:_files' \
  '-q[quiet]' \
  '-r+[reload config]:flag:' \
  '-S[sync database now]' \
  '-T[test config and exit]' \
  '-u+[run as user]:user:_users' \
  '-v[verbose]' \
  '-w+[chroot dir]:dir:_files -/' && ret=0

return ret
