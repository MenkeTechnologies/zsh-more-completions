#compdef milter-greylist
# Documentation: https://manpages.debian.org/trixie/milter-greylist/milter-greylist.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-A[disable greylisting for SMTP AUTH senders]' \
  '-a+[automatic whitelisting delay]:delay:' \
  '-c[validate configuration file and exit]' \
  '-D[run in foreground (do not daemonize)]' \
  '-d+[greylist database dump file]:file:_files' \
  '-f+[configuration file]:file:_files' \
  '-L+[IPv4 matching mask]:mask:' \
  '-M+[IPv6 prefix length]:length:' \
  '-l[debug output in access-list code]' \
  '-P+[PID file]:file:_files' \
  '-p+[milter socket]:socket:_files' \
  '-q[quiet mode]' \
  '-r[show version and build environment]' \
  '-S[disable SPF-based greylisting bypass]' \
  '-T[test mode for recipient filtering]' \
  '-u+[drop privileges to user[:group]]:user:_users' \
  '-v[debug output to syslog]' \
  '-w+[minimum delay before accepting message]:delay:' && ret=0

return ret
