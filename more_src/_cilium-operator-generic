#compdef cilium-operator-generic
# Documentation: https://docs.cilium.io/en/stable/cmdref/cilium-operator-generic/
# Cilium operator for generic (non-cloud) IPAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for cilium-operator-generic]' \
  '(-D --debug)'{-D,--debug}'[enable debugging mode]' \
  '--version[print version information]' \
  '--config=[configuration file]:config:_files' \
  '--config-dir=[configuration directory]:dir:_files -/' \
  '--cluster-id=[unique identifier of the cluster]:id' \
  '--cluster-name=[name of the cluster]:name' \
  '--cluster-pool-ipv4-cidr=[IPv4 CIDR range for pods in cluster]:cidr' \
  '--cluster-pool-ipv4-mask-size=[mask size for each IPv4 podCIDR per node]:size' \
  '--cluster-pool-ipv6-cidr=[IPv6 CIDR range for pods in cluster]:cidr' \
  '--cluster-pool-ipv6-mask-size=[mask size for each IPv6 podCIDR per node]:size' \
  '--ipam=[backend to use for IPAM]:backend' \
  '--identity-allocation-mode=[method to use for identity allocation]:mode' \
  '--identity-gc-interval=[GC interval for security identities]:interval' \
  '--enable-ipv4[enable IPv4 support]' \
  '--enable-ipv6[enable IPv6 support]' \
  '--enable-k8s[enable the k8s clientset]' \
  '--enable-metrics[enable Prometheus metrics]' \
  '--enable-gateway-api-secrets-sync[enable fan-in TLS secrets sync]' \
  '--enable-ingress-controller[enable cilium ingress controller]' \
  '--enable-l7-proxy[enable L7 proxy for L7 policy enforcement]' \
  '--enable-lb-ipam[enable LB IPAM]' \
  '--k8s-kubeconfig-path=[absolute path of the kubernetes kubeconfig file]:path:_files' \
  '--k8s-namespace=[namespace in which Cilium Operator is deployed]:namespace' \
  '--kvstore=[key-value store type]:type' \
  '--kvstore-opt=[key-value store options]:opt' \
  '--nodes-gc-interval=[GC interval for CiliumNodes]:interval' \
  '--operator-prometheus-serve-addr=[address to serve Prometheus metrics]:addr' \
  '--operator-pprof[enable serving pprof debugging API]' \
  '--skip-crd-creation[do not create Kubernetes Custom Resource Definitions]' \
  '*::arg:_default' && ret=0

return ret
