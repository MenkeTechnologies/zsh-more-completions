#compdef ovsdb-tool
# Documentation: https://man.archlinux.org/search?q=ovsdb-tool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:create database'
  'create-cluster:initialize first server in HA cluster'
  'join-cluster:initialize subsequent cluster servers'
  'cluster-to-standalone:convert clustered DB to standalone'
  'convert:translate to different schema version'
  'needs-conversion:check if schema conversion needed'
  'db-version:print embedded DB schema version'
  'schema-version:print JSON schema version'
  'db-cksum:print embedded DB checksum'
  'schema-cksum:print JSON schema checksum'
  'compare-versions:compare schema versions'
  'compact:write compacted database'
  'query:execute read-only transaction'
  'transact:execute transaction and commit'
  'show-log:print transaction log summary'
  'check-cluster:verify cluster consistency'
  'db-name:print schema name'
  'schema-name:print JSON schema name'
  'db-cid:print cluster ID UUID'
  'db-sid:print server ID UUID'
  'db-local-address:print clustering address'
  'db-is-clustered:test if clustered'
  'db-is-standalone:test if standalone'
  'help:show help'
)

_arguments -C \
  '*'{-v,--verbose=}'[logging spec]:spec:' \
  '--log-file=[log file]:file:_files' \
  '--syslog-target=[syslog target]:host:port:' \
  '--syslog-method=[syslog method]:method:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovsdb-tool subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create-cluster)
        _arguments '--election-timer=[ms]:ms:' && ret=0
        ;;
      (join-cluster)
        _arguments '--cid=[cluster id]:uuid:' && ret=0
        ;;
      (query|transact)
        _arguments '--rbac-role=[RBAC role]:role:' && ret=0
        ;;
      (show-log)
        _arguments '*'{-m,--more}'[more verbose]' && ret=0
        ;;
    esac
    ;;
esac

return ret
