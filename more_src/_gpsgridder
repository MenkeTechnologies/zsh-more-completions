#compdef gpsgridder
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/geodesy/gpsgridder.html
# Source: GenericMappingTools/gmt supplements/geodesy — Green's function GPS velocity-field interpolation (elastic sheet).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-C+[SVD eigenvalue elimination approx]:opts:_default' \
    '-E+[eval spline at input + misfit stats]:opts:_default' \
    '-F+[radius constant to avoid r=0 singularity]:value:_default' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-L[retain planar trend (do not remove)]' \
    '-N+[ASCII output node coordinates file]:file:_files' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[Poisson ratio (default 0.5)]:nu:_default' \
    '-T+[mask grid limiting evaluation nodes]:file:_files' \
    '*-V[verbose (stackable)]' \
    '-W+[data uncertainties / weights]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
