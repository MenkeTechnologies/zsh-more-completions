#compdef puppet-filebucket
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/filebucket.md
# puppet filebucket - store and retrieve files in a filebucket

local ret=1

_arguments -s -S \
  '(-b --bucket)'{-b,--bucket}'+[local filebucket path overriding default]:path:_files -/' \
  '(-d --debug)'{-d,--debug}'[enable full debugging]' \
  '(-f --fromdate)'{-f,--fromdate}'+[(list) select bucket files from date]:date:' \
  '(-h --help)'{-h,--help}'[print help message]' \
  '(-l --local)'{-l,--local}'[use the local filebucket]' \
  '(-r --remote)'{-r,--remote}'[use a remote filebucket]' \
  '(-s --server)'{-s,--server}'+[server for file storage]:server:_hosts' \
  '--server_list=[comma-separated server list]:servers:' \
  '(-t --todate)'{-t,--todate}'+[(list) select bucket files until date]:date:' \
  '(-v --verbose)'{-v,--verbose}'[print extra information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:action:(backup get restore diff list)' \
  '*::file:_files' && ret=0

return ret
