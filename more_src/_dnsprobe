#compdef dnsprobe

local -a arguments

arguments=(
  '(-l --list)'{-l,--list}'=[file with list of domains]:file:_files'
  '(-d --domain)'{-d,--domain}'=[target domain]:domain:'
  '(-s --subdomain)'{-s,--subdomain}'=[file with list of subdomains]:file:_files'
  '(-r --resolver)'{-r,--resolver}'=[file with list of resolvers]:file:_files'
  '(-t --type)'{-t,--type}'=[DNS record type]:type:(A AAAA CNAME MX NS TXT SOA PTR SRV CAA)'
  '(-c --concurrency)'{-c,--concurrency}'=[number of concurrent requests]:number:'
  '(-o --output)'{-o,--output}'=[output file]:file:_files'
  '--raw[output raw response]'
  '--resp[output with response data]'
  '--resp-only[output only response data]'
  '(-f --format)'{-f,--format}'=[output format]:format:(json csv)'
  '--silent[suppress output]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '--version[show version]'
)

_arguments -s -S $arguments
