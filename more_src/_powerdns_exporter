#compdef powerdns_exporter
# Documentation: https://github.com/janeczku/powerdns_exporter
# Prometheus exporter for PowerDNS authoritative server and recursor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-listen-address=[address to listen on for web interface and telemetry]:address' \
  '-metric-path=[path under which to expose metrics]:path' \
  '-api-url=[base-URL of PowerDNS authoritative server/recursor API]:url' \
  '-api-key=[PowerDNS API key]:key' \
  '*:arg:_default' && ret=0

return ret
