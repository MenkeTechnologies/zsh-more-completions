#compdef dmeventd
# _dmeventd — Linux device-mapper dmeventd CLI device-mapper event monitoring daemon detecting LVM thin-pool full snapshot exhaustion mirror failure RAID failure raid-leg events through DSO plugins and triggering autoextend repair fallback actions (LVM team, C); getopt
# upstream: https://gitlab.com/lvmteam/lvm2

_dmeventd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[debug mode, do not fork]' \
        '-ddd[increase debug level]' \
        '-f[do not fork]' \
        '-l[log to stdout]' \
        '-R[skip exit if no monitored devs]' \
        '-e+[exit threshold]:n:' \
        '*:device:_files'
}

_dmeventd "$@"
