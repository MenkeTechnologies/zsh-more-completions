#compdef yubikey-personalization-gui
# Documentation: https://man.archlinux.org/search?q=yubikey-personalization-gui
# Reference accessed: 2026-05-16

# yubikey-personalization-gui: Qt tool to program YubiKey slots
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*::yubikey-personalization-gui args:_files' && ret=0
return ret
