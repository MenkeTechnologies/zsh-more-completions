#compdef pinout
# Documentation: https://gpiozero.readthedocs.io/en/stable/cli_pinout.html
# A GPIO Zero tool to output a Raspberry Pi pinout diagram

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-r --revision)'{-r,--revision}'=[Raspberry Pi board revision code to query]:revision:' \
  '(-c --color -m --monochrome)'{-c,--color}'[force colored output]' \
  '(-c --color -m --monochrome)'{-m,--monochrome}'[force monochrome output]' \
  '(-x --xyz)'{-x,--xyz}'[open pinout.xyz in the default web browser]' && ret=0

return ret
