# THE cogent CLI
#
# cogent is a Haskell-implemented compiler CLI
# built on System.Console.GetOpt.  Invocation:
#   cogent [OPTIONS] <SOURCE.cogent>
#
# Compilation stages (mutually-exclusive primary
# flags):
#   --parse                           parse only
#   -t, --typecheck                   typecheck
#                                     surface program
#   -d, --desugar                     desugar + re-
#                                     typecheck
#   --normal                          normalize core
#                                     + re-typecheck
#   --simplify                        simplify core
#                                     + re-typecheck
#   --mono                            monomorphise +
#                                     re-typecheck
#   -g, --code-gen                    generate C code
#   -i, --repl                        run Cogent REPL
#   --llvm                            use LLVM
#                                     backend
#                                     (experimental)
#   --docgent                         generate HTML
#                                     documentation
#
# AST dump targets:
#   --ast-parse / --ast-tc / --ast-desugar /
#   --ast-normal / --ast-simpl / --ast-mono /
#   --ast-c                           dump AST at
#                                     named stage
#
# Pretty-print targets:
#   --pretty-parse / -T --pretty-tc /
#   -D --pretty-desugar / --pretty-normal /
#   --pretty-simpl / --pretty-mono    pretty-print
#                                     at named stage
#
# Isabelle/HOL embedding targets:
#   --deep-desugar / --deep-normal /
#   --deep-mono                       deep embeddings
#   --shallow-desugar / --shallow-normal /
#   --shallow-mono / --shallow-desugar-tuples
#                                     shallow embeddings
#   --shallow-consts-desugar /
#   --shallow-consts-normal /
#   --shallow-consts-mono /
#   --shallow-consts-desugar-tuples
#                                     shallow consts only
#   --scorres-desugar / --scorres-normal /
#   --scorres-mono                    shallow-correspondence
#                                     proofs
#   --shallow-tuples-proof            shallow tuples proof
#   --normal-proof                    normalisation proof
#   --mono-proof                      monomorphisation proof
#   --ac-install                      AutoCorres install
#   --corres-setup / --corres-proof   c-refinement
#                                     setup + proof
#   --type-proof-normal /
#   --type-proof                      type-correctness proofs
#   --all-refine [COLLECTIVE]         complete refinement
#   --root                            Isabelle root file
#   --table-c-types /
#   --new-table-c-types               C type tables
#   --table-shallow                   shallow type table
#   --table-abs-func-mono /
#   --table-abs-type-mono             abstract tables
#   -G, --graph-gen                   graph-refine
#                                     graph
#
# Haskell embedding:
#   --hs-shallow-desugar              Haskell shallow
#                                     embedding
#   --hs-shallow-desugar-tuples       Haskell shallow
#                                     with tuples
#   --hs-ffi                          Haskell FFI
#                                     bindings (.hsc +
#                                     .hs)
#
# Collective commands (multi-target):
#   -C, --c-refinement                [COLL] all C
#                                     refinement files
#   -F, --functional-correctness      [COLL] all
#                                     functional
#                                     correctness files
#   -A, --all                         [COLL] generate
#                                     everything
#   -Q, --quickcheck                  [COLL]
#                                     QuickCheck
#                                     artifacts
#
# Output paths:
#   -o, --output-name <NAME>          base name for
#                                     output files
#   --proof-name <NAME>               Isabelle theory
#                                     file name
#   --abs-type-dir <PATH>             abstract type
#                                     definitions dir
#                                     (default ./)
#   --dist-dir <PATH>                 output files
#                                     directory
#                                     (default ./)
#   --fake-header-dir <PATH>          fake C header
#                                     files dir
#   -I, --include <PATH>              cogent include
#                                     search paths
#                                     (repeatable)
#   --root-dir <PATH>                 top-level
#                                     directory for
#                                     theory imports
#                                     (default ./)
#   --arch <ARCH>                     target
#                                     architecture:
#                                     arm32 (default)
#                                     | x86_64 | x86
#   --cust-ty-gen <FILE>              custom type
#                                     generation
#                                     config
#   --entry-funcs <FILE>              list of entry-
#                                     point function
#                                     names
#   --ext-types <FILE>                external type
#                                     names for C
#                                     parser
#   --infer-c-funcs <FILES>           infer abstract
#                                     function defs
#   --infer-c-types <FILES>           infer abstract
#                                     type defs
#   --isabelle-var-avoidance <FILE>   var names to
#                                     avoid
#   --name-cache <FILE>               name cache file
#   --proof-input-c <FILE>            input C file
#                                     for proofs
#   --prune-call-graph <FILE>         entry-point
#                                     definitions
#   --cogent-pp-args <ARGS>           Cogent
#                                     preprocessor
#                                     arguments
#   --cpp <PROG>                      C preprocessor
#                                     binary (default
#                                     cpp)
#   --cpp-args <ARGS>                 C preprocessor
#                                     arguments
#
# Debug dumps:
#   --ddump-smt                       verbose SMT
#                                     solving info
