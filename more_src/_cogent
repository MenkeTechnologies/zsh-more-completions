#
# OPTIONS (sourced directly from
# https://github.com/au-ts/cogent/blob/master/cogent/src/Cogent/Flags.hs):
#
# (~150 flags total; see categorical documentation
# above.  Run `cogent -h 4` for the complete list
# from the compiler itself.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cogent_archs
_cogent_archs=(
    'arm32:ARM 32-bit (default)'
    'x86_64:x86 64-bit'
    'x86:x86 32-bit'
)

local -a _cogent_word_sizes
_cogent_word_sizes=(
    '8:8-bit base word'
    '16:16-bit base word'
    '32:32-bit base word'
    '64:64-bit base word'
)

local -a _cogent_norm_forms
_cogent_norm_forms=(
    'anf:A-normal form (default)'
    'knf:K-normal form'
    'lnf:L-normal form'
)

_arguments -C \
    '(- *)'{-h,-?,--help}'+[show help (VERBOSITY=0..4)]:verbosity: ' \
    '(- *)'{-v,-V,--version}'[show version]' \
    '--parse[parse Cogent source]' \
    '(-t --typecheck)'{-t,--typecheck}'[typecheck surface program]' \
    '(-d --desugar)'{-d,--desugar}'[desugar + re-typecheck]' \
    '--normal[normalise core + re-typecheck]' \
    '--simplify[simplify core + re-typecheck]' \
    '--mono[monomorphise + re-typecheck]' \
    '(-g --code-gen)'{-g,--code-gen}'[generate C code]' \
    '(-i --repl)'{-i,--repl}'[run Cogent REPL]' \
    '--llvm[use experimental LLVM backend]' \
    '--docgent[generate HTML documentation]' \
    '--ast-parse[dump AST after parse]' \
    '--ast-tc[dump AST after typecheck]' \
    '--ast-desugar[dump AST after desugar]' \
    '--ast-normal[dump AST after normalise]' \
    '--ast-simpl[dump AST after simplify]' \
    '--ast-mono[dump AST after monomorphise]' \
    '--ast-c[parse + dump C antiquotation AST]' \
    '--pretty-parse[pretty-print after parse]' \
    '(-T --pretty-tc)'{-T,--pretty-tc}'[pretty-print after typecheck]' \
    '(-D --pretty-desugar)'{-D,--pretty-desugar}'[pretty-print after desugar]' \
    '--pretty-normal[pretty-print after normalise]' \
    '--pretty-simpl[pretty-print after simplify]' \
    '--pretty-mono[pretty-print after monomorphise]' \
    '--deep-desugar[Isabelle deep embedding (desugar)]' \
    '--deep-normal[Isabelle deep embedding (normal)]' \
    '--deep-mono[Isabelle deep embedding (mono)]' \
    '--shallow-desugar[Isabelle shallow embedding (desugar)]' \
    '--shallow-normal[Isabelle shallow embedding (normal)]' \
    '--shallow-mono[Isabelle shallow embedding (mono)]' \
    '--shallow-desugar-tuples[Isabelle shallow embedding with tuples]' \
    '--shallow-consts-desugar[Isabelle shallow consts only (desugar)]' \
    '--shallow-consts-normal[Isabelle shallow consts only (normal)]' \
    '--shallow-consts-mono[Isabelle shallow consts only (mono)]' \
    '--shallow-consts-desugar-tuples[Isabelle shallow consts only with tuples]' \
    '--scorres-desugar[shallow-correspondence proof (desugar)]' \
    '--scorres-normal[shallow-correspondence proof (normal)]' \
    '--scorres-mono[shallow-correspondence proof (mono)]' \
    '--shallow-tuples-proof[shallow tuples embedding proof]' \
    '--normal-proof[normalisation proof]' \
    '--mono-proof[monomorphisation proof]' \
    '--ac-install[AutoCorres install theory]' \
    '--corres-setup[c-refinement setup lemmas]' \
    '--corres-proof[c-refinement proof]' \
    '--type-proof-normal[type-correctness proof (normal)]' \
    '--type-proof[type-correctness proof (mono)]' \
    '--all-refine[COLLECTIVE: complete shallow-to-C refinement proof]' \
    '--root[Isabelle root file]' \
    '--table-c-types[Cogent/C type correspondence table]' \
    '--new-table-c-types[Cogent/C type table + Dargent accessors]' \
    '--table-shallow[shallow embedding type synonyms]' \
    '--table-abs-func-mono[monomorphised abstract functions]' \
    '--table-abs-type-mono[monomorphised abstract types]' \
    '(-G --graph-gen)'{-G,--graph-gen}'[graph-refine graph]' \
    '--hs-shallow-desugar[Haskell shallow embedding (desugar)]' \
    '--hs-shallow-desugar-tuples[Haskell shallow with tuples (desugar)]' \
    '--hs-ffi[Haskell FFI bindings (.hsc + .hs)]' \
    '(-C --c-refinement)'{-C,--c-refinement}'[COLLECTIVE: all C refinement proof files]' \
    '(-F --functional-correctness)'{-F,--functional-correctness}'[COLLECTIVE: all functional correctness files]' \
    '(-A --all)'{-A,--all}'[COLLECTIVE: generate everything]' \
    '(-Q --quickcheck)'{-Q,--quickcheck}'[COLLECTIVE: QuickCheck artifacts]' \
    '(-o --output-name)'{-o,--output-name}'=[output base name]:name: ' \
    '--proof-name=[Isabelle theory file name]:name: ' \
    '--abs-type-dir=[abstract type definitions dir]:dir:_directories' \
    '--dist-dir=[output files directory]:dir:_directories' \
    '--fake-header-dir=[fake C header files dir]:dir:_directories' \
    '*'{-I,--include}'=[Cogent include search path]:dir:_directories' \
    '--root-dir=[top-level dir for theory imports]:dir:_directories' \
    '--arch=[target architecture]:arch:->arch' \
    '--cust-ty-gen=[custom type generation config]:file:_files' \
    '--entry-funcs=[entry-point function names list]:file:_files' \
    '--ext-types=[external type names for C parser]:file:_files' \
    '--infer-c-funcs=[infer abstract function definitions]:files: ' \
    '--infer-c-types=[infer abstract type definitions]:files: ' \
    '--isabelle-var-avoidance=[Isabelle variable names to avoid]:file:_files' \
    '--name-cache=[name cache file]:file:_files' \
    '--proof-input-c=[input C file for proofs]:file:_files -g "*.(c|h)"' \
    '--prune-call-graph=[Cogent entry-point definitions]:file:_files' \
    '--cogent-pp-args=[Cogent preprocessor arguments]:args: ' \
    '--cpp=[C preprocessor binary (default cpp)]:program: ' \
    '--cpp-args=[C preprocessor arguments]:args: ' \
    '--ddump-smt[verbose SMT-solving info]' \
    '--ddump-tc[typechecking internals]' \
    '--ddump-tc-ctx[typechecking with context]' \
    '--ddump-tc-filter=[filtered dump keywords: gen|sol|post|tc]:keywords: ' \
    '--ddump-to-file=[dump output to file]:file:_files' \
    '--ddump-pretty-ds-no-tc[desugared expr before typecheck]' \
    '--ddump-pretty-normal-no-tc[normalised expr before typecheck]' \
    '--type-proof-timing[log type proof timings to ~/TypeProofTacticTiming.json]' \
    '--fcheck-undefined[check undefined behaviours in C (default)]' \
    '--fno-check-undefined[reverse of --fcheck-undefined]' \
    '--fdargent-word-size=[Dargent base word size]:size:->wordsize' \
    '(-B --fdisambiguate-pp)'{-B,--fdisambiguate-pp}'[internal repr as comments in pretty-print]' \
    '--fffi-c-functions[generate FFI C functions (use with -Q)]' \
    '--fflatten-nestings[flatten nested structs]' \
    '--fno-flatten-nestings[reverse of --fflatten-nestings]' \
    '--ffncall-as-macro[generate macros instead of function calls]' \
    '--fno-fncall-as-macro[reverse of --ffncall-as-macro]' \
    '--ffull-src-path[full path for source file locations]' \
    '--ffunc-purity-attr[generate GCC purity attributes (default)]' \
    '--fno-func-purity-attr[reverse of --ffunc-purity-attr]' \
    '--fgen-header[generate build info header in output]' \
    '--fno-gen-header[no build info header (default)]' \
    '--fintermediate-vars[intermediate variables (default)]' \
    '--fno-intermediate-vars[reverse of --fintermediate-vars]' \
    '--flax-take-put[allow take/put on abstract types]' \
    '--fno-lax-take-put[no lax take/put (default)]' \
    '--flet-in-if[binding inside if-clause (default)]' \
    '--fno-let-in-if[reverse of --flet-in-if]' \
    '--fletbang-in-if[binding inside if-clause for let! (default)]' \
    '--fno-letbang-in-if[reverse of --fletbang-in-if]' \
    '--fml-typing-tree[ML typing tree in type proofs (default)]' \
    '--fno-ml-typing-tree[reverse of --fml-typing-tree]' \
    '--fnormalisation+[normalise core language]:NF:->normform' \
    '--fno-normalisation[reverse of --fnormalisation]' \
    '--fpragmas[respect pragmas]' \
    '--fno-pragmas[ignore pragmas]' \
    '--fpretty-errmsgs[pretty error messages]' \
    '--fno-pretty-errmsgs[plain error messages]' \
    '--freverse-tc-errors[reverse typecheck error order]' \
    '--fno-reverse-tc-errors[default typecheck error order]' \
    '--fshare-linear-vars[share linear variables]' \
    '--fno-share-linear-vars[no sharing (default)]' \
    '--fsimplifier[use simplifier]' \
    '--fno-simplifier[no simplifier (default)]' \
    '--fstatic-inline[static inline C functions]' \
    '--fno-static-inline[no static inline]' \
    '--ftuples-as-sugar[tuples as syntactic sugar]' \
    '--fno-tuples-as-sugar[tuples not as sugar]' \
    '--funion-for-variants[C union for variants]' \
    '--fno-union-for-variants[no union for variants (default)]' \
    '--build-info[log invocation in build_info file]' \
    '--libgum-dir[print libgum install directory]' \
    '--stack-usage=[parse gcc stack-usage .su file]:file:_files -g "*.su"' \
    '*:Cogent source file:_files -g "*.cogent"' \
    && ret=0

case $state in
    arch)
        _describe -t archs 'target architecture' _cogent_archs && ret=0
        ;;
    wordsize)
        _describe -t wordsizes 'Dargent word size' _cogent_word_sizes && ret=0
        ;;
    normform)
        _describe -t normforms 'normal form' _cogent_norm_forms && ret=0
        ;;
esac

return ret
