#compdef nixfmt

# Zsh completion for nixfmt - Nix code formatter

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verify)'{-v,--verify}'[verify output is correct]' \
  '(-c --check)'{-c,--check}'[check whether files are formatted]' \
  '(-q --quiet)'{-q,--quiet}'[do not report errors]' \
  '(-w --width)'{-w,--width}'=[max line width]:width' \
  '--strict[enable strict mode]' \
  '(-o --output)'{-o,--output}'=[output file (default stdout)]:file:_files' \
  '*:file:_files -g "*.nix"' \
  && return 0
