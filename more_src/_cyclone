#compdef cyclone icyc
# Documentation: https://github.com/justinethier/cyclone
# Reference accessed: 2026-05-17
# Verified: justinethier/cyclone Cyclone Scheme upstream (Cyclone is
# the compiler, icyc is the interactive REPL). Not the Caicloud
# workflow engine or CycloneDX SBOM tool.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

case $service in
  (cyclone)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-v[show version]' \
      '-vn[show versioning info]' \
      '-d[generate intermediate C only]' \
      '-c[compile to object only]' \
      '-co[compile only no link]' \
      '-t[generate trace info]' \
      '-A+[append library directory]:dir:_files -/' \
      '-I+[prepend include directory]:dir:_files -/' \
      '-CP+[C preprocessor flags]:flags:' \
      '-CC+[C compiler flags]:flags:' \
      '-CE+[linker flags]:flags:' \
      '-COPT+[CC option]:opt:' \
      '-CLNK+[linker option]:opt:' \
      '-CLNK-LIB+[linker library]:lib:' \
      '-CIPRE+[C include prefix]:prefix:' \
      '-Cm+[C macro define]:macro:' \
      '-O+[optimization level]:lvl:(0 1 2)' \
      '-batch[batch mode]' \
      '-no-batch[interactive mode]' \
      '-use-unsafe-prims[unsafe primitives]' \
      '-justc[generate C only]' \
      '*: :_files -g "*.scm *.sld"' && ret=0 ;;
  (icyc)
    _arguments -C \
      '-h[show help]' \
      '-v[show version]' \
      '-i+[init file]:file:_files -g "*.scm"' \
      '-s+[script file]:file:_files -g "*.scm"' \
      '-p+[evaluate and print]:expr:' \
      '-e+[evaluate]:expr:' \
      '-A+[append library dir]:dir:_files -/' \
      '-I+[prepend library dir]:dir:_files -/' \
      '*: :_files -g "*.scm *.sld"' && ret=0 ;;
esac

return ret
