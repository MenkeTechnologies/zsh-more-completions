#compdef arm-none-eabi-ranlib
# _arm-none-eabi-ranlib — Arm Limited arm-none-eabi-ranlib CLI for the bare-metal ARM cross-ranlib generating an index of symbols in a static-library archive to speed linking equivalent to ar -s deterministic mode (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-ranlib() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-D[deterministic mode]' \
        '-U[non-deterministic mode]' \
        '-t[touch and update timestamp]' \
        '*:archive:_files -g "*.a"'
}

_arm-none-eabi-ranlib "$@"
