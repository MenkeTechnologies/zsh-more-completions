#compdef kubectl-konfig
# kubectl-konfig (krew plugin): manage and merge kubeconfig files
# https://github.com/corneliusweig/konfig

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'import:import a kubeconfig file'
      'merge:merge multiple kubeconfig files'
      'split:split contexts into separate kubeconfig files'
      'delete:delete a context from kubeconfig'
      'clean:remove duplicates from kubeconfig'
    )
    _describe -t commands 'konfig command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--kubeconfig=[kubeconfig file]:file:_files' \
      '--context=[kubernetes context]:context' \
      '*:kubeconfig files:_files' && ret=0
    ;;
esac

return ret
