#compdef colmap
# Documentation: https://colmap.github.io/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'help:list available commands'
      'gui:launch the graphical user interface'
      'automatic_reconstructor:end-to-end sparse and dense reconstruction'
      'project_generator:generate a project file'
      'feature_extractor:extract features from images'
      'feature_importer:import features from a text file'
      'exhaustive_matcher:perform exhaustive feature matching'
      'sequential_matcher:perform sequential feature matching'
      'spatial_matcher:perform spatial feature matching'
      'transitive_matcher:perform transitive feature matching'
      'vocab_tree_matcher:perform vocabulary tree feature matching'
      'matches_importer:import matches from a text file'
      'mapper:sparse 3D reconstruction via Structure-from-Motion'
      'hierarchical_mapper:hierarchical sparse reconstruction'
      'global_mapper:global sparse reconstruction'
      'image_undistorter:undistort images for dense reconstruction'
      'image_undistorter_standalone:undistort a single image'
      'image_rectifier:rectify stereo images'
      'image_filterer:filter images from a model'
      'image_deleter:delete images from a model'
      'patch_match_stereo:dense Multi-View Stereo reconstruction'
      'stereo_fusion:fuse stereo results into a point cloud'
      'poisson_mesher:Poisson surface reconstruction mesher'
      'delaunay_mesher:Delaunay triangulation mesher'
      'mesh_simplifier:simplify mesh'
      'mesh_texturer:texture mesh'
      'database_creator:create a new COLMAP database'
      'database_cleaner:clean a COLMAP database'
      'database_merger:merge two COLMAP databases'
      'model_aligner:align two models'
      'model_analyzer:print model statistics'
      'model_comparer:compare two models'
      'model_converter:convert model formats'
      'model_cropper:crop a model'
      'model_merger:merge two models'
      'model_orientation_aligner:align model orientation'
      'model_splitter:split a model'
      'model_transformer:apply transformation to a model'
      'point_filtering:filter points in a model'
      'point_triangulator:triangulate 3D points'
      'rig_configurator:configure a rig'
      'bundle_adjuster:run bundle adjustment'
      'color_extractor:extract colors for 3D points'
    )
    _describe -t commands 'colmap command' commands && ret=0
    ;;
  (args)
    _arguments \
      '*:file:_files' && ret=0
    ;;
esac

return ret
