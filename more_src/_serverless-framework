#compdef serverless-framework
# _serverless-framework — Serverless Inc. Serverless Framework for AWS Lambda/Azure Functions/GCP CLI alias (serverless team, JavaScript); custom argparse
# upstream: https://github.com/serverless/serverless

_serverless-framework() {
    local -a sub=(
        'create:create service from template'
        'deploy:deploy service'
        'deploy function:deploy single function'
        'deploy list:list deployments'
        'deploy list functions:list deployed functions'
        'doctor:diagnose'
        'help:show help'
        'info:show service info'
        'install:install service'
        'invoke:invoke function'
        'invoke local:invoke function locally'
        'logs:show logs'
        'metrics:show metrics'
        'package:package service'
        'plugin install:install plugin'
        'plugin list:list plugins'
        'plugin search:search plugins'
        'plugin uninstall:uninstall plugin'
        'print:print resolved config'
        'remove:remove service'
        'rollback:rollback deployment'
        'rollback function:rollback function'
        'slstats:opt-in/out telemetry'
        'support:get support'
        'test:run tests'
        'login:login'
        'logout:logout'
        'config credentials:configure credentials'
        'config tabcompletion:setup tab completion'
        'config tabcompletion install:install tab completion'
        'config tabcompletion uninstall:uninstall tab completion'
        'output get:get output value'
        'output list:list outputs'
        'param get:get param'
        'param list:list params'
        'state list:list state'
        'state get:get state'
        'compose:run compose commands'
        'dashboard:open dashboard'
        'console:open console'
        'org list:list orgs'
        'app list:list apps'
        'stage list:list stages'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '--debug=+[debug name]:str:' \
        '--config=+[config file]:file:_files -g "serverless.{yml,yaml,json,js,ts}"' \
        '-c+[config file]:file:_files -g "serverless.{yml,yaml,json,js,ts}"' \
        '--stage=+[stage]:str:' \
        '-s+[stage]:str:' \
        '--region=+[region]:str:' \
        '-r+[region]:str:' \
        '--app=+[app]:str:' \
        '--org=+[org]:str:' \
        '--use-local-credentials[use local credentials]' \
        '--aws-profile=+[profile]:str:' \
        '--aws-s3-accelerate[s3 accelerate]' \
        '--no-aws-s3-accelerate[no s3 accelerate]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'serverless subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '--template-url=+[url]:url:_urls' \
                    '-u+[url]:url:_urls' \
                    '--template-path=+[path]:dir:_files -/' \
                    '--path=+[dir]:dir:_files -/' \
                    '-p+[dir]:dir:_files -/' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' ;;
                deploy) _arguments \
                    '--package=+[dir]:dir:_files -/' \
                    '-p+[dir]:dir:_files -/' \
                    '--force[force]' \
                    '-f[force]' \
                    '--no-confirm-changeset[no confirm]' \
                    '--update-config[update config only]' \
                    '--function=+[function]:str:' \
                    '--enforce-hash-update[enforce hash update]' ;;
                invoke) _arguments \
                    '--function=+[function]:str:' \
                    '-f+[function]:str:' \
                    '--data=+[json]:str:' \
                    '-d+[json]:str:' \
                    '--path=+[json file]:file:_files' \
                    '-p+[json file]:file:_files' \
                    '--type=+[type]:t:(RequestResponse Event DryRun)' \
                    '-t+[type]:t:(RequestResponse Event DryRun)' \
                    '--log[show log]' \
                    '-l[show log]' \
                    '--qualifier=+[qualifier]:str:' \
                    '-q+[qualifier]:str:' \
                    '--context=+[context name]:str:' \
                    '--contextPath=+[context file]:file:_files' \
                    '--env=+[env vars]:str:' \
                    '-e+[env vars]:str:' \
                    '--docker[run in docker (local)]' ;;
                logs) _arguments \
                    '--function=+[function]:str:' \
                    '-f+[function]:str:' \
                    '--tail[tail]' \
                    '-t[tail]' \
                    '--startTime=+[time]:str:' \
                    '--filter=+[filter pattern]:str:' \
                    '--interval=+[ms]:n:' \
                    '-i+[ms]:n:' ;;
                package) _arguments \
                    '--package=+[output dir]:dir:_files -/' \
                    '-p+[output dir]:dir:_files -/' ;;
                remove) ;;
                config) _arguments \
                    '1:subcmd:(credentials tabcompletion)' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_serverless-framework "$@"
