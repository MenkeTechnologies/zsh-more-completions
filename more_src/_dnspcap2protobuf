#compdef dnspcap2protobuf
# Documentation: https://doc.powerdns.com/authoritative/manpages/dnspcap2protobuf.1.html
# Convert DNS queries and responses from PCAP into PowerDNS protobuf format

local ret=1

_arguments -s -S \
  '--help[show a summary of options]' \
  '--version[show the version number]' \
  '1:pcapfile:_files' \
  '2:outfile:_files' && ret=0

return ret
