#compdef disown
# Documentation: man zshbuiltins (zsh)
# Source: zsh — remove jobs from the job table.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-a[disown all jobs]' \
    '*-h[mark jobs to not receive SIGHUP on shell exit]' \
    '*-r[disown only running jobs]' \
    '*:job:_jobs' \
    && ret=0

return ret
