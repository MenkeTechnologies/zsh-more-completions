#compdef ampctl
# Hamlib amplifier control program

local ret=1

_arguments -s -S \
  '-m[specify amplifier model]:model:' \
  '-r[specify serial port]:port:_files' \
  '-s[specify serial speed]:speed:(1200 2400 4800 9600 19200 38400 57600 115200)' \
  '-C[set configuration parameter]:param=value:' \
  '-L[show available configuration parameters]' \
  '-l[list amplifier models]' \
  '-u[dump capabilities]' \
  '-v[verbose mode]' \
  '-Z[suppress Rx frequency]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
