#compdef vt2geojson
# Documentation: https://github.com/mapbox/vt2geojson
# Dump vector tiles to GeoJSON from a URI, file, or stdin

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --layer)'{-l,--layer}'+[include only the specified layer]:layer' \
  '-x+[tile x coordinate (normally inferred from the URI)]:x' \
  '-y+[tile y coordinate (normally inferred from the URI)]:y' \
  '-z+[tile z coordinate (normally inferred from the URI)]:z' \
  '*:URI or file:_files' && ret=0

return ret
