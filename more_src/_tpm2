#compdef tpm2
# _tpm2 — tpm2-software tpm2 single-dispatch wrapper for tpm2-tools per-command binaries via tcti-device or tcti-mssim (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2() {
    local -a sub=(
        'activatecredential:activate a credential'
        'certify:certify a key'
        'changeauth:change object auth'
        'changeeps:change eps'
        'changepps:change pps'
        'checkquote:check a quote'
        'clear:reset TPM'
        'clearcontrol:control clear'
        'clockrateadjust:adjust clock rate'
        'commit:commit ECDAA'
        'create:create child object'
        'createak:create attestation key'
        'createek:create endorsement key'
        'createpolicy:create policy'
        'createprimary:create primary object'
        'dictionarylockout:dictionary lockout'
        'duplicate:duplicate object'
        'ecephemeral:ec ephemeral'
        'encryptdecrypt:encrypt decrypt'
        'eventlog:show eventlog'
        'evictcontrol:evict control'
        'flushcontext:flush context'
        'getcap:get capability'
        'gettestresult:get test result'
        'gettime:get time'
        'getekcertificate:get EK certificate'
        'getrandom:get random bytes'
        'getsessionauditdigest:get session audit digest'
        'getcommandauditdigest:get command audit digest'
        'hash:hash data'
        'hierarchycontrol:hierarchy control'
        'hmac:hmac'
        'import:import object'
        'incrementalselftest:incremental self-test'
        'load:load object'
        'loadexternal:load external'
        'makecredential:make credential'
        'nvdefine:nv define space'
        'nvextend:nv extend'
        'nvincrement:nv increment'
        'nvread:nv read'
        'nvreadlock:nv read lock'
        'nvreadpublic:nv read public'
        'nvsetbits:nv set bits'
        'nvundefine:nv undefine'
        'nvwrite:nv write'
        'nvwritelock:nv write lock'
        'pcrallocate:pcr allocate'
        'pcrevent:pcr event'
        'pcrextend:pcr extend'
        'pcrread:pcr read'
        'pcrreset:pcr reset'
        'policyauthorize:policy authorize'
        'policyauthorizenv:policy authorize nv'
        'policycommandcode:policy command code'
        'policyduplicationselect:policy duplication select'
        'policycountertimer:policy counter timer'
        'policycphash:policy cp hash'
        'policylocality:policy locality'
        'policynamehash:policy name hash'
        'policynv:policy nv'
        'policynvwritten:policy nv written'
        'policyor:policy or'
        'policypassword:policy password'
        'policypcr:policy pcr'
        'policyrestart:policy restart'
        'policysecret:policy secret'
        'policysigned:policy signed'
        'policytemplate:policy template'
        'policyticket:policy ticket'
        'print:print parsed data'
        'quote:quote PCRs'
        'rsadecrypt:rsa decrypt'
        'rsaencrypt:rsa encrypt'
        'selftest:self test'
        'send:send raw bytes'
        'shutdown:shutdown TPM'
        'sign:sign data'
        'startauthsession:start auth session'
        'startup:startup TPM'
        'stirrandom:stir random'
        'testparms:test parameters'
        'unseal:unseal data'
        'verifysignature:verify signature'
        'zgen2phase:zgen2phase'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-T+[TCTI string]:str:' \
        '--tcti=+[TCTI string]:str:' \
        '-Z[enable abrmd]' \
        '--enable-errata[enable errata]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tpm2 subcommand' sub ;;
    esac
}

_tpm2 "$@"
