#compdef supertux supertux2
# Documentation: https://github.com/SuperTux/supertux/blob/master/src/supertux/main.cpp
# Reference accessed: 2026-05-16
# Verified: upstream SuperTux/supertux src/supertux/main.cpp parse_arguments().
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated short -a/--aspect form (real flag is --aspect WxH, no short).

# supertux/supertux2: SuperTux platformer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbose[print verbose info]' \
  '--debug[print extra debug info]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[run in fullscreen mode]' \
  '(-w --window)'{-w,--window}'[run in window mode]' \
  '(-g --geometry)'{-g+,--geometry=}'[window geometry WxH]:WxH:' \
  '(-a --aspect)'{-a+,--aspect=}'[aspect ratio W:H]:W:H:' \
  '(-d --default)'{-d,--default}'[reset video settings to defaults]' \
  '--renderer[select renderer]:renderer:(sdl opengl opengl33 opengles2)' \
  '--disable-sfx[disable sound effects]' \
  '--disable-music[disable music]' \
  '--play-demo[play demo file]:file:_files' \
  '--record-demo[record demo to file]:file:_files' \
  '--spawn-pos[spawn position X,Y]:X,Y:' \
  '--sector[start in sector]:sector:' \
  '--debug-scripts[enable script debugger]' \
  '--print-datadir[print data directory]' \
  '--editor[open level editor]' \
  '--resave[resave level/world]' \
  '-s[run server (Christmas edition)]' \
  '-n[disable intro/menu]' \
  '--show-fps[display framerate]' \
  '--no-show-fps[hide framerate]' \
  '--show-pos[show object positions]' \
  '--no-show-pos[hide object positions]' \
  '--developer[run in developer mode]' \
  '--christmas[Christmas mode]' \
  '--no-christmas[disable Christmas mode]' \
  '(-D --datadir)'{-D+,--datadir=}'[set datadir]:dir:_files -/' \
  '(-u --userdir)'{-u+,--userdir=}'[set userdir]:dir:_files -/' \
  '*:level:_files -g "*.(stl|stwm|stws|nfo)(-.)"' && ret=0
return ret
