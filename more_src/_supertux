#compdef supertux supertux2

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-w --window)'{-w,--window}'[windowed]' \
  '(-g --geometry)'{-g,--geometry}'+[WxH]:geom:' \
  '(-a --aspect)'{-a,--aspect}'+[aspect WxH]:aspect:' \
  '(-d --default)'{-d,--default}'[default settings]' \
  '(-D --datadir)'{-D,--datadir}'+[data dir]:dir:_files -/' \
  '(--userdir)--userdir=+[user dir]:dir:_files -/' \
  '(--debug)--debug[debug]' \
  '(--debug-scripts)--debug-scripts[debug scripts]' \
  '(--debug-sound)--debug-sound[debug sound]' \
  '(--no-audio)--no-audio[no audio]' \
  '(--disable-sfx)--disable-sfx[disable sfx]' \
  '(--disable-music)--disable-music[disable music]' \
  '(--show-fps)--show-fps[show fps]' \
  '(--no-show-fps)--no-show-fps[no fps]' \
  '(--print-datadir)--print-datadir[print data dir]' \
  '(--editor)--editor[run editor]' \
  '*:level:_files -g "*.stl"' && ret=0

return ret
