#compdef supertux supertux2
# Documentation: https://github.com/SuperTux/supertux/blob/master/src/supertux/main.cpp
# Reference accessed: 2026-05-21
# Verified: upstream SuperTux/supertux main.cpp CommandLineArguments parsing.

# supertux/supertux2: SuperTux platformer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--datadir=[set data directory]:dir:_files -/' \
  '--userdir=[set user directory]:dir:_files -/' \
  '--print-datadir[print data directory]' \
  '--acknowledgements[print acknowledgements]' \
  '--editor[launch the level editor]' \
  '--resave[resave level/world files]' \
  '--sector=[start in sector]:sector:' \
  '--spawnpoint=[set spawnpoint]:spawnpoint:' \
  '--video=[select video system]:video:' \
  '--log-level=[set logging verbosity]:level:' \
  '--log-tinygettext[enable tinygettext logging]' \
  '*:level:_files -g "*.(stl|stwm|stws|nfo)(-.)"' && ret=0
return ret
