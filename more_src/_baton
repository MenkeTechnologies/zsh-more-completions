#compdef baton
# Documentation: https://github.com/americanexpress/baton
# HTTP load testing tool written in Go

local ret=1

_arguments -s -S \
  '-u[URL to run against]:url:' \
  '-c[number of concurrent requests]:count:' \
  '-r[number of requests (use instead of -t)]:count:' \
  '-t[duration of testing in seconds (use instead of -r)]:seconds:' \
  '-m[HTTP method (GET, POST, PUT, DELETE)]:method:(GET POST PUT DELETE)' \
  '-b[body (use instead of -f)]:body:' \
  '-f[file path used as the request body (use instead of -b)]:file:_files' \
  '-z[read requests from a file]:file:_files' \
  '-i[ignore TLS/SSL certificate validation]' \
  '-o[suppress output, no results printed to stdout]' \
  '-w[number of seconds to wait before running test]:seconds:' && ret=0

return ret
