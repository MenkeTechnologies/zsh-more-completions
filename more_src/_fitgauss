#compdef fitgauss
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Fit up to six Gauss profiles to a one-dimensional spectrum

local ret=1

_arguments -s -S \
  'IN=[input one-dimensional NDF]:in:_files' \
  'DEVICE=[plot device]:device:' \
  'INFO=[issue informational messages]:info:(TRUE FALSE)' \
  'VARUSE=[use input variances]:varuse:(TRUE FALSE)' \
  'DIALOG=[offer more interactive options]:dialog:(TRUE FALSE)' \
  'REPAIR=[change the spectroscopic number axis]:repair:(TRUE FALSE)' \
  'MASK1=[lower bounds of mask intervals]:mask1:' \
  'MASK2=[upper bounds of mask intervals]:mask2:' \
  'NCOMP=[number of Gauss profiles to fit]:ncomp:(1 2 3 4 5 6)' \
  'CONT=[continuum level value]:cont:' \
  'CENTRE=[guess centre position per component]:centre:' \
  'PEAK=[guess peak height per component]:peak:' \
  'FWHM=[guess full width at half maximum per component]:fwhm:' \
  'CF=[centre free/fixed/tied flag per component]:cf:' \
  'PF=[peak free/fixed/tied flag per component]:pf:' \
  'WF=[FWHM free/fixed/tied flag per component]:wf:' \
  'REMASK=[improve the mask again]:remask:(YES NO)' \
  'REGUESS=[improve the guess and fit again]:reguess:(YES NO)' \
  'FITGOOD=[store result in Specdre Extension]:fitgood:(YES NO)' \
  'COMP=[component numbers being fitted]:comp:' \
  'LOGFIL=[log file name]:logfil:_files' \
  'FCENTRE=[fitted centre position per component]:fcentre:' \
  'FPEAK=[fitted peak height per component]:fpeak:' \
  'FFWHM=[fitted FWHM per component]:ffwhm:' \
  '*:NDF data file:_files' && ret=0

return ret
