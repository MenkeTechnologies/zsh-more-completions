#compdef gasnetrun_ibv
# Documentation: https://gasnet.lbl.gov/dist-ex/ibv-conduit/README
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gasnetrun_ibv: GASNet job launcher (InfiniBand ibverbs)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-n[number of processes]:n:' \
  '-np[number of processes]:n:' \
  '-N[nodes]:n:' \
  '-h[hostfile]:file:_files' \
  '-hostfile[hostfile]:file:_files' \
  '-E[export env var]:var:' \
  '-v[verbose]' \
  '-keep-env[keep environment]' \
  '-spawn[spawner: ssh/mpi/pmi/etc.]:spawner:(ssh mpi pmi)' \
  '-debug-rank[debug attach for rank]:rank:' \
  '-debug-prog[debugger program]:prog:_files' \
  '*:command:_command_names' && ret=0
return ret
