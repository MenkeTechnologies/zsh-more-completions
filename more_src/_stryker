#compdef stryker
# Documentation: https://stryker-mutator.io/docs/stryker-js/configuration/
# Reference accessed: 2026-05-21
# Verified: stryker-mutator.io configuration reference for stryker-js
# (the official CLI). Subcommands (run, init, help) plus every
# documented config-driven flag are listed below.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run mutation tests'
  'init:scaffold a stryker.config file'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-m+,--mutate=}'[glob to mutate (repeatable)]:glob:' \
  '--reporters=[reporters (comma-separated)]:reporters:(progress html json clear-text dashboard event-recorder)' \
  '--testRunner=[test runner]:runner:(command jest mocha karma jasmine vitest cucumber tap)' \
  '*--testFiles=[limit which test files execute]:file:_files' \
  '--coverageAnalysis=[coverage analysis mode]:mode:(off all perTest)' \
  '--concurrency=[number of concurrent test runners]:n:' \
  '--maxTestRunnerReuse=[max reuse before respawn]:n:' \
  '--timeoutMS=[timeout per test in ms]:ms:' \
  '--timeoutFactor=[multiplicative timeout factor]:f:' \
  '--logLevel=[log level]:level:(off fatal error warn info debug trace)' \
  '--fileLogLevel=[file log level]:level:(off fatal error warn info debug trace)' \
  '--allowConsoleColors[allow ANSI colors]' \
  '--no-allowConsoleColors[disable ANSI colors]' \
  '--allowEmpty[no error when zero tests found]' \
  '--disableBail[report all failing tests]' \
  '--cleanTempDir=[clean temp dir mode]:mode:(true false always)' \
  '*--ignorePatterns=[glob to ignore]:glob:' \
  '*--plugins=[plugin to load]:plugin:' \
  '--dryRunOnly[run only the initial dry run]' \
  '--dryRunTimeoutMinutes=[dry-run timeout]:minutes:' \
  '--buildCommand=[build command before testing mutants]:cmd:' \
  '--incremental[enable incremental mode]' \
  '--incrementalFile=[incremental results file]:file:_files' \
  '--force[bypass incremental cache, rerun all mutants]' \
  '--checkers=[checkers to use]:checkers:(typescript)' \
  '--symlinkNodeModules[symlink node_modules]' \
  '--no-symlinkNodeModules[disable node_modules symlink]' \
  '--tempDirName=[temp dir name]:dir:' \
  '--thresholds.high=[mutation score high threshold]:n:' \
  '--thresholds.low=[mutation score low threshold]:n:' \
  '--thresholds.break=[break-build mutation score]:n:' \
  '*--mutator.excludedMutations=[mutator types to exclude]:mutators:' \
  '--ignoreStatic[ignore static-block mutations]' \
  '--inPlace[mutate files in place]' \
  '1: :->cmd' \
  '*::config:_files -g "*.{json,js,cjs,mjs,ts}"' && ret=0

case $state in
  (cmd) _describe -t cmds 'stryker command' commands && ret=0 ;;
esac

return ret
