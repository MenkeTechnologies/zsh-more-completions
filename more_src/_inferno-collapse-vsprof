#compdef inferno-collapse-vsprof
# Documentation: https://github.com/jonhoo/inferno
# Collapse Visual Studio profiler call tree summary into folded stacks

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[silence all log output]' \
  '*'{-v,--verbose}'[verbose logging (-v -vv -vvv)]' \
  '*:vsprof call tree summary:_files' && ret=0

return ret
