#compdef nix-prefetch-url

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--type=[hash type]:type:(md5 sha1 sha256 sha512)' \
  '--name=[store name]:name' \
  '--unpack[unpack source archive]' \
  '--print-path[print store path]' \
  '1:url' \
  '2:hash' && ret=0

return ret
