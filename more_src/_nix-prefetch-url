#compdef nix-prefetch-url
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-prefetch-url
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--type[hash algorithm]:type:(blake3 md5 sha1 sha256 sha512)' \
  '--name[override the name of the file in the Nix store]:name:' \
  '--unpack[unpack source archive]' \
  '--executable[set executable bit on downloaded file]' \
  '--print-path[print store path]' \
  '1:url:' \
  '2:hash:' && ret=0

return ret
