#compdef hive
# _hive-cli — Apache Hive CLI (legacy interactive Hive shell; -e single HiveQL query, -f script file, --hiveconf override per-session config, --hivevar set substitution variable, -i init script, -d/--define DBM variable, --database default DB, -S silent (no log), -v verbose, --service launch subservice (cli, metastore, jar, schematool, version), -H help)
# upstream: https://github.com/apache/hive
# Flags from Apache Hive bin/hive on tip.

_hive-cli() {
    _arguments \
        '-h[show help]' \
        '-H[show help]' \
        '--help[show help]' \
        '-e+[HiveQL query]:query:' \
        '-f+[script file]:file:_files -g "*.(hql|sql)"' \
        '-i+[init script]:file:_files' \
        '*--hiveconf+[key=value]:prop:' \
        '*--hivevar+[key=value]:var:' \
        '*-d+[key=value]:var:' \
        '*--define+[key=value]:var:' \
        '--database+[default DB]:db:' \
        '-S[silent]' \
        '--silent[silent]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--service+[hive service]:service:(cli metastore beeline schematool fix-acid-key-tables jar lineage llap orcfiledump rcfilecat hwi version) ' \
        '--auxpath+[aux jars]:path:' \
        '--driver+[JDBC driver]:driver:'
}

_hive-cli "$@"
