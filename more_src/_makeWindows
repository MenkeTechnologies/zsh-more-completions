#compdef makeWindows
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/makewindows.html
# make interval windows across a genome (bedtools makewindows)

local ret=1

_arguments -s -S \
  '-g[genome file defining chromosome sizes]:file:_files' \
  '-b[input BED file of regions to make windows in]:file:_files' \
  '-w[window size in base pairs]:bp' \
  '-s[step size between windows]:bp' \
  '-n[number of windows to divide each region into]:n' \
  '-reverse[reverse the numbering of windows]' \
  '-i[ID naming scheme for output windows]:scheme:(src winnum srcwinnum)' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
