#compdef clumpinfo
# Documentation: https://starlink.eao.hawaii.edu/docs/sun255.htx/sun255ss1.html
# CUPID: obtain information about one or more previously identified clumps.

local ret=1

_arguments -s -S \
  'NDF=[input NDF with identified clumps]:ndf:_files' \
  'CLUMPS=[clump indices to include]:clumps:' \
  'QUIET=[suppress screen output]:flag:(TRUE FALSE)' \
  'NCLUMPS=[output total number of clumps]:n:' \
  'FLBND=[output lower WCS bounds]:bounds:' \
  'FUBND=[output upper WCS bounds]:bounds:' \
  'LBOUND=[output lower pixel bounds]:bounds:' \
  'UBOUND=[output upper pixel bounds]:bounds:' \
  '*:ndf:_files' && ret=0

return ret
