#compdef brz breezy
# Documentation: https://www.breezy-vcs.org/doc/en/user-guide/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a branch in the current directory'
  'init-shared-repo:initialize a shared repository'
  'init-repo:initialize a shared repository'
  'add:add files to be tracked'
  'remove:remove files from versioning'
  'mv:rename or move a file'
  'commit:commit changes into a new revision (alias: ci)'
  'status:display current status (alias: st)'
  'diff:show working tree differences (alias: di)'
  'log:show revision history'
  'pull:update a mirror branch'
  'push:publish a branch'
  'branch:make a new branch from an existing one'
  'checkout:create a new checkout of a branch'
  'update:update working tree to latest revision'
  'merge:merge branches'
  'revert:revert files to a previous revision'
  'resolve:mark conflicts resolved'
  'tag:create or list tags'
  'tags:list tags'
  'cat:print a file at a revision'
  'annotate:show line-by-line authorship'
  'whoami:show or set your identity'
  'help:show help'
  'version:show version'
  'plugins:list installed plugins'
  'serve:run a Breezy smart server'
  'switch:switch the current checkout to another branch'
  'send:create a merge directive for review'
  'shelve:put pending changes aside'
  'unshelve:restore shelved changes'
  'split:split out a subdirectory as its own branch'
  'join:join branches into a single tree'
  'export:export a tree to an archive'
  'mkdir:create a new directory and add it'
  'lp-login:log in to Launchpad'
  'lp-logout:log out of Launchpad'
  'lp-propose-merge:propose a Launchpad merge'
  'lp-find-proposal:find a Launchpad merge proposal'
  'github-login:log in to GitHub'
  'gh-propose:propose a GitHub pull request'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--no-aliases[do not expand aliases]' \
  '--builtin[use built-in command only]' \
  '--profile[profile execution]' \
  '--lsprof[profile with lsprof]' \
  '--coverage[record coverage data]' \
  '--concurrency=[max parallel threads]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'brz command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (commit|ci)
        _arguments \
          '(-m --message)'{-m+,--message=}'[commit message]:msg:' \
          '(-F --file)'{-F+,--file=}'[message file]:file:_files' \
          '--unchanged[allow empty commit]' \
          '--fixes=[bug fixed by this commit]:bug:' \
          '--local[local commit]' \
          '--strict[disallow unknown files]' \
          '--author=[override author]:name:' \
          '*:file:_files' && ret=0 ;;
      (push|pull|branch|checkout)
        _arguments \
          '--revision=[revision]:rev:' \
          '--overwrite[overwrite divergent history]' \
          '--remember[remember location]' \
          '--directory=[branch directory]:dir:_files -/' \
          '*::location:_files' && ret=0 ;;
      (diff|di)
        _arguments \
          '(-r --revision)'{-r+,--revision=}'[revision range]:rev:' \
          '--diff-options=[options passed to diff]:opts:' \
          '--using=[external diff tool]:cmd:_command_names' \
          '*:file:_files' && ret=0 ;;
      (log)
        _arguments \
          '(-r --revision)'{-r+,--revision=}'[revision range]:rev:' \
          '--short[short log format]' \
          '--line[one-line log format]' \
          '(-n --limit)'{-n+,--limit=}'[limit number of revisions]:n:' \
          '--forward[oldest-first order]' \
          '*:path:_files' && ret=0 ;;
      (tag)
        _arguments \
          '--delete[delete the tag]' \
          '--force[overwrite existing]' \
          '*::name:' && ret=0 ;;
      (serve)
        _arguments \
          '--port=[port]:port:' \
          '--allow-writes[permit writes]' \
          '--inet[serve over inetd]' \
          '--directory=[serve directory]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
