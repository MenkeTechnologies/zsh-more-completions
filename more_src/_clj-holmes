#compdef clj-holmes
# ============================================================================
#  _clj-holmes — clj-holmes: CLI SAST (Static Application Security Testing)
#                tool for finding vulnerable Clojure code via pattern rules
#
#  Source-direct extraction from
#    https://github.com/clj-holmes/clj-holmes/blob/main/src/clj_holmes/main.clj
#    https://github.com/l3nz/cli-matic (the cli-matic library)
#
#  Maintained by the clj-holmes team (clj-holmes/clj-holmes).  116 GH
#  stars.  clj-holmes is a STATIC APPLICATION SECURITY TESTING (SAST)
#  scanner for Clojure code — uses pattern-matching rules to find
#  vulnerable code constructs (similar to Semgrep but Clojure-specific).
#  Sister tools: semgrep (general SAST, in corpus), brakeman (Ruby SAST),
#  bandit (Python SAST, in corpus), gosec (Go SAST, in corpus).
#
#  CLI library taxonomy update: 3rd Clojure CLI library — cli-matic.
#  Clojure ecosystem now has 3 documented CLI libraries (R302
#  babashka.cli + R318 org.clojure/tools.cli + R362 cli-matic)
#  joining the multi-library leaders.
#
#  cli-matic (Leonardo "l3nz" Borghi's cli-matic; ~400 GH stars on
#  l3nz/cli-matic) is a DATA-STRUCTURE-DRIVEN CLI library for Clojure
#  — the ENTIRE CLI is described as a SINGLE CLOJURE MAP, and one
#  function call `(cli-matic.core/run-cmd args CONFIG)` parses argv,
#  dispatches to the matched subcommand's handler, and exits.
#
#  cli-matic API:
#    (ns my.app
#      (:require [cli-matic.core :as cli]))
#
#    (def CONFIGURATION
#      {:app      {:command     "my-cli"
#                  :description "My CLI app"
#                  :version     "1.0.0"}
#       :commands [{:command     "verb"
#                   :description "verb description"
#                   :opts        [{:option  "name" :short "n"
#                                  :type    :string
#                                  :default "default-value"
#                                  :as      "Description of name option"}
#                                 {:option  "count" :short "c"
#                                  :type    :int
#                                  :default :present  ; required
#                                  :as      "Number of items"}
#                                 {:option   "tag" :short "t"
#                                  :multiple true
#                                  :type     :string
#                                  :as       "Tag (repeatable)"}
#                                 {:option  "output-type" :short "o"
#                                  :type    #{"json" "yaml" "txt"}  ; choices
#                                  :default "txt"
#                                  :as      "Output format"}
#                                 {:option  "verbose" :short "v"
#                                  :type    :with-flag
#                                  :default true
#                                  :as      "Verbose output"}]
#                   :runs        handler-fn}]})
#
#    (defn -main [& args]
#      (cli/run-cmd args CONFIGURATION))
#
#  cli-matic distinctive features:
#    - DATA-STRUCTURE-DRIVEN — the ENTIRE CLI is a CLOJURE MAP, no
#      fluent builder, no chained methods, no annotations, no
#      reflection
#    - DECLARATIVE `:opts` LIST per command — each option is a map
#      `{:option NAME :short C :type T :default V :as DESC :multiple BOOL}`
#    - `:type` can be `:string`/`:int`/`:flag`/`:with-flag`/`:edn`/
#      `:keyword`/`:slurp`/etc. OR a SET `#{"a" "b" "c"}` for choices
#    - `:default :present` marks the option as REQUIRED
#    - `:multiple true` makes the option REPEATABLE
#    - `(cli-matic.core/run-cmd args CONFIGURATION)` is the ONLY
#      runtime call needed — parses argv, dispatches to handler, exits
#  Distinct from R302 babashka.cli (uses Clojure maps too but with
#  different syntax: `(parse-args args {:spec {:foo {:default 42}}}`)
#  and R318 org.clojure/tools.cli (uses a different declarative style:
#  vector-of-vectors `[["-p" "--port PORT" "Port" :default 80]]`).
#  cli-matic's approach: SINGLE CLOJURE MAP for the WHOLE CLI + one-
#  function-call dispatch + `:type` as set-for-choices — corpus's
#  **first documented single-Clojure-map-for-whole-CLI CLI pattern**.
#  Brings cross-language CLI library taxonomy variant count to 101;
#  Clojure ecosystem now has 3 documented CLI libraries.
#
#  Surface (verbatim from src/clj_holmes/main.clj CONFIGURATION):
#
#  Subcommands:
#    fetch-rules                 Fetch rules from external server
#      -r, --repository URL      Repository URL (default
#                                git://clj-holmes/clj-holmes-rules#main)
#      -o, --output-directory D  Output directory (default
#                                /tmp/clj-holmes-rules/)
#    validate-rules              Validate rules conform expected format
#      -d, --rules-directory D   Rules directory (default
#                                /tmp/clj-holmes-rules/)
#      -r, --rule-tags TAG       Tag filter (repeatable)
#    scan                        Scan a path for vulnerabilities
#      -p, --scan-path PATH      Path to scan (REQUIRED)
#      -d, --rules-directory D   Rules directory (default
#                                /tmp/clj-holmes-rules/)
#      -o, --output-file F       Output file (default
#                                clj_holmes_scan_results.txt)
#      -t, --output-type T       Output type: sarif|stdout|json
#                                (default stdout)
#      -T, --rule-tags TAG       Tag filter (repeatable)
#      -S, --rule-severity SEV   Severity filter (repeatable)
#      -P, --rule-precision PR   Precision filter (repeatable)
#      -i, --ignored-paths RX    Ignore regex (repeatable)
#      -f, --fail-on-result      Fail on results (CI/CD-friendly;
#                                default false)
#      -v, --verbose             Enable scan feedback (default true)
#
#  Dup-skipped neighbors during hunt (smaller surface or in corpus):
#    - ftr (HealthSamurai/ftr 0 stars — narrow Fhir Terminology Repository)
#    - parti-time (JohannesFKnauf — narrow time-partition tool)
#    - undefhir (HealthSamurai — narrow Fhir tool)
# ============================================================================

_clj-holmes() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'fetch-rules:fetch rules from external server'
        'validate-rules:validate rules conform expected format'
        'scan:scan a path for vulnerabilities'
      )
      _describe -t commands 'clj-holmes subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        fetch-rules)
          _arguments -s -S \
            '(-r --repository)'{-r,--repository}'=[repository URL]:url' \
            '(-o --output-directory)'{-o,--output-directory}'=[output directory]:dir:_directories'
          ;;
        validate-rules)
          _arguments -s -S \
            '(-d --rules-directory)'{-d,--rules-directory}'=[rules directory]:dir:_directories' \
            '*'{-r,--rule-tags}'=[tag filter (repeatable)]:tag'
          ;;
        scan)
          _arguments -s -S \
            '(-p --scan-path)'{-p,--scan-path}'=[path to scan (REQUIRED)]:path:_files' \
            '(-d --rules-directory)'{-d,--rules-directory}'=[rules directory]:dir:_directories' \
            '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
            '(-t --output-type)'{-t,--output-type}'=[output type]:type:(sarif stdout json)' \
            '*'{-T,--rule-tags}'=[tag filter (repeatable)]:tag' \
            '*'{-S,--rule-severity}'=[severity filter (repeatable)]:severity' \
            '*'{-P,--rule-precision}'=[precision filter (repeatable)]:precision' \
            '*'{-i,--ignored-paths}'=[ignore regex (repeatable)]:regex' \
            '(-f --fail-on-result)'{-f,--fail-on-result}'[fail on results (CI/CD)]' \
            '(-v --verbose)'{-v,--verbose}'[enable scan feedback]'
          ;;
      esac
      ;;
  esac
}

_clj-holmes "$@"
