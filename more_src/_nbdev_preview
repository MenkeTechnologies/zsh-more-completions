#compdef nbdev_preview
# Documentation: https://nbdev.fast.ai/api/quarto.html
# nbdev_preview: preview nbdev docs locally with a live server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--path=[path to notebooks directory]:path:_files -/' \
  '--port=[preview server port]:port:' \
  '--host=[preview server host]:host:' \
  '--no_browser[prevent automatic browser launch]' \
  '--n_workers=[number of workers]:n:' && ret=0

return ret
