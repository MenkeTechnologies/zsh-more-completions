#compdef surelanan
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/velocity_analysis/surelanan.c
# Residual-moveout semblance analysis along an interface (SU data)

local ret=1

_arguments -s -S \
  'reflec=[reflector file]:file:_files' \
  'npicks=[number of points in the reflector file]:npicks' \
  'nr1=[number of r1-parameter samples]:nr1' \
  'dr1=[r1-parameter sampling interval]:dr1' \
  'fr1=[first value of r1-parameter]:fr1' \
  'nr2=[number of r2-parameter samples]:nr2' \
  'dr2=[r2-parameter sampling interval]:dr2' \
  'fr2=[first value of r2-parameter]:fr2' \
  'dzratio=[ratio of output to input depth sampling intervals]:dzratio' \
  'nsmooth=[length of semblance num and den smoothing window]:nsmooth' \
  'verbose=[diagnostic print on stderr flag]:verbose:(0 1)' \
  'method=[interpolation method for the interface]:method:(linear mono akima spline)' \
  '*:file:_files' && ret=0

return ret
