#compdef pdns_control
# Documentation: https://man.archlinux.org/search?q=pdns_control
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'bind-add-zone:add zone to BIND backend'
  'bind-domain-extended-status:extended domain status'
  'bind-domain-status:domain status'
  'bind-list-rejects:list rejected zones'
  'bind-reload-now:reload now'
  'ccounts:cache counts'
  'current-config:show running config'
  'cycle:cycle daemon'
  'flush:flush cache'
  'list:list config'
  'list-zones:list zones'
  'notify:send notify for zone'
  'notify-host:send notify to host for zone'
  'ping:ping daemon'
  'rping:remote ping'
  'purge:purge cache'
  'qtypes:show qtype counts'
  'quit:tell daemon to quit'
  'stop:stop daemon'
  'rediscover:rediscover backends'
  'reload:reload zones'
  'remotes:show recent remote IPs'
  'respsizes:show response size stats'
  'retrieve:retrieve zone'
  'set:set runtime variable'
  'show:show statistic'
  'status:daemon status'
  'token-login:HSM token login'
  'uptime:daemon uptime'
  'version:show version'
)

_arguments -C \
  '--help[show help]' \
  '--chroot=[chroot dir]:dir:_files -/' \
  '--config-dir=[config dir]:dir:_files -/' \
  '--config-name=[config name]:name:' \
  '--remote-address=[remote address]:addr:' \
  '--remote-port=[remote port]:port:' \
  '--secret=[shared secret]:secret:' \
  '--socket-dir=[socket dir]:dir:_files -/' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pdns_control command' subcommands && ret=0
    ;;
esac

return ret
