#compdef twc
# Documentation: https://github.com/timeweb-cloud/twc/blob/master/docs/ru/CLI_REFERENCE.md
# Timeweb Cloud Command Line Interface

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[display version information and exit]' \
  '(-v --verbose)'{-v,--verbose}'[activate verbose output mode]' \
  '(-c --config)'{-c,--config}'=[specify configuration file location]:file:_files' \
  '(-p --profile)'{-p,--profile}'=[select configuration profile]:profile' \
  '--install-completion[install shell completion]' \
  '--show-completion[display shell completion]' \
  '*:command:((account\:"manage account" apps\:"manage applications" balancer\:"manage load balancers" cluster\:"manage Kubernetes clusters" config\:"manage CLI configuration" database\:"manage databases" domain\:"manage domains and DNS records" firewall\:"manage cloud firewall rules" image\:"manage disk images" ip\:"manage floating IPs" project\:"manage projects" server\:"manage cloud servers" ssh-key\:"manage SSH keys" storage\:"manage object storage buckets" vpc\:"manage virtual networks" whoami\:"display current login information" version\:"display version and exit"))' && ret=0

return ret
