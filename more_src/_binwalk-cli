#compdef binwalk-cli
# _binwalk-cli — Craig Heffner binwalk firmware analysis tool CLI alias (ReFirmLabs team, Python); custom argparse
# upstream: https://github.com/ReFirmLabs/binwalk

_binwalk-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-B[signature scan]' \
        '--signature[signature scan]' \
        '-R+[search bytes]:str:' \
        '--raw=+[search bytes]:str:' \
        '-A[search arch opcodes]' \
        '--opcodes[search arch opcodes]' \
        '-m+[magic file]:file:_files' \
        '--magic=+[magic file]:file:_files' \
        '-b+[block size]:n:' \
        '--block=+[block size]:n:' \
        '-l+[length bytes]:n:' \
        '--length=+[length bytes]:n:' \
        '-o+[offset bytes]:n:' \
        '--offset=+[offset bytes]:n:' \
        '-f+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-y+[include type]:str:' \
        '--include=+[include type]:str:' \
        '-x+[exclude type]:str:' \
        '--exclude=+[exclude type]:str:' \
        '-I[invalid]' \
        '--invalid[invalid]' \
        '-W[delete after extraction]' \
        '--wipe[delete after extraction]' \
        '-r[remove failures]' \
        '--rm[remove failures]' \
        '-z[scan zip headers]' \
        '--no-extract[no extract]' \
        '-e[automatically extract]' \
        '--extract[automatically extract]' \
        '-M[matryoshka mode]' \
        '--matryoshka[matryoshka mode]' \
        '-d+[recursive depth]:n:' \
        '--depth=+[recursive depth]:n:' \
        '-C+[directory]:dir:_files -/' \
        '--directory=+[directory]:dir:_files -/' \
        '-j+[size mb]:n:' \
        '--size=+[size mb]:n:' \
        '-n[count]' \
        '--count[count]' \
        '-D+[type:[ext:]cmd]:str:' \
        '--dd=+[type:[ext:]cmd]:str:' \
        '-E[entropy analysis]' \
        '--entropy[entropy analysis]' \
        '-F[fast entropy]' \
        '--fast[fast entropy]' \
        '-J[save plot file]' \
        '--save[save plot file]' \
        '-Q[no entropy gradient]' \
        '--nlegend[no legend]' \
        '-N[show plot, no save]' \
        '--nplot[show plot, no save]' \
        '-H+[high entropy]:str:' \
        '--high=+[high entropy]:str:' \
        '-L+[low entropy]:str:' \
        '--low=+[low entropy]:str:' \
        '-K[carve everything found]' \
        '--carve[carve everything found]' \
        '-w[disable plot]' \
        '--disasm[scan for arch instructions]' \
        '-Y[arch architecture]' \
        '--minsize=+[size]:n:' \
        '-S[print strings]' \
        '--strings[print strings]' \
        '*:files:_files'
}

_binwalk-cli "$@"
