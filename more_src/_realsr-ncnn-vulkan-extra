#compdef realsr-ncnn-vulkan-extra
# Documentation: https://github.com/nihui/realsr-ncnn-vulkan
# RealSR ncnn Vulkan image upscaler (extra-models fork)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-i+[input image path or directory]:input:_files' \
  '-o+[output image path or directory]:output:_files' \
  '-s+[upscale ratio (4, default=4)]:scale:(4)' \
  '-t+[tile size (>=32/0=auto)]:tile size' \
  '-m+[realsr model path]:model dir:_files -/' \
  '-g+[gpu device to use]:gpu id' \
  '-j+[thread count for load:proc:save]:threads' \
  '-x[enable tta mode]' \
  '-f+[output image format]:format:(jpg png webp)' && ret=0

return ret
