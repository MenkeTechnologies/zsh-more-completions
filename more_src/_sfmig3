#compdef sfmig3
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/fomels/Mmig3.c
# Madagascar: 3D Kirchhoff time migration with antialiasing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'n1=[number of time samples]:n:' \
  'n2=[number of inline samples]:n:' \
  'd2=[inline sampling]:d:' \
  'o2=[inline origin]:o:' \
  'n3=[number of crossline samples]:n:' \
  'd3=[crossline sampling]:d:' \
  'o3=[crossline origin]:o:' \
  'antialias=[antialiasing method]:method:(triangle flat steep)' \
  'vel=[migration velocity]:vel:' \
  '*:RSF file:_files' && ret=0

return ret
