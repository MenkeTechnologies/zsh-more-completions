#compdef FilterVcf
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#FilterVcf
# Picard: apply hard-filtering to a VCF, flagging records that fail thresholds

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input VCF or BCF file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-O=,--OUTPUT=}'[output VCF or BCF file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  '--MIN_AB=[minimum allele balance for heterozygous genotypes]:float:' \
  '--MIN_DP=[minimum sequencing depth before a genotype is filtered]:int:' \
  '--MIN_GQ=[minimum genotype quality before a genotype is filtered]:int:' \
  '--MAX_FS=[maximum phred-scaled fisher strand value]:float:' \
  '--MIN_QD=[minimum QD value to accept the variant]:float:' \
  {-JS=,--JAVASCRIPT_FILE=}'[custom JavaScript filter file]:file:_files' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
