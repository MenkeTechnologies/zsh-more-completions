#compdef ecasignalview
# Documentation: https://manpages.debian.org/buster/ecatools/ecasignalview.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ecasignalview: terminal signal-level viewer from the ecatools/ecasound suite
local curcontext="$curcontext" ret=1
_arguments -C \
  '-r:[screen refresh rate in milliseconds]:rate_msec:' \
  '-I[use linear scale for sample amplitude]' \
  '-L[use logarithmic scale for sample amplitude]' \
  '-G[generic ECI client args, see ecasound(1)]:args:' \
  '-B[engine buffering mode, see ecasound(1)]:mode:' \
  '-M[runtime engine modes, see ecasound(1)]:mode:' \
  '-z[engine option, see ecasound(1)]:opt:' \
  '*:input output:_files' && ret=0
return ret
