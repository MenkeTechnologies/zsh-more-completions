#compdef ecasignalview

# ecasignalview: simple terminal signal-level viewer for ecasound
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[debug output level]:n:' \
  '-G[generic ECI client args]:args:' \
  '-R[refresh rate in ms]:ms:' \
  '-r[refresh rate]:ms:' \
  '-c[number of channels]:n:' \
  '-b[sample buffer size]:n:' \
  '*:input output:_files' && ret=0
return ret
