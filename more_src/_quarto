#compdef quarto

# Zsh completion for Quarto - scientific publishing system

local curcontext="$curcontext" state line ret=1

local -a quarto_commands
quarto_commands=(
  'render:render files or projects'
  'preview:preview document or website'
  'publish:publish to a provider'
  'create:create a new project or extension'
  'install:install an extension'
  'add:add an extension to a project'
  'update:update an extension'
  'remove:remove an extension'
  'use:use a project template'
  'convert:convert between document formats'
  'check:verify Quarto installation'
  'inspect:inspect a document or project'
  'tools:manage external tools'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:_describe -t commands command quarto_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      render)
        _arguments -s -S \
          '--to=[output format]:format:(html pdf docx revealjs beamer pptx epub gfm commonmark)' \
          '--output=[output file]:file:_files' \
          '--output-dir=[output directory]:directory:_directories' \
          '--execute[execute code cells]' \
          '--no-execute[do not execute code cells]' \
          '*--execute-param=[execution parameter]:param (key=value):' \
          '--execute-dir=[working directory for execution]:directory:_directories' \
          '--execute-daemon[use execution daemon]' \
          '--execute-debug[debug execution]' \
          '--cache[use computation cache]' \
          '--cache-refresh[force refresh cache]' \
          '--no-clean[do not clean output before render]' \
          '*--metadata=[set metadata value]:metadata (key=value):' \
          '--site-url=[override site URL]:url:_urls' \
          '--profile=[configuration profile]:profile:' \
          '--log=[log file path]:file:_files' \
          '--log-level=[log level]:level:(info warning error critical)' \
          '--log-format=[log format]:format:(plain json)' \
          '--quiet[suppress output]' \
          '--pandoc-args=[additional pandoc arguments]:args:' \
          '*:input files:_files' && ret=0
        ;;
      preview)
        _arguments -s -S \
          '--port=[port for preview server]:port:' \
          '--host=[host for preview server]:host:' \
          '--browser[open in browser]' \
          '--no-browser[do not open in browser]' \
          '--render=[what to render]:render:(all none)' \
          '--no-serve[render without serving]' \
          '--no-navigate[do not navigate browser on change]' \
          '*:input files:_files' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '1:provider:(quarto-pub gh-pages netlify confluence posit-cloud)' \
          '*:input files or directory:_files' && ret=0
        ;;
      create)
        _arguments -s -S \
          '1:type:(project extension)' \
          '2:name:' && ret=0
        ;;
      check)
        _arguments -s -S \
          '1:target:(install jupyter knitr all)' && ret=0
        ;;
      install)
        _arguments -s -S \
          '1:type:(extension tool chromium tinytex)' \
          '2:name or path:' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '--output=[output file]:file:_files' \
          '1:input file:_files' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '1:input file or project:_files' && ret=0
        ;;
      tools)
        _arguments -s -S \
          '1:action:(install update remove list)' \
          '2:tool:(chromium tinytex)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
