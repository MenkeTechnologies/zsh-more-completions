#compdef argocd-cmp-server
# _argocd-cmp-server — Argo CD config-management-plugin sidecar (argoproj/argo-cd)
# upstream: https://github.com/argoproj/argo-cd
# Flags from cmd/argocd-cmp-server/commands/argocd_cmp_server.go (cobra).

_argocd-cmp-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--logformat=[log format]:format:(json text)' \
        '--loglevel=[log level]:level:(trace debug info warn error)' \
        '--config-dir-path=[CMP configuration file directory]:dir:_files -/' \
        '--otlp-address=[OpenTelemetry collector address]:host\:port:' \
        '--otlp-insecure[disable OpenTelemetry TLS]' \
        '--otlp-headers=[comma-separated OTLP key=value headers]:kv:' \
        '--otlp-attrs=[colon-separated OTLP key:value attrs]:kv:'
}

_argocd-cmp-server "$@"
