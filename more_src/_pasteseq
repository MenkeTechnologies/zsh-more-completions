#compdef pasteseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pasteseq.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pasteseq: insert one sequence into another at a given position
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[sequence to insert]:sequence USA:_files' \
  '-bsequence=[sequence to insert into]:sequence USA:_files' \
  '-pos=[position in bsequence after which to paste]:position:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output format]:format:(fasta embl genbank swiss gcg pir nbrf raw msf ace text)' \
  '*:sequence USA:_files' && ret=0
return ret
