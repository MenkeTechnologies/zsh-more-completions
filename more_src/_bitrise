#compdef bitrise

# bitrise-io/bitrise (cobra); Homebrew: Formula/b/bitrise.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '--log-level=[log level]:level:(panic fatal error warn info debug)' \
  '--prudent-mode[prudent mode]' \
  '--ci[CI mode]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'bitrise command' compadd -- run trigger abort status workflow-list \
    validate secret-add secret-list secret-delete certificate-upload profile-upload
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
