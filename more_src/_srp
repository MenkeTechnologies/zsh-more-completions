#compdef srp
# ============================================================================
#  _srp — srp (scala-repl-pp): Scala REPL enhancements
#
#  Source-direct extraction from
#    https://github.com/mpollmeier/scala-repl-pp/blob/master/core/src/main/scala/replpp/Config.scala
#    https://github.com/mpollmeier/scala-repl-pp/blob/master/core/src/main/scala/replpp/Main.scala
#    https://github.com/scopt/scopt (the scopt library)
#
#  Authored by Michael Pollmeier (mpollmeier/scala-repl-pp).  26 GH
#  stars.  srp is a SCALA REPL ENHANCEMENT — wraps Scala's `dotty.tools.
#  repl` with: predef-script auto-loading, classpath inheritance from
#  parent JVM, dependency resolution via coursier (Maven coordinates),
#  remote JVM debugging, script execution mode, command execution mode,
#  parameterized scripts.  Binary name `srp` (Scala-Repl-PP) installed
#  via SDKMAN or downloadable from GitHub Releases.  Sister tools:
#  ammonite (Scala scripting, in corpus), scala-cli (in corpus),
#  scala (stdlib REPL).
#
#  CLI library taxonomy update: 3rd Scala CLI library — scopt.  Scala
#  ecosystem now has 3 documented CLI libraries (R278 decline +
#  R346 mainargs + R360 scopt) joining the multi-library leaders.
#  scopt (Eugene Yokota's scopt — Lightbend / Akka committer) is the
#  OLDEST and MOST-WIDELY-USED Scala CLI library (1500+ GH stars on
#  scopt/scopt) — used by Apache Spark, Apache Flink, Apache Kafka,
#  sbt-native-packager, many other JVM ecosystem tools.
#
#  scopt API:
#    import scopt.{OParser, OParserBuilder}
#
#    given builder: OParserBuilder[Config] = OParser.builder[Config]
#    import builder.*
#
#    val parser = OParser.sequence(
#      programName("scala-repl-pp"),
#      note("REPL options"),
#      opt[Path]("predef")
#        .valueName("myScript.sc")
#        .unbounded()
#        .optional()
#        .action((path, config) => config.copy(predefFiles = config.predefFiles :+ path))
#        .text("given source files will be compiled..."),
#      opt[String]("dep")
#        .valueName("com.michaelpollmeier:versionsort:1.0.7")
#        .unbounded()
#        .action((dep, config) => config.copy(dependencies = config.dependencies :+ dep))
#        .text("dependency"),
#      opt[Unit]("verbose")
#        .action((_, c) => c.copy(verbose = true)),
#      help("help").text("Print this help text"),
#    )
#
#    val config = OParser.parse(parser, args, Config()).getOrElse(sys.exit(1))
#
#  scopt distinctive features:
#    - IMMUTABLE-STATE-THREADING via `(value, config) => updatedConfig`
#      lambda — caller threads an IMMUTABLE config CASE CLASS through
#      option actions; each `.action` is a `(value, prev_config) =>
#      next_config` FUNCTION returning the UPDATED config
#    - GENERIC TYPED OPTIONS via `opt[T]("name")` — T is the Scala type
#      (`Unit` for boolean, `Int`/`String`/`Path`/`Duration`/`File`, custom
#      types via implicit `scopt.Read[T]` typeclass)
#    - METHOD-CHAIN BUILDER per option: `.valueName(...)`, `.unbounded()`,
#      `.optional()`, `.required()`, `.action(...)`, `.text(...)`,
#      `.validate(...)`, `.children(...)` (for subcommands)
#    - `OParser.sequence(programName, opt1, opt2, ...)` — assemble parser
#      from a SEQUENCE of options
#    - `note("section header")` — SECTION HEADER in help text
#    - `help("help")` — auto-handled help flag
#    - `OParser.parse(parser, args, initialConfig)` — returns
#      `Option[Config]` (None on parse failure)
#    - REUSABLE OPTION DEFINITIONS via builders that take `(using
#      OParserBuilder[C])` — caller can DEFINE OPTIONS ONCE and REUSE
#      them in multiple parsers (mpollmeier uses this for sharing
#      options between `srp` and `srp-server`)
#  Distinct from R278 decline (FUNCTIONAL applicative-based using cats
#  `(opt1, opt2).mapN((a, b) => ...)`), R346 mainargs (ANNOTATION-BASED
#  on method signatures `@main def run(@arg ...)`), R275 clap-derive
#  (Rust struct + macro), R322 JCommander (Java annotations on fields),
#  R341 yargs (TS fluent builder), R343 commander.js (TS explicit-
#  instance builder).  scopt's approach: IMMUTABLE-STATE-THREADING via
#  `(value, config) => updatedConfig` lambda + `OParser.sequence(...)`
#  + GENERIC TYPED `opt[T]("name")` — corpus's **first documented
#  immutable-state-threading-via-action-lambda CLI pattern**.  Brings
#  cross-language CLI library taxonomy variant count to 99; Scala
#  ecosystem now has 3 documented CLI libraries.
#
#  Surface (verbatim from core/src/main/scala/replpp/Config.scala):
#
#  Top-level options (mostly REPEATABLE via `.unbounded()`):
#    --predef FILE              Source files added to classpath
#    --runBefore CODE           Code executed on startup
#    --runAfter CODE            Code executed on shutdown
#    --nocolors                 Turn off colors
#    --verbose                  Enable verbose output
#    --classpathEntry PATH      Additional classpath entry
#    --cpinherit                Inherit Java classpath from JVM
#    --cpinclude PATTERN        Classpath include pattern
#    --cpexclude PATTERN        Classpath exclude pattern
#    --dep GROUP:ART:VER        Maven coordinate dependency
#    --repo URL                 Maven repository URL
#    --remoteJvmDebug           Enable remote JVM debugging
#    --scalacOption OPT         Scala compiler option
#
#  REPL options (under `note("REPL options")` section header):
#    --prompt STR               Custom prompt
#    --greeting STR             Custom greeting
#    --maxHeight N              Max display height
#
#  Script execution (under `note("Script execution")` section header):
#    --script FILE              Execute script file
#    --command STR              Execute command string
#    --param KEY=VALUE          Script parameter (repeatable)
#
#  Auto-handled:
#    --help                     Show help
#
#  Dup-skipped neighbors during hunt (smaller surface or unrelated):
#    - goatrodeo (spice-labs-inc 5 stars — narrow artifact dependency
#      graph tool)
#    - riddl (ossuminc/riddl 4 stars — DDD-design-language compiler,
#      narrow)
#    - xdfbinext (jtownson 14 stars — narrow Tunerpro XDF utility)
#    - mill, ammonite, bleep (all IN CORPUS — use mainargs or decline
#      not scopt)
# ============================================================================

_srp() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '*--predef=[source file added to classpath (repeatable)]:script:_files -g "*.{sc,scala}"' \
    '*--runBefore=[code executed on startup (repeatable)]:code' \
    '*--runAfter=[code executed on shutdown (repeatable)]:code' \
    '--nocolors[turn off colors]' \
    '--verbose[enable verbose output]' \
    '*--classpathEntry=[additional classpath entry (repeatable)]:path:_files' \
    '--cpinherit[inherit Java classpath from parent JVM]' \
    '*--cpinclude=[classpath include pattern (repeatable)]:pattern' \
    '*--cpexclude=[classpath exclude pattern (repeatable)]:pattern' \
    '*--dep=[Maven coordinate dependency (repeatable)]:dep (group\:artifact\:version)' \
    '*--repo=[Maven repository URL (repeatable)]:url' \
    '--remoteJvmDebug[enable remote JVM debugging]' \
    '*--scalacOption=[Scala compiler option (repeatable)]:scalac option' \
    '--prompt=[custom prompt]:prompt' \
    '--greeting=[custom greeting]:greeting' \
    '--maxHeight=[max display height]:height' \
    '--script=[execute script file]:script:_files -g "*.sc"' \
    '--command=[execute command string]:command' \
    '*--param=[script parameter (KEY=VALUE; repeatable)]:param (KEY=VALUE)' \
    '--help[show help]'
}

_srp "$@"
