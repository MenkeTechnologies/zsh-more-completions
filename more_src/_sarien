#compdef sarien
# Documentation: https://sarien.sourceforge.net/
# Reference accessed: 2026-05-16

# Sarien: Sierra AGI game engine (King's Quest 1-3, Police Quest 1, Space Quest 1-2, etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[config file]:file:_files' \
  '-d[debug level]:n:' \
  '-f[fullscreen]' \
  '-g[graphic mode]:mode:(ega cga hercules tandy mono)' \
  '-l[load saved game]:file:_files' \
  '-m[mouse mode]:mode:(none none mouse)' \
  '-s[scale factor]:n:' \
  '-v[verbose]' \
  '-V[show version]' \
  '*:Sierra AGI game directory:_files -/' && ret=0
return ret
