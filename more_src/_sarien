#compdef sarien
# Documentation: (none - Debian package "sarien" does not exist; sourceforge
# project is defunct and source is not currently accessible)
# Reference accessed: 2026-05-16
# Verified: packages.debian.org search for "sarien" returns "Sorry, your search
# gave no results"; dyn.manpages.debian.org/buster/sarien/sarien.6.html returns
# 404. Project was a defunct Sierra AGI engine port (predecessor to ScummVM's
# AGI engine integration). File kept per "do not delete files" directive but
# completion is conservative since no upstream source is verifiable.
# Removed from prior file: -c, -d, -f, -g, -l, -m, -s, -v, -V (cannot be
# source-verified - sarien is defunct/unavailable upstream; entire prior flag
# set was an unverified guess).

# sarien: defunct Sierra AGI engine port (use ScummVM AGI engine instead)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:Sierra AGI game directory:_files -/' && ret=0
return ret
