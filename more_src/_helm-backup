#compdef helm-backup
# Documentation: https://github.com/maorfr/helm-backup
# helm backup: backup/restore releases in a namespace to/from a file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --tiller-ns)'{-t,--tiller-ns}'=[namespace where Tiller is deployed]:namespace:' \
  '(-l --label)'{-l,--label}'=[label selector for Tiller resources]:label:' \
  '--file=[output file name (.tgz)]:file:_files' \
  '(-r --restore)'{-r,--restore}'[switch to restore mode]' \
  '*:namespace:' && ret=0

return ret
