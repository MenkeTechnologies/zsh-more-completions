#compdef rstats
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/ext/apps/geomatics/robust/rstats.cpp
# GPSTk robust statistics on columnar data

local ret=1

_arguments -s \
  '(-f --file)'{-f,--file}'[name of file with options]:file:_files' \
  '(-i --input)'{-i,--input}'[name of input file]:file:_files' \
  '--path[path for input file]:dir:_files -/' \
  '(-y --col)'{-y,--col}'[read data from this column]:c' \
  '(-x --xcol)'{-x,--xcol}'[read x-data from this column]:c' \
  '--wt[weight using absolute value of this column]:c' \
  '--beg[include only data where x > xb]:xb' \
  '--end[include only data where x < xe]:xe' \
  '--min[include only data where value > dmin]:dmin' \
  '--max[include only data where value < dmax]:dmax' \
  '--debias[remove bias d from data]:d' \
  '--debias0[remove bias equal to first data point]' \
  '--plot[generate stem-and-leaf plot]' \
  '--qplot[generate quantile-quantile plot data]' \
  '--bin[histogram with bin configuration]:args' \
  '--sum[compute sum of data]' \
  '--sum+[compute sum, range, gaps, step size]' \
  '--fit[fit robust polynomial of degree f]:f' \
  '--seq[output sequential statistics]' \
  '--disc[output discontinuities with stats]:y' \
  '--fdf[first-difference filter slip limit]:x' \
  '--fdf2[first-difference(2) filter]:x' \
  '--wind[window filter]:n' \
  '--xwind[window filter with two-sample stats]:n' \
  '--fix[FDiff fix filter]:n' \
  '--wnj[white noise jerk Kalman filter]:pom' \
  '--fft[compute FFT with timestep]:dt' \
  '--KS[Anderson-Darling normality test]' \
  '--nostats[suppress total statistics output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress title and timing info]' \
  '--stdout[send output to stdout instead of file]' \
  '--outs[list data outside s*(outlier limits)]:s' \
  '(-b --brief)'{-b,--brief}'[single-line quiet output]' \
  '(-l --label)'{-l,--label}'[add label to outputs]:L' \
  '(-p --prec)'{-p,--prec}'[set floating-point precision]:n' \
  '(-w --width)'{-w,--width}'[set floating-point width]:n' \
  '--help[display help]' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' && ret=0

return ret
