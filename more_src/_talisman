#compdef talisman
# Documentation: https://github.com/thoughtworks/talisman
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for talisman - Git pre-commit/pre-push hook for secret detection

_arguments \
  '(-c --checksum)'{-c,--checksum}'=[calculate checksum and suggest .talismanrc format]:string:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-g --githook)'{-g,--githook}'=[hook type]:hook type:(pre-commit pre-push)' \
  '--ignoreHistory[do not scan git commit history]' \
  '(-i --interactive)'{-i,--interactive}'[interactively update .talismanrc]' \
  '(-p --pattern)'{-p,--pattern}'=[glob pattern of files to scan]:pattern:' \
  '(-r --reportdirectory)'{-r,--reportdirectory}'=[directory for scan reports]:directory:_directories' \
  '(-s --scan)'{-s,--scan}'[scan git commit history for secrets]' \
  '(-w --scanWithHtml)'{-w,--scanWithHtml}'[scan and generate HTML report]' \
  '(-v --version)'{-v,--version}'[show version]'
