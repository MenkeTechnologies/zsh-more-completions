#compdef talisman

# Zsh completion for talisman - Git pre-commit/pre-push hook for secret detection

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --checksum)'{-c,--checksum}'[compute checksum]' \
  '(-p --pattern)'{-p,--pattern}'[specify pattern to scan for]:pattern:' \
  '(-s --scan)'{-s,--scan}'[scan repository]' \
  '--scanWithHtml[scan and generate HTML report]' \
  '(-g --githook)'{-g,--githook}'[specify git hook type]:hook type:(pre-commit pre-push)' \
  '--ignoreHistory[ignore git history during scan]' \
  '(-i --interactive)'{-i,--interactive}'[run in interactive mode]' \
  '(-r --reportdirectory)'{-r,--reportdirectory}'[directory for reports]:directory:_directories' \
  '--config[specify config file]:config file:_files' \
  '--debug[enable debug output]' \
  '--loglevel[set log level]:level:(info debug error)'
