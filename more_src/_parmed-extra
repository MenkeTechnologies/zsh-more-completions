#compdef parmed-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools parmed/ParmEd: read and modify Amber parameter files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*'{-i,--input}'[script with ParmEd commands]:file:_files' \
  '*'{-p,--parm}'[topology file to load]:file:_files' \
  '*'{-c,--inpcrd}'[inpcrd file to load]:file:_files' \
  '(-O --overwrite)'{-O,--overwrite}'[allow overwriting existing files]' \
  '(-l --logfile)'{-l,--logfile}'[log file for interactive session]:file:_files' \
  '--prompt[string to use as command prompt]:prompt:' \
  '(-n --no-splash)'{-n,--no-splash}'[do not print greeting logo]' \
  '(-e --enable-interpreter)'{-e,--enable-interpreter}'[allow arbitrary Python code]' \
  '(-s --strict)'{-s,--strict}'[stop on unrecognized input or errors]' \
  '(-r --relaxed)'{-r,--relaxed}'[ignore unrecognized input, skip failed actions]' \
  '*:file:_files' && ret=0

return ret
