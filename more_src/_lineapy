#compdef lineapy
# Documentation: https://docs.lineapy.org/0.2/reference/lineapy/cli/cli/
# LineaPy - capture, analyze and automate data science workflows

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[print debug logging]' \
  '--home-dir=[LineaPy home directory]:dir:_files -/' \
  '--database-url=[database connection url]:url:' \
  '--artifact-storage-dir=[artifact storage directory]:dir:_files -/' \
  '--customized-annotation-dir=[custom annotation directory]:dir:_files -/' \
  '--do-not-track=[disable anonymous usage tracking]:bool:(true false)' \
  '--logging-level=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--logging-file=[file to write logs to]:file:_files' \
  '--mlflow-registry-uri=[MLflow registry uri]:uri:' \
  '--mlflow-tracking-uri=[MLflow tracking uri]:uri:' \
  '--default-ml-models-storage-backend=[default ML model storage backend]:backend:' \
  '1:command:(init annotate python file notebook jupyter ipython jupytext benchmark)' \
  '*::arg:_files' && ret=0

return ret
