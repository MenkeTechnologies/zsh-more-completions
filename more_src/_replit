#compdef replit

_replit() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--version[Show the version and exit]'
        '--help[Show the help message and exit]'
    )

    subcmds=(
        'set:Add a given key-value pair to the DB'
        'del:Delete the key-value pair located at the given key'
        'match:List all keys that match the given prefix'
        'dump:Write all keys and values in the DB to a JSON file'
        'nuke:Wipe ALL key-value pairs in the DB'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'replit commands' subcmds
            ;;
        args)
            case $line[1] in
                set)
                    _arguments \
                        '1:key:' \
                        '2:value:'
                    ;;
                del)
                    _arguments \
                        '1:key:'
                    ;;
                match)
                    _arguments \
                        '1:prefix:'
                    ;;
                dump)
                    _arguments \
                        '1:file path:_files'
                    ;;
                nuke)
                    _arguments \
                        '--i-am-sure[Required to confirm the operation]'
                    ;;
            esac
            ;;
    esac
}

_replit "$@"
