#compdef codeium

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'auth:manage authentication'
      'install:install Codeium'
      'version:show version information'
    )
    _describe -t commands 'codeium command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        local -a auth_commands
        auth_commands=(
          'login:log in to Codeium'
          'logout:log out of Codeium'
          'token:show authentication token'
        )
        _describe -t commands 'auth command' auth_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
