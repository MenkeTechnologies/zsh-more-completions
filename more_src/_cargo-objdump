# Documentation: https://github.com/rust-embedded/cargo-binutils (src/tool.rs + src/lib.rs)
# Reference accessed: 2026-05-29
# cargo-binutils: cargo subcommand frontends for llvm-* binutils.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--lib[build only the package library]' \
  '--bin=[build only the specified binary]:name:' \
  '--example=[build only the specified example]:name:' \
  '--test=[build only the specified test target]:name:' \
  '--bench=[build only the specified bench target]:name:' \
  '--release[compile in release mode with optimizations]' \
  '--profile=[build using a specified custom profile]:profile:(dev release test bench)' \
  '--target=[compile for a target triple]:triple:' \
  '--target-dir=[directory for all generated artifacts]:dir:_directories' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
  '*--features=[space-separated features to enable]:features:' \
  '--all-features[activate all available features]' \
  '--no-default-features[disable the default feature]' \
  '(-p --package)'{-p,--package=}'[package to build]:spec:' \
  '(-j --jobs)'{-j,--jobs=}'[parallel job count]:n:' \
  '*--config=[override configuration values]:config:' \
  '--color=[control output coloring]:when:(auto always never)' \
  '(-q --quiet)'{-q,--quiet}'[suppress build output]' \
  '*'{-v,--verbose}'[verbose output (stackable)]' \
  '--frozen[require up-to-date Cargo.lock]' \
  '--locked[require up-to-date Cargo.lock]' \
  '--offline[run without network access]' \
  '*-Z[pass unstable nightly-only flag]:flag:' \
  '*::llvm-tool arguments:_files' && ret=0

return ret
