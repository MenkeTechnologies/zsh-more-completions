autoload -U is-at-least

_timewall() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_timewall_commands" \
"*::: :->timewall" \
&& ret=0
    case $state in
    (timewall)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:timewall-command-$line[1]:"
        case $line[1] in
            (info)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Path to HEIF wallpaper file:_files' \
&& ret=0
;;
(preview)
_arguments "${_arguments_options[@]}" : \
'-d+[Delay between wallpaper changes in milliseconds]:DELAY:_default' \
'--delay=[Delay between wallpaper changes in milliseconds]:DELAY:_default' \
'-r[Repeat the preview in a loop until killed]' \
'--repeat[Repeat the preview in a loop until killed]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Path to HEIF wallpaper file:_files' \
&& ret=0
;;
(unpack)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Path to HEIF wallpaper file:_files' \
':output -- Path to output directory:_files' \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
'-a+[Use light or dark variant]:APPEARANCE:(light dark)' \
'--appearance=[Use light or dark variant]:APPEARANCE:(light dark)' \
'-d[Run continuously and update the wallpaper as time passes]' \
'--daemon[Run continuously and update the wallpaper as time passes]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
'::file -- Path to HEIF wallpaper file:_files' \
&& ret=0
;;
(unset)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
'-a[Clear all - do not skip the currently set wallpaper]' \
'--all[Clear all - do not skip the currently set wallpaper]' \
'*-v[Increase logging verbosity]' \
'*--verbose[Increase logging verbosity]' \
'(-v --verbose)*-q[Decrease logging verbosity]' \
'(-v --verbose)*--quiet[Decrease logging verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_timewall__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:timewall-help-command-$line[1]:"
        case $line[1] in
            (info)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(preview)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(unpack)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(unset)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clear)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_timewall_commands] )) ||
_timewall_commands() {
    local commands; commands=(
'info:Print out wallpaper info' \
'preview:Quickly cycle through all images in the wallpaper' \
'unpack:Extract all images and metadata from HEIF wallpaper to a directory' \
'set:Set the wallpaper' \
'unset:Try to unset the wallpaper' \
'clear:Clear the wallpaper cache' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'timewall commands' commands "$@"
}
(( $+functions[_timewall__clear_commands] )) ||
_timewall__clear_commands() {
    local commands; commands=()
    _describe -t commands 'timewall clear commands' commands "$@"
}
