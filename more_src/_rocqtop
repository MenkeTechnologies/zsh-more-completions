#compdef rocqtop
# Documentation: https://github.com/rocq-prover/rocq/blob/master/topbin/coqtop_bin.ml
# Documentation: https://github.com/rocq-prover/rocq/blob/master/man/coqtop.1
# Reference accessed: 2026-05-27
# Verified: upstream rocq-prover/rocq master branch; rocqtop reuses the coqtop option set

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '*-I+[add ML loadpath]:dir:_files -/' \
  '*--include+[add ML loadpath]:dir:_files -/' \
  '*-Q+[add local loadpath]:dir:_files -/:dirpath:' \
  '*-R+[add installed loadpath (recursive)]:dir:_files -/:dirpath:' \
  '*-exclude-dir+[skip subdirectories]:dir:_files -/' \
  '-nois[start with an empty initial state]' \
  '-noinit[alias for -nois]' \
  '-init-file+[set rcfile to file]:file:_files' \
  '-q[skip loading rcfile]' \
  '-top+[set toplevel name]:dirpath:' \
  '-topfile+[set the toplevel file name]:file:_files' \
  '*-require+[load Rocq library]:qualid:' \
  '*-ri+[load and import library]:qualid:' \
  '*-require-import+[load and import library]:qualid:' \
  '*-re+[load and transitively import library]:qualid:' \
  '*-require-export+[load and transitively import library]:qualid:' \
  '*-rfrom+[load library from a directory]:root:' \
  '*-require-from+[load library from a directory]:root:' \
  '*-rifrom+[load and import from a directory]:root:' \
  '*-require-import-from+[load and import from a directory]:root:' \
  '*-refrom+[load and transitively import from a directory]:root:' \
  '*-require-export-from+[load and transitively import from a directory]:root:' \
  '*-l+[load Rocq file]:file:_files -g "*.v"' \
  '*-load-vernac-source+[load Rocq file]:file:_files -g "*.v"' \
  '*-lv+[verbosely load Rocq file]:file:_files -g "*.v"' \
  '*-load-vernac-source-verbose+[verbosely load Rocq file]:file:_files -g "*.v"' \
  '*-load-vernac-object+[obsolete synonym of -require]:lib:' \
  '*-load-ml-source+[load ML source file]:file:_files' \
  '*-load-ml-object+[load ML object file]:file:_files' \
  '*-arg+[pass option to compiler]:arg:' \
  '-batch[batch mode (exits after argument parsing)]' \
  '-compat+[provide compatibility with a previous version]:version:' \
  '-beautify[pretty-print the input file]' \
  '-color+[control color output]:when:(yes no auto)' \
  '-config[print Rocq configuration and exit]' \
  '-coqlib+[override default Rocq library directory]:dir:_files -/' \
  '-debug[turn on debugging]' \
  '-bt[print backtraces on errors]' \
  '-emacs[tells Rocq it is executed under Emacs]' \
  '-filteropts[print remaining options after filtering]' \
  '-impredicative-set[set sort Set impredicative]' \
  '-indices-matter[universe-polymorphic inductives indices matter]' \
  '-mangle-names+[mangle names with a prefix]:prefix:' \
  '-native-compiler+[control native compilation]:mode:(yes no ondemand)' \
  '-native-output-dir+[output directory for native code]:dir:_files -/' \
  '-no-glob[do not emit glob files]' \
  '-dump-glob+[dump globalizations to a file]:file:_files' \
  '-m+[memory limit in MB]:mb:' \
  '-memory-limit+[set memory limit]:mb:' \
  '-output-context[print the global vernacular context]' \
  '-profile+[write profile to file]:file:_files' \
  '-quick[generate vio quickly]' \
  '*-set+[set a runtime flag]:flag:' \
  '*-unset+[unset a runtime flag]:flag:' \
  '-toploop+[use given toploop]:module:' \
  '-w+[warning settings]:warnings:' \
  '-where[print Rocq standard library location and exit]' \
  '-v[print version and exit]' \
  '-version[print version and exit]' \
  '--version[print version and exit]' \
  '-print-version[print machine-readable version and exit]' \
  '--print-version[print machine-readable version and exit]' \
  '-boot[boot mode]' \
  '-dont-load-proofs[do not load opaque proofs in memory]' \
  '(- *)'{-h,-H,-help,--help}'[show help]' \
  '*:file:_files -g "*.v"' && ret=0

return ret
