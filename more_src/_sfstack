#compdef sfstack
# Documentation: https://raw.githubusercontent.com/ahay/src/master/system/main/stack.c
# Madagascar: stack a dataset over one of the dimensions

local ret=1

_arguments -s \
  'axis=[which axis to stack (0 = all dimensions)]:axis' \
  'scale=[optionally scale before stacking]:scale' \
  'rms=[if y compute root-mean-square instead of stack]:rms:(y n)' \
  'norm=[if y normalize by fold]:norm:(y n)' \
  'min=[if y find minimum instead of stack]:min:(y n)' \
  'max=[if y find maximum instead of stack]:max:(y n)' \
  'prod=[if y find product instead of stack]:prod:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
