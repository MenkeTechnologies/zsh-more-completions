#compdef lazygit
# Documentation: source-direct extraction from upstream
# jesseduffield/lazygit pkg/app/entry_point.go (Go-based
# CLI using **flaggy** library from `github.com/integrii/
# flaggy` — NOT cobra, NOT pflag):
#   pkg/app/entry_point.go lines 29-44 (cliArgs struct
#     with 13 fields)
#   pkg/app/entry_point.go lines 180-247 (parseCliArgsAndEnvVars
#     fn — 13 `flaggy.String/Bool` calls + 1
#     `flaggy.AddPositionalValue`)
#   pkg/app/entry_point.go lines 249-271 (parseGitArg fn:
#     valid values are status/branch/log/stash)
#   pkg/app/entry_point.go lines 213 + 216 (env var
#     defaults: `os.Getenv("GIT_WORK_TREE")`,
#     `os.Getenv("GIT_DIR")`)
#   pkg/app/entry_point.go lines 84-90 (CONFIG_DIR /
#     LG_CONFIG_FILE env-var bridging)
# Reference accessed: 2026-05-30 via gh api.
#
# lazygit is the **terminal UI for git** from jesseduffield
# — terminal-based interactive git client with vim-style
# keybindings, panels for status/branches/log/stash, and
# extensive customization.  Pivots from theming (R262
# matugen) into the **terminal UI tooling cluster**.
# Sister to lazydocker / lazyjj / lazysql / atac /
# slumber / yazi (all in corpus).  Major TUI tool.
#
# Critical extraction note: lazygit uses the **flaggy**
# library at `github.com/integrii/flaggy` — this is the
# **corpus's first documented flaggy CLI** (every prior
# Go CLI in the corpus used cobra/pflag; every prior Rust
# CLI used clap).  Documents the **3-way Go CLI library
# taxonomy**: (a) cobra (most popular; subcommand-first;
# kubectl/gh/gitsign/etc.), (b) pflag (POSIX-style flag
# parsing; primitive), (c) **flaggy** (simpler than cobra,
# more featureful than stdlib flag; auto-help generation;
# positional + named args).  flaggy API: `flaggy.String(&var,
# "short", "long", "help")` declares a flag; `flaggy.Bool(...)`
# for booleans; `flaggy.AddPositionalValue(&var, "name",
# index, required, "help")` for positionals; `flaggy.Parse()`
# to dispatch.  flaggy distinguishes from cobra by being
# **flat-only** (no subcommands by default; you add
# subcommands via Subcommand objects) which suits CLIs
# like lazygit that have no subcommand surface.
#
# Critical extraction note: lazygit uses **MULTI-CHAR
# "SHORT" FLAGS** like `-cd`, `-ucd`, `-ucf`, `-sm` at
# entry_point.go:208, 211, 220, 223 — flaggy treats both
# short and long names symmetrically, so a "short" name
# can be multiple characters.  Standard Unix CLIs use
# single-character short flags (`-c`/`--config`); lazygit
# uses 2-3 char "shorts" (`-cd`/`--print-config-dir`,
# `-ucd`/`--use-config-dir`, `-ucf`/`--use-config-file`,
# `-sm`/`--screen-mode`).  Documents the **multi-char
# short-flag convention** — unusual but valid.  Corpus's
# **first documented multi-char short flag** (every prior
# clap-based CLI restricted shorts to single chars per
# clap's convention).
#
# Critical extraction note: lazygit uses **env-var-as-
# default** at entry_point.go:213 + 216 — `flaggy.String
# (&workTree, "w", "work-tree", "...")` is preceded by
# `workTree := os.Getenv("GIT_WORK_TREE")` so the env
# var's value becomes the default for the flag.  Plus
# at entry_point.go:84-90 the parsed CLI value is REINJECTED
# into env vars via `os.Setenv("LG_CONFIG_FILE", cliArgs.
# CustomConfigFile)` so downstream code reading env vars
# sees the CLI override.  Documents the **bidirectional
# env-var-flag bridging** pattern in Go CLIs — env var
# initializes the flag default, then the parsed flag
# value is exported back as an env var for child processes
# / library code that reads env directly.  Distinct from
# R252 saya's `#[clap(long, env)]` (Rust clap auto-bridges
# in both directions) — flaggy requires manual bridging.
#
# Critical extraction note: lazygit's `git-arg` positional
# uses `flaggy.AddPositionalValue(&gitArg, "git-arg", 1,
# false, "...")` at entry_point.go:190 — the 4th arg
# (`required`) is `false` so the positional is OPTIONAL.
# Valid values restricted to `status / branch / log /
# stash` (decoded source-direct from parseGitArg switch
# at lines 254 + 258-263).  When invalid, lazygit exits
# with "Invalid git arg value: '...'. Must be one of:
# status, branch, log, stash".  Documents the **flaggy
# positional value with custom validation** pattern —
# flaggy doesn't have built-in restricted-value validators
# like clap's ValueEnum, so the validation is done
# manually in a switch.  Distinct from R249 cairo-profiler's
# clap-restricted value via ValueEnum.
#
# Critical extraction note: lazygit uses **deferred env-
# var bridging** at entry_point.go:227-229 — `if os.Getenv
# ("DEBUG") == "TRUE" { debug = true }` AFTER `flaggy.
# Parse()` to handle the legacy `DEBUG=TRUE` env var as
# an alternative to `--debug`.  Documents the **env-as-
# fallback pattern** — env var only applied if explicit
# flag wasn't set.  Practical for backward compatibility
# with older env-var-driven workflows.

local curcontext="$curcontext" state line

# Valid git-arg positional values (Panel to focus upon
# opening lazygit).  Decoded source-direct from parseGitArg
# at entry_point.go lines 254 + 258-263.
local -a git_arg_values=(
  'status:focus the Status panel (default)'
  'branch:focus the Branches panel'
  'log:focus the Commits/Log panel'
  'stash:focus the Stash panel'
)

# screen-mode valid values from --screen-mode help text
# at entry_point.go:223 ("normal / half / full").
local -a screen_modes=(
  'normal:standard panel layout (default)'
  'half:focused panel takes half the screen'
  'full:focused panel takes the full screen'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the current version]' \
  '(-p --path)'{-p+,--path=}'[path to git repo (equivalent to --work-tree=PATH --git-dir=PATH/.git/)]:dir:_files -/' \
  '(-f --filter)'{-f+,--filter=}'[path to filter on in `git log -- <path>` (filter mode: commits/reflog/stash filtered + ops restricted)]:path:_files' \
  '(-d --debug)'{-d,--debug}'[debug mode with logging (set LOG_LEVEL=debug/info/warn/error; can also be set via env DEBUG=TRUE)]' \
  '(-l --logs)'{-l,--logs}'[tail lazygit logs (intended for separate terminal tab while `lazygit --debug` runs)]' \
  '--profile[start the pprof profiler on http://localhost:6060]' \
  '(-c --config)'{-c,--config}'[print the default config to stdout]' \
  '(-cd --print-config-dir)-cd[print the config directory (multi-char short flag)]' \
  '(-cd --print-config-dir)--print-config-dir[print the config directory]' \
  '(-ucd --use-config-dir)-ucd+[override default config directory (multi-char short flag)]:dir:_files -/' \
  '(-ucd --use-config-dir)--use-config-dir=[override default config directory]:dir:_files -/' \
  '(-w --work-tree)'{-w+,--work-tree=}'[equivalent of git --work-tree arg (default: env GIT_WORK_TREE)]:dir:_files -/' \
  '(-g --git-dir)'{-g+,--git-dir=}'[equivalent of git --git-dir arg (default: env GIT_DIR)]:dir:_files -/' \
  '(-ucf --use-config-file)-ucf+[comma-separated list of custom config files (multi-char short flag)]:files:_files -g "*.yml"' \
  '(-ucf --use-config-file)--use-config-file=[comma-separated list of custom config files]:files:_files -g "*.yml"' \
  '(-sm --screen-mode)-sm+[initial screen-mode (multi-char short flag)]:mode:(($screen_modes))' \
  '(-sm --screen-mode)--screen-mode=[initial screen-mode]:mode:(($screen_modes))' \
  '1::git-arg (optional panel to focus):(($git_arg_values))'
