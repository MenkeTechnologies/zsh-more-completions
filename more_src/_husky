#compdef husky

# Zsh completion for husky - Git hooks manager

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a hook_names=(
  'pre-commit'
  'prepare-commit-msg'
  'commit-msg'
  'post-commit'
  'pre-push'
  'pre-rebase'
  'post-rewrite'
  'post-checkout'
  'post-merge'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize husky'
      'install:Install git hooks (deprecated in v9)'
      'set:Set a hook command'
      'add:Add a command to a hook'
      'uninstall:Uninstall git hooks'
    )
    _describe -t commands 'husky command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      set|add)
        _arguments \
          '1:hook name:(pre-commit prepare-commit-msg commit-msg post-commit pre-push pre-rebase post-rewrite post-checkout post-merge)' \
          '2:command' && ret=0
        ;;
    esac
    ;;
esac

return ret
