#compdef quay quay-cli
# _quay — Red Hat Quay container registry CLI alias (Red Hat, Python/Go); custom argparse
# upstream: https://github.com/quay/quay

_quay() {
    local -a sub=(
        'login:login to Quay'
        'logout:logout from Quay'
        'pull:pull image'
        'push:push image'
        'tag:manage tags'
        'list:list repositories'
        'info:show registry info'
        'config:configure CLI'
        'organization:manage organizations'
        'repository:manage repositories'
        'team:manage teams'
        'user:manage users'
        'robot:manage robot accounts'
        'permission:manage permissions'
        'logs:fetch logs'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--registry=+[registry URL]:url:_urls' \
        '-r+[registry URL]:url:_urls' \
        '--token=+[OAuth token]:str:' \
        '-t+[OAuth token]:str:' \
        '--username=+[username]:str:_users' \
        '-u+[username]:str:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--insecure[skip TLS verify]' \
        '--output=+[output format]:fmt:(json yaml table)' \
        '-o+[output format]:fmt:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quay subcommand' sub ;;
        args)
            case $words[1] in
                repository) _arguments \
                    '1:cmd:(create list get update delete visibility)' \
                    '*:repo:' ;;
                organization) _arguments \
                    '1:cmd:(create list get update delete)' \
                    '*:org:' ;;
                team) _arguments \
                    '1:cmd:(create list get update delete add-member remove-member)' \
                    '*:team:' ;;
                user) _arguments \
                    '1:cmd:(create list get update delete)' \
                    '*:user:_users' ;;
                robot) _arguments \
                    '1:cmd:(create list get delete regenerate)' \
                    '*:robot:' ;;
                permission) _arguments \
                    '1:cmd:(grant revoke list)' \
                    '*:arg:' ;;
                tag) _arguments \
                    '1:cmd:(list create delete restore)' \
                    '--repository=+[repository]:str:' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_quay "$@"
