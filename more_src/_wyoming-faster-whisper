#compdef wyoming-faster-whisper
# Documentation: https://github.com/rhasspy/wyoming-faster-whisper/blob/master/wyoming_faster_whisper/__main__.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse definitions in wyoming_faster_whisper/__main__.py (rhasspy/wyoming-faster-whisper).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--uri=[server URI: unix:// or tcp://]:uri:' \
  '--zeroconf=[enable zeroconf discovery with optional name]:name:' \
  '--model=[name of model to use]:model:(tiny tiny.en base base.en small small.en medium medium.en large large-v1 large-v2 large-v3 distil-small.en distil-medium.en distil-large-v2 distil-large-v3 auto)' \
  '--data-dir=[data directory containing downloaded models]:dir:_files -/' \
  '--download-dir=[directory to download models into]:dir:_files -/' \
  '--device=[device for inference]:device:(cpu cuda auto)' \
  '--language=[default language for transcription]:lang:(auto en zh de es ru ko fr ja pt tr pl ca nl ar sv it id hi fi vi he uk el ms cs ro da hu ta no th ur hr bg lt la mi ml cy sk te fa lv bn sr az sl kn et mk br eu is hy ne mn bs kk sq sw gl mr pa si km sn yo so af oc ka be tg sd gu am yi lo uz fo ht ps tk nn mt sa lb my bo tl mg as tt haw ln ha ba jw su)' \
  '--compute-type=[compute precision]:type:(default float16 float32 int8 int8_float16 int8_float32 int16 bfloat16)' \
  '--beam-size=[beam size during decoding (0 for auto)]:n:' \
  '--cpu-threads=[number of CPU threads for inference]:n:' \
  '--initial-prompt=[prompt text for the first window]:prompt:' \
  '--vad-filter[enable Silero VAD to filter non-speech]' \
  '--vad-threshold=[VAD speech probability threshold]:float:' \
  '--vad-min-speech-ms=[VAD minimum speech duration in ms]:ms:' \
  '--vad-min-silence-ms=[VAD minimum silence duration in ms to split]:ms:' \
  '--stt-library=[library to use for speech-to-text]:lib:(auto faster-whisper whisper)' \
  '--local-files-only[do not check HuggingFace hub for updates]' \
  '--debug[log DEBUG messages]' \
  '--log-format=[python logging format string]:format:' \
  '--version[print version and exit]' && ret=0

return ret
