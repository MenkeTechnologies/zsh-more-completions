#compdef bowtie bowtie-align-l bowtie-align-s bowtie-build bowtie-inspect
# _bowtie — Ben Langmead Cole Trapnell bowtie original ultrafast memory-efficient short read aligner predecessor to Bowtie2 (langmead-lab team, C++); custom argparse
# upstream: https://github.com/BenLangmead/bowtie

_bowtie() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-q[FASTQ input]' \
        '-f[FASTA input]' \
        '-r[raw reads input]' \
        '-C[colorspace alignment]' \
        '-s+[skip first N reads]:n:' \
        '--skip=+[skip first N reads]:n:' \
        '-u+[only first N reads]:n:' \
        '--upto=+[only first N reads]:n:' \
        '-5+[trim N bases from 5p end]:n:' \
        '--trim5=+[trim N bases from 5p end]:n:' \
        '-3+[trim N bases from 3p end]:n:' \
        '--trim3=+[trim N bases from 3p end]:n:' \
        '--phred33-quals[Phred+33]' \
        '--phred64-quals[Phred+64]' \
        '--solexa-quals[Solexa quality scale]' \
        '--solexa1.3-quals[Solexa 1.3 quality scale]' \
        '--integer-quals[integer quality values]' \
        '-v+[max mismatches]:n:' \
        '-n+[max mismatches in seed]:n:' \
        '-e+[max sum of quality values at mismatches]:n:' \
        '-l+[seed length]:n:' \
        '--seedmms=+[max mismatches in seed]:n:' \
        '--seedlen=+[seed length]:n:' \
        '--nomaqround[no Maq-like rounding]' \
        '-I+[min insert size]:n:' \
        '--minins=+[min insert size]:n:' \
        '-X+[max insert size]:n:' \
        '--maxins=+[max insert size]:n:' \
        '--fr[fwd-rev orientation]' \
        '--rf[rev-fwd orientation]' \
        '--ff[fwd-fwd orientation]' \
        '--norc[no reverse complement]' \
        '--nofw[no forward strand]' \
        '--maxbts=+[max backtracks]:n:' \
        '-y[try harder to find alignments]' \
        '--tryhard[try harder]' \
        '--chunkmbs=+[memory MB]:n:' \
        '-k+[max alignments to report]:n:' \
        '-a[report all alignments]' \
        '--all[report all alignments]' \
        '-m+[suppress alignments if more than N]:n:' \
        '-M+[discard reads with more than N alignments]:n:' \
        '--best[best alignments first]' \
        '--strata[strata-style reporting]' \
        '-p+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-o+[chunk overlap]:n:' \
        '-z[fragment-output]' \
        '--mm[memory-mapped indexes]' \
        '--shmem[shared memory indexes]' \
        '-S[SAM output]' \
        '--sam[SAM output]' \
        '--sam-RG=+[sam read group]:str:' \
        '--quiet[quiet mode]' \
        '--refout[print reference]' \
        '--refidx[refers to refs as numbers]' \
        '-t[print wall-clock time]' \
        '--time[print wall-clock time]' \
        '--seed=+[random seed]:n:' \
        '*:index reads:'
}

_bowtie "$@"
