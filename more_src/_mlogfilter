#compdef mlogfilter
# mtools filter MongoDB log files by time, slow queries and other attributes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[display parser and argument debugging info]' \
  '--shorten=[shorten long lines to at most LENGTH characters]:length' \
  '--human[make log lines easier to read for humans]' \
  '--exclude[invert filter logic to exclude matching lines]' \
  '--json[output results in JSON format]' \
  '--timestamp-format=[change timestamp format]:format:(ctime-pre2.4 ctime iso8601-utc iso8601-local)' \
  '*--markers=[custom merge markers for multiple files]:markers' \
  '*--timezone=[adjust timestamps by hour offset]:offset' \
  '--namespace=[filter by database.collection namespace]:namespace' \
  '--operation=[filter by operation type]:operation' \
  '--thread=[filter by thread name]:thread' \
  '--slow=[return operations slower than milliseconds]:ms' \
  '--fast=[return operations faster than milliseconds]:ms' \
  '--scan[detect inefficient collection scans]' \
  '*--word=[filter lines containing specified keywords]:word' \
  '*--from=[set log time lower bound]:from' \
  '*--to=[set log time upper bound]:to' \
  '*:logfile:_files' && ret=0

return ret
