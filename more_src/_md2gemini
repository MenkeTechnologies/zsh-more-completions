#compdef md2gemini
# Documentation: https://github.com/makeworld-the-better-one/md2gemini
# Convert Markdown files to Gemini text (gemtext)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show version number and exit]' \
  '(-w --write)'{-w,--write}'[write output to a new file with a .gmi extension]' \
  '(-d --dir)'{-d+,--dir=}'[directory to write files to, if --write is used]:dir:_files -/' \
  '(-a --ascii-table)'{-a,--ascii-table}'[use ASCII to create tables, not Unicode]' \
  '(-f --frontmatter)'{-f,--frontmatter}'[remove Jekyll and Zola style front matter before converting]' \
  '(-j --jekyll)'{-j,--jekyll}'[skip jekyll frontmatter when processing (deprecated)]' \
  '--code-tag=[alt text to add to unlabeled code blocks]:tag' \
  '--img-tag=[text to add after image links]:tag' \
  '--table-tag=[alt text to add to table blocks]:tag' \
  '(-i --indent)'{-i+,--indent=}'[number of spaces to use for list indenting]:indent' \
  '(-l --links)'{-l+,--links=}'[link handling mode]:mode:(off paragraph at-end copy)' \
  '(-p --plain)'{-p,--plain}'[remove markings text/gemini does not support]' \
  '(-s --strip-html)'{-s,--strip-html}'[strip all inline and block HTML from Markdown]' \
  '(-b --base-url)'{-b+,--base-url=}'[prepend this URL to links starting with a slash]:url' \
  '(-m --md-links)'{-m,--md-links}'[convert links to local .md files to end with .gmi]' \
  '(-c --no-checklist)'{-c,--no-checklist}'[disable GitHub-style checklist rendering]' \
  '*:file:_files' && ret=0

return ret
