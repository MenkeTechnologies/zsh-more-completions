#compdef bambutop
# ============================================================================
# _bambutop — zsh completion for the Bambu Labs 3D-printer MQTT TUI monitor
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/rhoopr/bambutop
#   Author     : rhoopr
#   License    : GPL-3.0
#   Stars      : 24
#   Language   : Rust
#   Crate      : bambutop v1.0.1  (Cargo.toml)
#   Binary     : bambutop  (Cargo.toml [package] name = "bambutop";
#                          built from src/main.rs)
#   Last push  : 2026-04-25
#
# WHAT IT IS
#   bambutop is a terminal-based status monitor for Bambu Labs 3D
#   printers built on ratatui + crossterm.  It connects to each
#   configured printer's local MQTT broker (port 8883 by default, with
#   the printer's access code as the password) and subscribes to the
#   printer's status topic, rendering live state, temperature,
#   filament, AMS slots, fan speed, print stage, layer progress, and
#   ETA in an alternate-screen TUI.  Multiple printers can be
#   monitored in a single session and switched via number-key hotkeys
#   (1-9).  A first-run setup wizard collects IP, serial, and access
#   code interactively, with optional CLI overrides for each.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap-derive Args struct)
#   bambutop [-i <IP>] [-s <SERIAL>] [-a <CODE>] [--reset] [--demo]
#
#   Options:
#     -i, --ip <IP>           Printer IP address (overrides config file)
#     -s, --serial <SERIAL>   Printer serial number (overrides config file)
#     -a, --access-code <CODE>
#                             Printer access code (overrides config file)
#         --reset             Delete config and run the setup wizard
#         --demo              Launch with demo data, no printer connection
#                             needed (uses pre-populated fixture state)
#
#   Standard clap auto-flags:
#     -h, --help              Show help
#     -V, --version           Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `rumqttc = "0.24"` declared in Cargo.toml —
#   the canonical Rust MQTT client maintained by Bytebeam Labs
#   (bytebeamio/rumqtt).  rumqttc provides typed async MQTT v3.1.1 /
#   v5.0 publish/subscribe with rustls TLS, automatic reconnect with
#   exponential backoff, persistent session state, and a typed
#   `EventLoop` for handling Incoming/Outgoing packets.  The bambutop
#   `MqttClient` in `src/mqtt.rs` builds one `AsyncClient` per
#   configured Bambu printer, subscribes to the report-status topic,
#   parses each JSON payload, and forwards normalized state through a
#   tokio mpsc to the ratatui render loop.  Verified via:
#     gh api repos/rhoopr/bambutop/contents/Cargo.toml
#       → rumqttc = "0.24"
#     gh api repos/rhoopr/bambutop/contents/src/main.rs
#       → #[derive(Parser, Debug)] struct Args { ip, serial,
#                                                access_code, reset, demo }
#   This entry is the Rust=124 leader bump that OPENS Axis 69
#   (MQTT Client Library), pairing with future Go=eclipse/paho.mqtt.golang
#   and TS-Node=mqtt.js (MQTT.js) poles to close the axis at 1/1/1.
#
#   No completion for `bambutop` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_bambutop() {
    _arguments -s \
        '(-i --ip)'{-i+,--ip=}'[printer IP address (overrides config file)]:IP address:' \
        '(-s --serial)'{-s+,--serial=}'[printer serial number (overrides config file)]:serial:' \
        '(-a --access-code)'{-a+,--access-code=}'[printer access code (overrides config file)]:access code:' \
        '--reset[delete config and run the setup wizard]' \
        '--demo[launch with demo data (no printer connection needed)]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_bambutop "$@"
