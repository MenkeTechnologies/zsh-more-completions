#compdef chessx
# Documentation: https://github.com/Hsync/chessx
# Reference accessed: 2026-05-16
# Verified: upstream Hsync/chessx Qt PGN viewer. GUI app; standard Qt
# args plus PGN file positional. No app-specific CLI flags.
# Removed from prior file: bogus man.archlinux.org search URL.

# chessx: Qt chess database viewer/editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--style=[Qt widget style]:style:' \
  '--display=[X display]:display:' \
  '*:PGN file:_files -g "*.pgn(-.)"' && ret=0
return ret
