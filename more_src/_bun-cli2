#compdef bun-cli2 bun2
# _bun-cli2 — Jarred Sumner Oven bun-cli2 CLI command-line frontend wrapping the Bun open-source incredibly fast JavaScript runtime bundler transpiler and package manager all in one written in Zig and JavaScriptCore originally Jarred Sumner now Oven Inc faster alternative to Node.js JavaScriptCore-based-not-V8 JIT-AOT all-in-one-toolkit-bundler-transpiler-package-manager-test-runner native-TypeScript JSX hot reloading file IO with much lower latency native-bundler-transpiler Web-APIs-compat-Node-stdlib-compat fetch WebSocket import npm-API run dev start test build add install link unlink remove update outdated x bunx create init audit pm publish patch x kill repl x init upgrade bun-cmd build watch hot smol jit cache-dir bunfig (Jarred Sumner Oven Inc team, Zig); custom argparse
# upstream: https://bun.sh/

_bun-cli2() {
    local -a sub=(
        'add:Add a dependency'
        'audit:Run security audit'
        'build:Bundle for production'
        'bunfig:Open the bunfig.toml'
        'completions:Generate shell completions'
        'create:Scaffold a new project'
        'dev:Run dev server'
        'discord:Open Discord'
        'docs:Open Bun docs'
        'help:show help'
        'init:Initialize project'
        'install:Install dependencies'
        'link:Link a package'
        'outdated:List outdated packages'
        'pack:Create a tarball'
        'patch:Patch a package'
        'patch-commit:Commit a patch'
        'pm:Show package manager utilities'
        'publish:Publish a package'
        'remove:Remove a dependency'
        'repl:Open JS REPL'
        'run:Run a script'
        'start:Run start script'
        'test:Run tests'
        'unlink:Unlink a package'
        'update:Update dependencies'
        'upgrade:Upgrade Bun'
        'x:Run a package via bunx'
        'kill:Kill the bun daemon'
        'why:Show why a package is installed'
        'shell:Open shell'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--watch[watch for changes]' \
        '--hot[hot reload]' \
        '--smol[smaller heap]' \
        '--inspect=+[host:port]:str:' \
        '--inspect-brk=+[host:port]:str:' \
        '--inspect-wait=+[host:port]:str:' \
        '--no-install[no install]' \
        '--no-summary[no summary]' \
        '--no-progress[no progress]' \
        '--no-save[no save]' \
        '--no-cache[no cache]' \
        '--no-lockfile[no lockfile]' \
        '--no-frozen-lockfile[no frozen lockfile]' \
        '--no-verify[no verify]' \
        '--silent[silent]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "bunfig.toml *.toml"' \
        '-c+[config]:file:_files -g "bunfig.toml *.toml"' \
        '--env-file=+[file]:file:_files -g ".env*"' \
        '*--env-file=+[file]:file:_files -g ".env*"' \
        '--define=+[k=v]:str:' \
        '*--define=+[k=v]:str:' \
        '-d+[k=v]:str:' \
        '*-d+[k=v]:str:' \
        '--tsconfig-override=+[file]:file:_files -g "tsconfig.json *.json"' \
        '--target=+[t]:t:(bun browser node)' \
        '--outdir=+[dir]:dir:_files -/' \
        '--outfile=+[file]:file:_files' \
        '--entry-naming=+[fmt]:str:' \
        '--chunk-naming=+[fmt]:str:' \
        '--asset-naming=+[fmt]:str:' \
        '--public-path=+[path]:str:' \
        '--external=+[mod]:str:' \
        '*--external=+[mod]:str:' \
        '--splitting[code splitting]' \
        '--minify[minify all]' \
        '--minify-whitespace[minify whitespace]' \
        '--minify-identifiers[minify identifiers]' \
        '--minify-syntax[minify syntax]' \
        '--sourcemap=+[s]:s:(none inline external linked)' \
        '--format=+[f]:f:(esm cjs iife)' \
        '--loader=+[ext:loader]:str:' \
        '*--loader=+[ext:loader]:str:' \
        '--root=+[dir]:dir:_files -/' \
        '--banner=+[text]:str:' \
        '--footer=+[text]:str:' \
        '--bytecode[bytecode]' \
        '--bun[force run with bun]' \
        '-b[force run with bun]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--inspect[start inspector]' \
        '--inspector[start inspector]' \
        '-i[interactive shell]' \
        '--print=+[expression]:str:' \
        '-e+[print]:str:' \
        '--main[show main file]' \
        '--shell=+[name]:str:' \
        '-Z[end of options]' \
        '--filter=+[name]:str:' \
        '*--filter=+[name]:str:' \
        '-F+[filter]:str:' \
        '*-F+[filter]:str:' \
        '--elide-lines=+[N]:n:' \
        '--timeout=+[ms]:n:' \
        '--bail[bail on test failure]' \
        '--rerun-each=+[N]:n:' \
        '--coverage[enable coverage]' \
        '--coverage-reporter=+[r]:r:(text lcov)' \
        '--coverage-dir=+[dir]:dir:_files -/' \
        '--update-snapshots[update snapshots]' \
        '--only[run only]' \
        '--todo[run todo]' \
        '--print-stack-trace[print stack]' \
        '--reporter=+[r]:str:' \
        '--reporter-outfile=+[file]:file:_files' \
        '--test-name-pattern=+[pattern]:str:' \
        '-t+[pattern]:str:' \
        '--prefer-offline[prefer offline]' \
        '--save[save]' \
        '--exact[exact version]' \
        '--dev[dev dep]' \
        '-D[dev dep]' \
        '--optional[optional dep]' \
        '--peer[peer dep]' \
        '--no-optional[no optional]' \
        '--production[production mode]' \
        '--workspace=+[name]:str:' \
        '-w+[workspace]:str:' \
        '--global[global install]' \
        '-g[global]' \
        '--check[check only]' \
        '--auto[auto]' \
        '--force[force install]' \
        '-f[force]' \
        '--registry=+[url]:str:' \
        '--otp=+[code]:str:' \
        '--access=+[a]:a:(public restricted)' \
        '--tag=+[name]:str:' \
        '--dry-run[dry run]' \
        '--allow=+[scripts]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bun subcommand' sub ;;
        args)
            case $words[1] in
                run|x|build|test|repl|init|create|dev|start|link|unlink|publish|patch|patch-commit|why) _arguments '*:arg:' ;;
                add|remove|update) _arguments '*:package:' ;;
                pm) _arguments '1:op:(ls hash hash-string hash-print cache bin trust untrusted version migrate)' '*:arg:' ;;
                completions) _arguments '1:shell:(bash zsh fish)' ;;
                kill) _arguments '1:server:' ;;
            esac
            ;;
    esac
}

_bun-cli2 "$@"
