#compdef unipacker
# Documentation: https://github.com/unipacker/unipacker
# Un{i}packer - automatic, platform-independent unpacker for Windows binaries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dest)'{-d,--dest}'[destination directory for unpacked binaries]:dir:_files -/' \
  '(-p --partition-by-packer)'{-p,--partition-by-packer}'[group the unpacked files by packer]' \
  '(-i --interactive)'{-i,--interactive}'[open the chosen sample(s) in the unipacker shell]' \
  '--version[show version information and exit]' \
  '*:samples:_files' && ret=0

return ret
