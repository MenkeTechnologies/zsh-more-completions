#compdef qjs
# Documentation: https://man.archlinux.org/search?q=qjs
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-i --interactive)'{-i,--interactive}'[Interactive REPL]' \
  '(-e --eval)'{-e,--eval}'=[Evaluate expression]:code:' \
  '(-m --module)'{-m,--module}'[Load as ES module]' \
  '--stack-size=[Stack size]:size:' \
  '*:script or args:_files'
