#compdef qjs
# Documentation: https://bellard.org/quickjs/quickjs.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-i --interactive)'{-i,--interactive}'[Interactive REPL]' \
  '(-e --eval)'{-e,--eval}'=[Evaluate expression]:code:' \
  '(-m --module)'{-m,--module}'[Load as ES module]' \
  '--stack-size=[Stack size]:size:' \
  '*:script or args:_files'
