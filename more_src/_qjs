#compdef qjs
# Documentation: https://github.com/quickjs-ng/quickjs/blob/master/qjs.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --eval)'{-e,--eval}'+[evaluate expression]:code:' \
  '(-i --interactive)'{-i,--interactive}'[interactive REPL]' \
  '(-C --script -m --module)'{-C,--script}'[load file as classic script]' \
  '(-m --module -C --script)'{-m,--module}'[load file as ES module]' \
  '(-I --include)'{-I,--include}'+[include additional file]:file:_files' \
  '--std[make standard library modules available]' \
  '(-T --trace)'{-T,--trace}'[enable memory allocation tracing]' \
  '(-d --dump)'{-d,--dump}'[display memory usage statistics]' \
  '(-D --dump-flags)'{-D,--dump-flags}'+[set debug data dump options]:flags:' \
  '(-c --compile)'{-c,--compile}'+[create standalone executable from script]:file:_files' \
  '(-o --out)'{-o,--out}'+[output file for standalone builds]:file:_files' \
  '--exe=[base executable for standalone compilation]:executable:_files' \
  '--memory-limit=[memory limit in kbytes]:kb:' \
  '--stack-size=[stack size in kbytes]:kb:' \
  '(-q --quit)'{-q,--quit}'[initialize interpreter and exit immediately]' \
  '*:script or args:_files'
