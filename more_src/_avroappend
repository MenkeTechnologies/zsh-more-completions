#compdef avroappend
# Documentation: https://github.com/apache/avro/blob/main/lang/c/src/avroappend.c
# avroappend - append data from an Avro file to an output Avro file (input stdin if omitted)

local ret=1

_arguments -s -S \
  ':input Avro file:_files' \
  ':output Avro file:_files' && ret=0

return ret
