#compdef saextrct
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/saextrct.txt
# Create light curves and/or spectra from XTE Science Array data

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input FITS file(s) or @ASCII file]:input file:_files' \
  'gtiorfile=[GTI information for each file]:gti file:_files' \
  'gtiandfile=[GTI information applied to all files]:gti file:_files' \
  'gticols=[start and stop column names in GTI file]:columns:' \
  'outroot=[root for the output file name]:root:' \
  'extenpha=[suffix for spectral output file]:suffix:' \
  'extenlc=[suffix for light curve output file]:suffix:' \
  'phasefile=[phase information file for filtering]:phase file:_files' \
  'accumulate=[ONE or MANY output columns]:mode:(ONE MANY)' \
  'timecol=[column containing timing information]:column:' \
  'columns=[column names to bin]:columns:' \
  'binsz=[binsize in seconds for the light curve]:seconds:' \
  'printmode=[output type]:mode:(LIGHTCURVE SPECTRUM BOTH)' \
  'lcmode=[binning type for light curves]:mode:(SUM RATE MEAN EVENT_SUM EVENT_RATE)' \
  'spmode=[binning type for spectra]:mode:(SUM RATE MEAN EVENT_SUM EVENT_RATE)' \
  'timeint=[time intervals in absolute time or @file]:intervals:' \
  'chmin=[minimum energy channel to include]:channel:' \
  'chmax=[maximum energy channel to include]:channel:' \
  'chint=[channel bins to include]:channels:' \
  'clobber=[overwrite existing output files]:flag:(yes no)' \
  'negative=[handle negative count rates]:mode:(IGNORE SUM)' \
  'dryrun=[test input compatibility without processing]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
