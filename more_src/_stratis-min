#compdef stratis-min
# _stratis-min — minimal stratisd JSON-RPC client (stratis-storage/stratisd)
# upstream: https://github.com/stratis-storage/stratisd
# Subcommands from src/bin/stratis-min/stratis-min.rs (clap builder).

_stratis-min() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--debug[enable debug output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(key:'manage keys' pool:'manage pools' filesystem:'manage filesystems' report:'print engine report')
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                key) _arguments '1:subcommand:(set list unset)' '*::: :_files' ;;
                pool) _arguments '1:subcommand:(start stop create init-cache rename add-data add-cache destroy is-encrypted is-stopped has-passphrase is-bound bind unbind rebind)' '*::: :_files' ;;
                filesystem) _arguments '1:subcommand:(create destroy rename origin)' ;;
            esac
            ;;
    esac
}

_stratis-min "$@"
