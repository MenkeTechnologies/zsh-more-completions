(( $+functions[_klef_commands] )) ||
_klef_commands() {
    local commands; commands=(
'add:Add a new key. Reads value from a TTY prompt or stdin' \
'get:Print the value of a key on stdout' \
'show:Display a key'\''s value formatted for human reading' \
'list:List stored keys (names + metadata, never values)' \
'rm:Remove a key' \
'edit:Edit a key (prompts for new value if no flag given)' \
'rename:Rename a key' \
'set-note:Shortcut for \`klef edit <name> --note <text>\`' \
'export:Print \`export VAR=value\` lines for eval' \
'run:Run a command with \`klef\:<name>\` references in \`.env\` resolved' \
'completions:Generate shell completion script for <shell> on stdout' \
'status:Print runtime diagnostic state (backend, index, key count, desync)' \
'import:Bulk import secrets from a .env file' \
'discover:Walk the filesystem and bulk-import secrets from every .env file found' \
'backup:Encrypted backup of the entire vault (values + metadata) to a single .age file' \
'restore:Restore the vault from a klef backup file' \
'tags:List all tags in the vault with the count of keys carrying each' \
'_names:Internal\: print one stored key name per line. Used by shell completion scripts. Hidden from --help' \
'keychain:macOS keychain helpers (avoid frequent password prompts)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'klef commands' commands "$@"
}
