#compdef jaeger

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--admin.http.host-port=[admin server host:port]:host:port' \
  '--collector.grpc-server.host-port=[collector gRPC host:port]:host:port' \
  '--collector.http-server.host-port=[collector HTTP host:port]:host:port' \
  '--collector.zipkin.host-port=[Zipkin collector host:port]:host:port' \
  '--collector.num-workers=[number of queue consumers]:workers' \
  '--collector.queue-size=[collector queue size]:size' \
  '--config=[config file]:config file:_files' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
  '--metrics-backend=[metrics backend]:backend:(prometheus expvar none)' \
  '--processor.jaeger-binary.server-host-port=[agent binary Thrift host:port]:host:port' \
  '--processor.jaeger-compact.server-host-port=[agent compact Thrift host:port]:host:port' \
  '--processor.zipkin-compact.server-host-port=[agent Zipkin Thrift host:port]:host:port' \
  '--query.base-path=[base path for UI]:path' \
  '--query.grpc-server.host-port=[query gRPC host:port]:host:port' \
  '--query.http-server.host-port=[query HTTP host:port]:host:port' \
  '--query.static-files=[path to static UI files]:directory:_directories' \
  '--query.ui-config=[UI config file]:config file:_files' \
  '--query.max-clock-skew-adjustment=[max clock skew adjustment]:duration' \
  '--reporter.grpc.host-port=[collector gRPC host:port for agent]:host:port' \
  '--reporter.type=[reporter type]:type:(grpc)' \
  '--sampling.strategies-file=[sampling strategies file]:file:_files' \
  '--span-storage.type=[span storage backend]:backend:(cassandra elasticsearch memory badger grpc kafka)' \
  '--es.server-urls=[Elasticsearch server URLs]:urls' \
  '--es.index-prefix=[Elasticsearch index prefix]:prefix' \
  '--cassandra.keyspace=[Cassandra keyspace]:keyspace' \
  '--cassandra.servers=[Cassandra servers]:servers' && ret=0

return ret
