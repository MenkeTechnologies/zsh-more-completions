#compdef dmkeypar
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmkeypar.html
# Read a header keyword value from a Data Model file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file with optional extension]:infile:_files' \
  'keyword=[keyword to retrieve]:keyword:' \
  'echo=[print the retrieved value to screen]:echo:(yes no)' \
  'verbose=[verbosity level]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
