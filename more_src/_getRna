#compdef getRna
# UCSC kent: get mRNA for a list of accessions, writing to a fasta file

local ret=1

_arguments -s -S \
  '-cdsUpper[lookup CDS and output it as upper case]' \
  '-cdsUpperAll[like -cdsUpper but keep sequences without CDS]' \
  '-inclVer[include version with sequence id]' \
  '-peptides[translate mRNAs to peptides]' \
  '-seqTbl=[use this table instead of gbSeq and seq]:tbl' \
  '-extFileTbl=[use this table instead of gbExtFile and extFile]:tbl' \
  '1:database:' \
  '2:accession file:_files' \
  '3:output fasta:_files' && ret=0

return ret
