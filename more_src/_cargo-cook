#compdef cargo-cook
# Documentation: https://crates.io/crates/cargo-cook
# package and deploy your crate's artifacts using a recipe

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --recipe)'{-r,--recipe}'[recipe file to use]:file:_files -g "*.toml"' && ret=0

return ret
