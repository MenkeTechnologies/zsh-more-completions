#compdef asami
# _asami — Paula Gearon Asami in-memory graph database CLI alias (quoll team, Clojure); custom argparse
# upstream: https://github.com/quoll/asami

_asami() {
    local -a sub=(
        'shell:start asami shell'
        'query:run datalog query'
        'transact:run transaction'
        'load:bulk load from JSON or EDN'
        'dump:dump database to file'
        'stats:show database stats'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--url=+[asami url]:str:' \
        '-u+[asami url]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'asami subcommand' sub ;;
        args)
            case $words[1] in
                query) _arguments \
                    '1:query:' \
                    '--file=+[query file]:file:_files' \
                    '-f+[query file]:file:_files' \
                    '--basis=+[basis]:str:' ;;
                transact) _arguments \
                    '1:tx data:' \
                    '--file=+[tx file]:file:_files' \
                    '-f+[tx file]:file:_files' ;;
                load|dump) _arguments \
                    '1:file:_files' \
                    '--format=+[format]:f:(json edn csv)' ;;
            esac
            ;;
    esac
}

_asami "$@"
