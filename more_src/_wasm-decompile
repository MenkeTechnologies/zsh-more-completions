#compdef wasm-decompile
# _wasm-decompile — WABT WebAssembly decompiler; lifts .wasm back to a readable pseudo-C-like notation
# upstream: https://github.com/WebAssembly/wabt

_wasm-decompile() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '--enable-saturating-float-to-int[enable saturating float to int]' \
        '--enable-sign-extension[enable sign extension]' \
        '--enable-simd[enable SIMD]' \
        '--enable-multi-value[enable multi-value]' \
        '--enable-reference-types[enable reference types]' \
        '--enable-bulk-memory[enable bulk memory]' \
        '--enable-tail-call[enable tail calls]' \
        '--enable-threads[enable threads]' \
        '--enable-gc[enable GC]' \
        '--enable-memory64[enable memory64]' \
        '--enable-all[enable all features]' \
        '*:wasm file:_files -g "*.wasm"'
}

_wasm-decompile "$@"
