#compdef termonad
# _termonad — Termonad (Haskell+VTE terminal emulator configured by editing ~/.config/termonad/termonad.hs and recompiling via xmonad-style recompile; --version prints, --help shows usage; supports +RTS GHC runtime args)
# upstream: https://github.com/cdepillabout/termonad
# Flags from termonad app/Main.hs on tip.

_termonad() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--recompile[recompile config and restart]' \
        '+RTS[GHC RTS options follow]' \
        '*:command:_command_names -e'
}

_termonad "$@"
