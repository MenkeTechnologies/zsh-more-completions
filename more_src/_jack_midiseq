#compdef jack_midiseq
# Documentation: https://github.com/jackaudio/example-clients/blob/master/midiseq.c
# Reference accessed: 2026-05-17
# Verified: jackaudio/example-clients midiseq.c (jack_midiseq from
# jack-example-tools, formerly jack-tools). No CLI flags — positional
# only: name nsamp [startindex note nsamp]... with argc >= 6.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h flag (not in upstream).

# jack_midiseq: JACK MIDI sequencer (positional only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:client name:' \
  '2:total samples (nsamp):' \
  '*:startindex note nsamp triple:' && ret=0
return ret
