#compdef lavToAxt
# UCSC kent: convert a blastz lav file to an axt file (which includes sequence)

local ret=1

_arguments -s -S \
  '-fa[qNibDir is a fasta file of multiple dna seq instead of nib directory]' \
  '-tfa[tNibDir is a fasta file of multiple dna seq instead of nib directory]' \
  '-dropSelf[remove alignment blocks on the diagonal for self alignments]' \
  '-scoreScheme=[read the scoring matrix from a blastz-format file]:file:_files' \
  '1:input lav:_files -g "*.lav"' \
  '2:target nib dir or 2bit:_files' \
  '3:query nib dir or 2bit:_files' \
  '4:output axt:_files -g "*.axt"' && ret=0

return ret
