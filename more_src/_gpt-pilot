#compdef gpt-pilot
# Documentation: https://man.archlinux.org/search?q=gpt-pilot
# Reference accessed: 2026-05-16

_gpt-pilot() {
    local -a args
    args=(
        '--step[Start the project from a specific step]:step:(architecture development testing)'
        '--skip-until-dev[Skip initial architecture and task planning]'
        '--theme[Set a specific UI theme]:theme'
        '--delete-project[Delete the current project data and start fresh]'
        '--continue[Resume the last active project session]'
        '--help[Display help message]'
    )

    _arguments -s -S $args
}

_gpt-pilot "$@"
