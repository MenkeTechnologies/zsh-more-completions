#compdef gpt-pilot
# Documentation: https://github.com/Pythagora-io/gpt-pilot
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
    '--list[list all created projects]' \
    '--project=[load and continue from latest step in a project]:app_id:' \
    '--step=[continue from a specific step (deletes progress after)]:step:' \
    '--delete=[delete a project entirely]:app_id:' \
    '--help[display help message]'
