#compdef cloudup
# Documentation: cloudup help (bash-snippets)
# Source: backup GitHub repositories to a Bitbucket account.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-v[show version]' \
    '-p[upload as private to bitbucket]' \
    '-a[backup all GitHub repositories]' \
    '-s[only backup repos you created (no forks, with -a)]' \
    '-t[add timestamp to the destination repo name]' \
    '-u[update bash-snippets tools]' \
    '*:github repo name:' \
    && ret=0

return ret
