#compdef jwtinfo
# Documentation: https://github.com/lmammino/jwtinfo
# jwtinfo - command-line tool to get information about JWTs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--header[print the JWT header instead of the body]' \
  '--full[print both header and claims together]' \
  '--pretty[pretty-print the output with indentation]' \
  '*:token:' && ret=0

return ret
