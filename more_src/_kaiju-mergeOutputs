#compdef kaiju-mergeOutputs
# Documentation: https://github.com/bioinformatics-centre/kaiju
# Merge the classification output of two kaiju runs

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-i[first input file]:input:_files' \
  '-j[second input file]:input:_files' \
  '-o[output file]:output:_files' \
  '-t[nodes.dmp taxonomy file]:nodes:_files' \
  '-c[conflict resolution rule]:rule:(1 2 lca lowest)' \
  '-s[use classification score for conflict resolution]' \
  '-v[verbose output]' \
  '*:file:_files' && ret=0

return ret
