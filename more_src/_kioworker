#compdef kioworker
# Documentation: https://community.kde.org/Guidelines_and_HOWTOs/Debugging/Debugging_KIO_Workers
# Reference accessed: 2026-05-16
# Verified: KDE community wiki for KIO Worker debugging. kioworker is
# an internal binary invoked by the KIO framework with positional
# args (protocol, pool socket, app socket); not user-facing. KIO
# Frameworks 6 rename of kioslave.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# kioworker: internal KIO framework worker (not user-facing)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:protocol:' \
  '2:pool socket:' \
  '3:app socket:' && ret=0
return ret
