#compdef kioworker
# Documentation: https://community.kde.org/Guidelines_and_HOWTOs/Debugging/Debugging_KIO_Workers
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: kioworker is an internal KIO framework binary invoked with
# positional args (protocol, pool socket, app socket); not user-facing.
# KIO Frameworks 6 rename of kioslave. No user CLI flags.

# kioworker: internal KIO framework worker (not user-facing)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:protocol:' \
  '2:pool socket:' \
  '3:app socket:' && ret=0
return ret
