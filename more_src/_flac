#compdef flac

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-H,--explain}'[show explanation of options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --decode)'{-d,--decode}'[decode FLAC to WAV/AIFF]' \
  '(-t --test)'{-t,--test}'[test FLAC stream integrity]' \
  '(-a --analyze)'{-a,--analyze}'[analyze FLAC file]' \
  '-0[fastest compression]' \
  '-1[fast compression]' \
  '-2[fast compression]' \
  '-3[default compression]' \
  '-4[good compression]' \
  '-5[default-good compression]' \
  '-6[best compression]' \
  '-7[best compression]' \
  '-8[slowest, best compression]' \
  '--fast[same as -0]' \
  '--best[same as -8]' \
  '(-V --verify)'{-V,--verify}'[verify encoding]' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-s --silent)'{-s,--silent}'[silent operation]' \
  '(-o --output-name)'{-o,--output-name=}'[output filename]:file:_files' \
  '--output-prefix=[output prefix]:prefix:' \
  '--keep-foreign-metadata[keep foreign metadata in encoded FLAC]' \
  '--keep-foreign-metadata-if-present[keep foreign metadata if present]' \
  '--delete-input-file[delete input after success]' \
  '--preserve-modtime[preserve modification time]' \
  '--no-padding[do not write padding]' \
  '-P=[padding bytes]:n:' \
  '--ogg[output as OGG-FLAC]' \
  '--cuesheet=[cuesheet]:file:_files' \
  '--picture=[picture]:spec:' \
  '*--tag=[Vorbis comment FIELD=VALUE]:tag:' \
  '*--tag-from-file=[Vorbis comment from file FIELD=FILENAME]:spec:' \
  '*-T+[Vorbis comment FIELD=VALUE]:tag:' \
  '--no-cued-seekpoints[do not add seekpoints from cuesheet]' \
  '*-S+[seek point spec]:spec:' \
  '*--seekpoint=[seek point spec]:spec:' \
  '*-A+[apodization function]:func:' \
  '*--apodization=[apodization function]:func:' \
  '-b=[block size]:n:' \
  '*:input:_files'
