#compdef help2man

# Zsh completion for help2man (generate man pages from --help output)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --name)'{-n,--name}'[description for NAME paragraph]:name' \
  '(-s --section)'{-s,--section}'[section number for man page]:section:(1 2 3 4 5 6 7 8)' \
  '(-m --manual)'{-m,--manual}'[name of manual]:manual name' \
  '(-S --source)'{-S,--source}'[source of program]:source' \
  '(-L --locale)'{-L,--locale}'[select locale]:locale' \
  '(-i --include)'{-i,--include}'[include material from file]:file:_files' \
  '(-I --opt-include)'{-I,--opt-include}'[include material from file if it exists]:file:_files' \
  '(-o --output)'{-o,--output}'[output to file]:output file:_files' \
  '(-p --info-page)'{-p,--info-page}'[name of Texinfo manual]:manual' \
  '(-N --no-info)'{-N,--no-info}'[suppress pointer to Texinfo manual]' \
  '(-l --libtool)'{-l,--libtool}'[exclude libtool library wrapper]' \
  '--help-option[help option string]:option string' \
  '--version-option[version option string]:option string' \
  '--version-string[version string]:string' \
  '--no-discard-stderr[include stderr output]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:executable:_command_names -e' && ret=0

return ret
