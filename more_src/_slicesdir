#compdef slicesdir
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/fslwiki/Miscvis
# FSL: call slicer on a list of images and produce a webpage of results

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[filelist is pairs of (underlying red-outline) images]' \
  '-p[use image as red-outline on top of all images in filelist]:image:_files' \
  '-e[use the specified threshold for edges]:thresh:' \
  '-S[output every second axial slice rather than 9 ortho slices]' \
  '*:image:_files' && ret=0

return ret
