#compdef scy
# Sequence checking with Yosys

local ret=1

_arguments -s -S \
  '-d+[set workdir name]:dirname:_files -/' \
  '-f[remove workdir if it already exists]' \
  '-E[throw an exception (incl stack trace) for most errors]' \
  '-j+[maximum number of processes to run in parallel]:N' \
  '--dumptree[print the task tree and exit]' \
  '--dumpcommon[prepare common input and exit]' \
  '--setup[set up the working directory and exit]' \
  '--debug[log debug events]' \
  '--checkerror[enable rudimentary error checking]' \
  '--tracefinal[always dump complete trace for last successful task]' \
  '--logfile=[name of file to log to]:file:_files' \
  '*:scy file:_files -g "*.scy"' && ret=0

return ret
