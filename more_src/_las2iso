#compdef las2iso
# Documentation: https://github.com/LAStools/LAStools
# LAStools: extract isolines (contours) from a TIN of LAS/LAZ points

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help information]' \
  '-version[display tool version]' \
  '-gui[start with GUI]' \
  '-demo[run in demo mode]' \
  '(-v -verbose)'{-v,-verbose}'[enable verbose output]' \
  '*-iso+[extract specific iso value]:value' \
  '-iso_every+[create contour every n units]:n' \
  '-iso_number+[extract n evenly spaced contours]:n' \
  '-iso_range+[contours from min to max in n intervals]:min' \
  '-smooth+[do n smooth iterations (typical 2..20)]:n' \
  '-simplify+[simplify contours below length]:n' \
  '-simplify_length+[simplify individual contours below length]:n' \
  '-simplify_area+[simplify area contours below area]:n' \
  '-clean+[remove contours with fewer than n points]:n' \
  '-kill+[remove isolines crossing long triangles]:meters' \
  '-concavity+[remove boundary triangles exceeding edge length]:n' \
  '-creeks+[integrate hard breaklines]:file:_files' \
  '-lakes+[enforce hydro breaklines]:file:_files' \
  '-loops_only[output closed polygons only]' \
  '-tin[write TIN output]' \
  '-first_only[use first returns only]' \
  '-last_only[use last returns only]' \
  '*-keep_class+[keep specific point classifications]:code' \
  '*-i+[input file or mask]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-iparse+[define fields for text input]:parse string' \
  '-merged[merge multiple input files]' \
  '-o+[output file]:output:_files' \
  '-oshp[save as ESRI shapefile]' \
  '-okml[output as KML]' \
  '-owkt[output as well-known text]' \
  '-otxt[output as text]' \
  '-odbf[include elevation attributes in DBF]' \
  '-cores+[process on multiple cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
