#compdef toml

# Zsh completion for toml-cli - TOML file manipulation

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get:get a value from a TOML file'
  'set:set a value in a TOML file'
  'unset:remove a key from a TOML file'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'toml command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      get|set|unset)
        _arguments \
          '--toml-path=[TOML file]:file:_files -g "*.toml"' \
          '1:key path:' \
          '2:value:'
        ;;
    esac
    ;;
esac

return ret
