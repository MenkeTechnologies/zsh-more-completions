#compdef toml
# Documentation: https://github.com/gnprice/toml-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get:get the value at the given path in a TOML file'
  'set:set the value at the given path in a TOML file'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'toml command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      get)
        _arguments \
          '(-r --raw)'{-r,--raw}'[print strings as raw, not as JSON]' \
          '--output-toml[output as a TOML fragment rather than JSON]' \
          '1:file:_files -g "*.toml"' \
          '2:key path:'
        ;;
      set)
        _arguments \
          '1:file:_files -g "*.toml"' \
          '2:key path:' \
          '3:value:'
        ;;
    esac
    ;;
esac

return ret
