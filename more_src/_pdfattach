#compdef pdfattach
# Documentation: https://manpages.debian.org/pdfattach.1
# Source: poppler-utils — embed a file inside a PDF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-replace[replace embedded file with same name]' \
    '(- *)-v[print copyright + version]' \
    '(- *)-h[print usage]' \
    '*:input.pdf + attachment-file + output.pdf:_files' \
    && ret=0

return ret
