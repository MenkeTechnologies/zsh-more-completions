#compdef nyc

# Zsh completion for nyc - Istanbul code coverage CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*--reporter=[coverage reporter to use]:reporter:(text lcov html json cobertura text-lcov text-summary json-summary clover teamcity)' \
  '--check-coverage[check whether coverage is within thresholds]' \
  '--lines=[minimum line coverage percentage]:percentage:' \
  '--functions=[minimum function coverage percentage]:percentage:' \
  '--branches=[minimum branch coverage percentage]:percentage:' \
  '--statements=[minimum statement coverage percentage]:percentage:' \
  '--all[instrument all files]' \
  '*--include=[include only files matching pattern]:glob pattern:' \
  '*--exclude=[exclude files matching pattern]:glob pattern:' \
  '--temp-dir=[directory to output raw coverage]:directory:_directories' \
  '--report-dir=[directory to output coverage reports]:directory:_directories' \
  '--clean[clean temp directory before running]' \
  '--produce-source-map[produce source map for instrumented code]' \
  '(--no-source-map)--source-map[enable source map support]' \
  '--per-file[check thresholds per file]' \
  '--skip-full[do not show files with 100% coverage]' \
  '--silent[suppress nyc output]' \
  '(--no-instrument)--instrument[enable instrumenting]' \
  '*--extension=[additional extensions to handle]:extension:' \
  '*--require=[require a module before running]:module:' \
  '--eager[instantiate the instrumenter at startup]' \
  '(--no-cache)--cache[enable file caching]' \
  '--cache-dir=[directory for caching]:directory:_directories' \
  '(--no-babel-cache)--babel-cache[enable babel caching]' \
  '(--no-hook-require)--hook-require[hook into require for instrumentation]' \
  '(--no-hook-run-in-context)--hook-run-in-context[hook into vm.runInContext]' \
  '(--no-hook-run-in-this-context)--hook-run-in-this-context[hook into vm.runInThisContext]' \
  '--show-process-tree[display the tree of spawned processes]' \
  '--nycrc-path=[path to nycrc config]:config file:_files' \
  '--cwd=[working directory]:directory:_directories' \
  '*:command and arguments: _normal' && ret=0

return ret
