#compdef fig2ps2tex
# Documentation: https://man.archlinux.org/search?q=fig2ps2tex
# Reference accessed: 2026-05-16

# fig2ps2tex: legacy wrapper to convert xfig figures to PS + LaTeX
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:xfig file:_files -g "*.fig"' && ret=0
return ret
