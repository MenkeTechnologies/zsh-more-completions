#compdef fig2ps2tex
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/fig2ps2tex.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fig2ps2tex: legacy wrapper to convert xfig figures to PS + LaTeX
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:xfig file:_files -g "*.fig"' && ret=0
return ret
