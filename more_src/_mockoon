#compdef mockoon

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start a mock API server'
  'list:list running mock servers'
  'stop:stop running mock servers'
  'dockerize:generate a Dockerfile for a mock'
  'import:import environment from file'
  'export:export environment to file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mockoon command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (start)
        _arguments \
          '-d+[path to environment file]:data file:_files' \
          '--data=[path to environment file]:data file:_files' \
          '-p+[override port]:port' \
          '--port=[override port]:port' \
          '-l+[hostname to listen on]:hostname' \
          '--hostname=[hostname to listen on]:hostname' \
          '--daemon-off[do not run as daemon]' \
          '--log-transaction[log request/response pairs]' \
          '--disable-tls[disable TLS]' \
          '--repair[repair environment file]' && ret=0
        ;;
      (stop)
        _arguments \
          '-a[stop all running instances]' \
          '--all[stop all running instances]' \
          '1:instance name or port' && ret=0
        ;;
      (dockerize)
        _arguments \
          '-d+[path to environment file]:data file:_files' \
          '--data=[path to environment file]:data file:_files' \
          '-p+[container port]:port' \
          '--port=[container port]:port' \
          '-o+[output Dockerfile]:output file:_files' \
          '--output=[output Dockerfile]:output file:_files' && ret=0
        ;;
      (import)
        _arguments \
          '-i+[input file]:input file:_files' \
          '--input=[input file]:input file:_files' \
          '-o+[output file]:output file:_files' \
          '--output=[output file]:output file:_files' && ret=0
        ;;
      (export)
        _arguments \
          '-i+[input environment]:input file:_files' \
          '--input=[input environment]:input file:_files' \
          '-o+[output file]:output file:_files' \
          '--output=[output file]:output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
