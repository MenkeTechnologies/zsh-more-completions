#compdef shp
# _shp — CLI for Shipwright's Build API (shipwright-io/cli)
# upstream: https://github.com/shipwright-io/cli
# Subcommands from pkg/shp/cmd/ (cobra).

_shp() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:context:' \
        '(-n --namespace)'{-n+,--namespace=}'[kubernetes namespace]:ns:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                build:'manage Shipwright Builds'
                bd:'manage Shipwright Builds'
                buildrun:'manage Shipwright BuildRuns'
                br:'manage Shipwright BuildRuns'
                buildstrategy:'manage BuildStrategies'
                clusterbuildstrategy:'manage ClusterBuildStrategies'
                version:'show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                build|bd)
                    _arguments '1:subcommand:(create list delete run upload)' ;;
                buildrun|br)
                    _arguments '1:subcommand:(list logs create cancel delete)' ;;
                buildstrategy|clusterbuildstrategy)
                    _arguments '1:subcommand:(list delete)' ;;
            esac
            ;;
    esac
}

_shp "$@"
