#compdef kivaloo-lbs-dynamodb-init
# _kivaloo-lbs-dynamodb-init — create LBS-on-DynamoDB tables (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from lbs-dynamodb-init/main.c (libcperciva GETOPT).

_kivaloo-lbs-dynamodb-init() {
    _arguments \
        '(- *)--version[print version]' \
        '-k+[AWS keyfile]:file:_files' \
        '-r+[DynamoDB region]:region:' \
        '-t+[data table name]:table:' \
        '-m+[metadata table name]:table:' \
        '-b+[item size]:bytes:'
}

_kivaloo-lbs-dynamodb-init "$@"
