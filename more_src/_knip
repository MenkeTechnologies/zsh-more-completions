#compdef knip

# Knip unused code finder completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to config file]:config file:_files' \
  '--tsConfig=[path to tsconfig file]:tsconfig file:_files' \
  '*--include=[include issue type]:type' \
  '*--exclude=[exclude issue type]:type' \
  '--dependencies[report unused dependencies]' \
  '--exports[report unused exports]' \
  '--files[report unused files]' \
  '--no-gitignore[do not use .gitignore]' \
  '--no-progress[do not show progress]' \
  '--reporter=[reporter to use]:reporter:(json compact symbol codeowners)' \
  '--reporter-options=[reporter options]:options' \
  '--max-issues=[maximum number of issues]:count' \
  '--no-exit-code[do not set exit code on issues]' \
  '--workspace=[workspace name]:workspace' \
  '--directory=[working directory]:directory:_directories' \
  '--strict[enable strict mode]' \
  '--production[only analyze production code]' \
  '--fix[auto-fix issues]' \
  '--cache[enable caching]' \
  '--debug[enable debug output]' \
  && ret=0

return ret
