#compdef knip
# Documentation: https://knip.dev/reference/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Knip unused code finder completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help summary]' \
  '(- *)'{-V,--version}'[show version number]' \
  '(-c --config)'{-c,--config}'=[alternative configuration file path]:config file:_files' \
  '--use-tsconfig-files[use tsconfig.json project files instead of patterns]' \
  '(-t --tsConfig)'{-t,--tsConfig}'=[TypeScript configuration file path]:tsconfig file:_files' \
  '--cache[enable caching for faster consecutive runs]' \
  '--cache-location=[custom cache directory location]:dir:_directories' \
  '--include-entry-exports[report unused exports in entry files]' \
  '--no-gitignore[ignore .gitignore files]' \
  '(-p --production)'{-p,--production}'[lint only production files]' \
  '(-s --strict)'{-s,--strict}'[isolate workspaces, direct dependencies only]' \
  '(-w --watch)'{-w,--watch}'[monitor directory for file changes]' \
  '(-W --workspace)'{-W,--workspace}'=[select specific workspaces]:workspace' \
  '(-D --directory)'{-D,--directory}'=[run from different directory]:directory:_directories' \
  '*--exclude=[omit specific issue types from report]:type' \
  '*--include=[report only specified issue types]:type' \
  '--dependencies[include all dependency-related issues]' \
  '--exports[include all export-related issues]' \
  '--files[include file issues only]' \
  '*--tags=[filter exports by JSDoc/TSDoc tags]:tag' \
  '(-f --fix)'{-f,--fix}'[enable auto-fix mode]' \
  '--fix-type=[fix specific issue types only]:type' \
  '--allow-remove-files[permit file deletion during fixes]' \
  '(-F --format)'{-F,--format}'[format files after applying fixes]' \
  '--reporter=[output format]:reporter:(symbols compact codeowners json codeclimate markdown disclosure github-actions)' \
  '--reporter-options=[pass configuration to reporter]:json' \
  '--preprocessor=[preprocess results before reporting]:preprocessor' \
  '--preprocessor-options=[pass configuration to preprocessor]:json' \
  '(-n --no-progress)'{-n,--no-progress}'[disable dynamic progress updates]' \
  '--no-config-hints[suppress configuration suggestions]' \
  '--treat-config-hints-as-errors[exit with error code if hints present]' \
  '--max-issues=[maximum issues before non-zero exit]:count' \
  '--max-show-issues=[limit displayed issues per type]:count' \
  '--no-exit-code[always exit with code 0]' \
  '(-d --debug)'{-d,--debug}'[show debug output]' \
  '--memory[display memory usage statistics]' \
  '--memory-realtime[log memory usage continuously]' \
  '--performance[show function execution timing metrics]' \
  '(-u --duration)'{-u,--duration}'[display total running time]' \
  '--performance-fn=[profile specific function performance]:fn' \
  '--trace[show export import paths]' \
  '--trace-dependency=[trace package/binary references]:name' \
  '--trace-export=[trace specific export usage]:name' \
  '--trace-file=[trace file export imports]:path:_files' \
  && ret=0

return ret
