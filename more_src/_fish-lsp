#compdef fish-lsp
# Documentation: https://github.com/ndonfris/fish-lsp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the language server'
  'complete:generate shell completions for fish'
  'env:manage environment variable configuration'
  'info:display server diagnostics'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--help-all[show complete flag and subcommand reference]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'fish-lsp command' commands && ret=0 ;;
  (args)
    case $words[1] in
      (start)
        _arguments \
          '--enable=[enable specific handlers]:handlers:' \
          '--disable=[disable specific handlers]:handlers:' \
          '--dump[display configuration without running]' && ret=0 ;;
      (env)
        _arguments \
          '--show-default[display default values]' \
          '--create[generate full configuration template]' \
          '--show[show current values]' \
          '--json[format output as JSON]' \
          '--confd[write to ~/.config/fish/conf.d/]' \
          '--names-only[list variable names only]' \
          '--only=[show specific variables]:vars:' && ret=0 ;;
      (info)
        _arguments \
          '--bin[show binary path]' \
          '--time-startup[measure startup duration]' \
          '--time-only[brief startup timing]' \
          '--use-workspace=[specify workspace]:path:_files -/' \
          '--check-health[server health status]' \
          '--log-file[display log file location]' \
          '--dump-parse-tree=[show parse tree]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
