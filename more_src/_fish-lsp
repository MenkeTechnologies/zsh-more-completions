#compdef fish-lsp
# Documentation: https://man.archlinux.org/search?q=fish-lsp
# Reference accessed: 2026-05-16

# Zsh completion for fish-lsp

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the language server'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmd' && ret=0

case $state in
  cmd)
    _describe -t commands 'fish-lsp command' commands && ret=0
    ;;
esac

return ret
