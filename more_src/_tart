#compdef tart
# Documentation: https://tart.run/quick-start/
# Reference accessed: 2026-05-21
# Verified: upstream source at Sources/tart/Commands/*.swift in github.com/cirruslabs/tart.

_tart_commands() {
  local -a commands=(
    'clone:Clone a VM'
    'create:Create a VM'
    'delete:Delete a VM'
    'exec:Execute a command inside a VM'
    'export:Export a VM to a file'
    'fqn:Show a fully qualified name'
    'get:Get a VM property'
    'import:Import a VM from a file'
    'ip:Get an IP of a running VM'
    'list:List VMs'
    'login:Log in to a registry'
    'logout:Log out from a registry'
    'prune:Prune OCI and IPSW caches'
    'pull:Pull a VM from a registry'
    'push:Push a VM to a registry'
    'rename:Rename a VM'
    'run:Run a VM'
    'set:Modify VM configuration'
    'stop:Stop a running VM'
    'suspend:Suspend a running VM'
  )
  _describe 'command' commands
}

_tart() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--version[show version]' \
    '--help[show help]' \
    '1:command:_tart_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        create)
          _arguments \
            '--from-ipsw=[create macOS VM from IPSW path/URL or "latest"]:path:_files -g "*.ipsw"' \
            '--linux[create a Linux VM]' \
            '--disk-size=[disk size in GB]:size:' \
            '--disk-format=[disk image format]:format:(raw asif)' \
            '1:name:'
          ;;
        run)
          _arguments \
            '--no-graphics[do not open UI window]' \
            '--graphics[force open UI window]' \
            '--serial[open serial console in /dev/ttySXX]' \
            '--serial-path=[external serial console path]:file:_files' \
            '--no-audio[disable audio pass-through]' \
            '--no-clipboard[disable clipboard sharing]' \
            '--recovery[boot into recovery mode]' \
            '--vnc[use Screen Sharing instead of built-in UI]' \
            '--vnc-experimental[use experimental Virtualization VNC]' \
            '*--disk=[attach additional disk path[:options]]:disk:_files' \
            '--rosetta=[Rosetta share tag]:tag:' \
            '*--dir=[directory share [name:]path[:options]]:dir:_directories' \
            '--nested[enable nested virtualization]' \
            '*--net-bridged=[bridged network interface]:interface:' \
            '--net-softnet[use Softnet networking]' \
            '--net-softnet-allow=[CIDRs allowed under Softnet]:cidrs:' \
            '--net-softnet-block=[CIDRs blocked under Softnet]:cidrs:' \
            '--net-softnet-expose=[Softnet TCP port forwards]:ports:' \
            '--net-host[restrict to host-only network]' \
            '--root-disk-opts=[root disk attach options]:opts:' \
            '--suspendable[mac-only inputs and disable audio/entropy]' \
            '--capture-system-keys[send system hot keys to guest]' \
            '--no-trackpad[disable trackpad on macOS VMs]' \
            '--no-pointer[disable the pointer]' \
            '--no-keyboard[disable the keyboard]' \
            '1:vm name:'
          ;;
        set)
          _arguments \
            '--cpu=[number of VM CPUs]:cpus:' \
            '--memory=[VM memory in MB]:memory:' \
            '--display=[display resolution WIDTHxHEIGHT[pt|px]]:resolution:' \
            '--display-refit[auto-refit display to window]' \
            '--no-display-refit[do not auto-refit display]' \
            '--random-mac[generate random MAC]' \
            '--random-serial[generate random serial (macOS)]' \
            '--disk=[replace VM disk contents from path]:path:_files' \
            '--disk-size=[resize disk in GB]:size:' \
            '1:vm name:'
          ;;
        clone)
          _arguments \
            '--insecure[allow insecure connections]' \
            '--concurrency=[parallel pull workers]:n:' \
            '1:source VM:' \
            '2:destination VM:'
          ;;
        pull)
          _arguments \
            '--insecure[allow insecure connections]' \
            '--concurrency=[parallel pull workers]:n:' \
            '1:remote name:'
          ;;
        push)
          _arguments \
            '--insecure[allow insecure connections]' \
            '--chunk-size-mb=[push chunk size MB]:mb:' \
            '1:local VM:' \
            '*:remote name:'
          ;;
        delete|get|ip|stop|suspend|rename|fqn)
          _arguments '1:vm name:'
          ;;
        list)
          _arguments \
            '--format=[output format]:format:(text json)' \
            '--source=[filter by source]:source:(local oci)' \
            '--quiet[only print VM names]'
          ;;
        login|logout)
          _arguments \
            '--username=[registry username]:username:' \
            '--password-stdin[read password from stdin]' \
            '1:host:'
          ;;
        prune)
          _arguments \
            '--older-than=[prune entries older than N days]:days:' \
            '--cache-budget=[max cache size in GB]:gb:' \
            '--gc[run garbage collection]'
          ;;
        exec)
          _arguments \
            '1:vm name:' \
            '*::command:_command_names -e'
          ;;
        export)
          _arguments \
            '1:vm name:' \
            '2:output file:_files'
          ;;
        import)
          _arguments \
            '1:input file:_files' \
            '2:vm name:'
          ;;
      esac
      ;;
  esac
}

_tart "$@"
