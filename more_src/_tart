#compdef tart

_tart_commands() {
  local -a commands=(
    'clone:Clone a VM'
    'create:Create a new VM'
    'delete:Delete a VM'
    'get:Get VM configuration'
    'ip:Get VM IP address'
    'list:List VMs'
    'login:Login to a registry'
    'logout:Logout from a registry'
    'pull:Pull a VM from a registry'
    'push:Push a VM to a registry'
    'rename:Rename a VM'
    'run:Run a VM'
    'set:Set VM configuration'
    'stop:Stop a running VM'
    'suspend:Suspend a running VM'
    'prune:Prune OCI and IPSW caches'
  )
  _describe 'command' commands
}

_tart() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--version[Print version]' \
    '--help[Show help]' \
    '1:command:_tart_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        create)
          _arguments \
            '--from-ipsw[Create from IPSW file]:ipsw:_files -g "*.ipsw"' \
            '--disk-size[Disk size in GB]:size:' \
            '--linux[Create a Linux VM]' \
            '1:name:'
          ;;
        run)
          _arguments \
            '--no-graphics[Run without graphics]' \
            '--no-clipboard[Disable clipboard sharing]' \
            '--vnc[Enable VNC server]' \
            '--vnc-experimental[Use experimental VNC]' \
            '--net-softnet[Use Softnet networking]' \
            '--net-bridged[Bridge to interface]:interface:' \
            '--disk[Attach additional disk]:disk:_files' \
            '--dir[Share directory]:dir:_directories' \
            '--rosetta[Enable Rosetta]:option:(on off)' \
            '--cpus[Number of CPUs]:cpus:' \
            '--memory[Memory in MB]:memory:' \
            '--display[Display resolution]:resolution:' \
            '1:vm name:'
          ;;
        set)
          _arguments \
            '--cpus[Number of CPUs]:cpus:' \
            '--memory[Memory in MB]:memory:' \
            '--disk-size[Disk size in GB]:size:' \
            '--display[Display resolution]:resolution:' \
            '1:vm name:'
          ;;
        clone)
          _arguments \
            '1:source VM:' \
            '2:destination VM:'
          ;;
        pull|push)
          _arguments \
            '--insecure[Allow insecure connections]' \
            '1:remote name:'
          ;;
        delete|get|ip|stop|suspend|rename)
          _arguments '1:vm name:'
          ;;
        list)
          _arguments '--source[Filter by source]:source:(local oci)'
          ;;
      esac
      ;;
  esac
}

_tart "$@"
