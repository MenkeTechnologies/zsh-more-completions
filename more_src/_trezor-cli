#compdef trezorctl trezor-cli
# _trezorctl — Trezor python-trezor CLI (control a Trezor hardware wallet; subgroups: device, btc, ethereum, cardano, eos, monero, nem, ripple, stellar, tezos, binance, debug; per-coin sign_tx, get_address, get_public_node; -p picks transport URL, -j JSON output)
# upstream: https://github.com/trezor/trezor-firmware (python/src/trezorlib/cli)
# Subcommands from trezor python/src/trezorlib/cli on tip.

_trezorctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-p+[transport URL]:transport:' \
        '-j[JSON output]' \
        '--script[script-friendly output]' \
        '--passphrase-on-host[enter passphrase on host]' \
        '--session-id+[session id]:hex:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'trezorctl command' '(device firmware btc ethereum cardano eos monero nem ripple stellar tezos binance debug benchmark list version settings set_passphrase_source set_homescreen set_label set_pin set_auto_lock_delay set_display_rotation set_safety_checks set_brightness reboot_to_bootloader wipe wipe_device recovery_device load_device backup_device sd_protect ping clear_session apply_settings)' ;;
        args)
            case $line[1] in
                btc) _describe -t commands 'btc cmd' '(get-address get-public-node sign-tx sign-message verify-message get-fingerprint authorize-coinjoin)' ;;
                ethereum) _describe -t commands 'ethereum cmd' '(get-address get-public-node sign-tx sign-tx-eip1559 sign-message verify-message sign-typed-data)' ;;
                device) _describe -t commands 'device cmd' '(setup recover wipe load erase backup sd-protect reboot self-test apply-settings reset)' ;;
                firmware) _describe -t commands 'firmware cmd' '(update download verify)' ;;
            esac
            ;;
    esac
}

_trezorctl "$@"
