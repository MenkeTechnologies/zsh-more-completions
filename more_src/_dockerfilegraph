#compdef dockerfilegraph
# Documentation: https://github.com/patrickhoefler/dockerfilegraph
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]' \
  '(-o --output)'{-o,--output}'=[output file format]:format:(canon dot pdf png raw svg)' \
  '(-f --filename)'{-f,--filename}'=[Dockerfile path]:file:_files' \
  '(-d --dpi)'{-d,--dpi}'=[dots per inch for PNG]:dpi' \
  '--legend[add a legend explaining notation]' \
  '--layers[display all Docker layers]' \
  '(-c --concentrate)'{-c,--concentrate}'[concentrate edges]' \
  '(-e --edgestyle)'{-e,--edgestyle}'=[edge style]:style:(default solid)' \
  '(-m --max-label-length)'{-m,--max-label-length}'=[max node label length]:length' \
  '(-n --nodesep)'{-n,--nodesep}'=[minimum space between adjacent nodes]:val' \
  '(-r --ranksep)'{-r,--ranksep}'=[minimum separation between ranks]:val' \
  '(-u --unflatten)'{-u,--unflatten}'=[stagger leaf edges]:val' \
  '--scratch=[how to handle scratch images]:mode:(collapsed hidden separated)' \
  '--separate=[external images as separate nodes]:images' \
  '--target=[show only stages needed for targets]:targets' \
  '*::arguments:_default'
