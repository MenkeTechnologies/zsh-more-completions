#compdef smoothing
# Documentation: https://healpix.sourceforge.io/html/fac_smoothing.htm
# HEALPix: smooth a map with a Gaussian beam

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
