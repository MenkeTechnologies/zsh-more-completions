#compdef tbump

# Zsh completion for tbump - version bumping tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--dry-run[show what would be done without making changes]' \
  '--non-interactive[do not prompt for confirmation]' \
  '--no-tag[do not create a git tag]' \
  '--no-push[do not push commits to remote]' \
  '--no-tag-push[do not push tags to remote]' \
  '--only-patch[only apply file patches, skip git operations]' \
  '(-C --config)'{-C,--config}'[path to configuration file]:config file:_files' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show version and exit]' \
  '1:version:' && ret=0

return ret
