#compdef tbump
# Documentation: https://github.com/your-tools/tbump
# Reference accessed: 2026-05-21
# Verified: upstream README documents init/current-version subcommands and
# flags --dry-run, --non-interactive, --no-tag, --no-push, --no-tag-push,
# --only-patch, --pyproject.

local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'init:initialize tbump configuration with a starting version'
  'current-version:print the current version'
)

_arguments -C -s -S \
  '--dry-run[show what would be done without making changes]' \
  '--non-interactive[do not prompt for confirmation]' \
  '--no-tag[do not create a git tag]' \
  '--no-push[do not push commits to remote]' \
  '--no-tag-push[do not push tags to remote]' \
  '--only-patch[only apply file patches, skip git operations]' \
  '--pyproject[(with init) append config to pyproject.toml instead of tbump.toml]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show version and exit]' \
  '1: :->arg1' \
  '*::rest:_default' && ret=0

case $state in
  (arg1) _describe -t commands 'tbump subcommand or new version' subcommands && ret=0 ;;
esac

return ret
