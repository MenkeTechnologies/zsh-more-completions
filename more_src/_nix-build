#compdef nix-build

# Zsh completion for nix-build - Nix build command

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--arg=[pass argument to Nix expression]:name value:' \
  '--argstr=[pass string argument to Nix expression]:name value:' \
  '(-A --attr)'{-A,--attr}'[select attribute from top-level expression]:attribute:' \
  '--no-out-link[do not create a symlink to the output path]' \
  '-o[change name of symlink to output path]:symlink:_files' \
  '--out-link=[change name of symlink to output path]:symlink:_files' \
  '--drv-link=[change name of symlink to derivation]:symlink:_files' \
  '--add-drv-link[create a symlink to the derivation]' \
  '--dry-run[show what would be built or downloaded]' \
  '-K[keep build directory on failure]' \
  '--keep-failed[keep build directory on failure]' \
  '-k[keep going on build failures]' \
  '--keep-going[keep going on build failures]' \
  '-j[set number of parallel build jobs]:jobs:' \
  '--max-jobs=[set number of parallel build jobs]:jobs:' \
  '--cores=[set number of CPU cores per build]:cores:' \
  '--max-silent-time=[set max silent time before killing]:seconds:' \
  '--timeout=[set max build time]:seconds:' \
  '--option=[set Nix configuration option]:name: :value:' \
  '--show-trace[show Nix expression evaluation trace on error]' \
  '--no-build-output[suppress build output]' \
  '-Q[suppress build output]' \
  '-v[increase verbosity level]' \
  '--verbose[increase verbosity level]' \
  '--quiet[decrease verbosity level]' \
  '--no-build-hook[disable build hook]' \
  '--readonly-mode[read-only mode]' \
  '--log-format=[set log format]:format:(raw bar bar-with-logs)' \
  '-I[add path to Nix expression search path]:path:_files' \
  '--include=[add path to Nix expression search path]:path:_files' \
  '--store=[Nix store URL]:url:' \
  '--impure[allow impure expressions]' \
  '--expr=[interpret installables as attribute paths relative to Nix expression]:expr:' \
  '*:Nix expression:_files -g "*.nix"'
