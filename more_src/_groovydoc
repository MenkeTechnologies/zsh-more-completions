#compdef groovydoc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-author[include @author paragraphs]' \
  '-charset=[charset for cross-platform viewing]:charset:' \
  {-cp+,-classpath+,--classpath=}'[classpath]:path:_files' \
  '-d+[output directory]:dir:_files -/' \
  '-doctitle=[document title]:title:' \
  '-fileEncoding=[source file encoding]:charset:' \
  '-footer=[footer]:html:' \
  '-header=[header]:html:' \
  '-help[show help]' \
  '-noscripts[do not include script files]' \
  '-notimestamp[suppress timestamp]' \
  '-overview=[overview file]:file:_files' \
  '-quiet[suppress informational messages]' \
  '-sourcepath=[source path]:path:_files -/' \
  '-stylesheetfile=[CSS stylesheet]:file:_files -g "*.css"' \
  '-tagletpath=[taglet classpath]:path:_files' \
  '-windowtitle=[window title]:title:' \
  '-version[show version]' \
  '*:packagename / source file:_files' && ret=0

return ret
