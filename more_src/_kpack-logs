#compdef kpack-logs
# _kpack-logs — kpack build-log tail utility
# upstream: https://github.com/buildpacks-community/kpack
# Flags from cmd/logs/main.go on tip.

_kpack-logs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[Kubernetes API server URL]:url:_urls' \
        '--image=[Image name to tail logs for]:name:' \
        '--build=[build number to tail logs for]:n:' \
        '--namespace=[namespace of the Image]:ns:'
}

_kpack-logs "$@"
