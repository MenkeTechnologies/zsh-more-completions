#compdef daphne

# Zsh completion for daphne - Django ASGI server

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-p,--port}'=[port to listen on]:port' \
  {-b,--bind}'=[host to bind to]:host' \
  '--unix-socket=[path to unix socket]:socket path:_files' \
  '--file-descriptor=[file descriptor to listen on]:fd' \
  '--fd=[file descriptor to listen on]:fd' \
  '--http-timeout=[HTTP timeout in seconds]:seconds' \
  '--websocket-timeout=[WebSocket timeout in seconds]:seconds' \
  {-u,--unix-socket-perms}'=[unix socket permissions]:permissions' \
  '--proxy-headers[enable proxy headers]' \
  '--proxy-headers-host=[header for proxy host]:header' \
  '--proxy-headers-port=[header for proxy port]:header' \
  {-v,--verbosity}'=[verbosity level]:level:(0 1 2)' \
  '--access-log=[access log file]:file:_files' \
  '--ping-interval=[WebSocket ping interval in seconds]:seconds' \
  '--ping-timeout=[WebSocket ping timeout in seconds]:seconds' \
  '--root-path=[root path prefix]:path' \
  '--server-name=[server name]:name' \
  {-e,--endpoint}'=[twisted endpoint string]:endpoint' \
  '--application-close-timeout=[application close timeout in seconds]:seconds' \
  {-s,--server-header}'=[override server header]:name' \
  '1:application'
