#compdef unpaper

# Zsh completion for unpaper (post-processing tool for scanned paper)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--layout[set page layout]:layout:(single double none)' \
  '--input-pages[number of input pages per sheet]:count:(1 2)' \
  '--output-pages[number of output pages per sheet]:count:(1 2)' \
  '--sheet-size[set sheet size]:size:(a5 a4 a3 letter legal)' \
  '--sheet-background[set sheet background]:color:(black white)' \
  '--pre-rotate[rotate input before processing]:angle:(-90 90 180)' \
  '--post-rotate[rotate output after processing]:angle:(-90 90 180)' \
  '--pre-mirror[mirror input before processing]:direction:(v h)' \
  '--post-mirror[mirror output after processing]:direction:(v h)' \
  '--pre-shift[shift input before processing]:horizontal,vertical' \
  '--post-shift[shift output after processing]:horizontal,vertical' \
  '*--pre-mask[mask on input page (x1,y1,x2,y2)]:mask coordinates' \
  '*--post-mask[mask on output page (x1,y1,x2,y2)]:mask coordinates' \
  '--no-blackfilter[disable black area filter]' \
  '--blackfilter-scan-direction[direction to scan for black areas]:direction:(h v)' \
  '--blackfilter-scan-size[size of scan area for black filter]:pixels' \
  '--blackfilter-scan-depth[depth of black filter scan]:pixels' \
  '--blackfilter-scan-step[step size between scan positions]:pixels' \
  '--blackfilter-scan-threshold[threshold for black filter]:value' \
  '--blackfilter-intensity[intensity threshold for black filter]:value' \
  '--no-noisefilter[disable noise filter]' \
  '--noisefilter-intensity[intensity of noise filter]:value' \
  '--no-blurfilter[disable blur filter]' \
  '--blurfilter-size[size of blur filter area]:pixels' \
  '--blurfilter-step[step size of blur filter]:pixels' \
  '--blurfilter-intensity[intensity threshold for blur filter]:value' \
  '--no-grayfilter[disable gray area filter]' \
  '--grayfilter-size[size of gray filter area]:pixels' \
  '--grayfilter-step[step size of gray filter]:pixels' \
  '--grayfilter-threshold[threshold for gray filter]:value' \
  '--no-deskew[disable deskewing]' \
  '--deskew-scan-direction[direction to scan for deskewing]:direction:(left right top bottom)' \
  '--deskew-scan-size[size of deskew scan area]:pixels' \
  '--deskew-scan-depth[depth of deskew scan]:pixels' \
  '--deskew-scan-range[rotation range for deskewing]:degrees' \
  '--deskew-scan-step[step size for deskewing]:degrees' \
  '--deskew-scan-deviation[maximum deviation for deskewing]:pixels' \
  '--no-border-scan[disable border scanning]' \
  '--border-scan-direction[direction to scan borders]:direction:(h v)' \
  '--border-scan-size[size of border scan area]:pixels' \
  '--border-scan-step[step size of border scan]:pixels' \
  '--border-scan-threshold[threshold for border scan]:value' \
  '--no-border-align[disable border alignment]' \
  '--border-align[border alignment direction]:direction:(left right top bottom)' \
  '--border-margin[border margin]:pixels' \
  '--type[set output file type]:type:(pbm pgm ppm)' \
  '--depth[set output color depth]:depth:(1 8)' \
  '--overwrite[allow overwriting existing files]' \
  '(-v --verbose)'{-v,--verbose}'[show processing details]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output messages]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-n --no-processing)'{-n,--no-processing}'[do not process, only convert]' \
  '*:file:_files' && ret=0

return ret
