#compdef unpaper
# Documentation: https://manpages.debian.org/testing/unpaper/unpaper.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for unpaper (post-processing tool for scanned paper)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-l --layout)'{-l,--layout}'[set page layout]:layout:(single double none)' \
  '(-\\#)--sheet[process specific sheets]:sheets:' \
  '--start-sheet[start at sheet number]:n:' \
  '--end-sheet[end at sheet number]:n:' \
  '(-x --exclude)'{-x,--exclude}'[exclude sheets]:sheets:' \
  '(-S --sheet-size)'{-S,--sheet-size}'[output sheet size]:size:' \
  '--sheet-background[sheet background]:color:(black white)' \
  '--pre-rotate[rotate input before processing]:angle:(-90 90)' \
  '--post-rotate[rotate output after processing]:angle:(-90 90)' \
  '(-M --pre-mirror)'{-M,--pre-mirror}'[mirror input]:direction:(v h vh)' \
  '--post-mirror[mirror output]:direction:(v h vh)' \
  '--pre-shift[shift input]:offset:' \
  '--post-shift[shift output]:offset:' \
  '--pre-wipe[wipe area on input]:area:' \
  '--post-wipe[wipe area on output]:area:' \
  '--pre-border[border on input]:border:' \
  '--post-border[border on output]:border:' \
  '(-s --size)'{-s,--size}'[set output size]:size:' \
  '--post-size[post-processing size]:size:' \
  '--stretch[stretch to size]:size:' \
  '--post-stretch[post-stretch to size]:size:' \
  '(-z --zoom)'{-z,--zoom}'[zoom factor]:factor:' \
  '--post-zoom[post-zoom factor]:factor:' \
  '--pre-mask[mask on input page]:mask:' \
  '(-p --mask-scan-point)'{-p,--mask-scan-point}'[mask scan starting point]:point:' \
  '(-m --mask)'{-m,--mask}'[mask area]:area:' \
  '(-mn --mask-scan-direction)'{-mn,--mask-scan-direction}'[mask scan direction]:dir:(h v)' \
  '(-ms --mask-scan-size)'{-ms,--mask-scan-size}'[mask scan size]:size:' \
  '(-md --mask-scan-depth)'{-md,--mask-scan-depth}'[mask scan depth]:depth:' \
  '(-mp --mask-scan-step)'{-mp,--mask-scan-step}'[mask scan step]:step:' \
  '(-mt --mask-scan-threshold)'{-mt,--mask-scan-threshold}'[mask scan threshold]:val:' \
  '(-mm --mask-scan-minimum)'{-mm,--mask-scan-minimum}'[mask scan minimum]:val:' \
  '(-mM --mask-scan-maximum)'{-mM,--mask-scan-maximum}'[mask scan maximum]:val:' \
  '(-mc --mask-color)'{-mc,--mask-color}'[mask color]:color:' \
  '(-mw --middle-wipe)'{-mw,--middle-wipe}'[wipe middle of page]:area:' \
  '(-bn --blackfilter-scan-direction)'{-bn,--blackfilter-scan-direction}'[blackfilter scan direction]:dir:(h v)' \
  '(-bs --blackfilter-scan-size)'{-bs,--blackfilter-scan-size}'[blackfilter scan size]:size:' \
  '(-bd --blackfilter-scan-depth)'{-bd,--blackfilter-scan-depth}'[blackfilter scan depth]:depth:' \
  '(-bp --blackfilter-scan-step)'{-bp,--blackfilter-scan-step}'[blackfilter scan step]:step:' \
  '(-bt --blackfilter-scan-threshold)'{-bt,--blackfilter-scan-threshold}'[blackfilter scan threshold]:val:' \
  '(-bx --blackfilter-scan-exclude)'{-bx,--blackfilter-scan-exclude}'[blackfilter scan exclude]:area:' \
  '(-bi --blackfilter-intensity)'{-bi,--blackfilter-intensity}'[blackfilter intensity]:val:' \
  '(-ni --noisefilter-intensity)'{-ni,--noisefilter-intensity}'[noisefilter intensity]:val:' \
  '(-ls --blurfilter-size)'{-ls,--blurfilter-size}'[blurfilter size]:size:' \
  '(-lp --blurfilter-step)'{-lp,--blurfilter-step}'[blurfilter step]:step:' \
  '(-li --blurfilter-intensity)'{-li,--blurfilter-intensity}'[blurfilter intensity]:val:' \
  '(-gs --grayfilter-size)'{-gs,--grayfilter-size}'[grayfilter size]:size:' \
  '(-gp --grayfilter-step)'{-gp,--grayfilter-step}'[grayfilter step]:step:' \
  '(-gt --grayfilter-threshold)'{-gt,--grayfilter-threshold}'[grayfilter threshold]:val:' \
  '(-dn --deskew-scan-direction)'{-dn,--deskew-scan-direction}'[deskew scan direction]:dir:' \
  '(-ds --deskew-scan-size)'{-ds,--deskew-scan-size}'[deskew scan size]:size:' \
  '(-dd --deskew-scan-depth)'{-dd,--deskew-scan-depth}'[deskew scan depth]:depth:' \
  '(-dr --deskew-scan-range)'{-dr,--deskew-scan-range}'[deskew scan range]:degrees:' \
  '(-dp --deskew-scan-step)'{-dp,--deskew-scan-step}'[deskew scan step]:step:' \
  '(-dv --deskew-scan-deviation)'{-dv,--deskew-scan-deviation}'[deskew scan deviation]:val:' \
  '(-W --wipe)'{-W,--wipe}'[wipe area]:area:' \
  '(-B --border)'{-B,--border}'[border]:border:' \
  '(-Bn --border-scan-direction)'{-Bn,--border-scan-direction}'[border scan direction]:dir:(h v)' \
  '(-Bs --border-scan-size)'{-Bs,--border-scan-size}'[border scan size]:size:' \
  '(-Bp --border-scan-step)'{-Bp,--border-scan-step}'[border scan step]:step:' \
  '(-Bt --border-scan-threshold)'{-Bt,--border-scan-threshold}'[border scan threshold]:val:' \
  '(-Ba --border-align)'{-Ba,--border-align}'[border alignment]:dir:(left right top bottom)' \
  '(-Bm --border-margin)'{-Bm,--border-margin}'[border margin]:margin:' \
  '(-w --white-threshold)'{-w,--white-threshold}'[white threshold]:val:' \
  '(-b --black-threshold)'{-b,--black-threshold}'[black threshold]:val:' \
  '(-ip --input-pages)'{-ip,--input-pages}'[input pages per sheet]:count:(1 2)' \
  '(-op --output-pages)'{-op,--output-pages}'[output pages per sheet]:count:(1 2)' \
  '(-t --type)'{-t,--type}'[output file type]:type:(pbm pgm ppm)' \
  '(-T --test-only)'{-T,--test-only}'[do not write output files]' \
  '(-si --start-input)'{-si,--start-input}'[input file numbering start]:n:' \
  '(-so --start-output)'{-so,--start-output}'[output file numbering start]:n:' \
  '--insert-blank[insert blank pages]:pages:' \
  '--replace-blank[replace pages with blanks]:pages:' \
  '--overwrite[allow overwriting existing files]' \
  '--no-blackfilter[disable blackfilter]' \
  '--no-noisefilter[disable noisefilter]' \
  '--no-blurfilter[disable blurfilter]' \
  '--no-grayfilter[disable grayfilter]' \
  '--no-mask-scan[disable mask scan]' \
  '--no-mask-center[disable mask centering]' \
  '--no-deskew[disable deskewing]' \
  '--no-wipe[disable wipe]' \
  '--no-border[disable border processing]' \
  '--no-border-scan[disable border scanning]' \
  '--no-border-align[disable border alignment]' \
  '(-n --no-processing)'{-n,--no-processing}'[do not process; only convert]' \
  '--interpolate[interpolation method]:method:' \
  '--no-multi-pages[disable multi-page processing]' \
  '--dpi[set DPI]:dpi:' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '-vv[very verbose output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
