#compdef enemat gmx-enemat
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-enemat.html
# gmx enemat: extract an energy matrix from an energy file

local ret=1

_arguments -s \
  '-f[energy file]:file:_files' \
  '-groups[generic data file]:file:_files' \
  '-eref[generic data file]:file:_files' \
  '-emat[X PixMap matrix file]:file:_files' \
  '-etot[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-sum[sum energy terms rather than display all]' \
  '-skip[skip number of frames between data points]:int:' \
  '-mean[extract matrix of mean energies]' \
  '-nlevels[number of levels for matrix colors]:int:' \
  '-max[maximum value for energies]:real:' \
  '-min[minimum value for energies]:real:' \
  '-coulsr[extract Coulomb short-range energies]' \
  '-coul14[extract Coulomb 1-4 energies]' \
  '-ljsr[extract Lennard-Jones short-range energies]' \
  '-lj14[extract Lennard-Jones 1-4 energies]' \
  '-bhamsr[extract Buckingham short-range energies]' \
  '-free[calculate free energy]' \
  '-temp[reference temperature for free energy calculation]:real:' && ret=0

return ret
