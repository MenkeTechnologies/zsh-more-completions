#compdef jsrepo
# Documentation: https://jsrepo.dev/docs/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for jsrepo registry client (Node CLI)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-color[disable ANSI color]' \
  '-d+[debug logging level]:level' \
  '-c+[config file]:file:_files' \
  '1:subcommand:(add build help init update version)' \
  '*::args:{ _files }' && ret=0

return ret
