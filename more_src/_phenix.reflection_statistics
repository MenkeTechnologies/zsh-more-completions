#compdef phenix.reflection_statistics
# Phenix: resolution-binned statistics and correlations for reflection data files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--unit-cell=[external unit cell parameters]:cell:' \
  '--space-group=[external space group symbol]:sg:' \
  '--symmetry=[external file with symmetry information]:file:_files' \
  '--weak-symmetry[symmetry on command line is weaker than in files]' \
  '--quick[do not compute statistics between pairs of data arrays]' \
  '--resolution=[high resolution limit (d_min)]:res:' \
  '--low-resolution=[low resolution limit (d_max)]:res:' \
  '--bins=[number of resolution bins]:n:' \
  '--bins-twinning-test=[number of bins for twinning test]:n:' \
  '--bins-second-moments=[number of bins for second moments]:n:' \
  '--lattice-symmetry-max-delta=[angular tolerance in degrees]:deg:' \
  '*:reflection file:_files -g "*.(mtz|sca|hkl|cns)"' && ret=0

return ret
