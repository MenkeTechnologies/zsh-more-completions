#compdef antsAlignOrigin
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsAlignOrigin.cxx — align image origin to reference (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-i --input)'{-i+,--input=}'[input image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-r --reference-image)'{-r+,--reference-image=}'[reference image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-o --output)'{-o+,--output=}'[output image]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
