#compdef checkTableCoords
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# check invariants on genomic coords in table(s)

local ret=1

_arguments -s -S \
  '-table=[check only this table]:table:' \
  '-daysOld=[check only tables modified in the last N days]:n:' \
  '-hoursOld=[check only tables modified in the last N hours]:n:' \
  '-exclude=[exclude tables matching this pattern list]:patList:' \
  '-ignoreBlocks[do not check block coords of bed/genePred/psl]' \
  '-verboseBlocks[print extra info about block coord errors]' \
  '*:database tableName:_files' && ret=0

return ret
