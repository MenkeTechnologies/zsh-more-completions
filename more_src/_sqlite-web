#compdef sqlite-web
# Documentation: https://github.com/coleifer/sqlite-web
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sqlite-web: web-based SQLite database browser
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-H --host)'{-H+,--host=}'[bind host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[server port]:port:' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-l --log-file)'{-l+,--log-file=}'[log file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[only log errors]' \
  '(-b --browser)'{-b,--browser}'[open web browser on startup]' \
  '(-x --no-browser)'{-x,--no-browser}'[prevent browser from opening]' \
  '(-P --password)'{-P,--password}'[prompt for access password]' \
  '(-r --read-only)'{-r,--read-only}'[open database in read-only mode]' \
  '(-R --rows-per-page)'{-R+,--rows-per-page=}'[content pagination rows]:n:' \
  '(-Q --query-rows-per-page)'{-Q+,--query-rows-per-page=}'[query pagination rows]:n:' \
  '(-T --no-truncate)'{-T,--no-truncate}'[disable text truncation with ellipsis]' \
  '(-B --base64)'{-B,--base64}'[display BLOB data as base64 instead of hex]' \
  '*'{-e+,--extension=}'[load SQLite extension]:ext:_files' \
  '(-s --startup-hook)'{-s+,--startup-hook=}'[path to initialization callable]:path:_files' \
  '(-f --foreign-keys)'{-f,--foreign-keys}'[enable foreign-key constraints]' \
  '(-u --url-prefix)'{-u+,--url-prefix=}'[application URL prefix]:prefix:' \
  '(-L --enable-load)'{-L,--enable-load}'[allow runtime database uploads]' \
  '(-U --upload-dir)'{-U+,--upload-dir=}'[destination for uploaded databases]:dir:_directories' \
  '(-F --enable-filesystem)'{-F,--enable-filesystem}'[allow runtime database path specification]' \
  '(-c --cert)'{-c+,--cert=}'[SSL certificate file]:file:_files' \
  '(-k --key)'{-k+,--key=}'[SSL private key file]:file:_files' \
  '(-a --ad-hoc)'{-a,--ad-hoc}'[use ad-hoc SSL context]' \
  '*:database:_files -g "*.(db|sqlite|sqlite3)"' && ret=0
return ret
