#compdef sqlite-web

# sqlite-web: web-based SQLite database browser
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-H[bind host]:host:_hosts' \
  '--host=[bind host]:host:_hosts' \
  '-p[port]:port:' \
  '--port=[port]:port:' \
  '-d[debug]' \
  '--debug[debug]' \
  '-l[log file]:file:_files' \
  '--log=[log file]:file:_files' \
  '-x[don'\''t open browser on start]' \
  '--no-browser[don'\''t open browser on start]' \
  '-r[read-only mode]' \
  '--read-only[read-only mode]' \
  '-P[require password (env)]' \
  '--password[require password (env)]' \
  '-T[query timeout (sec)]:seconds:' \
  '--query-timeout=[query timeout (sec)]:seconds:' \
  '-U[allow data export]' \
  '--allow-export[allow data export]' \
  '--no-export[disable data export]' \
  '-u[base URL prefix]:url:' \
  '--url-prefix=[base URL prefix]:url:' \
  '*:database:_files -g "*.(db|sqlite|sqlite3)"' && ret=0
return ret
