#compdef kubectl-advise-policy
# Documentation: https://github.com/sysdiglabs/kube-policy-advisor/blob/master/kube-policy-advisor.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kube-policy-advisor (kubectl advise-policy). Subcommands: inspect, convert, compare.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--level=[log level]:level:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'inspect:inspect the cluster and generate security policies'
      'convert:convert a pod spec to a security policy'
      'compare:compare YAML directories'
    )
    _describe -t commands 'kube-policy-advisor command' commands && ret=0
    ;;
  args)
    case $line[1] in
      inspect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[absolute path to the kubeconfig file]:file:_files' \
          '(-r --report)'{-r,--report}'[return with detail report]' \
          '(-g --grant)'{-g,--grant}'[return with pod security policies, roles and rolebindings]' \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
          '(-e --exclude-namespaces)'{-e+,--exclude-namespaces=}'[comma separated namespaces to exclude]:namespaces:' \
          '(-p --policy)'{-p+,--policy=}'[set policy type]:policy:' \
          '--OPADefaultRule[use if OPA Default Rule is Deny ALL]' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--podFile=[path to a yaml file containing a pod Spec]:file:_files' \
          '--policyFile=[write the resulting output to this file]:file:_files' \
          '(-p --policy)'{-p+,--policy=}'[set policy type]:policy:' \
          '--deny-by-default[use if OPA Default Rule is Deny ALL]' && ret=0
        ;;
      compare)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--sourceDir=[source YAML directory to load YAMLs]:dir:_directories' \
          '--targetDir=[target YAML directory to load YAMLs]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
