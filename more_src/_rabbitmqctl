#compdef rabbitmqctl

# Zsh completion for rabbitmqctl - RabbitMQ broker management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'help:display usage information'
  'version:display version'
  'status:display broker status'
  'environment:display broker environment'
  'cluster_status:display cluster status'
  'list_users:list all users'
  'add_user:create a new user'
  'delete_user:delete a user'
  'change_password:change user password'
  'set_user_tags:set user tags'
  'authenticate_user:attempt to authenticate a user'
  'list_vhosts:list all virtual hosts'
  'add_vhost:create a new virtual host'
  'delete_vhost:delete a virtual host'
  'set_permissions:set user permissions'
  'clear_permissions:clear user permissions'
  'list_permissions:list vhost permissions'
  'list_user_permissions:list user permissions'
  'list_queues:list queues'
  'list_exchanges:list exchanges'
  'list_bindings:list bindings'
  'list_connections:list connections'
  'list_channels:list channels'
  'list_consumers:list consumers'
  'purge_queue:purge a queue'
  'delete_queue:delete a queue'
  'close_connection:close a connection'
  'close_all_connections:close all connections'
  'stop_app:stop RabbitMQ application'
  'start_app:start RabbitMQ application'
  'reset:fully reset node'
  'force_reset:forcefully reset node'
  'join_cluster:join cluster'
  'forget_cluster_node:remove node from cluster'
  'change_cluster_node_type:change type of cluster node'
  'enable_feature_flag:enable feature flag'
  'list_feature_flags:list feature flags'
  'set_policy:set a policy'
  'clear_policy:clear a policy'
  'list_policies:list policies'
  'set_parameter:set a runtime parameter'
  'clear_parameter:clear a runtime parameter'
  'list_parameters:list runtime parameters'
  'eval:evaluate Erlang expression'
  'trace_on:enable tracing'
  'trace_off:disable tracing'
  'await_startup:wait for RabbitMQ to start'
  'shutdown:stop RabbitMQ and Erlang'
  'stop:stop Erlang node'
  'rotate_logs:rotate log files'
  'node_health_check:basic health check'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-n --node)'{-n,--node}'[target node]:node' \
  '(-l --longnames)'{-l,--longnames}'[use long node names]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-s --silent)'{-s,--silent}'[suppress output]' \
  '(-t --timeout)'{-t,--timeout}'[operation timeout in seconds]:seconds' \
  '--formatter[output formatter]:formatter:(json csv table erlang)' \
  '--no-table-headers[do not output table headers]' \
  '1:command:->command' \
  '*:argument' && ret=0

case $state in
  command)
    _describe -t commands 'rabbitmqctl command' commands && ret=0
    ;;
esac

return ret
