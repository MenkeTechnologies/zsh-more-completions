#compdef snapcraft

# Zsh completion for snapcraft - snap package builder

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'build:build artifacts defined for a part'
  'clean:remove a parts content or the snaps artifacts'
  'close:close a channel for a snap'
  'extensions:list available extensions'
  'help:show help'
  'init:initialize a snapcraft project'
  'list-extensions:list available extensions'
  'list-keys:list locally available signing keys'
  'list-plugins:list available plugins'
  'list-revisions:list snap revisions in the store'
  'login:login to the snap store'
  'logout:logout from the snap store'
  'metrics:show metrics for a snap'
  'names:list registered snap names'
  'pack:create a snap file from a directory'
  'plugins:list available plugins'
  'prime:prepare snap for distribution'
  'promote:promote snap to a different channel'
  'pull:download or retrieve artifacts'
  'push:push a snap to the store'
  'register:register a snap name'
  'release:release a snap revision to a channel'
  'remote-build:dispatch a build to Launchpad'
  'sign-build:sign a built snap file'
  'snap:create a snap'
  'stage:stage a parts content'
  'status:show channel status for a snap'
  'try:try a snap in the host'
  'upload:upload a snap to the store'
  'validate:validate a snap assertion'
  'version:show version'
  'whoami:show current login information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show debug output]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '--destructive-mode[run lifecycle on host, not container]' \
  '--use-lxd[use LXD for build environment]' \
  '--provider=[build environment provider]:provider:(lxd multipass)' \
  '--target-arch=[target architecture]:arch:(amd64 arm64 armhf i386 ppc64el s390x)' \
  '--enable-manifest[generate snap manifest]' \
  '--manifest-image-information=[set image info in manifest]:info:' \
  '--bind-ssh[bind ~/.ssh into build environment]' \
  '--build-for=[target architecture for build]:arch:' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      release)
        _arguments ':snap name:' ':revision:' ':channel:' && ret=0
        ;;
      register)
        _arguments ':snap name:' '--private[register as private snap]' && ret=0
        ;;
      pack)
        _arguments ':directory:_directories' '-o[output directory]:directory:_directories' && ret=0
        ;;
      push|upload)
        _arguments ':snap file:_files -g "*.snap"' '--release=[release to channel]:channel:' && ret=0
        ;;
      remote-build)
        _arguments '--launchpad-accept-public-upload[accept public build]' && ret=0
        ;;
      clean)
        _arguments '*:part name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
