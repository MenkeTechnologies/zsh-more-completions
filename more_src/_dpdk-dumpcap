#compdef dpdk-dumpcap
# Documentation: https://doc.dpdk.org/guides/tools/dumpcap.html
# DPDK packet capture tool (Wireshark dumpcap compatible)

local ret=1

_arguments -s -S \
  '--list-interfaces[list interfaces available for capture]' \
  '*-f+[filter packets using tshark-style syntax]:filter' \
  '*-i+[specify capture interface]:interface' \
  '-c+[set packet capture count]:count' \
  '-w+[write output to pcapng file]:file:_files' && ret=0

return ret
