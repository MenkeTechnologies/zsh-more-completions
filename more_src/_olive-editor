#compdef olive-editor
# Documentation: https://github.com/olive-editor/olive
# Reference accessed: 2026-05-16
# Verified: upstream olive-editor/olive GitHub issue #280 - CLI is
# minimal; headless export not yet implemented.
# Removed from prior file: fabricated -h/--help/-V/--version generic
# flags and bogus man.archlinux.org search URL.

# olive-editor: open-source non-linear video editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen]' \
  '--test[run tests]' \
  '*:project file:_files -g "*.ove(-.)"' && ret=0
return ret
