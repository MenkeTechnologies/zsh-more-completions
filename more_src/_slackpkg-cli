#compdef slackpkg-cli slackpkg
# _slackpkg-cli — Roberto F. Batista Slackware Linux slackpkg-cli CLI command-line frontend wrapping the slackpkg automated tool for managing Slackware Linux packages from official online repositories simple installation tool written in shell for Slackware Linux Patrick Volkerding installs upgrades and removes Slackware packages with fully integrated dependency resolution and rebuild support search install upgrade upgrade-all remove reinstall info update update-all check-updates blacklist info clean-system new-config download generate-template install-template remove-template help (Roberto F. Batista Slackware team Patrick Volkerding, Bash); custom argparse
# upstream: http://slackpkg.org/

_slackpkg-cli() {
    local -a sub=(
        'blacklist:blacklist a package'
        'check-updates:check for updates'
        'clean-system:clean packages not in slackware'
        'download:download a package'
        'file-search:search file in packages'
        'generate-template:generate a template'
        'help:show help'
        'info:show package info'
        'install:install packages'
        'install-new:install new packages'
        'install-template:install a template'
        'new-config:apply new config files'
        'reinstall:reinstall packages'
        'remove:remove packages'
        'remove-template:remove a template'
        'search:search for packages'
        'update:update package list'
        'update-all:update all'
        'upgrade:upgrade packages'
        'upgrade-all:upgrade all'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-batch=+[v]:v:(on off)' \
        '-default_answer=+[v]:v:(y n)' \
        '-delall=+[v]:v:(on off)' \
        '-dialog=+[v]:v:(on off)' \
        '-onoff=+[v]:v:(on off)' \
        '-mirror=+[url]:str:' \
        '-only_new_dotnew=+[v]:v:(on off)' \
        '-postinst=+[v]:v:(on off)' \
        '-spinning=+[v]:v:(on off)' \
        '-use_includes=+[v]:v:(on off)' \
        '-checkgpg=+[v]:v:(on off)' \
        '-checkmd5=+[v]:v:(on off)' \
        '-checksize=+[v]:v:(on off)' \
        '-prioritygt=+[priority]:str:' \
        '-priority=+[order]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'slackpkg subcommand' sub ;;
        args) _arguments '*:package:' ;;
    esac
}

_slackpkg-cli "$@"
