#compdef conmon-rs
# Documentation: https://man.archlinux.org/search?q=conmon-rs
# Reference accessed: 2026-05-16

# conmon-rs: Rust container monitor for OCI runtimes (CRI-O)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '--runtime=[runtime binary]:file:_files' \
  '--runtime-dir=[runtime dir]:dir:_files -/' \
  '--runtime-root=[runtime root]:dir:_files -/' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--cgroup-manager=[cgroup manager]:mgr:(systemd cgroupfs)' \
  '--metadata=[metadata path]:path:' \
  '--socket=[socket path]:file:_files' \
  '--enable-tracing[enable tracing]' \
  '--tracing-endpoint=[tracing endpoint]:addr:' \
  '*::conmon-rs args:_files' && ret=0
return ret
