#compdef fontmatrix
# Documentation: https://man.archlinux.org/search?q=fontmatrix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:font file:_files -g "*.{ttf,otf,pfb,pfa,ttc}"' && ret=0

return ret
