#compdef bend

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check a Bend file'
  'compile:compile a Bend file to HVM'
  'desugar:desugar a Bend file'
  'gen-cu:compile and generate CUDA code'
  'gen-c:compile and generate C code'
  'run:run a Bend file with the interpreter'
  'run-c:compile to C and run'
  'run-cu:compile to CUDA and run'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[enable verbose output]' \
  '--verbose[enable verbose output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'bend command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      run|run-c|run-cu|compile|desugar|gen-cu|gen-c|check)
        _arguments \
          '1:file:_files -g "*.bend"' && ret=0
        ;;
    esac
    ;;
esac

return ret
