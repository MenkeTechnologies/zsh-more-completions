#compdef bend
# Documentation: https://github.com/HigherOrderCO/Bend
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check that the program is syntactically and semantically correct'
  'run:alias for run-c (run with the C HVM implementation)'
  'run-rs:compile and run with the Rust HVM implementation (sequential)'
  'run-c:compile and run with the C HVM implementation (parallel)'
  'run-cu:compile and run with the CUDA HVM implementation (massively parallel)'
  'gen-hvm:compile the program to HVM and print to stdout'
  'gen-c:compile the program to standalone C and print to stdout'
  'gen-cu:compile the program to standalone CUDA and print to stdout'
  'desugar:run the lambda-term level desugaring passes'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'bend command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      run|run-c|run-cu|run-rs|gen-c|gen-cu|gen-hvm|desugar|check)
        _arguments \
          '-O+[set optimization passes]:opt:' \
          '-W+[enable warning]:warn:' \
          '-D+[deny warning]:warn:' \
          '-A+[allow warning]:warn:' \
          '-s[show detailed execution stats]' \
          '1:file:_files -g "*.bend"' && ret=0
        ;;
    esac
    ;;
esac

return ret
