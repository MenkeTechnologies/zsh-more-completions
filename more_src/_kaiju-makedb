#compdef kaiju-makedb
# Documentation: https://github.com/bioinformatics-centre/kaiju
# Download source data and build a kaiju reference database

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-s[source database to build]:source:(refseq progenomes viruses nr nr_euk fungi plasmids rvdb mar mar_ref mar_db mar_mag)' \
  '-t[number of parallel threads]:threads:' \
  '*:dir:_files -/' && ret=0

return ret
