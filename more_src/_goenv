#compdef goenv

# Zsh completion for goenv - Go version manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'commands:List all available goenv commands'
  'completions:List completions for a command'
  'exec:Run an executable with the selected Go version'
  'global:Set or show the global Go version'
  'help:Display help for a command'
  'hooks:List hook scripts for a given goenv command'
  'init:Configure the shell environment for goenv'
  'install:Install a Go version'
  'local:Set or show the local application-specific Go version'
  'prefix:Display prefix for a Go version'
  'rehash:Rehash goenv shims'
  'root:Display the root directory where versions and shims are kept'
  'shell:Set or show the shell-specific Go version'
  'shims:List existing goenv shims'
  'uninstall:Uninstall a specific Go version'
  'version:Show the current Go version and its origin'
  'version-file:Detect the file that sets the current goenv version'
  'version-name:Show the current Go version'
  'version-origin:Explain how the current Go version is set'
  'versions:List all Go versions available to goenv'
  'whence:List all Go versions that contain the given executable'
  'which:Display the full path to an executable'
)

_arguments -s -S \
  '--version[display the version of goenv]' \
  '(-h --help)'{-h,--help}'[display help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '(-l --list)'{-l,--list}'[list available versions]' \
          '-f[install even if the version appears to be installed already]' \
          '--force[install even if the version appears to be installed already]' \
          '-s[skip if the version appears to be installed already]' \
          '--skip-existing[skip if the version appears to be installed already]' \
          ':version:' && ret=0
        ;;
      uninstall)
        _arguments \
          '-f[attempt to remove the specified version without prompting]' \
          '--force[attempt to remove without prompting]' \
          ':version:($(goenv versions --bare 2>/dev/null))' && ret=0
        ;;
      global|local|shell)
        _arguments '*:version:(system $(goenv versions --bare 2>/dev/null))' && ret=0
        ;;
      exec)
        _arguments \
          ':command:' \
          '*:arguments:' && ret=0
        ;;
      completions)
        _arguments ':command:' && ret=0
        ;;
      hooks)
        _arguments ':command:' && ret=0
        ;;
      prefix|whence|which)
        _arguments ':version:($(goenv versions --bare 2>/dev/null))' && ret=0
        ;;
    esac
    ;;
esac

return ret
