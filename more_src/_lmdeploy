#compdef lmdeploy
# Documentation: source-direct extraction from upstream
# InternLM/lmdeploy lmdeploy/cli/entrypoint.py (per upstream
# `setup.py` entry_points: `lmdeploy = lmdeploy.cli:run`) +
# 3 sub-CLI classes: CLI (lmdeploy/cli/cli.py — `chat` /
# `check_env`), SubCliServe (lmdeploy/cli/serve.py — `serve
# api_server` / `serve proxy`), SubCliLite (lmdeploy/cli/lite.py
# — `lite auto_awq` / `lite auto_gptq` / `lite calibrate` /
# `lite smooth_quant`).
# Reference accessed: 2026-05-30 via gh api.
# InternLM lmdeploy R153c — OpenMMLab's LMDeploy: unified API
# for converting, compressing, and deploying large language
# models. Sister tool to vllm/llama-server/llama-cli/llamafile/
# wandb/mlflow already heavily covered in the corpus.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '1:subcommand:((chat\:interactive-chat-with-a-deployed-model check_env\:check-CUDA-driver-and-environment-versions serve\:deploy-a-model-as-an-API-server lite\:quantization-and-compression-tools))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      chat)
        # Interactive chat with a deployed model.
        _arguments -s -S \
          '1:model path or HF repo-id:' \
          '--backend=[inference backend]:backend:(turbomind pytorch)' \
          '--model-name=[model name override]:name:' \
          '--model-format=[model format]:format:(hf llama awq gptq)' \
          '--session-len=[max session length]:tokens:' \
          '--cache-max-entry-count=[KV cache max entries]:n:' \
          '--enable-prefix-caching[enable prefix caching]' \
          '--quant-policy=[KV quantization policy]:policy:(0 4 8)' \
          '--dtype=[model dtype]:dtype:(auto float16 bfloat16 float32)' \
          '--tp=[tensor parallel size]:n:' \
          '--trust-remote-code[trust HF model_remote_code]' \
          '--revision=[HF repo revision]:rev:' \
          '--download-dir=[HF download directory]:dir:_directories' \
          && ret=0
        ;;
      check_env)
        # Print CUDA driver + LMDeploy environment versions.
        _arguments -s -S \
          '--dump-file=[dump env info to file]:file:_files' \
          && ret=0
        ;;
      serve)
        _arguments -C -s -S \
          '1:serve-subcommand:((api_server\:start-OpenAI-compatible-HTTP-API-server proxy\:start-LB-proxy-fronting-multiple-api_servers))' \
          '*::: :_default' && ret=0
        ;;
      lite)
        _arguments -C -s -S \
          '1:lite-subcommand:((auto_awq\:AWQ-quantize-a-model auto_gptq\:GPTQ-quantize-a-model calibrate\:calibrate-a-model-for-quantization smooth_quant\:SmoothQuant-quantize-a-model))' \
          '*::: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
