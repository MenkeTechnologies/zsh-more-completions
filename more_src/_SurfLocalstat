#compdef SurfLocalstat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfLocalstat.html
# Compute neighborhood statistics on surface node values (SUMA)

local ret=1

_arguments -s -S \
  '(-h -help -HELP)'{-h,-help,-HELP}'[show help]' \
  '-hood[neighborhood radius along mesh]:R:' \
  '-nbhd_rad[neighborhood radius along mesh]:R:' \
  '-prefix[output dataset prefix]:prefix:' \
  '-stat[statistic to compute on neighborhood]:sss:(mean mode num FWHM ALL)' \
  '-input[input dataset of node values]:dataset:_files' \
  '-i_gii[input surface in GIFTI format]:surface:_files' \
  '-n_mask[restrict to nodes in index mask]:mask:_files' \
  '-b_mask[apply binary mask to nodes]:mask:_files' \
  '-c_mask[conditional masking by expression]:expr:' \
  '-talk_suma[send progress updates to SUMA]' \
  '-refresh_rate[max SUMA updates per second]:rps:' \
  '-send_kth[send every kth element to SUMA]:kth:' \
  '-sh[SUMA host computer]:host:' \
  '-ni_text[text data transmission mode]' \
  '-ni_binary[binary data transmission mode]' \
  '-feed_afni[send updates to AFNI via SUMA]' \
  '-novolreg[ignore surface volume transformations]' \
  '-noxform[ignore surface volume transformations]' \
  '-setenv[set environment variable]:env:' \
  '-trace[enable debug tracing]' \
  '-TRACE[enable extreme tracing]' \
  '-h_view[open help in editor]' \
  '-h_web[open help in browser]' \
  '-h_find[search help for word]:word:' \
  '*:dataset:_files' && ret=0

return ret
