#compdef mummer
# Documentation: https://manpages.debian.org/testing/mummer/mummer.1.en.html
# MUMmer maximal unique match finder between reference and query sequences

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-mum[compute maximal matches unique in both sequences]' \
  '-mumreference[compute maximal matches unique in reference only]' \
  '-mumcand[same as -mumreference]' \
  '-maxmatch[compute all maximal matches regardless of uniqueness]' \
  '-n[match only the characters a, c, g, or t]' \
  '-l+[set minimum length of a match]:len' \
  '-b[compute forward and reverse complement matches]' \
  '-r[only compute reverse complement matches]' \
  '-s[show the matching substrings]' \
  '-c[report query-position of reverse complement relative to original]' \
  '-F[force 4 column output format]' \
  '-L[show length of query sequences on header line]' \
  ':reference:_files' \
  '*:query:_files' && ret=0

return ret
