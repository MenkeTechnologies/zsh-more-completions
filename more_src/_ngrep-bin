#compdef ngrep
# _ngrep-bin — ngrep network grep (Jordan Ritter, C); grep through packet payloads with BPF filter
# upstream: https://github.com/jpr5/ngrep

_ngrep-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-A+[lines of context after match]:n:' \
        '-B+[lines of context before match]:n:' \
        '-D[replay pcap at recorded timing]' \
        '-d+[device]:iface:_net_interfaces' \
        '-e[show empty packets]' \
        '-F+[BPF filter file]:file:_files' \
        '-f+[BPF filter]:filter:' \
        '-G+[byte threshold]:n:' \
        '-g+[GeoIP database]:file:_files' \
        '-h[show help]' \
        '-I+[input file]:file:_files' \
        '-i[case-insensitive]' \
        '-K[pktloss]:n:' \
        '-k[colorize output]' \
        '-l[disable buffer]' \
        '-M+[multi-line match]:n:' \
        '-m+[max packets]:n:' \
        '-N[show sub-protocol]' \
        '-n+[print no payload, only counts]:n:' \
        '-O+[output file]:file:_files' \
        '-P+[print invalid chars as]:c:' \
        '-p[no promiscuous]' \
        '-q[quiet, omit non-matched]' \
        '-S+[snaplen]:n:' \
        '-s+[seconds delay]:n:' \
        '-T+[show time since previous match]:fmt:' \
        '-t[print absolute time]' \
        '-tt[print delta time]' \
        '-W+[output format]:fmt:(normal byline single none)' \
        '-w[matching word only]' \
        '-x[hex dump matches]' \
        '*:pattern:'
}

_ngrep-bin "$@"
