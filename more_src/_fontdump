#compdef fontdump
# Documentation: https://github.com/glasslion/fontdump
# Dump Google web fonts (CSS and font files) for local hosting

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--font-dir-path=[path to the font dir (ends with /)]:path:' \
  '--output=[directory to save the dumped css and font files]:dir:_files -/' \
  '1:google fonts url:_urls' && ret=0

return ret
