autoload -U is-at-least

_novops() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_novops_commands" \
"*::: :->novops" \
&& ret=0
    case $state in
    (novops)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:novops-command-$line[1]:"
        case $line[1] in
            (load)
_arguments "${_arguments_options[@]}" : \
'-c+[Configuration to use.]:FILE:_default' \
'--config=[Configuration to use.]:FILE:_default' \
'-e+[Environment to load. Prompt if not specified.]:ENVNAME:_default' \
'--env=[Environment to load. Prompt if not specified.]:ENVNAME:_default' \
'-w+[Working directory under which files and secrets will be saved. Default to XDG_RUNTIME_DIR if available, or a secured temporary files otherwise. Warning\: make sure to use a secured file when using this option. (i.e. directory with 0600 mod)]:DIR:_default' \
'--working-dir=[Working directory under which files and secrets will be saved. Default to XDG_RUNTIME_DIR if available, or a secured temporary files otherwise. Warning\: make sure to use a secured file when using this option. (i.e. directory with 0600 mod)]:DIR:_default' \
'-s+[Create a symlink pointing to generated environment variable file. Implies -o '\''workdir'\'']:SYMLINK:_default' \
'--symlink=[Create a symlink pointing to generated environment variable file. Implies -o '\''workdir'\'']:SYMLINK:_default' \
'-f+[Format for environment variables\: dotenv-export|dotenv]:FORMAT:_default' \
'--format=[Format for environment variables\: dotenv-export|dotenv]:FORMAT:_default' \
'--dry-run[Perform a dry-run\: no external service will be called and dummy secrets are generated.]' \
'--skip-workdir-check[Skip working directory safety checks for permissions and ownership. By default, working directory is ensured to be owned by current user without group or world access.]' \
'--skip-tty-check[Do not check if stdout is a tty (terminal), risking exposing secrets on screen. This is unsecure.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
'-c+[Configuration to use.]:FILE:_default' \
'--config=[Configuration to use.]:FILE:_default' \
'-e+[Environment to load. Prompt if not specified.]:ENVNAME:_default' \
'--env=[Environment to load. Prompt if not specified.]:ENVNAME:_default' \
'-w+[Working directory under which files and secrets will be saved. Default to XDG_RUNTIME_DIR if available, or a secured temporary files otherwise. Warning\: make sure to use a secured file when using this option. (i.e. directory with 0600 mod)]:DIR:_default' \
'--working-dir=[Working directory under which files and secrets will be saved. Default to XDG_RUNTIME_DIR if available, or a secured temporary files otherwise. Warning\: make sure to use a secured file when using this option. (i.e. directory with 0600 mod)]:DIR:_default' \
'--dry-run[Perform a dry-run\: no external service will be called and dummy secrets are generated.]' \
'--skip-workdir-check[Skip working directory safety checks for permissions and ownership. By default, working directory is ensured to be owned by current user without group or world access.]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':command -- Command to run.:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_novops__list_commands" \
"*::: :->list" \
&& ret=0

    case $state in
    (list)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:novops-list-command-$line[1]:"
        case $line[1] in
            (environments)
_arguments "${_arguments_options[@]}" : \
'-c+[Configuration to use.]:FILE:_default' \
'--config=[Configuration to use.]:FILE:_default' \
'-o+[Output format.]:OUTPUT_FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(outputs)
_arguments "${_arguments_options[@]}" : \
'-c+[Configuration to use.]:FILE:_default' \
'--config=[Configuration to use.]:FILE:_default' \
'-e+[Environment to load. Prompt if not specified.]:ENVNAME:_default' \
'--env=[Environment to load. Prompt if not specified.]:ENVNAME:_default' \
'-o+[Output format.]:OUTPUT_FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_novops__list__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:novops-list-help-command-$line[1]:"
        case $line[1] in
            (environments)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(outputs)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(schema)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
'*::subcommand -- Print help for the subcommand(s):_default' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_novops_commands] )) ||
_novops_commands() {
    local commands; commands=(
'load:Load a Novops environment. Output resulting environment variables to stdout or to a file using -s/--symlink. ' \
'run:Run a command with loaded environment variables and files.' \
'list:List existing environments and environment'\''s outputs' \
'completion:Output completion code for various shells.' \
'schema:Output Novops config JSON schema' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'novops commands' commands "$@"
}
(( $+functions[_novops__completion_commands] )) ||
_novops__completion_commands() {
    local commands; commands=()
    _describe -t commands 'novops completion commands' commands "$@"
}
(( $+functions[_novops__help_commands] )) ||
_novops__help_commands() {
