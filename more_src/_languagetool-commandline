#compdef languagetool-commandline
# Documentation: https://github.com/languagetool-org/languagetool/blob/master/languagetool-commandline/src/main/java/org/languagetool/commandline/CommandLineParser.java
# LanguageTool style and grammar checker, command-line interface

local ret=1

_arguments -s -S \
  '(-h -help --help --?)'{-h,-help,--help,--\?}'[display usage information]' \
  '--version[print version number and exit]' \
  '--list[print available languages and exit]' \
  '(-adl --autoDetect)'{-adl,--autoDetect}'[auto-detect input language]' \
  '(-v --verbose)'{-v,--verbose}'[print analysis to STDERR]' \
  '--line-by-line[process file line by line]' \
  '--enable-temp-off[enable temporary-off rules]' \
  '--clean-overlapping[show only highest priority matches]' \
  '--level=[enable specified level e.g. PICKY]:level' \
  '(-t --taggeronly)'{-t,--taggeronly}'[print text analysis without checking]' \
  '(-r --recursive)'{-r,--recursive}'[process directories recursively]' \
  '(-b2 --bitext)'{-b2,--bitext}'[check bilingual tab-separated text]' \
  '(-eo --enabledonly)'{-eo,--enabledonly}'[use only explicitly enabled rules]' \
  '(-d --disable)'{-d,--disable}'=[disable comma-separated rule IDs]:rules' \
  '(-e --enable)'{-e,--enable}'=[enable comma-separated rule IDs]:rules' \
  '--enablecategories=[enable category IDs]:categories' \
  '--disablecategories=[disable category IDs]:categories' \
  '(-l --language)'{-l,--language}'=[text language code]:lang' \
  '(-m --mothertongue)'{-m,--mothertongue}'=[first language for false-friend checks]:lang' \
  '--languagemodel=[directory with n-gram indexes]:dir:_files -/' \
  '--fasttextmodel=[fasttext language detection model]:file:_files' \
  '--fasttextbinary=[fasttext executable]:file:_files' \
  '--rulefile=[additional grammar file]:file:_files' \
  '--remoterules=[external rules JSON configuration]:file:_files' \
  '--falsefriends=[external false friend file]:file:_files' \
  '--bitextrules=[bitext XML rule file]:file:_files' \
  '(-c --encoding)'{-c,--encoding}'=[input character encoding]:enc' \
  '(-u --list-unknown)'{-u,--list-unknown}'[print unknown words summary]' \
  '-b[single line break marks paragraph end]' \
  '--json[output results as JSON]' \
  '(-a --apply)'{-a,--apply}'[auto-apply suggestions to output]' \
  '(-p --profile)'{-p,--profile}'[print performance measurements]' \
  '--xmlfilter[remove XML/HTML before checking]' \
  '*:file:_files' && ret=0

return ret
