#compdef crackmapexec cme
# Documentation: https://github.com/byt3bl33d3r/CrackMapExec
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# CrackMapExec was archived December 2023; successor project is NetExec.

local curcontext="$curcontext" state line ret=1
local -a protos

protos=(
  'smb:SMB protocol'
  'winrm:WinRM protocol'
  'mssql:MSSQL protocol'
  'ldap:LDAP protocol'
  'ssh:SSH protocol'
  'ftp:FTP protocol'
  'rdp:RDP protocol'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->proto' \
  '*::arg:->args' && ret=0

case $state in
  (proto) _describe -t protos 'protocol' protos && ret=0 ;;
  (args)
    case $line[1] in
      (smb|winrm|mssql|ldap|ssh|ftp|rdp)
        _arguments \
          '(-h --help)'{-h,--help}'[help for protocol]' \
          '(-u --user)'{-u+}'[username]:user:' \
          '(-p --password)'{-p+}'[password]:pw:' \
          '-H+[NTLM hash]:hash:' \
          '-d+[domain]:domain:' \
          '-k[use kerberos]' \
          '--aesKey=[AES key]:key:' \
          '--kdcHost=[KDC host]:host:' \
          '--local-auth[local auth]' \
          '-t+[threads]:n:' \
          '--timeout=[seconds]:n:' \
          '--jitter=[delay between conns]:dur:' \
          '--verbose[verbose]' \
          '(-x)-x+[execute cmd via cmd.exe]:cmd:' \
          '(-X)-X+[execute cmd via PowerShell]:cmd:' \
          '-M+[module to use]:module:' \
          '-L[list modules]' \
          '--module-info[show module info]' \
          '--options[show module options]' \
          '-o+[module option name=value]:opt:' \
          '--sam[dump SAM database]' \
          '--lsa[dump LSA secrets]' \
          '--ntds[dump NTDS.dit]' \
          '--shares[enumerate shares]' \
          '--users[enumerate users]' \
          '--groups[enumerate groups]' \
          '--loggedon-users[enumerate logged on users]' \
          '--sessions[enumerate sessions]' \
          '--disks[enumerate disks]' \
          '--pass-pol[dump password policy]' \
          '--rid-brute[RID brute force]' \
          '--wmi=[WMI query]:query:' \
          '--spider=[spider share]:share:' \
          '--exec-method=[exec method]:method:(wmiexec mmcexec smbexec atexec)' \
          '--get-file=[remote file to get]:remote:: :local:' \
          '--put-file=[local file to put]:local:: :remote:' \
          '--gen-relay-list=[output file for relay list]:file:_files' \
          '--continue-on-success[continue trying creds after one works]' \
          '--no-bruteforce[no bruteforce]' \
          '--kerberoasting=[kerberoasting output]:file:_files' \
          '--asreproast=[asreproast output]:file:_files' \
          '--trusted-for-delegation[unconstrained delegation]' \
          '--allowed-to-delegate[constrained delegation]' \
          '*:target:' && ret=0 ;;
    esac ;;
esac

return ret
