#compdef sprayhound
# Documentation: https://github.com/Hackndo/sprayhound
# Password spraying tool with BloodHound/Neo4j lockout awareness

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --username)'{-u,--username}'+[username]:user:' \
  '(-U --userfile)'{-U,--userfile}'+[file containing username list]:file:_files' \
  '(-p --password)'{-p,--password}'+[password]:password:' \
  '--lower[user as pass with lowercase password]' \
  '--upper[user as pass with uppercase password]' \
  '(-t --threshold)'{-t,--threshold}'+[passwords left allowed before lockout]:threshold:' \
  '(-dc --domain-controller)'{-dc,--domain-controller}'+[domain controller]:dc:' \
  '(-d --domain)'{-d,--domain}'+[domain FQDN]:domain:' \
  '(-lP --ldap-port)'{-lP,--ldap-port}'+[LDAP port]:port:' \
  '(-lu --ldap-user)'{-lu,--ldap-user}'+[LDAP user]:user:' \
  '(-lp --ldap-pass)'{-lp,--ldap-pass}'+[LDAP password]:password:' \
  '(-lssl --ldap-ssl)'{-lssl,--ldap-ssl}'[LDAP over TLS (ldaps)]' \
  '(-lpage --ldap-page-size)'{-lpage,--ldap-page-size}'+[LDAP paging size]:size:' \
  '(-nh --neo4j-host)'{-nh,--neo4j-host}'+[Neo4J host]:host:' \
  '(-nP --neo4j-port)'{-nP,--neo4j-port}'+[Neo4J port]:port:' \
  '(-nu --neo4j-user)'{-nu,--neo4j-user}'+[Neo4J user]:user:' \
  '(-np --neo4j-pass)'{-np,--neo4j-pass}'+[Neo4J password]:password:' \
  '--unsafe[enable login tries on almost locked out accounts]' \
  '--force[do not prompt for user confirmation]' \
  '--nocolor[do not use color for output]' \
  '*-v[verbosity level]' && ret=0

return ret
