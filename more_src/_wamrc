#compdef wamrc
# Documentation: https://github.com/bytecodealliance/wasm-micro-runtime/blob/main/wamr-compiler/main.c
# wamrc - WebAssembly Micro Runtime (WAMR) AOT compiler

local ret=1

_arguments -s -S \
  '-o[specify output file name]:output file:_files' \
  '--target=[set target architecture (x86_64, i386, aarch64, arm, thumb, xtensa, mips, riscv64, riscv32)]:arch' \
  '--target-abi=[set target ABI (gnu, eabi, gnueabihf, msvc)]:abi' \
  '--cpu=[set target CPU]:cpu' \
  '--cpu-features=[enable or disable CPU features with +/- prefix]:features' \
  '--opt-level=[optimization level 0-3 (default 3)]:level' \
  '--size-level=[code size level 0-3 (default 3)]:level' \
  '-sgx[generate code for Intel SGX platform]' \
  '--bounds-checks=[enable (1) or disable (0) memory access bounds checks]:0/1:(0 1)' \
  '--stack-bounds-checks=[enable (1) or disable (0) native stack bounds checks]:0/1:(0 1)' \
  '--stack-usage=[generate a stack-usage file]:file:_files' \
  '--format=[output format (aot, object, llvmir-unopt, llvmir-opt)]:format:(aot object llvmir-unopt llvmir-opt)' \
  '--disable-bulk-memory[disable bulk memory feature]' \
  '--enable-bulk-memory-opt[enable bulk memory optimization]' \
  '--enable-extended-const[enable extended const expressions]' \
  '--enable-multi-thread[enable multi-threading feature]' \
  '--enable-tail-call[enable tail call feature]' \
  '--disable-simd[disable 128-bit SIMD]' \
  '--disable-ref-types[disable reference types]' \
  '--enable-gc[enable garbage collection]' \
  '--enable-dump-call-stack[enable stack trace feature]' \
  '--call-stack-features=[configure call stack features]:features' \
  '--enable-perf-profiling[enable performance profiling]' \
  '--enable-memory-profiling[enable memory usage profiling]' \
  '--xip[enable XIP (execution in place) indirect mode]' \
  '--enable-indirect-mode[enable indirect function calls]' \
  '--disable-llvm-intrinsics[disable LLVM intrinsics]' \
  '--enable-builtin-intrinsics=[enable specific built-in intrinsics]:flags' \
  '--disable-llvm-jump-tables[disable LLVM jump tables]' \
  '--disable-llvm-lto[disable link-time optimization]' \
  '--enable-llvm-pgo[enable profile-guided optimization]' \
  '--enable-llvm-passes=[enable specific LLVM passes]:passes' \
  '--use-prof-file=[use a PGO profile file]:file:_files' \
  '--enable-segue=[use GS segment register (Linux x86-64)]::flags' \
  '--emit-custom-sections=[emit named custom sections to the AOT file]:names' \
  '--native-lib=[register native libraries (.so files)]:lib:_files' \
  '--invoke-c-api-import[treat unknown imports as C-API functions]' \
  '--enable-linux-perf[enable Linux perf support]' \
  '--enable-shared-heap[enable shared heap]' \
  '--enable-shared-chain[enable shared heap chain]' \
  '--disable-aux-stack-check[disable auxiliary stack checks]' \
  '--mllvm=[pass an LLVM command-line option]:option' \
  '-v=[set log verbosity level 0-5 (default 2)]:level' \
  '--version[show version information]' \
  '--llvm-version[show LLVM version information]' \
  '*:wasm file:_files -g "*.wasm"' && ret=0

return ret
