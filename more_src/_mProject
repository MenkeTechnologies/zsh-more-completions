#compdef mProject
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mProject.html
# Reproject a single FITS image to the scale defined in a header template

local ret=1

_arguments -s -S \
  '-z+[apply drizzle algorithm with factor]:factor' \
  '-d+[debugging level (1-5)]:level' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-h+[FITS extension (HDU) to use]:hdu' \
  '-x+[pixel value correction factor]:scale' \
  '-w+[weight map for input image values]:weightfile:_files -g "*.fits"' \
  '-t+[blank pixels with weight below threshold]:threshold' \
  '-X[expand output region to include all input data]' \
  '-f[reproject entire image]' \
  '1:input FITS:_files -g "*.fits"' \
  '2:output FITS:_files -g "*.fits"' \
  '3:header template:_files' && ret=0

return ret
