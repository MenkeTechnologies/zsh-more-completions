#compdef karma-cli
# _karma-cli — Karma JavaScript test runner CLI alias (karma-runner team, JavaScript); optimist
# upstream: https://github.com/karma-runner/karma

_karma-cli() {
    local -a sub=(
        'start:start karma server'
        'init:initialize karma config'
        'run:run tests against running server'
        'stop:stop running karma server'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'karma subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '1:config:_files -g "karma.conf.*"' \
                    '--port=+[port]:port:' \
                    '--auto-watch[auto watch]' \
                    '--no-auto-watch[no auto watch]' \
                    '--detached[detached]' \
                    '--no-colors[no colors]' \
                    '--colors[colors]' \
                    '--reporters=+[reporters]:r:(dots progress junit growl coverage)' \
                    '--browsers=+[browsers]:b:(Chrome Firefox Safari PhantomJS ChromeHeadless FirefoxHeadless IE Edge)' \
                    '--capture-timeout=+[ms]:n:' \
                    '--single-run[single run]' \
                    '--no-single-run[no single run]' \
                    '--report-slower-than=+[ms]:n:' \
                    '--log-level=+[level]:l:(disable error warn info debug)' \
                    '--ui=+[ui]:u:(bdd tdd)' ;;
                run) _arguments \
                    '--port=+[port]:port:' \
                    '--no-refresh[no refresh]' \
                    '--refresh[refresh]' \
                    '--fail-on-empty-test-suite[fail on empty test suite]' \
                    '--no-fail-on-empty-test-suite[no fail on empty test suite]' ;;
                stop) _arguments '--port=+[port]:port:' ;;
                init) _arguments '1:config:_files -g "karma.conf.*"' ;;
                completion) ;;
            esac
            ;;
    esac
}

_karma-cli "$@"
