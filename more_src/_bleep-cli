#compdef bleep-cli bleep
# _bleep-cli — Øyvind Raddum Berg bleep fast Scala build tool CLI alias (oyvindberg team, Scala); clap-style argparse
# upstream: https://github.com/oyvindberg/bleep

_bleep-cli() {
    local -a sub=(
        'about:about bleep'
        'build:build subcommands'
        'build:new:scaffold new project'
        'build:show:show effective build'
        'build:show-jvm:show jvm build'
        'build:show-scala:show scala build'
        'build:templates-generate-new:generate template'
        'build:templates-reapply:reapply template'
        'build:update-deps:update dependencies'
        'build:check:check build'
        'build:dot:generate dot graph'
        'compile:compile project'
        'clean:clean output'
        'config:show or set config'
        'fmt:format sources'
        'install-tab-completions-bash:install bash completions'
        'install-tab-completions-fish:install fish completions'
        'install-tab-completions-zsh:install zsh completions'
        'projects:list projects'
        'projects-test:list test projects'
        'publish-local:publish to local repo'
        'run:run project main'
        'script:run bleep script'
        'test:run tests'
        'patch:patch dependencies'
        'setup-ide:setup metals/IDE'
        'upgrade:upgrade bleep version'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--directory=+[work dir]:dir:_files -/' \
        '-C+[work dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bleep subcommand' sub ;;
        args)
            case $words[1] in
                compile|test|run|clean) _arguments '*:project:' '--watch[watch]' '-w[watch]' ;;
                build:new) _arguments \
                    '1:project name:' \
                    '--scala-version=+[scala version]:str:' \
                    '--platform=+[platform]:p:(jvm js native)' ;;
                projects|projects-test) ;;
                install-tab-completions-bash|install-tab-completions-fish|install-tab-completions-zsh) ;;
            esac
            ;;
    esac
}

_bleep-cli "$@"
