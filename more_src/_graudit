#compdef graudit
# Documentation: https://man.archlinux.org/search?q=graudit
# Reference accessed: 2026-05-16

_arguments -s -S \
  '-d+[signature database or path to .db]:db:_files' \
  '-A[scan extra file types]' \
  '-x+[exclude comma-separated globs]:patterns' \
  '-i[case insensitive]' \
  '-c+[context lines]:lines' \
  '-B[suppress banner]' \
  '-L[vim-friendly output]' \
  '-b[colour-blind template]' \
  '-z[suppress colors]' \
  '-Z[high-contrast colors]' \
  '-l[list signature databases]' \
  '-v[print version]' \
  '-h[help]' \
  '1:path to scan:_files -/'
