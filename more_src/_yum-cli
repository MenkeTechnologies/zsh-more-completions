#compdef yum-cli
# _yum-cli — Yellowdog Updater Modified RPM package manager CLI alias (Red Hat / Fedora, Python); custom argparse
# upstream: https://github.com/rpm-software-management/yum

_yum-cli() {
    local -a sub=(
        'check:check for problems'
        'check-update:check for updates'
        'clean:remove cached data'
        'deplist:list dependencies'
        'distribution-synchronization:sync to distribution'
        'downgrade:downgrade packages'
        'erase:remove packages'
        'fs:filesystem helpers'
        'fssnapshot:filesystem snapshot'
        'groups:work with groups'
        'help:show help'
        'history:show transaction history'
        'info:show package information'
        'install:install packages'
        'list:list packages'
        'load-transaction:load saved transaction'
        'makecache:create cache'
        'provides:find which provides file'
        'reinstall:reinstall'
        'repolist:list configured repos'
        'repository-packages:work with packages from repo'
        'resolvedep:resolve dependencies'
        'search:search packages'
        'shell:interactive shell'
        'swap:swap two packages'
        'update:update packages'
        'update-minimal:update minimal'
        'updateinfo:show advisory info'
        'upgrade:upgrade packages'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--tolerant[tolerant]' \
        '-t[tolerant]' \
        '--cacheonly[cache only]' \
        '-C[cache only]' \
        '--randomwait=+[random wait]:n:' \
        '-R+[random wait]:n:' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--rpmverbosity=+[rpm verbosity]:level:(emergency alert critical error warning notice info debug)' \
        '--installroot=+[install root]:dir:_files -/' \
        '--showduplicates[show duplicates]' \
        '--enablerepo=+[enable repo]:list:' \
        '--disablerepo=+[disable repo]:list:' \
        '--exclude=+[exclude packages]:list:' \
        '-x+[exclude packages]:list:' \
        '--disableplugin=+[disable plugin]:list:' \
        '--enableplugin=+[enable plugin]:list:' \
        '--obsoletes[handle obsoletes]' \
        '--noplugins[no plugins]' \
        '--nogpgcheck[no gpg check]' \
        '--skip-broken[skip broken]' \
        '--color=+[color]:c:(always auto never)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--assumeyes[assume yes]' \
        '-y[assume yes]' \
        '--assumeno[assume no]' \
        '--setopt=+[set option]:str:' \
        '--bugfix[bugfix only]' \
        '--security[security only]' \
        '--cve=+[CVE]:list:' \
        '--bz=+[bugzilla id]:str:' \
        '--advisory=+[advisory id]:str:' \
        '--sec-severity=+[sec severity]:str:' \
        '--downloadonly[download only]' \
        '--downloaddir=+[download dir]:dir:_files -/' \
        '--destdir=+[destdir]:dir:_files -/' \
        '--releasever=+[release version]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yum subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|erase|upgrade|update|reinstall|downgrade|info|list|search|provides|deplist|swap) _arguments '*:package:' ;;
                history) _arguments \
                    '1:cmd:(list info undo redo rollback userinstalled new sync stats)' \
                    '*:arg:' ;;
                groups) _arguments \
                    '1:cmd:(install remove list info summary)' \
                    '*:arg:' ;;
                repolist) _arguments \
                    '1:cmd:(all enabled disabled)' ;;
            esac
            ;;
    esac
}

_yum-cli "$@"
