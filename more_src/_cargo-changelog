#compdef cargo-changelog
# Documentation: https://github.com/matthiasbeyer/cargo-changelog
# Merge-friendly changelog management tool for the CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmd' && ret=0

case $state in
  cmd)
    _values 'cargo-changelog subcommand' \
      'init[initialize cargo-changelog on a project]' \
      'add[generate a new unreleased changelog file]' \
      'create-release[move unreleased changes to a version]' \
      'generate[re-generate CHANGELOG.md from entries]' && ret=0
    ;;
esac

return ret
