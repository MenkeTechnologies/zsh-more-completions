#compdef giac icas
# Documentation: https://man.archlinux.org/search?q=giac
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-readline[disable readline]' \
  '--xcas[enable Xcas mode]' \
  '--mupad[MuPAD-like syntax]' \
  '--maple[Maple-like syntax]' \
  '--ti[TI compatibility mode]' \
  '*:file:_files -g "*.{cxx,cas,xws}"' && ret=0

return ret
