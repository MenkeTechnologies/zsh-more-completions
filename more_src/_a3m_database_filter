#compdef a3m_database_filter
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# a3m_database_filter: filter an a3m ffindex database by a given set file

local ret=1

_arguments -s -S \
  '-h[show usage]' \
  '-i+[ffindex a3m database prefix]:prefix:_files' \
  '-o+[output ffindex a3m database prefix]:prefix:_files' \
  '-s+[filter set file]:file:_files' && ret=0

return ret
