#compdef dbeaver-cli dbeaver dbeaverc
# Documentation: https://github.com/dbeaver/dbeaver/wiki/Command-Line
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-help[show help]' \
  '-stop[terminate DBeaver]' \
  '-dump[print thread dump]' \
  '-con+[open database connection with parameters (driver=...|host=...|name=...|...)]:connection string:' \
  '-connect+[open database connection in UI]:connection params:' \
  '-closeTabs[close all open editor tabs]' \
  '-disconnectAll[close all open connections]' \
  '-f+[open file in SQL editor]:file:_files' \
  '-reuseWorkspace[force single workspace reuse across instances]' \
  '-newInstance[create new DBeaver instance]' \
  '-bringToFront[bring DBeaver window to front]' \
  '-runTask+[execute specified task (commercial)]:task:' \
  '-var+[set custom variable for tasks (commercial)]:name=value:' \
  '-vars+[path to properties file for runtime variables]:file:_files' \
  '-license+[license file path]:file:_files' \
  '-nl+[UI language/locale]:locale:' \
  '-data+[workspace path]:dir:_files -/' \
  '-nosplash[omit splash screen]' \
  '-clean[clear Eclipse caches]' \
  '-vmargs[pass VM parameters]' \
  '*:file:_files'
