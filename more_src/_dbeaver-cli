#compdef dbeaver-cli

# Zsh completion for dbeaver-cli (DBeaver database tool CLI)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-con=[connect to database]:connection string' \
  '-closeTabs[close all open editor tabs]' \
  '-create[create new connection]' \
  '-disconnect=[disconnect from datasource]:datasource' \
  '-disconnectAll[disconnect from all datasources]' \
  '-f+[open file in SQL editor]:file:_files' \
  '-reuseEditor[reuse already open editor]' \
  '-newInstance[force open new DBeaver instance]' \
  '-nosplash[do not show splash screen]' \
  '-nl[new line in console mode]' \
  '-bringToFront[bring DBeaver window to front]' \
  '*:file:_files'
