#compdef xia2
# Documentation: https://xia2.github.io/
# Automated data reduction pipeline for macromolecular crystallography

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'pipeline=[processing pipeline]:pipeline:(3d 3dii dials dials-aimless)' \
  'atom=[separate anomalous pairs in scaling]:atom' \
  '*image=[process specific scans or image range image.img:start:end]:file:_files' \
  'xinfo=[use a modified .xinfo input file]:file:_files' \
  'space_group=[set the spacegroup]:sg' \
  'unit_cell=[set unit cell constants a,b,c,alpha,beta,gamma]:cell' \
  'small_molecule=[process small molecule data]:bool:(true false)' \
  'cc_half=[override default resolution limit calculation]:value' \
  'misigma=[set mean intensity/sigma threshold]:value' \
  'isigma=[set intensity/sigma threshold]:value' \
  'project=[set project name]:name' \
  'crystal=[set crystal identifier]:name' \
  'hdf5_plugin=[path to HDF5 reader for Eiger data]:file:_files' \
  'nproc=[number of processors to use]:n' \
  '*:arg:_files' && ret=0

return ret
