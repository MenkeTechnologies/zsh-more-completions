#compdef xen-livepatch
# Documentation: https://man.archlinux.org/search?q=xen-livepatch
# Reference accessed: 2026-05-16

# xen-livepatch: load/unload Xen live patches
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'list:list loaded patches'
  'upload:upload a patch payload'
  'apply:apply an uploaded patch'
  'revert:revert an applied patch'
  'unload:unload a patch'
  'replace:replace patches in a single transaction'
  'load:load and apply patch in one step'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xen-livepatch command' commands && ret=0 ;;
esac
return ret
