#compdef dbxflat
# EMBOSS: index a flat file database using b+tree indices

local ret=1

_arguments -s -S \
  '-dbname=[basename for index files]:dbname' \
  '-dbresource=[resource name]:dbresource' \
  '-idformat=[entry format]:format:(EMBL SWISS GB REFSEQ FASTQ USPTO)' \
  '-filenames=[wildcard pattern for database files]:pattern' \
  '-directory=[database directory]:dir:_files -/' \
  '-fields=[which fields to index]:fields:(id acc sv des key org)' \
  '-compressed[create compressed index files]' \
  '-nocompressed[do not compress index files]' \
  '-outfile=[output log file name]:outfile:_files' \
  '-auto[turn off prompts]' \
  '-stdout[write first file to standard output]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-die[report dying program messages]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-version[report version number and exit]' && ret=0

return ret
