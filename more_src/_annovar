#compdef annotate_variation.pl table_annovar.pl convert2annovar.pl coding_change.pl retrieve_seq_from_fasta.pl annovar
# _annovar — Kai Wang ANNOVAR efficient annotation of genetic variants from high-throughput sequencing data Perl scripts (annovar team, Perl); custom argparse
# upstream: https://annovar.openbioinformatics.org

_annovar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-buildver+[build version]:b:(hg18 hg19 hg38 mm9 mm10 GRCh37 GRCh38 rn4 rn5 rn6)' \
        '--buildver=+[build version]:b:(hg18 hg19 hg38 mm9 mm10 GRCh37 GRCh38 rn4 rn5 rn6)' \
        '-out+[output prefix]:str:' \
        '--outfile=+[output prefix]:str:' \
        '-protocol+[csv protocols]:str:' \
        '--protocol=+[csv protocols]:str:' \
        '-operation+[csv operations]:str:' \
        '--operation=+[csv operations]:str:' \
        '-nastring+[NA string]:str:' \
        '--nastring=+[NA string]:str:' \
        '-csvout[CSV output]' \
        '-otherinfo[include other info]' \
        '-thread+[N threads]:n:' \
        '--thread=+[N threads]:n:' \
        '-maxgenethread+[N]:n:' \
        '-arg+[arguments]:str:' \
        '--argument=+[arguments]:str:' \
        '-remove[remove temp files]' \
        '-polish[polish output]' \
        '-vcfinput[VCF input]' \
        '-onetranscript[one transcript per gene]' \
        '-codingarg+[arguments]:str:' \
        '-geneanno[gene annotation]' \
        '-regionanno[region annotation]' \
        '-filter[filter annotation]' \
        '-downdb[download database]' \
        '-webfrom+[web source]:s:(annovar ucsc)' \
        '-tempfile+[file]:file:_files' \
        '-keepfirst[keep first transcript]' \
        '-precedence+[csv precedence]:str:' \
        '-dbtype+[database type]:str:' \
        '--dbtype=+[database type]:str:' \
        '-comment[include comment]' \
        '-batchsize+[N]:n:' \
        '-genericbatchsize+[N]:n:' \
        '-firstcodondel[first codon del]' \
        '-exonicsplicing[exonic splicing]' \
        '-keepidx[keep index]' \
        '-aamatrixfile+[file]:file:_files' \
        '-bedfile+[file]:file:_files -g "*.bed"' \
        '-genericdbfile+[file]:file:_files' \
        '-gffdbfile+[file]:file:_files -g "*.gff *.gff3 *.gtf"' \
        '-vcfdbfile+[file]:file:_files -g "*.vcf *.vcf.gz"' \
        '-otherinfo[include other info]' \
        '-time[print timing]' \
        '*:input VCF or annovar:_files -g "*.vcf *.avinput *.txt *.tab"'
}

_annovar "$@"
