#compdef iadd
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Add two images

local ret=1

_arguments -s -S \
  'IMAGE=[first image]:image:_files' \
  'IMAGE1=[second image]:image:_files' \
  'OUTPUT=[resulting image]:output:_files' \
  '*:NDF data file:_files' && ret=0

return ret
