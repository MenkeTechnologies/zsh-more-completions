#compdef gettextize
# Documentation: gettextize --help (GNU gettext)
# Source: prepare a source package to use gettext.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    {-f,--force}'[force writing even if old files exist]' \
    '--po-dir=[directory with PO files]:dir:_files -/' \
    '--no-changelog[do not update or create ChangeLog files]' \
    '--symlink[make symbolic links instead of copying files]' \
    {-n,--dry-run}'[print modifications but do not perform them]' \
    '*:package-dir:_files -/' \
    && ret=0

return ret
