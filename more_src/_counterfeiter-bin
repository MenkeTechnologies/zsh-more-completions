#compdef counterfeiter
# _counterfeiter-bin — counterfeiter Go fake generator (Pivotal/MaxBrunsfeld, Go); generates fakes for interface testing
# upstream: https://github.com/maxbrunsfeld/counterfeiter

_counterfeiter-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-version)-version[show version]' \
        '-o+[output file]:file:_files' \
        '-fake-name+[fake type name]:name:' \
        '-header+[file header (eg license)]:file:_files' \
        '-q[quiet]' \
        '-p[generate package-level fake]' \
        '-generate[regenerate from go:generate comments]' \
        '*:package interface:'
}

_counterfeiter-bin "$@"
