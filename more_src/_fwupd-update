#compdef fwupd-update

# fwupd-update: helper that drives `fwupdmgr update` (non-interactive)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-y[answer yes to all prompts]' \
  '--assume-yes[answer yes to all prompts]' \
  '--allow-older[allow downgrades]' \
  '--allow-reinstall[allow reinstall]' \
  '--no-reboot-check[do not prompt for reboot]' \
  '--json[JSON output]' \
  '*::fwupd-update args:_files' && ret=0
return ret
