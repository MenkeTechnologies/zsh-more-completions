#compdef sbom-convert
# Documentation: https://github.com/protobom/sbom-convert
# convert SBOMs between CycloneDX and SPDX formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[logging verbosity level]' \
  '(-f --format)'{-f,--format}'=[target format]:format:' \
  '(-e --encoding)'{-e,--encoding}'=[output encoding]:encoding:' \
  '(-o --output)'{-o,--output}'=[output file path]:file:_files' \
  '1:command:->cmds' \
  '*::arg:_files' && ret=0

case $state in
  cmds)
    _values 'sbom-convert command' \
      'convert[convert an SBOM document]' && ret=0
    ;;
esac

return ret
