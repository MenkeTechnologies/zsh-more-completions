#compdef cargo-dylint
# Documentation: https://github.com/trailofbits/dylint
# Reference accessed: 2026-05-27
# Verified: upstream cargo-dylint/src/main.rs clap derive definitions
# (Dylint, Operation, LibrarySelection, OutputOptions) on master branch.

local curcontext="$curcontext" state line ret=1
local -a _dylint_subcommands

_dylint_subcommands=(
  'list:list libraries or lints'
  'new:create a new library package'
  'upgrade:upgrade library package'
)

local -a _dylint_lib_args
_dylint_lib_args=(
  '--all[load all discovered libraries]'
  '--branch=[branch to use when downloading library packages]:branch:'
  '--git=[git URL containing library packages]:url:'
  '*--lib-path=[library path to load lints from]:path:_files -/'
  '*--lib=[library name to load lints from]:name:'
  '--manifest-path=[path to Cargo.toml]:file:_files -g Cargo.toml'
  '--no-build[do not build metadata entries]'
  '--no-metadata[ignore metadata entirely]'
  '*--path=[path containing library packages]:path:_files -/'
  '--pattern=[subdirectories of --git or --path containing library packages]:pattern:'
  '--rev=[specific commit to use when downloading library packages]:rev:'
  '--tag=[tag to use when downloading library packages]:tag:'
)

local -a _dylint_output_args
_dylint_output_args=(
  '--pipe-stderr=[path to pipe stderr to]:file:_files'
  '--pipe-stdout=[path to pipe stdout to]:file:_files'
  '(-q --quiet)'{-q,--quiet}'[do not show warnings or progress]'
)

_arguments -C \
  '--fix[automatically apply lint suggestions]' \
  '--keep-going[continue if cargo check fails]' \
  '--no-deps[do not check other packages within the workspace]' \
  '*'{-p+,--package=}'[package to check]:spec:' \
  '--workspace[check all packages in the workspace]' \
  $_dylint_lib_args \
  $_dylint_output_args \
  '(- 1 *)'{-h,--help}'[print help]' \
  '(- 1 *)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cargo-dylint subcommand' _dylint_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments \
          $_dylint_lib_args \
          $_dylint_output_args && ret=0
        ;;
      new)
        _arguments \
          '--isolate[put the package in its own workspace]' \
          $_dylint_output_args \
          '1:path:_files -/' && ret=0
        ;;
      upgrade)
        _arguments \
          '--allow-downgrade[allow downgrade (hidden)]' \
          '--rust-version=[upgrade to clippy_utils with tag rust-VERSION]:version:' \
          '--auto-correct[try to extract fixes from Clippy repository commits]' \
          $_dylint_output_args \
          '1:path:_files -/' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
