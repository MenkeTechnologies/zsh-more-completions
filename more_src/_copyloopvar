#compdef copyloopvar dupword exhaustivestruct fatcontext funcorder promlinter testableexamples
# Documentation: upstream READMEs at github.com/{karamaru-alpha/copyloopvar,Abirdcfly/dupword,mbilski/exhaustivestruct,Crocmagnon/fatcontext,manuelarte/funcorder,yeya24/promlinter,maratori/testableexamples}
# Reference accessed: 2026-05-30
# Continuation of Go linter sweep R25 — 7 more single-purpose linters
# wrapping the analysis/passes framework. Most are also runnable via
# `go vet -vettool=$(which TOOL) PKG/...` and through golangci-lint.
# Hunt-note: exhaustivestruct is archived (2022-12-06) but still
# documented and used through golangci-lint v1.x; coverage is for
# historical-codebases.

local curcontext="$curcontext" state line ret=1

case $service in

  copyloopvar)
    # karamaru-alpha/copyloopvar — flag unnecessary loop-variable copies
    # (v := v, i := i) — addressable since Go 1.22 loop-variable semantics.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  dupword)
    # Abirdcfly/dupword — detect duplicate words in comments and strings.
    _arguments -s -S \
      '-fix[apply fixes automatically]' \
      '-keyword=[target words (comma-separated)]:words:' \
      '-test=[analyze test files (default true)]:bool:(true false)' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  exhaustivestruct)
    # mbilski/exhaustivestruct — flag struct literals with uninitialized fields.
    # ARCHIVED 2022-12-06; preserved for historical-codebase use via golangci-lint.
    _arguments -s -S \
      '-struct_patterns=[comma-separated patterns to match struct package+name]:patterns:' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  fatcontext)
    # Crocmagnon/fatcontext — detect nested contexts in loops or function literals
    # (e.g. `ctx = context.WithValue(ctx, ...)` inside a loop without `:=` rebinding).
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  funcorder)
    # manuelarte/funcorder — enforce function/method/constructor ordering
    # (Uber style guide: exported first, constructors after struct decl,
    # alphabetical within visibility group).
    _arguments -s -S \
      '-constructor=[check constructor placement]:bool:(true false)' \
      '-struct-method=[check method visibility within structs]:bool:(true false)' \
      '-alphabetical=[sort within visibility groups]:bool:(true false)' \
      '-function=[check function visibility ordering]:bool:(true false)' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  promlinter)
    # yeya24/promlinter — Prometheus metrics-naming linter (built on promlint).
    local -a _subcmds
    _subcmds=(
      'list:display discovered metric names'
      'lint:validate metrics against promlint rules'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'promlinter subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          lint)
            _arguments \
              '--disable=[disable specific checks (comma-separated)]:checks:' \
              '--strict[detailed error reporting]' \
              '*:Go package or file:_files' && ret=0
            ;;
          list)
            _arguments \
              '*:Go package or file:_files' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  testableexamples)
    # maratori/testableexamples — flag Example functions missing `// Output:`
    # comments (without them, `go test` compiles but doesn't execute them).
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
