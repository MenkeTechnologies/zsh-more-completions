#compdef kclx
# _kclx — extended KCL CLI with plugins (kcl-lang/cli)
# upstream: https://github.com/kcl-lang/cli
# Subcommands from cmd/kcl/commands/*.go (cobra).

_kclx() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:compile and run KCL files'
                'fmt:format KCL files'
                'lint:lint KCL files'
                'vet:type-check KCL against a schema'
                'test:run KCL tests'
                'doc:generate KCL documentation'
                'import:import schemas (OpenAPI/JSON/CRD/etc) as KCL'
                'clean:clean cached artifacts'
                'mod:manage KCL packages'
                'registry:manage OCI registry credentials'
                'plugin:manage KCL plugins'
                'server:run KCL server'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                mod)
                    _arguments '1:sub:(init add update pull push graph metadata pkg test)'
                    ;;
                registry)
                    _arguments '1:sub:(login logout)'
                    ;;
            esac
            ;;
    esac
}

_kclx "$@"
