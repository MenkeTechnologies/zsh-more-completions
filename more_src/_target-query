#compdef target-query
# Documentation: https://github.com/fox-it/dissect.target/blob/main/dissect/target/tools/query.py
# dissect.target query tool - run forensic plugins/functions against targets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--direct[treat TARGETS as paths to pass to plugins directly]' \
  '--direct-sensitive[same as --direct but paths are case-sensitive]' \
  '(-s --strings)'{-s,--strings}'[print output as string]' \
  '(-d --delimiter)'{-d,--delimiter}'=[field delimiter]:delimiter' \
  '(-j --json)'{-j,--json}'[output records as json]' \
  '--limit=[limit number of produced records]:n' \
  '(--no-cache --ignore-cache)'{--no-cache,--ignore-cache}'[do not use file based caching]' \
  '--only-read-cache[only read cache files, never write them]' \
  '--rewrite-cache[force cache files to be rewritten]' \
  '--cmdb[use cmdb]' \
  '--hash[hash all paths in records]' \
  '--resolve[resolve all paths in records]' \
  '--report-dir=[write the query report file to the given directory]:dir:_files -/' \
  '(-f --function)'{-f,--function}'=[comma separated functions to execute]:function' \
  '(-xf --excluded-functions)'{-xf,--excluded-functions}'=[functions to exclude from execution]:function' \
  '(-l --list)'{-l,--list}'=[list matching available plugins and loaders]::filter' \
  '--dry-run[print which functions would be executed without running them]' \
  '(-K --keychain-file)'{-K,--keychain-file}'=[keychain file in CSV format]:file:_files' \
  '(-Kv --keychain-value)'{-Kv,--keychain-value}'=[passphrase, recovery key or key file path value]:value' \
  '(-L --loader)'{-L,--loader}'=[select a specific loader]:loader' \
  '--child=[load child of target by path or index]:child' \
  '--children[include children]' \
  '--list-children[list children indices and paths, then exit]' \
  '--recursive[make --(list-)children behave recursively]' \
  '*'{-v,--verbose}'[increase output verbosity]' \
  '--version[print version]' \
  '(-q --quiet)'{-q,--quiet}'[do not output logging information]' \
  '--plugin-path=[a file or directory containing plugins and extensions]:path:_files' \
  '*:target:_files' && ret=0

return ret
