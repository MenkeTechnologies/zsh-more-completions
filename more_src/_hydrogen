#compdef hydrogen

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --driver)'{-d,--driver}'+[audio driver]:driver:(jack alsa oss pulseaudio coreaudio portaudio)' \
  '(-s --song)'{-s,--song}'+[load song file]:file:_files -g "*.h2song"' \
  '(-k --kit)'{-k,--kit}'+[load drumkit]:kit:' \
  '(-p --playlist)'{-p,--playlist}'+[load playlist]:file:_files -g "*.h2playlist"' \
  '(-S --shotlist)'{-S,--shotlist}'+[shotlist]:file:_files' \
  '(-n --nosplash)'{-n,--nosplash}'[no splash screen]' \
  '(-V --verbose)'{-V,--verbose}'+[log level]:lvl:(None Error Warning Info Debug)' \
  '(-l --logFile)'{-l,--logFile}'+[log file]:file:_files' \
  '(-L --layout)'{-L,--layout}'+[ui layout]:lay:' \
  '(-N --nogui)'{-N,--nogui}'[no gui]' \
  '(-I --install)'{-I,--install}'+[install drumkit]:file:_files' \
  '(-i --interpolate)'{-i,--interpolate}'+[interpolation]:mode:(linear cosine third cubic hermite)' \
  '(-O --osc-port)'{-O,--osc-port}'+[OSC server port]:port:' \
  '(-T --version-check)'{-T,--version-check}'[check for updates]' \
  '(-c --child)'{-c,--child}'[run as a session child]' \
  '*:song:_files -g "*.h2song"' && ret=0

return ret
