#compdef hydrogen
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/hydrogen.1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-P --data)'{-P+,--data=}'[alternate system data directory]:path:_files -/' \
  '(-d --driver)'{-d+,--driver=}'[audio driver]:driver:(jack alsa oss pulseaudio auto)' \
  '(-s --song)'{-s+,--song=}'[load song file]:file:_files -g "*.h2song"' \
  '(-S --jacksessionid)'{-S+,--jacksessionid=}'[Jack session id]:id:' \
  '(-k --kit)'{-k+,--kit=}'[load drumkit]:kit:' \
  '(-p --playlist)'{-p+,--playlist=}'[load playlist]:file:_files -g "*.h2playlist"' \
  '(-i --install)'{-i+,--install=}'[install drumkit]:file:_files -g "*.h2drumkit"' \
  '(-n --nosplash)'{-n,--nosplash}'[hide splash screen]' \
  '(-V --verbose)'{-V-,--verbose=-}'[log level]:lvl:(None Error Warning Info Debug)' \
  '*:song:_files -g "*.h2song"' && ret=0

return ret
