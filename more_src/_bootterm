#compdef bootterm bt
# Documentation: https://github.com/wtarreau/bootterm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-h[show help]' \
  '-l[list available serial ports]' \
  '-n[wait for a new port to appear]' \
  '-a[wait for any port to become available]' \
  '-b+[baud rate]:rate:' \
  '-B[send break sequence before connecting]' \
  '-c+[capture mode]:mode:(none fixed timed)' \
  '-f+[capture filename format]:fmt:' \
  '-t+[timestamps mode]:mode:(none abs init line)' \
  '-e+[escape character]:char:' \
  '-m+[minimum printable char code]:n:' \
  '-M+[maximum printable char code]:n:' \
  '-p[print mode (device name)]' \
  '-q[quiet mode]' \
  '-N[non-interactive mode]' \
  '*:port:_files -W /dev'
