#compdef attic
# Documentation: https://github.com/zhaofengli/attic
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize a repository'
  'create:backup files into archive'
  'extract:restore files from archive'
  'check:verify repository/archive consistency'
  'list:display archives or contents'
  'info:show archive metadata'
  'delete:delete archive or repository'
  'prune:remove archives by retention policy'
  'mount:access archive via FUSE'
  'change-passphrase:update encryption passphrase'
  'serve:run server-side daemon'
)

_arguments -C \
  '*'{-v,--verbose}'[verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'attic subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments '--encryption=[encryption mode]:mode:(passphrase keyfile none)' && ret=0
        ;;
      (create)
        _arguments \
          '*--exclude=[exclude pattern]:pattern:' \
          '--exclude-from=[exclude file]:file:_files' \
          '--do-not-cross-mountpoints[do not cross mounts]' \
          '--stats[show stats]' && ret=0
        ;;
      (prune)
        _arguments \
          '--keep-daily=[daily archives]:n:' \
          '--keep-weekly=[weekly archives]:n:' \
          '--keep-monthly=[monthly archives]:n:' \
          '--keep-within=[keep within range]:duration:' \
          '--prefix=[archive prefix]:prefix:' && ret=0
        ;;
    esac
    ;;
esac

return ret
