#compdef abcde
# Documentation: man abcde(1)
# Source: abcde (man) — A Better CD Encoder (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-1[encode whole CD into one file]' \
    '-a+[comma-separated actions]:actions:_values -s , "actions" cddb cue read getalbumart normalize encode tag move replaygain playlist clean' \
    '-b[batch mode]' \
    '-c+[abcde config file]:file:_files' \
    '-C+[force a discid]:discid:_default' \
    '-d+[CD device or filename]:device:_files' \
    '-D[debug output]' \
    '-e[erase previous CD encoding info]' \
    '-f[force overwrite]' \
    '-g[lame --nogap (no gap between tracks)]' \
    '-G[interactive CDDB result]' \
    '-h[show help]' \
    '-j+[parallel jobs]:N:_default' \
    '-k[keep WAV files]' \
    '-l[use low disk space mode]' \
    '-L[use a CDDB cache]' \
    '-m[modify playlist for inclusion]' \
    '-n[no CDDB query]' \
    '-N[non-interactive]' \
    '-o+[output filetype[\:options]]:type:(mp3 ogg vorbis flac spx mpc m4a wav wv ape opus tta mp2)' \
    '-p[pad track numbers]' \
    '-P[use UNIX pipes (no temp files)]' \
    '-r+[remote hosts]:hosts:_hosts' \
    '-s+[CDDB fields shown]:fields:_default' \
    '-S+[CD read speed]:speed:_default' \
    '-t+[start track number]:N:_default' \
    '-T+[CDDB track-number start]:N:_default' \
    '-U[use UNICODE-aware CDDB]' \
    '-v[show version]' \
    '-V[verbose]' \
    '-x[exit after encoding]' \
    '-X+[cue2discid command]:command:_command_names -e' \
    '-w+[comment for tag]:comment:_default' \
    '-W+[multidisc number]:N:_default' \
    '-z[remove temporary files]' \
    '*:track number:_default' \
    && ret=0

return ret
