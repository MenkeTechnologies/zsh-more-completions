#compdef img2grd
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/img — extract a subset of a .img file into a GMT grid

local ret=1

_arguments -s \
  '-D+[extended latitude range of input img]:lat:_default' \
  '-E[force output grid to match exact region]' \
  '-F[Mercator coords relative to lower-left corner]' \
  '-G+[output grid file]:file:_files' \
  '-I+[input img pixel width in minutes]:width:_default' \
  '-M[output spherical Mercator grid]' \
  '-N+[average pixels into larger squares]:n:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '-S+[multiply values by scale factor]:scale:_default' \
  '-T+[constraint info encoding]:mode:_default' \
  '-W+[max longitude extent of input img]:lon:_default' \
  '*-V[verbose (stackable)]' \
  '-n+[grid interpolation mode]:mode:_default' \
  '*:input img file:_files' \
  && ret=0

return ret
