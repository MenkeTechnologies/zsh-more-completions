#compdef sjeng

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-q[quiet]' \
  '-xboard[xboard protocol]' \
  '-uci[UCI protocol]' \
  '-st+[search time sec]:sec:' \
  '-sd+[search depth]:depth:' \
  '-book+[book file]:file:_files' && ret=0

return ret
