#compdef h5perf
# Documentation: https://davis.lbl.gov/Manuals/HDF5-1.6.5/Tools.html
# Measures parallel HDF5 / MPI-IO / POSIX I/O performance

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message and exit]' \
  '(-a --align)'{-a+,--align=}'[alignment of objects in HDF5 file]:size' \
  '(-A --api)'{-A+,--api=}'[which APIs to test (phdf5,mpiio,posix)]:api list' \
  '(-B --block-size)'{-B+,--block-size=}'[block size within transfer buffer]:size' \
  '(-c --chunk)'{-c,--chunk}'[create HDF5 datasets in chunked layout]' \
  '(-C --collective)'{-C,--collective}'[use collective I/O for MPI-IO and PHDF5 APIs]' \
  '(-d --num-dsets)'{-d+,--num-dsets=}'[number of datasets per file]:N' \
  '(-D --debug)'{-D+,--debug=}'[set debugging level (1-4,r,t,v)]:flags' \
  '(-e --num-bytes)'{-e+,--num-bytes=}'[number of bytes per process per dataset]:size' \
  '(-F --num-files)'{-F+,--num-files=}'[number of files]:N' \
  '(-i --num-iterations)'{-i+,--num-iterations=}'[number of iterations to perform]:N' \
  '(-I --interleaved)'{-I,--interleaved}'[set interleaved block I/O]' \
  '(-m --mpi-posix)'{-m,--mpi-posix}'[use MPI-posix driver for HDF5 I/O]' \
  '(-n --no-fill)'{-n,--no-fill}'[do not write fill values to HDF5 datasets]' \
  '(-o --output)'{-o+,--output=}'[output file for raw data]:file:_files' \
  '(-p --min-num-processes)'{-p+,--min-num-processes=}'[minimum number of processes to use]:N' \
  '(-P --max-num-processes)'{-P+,--max-num-processes=}'[maximum number of processes to use]:N' \
  '(-T --threshold)'{-T+,--threshold=}'[threshold for alignment of objects]:size' \
  '(-w --write-only)'{-w,--write-only}'[perform only write tests, not read tests]' \
  '(-x --min-xfer-size)'{-x+,--min-xfer-size=}'[minimum transfer buffer size]:size' \
  '(-X --max-xfer-size)'{-X+,--max-xfer-size=}'[maximum transfer buffer size]:size' && ret=0

return ret
