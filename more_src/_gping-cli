#compdef gping
# Documentation: https://man.archlinux.org/search?q=gping
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-4)-4[IPv4]' \
  '(-6)-6[IPv6]' \
  '(-b --buffer)'{-b+,--buffer=}'[buffer seconds]:s:' \
  '(-c --cmd)'{-c,--cmd}'[exec command instead of pinging]' \
  '(-i --interval)'{-i+,--interval=}'[interval seconds]:s:' \
  '(-n --watch-interval)'{-n+,--watch-interval=}'[watch refresh ms]:ms:' \
  '(-s --simple-graphics)'{-s,--simple-graphics}'[simple graphics]' \
  '(--vertical-margin)--vertical-margin=[vertical margin]:n:' \
  '(--horizontal-margin)--horizontal-margin=[horizontal margin]:n:' \
  '(-t --color)*'{-t+,--color=}'[graph color]:c:' \
  '*: :_hosts' && ret=0

return ret
