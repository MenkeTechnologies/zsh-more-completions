#compdef naps2
# Documentation: https://www.naps2.com/doc-command-line.html
# NAPS2 console scanning and PDF/image automation

local ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'[output file path, name and extension]:file:_files' \
  '(-e --email)'{-e,--email}'[send an email with the scan attached]:filename:_files' \
  '(-a --autosave)'{-a,--autosave}'[use Auto Save settings from selected profile]' \
  '--listdevices[list scanners available for the specified driver]' \
  '--install=[install the specified component]:component:(ocr-eng ocr-fra)' \
  '--help[display usage documentation]' \
  '(-p --profile)'{-p,--profile}'[profile name to use when scanning]:profile' \
  '--noprofile[use default profile settings instead of a GUI profile]' \
  '--driver=[driver to use when scanning]:driver:(wia twain escl sane apple)' \
  '--device=[name of device to use when scanning]:device' \
  '--source=[paper source to use when scanning]:source:(glass feeder duplex)' \
  '--pagesize=[page size or dimension to use when scanning]:size' \
  '--dpi=[resolution in dots per inch]:dpi' \
  '--bitdepth=[bit depth to use when scanning]:depth:(color gray bw)' \
  '--deskew[automatically straighten pages]' \
  '--rotate=[rotate pages clockwise by degrees]:degrees' \
  '(-i --import)'{-i,--import}'[import one or more pdf/image files]:files:_files' \
  '--importpassword=[password to import encrypted PDFs]:password' \
  '--pdftitle=[title for generated PDF metadata]:title' \
  '--pdfauthor=[author for generated PDF metadata]:author' \
  '--pdfsubject=[subject for generated PDF metadata]:subject' \
  '--pdfkeywords=[keywords for generated PDF metadata]:keywords' \
  '--usesavedmetadata[use GUI-configured metadata for generated PDF]' \
  '--encryptconfig=[XML file to configure PDF encryption]:file:_files' \
  '--usesavedencryptconfig[use GUI-configured encryption for the PDF]' \
  '--pdfcompat=[standard used for the generated PDF]:type:(default A1-b A2-b A3-b A3-u)' \
  '--jpegquality=[JPEG quality level 0-100]:quality' \
  '--tiffcomp=[compression type for TIFF files]:type:(auto lzw ccitt4 none)' \
  '--to=[comma-separated email recipient addresses]:address' \
  '--cc=[comma-separated email cc addresses]:address' \
  '--bcc=[comma-separated email bcc addresses]:address' \
  '--subject=[subject of the email message]:subject' \
  '--body=[body text of the email message]:text' \
  '--autosend[send the email without prompting to edit it first]' \
  '--silentsend[do not prompt the user to authenticate]' \
  '--ocrlang=[three-letter code for the OCR language]:lang' \
  '--enableocr[use OCR when generating PDFs]' \
  '--disableocr[do not use OCR when generating PDFs]' \
  '--interleave[place odd-numbered pages before even-numbered ones]' \
  '--altinterleave[alternative page interleaving method]' \
  '--deinterleave[reorder interleaved pages into sequential order]' \
  '--altdeinterleave[alternative deinterleaving method]' \
  '--reverse[reverse the order of pages]' \
  '--split[save each page to its own PDF or TIFF file]' \
  '--splitscans[save pages from each scan to their own file]' \
  '--splitpatcht[split files separated by Patch-T pages]' \
  '--splitsize=[number of pages per output file]:count' \
  '(-v --verbose)'{-v,--verbose}'[display progress information]' \
  '--progress[display a graphical scanning progress window]' \
  '(-n --number)'{-n,--number}'[quantity of scanning operations]:count' \
  '(-d --delay)'{-d,--delay}'[delay in milliseconds between each scan]:ms' \
  '(-f --force)'{-f,--force}'[overwrite existing files]' \
  '(-w --wait)'{-w,--wait}'[wait for user input before exiting]' && ret=0

return ret
