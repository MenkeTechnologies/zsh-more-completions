#compdef pg_walsummary
# Documentation: https://www.postgresql.org/docs/current/app-pgwalsummary.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# pg_walsummary: print WAL summary file contents (PG 17+)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-i[show individual block info]' \
  '--individual[show individual block info]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '*:wal summary file:_files' && ret=0
return ret
