#compdef 1dBandpass
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dBandpass.html
# FFT-based bandpass filter for 1D time series

local ret=1

_arguments -s -S \
  '-dt[set time step in seconds (default 1.0)]:dd' \
  '-ort[orthogonalize input to columns in file]:file:_files' \
  '-nodetrend[skip quadratic detrending of input]' \
  '-norm[scale output to have L2 norm equal to 1]' \
  '*:file:_files' && ret=0

return ret
