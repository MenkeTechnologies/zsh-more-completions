#compdef newlisp

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-c[suppress prompt]' \
  '-C[show prompt]' \
  '-d+[daemon mode on port]:port:' \
  '-e+[evaluate expression]:expr:' \
  '-l+[redirect stdout to file]:file:_files' \
  '-L+[append to log file]:file:_files' \
  '-m+[max memory cells in MB]:mb:' \
  '-n[no init file]' \
  '-p+[network server on port]:port:' \
  '-r+[change root directory]:dir:_files -/' \
  '-s+[stack size]:bytes:' \
  '-t+[connection timeout]:ms:' \
  '-w+[working directory]:dir:_files -/' \
  '-x+[link executable to source]:file:_files' \
  '*:file:_files -g "*.lsp"' && ret=0

return ret
