#compdef newlisp
# Documentation: https://www.mankier.com/1/newlisp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-c[suppress prompt]' \
  '-C[show prompt in Emacs pipe I/O mode]' \
  '-http[only accept HTTP commands]' \
  '-d+[daemon mode on port]:port:' \
  '-e+[evaluate expression]:expr:' \
  '-l+[log connections/IO to file]:file:_files' \
  '-L+[log connections/IO append to file]:file:_files' \
  '-m+[max memory cells in MB]:mb:' \
  '-n[no init file]' \
  '-p+[network server on port]:port:' \
  '-s+[stack size]:bytes:' \
  '-t+[connection timeout in microseconds]:us:' \
  '-w+[working directory]:dir:_files -/' \
  '-x+[link executable to source]:source target:_files' \
  '-6[start in IPv6 mode]' \
  '*:file:_files -g "*.lsp"' && ret=0

return ret
