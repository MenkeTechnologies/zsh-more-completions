#compdef bluetui
# Documentation: https://man.archlinux.org/search?q=bluetui
# Reference accessed: 2026-05-16

# Zsh completion for bluetui (pythops/bluetui).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config-path)'{-c,--config-path=}'[path to TOML config]:file:_files'
