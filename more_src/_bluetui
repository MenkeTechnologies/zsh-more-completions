#compdef bluetui
# Documentation: https://github.com/pythops/bluetui
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for bluetui (pythops/bluetui).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config-path)'{-c,--config-path=}'[path to TOML config]:file:_files'
