#compdef wingetcreate
# _wingetcreate — Windows Package Manager Manifest Creator (microsoft/winget-create)
# upstream: https://github.com/microsoft/winget-create
# Subcommands + flags from src/WingetCreateCLI/Commands/*.cs (CommandLineParser).

_wingetcreate() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_wingetcreate_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)
                    _arguments \
                        '(-o --out)'{-o+,--out=}'[output directory]:dir:_files -/' \
                        '--allow-unsecure-downloads[allow downloading installers over HTTP]' \
                        '(-f --format)'{-f+,--format=}'[manifest format]:format:(yaml json)' \
                        '(-t --token)'{-t+,--token=}'[GitHub token]:token:' \
                        '(-n --no-open)'{-n,--no-open}'[do not open the PR in a browser]' \
                        '*:installer URL:_files' && ret=0 ;;
                update)
                    _arguments \
                        '(-v --version)'{-v+,--version=}'[new package version]:version:' \
                        '(-d --display-version)'{-d+,--display-version=}'[display version (if different from package version)]:version:' \
                        '--release-notes-url=[URL of release notes]:url:' \
                        '--release-date=[release date (YYYY-MM-DD)]:date:' \
                        '(-o --out)'{-o+,--out=}'[output directory]:dir:_files -/' \
                        '(-p --prtitle)'{-p+,--prtitle=}'[pull-request title]:title:' \
                        '(-s --submit)'{-s,--submit}'[submit the manifest to winget-pkgs]' \
                        '(-r --replace)'{-r,--replace}'[replace the previous version]' \
                        '(-i --interactive)'{-i,--interactive}'[interactive update mode]' \
                        '(-t --token)'{-t+,--token=}'[GitHub token]:token:' \
                        '(-n --no-open)'{-n,--no-open}'[do not open the PR in a browser]' \
                        '1:package id:' \
                        '*:installer URL:_files' && ret=0 ;;
                submit)
                    _arguments \
                        '(-p --prtitle)'{-p+,--prtitle=}'[pull-request title]:title:' \
                        '(-r --replace)'{-r,--replace}'[replace the previous version]' \
                        '(-t --token)'{-t+,--token=}'[GitHub token]:token:' \
                        '(-n --no-open)'{-n,--no-open}'[do not open the PR in a browser]' \
                        '1:manifest path:_files -/' && ret=0 ;;
                show)
                    _arguments \
                        '(-v --version)'{-v+,--version=}'[show this version (omit for latest)]:version:' \
                        '(-i --installer-manifest)'{-i,--installer-manifest}'[show the installer manifest]' \
                        '(-d --defaultlocale-manifest)'{-d,--defaultlocale-manifest}'[show the default-locale manifest]' \
                        '(-l --locale-manifests)'{-l,--locale-manifests}'[show all locale manifests]' \
                        '--version-manifest[show the version manifest]' \
                        '(-f --format)'{-f+,--format=}'[output format]:format:(yaml json)' \
                        '(-t --token)'{-t+,--token=}'[GitHub token]:token:' \
                        '1:package id:' && ret=0 ;;
                token)
                    _arguments \
                        '(-c --clear)'{-c,--clear}'[clear the stored GitHub token]' \
                        '(-s --store)'{-s,--store}'[store a new GitHub token]' \
                        '(-t --token)'{-t+,--token=}'[GitHub token value (with --store)]:token:' && ret=0 ;;
                cache)
                    _arguments \
                        '(-c --clean)'{-c,--clean}'[clean the cache]' \
                        '(-l --list)'{-l,--list}'[list cached entries]' \
                        '(-o --open)'{-o,--open}'[open the cache directory]' && ret=0 ;;
                new-locale|update-locale)
                    _arguments \
                        '(-l --locale)'{-l+,--locale=}'[BCP-47 locale (e.g. en-US)]:locale:' \
                        '(-o --out)'{-o+,--out=}'[output directory]:dir:_files -/' \
                        '1:package id:' && ret=0 ;;
                dsc|settings|info) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_wingetcreate_commands] )) ||
_wingetcreate_commands() {
    local -a commands
    commands=(
        'new:create a new winget manifest from installer URL(s)'
        'update:update an existing winget manifest to a new version'
        'submit:submit a manifest to the winget-pkgs community repo'
        'show:display a published manifest from winget-pkgs'
        'new-locale:scaffold a new locale manifest for a package'
        'update-locale:update an existing locale manifest for a package'
        'token:manage the stored GitHub PAT used for submissions'
        'cache:list / clean the wingetcreate cache'
        'settings:edit wingetcreate settings'
        'info:print wingetcreate environment info'
        'dsc:DSC v3 resource bridge'
    )
    _describe -t commands 'wingetcreate command' commands
}

_wingetcreate "$@"
