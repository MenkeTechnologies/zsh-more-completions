#compdef astyle

# Zsh completion for Artistic Style (astyle) code formatter

_astyle() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--style=[brace style]:style:(allman java kr stroustrup whitesmith vtk ratliff gnu linux horstmann 1tbs google mozilla webkit pico lisp)' \
    '(-A1)'-A1'[Allman style]' \
    '(-A2)'-A2'[Java style]' \
    '(-A3)'-A3'[K&R style]' \
    '(-A4)'-A4'[Stroustrup style]' \
    '(-A5)'-A5'[Whitesmith style]' \
    '(-A6)'-A6'[VTK style]' \
    '(-A7)'-A7'[Ratliff style]' \
    '(-A8)'-A8'[GNU style]' \
    '(-A9)'-A9'[Linux style]' \
    '(-A10)'-A10'[Horstmann style]' \
    '(-A14)'-A14'[Google style]' \
    '(-A16)'-A16'[Mozilla style]' \
    '(-s --indent=spaces)'{-s,--indent=spaces}'[indent using spaces]:spaces per indent:' \
    '(-t --indent=tab)'{-t,--indent=tab}'[indent using tabs]:tab size:' \
    '(-T --indent=force-tab)'{-T,--indent=force-tab}'[indent using force tab]:tab size:' \
    '(-xT --indent=force-tab-x)'{-xT,--indent=force-tab-x}'[indent force tab x]:tab size:' \
    '--attach-namespaces[attach braces to namespace statements]' \
    '--attach-classes[attach braces to class statements]' \
    '--attach-inlines[attach braces to inline functions]' \
    '--attach-extern-c[attach braces to extern "C" statements]' \
    '--attach-closing-while[attach closing while to do statement]' \
    '--indent-classes[indent class blocks]' \
    '--indent-modifiers[indent class access modifiers]' \
    '--indent-switches[indent switch blocks]' \
    '--indent-cases[indent case blocks]' \
    '--indent-namespaces[indent namespace blocks]' \
    '--indent-after-parens[indent after parens]' \
    '--indent-continuation=[indent continuation lines]:indent count:' \
    '--indent-labels[indent labels]' \
    '--indent-preproc-block[indent preprocessor blocks]' \
    '--indent-preproc-define[indent preprocessor define continuations]' \
    '--indent-preproc-cond[indent preprocessor conditionals]' \
    '--indent-col1-comments[indent C++ comments in column 1]' \
    '--min-conditional-indent=[minimal indent for continuation line]:indent mode:(0 1 2 3)' \
    '--max-continuation-indent=[max indent for continuation line]:indent:' \
    '--break-blocks[break before and after unrelated blocks]' \
    '--break-blocks=all[break before and after all blocks]' \
    '--pad-oper[pad around operators]' \
    '--pad-comma[pad after commas]' \
    '--pad-paren[pad around parentheses]' \
    '--pad-paren-out[pad outside parentheses]' \
    '--pad-paren-in[pad inside parentheses]' \
    '--pad-first-paren-out[pad first paren outside only]' \
    '--pad-header[pad after header]' \
    '--unpad-paren[unpad inside parentheses]' \
    '--delete-empty-lines[delete empty lines within a function]' \
    '--fill-empty-lines[fill empty lines with whitespace]' \
    '--align-pointer=[align pointer]:alignment:(type middle name)' \
    '--align-reference=[align reference]:alignment:(none type middle name)' \
    '--break-closing-braces[break closing header braces]' \
    '--break-elseifs[break else-if header combinations]' \
    '--break-one-line-headers[break one-line headers]' \
    '--add-braces[add braces to one-line conditional statements]' \
    '--add-one-line-braces[add one-line braces]' \
    '--remove-braces[remove braces from one-line conditional statements]' \
    '--break-return-type[break return type from function name]' \
    '--attach-return-type[attach return type to function name]' \
    '--keep-one-line-blocks[do not break one-line blocks]' \
    '--keep-one-line-statements[do not break one-line statements]' \
    '--convert-tabs[convert tabs to spaces]' \
    '--close-templates[close template spacing]' \
    '--remove-comment-prefix[remove comment prefix]' \
    '--max-code-length=[break lines longer than max]:length:' \
    '--break-after-logical[break after logical operator]' \
    '--mode=[set file mode]:mode:(c java cs)' \
    '(-n --suffix=none)'{-n,--suffix=none}'[do not retain backup files]' \
    '--suffix=[set backup suffix]:suffix:' \
    '(-R --recursive)'{-R,--recursive}'[recurse into subdirectories]' \
    '--dry-run[do not write output files]' \
    '--exclude=[exclude directory or file]:path:_files' \
    '--ignore-exclude-errors[continue if excluded files are not found]' \
    '--ignore-exclude-errors-x[continue with no error if excluded are not found]' \
    '--errors-to-stdout[print errors to stdout]' \
    '--preserve-date[preserve the original file date]' \
    '-v[verbose mode]' \
    '--verbose[verbose mode]' \
    '-Q[formatted files display mode]' \
    '--formatted[formatted files display mode]' \
    '-q[quiet mode]' \
    '--quiet[quiet mode]' \
    '--lineend=[set line end mode]:mode:(windows linux macold)' \
    '--options=[specify options file]:options file:_files' \
    '--options=none[do not use an options file]' \
    '--project=[specify project options file]:file:_files' \
    '--ascii[display ASCII characters only]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-V --version)'{-V,--version}'[display version]' \
    '*:source files:_files -g "*.{c,cpp,cc,cxx,h,hpp,hxx,cs,java,m,mm}"' \
    && ret=0

  return ret
}

_astyle "$@"
