#compdef imba
# ============================================================================
# _imba — zsh completion for the Imba programming language CLI driver
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/imba/imba
#   Author     : Sindre Aarsaether
#   License    : MIT
#   Stars      : 6500
#   Language   : JavaScript (compiler bootstrap) / Imba (.imba source files)
#   npm        : imba v2.0.0-alpha.251
#   Binaries   : imba   (runtime + bundler driver — ./bin/imba)
#                imbac  (compiler — ./bin/imbac)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Imba is "the friendly full-stack language" — an indentation-sensitive,
#   memoized-rendering, Ruby-influenced programming language that compiles
#   to JavaScript and targets browser + Node.js.  Imba's calling card is
#   its DOM tag literal syntax (`<button @click=submit> "Send"`) and the
#   memoized rendering model that powers it (the compiler emits an
#   incremental DOM diffing layer with O(1) tag reconciliation).  The
#   language also ships:  CSS-in-source via top-level `css` blocks,
#   first-class JSX-style web components without an explicit virtual DOM,
#   typed-ish duck typing via inferred shapes, and a built-in dev server
#   with HMR.  The `imba` binary doubles as runtime + bundler + dev server;
#   `imbac` is the pure compiler binary.
#
# CLI ARGUMENT GRAMMAR  (verbatim from packages/imba/bin/imba.imba commander
#                       chain;  `binary = cli.storeOptionsAsProperties(false)
#                                            .version(...).name('imba')`)
#   imba <command> [SCRIPT] [OPTIONS]
#
#   Commands  (.command(...) chain):
#     run [SCRIPT]              (DEFAULT) run an Imba/JS entrypoint
#                                 -i, --instances [count]   number to start
#                                 --inspect                 enable debugger
#                                 --memlimit <bytes>        process memlimit
#                                 (+ all common build options below)
#     build [SCRIPT]            Build an imba/js/html entrypoint and deps
#                                 --platform <platform>     default "browser"
#                                 (+ all common build options below)
#     preview                   Locally preview production build (Vite only)
#                                 --port <port>             preview port
#                                 (+ all common build options below)
#     serve                     Spawn a webserver for an entrypoint
#                                 -i, --instances [count]
#                                 --port <port>
#                                 --host [host]             true → 0.0.0.0
#                                 (+ all common build options below)
#     test                      Run tests (wrapper over vitest)
#                                 -h, --help                vitest help link
#     bench                     Run benchmark tests (vitest bench wrapper)
#                                 -h, --help                vitest bench help
#     create [name]             Create a new imba project from a template
#                                 -t, --template [template] template name
#                                 -y, --yes                 yes to all prompts
#                                 --fast                    random name +
#                                                           defaults, print
#                                                           resulting dir only
#     info                      Print helpful information
#     fmt [formatters...]       Strip extra whitespace + debug logs from
#                               **/*.imba files
#                                 -f, --force               format even with
#                                                           dirty git tree
#
#   Common build options  (added to run / build / preview / serve via the
#                          `common(cmd)` helper function):
#     -o, --outdir <dir>        directory to output files
#     -w, --watch               continuously build and watch project
#     --loglevel <level>        debug | info | success | warning | error | silent
#     -v, --verbose             verbosity (repeat to increase, count)
#     -s, --sourcemap           enable sourcemaps
#     -S, --no-sourcemap        omit sourcemaps
#     -m, --minify              minify generated files
#     -M, --no-minify           disable minifying
#     -f, --force               disregard previously cached outputs
#     -k, --keep                keep existing files in output directory
#     -d, --development         use defaults for development
#     -p, --production          use defaults for production
#     --br                      compress assets with brotli
#     --vite                    use Vite as a bundler
#     --fork                    disable cluster mode
#     --esbuild                 use the built-in esbuild bundler
#     --skipReloadingFor <glob> skip reloading server code for these globs
#                               (micromatch format)
#     --bundle                  try to bundle all external dependencies
#     --base <url>              base url for generated site         [/]
#     --assets-dir <dir>        base dir for assets                 [assets]
#     --web                     build entrypoints for the browser
#     --esm                     output module files
#     --writeBundlePathTo <url> write bundle path to a file
#
#   Standard commander auto-flags:
#     -V, --version             print version
#     -h, --help                print help (per-command)
#
# LANGUAGE-CORPUS POSITION
#   Imba is the 139th programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R825 (_yamldap/ldap3_proto
#   Rust=114 opens Axis 59) and continued through R826 (_ldap2pg/go-ldap
#   Go=114) and R827 (_ldap-server-mock/ldapjs TS-Node=114 CLOSES Axis 59
#   LDAP Directory Service Library at 1/1/1 + triple-114 landmark + 52
#   axes at 1/1/1).  Imba joins the roster of exotic languages already in
#   the corpus including Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), Stanza (R812 135th), Rune, Egel, Mlatu, Gwion, Silq (quantum),
#   Mirth, Lawvere/bill, Cognac/Cognate, and Scrapscript.
#
#   No completion for `imba` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_imba() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_imba_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)         _imba_run        && ret=0 ;;
                build)       _imba_build      && ret=0 ;;
                preview)     _imba_preview    && ret=0 ;;
                serve)       _imba_serve      && ret=0 ;;
                test)        _imba_test       && ret=0 ;;
                bench)       _imba_bench      && ret=0 ;;
                create)      _imba_create     && ret=0 ;;
                info)        _imba_info       && ret=0 ;;
                fmt)         _imba_fmt        && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_imba_commands] )) ||
_imba_commands() {
    local -a commands
    commands=(
        'run:run an Imba/JS entrypoint (default command)'
        'build:build an imba/js/html entrypoint and its dependencies'
        'preview:locally preview production build (Vite only)'
        'serve:spawn a webserver for an entrypoint'
        'test:run tests (wrapper on top of vitest)'
        'bench:run benchmark tests (wrapper on top of vitest bench)'
        'create:create a new imba project from a template'
        'info:print helpful information'
        'fmt:strip extra whitespace and debug/commented logs from **/*.imba'
    )
    _describe -t commands 'imba command' commands
}

# Common build/bundler options shared by run/build/preview/serve
_imba_common_args() {
    print -- \
        '(-o --outdir)'{-o+,--outdir=}'[directory to output files]:output dir:_files -/' \
        '(-w --watch)'{-w,--watch}'[continuously build and watch project]' \
        '--loglevel=[log level]:level:(debug info success warning error silent)' \
        '*'{-v,--verbose}'[verbosity (repeat to increase)]' \
        '(-s --sourcemap -S --no-sourcemap)'{-s,--sourcemap}'[enable sourcemaps]' \
        '(-s --sourcemap -S --no-sourcemap)'{-S,--no-sourcemap}'[omit sourcemaps]' \
        '(-m --minify -M --no-minify)'{-m,--minify}'[minify generated files]' \
        '(-m --minify -M --no-minify)'{-M,--no-minify}'[disable minifying]' \
        '(-f --force)'{-f,--force}'[disregard previously cached outputs]' \
        '(-k --keep)'{-k,--keep}'[keep existing files in output directory]' \
        '(-d --development -p --production)'{-d,--development}'[use defaults for development]' \
        '(-d --development -p --production)'{-p,--production}'[use defaults for production]' \
        '--br[compress assets with brotli]' \
        '--vite[use Vite as a bundler]' \
        '--fork[disable cluster mode]' \
        '--esbuild[use the built-in esbuild bundler]' \
        '--skipReloadingFor=[skip reloading server code for these globs (micromatch)]:glob:' \
        '--bundle[try to bundle all external dependencies]' \
        '--base=[base url for generated site (default /)]:base url:' \
        '--assets-dir=[base dir for assets (default assets)]:assets dir:' \
        '--web[build entrypoints for the browser]' \
        '--esm[output module files]' \
        '--writeBundlePathTo=[write bundle path to a file]:bundle path file:_files'
}

(( $+functions[_imba_run] )) ||
_imba_run() {
    _arguments \
        $(_imba_common_args) \
        '(-i --instances)'{-i+,--instances=}'[number of instances to start]:count:' \
        '--inspect[enable Node.js debugger]' \
        '--memlimit=[memory limit of the process (bytes)]:bytes:' \
        '(- *)'{-h,--help}'[help for run]' \
        ':script:_files -g "*.(imba|js|mjs|ts)"'
}

(( $+functions[_imba_build] )) ||
_imba_build() {
    _arguments \
        $(_imba_common_args) \
        '--platform=[target platform (default browser)]:platform:(browser node neutral)' \
        '(- *)'{-h,--help}'[help for build]' \
        ':script:_files -g "*.(imba|js|html|mjs|ts)"'
}

(( $+functions[_imba_preview] )) ||
_imba_preview() {
    _arguments \
        $(_imba_common_args) \
        '--port=[port for preview server]:port:' \
        '(- *)'{-h,--help}'[help for preview]'
}

(( $+functions[_imba_serve] )) ||
_imba_serve() {
    _arguments \
        $(_imba_common_args) \
        '(-i --instances)'{-i+,--instances=}'[number of instances to start]:count:' \
        '--port=[port for dev server]:port:' \
        '--host=[host (true for 0.0.0.0; see Vite server-options)]:host:_hosts' \
        '(- *)'{-h,--help}'[help for serve]'
}

(( $+functions[_imba_test] )) ||
_imba_test() {
    _arguments \
        '(- *)'{-h,--help}'[display help (links to https://vitest.dev/)]'
}

(( $+functions[_imba_bench] )) ||
_imba_bench() {
    _arguments \
        '(- *)'{-h,--help}'[display help (links to vitest bench docs)]'
}

(( $+functions[_imba_create] )) ||
_imba_create() {
    _arguments \
        '(-t --template)'{-t+,--template=}'[specify a template instead of selecting interactively]:template:' \
        '(-y --yes)'{-y,--yes}'[say yes to any confirmation prompts]' \
        '--fast[generate random project name, default to all prompts, print only resulting directory name]' \
        '(- *)'{-h,--help}'[help for create]' \
        ':project name:'
}

(( $+functions[_imba_info] )) ||
_imba_info() {
    _arguments \
        '(- *)'{-h,--help}'[help for info]'
}

(( $+functions[_imba_fmt] )) ||
_imba_fmt() {
    _arguments \
        '(-f --force)'{-f,--force}'[format without checking git status]' \
        '(- *)'{-h,--help}'[help for fmt]' \
        '*:formatter:'
}

_imba "$@"
