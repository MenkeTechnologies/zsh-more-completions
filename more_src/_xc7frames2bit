#compdef xc7frames2bit
# Documentation: https://github.com/SymbiFlow/prjxray/blob/master/tools/xc7frames2bit.cc
# Project X-Ray: convert frame deltas to a 7-series bitstream

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--part_name=[name of the 7-series part]:part' \
  '--part_file=[definition file for target 7-series part]:file:_files' \
  '--frm_file=[file with list of frame deltas to apply]:file:_files' \
  '--output_file=[write bitstream to file]:file:_files' \
  '--architecture=[architecture of the provided bitstream]:arch:(Series7)' && ret=0

return ret
