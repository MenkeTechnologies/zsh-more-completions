#compdef qodana

# Zsh completion for JetBrains Qodana - code quality platform

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:run Qodana analysis'
      'show:show Qodana report'
      'init:initialize Qodana configuration'
      'send:send report to Qodana Cloud'
      'view:view previous reports'
      'contributors:show project contributors'
      'cloc:count lines of code'
      'pull:pull Qodana Docker image'
    )
    _describe -t commands 'qodana command' commands && ret=0
    ;;
  args)
    case $line[1] in
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-i+[project directory]:directory:_directories' \
          '--project-dir=[project directory]:directory:_directories' \
          '-o+[results directory]:directory:_directories' \
          '--results-dir=[results directory]:directory:_directories' \
          '-l+[linter to use]:linter' \
          '--linter=[linter to use]:linter' \
          '--ide=[IDE to use for analysis]:ide' \
          '-e+[environment variable]:var' \
          '--env=[environment variable]:var' \
          '-v+[volume mount]:mount' \
          '--volume=[volume mount]:mount' \
          '--cache-dir=[cache directory]:directory:_directories' \
          '--fail-threshold=[fail threshold]:threshold' \
          '--baseline=[baseline file]:file:_files -g "*.sarif.json"' \
          '--profile-name=[inspection profile name]:profile' \
          '--profile-path=[inspection profile path]:file:_files -g "*.xml"' \
          '--property=[JVM property]:property' \
          '--source-directory=[source directory]:directory:_directories' \
          '--disable-sanity[disable sanity inspections]' \
          '--save-report[save report]' \
          '--print-problems[print problems to stdout]' \
          '--clear-cache[clear cache before running]' \
          '--apply-fixes[apply fixes]' \
          '--cleanup[run code cleanup]' \
          '--fixes-strategy=[fixes strategy]:strategy:(apply cleanup)' \
          '--stub-profile=[stub profile path]:file:_files' && ret=0
        ;;
      show)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-d+[report directory]:directory:_directories' \
          '--report-dir=[report directory]:directory:_directories' \
          '-p+[port]:port' \
          '--port=[port]:port' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-i+[project directory]:directory:_directories' \
          '--project-dir=[project directory]:directory:_directories' \
          '-f[force overwrite existing config]' \
          '--force[force overwrite existing config]' && ret=0
        ;;
    esac
    ;;
esac

return ret
