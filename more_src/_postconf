#compdef postconf

_arguments -s \
  '-a[show SASL plugin types]' \
  '-A[show TLS provider types]' \
  '-b[show bounce templates]' \
  '-c=[config directory]:dir:_files -/' \
  '-C=[parameter class]:class:(builtin service user all)' \
  '-d[show default values]' \
  '-e[edit values (deprecated; implicit)]' \
  '-f[fold long lines]' \
  '-F[show master.cf entries]' \
  '-h[suppress parameter name in output]' \
  '-H[show parameter names only]' \
  '-l[show lock types]' \
  '-m[show lookup table types]' \
  '-M[show master.cf service entries]' \
  '-n[show non-default values]' \
  '*-o=[override parameter name=value]:override:' \
  '-p[show main.cf]' \
  '-P[show per-service master parameters]' \
  '-t[show template]' \
  '-T=[show TLS settings]:setting:' \
  '-v[verbose]' \
  '-x[expand $name references]' \
  '-X[delete parameters]' \
  '-#[comment out parameters]' \
  '*:param:'
