#compdef postconf
# Documentation: https://www.postfix.org/postconf.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-a[list SASL plugin types for SMTP server]' \
  '-A[list SASL plugin types for SMTP client]' \
  '-b[show bounce message template]:template file:_files' \
  '-c+[config directory]:dir:_files -/' \
  '-C+[parameter class]:class:(builtin service user all)' \
  '-d[print default parameter settings]' \
  '-e[edit main.cf]' \
  '-f[fold long lines]' \
  '-F[show master.cf per-entry field settings]' \
  '-h[show values without name = label]' \
  '-H[show parameter or attribute names only]' \
  '-l[list supported mailbox locking methods]' \
  '-m[list supported lookup table types]' \
  '-M[show master.cf file contents]' \
  '-n[show only explicit name=value parameters]' \
  '*-o+[override parameter as name=value]:override:' \
  '-p[show main.cf parameter settings (default)]' \
  '-P[show master.cf service parameter settings]' \
  '-t[show bounce message template]:template file:_files' \
  '-T+[show TLS settings]:mode:(compile-version run-version public-key-algorithms)' \
  '*-v[verbose logging (repeatable)]' \
  '-x[expand $name references]' \
  '-X[edit main.cf and remove parameters]' \
  '-#[edit main.cf and comment out parameters]' \
  '*:param:'
