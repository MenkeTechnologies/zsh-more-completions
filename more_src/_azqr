#compdef azqr
# Documentation: https://github.com/Azure/azqr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'scan:scan Azure subscriptions and write report'
      'show:open interactive report dashboard'
      'openai-throttling:OpenAI throttling monitor plugin'
      'carbon-emissions:carbon emissions plugin'
      'zone-mapping:availability zone mapping plugin'
      'mcp:start MCP server'
      'plugins:plugin commands'
      'help:help'
    )
    _describe -t commands 'azqr command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      scan)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--debug[debug logging]' \
          '--subscription-id=[subscription ID]:id' \
          '--management-group-id=[management group]:id' \
          '--resource-group=[resource group]:name' \
          '--output-name=[output base name]:name' \
          '--json[JSON output]' \
          '--csv[CSV output]' \
          '--filters=[filters YAML]:file:_files' \
          '*--stages=[scan stages]:stage' \
          '*--plugin=[internal plugin]:plugin' \
          && ret=0
        ;;
      show)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --file)'{-f,--file}'=[report file]:file:_files' \
          '--open[open browser]' \
          && ret=0
        ;;
      mcp)
        _arguments -s -S \
          '--mode=[transport mode]:(stdio http)' \
          '--addr=[listen address for http]:addr' \
          && ret=0
        ;;
      plugins)
        _arguments -s -S '2:subcommand:(list)' '*: : _default' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
