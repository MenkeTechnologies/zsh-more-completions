#compdef iwgtk
# _iwgtk — iNet wireless daemon GTK frontend CLI alias (J. Lavoie, C); custom argparse
# upstream: https://github.com/J-Lentz/iwgtk

_iwgtk() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--indicator[run as system tray indicator]' \
        '-i[run as system tray indicator]' \
        '--no-indicator[no system tray indicator]' \
        '-n[no system tray indicator]' \
        '--display=+[display]:str:' \
        '-d+[display]:str:' \
        '*:arg:'
}

_iwgtk "$@"
