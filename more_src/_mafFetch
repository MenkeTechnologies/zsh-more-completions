#compdef mafFetch
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: select MAF records overlapping records in a BED using an index table

local ret=1

_arguments -s -S \
  '1:database:' \
  '2:table:' \
  '3:overlap bed:_files -g "*.bed"' \
  '4:output maf:_files -g "*.maf"' && ret=0

return ret
