#compdef funindex
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/funindex.1.html
# create an index for a column of a FITS binary table

local ret=1

_arguments -s -S \
  '-c[compress output using gzip]' \
  '-a[ASCII output, ignore -c (default: FITS table)]' \
  '-f[FITS table output (default: FITS table)]' \
  '-l[long output, i.e. with key value(s) (default)]' \
  '-s[short output, i.e. no key value(s)]' \
  '1:input FITS table:_files' \
  '2:output name:_files' && ret=0

return ret
