#compdef atlasquery
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/fslwiki/Atlasquery
# FSL: query brain atlases about stereotaxic coordinates or a mask

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --atlas)'{-a,--atlas=}'[name of atlas to use]:atlas:' \
  '(-m --mask)'{-m,--mask=}'[a mask image to use during structural lookups]:mask:_files' \
  '(-c --coord)'{-c,--coord=}'[coordinates X,Y,Z of point of interest (mm)]:coord:' \
  '(-V --verbose)'{-V,--verbose}'[switch on diagnostic messages]' \
  '--dumpatlases[dump a list of the available atlases]' \
  '*:arg:' && ret=0

return ret
