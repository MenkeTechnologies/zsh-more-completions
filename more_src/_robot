#compdef robot

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[output directory]:directory:_directories' \
  '--outputdir=[output directory]:directory:_directories' \
  '-o+[output file]:output file:_files -g "*.xml"' \
  '--output=[output file]:output file:_files -g "*.xml"' \
  '-l+[log file]:log file:_files -g "*.html"' \
  '--log=[log file]:log file:_files -g "*.html"' \
  '-r+[report file]:report file:_files -g "*.html"' \
  '--report=[report file]:report file:_files -g "*.html"' \
  '-x+[xunit compatible result file]:xunit file:_files -g "*.xml"' \
  '--xunit=[xunit compatible result file]:xunit file:_files -g "*.xml"' \
  '-b+[debug file]:debug file:_files' \
  '--debugfile=[debug file]:debug file:_files' \
  '-T[add timestamp to output files]' \
  '--timestampoutputs[add timestamp to output files]' \
  '-s+[select suite by name]:suite name' \
  '--suite=[select suite by name]:suite name' \
  '-t+[select test by name]:test name' \
  '--test=[select test by name]:test name' \
  '-i+[include tests by tag]:tag' \
  '--include=[include tests by tag]:tag' \
  '-e+[exclude tests by tag]:tag' \
  '--exclude=[exclude tests by tag]:tag' \
  '--skip=[skip tests by tag]:tag' \
  '--skiponfailure=[skip on failure tag]:tag' \
  '-R[rerun only failed tests]' \
  '--rerunfailed=[rerun failed from output]:output file:_files -g "*.xml"' \
  '--rerunfailedsuites=[rerun failed suites from output]:output file:_files -g "*.xml"' \
  '-N+[set top level suite name]:name' \
  '--name=[set top level suite name]:name' \
  '-D+[set top level suite documentation]:documentation' \
  '--doc=[set top level suite documentation]:documentation' \
  '-M+[set suite metadata]:name\:value' \
  '--metadata=[set suite metadata]:name\:value' \
  '-G+[set global tag]:tag' \
  '--settag=[set global tag]:tag' \
  '-v+[set variable]:name\:value' \
  '--variable=[set variable]:name\:value' \
  '-V+[variable file]:variable file:_files -g "*.py"' \
  '--variablefile=[variable file]:variable file:_files -g "*.py"' \
  '-P+[add library search path]:path:_directories' \
  '--pythonpath=[add library search path]:path:_directories' \
  '-L+[set log level]:level:(TRACE DEBUG INFO WARN ERROR NONE)' \
  '--loglevel=[set log level]:level:(TRACE DEBUG INFO WARN ERROR NONE)' \
  '--console=[console output type]:type:(verbose dotted quiet none)' \
  '--dotted[use dotted console output]' \
  '--quiet[suppress console output]' \
  '-W+[console width]:width' \
  '--consolewidth=[console width]:width' \
  '-C[use console colors]:mode:(auto on off ansi)' \
  '--consolecolors=[use console colors]:mode:(auto on off ansi)' \
  '-K=[console markers]:mode:(auto on off)' \
  '--consolemarkers=[console markers]:mode:(auto on off)' \
  '--listener=[register listener]:listener' \
  '--prerunmodifier=[pre-run modifier]:modifier' \
  '--prerebotmodifier=[pre-rebot modifier]:modifier' \
  '--dryrun[dry run mode]' \
  '--exitonfailure[exit on first failure]' \
  '--exitonerror[exit on error]' \
  '--skipteardownonexit[skip teardown on exit]' \
  '--randomize=[randomize execution order]:mode:(TESTS SUITES ALL NONE)' \
  '--maxerrorlines=[max error message lines]:count' \
  '--maxassignlength=[max assign variable display length]:count' \
  '*:data sources:_files' && ret=0

return ret
