#compdef umpv
# Documentation: https://man.archlinux.org/search?q=umpv
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:media file or URL:_files -g "*.mp4 *.mkv *.webm *.avi *.mov *.flv *.wmv *.mpg *.mpeg *.mp3 *.flac *.ogg *.opus *.m4a *.wav *.aiff *.aac"' && ret=0

return ret
