#compdef umpv
# Documentation: https://github.com/mpv-player/mpv/blob/master/TOOLS/umpv
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:media file or URL:_files -g "*.mp4 *.mkv *.webm *.avi *.mov *.flv *.wmv *.mpg *.mpeg *.mp3 *.flac *.ogg *.opus *.m4a *.wav *.aiff *.aac"' && ret=0

return ret
