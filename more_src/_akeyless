#compdef akeyless akeyless-cli
# _akeyless — Akeyless Vault unified secrets management CLI (Akeyless Security, Go); spf13/cobra
# upstream: https://github.com/akeylesslabs/akeyless-cli

_akeyless() {
    local -a sub=(
        'auth:authenticate'
        'auth-method:auth methods commands'
        'cluster:cluster commands'
        'completion:generate shell completion'
        'configure:configure CLI'
        'create-auth-method:create an auth method'
        'create-secret:create a secret'
        'create-rotated-secret:create rotated secret'
        'create-ssh-cert:create SSH cert'
        'create-rdp-cert:create RDP cert'
        'create-dynamic-secret:create dynamic secret'
        'create-pki-cert:create PKI cert'
        'create-role:create role'
        'create-target:create target'
        'create-tokenizer:create tokenizer'
        'create-event-forwarder:create event forwarder'
        'delete-item:delete item'
        'describe-item:describe item'
        'dynamic-secret:dynamic secret commands'
        'get-secret-value:get secret value'
        'gateway:gateway commands'
        'init:init CLI config'
        'kmip:KMIP commands'
        'list-items:list items'
        'list-roles:list roles'
        'list-targets:list targets'
        'rotated-secret:rotated secret commands'
        'set-item-state:set item state'
        'set-role-rule:set role rule'
        'static-secret:static secret commands'
        'target:target commands'
        'update-item:update item'
        'usage-report:usage report'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--profile=+[profile]:str:' \
        '--config=+[config file]:file:_files' \
        '--token=+[token]:str:' \
        '--access-id=+[access id]:str:' \
        '--access-key=+[access key]:str:' \
        '--access-type=+[access type]:t:(api_key password aws_iam azure_ad k8s saml oauth ldap email gcp openid universal_identity)' \
        '--api-url=+[API URL]:url:_urls' \
        '--cli-version[show cli version]' \
        '--json[json output]' \
        '-j[json output]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'akeyless subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments \
                    '--access-id=+[access id]:str:' \
                    '--access-key=+[access key]:str:' \
                    '--access-type=+[access type]:t:(api_key password aws_iam azure_ad k8s saml oauth ldap email gcp openid universal_identity)' \
                    '--admin-email=+[admin email]:str:' \
                    '--admin-password=+[admin password]:str:' ;;
                create-secret|create-rotated-secret|create-ssh-cert|create-rdp-cert|create-dynamic-secret|create-pki-cert) _arguments \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--value=+[value]:str:' \
                    '-v+[value]:str:' \
                    '--metadata=+[metadata]:str:' \
                    '--tag=+[tag]:list:' \
                    '*:arg:' ;;
                get-secret-value) _arguments \
                    '--names=+[names csv]:list:' \
                    '-n+[names csv]:list:' \
                    '--version=+[version]:n:' ;;
                list-items|list-roles|list-targets) _arguments \
                    '--filter=+[filter]:str:' \
                    '--type=+[type]:list:' \
                    '--path=+[path]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_akeyless "$@"
