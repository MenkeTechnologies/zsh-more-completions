#compdef resumeio2pdf
# ============================================================================
# resumeio2pdf - resume.io public-profile PDF exporter (Go, MIT)
#
# Author : Leonid Sopov (sopov)
# Upstream: https://github.com/sopov/resumeio2pdf
#
# resumeio2pdf takes a public resume.io profile URL (or its SecureID),
# fetches the per-page image renders + click-map metadata from the
# resume.io public CDN, and stitches the pages into a single PDF file
# with clickable hyperlinks overlaid at the correct pixel offsets - a
# clean-room PDF emitter for a third-party CV-hosting service that
# does not provide a public PDF download.
#
# The PDF emission lane is built on `github.com/signintech/gopdf v0.9.20`
# (declared verbatim in go.mod at HEAD - the older line that pre-dates
# the v0.36.0 modernization but is API-equivalent for the constructor +
# image-add path the tool exercises). Verbatim from upstream `main.go`:
#
#     package main
#     import (
#         "github.com/signintech/gopdf"
#     )
#
#     func generatePDF(info *metaInfo, images []string) error {
#         pdf := gopdf.GoPdf{}
#         pageSize := gopdf.Rect{ ... }
#         pdf.Start(gopdf.Config{PageSize: pageSize})
#         for i, image := range images {
#             pdf.AddPage()
#             pdf.Image(image, 0, 0, &pageSize)
#             for _, link := range info.Pages[i].Links {
#                 pdf.AddExternalLink(link.URL, link.Left, link.Top,
#                                     link.Width, link.Height)
#             }
#         }
#         return pdf.WritePdf(*pdfFileName)
#     }
#
# This is the canonical use of `gopdf`: instantiate `GoPdf{}`,
# `Start(Config{PageSize:...})`, then per-page `AddPage()` followed by
# the relevant content drawing calls (text, image, line, rect, link)
# and finally `WritePdf(filename)` to serialize to disk.
#
# ----------------------------------------------------------------------------
# AXIS 198 :: PDF GENERATION (PDF 1.7 / ISO 32000-1)
# Round 1293 :: Go slot 2 of 4 :: continues Axis 198
#
# Cross-language canonical library family for this axis:
#   Rust    : printpdf + lopdf            (fschutt + J-F-Liu)       [R1292 _markdown2pdf]
#   Go      : signintech/gopdf            (active jung-kurt successor) [R1293 THIS FILE]
#   TS/Node : foliojs/pdfkit              (dominant Node PDF lib)      [R1294 closing]
#
# `signintech/gopdf` is the modern maintained Go PDF builder, sitting
# at 2900+ stars on github.com/signintech/gopdf with active commits
# (HEAD 2026-05-19). It is the de-facto successor to the long-dormant
# `jung-kurt/gofpdf` project which was archived in 2021 after the
# original author stepped back; gopdf inherited the same Cell/Text/Rect
# API surface plus modern additions (TTF font embedding, Unicode + CJK
# support, image embedding via Go's stdlib image/* packages).
#
# resumeio2pdf is a clean example of the "pages-from-images" workflow -
# instead of building text/shape content from scratch, the tool grabs
# pre-rendered page images from resume.io's CDN and emits a PDF where
# each page is a single full-bleed image with link annotations layered
# on top. This exercises gopdf's `.Image()` + `.AddExternalLink()`
# surface, which is the most commonly-used pair after the text path.
# ============================================================================

_resumeio2pdf() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--url[link to resume of the format https://resume.io/r/SecureID]:url:' \
        '--sid[SecureID of resume (alternative to --url)]:secure id:' \
        '--pdf[output PDF filename (default: SecureID + .pdf)]:pdf file:_files -g "*.pdf"' \
        '--verbose[show detail information during fetch + emit]' \
        '-y[overwrite the output PDF if it already exists]' \
        '--version[show version and exit]' \
        '(- *)'{-h,--help}'[show help]'
}

_resumeio2pdf "$@"
