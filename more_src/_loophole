#compdef loophole
# Documentation: https://man.archlinux.org/search?q=loophole
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'http:expose local HTTP service'
  'path:serve a directory'
  'dir:alias for path'
  'directory:alias for path'
  'webdav:serve a directory over WebDAV'
  'account:manage account (login/logout)'
  'completion:generate shell completion'
  'docs:generate docs'
  'help:show help'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

local serve_args=(
  '(-i --identity-file)'{-i,--identity-file}'=[SSH identity file]:file:_files'
  '--hostname=[requested hostname]:name:'
  '--qr[print QR code]'
  '(-u --basic-auth-username)'{-u,--basic-auth-username}'=[basic auth user]:user:'
  '(-p --basic-auth-password)'{-p,--basic-auth-password}'=[basic auth password]:password:'
  '--disable-old-ciphers[disable old TLS ciphers]'
)

case $state in
  (subcommand)
    _describe -t subcommands 'loophole subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (http)
        _arguments $serve_args \
          '--https[upstream is HTTPS]' \
          '--disable-proxy-error-page[disable proxy error page]' \
          '--path=[URL path]:path:' \
          '*:port: ' && ret=0
        ;;
      (path|dir|directory|webdav)
        _arguments $serve_args '*:dir:_files -/' && ret=0
        ;;
      (account)
        _values 'account action' login logout && ret=0
        ;;
    esac
    ;;
esac

return ret
