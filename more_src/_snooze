#compdef snooze
# Documentation: https://github.com/leahneukirchen/snooze
# Lightweight cron replacement

_arguments -s -S \
  '-v[verbose mode, print next matching time]' \
  '-n[dry run, print matching times without executing]' \
  '-s[slack in seconds for matching]:seconds:' \
  '-t[timefile to use for one-shot jobs]:file:_files' \
  '-T[timefile to create/update]:file:_files' \
  '-R[random delay in seconds]:seconds:' \
  '-H[set hour constraint]:hours:' \
  '-M[set minute constraint]:minutes:' \
  '-S[set second constraint]:seconds:' \
  '-d[set day of month constraint]:days:' \
  '-m[set month constraint]:months:' \
  '-w[set weekday constraint]:weekdays:' \
  '-D[set day of year constraint]:days:' \
  '-W[set ISO week constraint]:weeks:' \
  '*:command:_command_names -e' \
  && return 0
