#compdef nest

# Zsh completion for nest - NestJS CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:generate a new Nest application'
  'n:alias for new'
  'generate:generate a Nest element'
  'g:alias for generate'
  'build:build a Nest application'
  'start:run a Nest application'
  'info:display system information'
  'i:alias for info'
  'add:add a library to your project'
  'update:update Nest dependencies'
  'u:alias for update'
)

local -a schematics=(
  'application:generate a new application workspace'
  'class:generate a new class'
  'configuration:generate a CLI configuration file'
  'controller:generate a controller declaration'
  'decorator:generate a custom decorator'
  'filter:generate a filter declaration'
  'gateway:generate a gateway declaration'
  'guard:generate a guard declaration'
  'interceptor:generate an interceptor declaration'
  'interface:generate an interface'
  'library:generate a new library in a monorepo'
  'middleware:generate a middleware declaration'
  'module:generate a module declaration'
  'pipe:generate a pipe declaration'
  'provider:generate a provider declaration'
  'resolver:generate a GraphQL resolver declaration'
  'resource:generate a new CRUD resource'
  'service:generate a service declaration'
  'sub-app:generate a new application within a monorepo'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[output usage information]' \
  '(-v --version)'{-v,--version}'[output the current version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nest command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (new|n)
        _arguments -s -S \
          '(-d --dry-run)'{-d,--dry-run}'[report actions without writing results]' \
          '(-s --skip-install)'{-s,--skip-install}'[skip package installation]' \
          '(-g --skip-git)'{-g,--skip-git}'[skip git repository initialization]' \
          '(-p --package-manager)'{-p,--package-manager}'[specify package manager]:manager:(npm yarn pnpm)' \
          '(-l --language)'{-l,--language}'[programming language]:language:(TS JS)' \
          '(-c --collection)'{-c,--collection}'[schematics collection]:collection:' \
          '--strict[enable strict mode in TypeScript]' \
          '1:application name' && ret=0
        ;;
      (generate|g)
        _arguments -s -S \
          '(-d --dry-run)'{-d,--dry-run}'[report actions without writing results]' \
          '(-p --project)'{-p,--project}'[project name to generate the element in]:project:' \
          '--flat[enforce flat structure of generated element]' \
          '--no-flat[enforce non-flat structure of generated element]' \
          '--spec[enable spec files generation]' \
          '--no-spec[disable spec files generation]' \
          '(-c --collection)'{-c,--collection}'[schematics collection]:collection:' \
          '1:schematic:->schematic' \
          '2:name' \
          '3:path:_files -/' && ret=0
        case $state in
          (schematic)
            _describe -t schematics 'schematic' schematics && ret=0
            ;;
        esac
        ;;
      (build)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to nest-cli configuration file]:file:_files' \
          '(-p --path)'{-p,--path}'[path to tsconfig file]:file:_files' \
          '(-w --watch)'{-w,--watch}'[run in watch mode (live-reload)]' \
          '(-b --builder)'{-b,--builder}'[builder to use]:builder:(tsc webpack swc)' \
          '--webpack[use webpack for compilation]' \
          '--webpackPath[path to webpack configuration]:file:_files' \
          '--tsc[use tsc for compilation]' \
          '--watchAssets[watch non-ts files]' \
          '1:app:' && ret=0
        ;;
      (start)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to nest-cli configuration file]:file:_files' \
          '(-p --path)'{-p,--path}'[path to tsconfig file]:file:_files' \
          '(-w --watch)'{-w,--watch}'[run in watch mode (live-reload)]' \
          '(-b --builder)'{-b,--builder}'[builder to use]:builder:(tsc webpack swc)' \
          '--debug[enable debug mode]:host\:port:' \
          '(-e --exec)'{-e,--exec}'[binary to run]:binary:' \
          '--preserveWatchOutput[preserve watch output between rebuilds]' \
          '1:app:' && ret=0
        ;;
    esac
    ;;
esac

return ret
