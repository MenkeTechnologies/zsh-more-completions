#compdef lxsudo

# lxsudo: LXQt wrapper that picks pkexec/sudo to run a GUI command as root
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[print version]' \
  '--su[force using su backend]' \
  '--sudo[force using sudo backend]' \
  '--pkexec[force using pkexec/polkit backend]' \
  '(-s --backend)'{-s,--backend=}'[backend to use]:backend:(su sudo pkexec)' \
  '*::command:_command_names -e' && ret=0

return ret
