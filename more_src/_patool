#compdef patool
# Documentation: https://github.com/wummel/patool/blob/master/doc/patool.txt
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'create:create an archive'
  'extract:extract files from an archive'
  'list:list contents of an archive'
  'test:test an archive for errors'
  'diff:show differences between two archives'
  'search:search in archive contents'
  'repack:repack an archive to a different format'
  'recompress:recompress an archive'
  'formats:show supported archive formats'
  'version:show version'
)

_arguments -s -S \
  '1:subcommand:->subcommand' \
  '(-v --verbose)'{-v,--verbose}'[verbose operation]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--non-interactive[non-interactive mode]' \
  '(- *)'{-h,--help}'[show help]' \
  '*::: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (create)
        _arguments -s -S \
          '--password=[archive password]:password:' \
          '1:archive file:_files' \
          '*:files to add:_files' && ret=0
        ;;
      (extract)
        _arguments -s -S \
          '--outdir=[output directory]:directory:_files -/' \
          '--password=[archive password]:password:' \
          '*:archive file:_files' && ret=0
        ;;
      (list|test)
        _arguments -s -S \
          '--password=[archive password]:password:' \
          '*:archive file:_files' && ret=0
        ;;
      (diff)
        _arguments -s -S \
          '1:first archive:_files' \
          '2:second archive:_files' && ret=0
        ;;
      (search)
        _arguments -s -S \
          '--password=[archive password]:password:' \
          '1:search pattern:' \
          '2:archive file:_files' && ret=0
        ;;
      (repack)
        _arguments -s -S \
          '1:source archive:_files' \
          '2:destination archive:_files' && ret=0
        ;;
      (recompress)
        _arguments -s -S \
          '1:archive file:_files' && ret=0
        ;;
      (formats|version)
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
