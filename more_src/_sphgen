#compdef sphgen
# Documentation: https://dock.compbio.ucsf.edu/DOCK_6/tutorials/sphere_generation/generating_spheres.htm
# sphgen - DOCK6 sphere generation from molecular surface (reads INSPH).

local ret=1

_arguments -s \
  '-i+[input parameter file (default INSPH)]:file:_files' \
  '-o+[output log file (default OUTSPH)]:file:_files' \
  '*:file:_files' && ret=0

return ret
