#compdef delp
# Documentation: delp -h (Free Pascal)
# Source: deletes Free Pascal compiler-generated files (.o, .ppu, etc.).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-e[delete executables too (not on Unix)]' \
    '*-x+[extension to delete (no dot)]:ext:' \
    '-r[recurse into directories]' \
    '-n[do not actually delete files]' \
    '-m+[max recursion depth (1-based, 0=no max)]:N:' \
    '-q[quiet]' \
    '-v[verbose - print names of deleted files]' \
    '*:directory:_files -/' \
    && ret=0

return ret
