#compdef simpress
# _libreoffice-impress — LibreOffice simpress / soffice --impress (presentation entrypoint; --show plays a slideshow then exits, --convert-to pptx/odp/pdf, --show-mode auto/manual, --norestore, --nofirststartwizard for unattended runs)
# upstream: https://git.libreoffice.org/core
# Flags from libreoffice core/desktop/source/app on tip.

_libreoffice-impress() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--headless[run without UI]' \
        '--norestore[skip restoring previous session]' \
        '--nologo[no splash]' \
        '--show[run slideshow then exit]' \
        '--convert-to+[convert to format]:format:(pdf pptx odp ppt fodp html svg png jpg)' \
        '--outdir+[output directory]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name+[printer]:printer:_printers' \
        '*-env+[env var]:key=value:' \
        '*:presentation:_files -g "*.(odp|pptx|ppt|fodp|key|pps|ppsx)"'
}

_libreoffice-impress "$@"
