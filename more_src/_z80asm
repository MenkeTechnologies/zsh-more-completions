#compdef z80asm z80nm z80dasm

local curcontext="$curcontext" state line ret=1

case $service in
  (z80asm)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '-i+[include file]:file:_files' \
      '*-I+[include path]:dir:_files -/' \
      '-l+[list file]:file:_files' \
      '-o+[output file]:file:_files' \
      '-L+[label file]:file:_files' \
      '-M+[mapfile]:file:_files' \
      '-e[error on bad addr]' \
      '-w[suppress warnings]' \
      '-v[verbose]' \
      '-r+[address]:n:' \
      '-b[binary output]' \
      '-c[chunked output]' \
      '-m+[memory size]:n:' \
      '-d+[define]:macro:' \
      '*: :_files -g "*.asm *.z80 *.s"' && ret=0 ;;
  (z80nm)
    _arguments -C \
      '-h[help]' \
      '-V[version]' \
      '-l[print list]' \
      '*: :_files -g "*.o *.lib"' && ret=0 ;;
  (z80dasm)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '(-a --address)'{-a+,--address=}'[start address hex]:n:' \
      '(-l --length)'{-l+,--length=}'[length]:n:' \
      '(-o --offset)'{-o+,--offset=}'[file offset]:n:' \
      '(-S --sym-output)'{-S+,--sym-output=}'[symbol output]:file:_files' \
      '(-s --sym-input)'{-s+,--sym-input=}'[symbol input]:file:_files' \
      '(-t --sym-output)'{-t,--sym-output}'[symbol output]' \
      '(-g --origin)'{-g+,--origin=}'[origin]:n:' \
      '(-O --output-name)'{-O+,--output-name=}'[output]:file:_files' \
      '*: :_files -g "*.bin *.rom *.com"' && ret=0 ;;
esac

return ret
