#compdef hmmlogo
# Documentation: http://hmmer.org/documentation.html
# HMMER: produce data for an HMM profile logo

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '--height_relent_all[height = relative entropy, all letters positive (default)]' \
  '--height_relent_abovebg[height = relative entropy, only above-background letters positive]' \
  '--height_score[height = sums of positive-scoring letter scores]' \
  '--no_indel[do not print the indel probability table]' \
  '*:hmm file:_files' && ret=0

return ret
