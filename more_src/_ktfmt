#compdef ktfmt
# Documentation: https://github.com/facebook/ktfmt/blob/main/core/src/main/java/com/facebook/ktfmt/cli/ParsedArgs.kt
# Reference accessed: 2026-05-19
# Verified: upstream ParsedArgs.kt flag parser. Removed from prior file:
# invented --drop-unused-imports, --print-width and bogus
# man.archlinux.org search URL.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[show version number]' \
  '(--google-style --kotlinlang-style)--meta-style[apply Meta 2-space block indent (default)]' \
  '(--meta-style --kotlinlang-style)--google-style[apply Google internal style (2 spaces)]' \
  '(--meta-style --google-style)--kotlinlang-style[apply Kotlin lang style (4-space block indent)]' \
  '(-n --dry-run)'{-n,--dry-run}'[do not write files; report files that would change]' \
  '--set-exit-if-changed[set exit code 1 if any input was not formatted]' \
  '--do-not-remove-unused-imports[preserve all imports even if unused]' \
  '--enable-editorconfig[enable .editorconfig overrides for formatting]' \
  '--quiet[suppress all non-error output]' \
  '--stdin-name=[name to report when formatting code from stdin]:name:' \
  '*:kotlin files:_files -g "*.kt(-.) *.kts(-.)"'
