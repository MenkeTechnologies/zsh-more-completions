#compdef ktfmt

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '--drop-unused-imports[Remove unused imports]' \
  '--google-style[Google Kotlin style]' \
  '--kotlinlang-style[Kotlin language style]' \
  '--print-width=[Max line width]:width:' \
  '*:kotlin files:_files -g "*.kt(-.) *.kts(-.)"'
