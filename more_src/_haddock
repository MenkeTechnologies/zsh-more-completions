#compdef haddock
# Documentation: haddock --help (Haskell)
# Source: documentation tool for annotated Haskell source code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '-B+[GHC lib dir override]:dir:_files -/' \
    {-o+,--odir=}'[output directory]:dir:_files -/' \
    {-l+,--lib=}'[auxiliary files location]:dir:_files -/' \
    '*'{-i+,--read-interface=}'[read interface from FILE]:file:_files' \
    {-D+,--dump-interface=}'[write resulting interface]:file:_files' \
    '--show-interface=[print interface human-readable]:file:_files' \
    '--no-compilation[never compile, read .hi files]' \
    '--incremental=[single module]:module:' \
    {-h,--html}'[output HTML]' \
    '--latex[experimental LaTeX rendering]' \
    '--latex-style=[LaTeX style file]:file:_files' \
    '--mathjax=[MathJax URL]:url:_urls' \
    {-U,--use-unicode}'[use Unicode in HTML output]' \
    '--hoogle[output for Hoogle]' \
    '--quickjump[interactive nav index]' \
    '--hyperlinked-source[hyperlinked source code]' \
    '--source-css=[custom CSS for hyperlinked source]:file:_files' \
    '--source-base=[URL for source link on contents]:url:_urls' \
    {-s+,--source-module=}'[per-module source URL]:url:_urls' \
    '--source-entity=[per-entity source URL]:url:_urls' \
    '--source-entity-line=[per-entity source URL fallback]:url:_urls' \
    '--comments-base=[comments URL on contents]:url:_urls' \
    '--base-url=[static asset base URL]:url:_urls' \
    '--comments-module=[per-module comments URL]:url:_urls' \
    '--comments-entity=[per-entity comments URL]:url:_urls' \
    {-c+,--css=,--theme=}'[CSS file or theme directory]:path:_files' \
    '--built-in-themes[include built-in themes]' \
    {-p+,--prologue=}'[prologue file]:file:_files' \
    {-t+,--title=}'[page heading]:title:' \
    {-q+,--qual=}'[name qualification]:mode:(none full local relative aliased)' \
    '--compatible-interface-versions[output compatible versions and exit]' \
    '--interface-version[output interface file version and exit]' \
    '--bypass-interface-version-check[bypass interface version check]' \
    {-v+,--verbosity=}'[verbosity level]:level:(0 1 2)' \
    '--use-contents=[URL for contents page]:url:_urls' \
    '--gen-contents[generate index of contents]' \
    '--use-index=[URL for index page]:url:_urls' \
    '--gen-index[generate alphabetical index]' \
    '--ignore-all-exports[behave as if all modules had hiding none]' \
    '--hide=[hide MODULE]:module:' \
    '--show=[show MODULE]:module:' \
    '--show-all[reverse all --hide]' \
    '--show-extensions=[show used extensions for MODULE]:module:' \
    '--optghc=[option to pass to GHC]:opt:' \
    '--ghc-version[output GHC version and exit]' \
    '--print-ghc-path[output GHC path and exit]' \
    '--print-ghc-libdir[output GHC lib dir and exit]' \
    '--package-name=[package name]:name:' \
    '--package-version=[package version]:version:' \
    '--no-tmp-comp-dir[do not use temporary compilation dir]' \
    '--no-warnings[turn off warnings]' \
    '*:file:_files -g "*.(hs|lhs|hi)"' \
    && ret=0

return ret
