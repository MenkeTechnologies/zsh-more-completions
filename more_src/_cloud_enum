#compdef cloud_enum
# Documentation: https://github.com/initstring/cloud_enum
# Enumerate public resources in AWS, Azure, and Google Cloud.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-k,--keyword}'[keyword to use (repeatable)]:keyword' \
  '(-kf --keyfile)'{-kf,--keyfile}'[input file with one keyword per line]:file:_files' \
  '(-m --mutations)'{-m,--mutations}'[custom mutations file]:file:_files' \
  '(-b --brute)'{-b,--brute}'[custom list for brute-forcing Azure containers]:file:_files' \
  '(-t --threads)'{-t,--threads}'[number of threads for HTTP brute-force (default 5)]:threads' \
  '(-ns --nameserver)'{-ns,--nameserver}'[DNS server to use in brute-force]:nameserver' \
  '(-l --logfile)'{-l,--logfile}'[append discovered items to file]:file:_files' \
  '(-f --format)'{-f,--format}'[log file format (default text)]:format:(text json csv)' \
  '--disable-aws[skip Amazon Web Services checks]' \
  '--disable-azure[skip Microsoft Azure checks]' \
  '--disable-gcp[skip Google Cloud Platform checks]' \
  '(-qs --quickscan)'{-qs,--quickscan}'[disable all mutations and second-level scans]' && ret=0

return ret
