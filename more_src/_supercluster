#compdef supercluster
# ============================================================================
#  _supercluster — Stellar-core integration test automation tool (F#)
#
#  Source-direct extraction from
#    https://github.com/stellar/supercluster/blob/main/src/App/Program.fs
#    https://github.com/commandlineparser/commandline (CommandLineParser
#    library — .NET cross-language)
#
#  Maintained by Stellar Development Foundation (stellar/supercluster).
#  9 GH stars (small but production tool for Stellar blockchain core
#  testing).  supercluster orchestrates Kubernetes-based integration
#  tests for Stellar-core (the Stellar blockchain node software) —
#  spins up multi-node test clusters in Kubernetes, runs synthetic load
#  scenarios called "missions", collects telemetry, and reports.
#  Sister tools: stellar-core (Stellar consensus node, in corpus),
#  stellar-cli (Stellar smart contract CLI, in corpus).
#
#  CLI library taxonomy update: 2nd F# CLI library — commandlineparser/
#  commandline (the .NET CommandLineParser library used from F#).
#  F# ecosystem now has 2 documented CLI libraries (R284 Argu + R364
#  CommandLineParser) joining the multi-library leaders.
#
#  CommandLineParser (commandlineparser/commandline; ~4500 GH stars on
#  the library repo) is the OLDEST .NET CLI library — predates
#  System.CommandLine.  Used by many .NET tools across C# and F#.
#  F# adapts it via class-with-attributes pattern: each subcommand is
#  an F# CLASS with `[<Verb("name", HelpText = "X")>]` ATTRIBUTE +
#  PROPERTIES annotated with `[<Option('s', "long", HelpText = "X",
#  Required = R, Default = V)>]` ATTRIBUTES.
#
#  CommandLineParser F# API:
#    open CommandLine
#
#    [<Verb("poll", HelpText = "Poll cluster for status")>]
#    type PollOptions(kubeConfig: string, ns: string option) =
#      [<Option('k', "kubeconfig", HelpText = "...",
#               Required = false, Default = "~/.kube/config")>]
#      member self.KubeConfig = kubeConfig
#
#      [<Option("namespace", HelpText = "...", Required = false)>]
#      member self.Namespace = ns
#
#    [<Verb("mission", HelpText = "Run one or more missions")>]
#    type MissionOptions(...) = ...
#
#    let parser = ParserResult.WithParsed(
#      Parser.Default.ParseArguments<PollOptions, MissionOptions,
#                                    ForceCleanNamespaceOptions>(args),
#      function
#      | :? PollOptions as opts -> handlePoll opts
#      | :? MissionOptions as opts -> handleMission opts
#      | ...)
#
#  CommandLineParser F# distinctive features:
#    - `[<Verb("name", HelpText = "X")>]` ATTRIBUTE on CLASS marks
#      it as a SUBCOMMAND
#    - `[<Option('s', "long", HelpText = "...", Required = R,
#       Default = V)>]` ATTRIBUTE on PROPERTY marks it as an
#       OPTION/FLAG
#    - F# CLASS INHERITANCE via `inherit BaseClass(args)` for SHARED
#      OPTION SETS (e.g. `inherit KubeOption(kubeConfig, ns)` makes
#      PollOptions / MissionOptions share kubeconfig + namespace
#      options without repetition)
#    - CONSTRUCTOR-INJECTION style: each option class takes constructor
#      args; CommandLineParser uses REFLECTION to discover constructor
#      parameters and BIND them to option values at parse time
#    - `Parser.Default.ParseArguments<T1, T2, T3>(args)` GENERIC PARSER
#      with VARIADIC TYPE PARAMETERS — caller lists all subcommand
#      types as generic parameters
#    - `ParserResult.WithParsed(parseResult, handlerFn)` SUCCESS
#      CALLBACK + `WithNotParsed(parseResult, errorHandlerFn)` ERROR
#      CALLBACK — fluent error handling
#    - `seq<string>` for repeatable string flags
#    - `string option` for optional flags (None if not given)
#  Distinct from R284 Argu (uses F# DISCRIMINATED UNIONS — `type
#  Arguments = | Flag1 | Flag2 of int`), R359 System.CommandLine
#  (CLR Argument<T>/Option<T> with imperative builder), R322 JCommander
#  (Java field annotations + reflection), R275 Rust clap-derive
#  (struct + proc-macro), R346 Scala mainargs (method annotations).
#  CommandLineParser F#'s approach: CLASS-WITH-ATTRIBUTES via F#'s
#  CLR-class-syntax + `[<Verb>]` attribute on class + `[<Option>]`
#  attribute on property + CONSTRUCTOR-INJECTION via reflection —
#  corpus's **first documented CLR-class-with-Verb-and-Option-
#  attributes CLI pattern**.  Brings cross-language CLI library
#  taxonomy variant count to 103; F# ecosystem now has 2 documented
#  CLI libraries.
#
#  Surface (verbatim from src/App/Program.fs):
#
#  Common KubeOption (shared via INHERITANCE):
#    -k, --kubeconfig FILE       Kubernetes config file
#                                (default ~/.kube/config)
#        --namespace NS          Namespace to use, overriding kubeconfig
#
#  Subcommands:
#    poll                        Poll a running stellar-core cluster
#                                for status (inherits KubeOption)
#    force-clean-namespace       Delete every K8s resource in namespace
#                                and helm-uninstall parallel-catchup-*
#                                releases (DESTRUCTIVE; inherits KubeOption)
#    mission                     Run one or more named missions
#                                (RICH option set — see below)
#
#  Mission-specific options (subset; full list ~60 options):
#    --num-nodes N               Number of nodes
#    --log-debug-partitions PARTS  Debug log partitions
#    --log-trace-partitions PARTS  Trace log partitions
#    --ingress-class CLASS       Ingress class
#    --ingress-internal-domain D  Internal ingress domain
#    --ingress-external-host H   External ingress host
#    --ingress-external-port P   External ingress port
#    --export-to-prometheus      Enable Prometheus export
#    --probe-timeout SEC         Probe timeout
#    --missions LIST             Mission names to run
#    --destination PATH          Output destination
#    --image NAME                Stellar-core image
#    --old-image NAME            Old version image
#    --tx-rate N                 Transaction rate
#    --max-tx-rate N             Max transaction rate
#    --num-accounts N            Number of accounts
#    --num-txs N                 Number of transactions
#    --spike-size N              Spike size
#    --spike-interval SEC        Spike interval
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - shader-minifier (laurentlb/shader-minifier 564 stars — uses Argu
#      already R284; not new)
#    - fsdocs (fsprojects/FSharp.Formatting — IN CORPUS via _fsdocs;
#      uses CommandLineParser already documented under different
#      attribution)
# ============================================================================

_supercluster() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'poll:poll cluster for status'
        'force-clean-namespace:delete all K8s resources in namespace (DESTRUCTIVE)'
        'mission:run one or more named missions'
      )
      _describe -t commands 'supercluster subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        poll|force-clean-namespace)
          _arguments -s -S \
            '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubernetes config file]:file:_files' \
            '--namespace=[namespace to use]:namespace'
          ;;
        mission)
          _arguments -s -S \
            '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubernetes config file]:file:_files' \
            '--namespace=[namespace to use]:namespace' \
            '--num-nodes=[number of nodes]:N' \
            '--log-debug-partitions=[debug log partitions]:parts' \
            '--log-trace-partitions=[trace log partitions]:parts' \
            '--ingress-class=[ingress class]:class' \
            '--ingress-internal-domain=[internal ingress domain]:domain' \
            '--ingress-external-host=[external ingress host]:host' \
            '--ingress-external-port=[external ingress port]:port' \
            '--export-to-prometheus[enable Prometheus export]' \
            '--probe-timeout=[probe timeout]:seconds' \
            '--missions=[mission names to run]:missions' \
            '--destination=[output destination]:path:_directories' \
            '--image=[stellar-core image]:image' \
            '--old-image=[old version image]:image' \
            '--tx-rate=[transaction rate]:rate' \
            '--max-tx-rate=[max transaction rate]:rate' \
            '--num-accounts=[number of accounts]:N' \
            '--num-txs=[number of transactions]:N' \
            '--spike-size=[spike size]:N' \
            '--spike-interval=[spike interval seconds]:seconds' \
            '--keep-data[keep data after run]' \
            '--api-rate-limit=[API rate limit]:limit'
          ;;
      esac
      ;;
  esac
}

_supercluster "$@"
