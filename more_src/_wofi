#compdef wofi

# Zsh completion for wofi - Wayland launcher/menu

_arguments \
  '(-)'{-h,--help}'[display help information]' \
  '(-)'{-v,--version}'[display version information]' \
  {-f,--fork}'[fork the process]' \
  {-S,--show}'[specify mode]:mode:(run drun dmenu)' \
  {-s,--style}'[specify style file]:style file:_files' \
  {-c,--conf}'[specify config file]:config file:_files' \
  {-C,--color}'[specify color file]:color file:_files' \
  {-W,--width}'[set width in pixels]:width (pixels)' \
  {-H,--height}'[set height in pixels]:height (pixels)' \
  {-p,--prompt}'[set prompt string]:prompt' \
  {-x,--xoffset}'[set x offset]:x offset' \
  {-y,--yoffset}'[set y offset]:y offset' \
  {-n,--normal-window}'[use normal window instead of layer shell]' \
  {-I,--no-actions}'[disable desktop actions]' \
  {-D,--define}'[define a config option]:key=value' \
  {-o,--output}'[specify output name]:output name' \
  {-O,--sort-order}'[set sort order]:sort order:(default alphabetical)' \
  {-Q,--search}'[set initial search string]:search string' \
  {-i,--insensitive}'[case insensitive matching]' \
  {-b,--location}'[set window location]:location:(0 1 2 3 4 5 6 7 8)' \
  {-k,--allow-images}'[allow images]' \
  {-K,--image-size}'[set image size]:image size' \
  {-a,--allow-markup}'[allow pango markup]' \
  {-m,--matching}'[set matching mode]:matching mode:(contains multi-contains fuzzy)' \
  {-e,--exec-search}'[execute search term if no match]' \
  {-L,--lines}'[set number of lines]:lines' \
  {-w,--columns}'[set number of columns]:columns' \
  {-d,--dmenu-separator}'[set dmenu separator]:separator' \
  {-G,--gtk-dark}'[use GTK dark theme]' \
  {-l,--layer}'[set layer]:layer:(background bottom top overlay)' \
  '--pre-display-cmd[command to run before displaying]:command' \
  '--password[enable password mode]' \
  '--cache-file[specify cache file]:cache file:_files' \
  '*:file:_files'
