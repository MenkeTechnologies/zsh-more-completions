#compdef wofi
# Documentation: https://man.archlinux.org/man/wofi.1.en
# Reference accessed: 2026-05-21
# Verified: upstream Arch wofi(1) man page OPTIONS list.

# Zsh completion for wofi - Wayland launcher/menu

_arguments \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  {-f,--fork}'[fork the menu process]' \
  {-c,--conf=}'[config file]:file:_files' \
  {-s,--style=}'[CSS stylesheet]:file:_files' \
  {-C,--color=}'[colors file]:file:_files' \
  {-d,--dmenu}'[enable dmenu mode]' \
  {-S,--show=}'[operation mode]:mode:(run drun dmenu)' \
  {-W,--width=}'[menu width (pixels or %)]:width' \
  {-H,--height=}'[menu height (pixels or %)]:height' \
  {-p,--prompt=}'[prompt text]:prompt' \
  {-x,--xoffset=}'[x offset in pixels]:offset' \
  {-y,--yoffset=}'[y offset in pixels]:offset' \
  {-n,--normal-window}'[use normal window instead of layer-shell]' \
  {-I,--allow-images}'[enable image escape sequences]' \
  {-m,--allow-markup}'[enable pango markup]' \
  {-k,--cache-file=}'[cache file]:file:_files' \
  {-t,--term=}'[terminal program]:term:_command_names' \
  {-P,--password=}'[enable password mode]:character' \
  {-e,--exec-search}'[execute search string instead of first result]' \
  {-E,--no-custom-entry}'[restrict submissions to entries only]' \
  {-b,--hide-scroll}'[hide scrollbars]' \
  {-M,--matching=}'[matching mode]:mode:(contains strict-contains multi-contains fuzzy)' \
  {-i,--insensitive}'[case-insensitive search]' \
  {-q,--parse-search}'[strip image/markup from search]' \
  {-l,--location=}'[window position]:location:(0 1 2 3 4 5 6 7 8)' \
  {-a,--no-actions}'[disable multiple actions]' \
  {-D,--define=}'[set config option]:KEY=VALUE' \
  {-L,--lines=}'[height by line count]:lines' \
  {-w,--columns=}'[column count]:columns' \
  {-O,--sort-order=}'[sort order]:order:(default alphabetical)' \
  {-G,--gtk-dark}'[use dark GTK theme]' \
  {-Q,--search=}'[perform immediate search]:string' \
  {-o,--monitor=}'[target monitor]:monitor' \
  {-r,--pre-display-cmd=}'[transform display output]:command' \
  {-j,--hide-search}'[hide search bar]'
