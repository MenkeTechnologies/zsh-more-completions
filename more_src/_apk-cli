#compdef apk-cli
# _apk-cli — Alpine Linux apk-tools package manager CLI alias (Alpine Linux team / Timo Teräs, C); custom argparse
# upstream: https://gitlab.alpinelinux.org/alpine/apk-tools

_apk-cli() {
    local -a sub=(
        'add:add packages'
        'audit:audit changed files'
        'cache:cache management'
        'del:delete packages'
        'dot:generate graph in DOT format'
        'fetch:fetch packages without installing'
        'fix:fix installed packages'
        'index:create repository index'
        'info:show info on packages'
        'list:list available/installed packages'
        'manifest:show file manifest'
        'policy:show repository preference policy'
        'search:search for packages'
        'stats:show stats'
        'update:update repository indexes'
        'upgrade:upgrade installed packages'
        'verify:verify package signatures'
        'version:show version comparisons'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--allow-untrusted[allow untrusted]' \
        '--arch=+[architecture]:str:' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--cache-max-age=+[cache max age]:n:' \
        '--cache-predownload[cache predownload]' \
        '--clean-protected[clean protected]' \
        '--force[force]' \
        '-f[force]' \
        '--force-binary-stdout[force binary stdout]' \
        '--force-broken-world[force broken world]' \
        '--force-missing-repositories[force missing repos]' \
        '--force-no-chroot[force no chroot]' \
        '--force-non-repository[force non repository]' \
        '--force-old-apk[force old apk]' \
        '--force-overwrite[force overwrite]' \
        '--force-refresh[force refresh]' \
        '--initramfs-diskless-boot[initramfs diskless boot]' \
        '--interactive[interactive]' \
        '-i[interactive]' \
        '--keys-dir=+[keys dir]:dir:_files -/' \
        '--no-cache[no cache]' \
        '--no-check-certificate[no check certificate]' \
        '--no-commit-hooks[no commit hooks]' \
        '--no-interactive[no interactive]' \
        '--no-logfile[no logfile]' \
        '--no-network[no network]' \
        '--no-progress[no progress]' \
        '--no-scripts[no scripts]' \
        '--overlay-from-stdin[overlay from stdin]' \
        '--print-arch[print arch]' \
        '--progress[show progress]' \
        '--progress-fd=+[progress fd]:n:' \
        '--purge[purge]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--repositories-file=+[repositories file]:file:_files' \
        '--repository=+[repository]:list:_urls' \
        '-X+[repository]:list:_urls' \
        '--root=+[root dir]:dir:_files -/' \
        '-p+[root dir]:dir:_files -/' \
        '--update-cache[update cache]' \
        '-U[update cache]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--wait=+[wait seconds]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apk subcommand' sub ;;
        args)
            case $words[1] in
                add|del|fetch|info|search|list|policy|version|manifest|verify) _arguments '*:package:' ;;
                cache) _arguments \
                    '1:cmd:(clean download purge)' \
                    '*:arg:' ;;
                upgrade|update|fix|stats|audit) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_apk-cli "$@"
