#compdef mkdssp
# Documentation: https://github.com/PDB-REDO/dssp/blob/trunk/doc/mkdssp.md
# Assign secondary structure (DSSP) from a protein structure

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--version[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--quiet[reduce verbose output to a minimum]' \
  '--output-format=[output format]:format:(dssp mmcif)' \
  '--min-pp-stretch=[min residues in PHI/PSI range for PP helix]:n' \
  '--write-other[write the type OTHER for loops]' \
  '--no-dssp-categories[suppress dssp_ categories in mmCIF output]' \
  '--calculate-accessibility[calculate surface accessibility]' \
  '--mmcif-dictionary=[path to mmcif_pdbx.dic file]:file:_files' \
  '1:input structure file:_files -g "*.(pdb|cif|cif.gz|pdb.gz)"' \
  '2:output file:_files' && ret=0

return ret
