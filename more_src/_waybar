#compdef waybar

# Zsh completion for waybar - Wayland bar for Sway and wlroots compositors

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file]:config file:_files -g "*.jsonc"' \
  '(-s --style)'{-s,--style}'[style file]:style file:_files -g "*.css"' \
  '(-l --log-level)'{-l,--log-level}'[set log level]:level:(trace debug info warning error off)' \
  '(-b --bar)'{-b,--bar}'[specify bar ID]:bar id'
