#compdef waybar
# Documentation: https://github.com/Alexays/Waybar
# Reference accessed: 2026-05-21
# Verified: upstream src/client.cpp at github.com/Alexays/Waybar.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-s --style)'{-s,--style}'+[style file]:file:_files -g "*.css"' \
  '(-l --log-level)'{-l,--log-level}'+[set log level]:level:(trace debug info warning error critical off)' \
  '(-b --bar)'{-b,--bar}'+[specify bar ID]:bar id'
