#compdef metview
# Documentation: https://confluence.ecmwf.int/display/METV/Metview%27s+Startup+Options
# metview - ECMWF meteorological workstation and batch system

local ret=1

_arguments -s \
  '-h[display help with complete list of startup options]' \
  '-slog[get logging information to the console]' \
  '-fs[change the font size]:size' \
  '-b[run a Macro from the command line in batch mode]:macro:_files' \
  '-p[bring up interactive plot window for a data file]:data file:_files' \
  '-e[launch data examiner for a file type]:type:(grib bufr geopoints netcdf odb):file:_files' \
  '-u[start with home directory different from $HOME/metview]:directory:_files -/' \
  '*:file:_files' && ret=0

return ret
