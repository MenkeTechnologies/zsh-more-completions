#compdef backstage-cli
# _backstage — Backstage developer portal CLI (backstage/backstage)
# upstream: https://github.com/backstage/backstage

_backstage() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :_backstage_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                app:build|build)
                    _arguments \
                        '--stats[write build stats to file]' \
                        '--config=[config file]:file:_files' \
                        '--help[show help]' && ret=0 ;;
                app:serve|start)
                    _arguments \
                        '--check[enable type checking]' \
                        '--config=[config file]:file:_files' \
                        '--help[show help]' && ret=0 ;;
                create-app)
                    _arguments \
                        '--path=[directory]:dir:_files -/' \
                        '--skip-install[skip dependency install]' \
                        '--help[show help]' && ret=0 ;;
                new)
                    _arguments \
                        '--select=[template]:template:' \
                        '--option=[key=value]:option:' \
                        '--scope=[monorepo scope]:scope:' \
                        '--help[show help]' && ret=0 ;;
                test)
                    _arguments \
                        '--help[show help]' \
                        '*:test pattern:' && ret=0 ;;
                *) _arguments '--help[show help]' '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_backstage_commands] )) ||
_backstage_commands() {
    local -a commands
    commands=(
        'app\:build:build the app for deployment'
        'app\:serve:serve the app for development'
        'build:build a package'
        'build-workspace:build all packages'
        'clean:remove build output'
        'config\:check:validate configuration files'
        'config\:docs:generate configuration docs'
        'config\:print:print effective configuration'
        'create-app:create a new Backstage app'
        'info:show environment info'
        'install:install a plugin'
        'migrate:run upgrade migrations'
        'new:create a new package from template'
        'package:manage packages'
        'repo:manage the monorepo'
        'start:start the app for development'
        'test:run tests'
        'versions\:bump:bump package versions'
    )
    _describe -t commands 'backstage command' commands
}

_backstage "$@"
