#compdef statoscope
# Documentation: https://github.com/statoscope/statoscope/tree/master/packages/cli
# statoscope - toolkit to analyze and validate webpack bundles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(validate vrules init create serve generate query inject-report inject-extension)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-i --input)'{-i,--input}'=[path to webpack stats.json]:file:_files' \
      '(-r --reference)'{-r,--reference}'=[path to comparison stats file]:file:_files' \
      '(-c --config)'{-c,--config}'=[path to statoscope config]:file:_files' \
      '(-o --output)'{-o,--output}'=[output path]:file:_files' \
      '(-w --warn-as-error)'{-w,--warn-as-error}'[treat warnings as errors]' \
      '(-e --entity)'{-e,--entity}'=[entity type to generate]:entity:(plugin rule reporter)' \
      '(-t --type)'{-t,--type}'=[output format]:type:(js ts)' \
      '(-m --module)'{-m,--module}'=[module type]:module:(commonjs esm)' \
      '--host=[server host]:host' \
      '(-p --port)'{-p,--port}'=[server port]:port' \
      '(-q --query)'{-q,--query}'=[jora query string]:query' \
      '--open[open browser]' \
      '--custom-report=[custom report path]:file:_files' \
      '--no-compression[disable data compression]' && ret=0
    ;;
esac

return ret
