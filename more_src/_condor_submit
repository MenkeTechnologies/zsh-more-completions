#compdef condor_submit
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_submit.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-verbose[display created job ClassAd]' \
  '-terse[display JobId ranges only]' \
  '-unused[control warnings about unused macros]' \
  '-file[submit description file]:file:_files' \
  '-debug[send debugging information to stderr]' \
  '-disable[disable file permission checks]' \
  '-password[provide submission password]:passphrase:' \
  '-spool[spool input/output, event log, proxy]' \
  '-dry-run[parse but do not submit]:file:_files' \
  '-dump[dump ClassAd to file]:file:_files' \
  '-allow-crlf-script[allow CRLF in script #!]' \
  '-name[specify schedd]:schedd:' \
  '-pool[specify pool]:pool:' \
  '-remote[remote schedd via spooling]:schedd:' \
  '-addr[schedd address]:sinful:' \
  '-append[append command before queue]:command:' \
  '-batch-name[batch name]:name:' \
  '-queue[command-line queue specification]:queue:' \
  '-factory[late materialization factory]' \
  '-maxjobs[max total jobs]:n:' \
  '-single-cluster[error if multiple clusters]' \
  '-interactive[interactive job]' \
  '-i[interactive job]' \
  '*:submit-file:_files -g "*.(sub|submit|cmd)"' && ret=0
return ret
