#compdef demos
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/demos.html
# MIRIAD: inverse mosaicing of a sky model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'map=[primary-beam-corrected image]:map:_files' \
  'vis=[input visibility datasets]:vis:_files' \
  'select=[UV selection]:select:' \
  'out=[output image template name]:out:_files' \
  'imsize=[output image dimensions]:imsize:' \
  'options=[detaper]:options:(detaper)' \
  '*:image:_files' && ret=0

return ret
