#compdef tomtom
# Documentation: https://meme-suite.org/meme/doc/tomtom.html
# MEME Suite: compare a query motif against a database of known motifs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output directory (default tomtom_out), fail if exists]:dir:_files -/' \
  '-oc[output directory (default tomtom_out), overwrite if exists]:dir:_files -/' \
  '-text[output tab-delimited text to stdout, no other files]' \
  '*-m[only use the query motif with the given id]:id:' \
  '*-mi[only use the query motif at the given index]:index:' \
  '-bfile[background model file]:file:_files' \
  '-motif-pseudo[pseudocount added to motif counts]:count:' \
  '-png[create PNG logo images]' \
  '-eps[create EPS logo images]' \
  '-no-ssc[do not apply small-sample correction to columns]' \
  '-norc[do not score the reverse complement strand]' \
  '-incomplete-scores[score only aligned columns]' \
  '-thresh[significance threshold]:value:' \
  '-evalue[use E-value rather than q-value threshold]' \
  '-dist[column comparison function]:dist:(allr ed kullback pearson sandelin blic1 blic5 llr1 llr5)' \
  '-internal[force the shorter motif to be fully contained]' \
  '-min-overlap[minimum overlap between query and target]:overlap:' \
  '-time[maximum runtime in CPU seconds]:time:' \
  '*:motif file:_files' && ret=0

return ret
