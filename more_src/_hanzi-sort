#compdef hanzi-sort
# Documentation: https://man.archlinux.org/search?q=hanzi-sort
# Reference accessed: 2026-05-16
# Source: cargo binstall hanzi-sort@0.2.1
# Probed via: completions zsh
# Repository: https://github.com/Acture/hanzi-sort

autoload -U is-at-least

_hanzi-sort() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'(-t --text)*-f+[Input file path (can be multiple, '\''-'\'' reads stdin)]:FILE:_files' \
'(-t --text)*--file=[Input file path (can be multiple, '\''-'\'' reads stdin)]:FILE:_files' \
'(-f --file)*-t+[Directly input text data (can be multiple)]:INPUT_TEXTS:_default' \
'(-f --file)*--text=[Directly input text data (can be multiple)]:INPUT_TEXTS:_default' \
'-o+[Output file path, defaults to stdout]:OUTPUT_PATH:_files' \
'--output=[Output file path, defaults to stdout]:OUTPUT_PATH:_files' \
'-c+[Override pronunciation configuration file path]:CONFIG_PATH:_files' \
'--config=[Override pronunciation configuration file path]:CONFIG_PATH:_files' \
'--columns=[Number of entries per row]:COLUMNS_PER_ROW:_default' \
'--blank-every=[Insert a blank line every N lines; use 0 to disable]:BLANK_PER:_default' \
'--entry-width=[Pad each entry to this display width]:ENTRY_WIDTH:_default' \
'--align=[Alignment strategy]:ALIGN:(left center right even)' \
'--padding-char=[Character used for padding]:PADDING_CHAR:_default' \
'--separator=[Character used to separate entries (default\: tab)]:SEPARATOR:_default' \
'--line-ending=[Line ending character (default\: newline)]:LINE_ENDING:_default' \
'--sort-by=[Sort strategy]:SORT_BY:(pinyin strokes)' \
'-r[Reverse the sorted output]' \
'--reverse[Reverse the sorted output]' \
'-u[Remove adjacent duplicates from the sorted output (like sort -u)]' \
'--unique[Remove adjacent duplicates from the sorted output (like sort -u)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_hanzi-sort_commands" \
"*::: :->hanzi-sort" \
&& ret=0
    case $state in
    (hanzi-sort)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hanzi-sort-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The target shell (bash, zsh, fish, powershell, elvish):(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_hanzi-sort__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:hanzi-sort-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_hanzi-sort_commands] )) ||
_hanzi-sort_commands() {
    local commands; commands=(
'completions:Generate a shell completion script for the given shell to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hanzi-sort commands' commands "$@"
}
(( $+functions[_hanzi-sort__subcmd__completions_commands] )) ||
_hanzi-sort__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'hanzi-sort completions commands' commands "$@"
}
(( $+functions[_hanzi-sort__subcmd__help_commands] )) ||
_hanzi-sort__subcmd__help_commands() {
    local commands; commands=(
'completions:Generate a shell completion script for the given shell to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hanzi-sort help commands' commands "$@"
}
(( $+functions[_hanzi-sort__subcmd__help__subcmd__completions_commands] )) ||
_hanzi-sort__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'hanzi-sort help completions commands' commands "$@"
}
(( $+functions[_hanzi-sort__subcmd__help__subcmd__help_commands] )) ||
_hanzi-sort__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'hanzi-sort help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_hanzi-sort" ]; then
    _hanzi-sort "$@"
else
    compdef _hanzi-sort hanzi-sort
fi
