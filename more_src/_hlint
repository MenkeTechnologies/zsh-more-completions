#compdef hlint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r+[hint file or directory]:hint:_files' \
  '--hint=[hint file or directory]:hint:_files' \
  '--with-group=[include hint group]:group:' \
  '--without-group=[exclude hint group]:group:' \
  '-c+[color output]:when:(auto always never)' \
  '--colour=[color output]:when:(auto always never)' \
  '--color=[color output]:when:(auto always never)' \
  '-j+[number of threads]:threads:' \
  '--threads=[number of threads]:threads:' \
  '--cross[enable cross-module analysis]' \
  '-s+[minimum severity]:severity:(Ignore Suggestion Warning Error)' \
  '--severity=[minimum severity]:severity:(Ignore Suggestion Warning Error)' \
  '--error=[set hint severity to error]:hint:' \
  '--warning=[set hint severity to warning]:hint:' \
  '--suggest=[set hint severity to suggest]:hint:' \
  '--ignore=[ignore a hint]:hint:' \
  '-g[generate a report]:report file:_files' \
  '--report=[generate a report]:report file:_files' \
  '--serialise[serialize hints as JSON]' \
  '--refactor[apply refactorings]' \
  '--refactor-options=[options for refactoring tool]:options:' \
  '--with-refactor=[path to refactoring tool]:tool:_files' \
  '--no-summary[do not show summary]' \
  '--no-exit-code[always exit with code 0]' \
  '--json[output as JSON]' \
  '--cc[output in Code Climate format]' \
  '--sarif[output in SARIF format]' \
  '--plain[output in plain format]' \
  '-f+[find hints matching pattern]:pattern:' \
  '--find=[find hints matching pattern]:pattern:' \
  '--test[run built-in tests]' \
  '--default[generate default hlint.yaml]' \
  '-d[generate default hlint.yaml]' \
  '-X+[language extension]:extension:' \
  '--language-extension=[language extension]:extension:' \
  '--cpp-define=[CPP define]:define:' \
  '--cpp-include=[CPP include directory]:directory:_directories' \
  '--cpp-file=[CPP include file]:file:_files' \
  '--cpp-simple[use simple CPP processing]' \
  '--cpp-ansi[use ANSI CPP processing]' \
  '-i+[ignore a hint]:hint:' \
  '*:files:_files -g "*.hs"' && ret=0

return ret
