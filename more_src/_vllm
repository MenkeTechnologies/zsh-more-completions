#compdef vllm
# Documentation: https://github.com/vllm-project/vllm
# Reference accessed: 2026-05-27
# Verified: upstream vllm/entrypoints/cli/main.py (subcommand dispatch),
# vllm/entrypoints/cli/serve.py, vllm/entrypoints/cli/openai.py,
# vllm/entrypoints/openai/cli_args.py (FrontendArgs), vllm/engine/arg_utils.py
# (AsyncEngineArgs).

# Zsh completion for vllm CLI (vllm-project)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _vllm_subcommands
_vllm_subcommands=(
  'serve:launch a local OpenAI-compatible API server'
  'chat:interactive chat against a running vLLM server'
  'complete:single-turn completion request'
  'bench:performance benchmarks (latency, throughput, serving)'
  'run-batch:process batch prompts from a JSONL file'
  'collect-env:print system environment info for bug reports'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show vllm version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'vllm subcommand' _vllm_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--headless[run in headless mode]' \
          '(--api-server-count -asc)'{--api-server-count=,-asc+}'[number of API server processes]:n:' \
          '--config=[YAML config file]:file:_files -g "*.yaml"' \
          '--grpc[launch a gRPC server instead of HTTP]' \
          '--model=[name or path of the HuggingFace model]:model:' \
          '--tokenizer=[name or path of the tokenizer]:tokenizer:' \
          '--tokenizer-mode=[tokenizer mode]:mode:(auto slow mistral custom)' \
          '--trust-remote-code[trust remote code from HuggingFace]' \
          '--download-dir=[directory to download weights]:dir:_directories' \
          '--load-format=[model weight load format]:format:(auto pt safetensors npcache dummy tensorizer bitsandbytes mistral)' \
          '--dtype=[data type for model weights]:dtype:(auto half float16 bfloat16 float float32)' \
          '--max-model-len=[maximum model context length]:tokens:' \
          '--seed=[random seed]:seed:' \
          '--quantization=[quantization method]:method:(awq gptq squeezellm marlin gguf bitsandbytes fp8 fbgemm_fp8 modelopt deepspeedfp compressed-tensors)' \
          '--kv-cache-dtype=[KV cache data type]:dtype:(auto fp8 fp8_e5m2 fp8_e4m3)' \
          '--block-size=[token block size]:n:' \
          '--swap-space=[CPU swap space size in GiB per GPU]:gib:' \
          '--cpu-offload-gb=[CPU offload memory in GiB]:gib:' \
          '--gpu-memory-utilization=[fraction of GPU memory to use]:fraction:' \
          '--tensor-parallel-size=[number of tensor parallel replicas]:n:' \
          '--pipeline-parallel-size=[number of pipeline parallel stages]:n:' \
          '--data-parallel-size=[number of data parallel replicas]:n:' \
          '--max-num-seqs=[maximum number of concurrent sequences]:n:' \
          '--max-num-batched-tokens=[maximum batched tokens per step]:n:' \
          '--enforce-eager[disable CUDA graph]' \
          '--enable-chunked-prefill[enable chunked prefill]' \
          '--enable-lora[enable LoRA adapters]' \
          '--disable-log-stats[disable periodic logging stats]' \
          '--disable-log-requests[disable request logging]' \
          '--enable-log-requests[enable request logging]' \
          '--served-model-name=[name(s) used in the API]:name:' \
          '--host=[host name]:host:' \
          '--port=[port number]:port:' \
          '--uds=[Unix domain socket path]:path:_files' \
          '--api-key=[require API key]:key:' \
          '--ssl-keyfile=[SSL key file]:file:_files' \
          '--ssl-certfile=[SSL cert file]:file:_files' \
          '--ssl-ca-certs=[SSL CA certs file]:file:_files' \
          '--ssl-cert-reqs=[client cert requirement]:n:' \
          '--root-path=[FastAPI root path]:path:' \
          '*--middleware=[ASGI middleware import path]:path:' \
          '--allow-credentials[allow credentials in CORS]' \
          '--allowed-origins=[CORS allowed origins JSON]:json:' \
          '--allowed-methods=[CORS allowed methods JSON]:json:' \
          '--allowed-headers=[CORS allowed headers JSON]:json:' \
          '--uvicorn-log-level=[uvicorn log level]:level:(critical error warning info debug trace)' \
          '--disable-uvicorn-access-log[disable uvicorn access log]' \
          '--enable-request-id-headers[add X-Request-Id headers to responses]' \
          '--disable-fastapi-docs[disable Swagger UI and OpenAPI schema]' \
          '--chat-template=[chat template file or string]:template:' \
          '--chat-template-content-format=[chat template content format]:fmt:(auto string openai)' \
          '--response-role=[role for generation prompts]:role:' \
          '--tool-call-parser=[tool call parser]:parser:' \
          '--tool-parser-plugin=[tool parser plugin path]:path:' \
          '--enable-auto-tool-choice[enable auto tool choice]' \
          '*--lora-modules=[LoRA module spec name=path or JSON]:module:' \
          '1:model_tag:' && ret=0
        ;;
      chat|complete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--url=[OpenAI-compatible API server URL]:url:' \
          '--model-name=[model name on the server]:name:' \
          '--api-key=[API key for the server]:key:' \
          '--system-prompt=[system prompt (chat only)]:prompt:' && ret=0
        ;;
      bench)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:bench type:(latency throughput serving sweep)' \
          '*::bench args:' && ret=0
        ;;
      run-batch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-i --input-file)'{-i+,--input-file=}'[input JSONL file]:file:_files' \
          '(-o --output-file)'{-o+,--output-file=}'[output JSONL file]:file:_files' \
          '--model=[model to use]:model:' \
          '--response-role=[response role]:role:' && ret=0
        ;;
      collect-env)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
