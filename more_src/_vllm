#compdef vllm

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'serve:start the vLLM API server'
      'complete:run a completion request'
      'chat:run a chat completion request'
    )
    _describe -t commands 'vllm command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model[name or path of the model]:model:' \
          '--tokenizer[name or path of the tokenizer]:tokenizer:' \
          '--host[host to bind to]:host:' \
          '--port[port to listen on]:port:' \
          '--tensor-parallel-size[number of tensor parallel replicas]:size:' \
          '--pipeline-parallel-size[number of pipeline parallel stages]:size:' \
          '--dtype[data type for model weights]:dtype:(auto half float16 bfloat16 float float32)' \
          '--max-model-len[maximum model context length]:length:' \
          '--gpu-memory-utilization[fraction of GPU memory to use]:fraction:' \
          '--quantization[quantization method]:method:(awq gptq squeezellm)' \
          '--enforce-eager[enforce eager mode without CUDA graph]' \
          '--max-num-seqs[maximum number of sequences per iteration]:num:' \
          '--max-num-batched-tokens[maximum number of batched tokens]:num:' \
          '--trust-remote-code[trust remote code from HuggingFace]' \
          '--download-dir[directory to download and load weights]:dir:_directories' \
          '--served-model-name[model name used in the API]:name:' \
          '--api-key[API key for server authentication]:key:' \
          '--chat-template[path to chat template file]:file:_files' && ret=0
        ;;
      complete|chat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--model[model to use]:model:' \
          '--url[vLLM server URL]:url:' && ret=0
        ;;
    esac
    ;;
esac

return ret
