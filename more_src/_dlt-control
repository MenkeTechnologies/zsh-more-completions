#compdef dlt-control
# Documentation: https://man.archlinux.org/search?q=dlt-control
# Reference accessed: 2026-05-16

_arguments -s \
  '-v[verbose]' \
  '(- *)-h[show help]' \
  '-S[serial header on send]' \
  '-R[resync serial header]' \
  '-y[serial device mode]' \
  '-b+[serial baudrate]:rate:' \
  '-e+[ECU ID]:id:' \
  '-a+[application id]:id:' \
  '-c+[context id]:id:' \
  '-s+[injection service id]:id:' \
  '-m+[injection ASCII payload]:msg:' \
  '-x+[injection hex payload]:hex:' \
  '-t+[termination timeout ms]:ms:' \
  '-l+[log level]:level:(0 1 2 3 4 5 6)' \
  '-r+[trace status]:value:(0 1)' \
  '-d+[default log level]:level:(0 1 2 3 4 5)' \
  '-f+[default trace status]:value:(0 1)' \
  '-i+[enable timing packets]:value:(0 1)' \
  '-o[store configuration]' \
  '-g[reset to factory default]' \
  '-j[get log info]' \
  '-u[Unix port]' \
  '-p+[TCP port]:port:' \
  ':host:'
