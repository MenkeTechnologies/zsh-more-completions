#compdef router
# Documentation: https://man.archlinux.org/search?q=router
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:configuration helpers (experimental/upgrade/schema)'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[router configuration file]:file:_files -g "*.{yaml,yml}"' \
  '(-s --supergraph)'{-s+,--supergraph=}'[supergraph schema file]:file:_files -g "*.{graphql,graphqls}"' \
  '(-a --apollo-key)'{-a+,--apollo-key=}'[Apollo GraphOS key]:key:' \
  '(-g --apollo-graph-ref)'{-g+,--apollo-graph-ref=}'[Apollo graph ref]:ref:' \
  '--hot-reload[hot-reload local config]' \
  '--listen=[bind address]:address:' \
  '--log=[log level]:level:(off error warn info debug trace)' \
  '--anonymous-telemetry-disabled[disable telemetry]' \
  '(--dev)--dev[enable dev mode]' \
  '--apollo-uplink-endpoints=[Uplink endpoints]:url:' \
  '--apollo-uplink-poll-interval=[Uplink poll interval]:duration:' \
  '--license=[license file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'router command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments '*::sub:(experimental schema upgrade)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
