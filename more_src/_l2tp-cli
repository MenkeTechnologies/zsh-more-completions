#compdef l2tp-cli
# _l2tp-cli — Katalix l2tp-tools l2tp-cli (control wrapper over the kernel L2TPv3 netlink interface; subcommands: tunnel create/delete/show, session create/delete/show, monitor; per-subcommand flags: --tunnel-id, --peer-tunnel-id, --session-id, --peer-session-id, --encap UDP|IP, --src-addr, --dest-addr, --src-port, --dest-port, --cookie, --peer-cookie, --offset, --tunnel-version 2|3, --pseudowire-type)
# upstream: https://github.com/openvpn/openvpn-l2tp (or katalix l2tp-tools)
# Subcommands from openvpn-l2tp l2tp-cli on tip.

_l2tp-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'l2tp-cli command' '(tunnel session monitor)' ;;
        args)
            case $line[1] in
                tunnel|session) _describe -t commands 'sub-action' '(create delete show modify)' ;;
                monitor) _arguments '--event-mask=*[mask]:mask:' ;;
            esac
            ;;
    esac
}

_l2tp-cli "$@"
