#compdef hyperrogue
# Documentation: https://github.com/zenorogue/hyperrogue/blob/master/commandline.cpp
# Reference accessed: 2026-05-16
# Verified: commandline.cpp built-in --help printout (lines 405-450). HyperRogue
# has 461 total argis() handlers across the codebase; this completion lists
# only the flags the built-in help advertises as "basic options" plus the
# documented file/logging/quick-testing groups. The "shmup", "geometry",
# "screenshot", "F" (fullscreen), "tactic", "KL", "spec" claims from the prior
# version of this file are not in the source — removed.

# HyperRogue: hyperbolic-plane roguelike
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-v[show the version number]' \
  '(- *)--version[show the version number]' \
  '(- *)-h[show commandline options and quit]' \
  '(- *)--help[show commandline options and quit]' \
  '-offline[do not connect to Steam]' \
  '-L[list of features]' \
  '-fix[fix the RNG seed (cheat)]' \
  '-fixx[fix the RNG seed to the given value (cheat)]:seed:' \
  '-noscr[skip the start menu]' \
  '-viz[visualization mode: hide game elements]' \
  '-vizs[visualization mode with smooth control]' \
  '-g[debug mode: no scorefile, fixed seed, cheats]' \
  '-nogui[do not start the GUI]' \
  '-run[run (handle other options) until F10]' \
  '-exit[exit the program]' \
  '-c[config file]:file:_files' \
  '-s[highscore file]:file:_files' \
  '-m[soundtrack (music) file]:file:_files' \
  '-se[sound-effects directory]:dir:_files -/' \
  '-rsrc[resources directory]:dir:_files -/' \
  '-font[font file]:file:_files' \
  '-log[log events matching pattern]:pattern:' \
  '-no-log[do not log events matching pattern]:pattern:' \
  '-log-to[log to file]:file:_files' \
  '-log-append[append log to file]:file:_files' \
  '-load[load a map-editor level file]:file:_files' \
  '-geo[choose the geometry]:id:' \
  '-PM[choose the projection/model]:id:' \
  '-W[start in the given land]:id:' \
  '-W2[make the given land easy to find (cheat)]:id:' \
  '-W3[like -W2 but repeatable (cheat)]:id:' \
  '-I[start with n of item ID nearby (cheat)]:id n:' \
  '-M[start with n of monster ID nearby (cheat)]:id n:' \
  '-MK[start with n kills of monster ID (cheat)]:id n:' \
  '-canvas[set background color or pattern code]:id:' \
  '-noshaders[disable OpenGL shaders]' \
  '-o0[disable OpenGL]' \
  '-wm[wall mode (disable 3D walls)]:n:' \
  '-mm[monster mode (disable 3D monsters)]:n:' \
  '-log-all[log every event]' \
  '*::extra args (461 hyperrogue commands not enumerated):_files' && ret=0
return ret
