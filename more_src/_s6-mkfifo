#compdef s6-mkfifo
# Documentation: https://skarnet.org/software/s6-portable-utils/s6-mkfifo.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-m+[permission mode]:mode:' \
  '*:fifo path:_files' && ret=0

return ret
