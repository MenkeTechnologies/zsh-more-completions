#compdef sqlite3-rsync
# Documentation: https://sqlite.org/rsync.html
# sqlite3-rsync - database remote-copy tool for SQLite (WAL-mode replication)

local ret=1

_arguments -s \
  '(-? --help)'{-\?,--help}'[show help]' \
  '--exe[name of sqlite3_rsync program on the remote side]:path:_files' \
  '--ssh[name of the SSH program used to reach the remote side]:ssh:_files' \
  '--protocol[use sync protocol version N]:version:(1)' \
  '-v[verbose output]' \
  '1:origin:_files' \
  '2:replica:_files' && ret=0

return ret
