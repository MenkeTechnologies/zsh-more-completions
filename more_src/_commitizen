#compdef cz commitizen

# Zsh completion for commitizen (cz) - conventional commit tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:init commitizen configuration'
  'commit:create a commit using commitizen'
  'c:create a commit using commitizen'
  'ls:show available commitizen templates'
  'example:show commit example'
  'info:show commitizen information'
  'schema:show commit schema'
  'bump:bump version based on commits'
  'changelog:generate changelog'
  'ch:generate changelog'
  'check:validate a commit message'
  'version:get the version of commitizen'
)

local -a global_args=(
  '--debug[enable debug output]'
  '--name[name of the committing rules]:name:'
  '(-n)'-n'[name of the committing rules]:name:'
  '--no-raise[comma-separated list of exit codes to skip]:exit codes:'
  '(-nr)'-nr'[comma-separated list of exit codes to skip]:exit codes:'
)

_arguments -s -S \
  ${global_args[@]} \
  '1:command:->command' \
  '*:option:->options' && ret=0

case $state in
  (command)
    _describe -t commands 'commitizen command' subcommands && ret=0
    ;;
  (options)
    case ${line[1]} in
      (commit|c)
        _arguments -s -S \
          ${global_args[@]} \
          '--dry-run[do not perform the commit]' \
          '--write-message-to-file[write message to file]:file:_files' \
          '(-s --signoff)'{-s,--signoff}'[add Signed-off-by trailer]' \
          '(-a --all)'{-a,--all}'[stage all changed files]' \
          '--retry[retry last commit]' \
          '--no-raise[comma-separated list of exit codes to skip]:exit codes:' && ret=0
        ;;
      (bump)
        _arguments -s -S \
          ${global_args[@]} \
          '--dry-run[do not perform the bump]' \
          '--yes[answer yes to all prompts]' \
          '--tag-format[tag format]:format:' \
          '--prerelease[prerelease identifier]:prerelease:(alpha beta rc)' \
          '--devrelease[dev release number]:number:' \
          '--increment[manual increment override]:increment:(MAJOR MINOR PATCH)' \
          '--check-consistency[check version consistency across files]' \
          '--annotated-tag[create an annotated tag]' \
          '--no-annotated-tag[do not create an annotated tag]' \
          '--changelog[generate changelog on bump]' \
          '--no-changelog[do not generate changelog on bump]' \
          '--local-version[use local version scheme]' \
          '--files-only[update files only, do not commit or tag]' \
          '--changelog-to-stdout[output changelog to stdout]' \
          '--git-output-to-stderr[redirect git output to stderr]' \
          '--retry[retry last bump]' \
          '--major-version-zero[keep major version at 0]' && ret=0
        ;;
      (changelog|ch)
        _arguments -s -S \
          ${global_args[@]} \
          '--dry-run[do not write changelog]' \
          '--file-name[changelog file name]:file:_files' \
          '--unreleased-version[set unreleased version]:version:' \
          '--incremental[generate changelog incrementally]' \
          '--start-rev[start revision]:revision:' \
          '--merge-prerelease[merge prerelease tags into next release]' \
          '--template[changelog template]:template:_files' \
          '--extra[extra variables for changelog template]:extra:' && ret=0
        ;;
      (check)
        _arguments -s -S \
          ${global_args[@]} \
          '--commit-msg-file[path to commit message file]:file:_files' \
          '--allow-abort[allow empty commit messages]' \
          '--allowed-prefixes[allowed prefixes for commit messages]:prefixes:' \
          '(-m --message)'{-m,--message}'[commit message to check]:message:' && ret=0
        ;;
      (init)
        _arguments -s -S \
          ${global_args[@]} \
          '--config[config file format]:config:(cz.toml .cz.toml pyproject.toml cz.json cz.yaml)' && ret=0
        ;;
      (*)
        _arguments -s -S ${global_args[@]} && ret=0
        ;;
    esac
    ;;
esac

return ret
