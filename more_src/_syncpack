#compdef syncpack

# Zsh completion for syncpack - monorepo dependency sync tool

local curcontext="$curcontext" state line ret=1

local -a syncpack_commands
syncpack_commands=(
  'list:list all dependencies and their versions'
  'list-mismatches:list dependencies with version mismatches'
  'fix-mismatches:fix version mismatches'
  'format:sort and format package.json files'
  'lint:lint packages for consistency'
  'set-semver-ranges:set semver range types'
  'prompt:interactively fix mismatches'
)

local -a syncpack_common_flags
syncpack_common_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '*--source=[glob pattern for source packages]:glob pattern:'
  '*--types=[dependency types to include]:type:(dev peer prod overrides pnpmOverrides resolutions)'
  '--filter=[regex to filter packages]:regex pattern:'
  '--indent=[indentation format]:indent:(tab 2 4)'
  '--config=[path to config file]:config file:_files'
)

_arguments -s -S \
  "${syncpack_common_flags[@]}" \
  '1:command:_describe -t commands command syncpack_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    _arguments -s -S "${syncpack_common_flags[@]}" && ret=0
    ;;
esac

return ret
