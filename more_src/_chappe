_chappe() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--config=[path to config.json]:config:_files -g "*.json"' \
        '--assets=[static assets directory]:dir:_files -/' \
        '--data=[Markdown + YAML data directory]:dir:_files -/' \
        '--dist=[build output directory]:dir:_files -/' \
        '--temp=[build cache directory]:dir:_files -/' \
        '--env=[environment]:env:(development production)' \
        '--host=[dev server bind host]:host:' \
        '--port=[dev server bind port]:port:' \
        '--quiet[suppress informational output]' \
        '--verbose[enable verbose output]' \
        '--example=[build from examples/<name>/ bundle]:example name:' \
        '1: :->action' && ret=0

    case $state in
        action)
            local -a _ch_actions=(
                'build:build the docs site to <dist>/'
                'clean:clean <dist>/ + <temp>/ cache'
                'watch:build + watch source directories for changes'
                'serve:start local dev HTTP server with live-reload'
                'lint:run the docs lint pipeline (link/Markdown/YAML)'
            )
            _describe -t actions 'chappe action' _ch_actions && ret=0
            ;;
    esac

    return ret
}

_chappe "$@"
