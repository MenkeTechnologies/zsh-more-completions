#compdef jsfinder
# Documentation: https://github.com/Threezh1/JSFinder
# tool to quickly extract URLs and subdomains from JS files of a website

local ret=1

_arguments -s -S \
  '-u[specify target URL for crawling]:url:_urls' \
  '-d[enable deep crawling (one level deeper)]' \
  '-f[file containing URLs or JS links (one per line)]:file:_files' \
  '-j[process input file as JS links instead of URLs]' \
  '-c[provide cookies for authenticated page crawling]:cookies' \
  '-ou[output filename for extracted URLs]:file:_files' \
  '-os[output filename for extracted subdomains]:file:_files' && ret=0

return ret
