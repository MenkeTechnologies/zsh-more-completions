#compdef llvm-reduce
# _llvm-reduce — LLVM IR bug reducer (LLVM project, C++); shrink IR test cases while preserving interestingness
# upstream: https://github.com/llvm/llvm-project

_llvm-reduce() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--test=+[interestingness test]:file:_files' \
        '--test-arg=+[test argument]:arg:' \
        '-o+[output file]:file:_files' \
        '--max-pass-iterations=+[max pass iterations]:n:' \
        '--starting-granularity-level=+[starting granularity]:n:' \
        '--delta-passes=+[delta passes]:list:' \
        '--skip-delta-passes=+[skip delta passes]:list:' \
        '--mtriple=+[triple]:triple:' \
        '--write-tmp-files-as-bitcode[write bitcode]' \
        '--print-delta-passes[print delta passes]' \
        '--in-place[in place]' \
        '--ir-attribute-rules[ir attribute rules]' \
        '-j+[parallel jobs]:n:' \
        '*:file:_files'
}

_llvm-reduce "$@"
