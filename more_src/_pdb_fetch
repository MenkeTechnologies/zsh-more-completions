#compdef pdb_fetch
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Downloads a structure in PDB format from the RCSB website

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-biounit[download the biological unit instead of the unit cell]' \
  '*:PDB code:' && ret=0

return ret
