_rix() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'init:generate AI project rules interactively'
        'sync:regenerate rule files from rix.config.json'
        'update:check for a newer rix-cli version and install globally'
        'version:print version number'
        'help:show help message'
    )

    _arguments -C \
        '(-v -V --version)'{-v,-V,--version}'[print Rix CLI version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'rix subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                init)
                    _arguments \
                        '--dir=[target directory for generated files]:directory:_files -/' \
                        '--force[overwrite existing generated files]' \
                        '--locale=[preselect generated document locale]:locale:(zh-cn us-en)' && ret=0
                    ;;
                sync|update|version|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_rix "$@"
