#compdef msconvert
# ProteoWizard: convert and filter mass-spectrometry data files

local ret=1

_arguments -s -S \
  '(-f --filelist)'{-f,--filelist}'[text file containing filenames]:file:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory]:dir:_files -/' \
  '--outfile[override the name of output file]:name:' \
  '(-e --ext)'{-e,--ext}'[extension for output files]:ext:' \
  '--mzML[write mzML format (default)]' \
  '--mzXML[write mzXML format]' \
  '--mz5[write mz5 format]' \
  '--mgf[write Mascot generic format]' \
  '--text[write ProteoWizard internal text format]' \
  '--ms1[write MS1 format]' \
  '--cms1[write CMS1 format]' \
  '--ms2[write MS2 format]' \
  '--cms2[write CMS2 format]' \
  '--32[default binary encoding 32-bit precision]' \
  '--64[default binary encoding 64-bit precision]' \
  '--mz32[encode m/z in 32-bit precision]' \
  '--mz64[encode m/z in 64-bit precision]' \
  '--inten32[encode intensity in 32-bit precision]' \
  '--inten64[encode intensity in 64-bit precision]' \
  '(-z --zlib)'{-z,--zlib}'[use zlib compression for binary data]' \
  '(-g --gzip)'{-g,--gzip}'[gzip entire output file]' \
  '--numpressLinear[numpress linear prediction lossy compression]' \
  '--numpressPic[numpress positive integer lossy compression]' \
  '--numpressSlof[numpress short logged float lossy compression]' \
  '(-n --numpressAll)'{-n,--numpressAll}'[apply numpressLinear and numpressSlof]' \
  '--noindex[do not write index]' \
  '(-c --config)'{-c,--config}'[configuration file (optionName=value)]:file:_files' \
  '(-i --contactInfo)'{-i,--contactInfo}'[filename for contact info]:file:_files' \
  '*--filter[add a spectrum list filter]:filter:' \
  '--merge[create single output file from multiple inputs]' \
  '--simAsSpectra[write selected ion monitoring as spectra]' \
  '--srmAsSpectra[write selected reaction monitoring as spectra]' \
  '(-v --verbose)'{-v,--verbose}'[display detailed progress information]' \
  '--help[show help message with filter details]' \
  '*:input file:_files' && ret=0

return ret
