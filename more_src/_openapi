#compdef openapi

# Zsh completion for openapi CLI (OpenAPI / Arazzo)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'openapi' bundle lint convert generate validate help && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
