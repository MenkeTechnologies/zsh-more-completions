#compdef a2jmidi
# Documentation: https://man.archlinux.org/search?q=a2jmidi
# Reference accessed: 2026-05-16

# a2jmidi: legacy ALSA-to-JACK MIDI bridge (per-port)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '*::a2jmidi args:_files' && ret=0
return ret
