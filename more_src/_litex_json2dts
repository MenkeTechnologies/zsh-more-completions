#compdef litex_json2dts
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex/tools/litex_json2dts_linux.py
# LiteX CSR JSON to Linux device-tree (DTS) generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--initrd-start=[location of initrd in RAM (relative)]:addr:' \
  '--initrd-size=[size of initrd (default=8MB)]:size:' \
  '--initrd=[enabled, disabled, or initrd file name]:initrd:' \
  '--root-device=[device containing root filesystem (default ram0)]:device:' \
  '--polling[use polling mode for peripherals instead of interrupts]' \
  '*:CSR JSON file:_files -g "*.json"' && ret=0

return ret
