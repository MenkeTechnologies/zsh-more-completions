#compdef spatialite_osm spatialite_osm_map spatialite_osm_raw spatialite_osm_overpass spatialite_osm_filter spatialite_osm_net
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/spatialite_osm_map.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu trusty spatialite_osm_map(1) manpage + upstream
# gaia-gis spatialite_osm_overpass wiki. NOTE: "spatialite_osm" is not
# a single binary - the family is osm_map / osm_raw / osm_overpass /
# osm_filter / osm_net. This completion targets the shared flag set;
# all variants accepted via #compdef alias.

# spatialite_osm: OSM import family for spatialite databases
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --osm-path)'{-o+,--osm-path=}'[OSM file (.osm or .osm.pbf)]:file:_files -g "*.(osm|pbf)(-.)"' \
  '(-d --db-path)'{-d+,--db-path=}'[spatialite database file]:file:_files' \
  '(-cs --cache-size)'{-cs+,--cache-size=}'[cache size]:n:' \
  '(-m --in-memory)'{-m,--in-memory}'[use in-memory database]' \
  '(-n --no-spatial-index)'{-n,--no-spatial-index}'[suppress R*Tree generation]' \
  '(-jo --journal-off)'{-jo,--journal-off}'[disable SQLite journal]' \
  '-minx[overpass: min longitude]:lon:' \
  '-miny[overpass: min latitude]:lat:' \
  '-maxx[overpass: max longitude]:lon:' \
  '-maxy[overpass: max latitude]:lat:' \
  '-mode[overpass mode]:mode:(RAW MAP ROAD RAIL)' \
  '-p[overpass: skip cleanup]' \
  '-w[filter: WKT spatial filter mask]:file:_files' && ret=0
return ret
