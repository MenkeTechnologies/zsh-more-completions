#compdef plumed-kt
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/kt.html
# plumed kt: print the value of kBT at a given temperature

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--temp=[temperature value]:temperature' \
  '--units=[energy units]:units:(kj/mol kcal/mol j/mol eV)' && ret=0

return ret
