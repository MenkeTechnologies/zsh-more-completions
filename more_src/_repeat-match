#compdef repeat-match
# Documentation: https://manpages.debian.org/testing/mummer/repeat-match.1.en.html
# MUMmer utility to find maximal exact matches within a genome

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-E[use exhaustive (slow) search to find matches]' \
  '-f[forward strand only, do not use reverse complement]' \
  '-n+[set minimum exact match length]:len' \
  '-t[only output tandem repeats]' \
  '-V+[set level of verbose printing]:level' \
  ':genome file:_files' && ret=0

return ret
