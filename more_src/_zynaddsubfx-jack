#compdef zynaddsubfx-jack
# Documentation: https://man.archlinux.org/search?q=zynaddsubfx-jack
# Reference accessed: 2026-05-16

# ZynAddSubFX synth (JACK build) - same CLI as zynaddsubfx
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --load)'{-l,--load=}'[load XMZ file]:file:_files -g "*.xmz"' \
  '(-L --load-instrument)'{-L,--load-instrument=}'[load XIZ file]:file:_files -g "*.xiz"' \
  '(-r --sample-rate)'{-r,--sample-rate=}'[sample rate]:n:' \
  '(-b --buffer-size)'{-b,--buffer-size=}'[audio buffer size]:n:' \
  '(-o --oscil-size)'{-o,--oscil-size=}'[oscillator buffer size]:n:' \
  '(-S --swap)'{-S,--swap}'[swap stereo channels]' \
  '(-U --no-gui)'{-U,--no-gui}'[no GUI (audio engine only)]' \
  '(-A --auto-connect)'{-A,--auto-connect}'[auto-connect JACK ports]' \
  '(-a --auto-connect)'{-a,--auto-connect}'[auto-connect MIDI]' \
  '(-N --named)'{-N,--named=}'[set JACK client name]:name:' \
  '(-I --audio)'{-I,--audio=}'[audio backend]:backend:(jack alsa portaudio oss null)' \
  '(-O --output)'{-O,--output=}'[MIDI backend]:backend:(jack alsa oss)' \
  '(-Y --midi-learn)'{-Y,--midi-learn=}'[MIDI learn file]:file:_files' \
  '(-e --exec-after-init)'{-e,--exec-after-init=}'[run command after init]:cmd:' \
  '*::zynaddsubfx-jack args:_files' && ret=0
return ret
