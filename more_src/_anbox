#compdef anbox
# _anbox — run Android apps in a Linux container (anbox/anbox)
# upstream: https://github.com/anbox/anbox
# Subcommands + flags from src/anbox/cmds/*.cpp.

_anbox() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_anbox_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                launch)
                    _arguments \
                        '--action=[Android intent action]:action:' \
                        '--type=[MIME type for the intent]:type:' \
                        '--uri=[URI data for the intent]:uri:' \
                        '--package=[target Android package name]:package:' \
                        '--component=[target component within the package]:component:' \
                        '--stack=[window stack to launch into]:stack:(default fullscreen freeform)' \
                        '--use-system-dbus[use the system DBus instead of the session DBus]'
                    ;;
                session-manager)
                    _arguments \
                        '--desktop_file_hint=[Desktop-file hint for QtMir/Unity8]:hint:' \
                        '--single-window[start in single-window mode]' \
                        '--window-size=[window size, e.g. 1024,768]:size:' \
                        '--standalone[do not let container-manager start the default container]' \
                        '--experimental[enable experimental features]' \
                        '--use-system-dbus[use the system DBus instead of the session DBus]' \
                        '--software-rendering[disable hardware-accelerated GL rendering]' \
                        '--no-touch-emulation[disable mouse→touch emulation]' \
                        '--server-side-decoration[prefer server-side window decoration]' \
                        '--disabled-sensors=[comma-separated list of sensors to disable]:sensors:' \
                        '--rootless[run in rootless window mode]'
                    ;;
                container-manager)
                    _arguments \
                        '--data-path=[container data path]:dir:_files -/' \
                        '--privileged[run with privileged capabilities]' \
                        '--use-rootfs-overlay[use a writable rootfs overlay]' \
                        '--daemon[run in the background]' \
                        '--android-image=[path to the Android image]:file:_files -g "*.img"'
                    ;;
                install)
                    _arguments '*:APK file:_files -g "*.apk"'
                    ;;
                wait-ready)
                    _arguments
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_anbox_commands] )) ||
_anbox_commands() {
    local -a commands
    commands=(
        'launch:launch an Android Activity by intent'
        'session-manager:run the per-session manager (Android session lifecycle)'
        'container-manager:run the container-manager daemon'
        'install:install an APK into the Android session'
        'wait-ready:block until the Anbox session is ready'
        'system-info:print Anbox system information (renderer, kernel, etc.)'
        'check-features:check whether the kernel supports required features'
        'version:print Anbox version'
    )
    _describe -t commands 'anbox command' commands
}

_anbox "$@"
