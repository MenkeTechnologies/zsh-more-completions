#compdef 3dfractionize
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dfractionize.html
# Resample a dataset to a template grid by voxel occupancy fraction

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-template[template dataset defining output grid]:dataset:_files' \
  '-input[input dataset (sub-brick 0 only)]:dataset:_files' \
  '-prefix[output dataset prefix]:prefix:' \
  '-clip[remove voxels below occupancy threshold]:fff:' \
  '-warp[transformation dataset for warping]:dataset:_files' \
  '-preserve[preserve nonzero input values by voting]' \
  '-vote[preserve nonzero input values by voting]' \
  '*:dataset:_files' && ret=0

return ret
