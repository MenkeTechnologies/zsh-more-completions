#compdef verdaccio
# Documentation: https://verdaccio.org/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --info)'{-i,--info}'[print local environment information]' \
  '-l+[host:port to listen on]:listen address' \
  '--listen=[host:port to listen on]:listen address' \
  '-c+[path to config file]:config:_files -g "*.{yaml,yml}"' \
  '--config=[path to config file]:config:_files -g "*.{yaml,yml}"' && ret=0

return ret
