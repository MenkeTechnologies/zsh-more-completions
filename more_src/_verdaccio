#compdef verdaccio

# Zsh completion for Verdaccio - lightweight npm proxy registry

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-l+[host:port to listen on]:listen address' \
  '--listen=[host:port to listen on]:listen address' \
  '-c+[path to config file]:config:_files -g "*.{yaml,yml}"' \
  '--config=[path to config file]:config:_files -g "*.{yaml,yml}"' \
  '--info[show environment information]' && ret=0

return ret
