#compdef conda-build
# Documentation: https://man.archlinux.org/search?q=conda-build
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-n --no-test)'{-n,--no-test}'[do not test after build]' \
  '--build-only[build without post processing or testing]' \
  '--post[run only post-build logic]' \
  '--test-run-post[test post script]' \
  '(-b --build-only)'{-b,--build-only}'[build only without test/upload]' \
  '(-s --source)'{-s,--source}'[only fetch source]' \
  '(-t --test)'{-t,--test}'[test pre-built package]' \
  '--no-anaconda-upload[disable anaconda upload]' \
  '--no-include-recipe[do not include recipe in package]' \
  '--output[show output build path]' \
  '--output-folder=[output package folder]:dir:_files -/' \
  '--cache-dir=[cache directory]:dir:_files -/' \
  '--no-prefix-length-fallback[no prefix length fallback]' \
  '--prefix-length-fallback[shorten prefix on conflict]' \
  '--prefix-length=[prefix length]:n:' \
  '--no-locking[disable filesystem locking]' \
  '--no-remove-work-dir[keep work dir after build]' \
  '--error-overlinking[error on overlinked libs]' \
  '--no-error-overlinking[no error on overlink]' \
  '--error-overdepending[error on overdepending]' \
  '--no-error-overdepending[no error on overdepending]' \
  '--keep-old-work[keep old work folders]' \
  '--debug[enable debug logging]' \
  '*--variants=[build variants override]:json:' \
  '*-c+[additional channel]:channel:' \
  '*--channel=[additional channel]:channel:' \
  '--override-channels[do not search default channels]' \
  '--repodata-fn=[repodata filename]:fn:' \
  '--use-channeldata[use channeldata.json]' \
  '--zstd-compression-level=[zstd level]:n:' \
  '--no-test-run-post[do not run post-link test]' \
  '--quiet[reduce output]' \
  '--token=[binstar token]:tok:' \
  '--user=[anaconda user]:user:' \
  '--label=[label for anaconda]:label:' \
  '--no-force-upload[do not force upload]' \
  '--croot=[conda-build root directory]:dir:_files -/' \
  '--skip-existing[skip if already built]' \
  '--keep-going[keep going on failures]' \
  '*-m+[variants config files]:file:_files' \
  '*--variant-config-files=[variants config files]:file:_files' \
  '*-e+[exclusive config file]:file:_files' \
  '*--exclusive-config-files=[exclusive config file]:file:_files' \
  '--old-build-string[use old build string]' \
  '--use-local[search local build for deps]' \
  '--check[only check recipe validity]' \
  '--no-anaconda-upload[skip upload]' \
  '--stats-file=[write stats JSON]:file:_files' \
  '--extra-deps=[extra build deps csv]:list:' \
  '--no-anaconda-upload[do not upload to anaconda]' \
  '--package-format=[package format]:fmt:(1 2 .tar.bz2 .conda)' \
  '--suppress-variables[suppress variables in summary]' \
  '*:recipe directory:_files -/' && ret=0

return ret
