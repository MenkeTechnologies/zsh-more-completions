#compdef req-exclude
# Documentation: https://hashcat.net/wiki/doku.php?id=hashcat_utils
# filter OUT words matching password-policy requirements (LOWER=1 UPPER=2 DIGIT=4 SYMBOL=8 OTHER=16)

local ret=1

_arguments -s -S \
  '1:criteria (sum of LOWER=1 UPPER=2 DIGIT=4 SYMBOL=8 OTHER=16):' && ret=0

return ret
