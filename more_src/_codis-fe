#compdef codis-fe
# Documentation: https://github.com/CodisLabs/codis/blob/master/cmd/fe/main.go
# Codis front-end dashboard web UI

local ret=1

_arguments -s -S \
  '--ncpu=[set runtime.GOMAXPROCS to N]:n:' \
  '(-d --dashboard-list)'{-d,--dashboard-list=}'[file listing dashboards, from codis-admin]:file:_files' \
  '(-l --log)'{-l,--log=}'[path/name of daily rotated log file]:file:_files' \
  '--log-level=[set the log level]:level:(INFO WARN DEBUG ERROR)' \
  '--assets-dir=[path to web assets directory]:dir:_files -/' \
  '--pidfile=[write pid to this file]:file:_files' \
  '--zookeeper=[ZooKeeper address for coordination]:addr:' \
  '--zookeeper-auth=[ZooKeeper auth as USR:PWD]:auth:' \
  '--etcd=[etcd address for coordination]:addr:' \
  '--etcd-auth=[etcd auth as USR:PWD]:auth:' \
  '--filesystem=[filesystem root for coordination]:root:_files -/' \
  '--listen=[listen address]:addr:' \
  '--version[show version and exit]' && ret=0

return ret
