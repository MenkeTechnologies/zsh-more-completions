#compdef csvlint
# Documentation: https://github.com/Clever/csvlint
# Clever csvlint: validate a CSV file according to RFC 4180

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--delimiter=[field delimiter (single unicode character, default comma)]:delimiter' \
  '--lazyquotes[allow quotes in unquoted fields and non-doubled quotes in quoted fields]' \
  '*:csv file:_files' && ret=0

return ret
