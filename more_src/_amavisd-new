#compdef amavisd-new

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start daemon'
  'stop:stop daemon'
  'restart:restart daemon'
  'reload:reload configuration'
  'kill:kill daemon'
  'status:show status'
  'debug:run in debug mode'
  'debug-sa:run with SpamAssassin debug'
  'foreground:run in foreground'
  'showkeys:show DKIM public keys'
  'testkeys:test DKIM signing keys'
  'genrsa:generate RSA key pair'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '-u+[user]:user:_users' \
  '-g+[group]:group:_groups' \
  '-p+[pid file]:file:_files' \
  '-X+[exclude policy]:bank:' \
  '-v+[verbose level]:lvl:(0 1 2 3 4 5)' \
  '-q+[quiet level]:lvl:' \
  '-d+[debug level]:lvl:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'amavisd-new command' commands && ret=0 ;;
esac

return ret
