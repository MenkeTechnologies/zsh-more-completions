#compdef glab-mr
# _glab-mr — GitLab glab merge request subcommand alias (GitLab Inc., Go); spf13/cobra
# upstream: https://gitlab.com/gitlab-org/cli

_glab-mr() {
    local -a sub=(
        'approve:approve a merge request'
        'approvers:list approvers'
        'changes:show changes/diff'
        'checkout:check out a merge request locally'
        'close:close a merge request'
        'create:create a merge request'
        'delete:delete a merge request'
        'diff:show diff for an MR'
        'for:show MR for branch'
        'issues:list referenced issues'
        'list:list merge requests'
        'merge:merge a merge request'
        'note:add a note to an MR'
        'rebase:rebase a merge request'
        'reopen:reopen a merge request'
        'revoke:revoke MR approval'
        'show:show MR details'
        'subscribe:subscribe to MR'
        'todo:add a todo for an MR'
        'unsubscribe:unsubscribe from MR'
        'update:update merge request'
        'view:view an MR'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--repo=+[repository]:str:' \
        '-R+[repository]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glab-mr subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--allow-collaboration[allow collaboration]' \
                    '--assignee=+[assignee]:list:' \
                    '-a+[assignee]:list:' \
                    '--description=+[description]:str:' \
                    '-d+[description]:str:' \
                    '--draft[draft]' \
                    '--fill[fill from commits]' \
                    '-f[fill from commits]' \
                    '--label=+[label]:list:' \
                    '-l+[label]:list:' \
                    '--milestone=+[milestone]:str:' \
                    '-m+[milestone]:str:' \
                    '--remove-source-branch[remove source branch]' \
                    '--reviewer=+[reviewer]:list:' \
                    '-r+[reviewer]:list:' \
                    '--source-branch=+[source branch]:str:' \
                    '-s+[source branch]:str:' \
                    '--squash[squash on merge]' \
                    '--target-branch=+[target branch]:str:' \
                    '-b+[target branch]:str:' \
                    '--target-project=+[target project]:str:' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '--yes[yes]' \
                    '-y[yes]' ;;
                list) _arguments \
                    '--all[all]' \
                    '-A[all]' \
                    '--assignee=+[assignee]:str:' \
                    '-a+[assignee]:str:' \
                    '--closed[closed]' \
                    '--draft[drafts only]' \
                    '--group=+[group]:str:' \
                    '-g+[group]:str:' \
                    '--label=+[label]:list:' \
                    '-l+[label]:list:' \
                    '--merged[merged only]' \
                    '-M[merged only]' \
                    '--mine[mine]' \
                    '-m[mine]' \
                    '--milestone=+[milestone]:str:' \
                    '--opened[open only]' \
                    '-o[open only]' \
                    '--per-page=+[per page]:n:' \
                    '-P+[per page]:n:' \
                    '--reviewer=+[reviewer]:str:' \
                    '-r+[reviewer]:str:' \
                    '--search=+[search]:str:' \
                    '-s+[search]:str:' \
                    '--state=+[state]:s:(opened closed merged all)' ;;
                view|approve|approvers|close|delete|merge|note|rebase|reopen|revoke|show|subscribe|todo|unsubscribe|update|diff|changes|issues|checkout) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '*:mr-id:' ;;
            esac
            ;;
    esac
}

_glab-mr "$@"
