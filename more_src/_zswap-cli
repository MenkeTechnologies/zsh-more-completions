#compdef zswap-cli
# _zswap-cli — Linux kernel zswap compressed cache for swap pages sysfs CLI alias (Linux kernel, C); custom argparse
# upstream: https://github.com/torvalds/linux

_zswap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--enabled=+[enabled]:b:(Y N)' \
        '--max-pool-percent=+[max pool percent]:n:' \
        '--compressor=+[compressor]:c:(lzo lzo-rle lz4 lz4hc zstd deflate-iaa 842 deflate)' \
        '--zpool=+[zpool backend]:b:(zbud z3fold zsmalloc)' \
        '--accept-threshold-percent=+[accept threshold percent]:n:' \
        '--non-same-filled-pages-enabled=+[non same filled pages enabled]:b:(Y N)' \
        '--same-filled-pages-enabled=+[same filled pages enabled]:b:(Y N)' \
        '--shrinker-enabled=+[shrinker enabled]:b:(Y N)' \
        '--stat[print stats]' \
        '--stored-pages[print stored pages]' \
        '--pool-total-size[print pool total size]' \
        '--reset[reset zswap]' \
        '--debug[debug]' \
        '*:arg:'
}

_zswap-cli "$@"
