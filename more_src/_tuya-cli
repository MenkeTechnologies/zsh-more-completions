#compdef tuya-cli
# Documentation: https://github.com/TuyaAPI/cli
# tuya-cli: command line interface for Tuya devices

local ret=1
local -a subcmds
subcmds=(
  'cloud:interact with the Tuya cloud API'
  'link:link a new device to your WiFi'
  'get:get a property on a device'
  'set:set a property on a device'
  'list:list all locally saved devices'
  'list-app:list devices from the Tuya Smart app'
  'mock:mock a Tuya device for local testing'
  'wizard:list devices from an official app account'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--ssid=[name of WiFi to connect to]:ssid' \
  '--password=[password of WiFi]:password' \
  '--bind-addr=[ip of wireless interface to broadcast on]:ip' \
  '--api-key=[your tuya.com API key]:key' \
  '--api-secret=[your tuya.com API secret]:secret' \
  '--schema=[your tuya.com app identifier]:schema' \
  '(-t --timezone)'{-t,--timezone}'=[your local timezone in tz format]:tz' \
  '(-r --region)'{-r,--region}'=[the region closest to you]:region' \
  '--saveAPI[save your API pair]' \
  '(-s --save)'{-s,--save}'[save device parameters]' \
  '(-n --num)'{-n,--num}'=[number of devices to link]:num' \
  '--ip=[ip address of device]:ip' \
  '--id=[id of device]:id' \
  '--key=[key of device]:key' \
  '--cid=[zigbee sub-device id]:cid' \
  '--dps=[property index]:dps' \
  '--full[get full response payload]' \
  '--protocol-version=[tuya protocol version]:version' \
  '--set=[value to set]:value' \
  '--raw-value[pass the raw set value]' \
  '(-p --port)'{-p,--port}'=[proxy port]:port' \
  '--cert-port=[certificate download port]:port' \
  '(-q --omitQR)'{-q,--omitQR}'[do not show the QR code]' \
  '(-o --out)'{-o,--out}'=[export devices to a JSON file]:file:_files' \
  '--stringify[stringify JSON before printing]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'tuya-cli command' subcmds && ret=0 ;;
esac

return ret
