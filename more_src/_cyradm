#compdef cyradm

# cyradm: interactive Cyrus IMAP administration shell
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-u[user]:user:_users' \
  '--user=[user]:user:_users' \
  '-a[authentication name]:authname:' \
  '--auth=[authentication name]:authname:' \
  '-w[password]:pass:' \
  '--password=[password]:pass:' \
  '-s[use TLS]' \
  '--tls[use TLS]' \
  '--notls[no TLS]' \
  '-m[SASL mech]:mech:' \
  '--mechanism=[SASL mech]:mech:' \
  '-r[SASL realm]:realm:' \
  '--realm=[SASL realm]:realm:' \
  '--port=[port]:port:' \
  '-q[batch mode]' \
  '--quiet[batch mode]' \
  '*:server:_hosts' && ret=0
return ret
