#compdef scilab
# Documentation: https://help.scilab.org/startup_options
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-args=[script args]:args:' \
  '(-d -display)'{-d,-display}'=[display]:display:' \
  '--display=[display]:display:' \
  '-e=[instruction]:cmd:' \
  '-f=[script file]:file:_files -g "*.sce"' \
  '-quit[exit after -e/-f]' \
  '-l=[language]:lang:(en_US fr_FR)' \
  '-nocolor[no color]' \
  '-nw[console mode]' \
  '-nwni[terminal mode]' \
  '-nogui[no GUI]' \
  '--parse-trace[bison trace]' \
  '--AST-trace[ASCII AST]' \
  '--pretty-print[pretty print]' \
  '--AST-timed[time AST nodes]' \
  '--timed[time execution]' \
  '--context-dump[context dump]' \
  '--exec-verbose[echo commands]' \
  '-nb[no banner]' \
  '-noatomsautoload[no ATOMS]' \
  '--no-exec[parse only]' \
  '-nouserstartup[no user startup]' \
  '-ns[no scilab.start]' \
  '--timeout=[delay]:seconds:' \
  '-debug[run gdb]' \
  '-debug-kdbg[run kdbg]' \
  '-profiling[valgrind]' \
  '-profiling-visu[callgrind]' \
  '-disable-exception-catching[no catch]' \
  '--parse-file=[file]:file:_files' \
  '--help[show help]' \
  '(--version -version)'{--version,-version}'[show version]' \
  '-texmacs[TeXmacs frontend]'
