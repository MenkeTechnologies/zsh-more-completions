#compdef mpv-cli
# _mpv-cli — mpv command-line video/audio player (mpv-player team, C); custom argparse
# upstream: https://github.com/mpv-player/mpv

_mpv-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--no-config[disable config]' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--load-scripts=+[bool]:b:(yes no)' \
        '--script=+[script file]:file:_files' \
        '--scripts=+[scripts]:str:' \
        '--script-opts=+[opts]:str:' \
        '--include=+[file]:file:_files' \
        '--profile=+[profile]:str:' \
        '--list-options[list options]' \
        '--list-properties[list properties]' \
        '--audio-devices[list audio devices]' \
        '--vo=+[video output]:str:' \
        '--ao=+[audio output]:str:' \
        '--hwdec=+[hwdec]:m:(no auto auto-safe vaapi vaapi-copy vdpau vdpau-copy videotoolbox videotoolbox-copy d3d11va d3d11va-copy dxva2 dxva2-copy nvdec nvdec-copy crystalhd cuda cuda-copy rkmpp drm drm-copy)' \
        '--hwdec-codecs=+[codecs]:str:' \
        '--volume=+[volume]:n:' \
        '--mute=+[bool]:b:(yes no auto)' \
        '--audio-pitch-correction=+[bool]:b:(yes no)' \
        '--audio-delay=+[seconds]:str:' \
        '--af=+[audio filter]:str:' \
        '--vf=+[video filter]:str:' \
        '--start=+[time]:str:' \
        '--end=+[time]:str:' \
        '--length=+[time]:str:' \
        '--rebase-start-time=+[bool]:b:(yes no)' \
        '--speed=+[speed]:str:' \
        '--loop[loop file]' \
        '--loop-file=+[bool/n]:str:' \
        '--loop-playlist=+[bool/n]:str:' \
        '--shuffle[shuffle playlist]' \
        '--input-conf=+[file]:file:_files -g "input.conf"' \
        '--input-default-bindings=+[bool]:b:(yes no)' \
        '--input-ipc-server=+[socket]:file:_files' \
        '--input-cursor=+[bool]:b:(yes no)' \
        '--input-keyboard=+[bool]:b:(yes no)' \
        '--input-vo-keyboard=+[bool]:b:(yes no)' \
        '--fs[fullscreen]' \
        '--no-fs[no fullscreen]' \
        '--fullscreen[fullscreen]' \
        '--ontop[stay on top]' \
        '--border=+[bool]:b:(yes no)' \
        '--no-border[no window decorations]' \
        '--no-osc[no on-screen controller]' \
        '--osc=+[bool]:b:(yes no)' \
        '--osd-level=+[level]:n:' \
        '--osd-font=+[font]:str:' \
        '--osd-font-size=+[size]:n:' \
        '--osd-back-color=+[color]:str:' \
        '--osd-color=+[color]:str:' \
        '--no-audio[no audio]' \
        '--no-video[no video]' \
        '--no-sub[no subtitles]' \
        '--audio-file=+[file]:file:_files' \
        '--sub-file=+[file]:file:_files' \
        '--sub-files=+[files]:str:' \
        '--sub-pos=+[n]:n:' \
        '--sub-scale=+[n]:str:' \
        '--sub-codepage=+[codepage]:str:' \
        '--sub-font=+[font]:str:' \
        '--sub-color=+[color]:str:' \
        '--sub-back-color=+[color]:str:' \
        '--sub-border-color=+[color]:str:' \
        '--sid=+[id]:str:' \
        '--aid=+[id]:str:' \
        '--vid=+[id]:str:' \
        '--audio-lang=+[langs]:str:' \
        '--sub-lang=+[langs]:str:' \
        '--alang=+[langs]:str:' \
        '--slang=+[langs]:str:' \
        '--cache=+[bool]:b:(yes no auto)' \
        '--cache-secs=+[seconds]:n:' \
        '--demuxer-max-bytes=+[bytes]:n:' \
        '--demuxer-max-back-bytes=+[bytes]:n:' \
        '--demuxer=+[demuxer]:str:' \
        '--user-agent=+[string]:str:' \
        '--referrer=+[url]:url:_urls' \
        '--http-header-fields=+[fields]:str:' \
        '--cookies=+[bool]:b:(yes no)' \
        '--cookies-file=+[file]:file:_files' \
        '--tls-ca-file=+[file]:file:_files' \
        '--tls-cert-file=+[file]:file:_files' \
        '--tls-key-file=+[file]:file:_files' \
        '--tls-verify=+[bool]:b:(yes no)' \
        '--ytdl[use yt-dlp]' \
        '--ytdl-format=+[format]:str:' \
        '--ytdl-raw-options=+[opts]:str:' \
        '--screenshot-directory=+[dir]:dir:_files -/' \
        '--screenshot-format=+[fmt]:f:(jpg jpeg png webp jxl avif)' \
        '--screenshot-template=+[template]:str:' \
        '--save-position-on-quit[save position]' \
        '--watch-later-directory=+[dir]:dir:_files -/' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--really-quiet[really quiet]' \
        '--no-terminal[no terminal output]' \
        '--msg-level=+[modules]:str:' \
        '--log-file=+[file]:file:_files' \
        '--no-input-default-bindings[no default bindings]' \
        '--idle=+[bool]:b:(yes no)' \
        '--idle-mode[idle mode]' \
        '--keep-open=+[bool]:b:(yes no always)' \
        '--vo-vdpau-deint=+[mode]:n:' \
        '*:files urls:_files'
}

_mpv-cli "$@"
