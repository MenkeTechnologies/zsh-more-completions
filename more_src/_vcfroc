#compdef vcfroc
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfroc.md
# Generate a ROC curve by comparing a VCF against a ground-truth VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --truth-vcf)'{-t,--truth-vcf}'[use this VCF as ground truth for ROC generation]:VCF file:_files -g "*.(vcf|vcf.gz)"' \
  '(-w --window-size)'{-w,--window-size}'[compare records up to this many bp away (default 30)]:bp' \
  '(-c --complex)'{-c,--complex}'[directly compare complex alleles, do not parse into primitives]' \
  '(-r --reference)'{-r,--reference}'[FASTA reference file]:FASTA file:_files' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
