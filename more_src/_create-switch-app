#compdef create-switch-app
# Documentation: https://www.npmjs.com/package/create-switch-app
# Reference accessed: 2026-05-24
# Verified: npm view create-switch-app bin; package source defines init/generate subcommands.

# Zsh completion for create-switch-app - React/Next.js/Expo/Node POC scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-f --force)'{-f,--force}'[overwrite existing directory if it exists]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' init generate g && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -C \
          '(-f --force)'{-f,--force}'[overwrite existing directory if it exists]' \
          ':project name:' && ret=0
        ;;
      generate|g)
        _arguments -C \
          '(-f --force)'{-f,--force}'[overwrite if already exists]' \
          ':type:(service component hook)' \
          ':name:' && ret=0
        ;;
      *)
        _arguments -C \
          '(-f --force)'{-f,--force}'[overwrite existing directory if it exists]' \
          ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
