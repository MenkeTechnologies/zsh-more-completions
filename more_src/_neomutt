#compdef neomutt

# completions for NeoMutt email client

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-v,--version}'[show version and exit]'
  '-vv[show detailed version and compile options]'
  '-A+[expand an alias]:alias'
  '-a+[attach a file to the message]:file:_files'
  '-b+[specify BCC address]:address'
  '-c+[specify CC address]:address'
  '-d+[set debug level]:level:(1 2 3 4 5)'
  '-D[print values of all config options]'
  '-DS[like -D but hide sensitive values]'
  '-DO[like -D but show one-liner documentation]'
  '-e+[specify command to execute after init]:command'
  '-f+[specify mailbox to load]:mailbox:_files'
  '-F+[specify alternate muttrc file]:file:_files'
  '-H+[specify draft file for message header]:file:_files'
  '-i+[specify include file for message body]:file:_files'
  '-l+[specify file for debug log]:file:_files'
  '-m+[specify default mailbox type]:type:(mbox Maildir MH MMDF)'
  '-n[do not read system muttrc]'
  '-p[resume postponed message]'
  '-Q+[query a configuration variable]:variable'
  '-R[open mailbox in read-only mode]'
  '-s+[specify subject]:subject'
  '-y[show mailbox browser at startup]'
  '-z[exit immediately if no new messages]'
  '-Z[open first mailbox with new mail]'
  '*:address:'
)

_arguments -s -S $arguments
