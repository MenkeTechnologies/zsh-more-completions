#compdef n3n-supernode
# Documentation: https://man.archlinux.org/search?q=n3n-supernode
# Reference accessed: 2026-05-16

_arguments -s \
  '*-O[set config option section.option=value]:setting:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '1:subcommand:(start help)' \
  '*::arg: '
