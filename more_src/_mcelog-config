#compdef mcelog-config

# mcelog-config: helper to set mcelog configuration
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--get[get config value]:key:' \
  '--set[set config value]:key value:' \
  '--list[list all config]' \
  '*::mcelog-config args:_files' && ret=0
return ret
