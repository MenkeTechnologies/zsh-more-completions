#compdef vale

# Zsh completion for vale - a syntax-aware linter for prose

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'ls-config:Print the current configuration'
  'ls-metrics:Print information about a given file'
  'ls-vars:Print a list of user-defined variables'
  'new-rule:Create a rule in the current directory'
  'sync:Initialize or update Vale packages'
  'run:Lint one or more files'
  'help:Print help'
)

_arguments -s -S \
  '--config[use this configuration file]:file:_files -g "*.ini"' \
  '--ext[treat stdin as having this extension]:ext:' \
  '--filter[use a JMESPath expression to filter alerts]:expr:' \
  '--glob[glob pattern to limit scanning to matching files]:glob:' \
  '--ignore-syntax[lint all files line-by-line]' \
  '--minAlertLevel[minimum alert level to display]:level:(suggestion warning error)' \
  '--no-exit[do not return a non-zero exit code on lint errors]' \
  '--no-wrap[do not wrap CLI output]' \
  '--normalize[replace each path separator with a slash]' \
  '--output[output style]:format:(line JSON CLI)' \
  '--relative[return relative file paths]' \
  '--sort[sort output by file name]' \
  '--time[print execution time]' \
  '--version[print the current version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run|'')
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
