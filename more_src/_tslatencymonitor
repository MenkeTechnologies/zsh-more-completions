#compdef tslatencymonitor
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tslatencymonitor.cpp
# tslatencymonitor - monitor latency between two transport stream input sources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:ts input:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
