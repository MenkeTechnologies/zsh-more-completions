#compdef acra-rotate
# _acra-rotate — rotate Acra encryption keys and re-encrypt data (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Flags from cmd/acra-rotate/acra-rotate.go (flag).

_acra-rotate() {
    _arguments \
        '(- *)-h[show help]' \
        '-keys_dir=[directory containing keys]:dir:_files -/' \
        '-file_map_config=[JSON map of clientID → file paths]:file:_files -g "*.json"' \
        '-sql_select=[SELECT query (ClientId/AcraStruct trailing cols)]:sql:' \
        '-sql_update=[INSERT/UPDATE query for rotated AcraStructs]:sql:' \
        '-db_connection_string=[DB connection string]:dsn:' \
        '-mysql_enable[handle MySQL connections]' \
        '-postgresql_enable[handle PostgreSQL connections]' \
        '-dry-run[do not save rotated data/keys]' \
        '-tls_database_enabled[enable TLS for database connection]'
}

_acra-rotate "$@"
