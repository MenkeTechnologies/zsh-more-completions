#compdef fluidsynth
# Documentation: https://github.com/FluidSynth/fluidsynth
# Reference accessed: 2026-05-27
# Verified: upstream src/fluidsynth.c long_options table and short optchars (FluidSynth/fluidsynth)

local curcontext="$curcontext" state line ret=1

# fluidsynth accepts SoundFont files (.sf2, .sf3, .dls) and MIDI files (.mid, .midi, .kar).
_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '(-V --version)'{-V,--version}'[print version information and exit]' \
  '(-n --no-midi-in)'{-n,--no-midi-in}'[do not create a MIDI driver to read MIDI input events]' \
  '(-i --no-shell)'{-i,--no-shell}'[do not read commands from the shell]' \
  '(-s --server)'{-s,--server}'[start FluidSynth as a server process]' \
  '(-d --dump)'{-d,--dump}'[dump incoming and outgoing MIDI events to stdout]' \
  '(-v --verbose)'{-v,--verbose}'[print all command-line arguments and settings before starting]' \
  '(-q --quiet)'{-q,--quiet}'[do not print welcome message or any other output to stdout]' \
  '(-j --connect-jack-outputs)'{-j,--connect-jack-outputs}'[attempt to connect JACK outputs to physical ports]' \
  '(-l --disable-lash)'{-l,--disable-lash}'[disable LASH support]' \
  '(-Q --query-audio-devices)'{-Q,--query-audio-devices}'[print available audio devices for each driver and exit]' \
  '(-a --audio-driver)'{-a+,--audio-driver=}'[audio driver]:driver:(alsa coreaudio dsound jack oboe oss portaudio pulseaudio sdl2 sndman wasapi waveout file help)' \
  '(-m --midi-driver)'{-m+,--midi-driver=}'[MIDI driver]:driver:(alsa_raw alsa_seq coremidi jack midishare oss winmidi help)' \
  '(-c --audio-bufcount)'{-c+,--audio-bufcount=}'[number of audio buffers]:count:' \
  '(-z --audio-bufsize)'{-z+,--audio-bufsize=}'[size of each audio buffer in frames]:size:' \
  '(-r --sample-rate)'{-r+,--sample-rate=}'[sample rate in Hz]:rate:(22050 44100 48000 88200 96000 192000)' \
  '(-g --gain)'{-g+,--gain=}'[master gain, value between 0.0 and 10.0]:gain:' \
  '(-K --midi-channels)'{-K+,--midi-channels=}'[number of MIDI channels]:channels:' \
  '(-L --audio-channels)'{-L+,--audio-channels=}'[number of stereo audio channels]:channels:' \
  '(-G --audio-groups)'{-G+,--audio-groups=}'[number of audio mixdown groups]:groups:' \
  '(-R --reverb)'{-R+,--reverb=}'[enable/disable reverb (yes/no/0/1)]:state:(yes no 0 1)' \
  '(-C --chorus)'{-C+,--chorus=}'[enable/disable chorus (yes/no/0/1)]:state:(yes no 0 1)' \
  '(-E --audio-file-endian)'{-E+,--audio-file-endian=}'[audio file endianness for fast-render]:endian:(little big cpu help)' \
  '(-T --audio-file-type)'{-T+,--audio-file-type=}'[audio file type for fast-render]:type:(wav aiff au flac oga raw help)' \
  '(-O --audio-file-format)'{-O+,--audio-file-format=}'[audio file sample format for fast-render]:format:(s8 s16 s24 s32 u8 float double help)' \
  '(-F --fast-render)'{-F+,--fast-render=}'[render MIDI files as fast as possible to an audio file]:file:_files' \
  '(-f --load-config)'{-f+,--load-config=}'[load command configuration file on startup]:file:_files' \
  '(-p --portname)'{-p+,--portname=}'[set JACK or PortAudio port name]:name:' \
  '(-b --bank-offset)'{-b+,--bank-offset=}'[bank offset to apply to the next SoundFont]:offset:' \
  '*'{-o+,--option=}'[set an arbitrary FluidSynth setting (name=value)]:setting:' \
  '*:file:_files -g "*.(sf2|sf3|dls|mid|midi|kar|SF2|SF3|DLS|MID|MIDI|KAR)"' && ret=0

return ret
