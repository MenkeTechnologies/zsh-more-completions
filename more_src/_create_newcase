#compdef create_newcase
# Documentation: https://esmci.github.io/cime/versions/cesm2.2/html/Tools_user/create_newcase.html
# CIME: create a new CESM/E3SM case

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to file]' \
  '(-v --verbose)'{-v,--verbose}'[add additional context to log messages]' \
  '(-s --silent)'{-s,--silent}'[print only warnings and error messages]' \
  '--case[case name]:case name:_files' \
  '--compset[component set longname or alias]:compset' \
  '--res[model resolution grid]:grid' \
  '--machine[machine name]:machine' \
  '--compiler[compiler to use]:compiler' \
  '--multi-driver[use one driver per ensemble member]' \
  '--ninst[number of component instances]:ninst' \
  '--mpilib[MPI library to use]:mpilib' \
  '--project[project id for batch and archiving]:project' \
  '--pecount[machine PE count layout]:pecount:(S M L X1 X2)' \
  '--user-mods-dir[directory of user modifications to apply]:dir:_files -/' \
  '--pesfile[full pathname of file containing PE layout]:file:_files' \
  '--gridfile[full pathname of config grids file to use]:file:_files' \
  '--workflow[workflow from config_workflow.xml]:workflow' \
  '--srcroot[alternative pathname for source root directory]:dir:_files -/' \
  '--output-root[alternative pathname for case output directory]:dir:_files -/' \
  '--run-unsupported[allow creation of unsupported compset/grid cases]' \
  '--walltime[wallclock limit in HH:MM:SS]:walltime' \
  '(-q --queue)'{-q,--queue}'[force batch system to use the specified queue]:queue' \
  '--handle-preexisting-dirs[how to handle pre-existing bld/exe dirs]:mode:((a\:abort r\:replace u\:use))' \
  '-i[use a non-default location for input files]:dir:_files -/' \
  '-n[do not create a case, just print the result of compset/grid parsing]' && ret=0

return ret
