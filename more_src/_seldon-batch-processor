#compdef seldon-batch-processor
# Documentation: https://man.archlinux.org/search?q=seldon-batch-processor
# Reference accessed: 2026-05-16

# Seldon batch processor: run batched predictions against a Seldon model
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--deployment-name=[Seldon deployment name]:name:' \
  '--gateway-type=[gateway type]:type:(ambassador istio)' \
  '--namespace=[k8s namespace]:ns:' \
  '--host=[gateway host]:host:_hosts' \
  '--transport=[transport]:transport:(rest grpc)' \
  '--workers=[worker count]:n:' \
  '--retries=[retries]:n:' \
  '--input-data-type=[input type]:type:(data ndarray tensor str raw_data)' \
  '--output-data-type=[output type]:type:(data ndarray tensor)' \
  '--data-type=[payload data type]:type:' \
  '--batch-size=[batch size]:n:' \
  '--method=[seldon method]:method:(predict transform-input transform-output route aggregate)' \
  '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR)' \
  '--benchmark[show benchmark info]' \
  '1:input file:_files' \
  '2:output file:_files' \
  '*::seldon-batch-processor args:_files' && ret=0
return ret
