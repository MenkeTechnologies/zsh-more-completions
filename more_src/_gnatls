#compdef gnatls
# Documentation: https://man.archlinux.org/search?q=gnatls
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[all files]' \
  '-aO+[search obj dir]:dir:_files -/' \
  '-aI+[search src dir]:dir:_files -/' \
  '-aP+[project path]:dir:_files -/' \
  '-d[depends on]' \
  '-h[help]' \
  '-I+[search dir]:dir:_files -/' \
  '-l[long listing]' \
  '-nostdinc[no stdinc]' \
  '-nostdlib[no stdlib]' \
  '-o[print object files only]' \
  '-p[print project info]' \
  '-P+[project file]:file:_files -g "*.gpr"' \
  '-s[print source files only]' \
  '-u[print unit names only]' \
  '-v[verbose - show paths]' \
  '-X+[scenario var]:var=val:' \
  '*:file:_files' && ret=0

return ret
