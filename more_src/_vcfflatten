#compdef vcfflatten
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfflatten.md
# Remove multi-allelic sites by picking the most common alternate

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[do not flatten locus if AF is not specified]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
