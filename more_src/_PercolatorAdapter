#compdef PercolatorAdapter
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: adapter to rescore identifications using Percolator

local ret=1

_arguments -s -S \
  '*-in[input identification files]:input file:_files' \
  '-in_decoy[separate decoy search results]:file:_files' \
  '-in_osw[OSW format input file]:file:_files' \
  '-out[output file]:output file:_files' \
  '-out_type[output format]:type:' \
  '-out_pin[debug PIN file output]:file:_files' \
  '-out_pout_target[debug target pout file]:file:_files' \
  '-out_pout_decoy[debug decoy pout file]:file:_files' \
  '-enzyme[protease type]:enzyme:' \
  '-use_subprocess[run external percolator binary]' \
  '-percolator_executable[path to percolator binary]:exe:_files' \
  '-peptide_level_fdrs[calculate peptide-level FDRs]' \
  '-protein_level_fdrs[infer protein probabilities using protein-level FDR]' \
  '-score_type[main score selection]:type:(q-value pep svm)' \
  '-osw_level[OSW data level]:level:(ms1 ms2 transition)' \
  '-testFDR[FDR threshold for cross-validation]:value:' \
  '-trainFDR[FDR threshold for training examples]:value:' \
  '-nested_xval_bins[cross-validation bin count]:n:' \
  '-post_processing_tdc[apply target-decoy competition]' \
  '-train_best_positive[limit positive PSMs per spectrum during training]' \
  '-score:fdr[FDR cutoff for output filtering]:value:' \
  '-best_per_spectrum_only[retain only top PSM per spectrum]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
