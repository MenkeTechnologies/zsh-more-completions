#compdef tcping

# Zsh completion for tcping - ping over TCP

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h -?)'{-h,-\?}'[show help]' \
  '(-v)-v[show version]' \
  '-t[ping until stopped with Ctrl-C]' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-i[interval in seconds between pings]:seconds' \
  '-c[number of pings to send]:count' \
  '-r[retry DNS lookup between pings]:number' \
  '-w[time to wait for reply in ms]:milliseconds' \
  '-d[do not print date/time]' \
  '-b[use beep on failures/changes]:beep mode' \
  '--color[colorize output]' \
  '--db[output to sqlite db]:file:_files' \
  '--csv[output to CSV]:file:_files' \
  '--json[output as JSON]' \
  '--pretty[pretty output]' \
  '1:hostname' \
  '2:port (default 80)' && ret=0

return ret
