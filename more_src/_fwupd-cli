#compdef fwupd-cli fwupdmgr

# fwupd-cli / fwupdmgr: client for fwupd firmware update daemon
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'activate:Activate devices pending update'
  'block-firmware:Blocks a specific firmware from being installed'
  'clear-history:Clears all device history'
  'device-emulate:Emulate a device using captured data'
  'device-test:Test a device using a JSON manifest'
  'device-wait:Wait for a device to appear'
  'disable-remote:Disables a given remote'
  'download:Download a file'
  'downgrade:Downgrades the firmware on a device'
  'emulation-load:Load device emulation data'
  'emulation-save:Save device emulation data'
  'emulation-tag:Adds devices to watch for future emulation'
  'emulation-untag:Removes devices to watch for future emulation'
  'enable-remote:Enables a given remote'
  'get-approved-firmware:Gets the list of approved firmware'
  'get-bios-setting:Get bios setting'
  'get-details:Gets details about a firmware file'
  'get-devices:Get all devices that support firmware updates'
  'get-history:Show history of firmware updates'
  'get-plugins:Get all plugins registered with the system'
  'get-releases:Gets the releases for a device'
  'get-remotes:Gets the configured remotes'
  'get-results:Gets the results from the last update'
  'get-topology:Show the host topology'
  'get-updates:Gets the list of updates for connected hardware'
  'get-upgrades:Alias for get-updates'
  'inhibit:Inhibit the system to prevent upgrades'
  'install:Install a specific firmware on a device'
  'local-install:Install a firmware file in cabinet format on the system'
  'modify-config:Modifies a daemon configuration value'
  'modify-remote:Modifies a given remote'
  'quit:Asks the daemon to quit'
  'refresh:Refresh metadata from remote server'
  'reinstall:Reinstall current firmware on the device'
  'release:Releases the system as suitable to start updates'
  'report-export:Export firmware history for manual upload'
  'report-history:Share firmware history with the developers'
  'reset-config:Resets configuration sections of a daemon'
  'security:Gets the host security attributes'
  'security-fix:Fix one or more host security attributes'
  'security-undo:Undo the host security attribute fix'
  'set-approved-firmware:Sets the list of approved firmware'
  'set-bios-setting:Sets one or more BIOS settings'
  'switch-branch:Switch the firmware branch on the device'
  'sync:Sync firmware versions to a configuration deployment'
  'unblock-firmware:Unblocks a specific firmware from being installed'
  'uninhibit:Uninhibit the system to allow upgrades'
  'unlock:Unlocks the device for firmware access'
  'update:Updates all specified devices to latest firmware version, or all devices'
  'upgrade:Alias for update'
  'verify:Checks cryptographic hash matches firmware'
  'verify-update:Update the stored cryptographic hash with current ROM contents'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--verbose}'[verbose]' \
  '--version[show version]' \
  '-y[answer yes to all prompts]' \
  '--assume-yes[answer yes to all prompts]' \
  '--no-unreported-check[do not check for unreported history]' \
  '--no-metadata-check[do not check for old metadata]' \
  '--no-remote-check[do not check if download remotes should be enabled]' \
  '--no-reboot-check[do not check or prompt for reboot after update]' \
  '--no-safety-check[do not perform device safety checks]' \
  '--force[force the action by relaxing some runtime checks]' \
  '--show-all[show extra debugging information]' \
  '--filter=[filter with a set of device flags]:filter:' \
  '--filter-release=[filter with a set of release flags]:filter:' \
  '--json[output in JSON format]' \
  '--no-history[do not write to the history database]' \
  '--no-security-fix[do not prompt to fix security issues]' \
  '--disable-ssl-strict[ignore SSL strict checks]' \
  '--ipfs[use IPFS when downloading files]' \
  '--allow-branch-switch[allow firmware branch switch]' \
  '--allow-older[allow downgrading firmware versions]' \
  '--allow-reinstall[allow re-installing existing firmware versions]' \
  '--p2p[only use peer-to-peer networking when downloading files]' \
  '--sign[sign the uploaded data with the client certificate]' \
  '--plugins=[set the list of plugins to load]:plugins:' \
  '--plugin-whitelist=[set the list of plugins to load (deprecated)]:plugins:' \
  '--save-backends[save backend devices to file]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'fwupd-cli command' commands && ret=0 ;;
esac
return ret
