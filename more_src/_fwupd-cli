#compdef fwupd-cli

# fwupd-cli: command-line firmware update tool (alternate name)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'get-devices:list available firmware devices'
  'get-updates:list available firmware updates'
  'get-releases:show device releases'
  'install:install firmware file or release'
  'refresh:refresh local metadata cache'
  'enable-remote:enable remote firmware source'
  'disable-remote:disable remote firmware source'
  'modify-remote:modify remote settings'
  'get-history:show firmware update history'
  'verify:verify device firmware checksum'
  'verify-update:update verification info'
  'unlock:unlock device for updates'
  'clear-results:clear firmware update results'
  'get-results:get firmware update result'
  'get-remotes:list configured remotes'
  'get-approved-firmware:list approved firmware checksums'
  'reset[-engine]:reset fwupd engine'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--version[show version]' \
  '--allow-reinstall[allow reinstalling]' \
  '--allow-older[allow downgrading]' \
  '--force[bypass policy checks]' \
  '--no-history[do not log to history]' \
  '--no-reboot-check[skip reboot prompts]' \
  '--no-safety-check[skip safety checks]' \
  '--no-metadata-check[skip metadata version check]' \
  '--show-all[show all devices, including hidden]' \
  '--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'fwupd-cli command' commands && ret=0 ;;
esac
return ret
