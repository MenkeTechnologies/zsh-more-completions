#compdef antrea
# _antrea — Antrea Authors VMware antrea CLI top-level wrapper for the Antrea Kubernetes CNI network plugin providing pod networking NetworkPolicy ClusterNetworkPolicy Multicast Egress IPSec Wireguard ServiceExternalIP FlowExporter trace flows ofctl tflow status connectivity-debug commands for the OVS-Open-vSwitch-backed CNI (Antrea team, Go); cobra
# upstream: https://antrea.io/

_antrea() {
    local -a sub=(
        'agent:agent commands'
        'controller:controller commands'
        'cni:CNI commands'
        'octant-plugin:Octant plugin'
        'netpol:NetworkPolicy testing'
        'traceflow:run Traceflow'
        'get:fetch resources'
        'set:set configuration'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'antrea subcommand' sub ;;
        args)
            case $words[1] in
                get) _arguments '1:resource:(agentinfo controllerinfo featuregates flowrecords appliedtogroup ovsflows policy networkpolicy clusternetworkpolicy)' '*:name:' ;;
                traceflow) _arguments \
                    '--src=+[src pod]:str:' \
                    '--dst=+[dst pod or ip]:str:' \
                    '--flow=+[flow spec]:str:' \
                    '--live[live trace]' ;;
            esac
            ;;
    esac
}

_antrea "$@"
