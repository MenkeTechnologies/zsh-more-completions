#compdef fwupdmgr

# Zsh completion for fwupdmgr - fwupd firmware update manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[show extra debugging information]' \
  '--allow-reinstall[allow reinstalling existing firmware]' \
  '--allow-older[allow downgrading firmware]' \
  '--force[override warnings and force action]' \
  '--show-all[show all results]' \
  '--offline[schedule installation for next reboot]' \
  '--json[output in JSON format]' \
  '--no-reboot-check[do not check for reboot after update]' \
  '--no-safety-check[do not perform safety checks]' \
  '--no-history[do not write to history database]' \
  '--no-unreported-check[do not check for unreported history]' \
  '--no-metadata-check[do not check for old metadata]' \
  '--no-remote-check[do not check if download remotes are enabled]' \
  '--no-search[do not search for devices]' \
  '(-y --assume-yes)'{-y,--assume-yes}'[assume yes to all prompts]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'activate:activate firmware update on device'
      'block-firmware:block firmware from being installed'
      'clear-history:clear firmware update history'
      'clear-offline:clear offline update request'
      'clear-results:clear results of last update'
      'disable-remote:disable a remote'
      'disable-plugins:disable plugins'
      'downgrade:downgrade firmware on device'
      'download:download a file'
      'emulation-load:load device emulation data'
      'emulation-save:save device emulation data'
      'emulation-tag:tag device for emulation'
      'enable-remote:enable a remote'
      'get-approved-firmware:get list of approved firmware'
      'get-blocked-firmware:get list of blocked firmware'
      'get-details:get details for firmware file'
      'get-devices:get all devices'
      'get-history:get update history'
      'get-plugins:get all enabled plugins'
      'get-releases:get releases for device'
      'get-remotes:get configured remotes'
      'get-results:get results of last update'
      'get-topology:get device topology'
      'get-updates:get available updates'
      'get-upgrades:get available upgrades'
      'inhibit:inhibit firmware updates'
      'install:install firmware from file or remote'
      'local-install:install firmware from local file'
      'modify-config:modify daemon configuration'
      'modify-remote:modify remote configuration'
      'quit:ask the daemon to quit'
      'refresh:refresh metadata from remote'
      'reinstall:reinstall firmware on device'
      'report-history:report update history to server'
      'report-export:export update report'
      'security:show host security attributes'
      'set-approved-firmware:set list of approved firmware'
      'switch-branch:switch firmware branch'
      'uninhibit:uninhibit firmware updates'
      'unblock-firmware:unblock firmware from being installed'
      'unlock:unlock device'
      'update:update firmware on all devices'
      'upgrade:upgrade firmware on device'
      'verify:verify firmware on device'
      'verify-update:update verification metadata'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
