#compdef tsp ts
# Documentation: https://manpages.debian.org/testing/task-spooler/tsp.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# task-spooler (tsp / ts): queue jobs for sequential execution
# Verified flags from manpage.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-K[kill task spooler server]' \
  '-C[clear finished job results]' \
  '-l[show job list]' \
  '-t+[show last ten lines of job output]:job id' \
  '-c+[display complete output file of job]:job id' \
  '-p+[show PID of a job]:job id' \
  '-o+[show output filename of a job]:job id' \
  '-i+[show information about a job]:job id' \
  '-s+[display state of a job]:job id' \
  '-r+[remove a job]:job id' \
  '-w+[wait for job completion]:job id' \
  '-k+[kill job process group]:job id' \
  '-u+[mark job as urgent]:job id' \
  '-U+[swap queue positions]:from-to' \
  '-S+[set/display maximum running jobs]:slots' \
  '-n[do not store standard output/error]' \
  '-g[compress output with gzip]' \
  '-f[run in foreground without detaching]' \
  '-m[email results]' \
  '-L+[label the task]:label' \
  '-d[run only if previous job succeeded]' \
  '-D+[run only if given job id succeeded]:job id' \
  '-B[exit instead of blocking when queue full]' \
  '-E[separate stdout and stderr files]' \
  '-N+[require specified free slots]:count' \
  '*:command to queue:_command_names -e' && ret=0

return ret
