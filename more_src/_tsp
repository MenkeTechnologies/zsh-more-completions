#compdef tsp

# completions for tsp/ts - task spooler (queue jobs)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-K[kill the task spooler server]' \
  '(- *)-C[clear finished jobs]' \
  '(- *)-l[list jobs]' \
  '-S+[set number of execution slots]:number of slots' \
  '-t+[tail output of a job]:job id' \
  '-c+[cat output of a job]:job id' \
  '-p+[show PID of a job]:job id' \
  '-o+[show output file of a job]:job id' \
  '-i+[show info of a job]:job id' \
  '-s+[show state of a job]:job id' \
  '-r+[remove a job from the queue]:job id' \
  '-w+[wait for a job to finish]:job id' \
  '-u+[urgently run a job (move to front)]:job id' \
  '-k+[kill a running job]:job id' \
  '-n[notify when the job finishes (by mail)]' \
  '-B[run in background and return job ID]' \
  '-E[pass environment to job]' \
  '-L+[set label for the job]:label' \
  '-D+[depend on another job]:job id' \
  '-W+[depend on job and wait for its output]:job id' \
  '-T+[set timeout for the job]:seconds' \
  '*:command to queue:_command_names -e' && ret=0

return ret
