#compdef gen-jsonld
# _gen-jsonld — generate a JSON-LD document from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/jsonldgen.py (click).

_gen-jsonld() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(jsonld|json)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(json-ld json)'
        '--context=[context URL or filepath to merge into the JSON-LD output]:context:_files'
        '--context-kwargs=[extra context keyword arguments (key=value, repeatable)]:kwargs:'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-jsonld "$@"
