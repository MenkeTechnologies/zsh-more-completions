#compdef timeconvert
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/core/apps/time/timeconvert.cpp
# GPSTk time format conversion utility

local ret=1

_arguments -s \
  '(-A --ansi)'{-A,--ansi}'[ANSI second]:ansi sec' \
  '(-c --civil)'{-c,--civil}'[month day year hour:minute:second]:civil time' \
  '(-R --rinex-file)'{-R,--rinex-file}'[2-digit year month day hour minute second]:rinex time' \
  '(-o --ews)'{-o,--ews}'[GPSEpoch 10bitGPSweek SecondOfWeek]:ews' \
  '(-f --ws)'{-f,--ws}'[FullGPSWeek SecondOfWeek]:ws' \
  '(-w --wz)'{-w,--wz}'[FullGPSWeek Zcount]:wz' \
  '--z29[29-bit Zcount]:z29' \
  '(-Z --z32)'{-Z,--z32}'[32-bit Zcount]:z32' \
  '(-j --julian)'{-j,--julian}'[JulianDate]:jd' \
  '(-m --mjd)'{-m,--mjd}'[ModifiedJulianDate]:mjd' \
  '(-u --unixtime)'{-u,--unixtime}'[UnixSeconds UnixMicroseconds]:unix' \
  '(-y --doy)'{-y,--doy}'[Year DayOfYear SecondsOfDay]:doy' \
  '--input-format[time format to use on input]:fmt' \
  '--input-time[time to be parsed by input-format]:time' \
  '(-F --format)'{-F,--format}'[time format to use on output]:fmt' \
  '(-a --add-offset)'{-a,--add-offset}'[add NUM seconds to specified time]:num' \
  '(-s --sub-offset)'{-s,--sub-offset}'[subtract NUM seconds from specified time]:num' \
  '(-d --debug)'{-d,--debug}'[increase debug level]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[print help usage]' && ret=0

return ret
