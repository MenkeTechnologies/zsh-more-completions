#compdef checkmarx checkmarx-cli cx-cli
# _checkmarx — Checkmarx CxSAST/CxOne CLI (Checkmarx, Java); custom argparse
# upstream: https://github.com/Checkmarx/ast-cli

_checkmarx() {
    local -a sub=(
        'scan:run SAST/SCA scan'
        'project:manage projects'
        'result:fetch results'
        'auth:authenticate'
        'configure:configure CLI'
        'tenant:manage tenants'
        'utils:misc utilities'
        'workflow:run pipeline workflows'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--base-uri=+[base URI]:url:_urls' \
        '--base-auth-uri=+[auth base URI]:url:_urls' \
        '--client-id=+[client id]:str:' \
        '--client-secret=+[client secret]:str:' \
        '--apikey=+[api key]:str:' \
        '--tenant=+[tenant]:str:' \
        '--profile=+[profile]:str:' \
        '--retry=+[retry count]:n:' \
        '--retry-delay=+[retry delay]:n:' \
        '--insecure[insecure]' \
        '--agent=+[agent]:str:' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'checkmarx subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '1:cmd:(create cancel delete list logs metadata recalculate show summary tags)' \
                    '--branch=+[branch]:str:' \
                    '-b+[branch]:str:' \
                    '--scan-types=+[scan types]:list:(sast sca kics iac iac-security secrets api-security container-security 2ms scs-secret-detection)' \
                    '--file-source=+[source path]:dir:_files -/' \
                    '-s+[source path]:dir:_files -/' \
                    '--project-name=+[project name]:str:' \
                    '--file-filter=+[file filter]:str:' \
                    '--threshold=+[threshold]:str:' \
                    '--report-format=+[report format]:fmt:(summaryConsole summaryHTML summaryJSON json sarif gl-sast gl-sca sbom-cyclonedx sbom-cyclonedx-json sbom-spdx-json pdf markdown junit-xml)' \
                    '--output-name=+[output name]:str:' \
                    '--output-path=+[output path]:dir:_files -/' \
                    '--wait[wait until scan finishes]' \
                    '--async[async]' \
                    '--tags=+[tags csv]:list:' \
                    '*:arg:' ;;
                project) _arguments \
                    '1:cmd:(create delete list show tags branches)' \
                    '--project-id=+[project id]:id:' \
                    '*:arg:' ;;
                result) _arguments \
                    '1:cmd:(show list summary code-bashing)' \
                    '--scan-id=+[scan id]:id:' \
                    '--report-format=+[report format]:fmt:(summaryConsole summaryHTML summaryJSON json sarif gl-sast gl-sca sbom-cyclonedx sbom-cyclonedx-json sbom-spdx-json pdf markdown junit-xml)' \
                    '--output-name=+[output name]:str:' \
                    '--output-path=+[output path]:dir:_files -/' ;;
                auth) _arguments \
                    '1:cmd:(register login validate revoke create-oauth2-client)' \
                    '*:arg:' ;;
                configure) _arguments \
                    '1:cmd:(show set)' \
                    '--prop-name=+[property name]:str:' \
                    '--prop-value=+[property value]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_checkmarx "$@"
