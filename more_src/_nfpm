#compdef nfpm

local curcontext="$curcontext" state line ret=1

_nfpm_commands() {
  local -a commands=(
    'init:Initialize a default config file'
    'package:Create a package'
    'jsonschema:Output JSON schema for config'
    'completion:Generate shell completion script'
  )
  _describe -t commands 'nfpm command' commands
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_nfpm_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '(-f --config)'{-f,--config}'[config file path]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      package)
        _arguments -s -S \
          '(-f --config)'{-f,--config}'[config file path]:file:_files' \
          '(-t --target)'{-t,--target}'[output file or directory]:file:_files' \
          '(-p --packager)'{-p,--packager}'[packager to use]:packager:(apk deb rpm archlinux ipk)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
