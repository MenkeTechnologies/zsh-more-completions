#compdef goreplay
# Documentation: https://github.com/buger/goreplay
# GoReplay: capture and replay live HTTP traffic

local ret=1

_arguments -s \
  '--input-raw=[capture traffic from given port via RAW sockets]:port' \
  '--input-raw-track-response[track responses in addition to requests]' \
  '--input-raw-engine=[interception engine]:engine:(libpcap raw_socket pcap_file vxlan)' \
  '--input-raw-protocol=[application protocol of intercepted traffic]:proto:(http binary)' \
  '--input-raw-bpf-filter=[BPF filter expression]:filter' \
  '--input-raw-expire=[wait time for last TCP packet]:duration' \
  '--input-raw-realip-header=[inject header with real IP value]:header' \
  '--input-raw-allow-incomplete[record HTTP messages with missing packets]' \
  '--input-raw-promisc[enable promiscuous mode]' \
  '--input-file=[read requests from file]:file:_files' \
  '--input-file-loop[loop input files]' \
  '--input-file-dry-run[simulate reading without replaying]' \
  '--input-tcp=[internal communication between Gor instances]:addr' \
  '--input-dummy=[emit a Get request every 1s for testing]:value' \
  '--output-http=[forward incoming requests to http address]:url' \
  '--output-http-workers=[maximum number of workers]:n' \
  '--output-http-workers-min=[minimum number of workers]:n' \
  '--output-http-timeout=[HTTP request/response timeout]:duration' \
  '--output-http-redirects=[how often redirects should be followed]:n' \
  '--output-http-track-response[set HTTP output responses to all outputs]' \
  '--output-http-skip-verify[do not verify hostname on TLS connection]' \
  '--output-http-elasticsearch=[send stats to ElasticSearch]:addr' \
  '--output-file=[write incoming requests to file]:file:_files' \
  '--output-file-append[append flushed chunk to existing file]' \
  '--output-file-size-limit=[size of each chunk]:size' \
  '--output-stdout[print data coming from inputs]' \
  '--output-null[drop all requests]' \
  '--output-tcp=[internal communication between Gor instances]:addr' \
  '--output-binary=[forward incoming binary payloads to address]:addr' \
  '--output-kafka-host=[send stats to Kafka]:host' \
  '--output-kafka-topic=[send stats to Kafka topic]:topic' \
  '--middleware=[modify traffic using external command]:command' \
  '--http-allow-url=[regexp to match requests, drop the rest]:regexp' \
  '--http-disallow-url=[regexp to match requests, forward the rest]:regexp' \
  '--http-allow-method=[whitelist of HTTP methods to replay]:method' \
  '--http-allow-header=[regexp to match a specific header]:header' \
  '--http-disallow-header=[regexp to match a header, drop matches]:header' \
  '--http-rewrite-url=[rewrite request url based on a mapping]:mapping' \
  '--http-set-header=[inject additional header to http request]:header' \
  '--http-set-param=[set request url param]:param' \
  '--http-original-host[preserve the original Host header]' \
  '--http-basic-auth-filter=[regexp to match decoded basic auth string]:regexp' \
  '--prettify-http[decode gzip and chunked encoded requests]' \
  '--split-output=[split traffic equally among all outputs]:bool:(true false)' \
  '--exit-after=[exit after specified duration]:duration' \
  '--stats[turn on queue stats output]' \
  '--verbose=[set the level of verbosity]:level' \
  '--http-pprof=[enable profiling http server on port]:addr' \
  '(- *)--help[show help]' \
  '*:arg:_files' && ret=0

return ret
