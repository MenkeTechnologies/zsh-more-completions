#compdef sct

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[set display]:display:' \
  '-s[set screen]:screen:' \
  '1:color temperature (K, e.g. 3700 for warm, 6500 for neutral):' && ret=0

return ret
