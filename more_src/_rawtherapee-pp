#compdef rawtherapee-pp
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# RawTherapee CLI (rawtherapee-cli aka pp suffix): raw photo processor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version and exit]' \
  '-c[input files (use trailing -c FILES)]:files:_files' \
  '-Y[overwrite output files]' \
  '-o[output directory or file]:path:_files -/' \
  '-O[output dir with same names]:dir:_files -/' \
  '-d[use default profile]' \
  '-s[use sidecar .pp3 next to input]' \
  '-S[skip files w/o sidecar .pp3]' \
  '-p[apply pp3 profile]:profile:_files -g "*.pp3"' \
  '-j[JPEG output (quality 92 default)]:quality 1-100:' \
  '-js[JPEG subsampling]:val:(1 2 3)' \
  '-b8[8-bit TIFF/PNG]' \
  '-b16[16-bit TIFF/PNG]' \
  '-b16f[16-bit floating-point TIFF]' \
  '-b32[32-bit floating-point TIFF]' \
  '-t[uncompressed TIFF]' \
  '-tz[ZIP-compressed TIFF]' \
  '-n[PNG output (compression 6 default)]:compression 0-9:' \
  '*:raw files:_files -g "*.(cr2|cr3|nef|arw|raf|orf|dng|rw2|pef|srw|3fr|fff|iiq|x3f|mrw|mef|kdc|dcr|mos|raw|nrw|raw)"' && ret=0
return ret
