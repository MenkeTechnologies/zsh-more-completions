#compdef shunit2
# Documentation: https://github.com/kward/shunit2
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above. Invocation forms:
#   shunit2 test-script.sh [testName ...]
#   test-script.sh -- [testName ...] [--output-junit-xml=FILE] [--suite-name=NAME]

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--output-junit-xml=[write JUnit XML to FILE]:file:_files' \
  '--suite-name=[JUnit suite name]:name' \
  '1:test script:_files -g "*.sh(-.)"' \
  '*:test name:' && ret=0

return ret
