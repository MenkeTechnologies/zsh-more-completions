#compdef buf-cli
# _buf-cli — Buf Build buf modern protobuf toolchain CLI alias (Buf Build, Go); spf13/cobra
# upstream: https://github.com/bufbuild/buf

_buf-cli() {
    local -a sub=(
        'beta:beta commands'
        'breaking:detect breaking schema changes'
        'build:build into binary image'
        'config:manage buf config'
        'curl:make curl-like request through buf'
        'dep:dependency commands'
        'export:export images and files'
        'format:format proto files'
        'generate:generate language stubs'
        'lint:lint proto files'
        'lsp:run Buf Language Server'
        'ls-files:list files'
        'lsfiles:list files (alias)'
        'mod:module commands'
        'plugin:plugin commands'
        'push:push to BSR'
        'pull:pull from BSR'
        'registry:BSR registry commands'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--log-format=+[log format]:fmt:(text color json)' \
        '--timeout=+[network timeout]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'buf subcommand' sub ;;
        args)
            case $words[1] in
                lint|format|breaking|build|generate|push|export) _arguments \
                    '--config=+[config file]:file:_files -g "buf.yaml *.yaml *.yml"' \
                    '--path=+[paths]:list:_files' \
                    '--exclude-path=+[exclude paths]:list:_files' \
                    '--disable-symlinks[disable symlinks]' \
                    '--error-format=+[error format]:fmt:(text json text-vim text-emacs github-actions junit)' \
                    '--against=+[against]:str:' \
                    '--against-config=+[against config]:file:_files' \
                    '--diff[diff]' \
                    '-d[diff]' \
                    '--write[write]' \
                    '-w[write]' \
                    '--exit-code[exit code]' \
                    '--template=+[template]:str:' \
                    '--template-file=+[template file]:file:_files' \
                    '--output=+[output dir/file]:str:' \
                    '-o+[output dir/file]:str:' \
                    '*:input:_files' ;;
                mod) _arguments \
                    '1:cmd:(clear-cache init prune update)' \
                    '*:arg:' ;;
                dep) _arguments \
                    '1:cmd:(add list prune update)' \
                    '*:arg:' ;;
                registry) _arguments \
                    '1:cmd:(login logout whoami)' \
                    '*:arg:' ;;
                plugin) _arguments \
                    '1:cmd:(prune update)' \
                    '*:arg:' ;;
                curl) _arguments \
                    '--data=+[data]:str:' \
                    '-d+[data]:str:' \
                    '--header=+[header]:list:' \
                    '-H+[header]:list:' \
                    '--protocol=+[protocol]:p:(grpc grpcweb connect)' \
                    '--http2-prior-knowledge[http2 prior knowledge]' \
                    '--schema=+[schema]:str:' \
                    '*:url:_urls' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_buf-cli "$@"
