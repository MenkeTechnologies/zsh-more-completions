#compdef kmidiff
# Documentation: https://sourceware.org/libabigail/manual/kmidiff.html
# libabigail tool to compare the Kernel Module Interfaces of two Linux kernel trees

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[enable verbose logging]' \
  '--debug-info-dir1[first debug info directory]:dir:_files -/' \
  '--debug-info-dir2[second debug info directory]:dir:_files -/' \
  '--vmlinux1[first vmlinux binary]:file:_files' \
  '--vmlinux2[second vmlinux binary]:file:_files' \
  '(-w --kmi-whitelist)'{-w,--kmi-whitelist}'[kernel module interface whitelist]:file:_files' \
  '*--suppressions[suppression specification file]:file:_files' \
  '(-x --no-change-categorization)'{-x,--no-change-categorization}'[do not categorize changes]' \
  '--ctf[read ABI from CTF debug info]' \
  '--btf[read ABI from BTF debug info]' \
  '(-i --impacted-interfaces)'{-i,--impacted-interfaces}'[show impacted interfaces]' \
  '(-f --full-impact)'{-f,--full-impact}'[emit a full impact report]' \
  '--exported-interfaces-only[consider only exported interfaces]' \
  '--allow-non-exported-interfaces[consider non-exported interfaces too]' \
  '--show-bytes[show sizes in bytes]' \
  '--show-bits[show sizes in bits]' \
  '--show-hex[show numerical values in hexadecimal]' \
  '--show-dec[show numerical values in decimal]' \
  '*:dir:_files -/' && ret=0

return ret
