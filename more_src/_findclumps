#compdef findclumps
# Documentation: https://starlink.eao.hawaii.edu/docs/sun255.htx/sun255ss5.html
# CUPID: identify clumps of emission within a 1, 2 or 3 dimensional NDF.

local ret=1

_arguments -s -S \
  'IN=[input NDF to analyse]:ndf:_files' \
  'OUT=[output NDF with clump info]:ndf:_files' \
  'OUTCAT=[output clump catalogue]:cat:_files' \
  'METHOD=[algorithm]:method:(GaussClumps ClumpFind Reinhold FellWalker)' \
  'CONFIG=[configuration parameters]:config:_files' \
  'RMS=[global RMS noise level]:rms:' \
  'BACKOFF=[remove background before sizing]:flag:(TRUE FALSE)' \
  'DECONV=[correct for beam width]:flag:(TRUE FALSE)' \
  'WCSPAR=[use WCS coords in output]:flag:(TRUE FALSE)' \
  'QOUT=[output quality NDF]:ndf:_files' \
  'JSACAT=[JSA-style FITS catalogue]:cat:_files' \
  'SHAPE=[catalogue shape]:shape:(Polygon Ellipse Ellipse2 Ellipse3 None)' \
  'PERSPECTRUM=[process 3D spectra independently]:flag:(TRUE FALSE)' \
  'NCLUMPS=[output number of clumps]:n:' \
  'LOGFILE=[text log file]:file:_files' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  'REPCONF=[list config params to stdout]:flag:(TRUE FALSE)' \
  '*:ndf:_files' && ret=0

return ret
