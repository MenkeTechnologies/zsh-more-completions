# https://github.com/j178/leetgo — cobra (cmd/root.go initCommands)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[detailed build/version]' \
  '(-l --lang)'{-l,--lang}'=-[code language slug]:lang:' \
  '--site=-[LeetCode region]:site:(cn us)' \
  '(-y --yes)'{-y,--yes}'[assume yes]' \
  '1:command:(init pick info test submit fix edit contest cache debug open help)' \
  '*::arguments:_default'
