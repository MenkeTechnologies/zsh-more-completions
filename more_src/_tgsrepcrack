#compdef tgsrepcrack.py tgsrepcrack
# Documentation: https://github.com/nidem/kerberoast/blob/master/tgsrepcrack.py
# tgsrepcrack — crack Kerberos TGS-REP (.kirbi) tickets with a wordlist. Args from argparse metavars.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:wordlist (dictionary.txt):_files' \
  '*:kirbi ticket file(s) (file.kirbi):_files -g "*.kirbi"' \
  && ret=0

return ret
