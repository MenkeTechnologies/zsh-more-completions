#compdef cargo-vendor-filterer
# Documentation: https://github.com/coreos/cargo-vendor-filterer
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# cargo-vendor-filterer: like `cargo vendor` but supports filtering by target
# platform, dependency kind, glob path exclusion and archive output formats.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--help[display complete flag documentation]' \
  '*--platform=[filter crates by rustc target triple]:triple:' \
  '*--tier=[filter by platform tier level]:tier:(1 2)' \
  '--all-features[enable all features when vendoring]' \
  '*--keep-dep-kinds=[dependency kinds to retain]:kind:(all normal build dev no-normal no-build no-dev)' \
  '*--exclude-crate-paths=[remove files/dirs matching glob pattern]:pattern:' \
  '--format=[output archive format]:format:(tar.zstd tar.gz tar)' \
  '--prefix=[archive root directory name]:name:' \
  '*::path:_files -/' && ret=0

return ret
