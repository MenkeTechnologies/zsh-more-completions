#compdef wbg
# _wbg — simple wallpaper for Wayland layer-shell compositors (dnkl/wbg)
# upstream: https://codeberg.org/dnkl/wbg
# Flags from main.c (getopt_long).

_wbg() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-s --stretch)'{-s,--stretch}'[stretch image instead of scale-to-fit]' \
        '*:image file:_files -g "*.{png,jpg,jpeg,webp,jxl,svg}"'
}

_wbg "$@"
