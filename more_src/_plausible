#compdef plausible
# _plausible — CLI for Plausible Analytics Plugins/Stats APIs (queso/plausible-cli)
# upstream: https://github.com/queso/plausible-cli
# Subcommands from cmd/ (cobra).

_plausible() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--json[output raw JSON]' \
        '--verbose[verbose output]' \
        '--config=[config file]:file:_files' \
        '--base-url=[API base URL]:url:' \
        '--no-color[disable color output]' \
        '--domain=[site domain]:domain:' \
        '--token=[Plugins API token]:token:' \
        '--stats-token=[Stats API token]:token:' \
        '--profile=[named profile from config]:profile:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'goals:manage goals'
                'funnels:manage funnels'
                'shared-links:manage shared links'
                'custom-props:manage custom properties'
                'capabilities:list site capabilities'
                'tracker:tracker configuration'
                'stats:query the Stats API'
                'completion:generate shell completions'
                'help:show command help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                goals) _arguments '1:subcommand:(list create get delete delete-bulk)' ;;
                funnels) _arguments '1:subcommand:(list create get)' ;;
                shared-links) _arguments '1:subcommand:(list create)' ;;
                custom-props) _arguments '1:subcommand:(list enable disable)' ;;
                stats) _arguments '1:subcommand:(query)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_plausible "$@"
