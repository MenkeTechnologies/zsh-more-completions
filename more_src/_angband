#compdef angband

# Zsh completion for angband (roguelike dungeon exploration game)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-n[Start a new character]' \
  '-w[Display on this term]' \
  '-g[Request a specific graphics mode]' \
  '-u+[Specify a player name]:name' \
  '-d+[Override a specific path]:path spec' \
  '-s+[Show high scores]:number' \
  '-m+[Force a display module]:module:(x11 gcu sdl sdl2 win)' \
  '-f[Request fiddle (wizard) mode]' && ret=0

return ret
