#compdef pgpdisk2john pgpdisk2john.py
# Documentation: https://github.com/openwall/john/blob/bleeding-jumbo/run/pgpdisk2john.py
# pgpdisk2john (JtR) — extract hash from PGP Virtual Disk files. Usage: pgpdisk2john [PGP Virtual Disk .pgd file(s)].

local ret=1

_arguments -s -S \
  '*:PGP Virtual Disk file:_files -g "*.pgd"' \
  && ret=0

return ret
