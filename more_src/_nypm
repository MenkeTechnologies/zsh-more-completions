#compdef nypm
# ============================================================================
#  _nypm — nypm: Unified Package Manager wrapper for Node.js
#          (npm, pnpm, yarn, Bun, Deno) — auto-detects which
#          package manager a project uses and dispatches the
#          appropriate command (Pooya Parsa / UnJS / Nuxt team)
#
#  Source-direct extraction from
#    https://github.com/unjs/nypm/blob/main/src/cli.ts
#    https://github.com/unjs/citty (the citty library by Pooya
#    Parsa — UnJS / Nuxt team's CLI framework)
#
#  Maintained by Pooya "pi0" Parsa (Nuxt core lead, UnJS founder).
#  679 GH stars.  nypm is a UNIFIED PACKAGE MANAGER for Node.js —
#  one CLI that AUTO-DETECTS whether a project uses npm, pnpm,
#  yarn, Bun, or Deno and dispatches the equivalent command.  Uses
#  package.json `packageManager` field, lockfile presence (package-
#  lock.json / pnpm-lock.yaml / yarn.lock / bun.lockb / deno.lock),
#  and corepack settings to pick the right tool.  Solves the
#  "I need to install pkg X but I don't remember which package
#  manager this project uses" problem.  Used internally by the
#  ENTIRE UnJS/Nuxt ecosystem — nuxi (Nuxt CLI), nuxt-module-builder,
#  giget (template downloader), and dozens of UnJS packages call
#  nypm to invoke the right pm at runtime.  Sister tools: npm
#  (in corpus via _npm + STOCK), pnpm (in corpus via _pnpm), yarn
#  (in corpus via _yarn + STOCK), bun (in corpus via _bun), deno
#  (in corpus via _deno), corepack (Node Corepack — manages pm
#  versions via packageManager field), nu (Nu shell — in corpus
#  via _nu), antfu/ni (the ORIGINAL "use the right pm" wrapper by
#  Anthony Fu — also in corpus via _ni).
#
#  CLI library taxonomy update: 12th TypeScript/Node CLI library —
#  Pooya Parsa's **citty** (unjs/citty).  TypeScript-Node ecosystem
#  now has 12 documented CLI libraries — TYING WITH RUST AND GO at
#  the top of the cross-language taxonomy in a THREE-WAY TIE at 12
#  each.  🎉 TypeScript-Node CATCHES UP again — restoring three-
#  way parity (Rust=12, Go=12, TypeScript-Node=12).
#
#  citty (unjs/citty) is Pooya Parsa's ELEGANT CLI BUILDER — a
#  TypeScript-first CLI framework with a `defineCommand` factory
#  function and an `args` SCHEMA OBJECT that supports STRING /
#  BOOLEAN / POSITIONAL / ENUM types with REQUIRED / DEFAULT /
#  ALIAS / DESCRIPTION metadata.  1,260 GH stars.  Distinguishing
#  features: TYPESCRIPT-FIRST (full type inference from args schema
#  to handler's `args` parameter) + DECLARATIVE schema (no
#  chained-builder method calls; `args: { foo: { type: 'string',
#  ... } }` object) + NESTED SUBCOMMANDS via `subCommands` property
#  (each subcommand is itself a CommandDef — recursive structure) +
#  ALIASES via `subCommands: { install, i: install, add: install }`
#  shared-reference pattern + `runMain()` convenience entry +
#  ZERO RUNTIME DEPENDENCIES (uses scule/string-utils only).  Used
#  by ALL of unjs's tooling: nuxi (Nuxt CLI — IN CORPUS via _nuxi),
#  nitro (Nuxt's Nitro server toolkit 10876 stars — IN CORPUS via
#  _nitro), nypm (679 stars), giget (template downloader 731 stars
#  — IN CORPUS via _giget), unhead, nuxt/cli, nuxt/module-builder,
#  nuxt/telemetry, jiti (TypeScript runtime 2856 stars), and many
#  other UnJS/Nuxt packages.  Also used outside the UnJS ecosystem
#  by CorentinTh/enclosed (Enclosed CLI), olistic/warriorjs (Warrior
#  JS), modiimedia/arri (Arri RPC), comfy-addons/comfy-station, and
#  others.
#
#  citty API:
#    import { defineCommand, runMain, type ArgsDef } from 'citty'
#
#    // SHARED args definition with `satisfies ArgsDef` for type safety
#    const operationArgs = {
#      cwd: {
#        type: 'string',
#        description: 'Current working directory',
#      },
#      workspace: {
#        type: 'boolean',
#        description: 'Add to workspace',
#      },
#      corepack: {
#        type: 'boolean',
#        default: true,
#        description: 'Use corepack',
#      },
#      dry: {
#        type: 'boolean',
#        description: 'Run in dry mode (does not execute)',
#      },
#    } as const satisfies ArgsDef;
#
#    const install = defineCommand({
#      meta: {
#        description: 'Install dependencies',
#      },
#      args: {
#        ...operationArgs,                  // spread shared args
#        name: {
#          type: 'positional',              // POSITIONAL value
#          description: 'Dependency name',
#          required: false,
#        },
#        dev: {
#          type: 'boolean',
#          alias: 'D',                      // -D short alias
#          description: 'Add as dev dependency',
#        },
#      },
#      run: async ({ args }) => {
#        // args.name (positional), args.dev (boolean), etc.
#        // args._ contains all positionals as array
#      },
#    });
#
#    const main = defineCommand({
#      meta: {
#        name: 'nypm',
#        version: '1.0.0',
#        description: 'Unified Package Manager',
#      },
#      subCommands: {
#        install,
#        i: install,                        // ALIAS: same reference
#        add: install,                      // ALIAS: same reference
#        remove,
#        rm: remove,
#      },
#    });
#
#    runMain(main);                         // entry point — parses
#                                           // process.argv, runs
#                                           // matched command
#
#  citty distinctive features:
#    - `defineCommand({ meta, args, subCommands, run })` factory —
#      returns CommandDef object with type-inferred handler
#    - `meta: { name, version, description, hidden }` — command
#      metadata used for auto-help generation
#    - `args` SCHEMA OBJECT with per-arg `{ type, description,
#      default, alias, required, valueHint }` config — DECLARATIVE,
#      not chained-builder
#    - `type: 'string'` — string-valued flag (--name value)
#    - `type: 'boolean'` — boolean flag (--flag, no value)
#    - `type: 'positional'` — POSITIONAL arg (consumed by position
#      from process.argv._)
#    - `type: 'enum'` — choice flag with `options: [...]` list
#    - `alias: 'D'` or `alias: ['D', 'd']` — short flag alias(es)
#    - `default: value` — default applied if not provided
#    - `required: true` — error if not provided
#    - `valueHint: 'NAME'` — placeholder shown in --help
#    - `subCommands: { name: CommandDef, alias: ref }` — nested
#      command tree; aliases just reference the same CommandDef
#    - `run: async ({ args, rawArgs, cmd }) => ...` — async handler
#      receiving PARSED args (with full TypeScript inference from
#      schema), `rawArgs` (process.argv.slice), and `cmd` (parent
#      CommandDef)
#    - `runMain(cmd)` — runs the command tree against process.argv,
#      auto-detects --help/--version, prints AUTO-GENERATED USAGE
#      on error
#    - `runCommand(cmd, opts)` — programmatic entry (useful for
#      testing or composing CLIs)
#    - `parseArgs(args, schema)` — pure parser exposed (used by
#      olistic/warriorjs etc. for custom parsing without runMain)
#    - `createMain(cmd)` — returns a function that calls runMain
#      (used by nuxt/telemetry pattern)
#    - AUTO --help / --version generation from `meta` + `args`
#      schema; no manual usage strings
#    - TYPESCRIPT TYPE INFERENCE from args schema to handler — IDE
#      autocomplete on `args.foo` after defining `foo: { type:
#      'string' }`
#    - ZERO RUNTIME DEPENDENCIES (uses scule string-utils only)
#  Distinct from R236 commander (TJ Holowaychuk builder-with-
#  subcommand-tree — Vue CLI/jest/ngx), R237 oclif (Heroku/
#  Salesforce enterprise CLI framework with plugin discovery),
#  yargs (Bash-style yargs-parser framework — npm/jest), R398 meow
#  (Sindre Sorhus zero-config flag parser using minimist), R399
#  substack/minimist (the ORIGINAL micro-arg-parser), R400 cac
#  (Anthony Fu — uses mri internally), R403 clipanion (Yarn's
#  class-based CLI framework with `@Command()` decorators), R406
#  vercel/arg (spec-object schema with built-in type coercion
#  functions), R409 mri (lukeed minimal parser — what cac/sade use
#  internally).  TypeScript-Node documented libraries so far:
#  commander, oclif, yargs, meow, minimist, cac, clipanion, arg,
#  mri, sade, gluegun-ish... and now citty makes 12.  citty's
#  approach: TYPESCRIPT-FIRST DECLARATIVE schema with
#  `defineCommand({meta, args, subCommands, run})` factory + `args`
#  object schema with `{type/description/default/alias/required/
#  valueHint}` per-arg config + `type: 'string'/'boolean'/
#  'positional'/'enum'` types + nested `subCommands` with alias
#  shared-reference pattern + `runMain(cmd)` entry + TYPESCRIPT TYPE
#  INFERENCE from schema to handler + AUTO --help/--version + zero
#  runtime dependencies — corpus's **first documented TypeScript-
#  first declarative-schema TypeScript-Node CLI library**.  Brings
#  cross-language CLI library taxonomy variant count to 151;
#  TypeScript-Node ecosystem now has 12 documented CLI libraries —
#  TYING WITH RUST AND GO at the top of the cross-language taxonomy
#  in a THREE-WAY TIE at 12.
#
#  Surface (verbatim from `src/cli.ts` citty subCommands):
#
#  Usage:
#    nypm <subcommand> [options] [name]
#
#  Subcommands:
#    install (i, add)               Install dependencies (or add a
#                                   single dep if NAME given)
#    remove (rm, uninstall, un)     Remove dependencies
#    detect                         Detect the current package
#                                   manager (prints name@version)
#    dedupe                         Dedupe dependencies
#    run                            Run a package.json script
#
#  Shared operation options (install/remove/run):
#        --cwd <DIR>                Current working directory
#        --workspace                Add to workspace
#        --silent                   Run in silent mode
#        --corepack                 Use corepack (Default: true)
#        --dry                      Run in dry run mode (does not
#                                   execute commands — just prints
#                                   the resolved pm command)
#
#  install/i/add options:
#    -D, --dev                      Add as dev dependency
#    -g, --global                   Add globally
#        --frozen-lockfile          Install dependencies with frozen
#                                   lock file (CI mode)
#        --install-peer-dependencies   Also install peer dependencies
#
#  dedupe options:
#        --cwd <DIR>                Working directory
#        --silent                   Silent mode
#        --recreateLockFile         Recreate lock file
#
#  detect options:
#        --cwd <DIR>                Working directory to detect in
#
#  Meta:
#        --help                     Auto-generated help (from citty)
#        --version                  Show version (from pkg.json
#                                   meta.version)
#
#  Examples:
#    nypm install                                       # Install all deps in CWD
#    nypm i lodash                                      # Install lodash dep
#    nypm add -D vitest                                 # Add vitest as dev dep
#    nypm install -g pnpm                               # Install pnpm globally
#    nypm install --frozen-lockfile                     # CI install (no lockfile updates)
#    nypm install --install-peer-dependencies           # Install peers too
#    nypm remove lodash                                 # Remove dep
#    nypm rm -g typescript                              # Remove global
#    nypm detect                                        # Print "Detected package manager in '/path': npm@10.x"
#    nypm detect --cwd /path/to/project                 # Detect in specific dir
#    nypm dedupe                                        # Dedupe deps
#    nypm dedupe --recreateLockFile                     # Recreate lockfile from scratch
#    nypm run build                                     # Run build script
#    nypm install --dry lodash                          # Print "npm install lodash" without executing
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also citty users):
#    - nuxi (IN CORPUS via _nuxi — Nuxt's official CLI; the
#      FLAGSHIP citty user; already documented)
#    - nitro (IN CORPUS via _nitro — Nuxt's Nitro server toolkit
#      10876 stars; uses citty)
#    - giget (IN CORPUS via _giget — UnJS template downloader 731
#      stars; uses citty)
#    - nuxt (IN CORPUS via _nuxt — Nuxt framework)
#    - unhead (UnJS HTML head manager; CLI subcommands use citty;
#      FUTURE candidate)
#    - jiti (UnJS TypeScript runtime 2856 stars — uses citty in
#      jiti's CLI; FUTURE candidate but minimal CLI surface)
#    - arri (modiimedia/arri RPC framework; uses citty;
#      multi-component, FUTURE candidate)
#    - enclosed (CorentinTh/enclosed — encrypted notes; uses citty)
# ============================================================================

_nypm() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '--help[show auto-generated help]' \
    '--version[show version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'install:install dependencies'
        'i:install dependencies (alias)'
        'add:install dependencies (alias)'
        'remove:remove dependencies'
        'rm:remove dependencies (alias)'
        'uninstall:remove dependencies (alias)'
        'un:remove dependencies (alias)'
        'detect:detect the current package manager'
        'dedupe:dedupe dependencies'
        'run:run a package.json script'
      )
      _describe -t subcommands 'nypm subcommand' subcmds
      ;;
    args)
      local -a shared_args install_args dedupe_args
      shared_args=(
        '--cwd[current working directory]:dir:_directories'
        '--workspace[add to workspace]'
        '--silent[run in silent mode]'
        '--corepack[use corepack]'
        '--dry[run in dry run mode (does not execute commands)]'
      )
      install_args=(
        '(-D --dev)'{-D,--dev}'[add as dev dependency]'
        '(-g --global)'{-g,--global}'[add globally]'
        '--frozen-lockfile[install dependencies with frozen lock file]'
        '--install-peer-dependencies[also install peer dependencies]'
      )
      dedupe_args=(
        '--cwd[current working directory]:dir:_directories'
        '--silent[run in silent mode]'
        '--recreateLockFile[recreate lock file]'
      )

      case "${words[1]}" in
        install|i|add)
          _arguments -s -S "${shared_args[@]}" "${install_args[@]}" \
            '*:dependency:'
          ;;
        remove|rm|uninstall|un)
          _arguments -s -S "${shared_args[@]}" \
            '*:dependency:'
          ;;
        detect)
          _arguments -s -S \
            '--cwd[current working directory]:dir:_directories'
          ;;
        dedupe)
          _arguments -s -S "${dedupe_args[@]}"
          ;;
        run)
          _arguments -s -S "${shared_args[@]}" \
            ':script:' \
            '*:: :->script_args'
          ;;
      esac
      ;;
  esac
}

_nypm "$@"
