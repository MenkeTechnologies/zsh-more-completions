#compdef cargo-modules

_cargo-modules_subcommands() {
  local -a subcmds=(
    'generate:Generate a visualization of the module tree'
    'orphans:Find orphaned modules'
    'structure:Show the module structure'
    'dependencies:Show module dependencies'
  )
  _describe -t commands 'cargo-modules subcommand' subcmds
}

_cargo-modules() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '1:subcommand:_cargo-modules_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        generate)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
            {-p,--package}'[Package to analyze]:package:' \
            '--lib[Analyze library target]' \
            '--bin[Analyze binary target]:name:' \
            '--no-fns[Hide functions]' \
            '--no-traits[Hide traits]' \
            '--no-types[Hide types]' \
            '--no-externs[Hide extern crate items]' \
            '--no-uses[Hide use items]' \
            '--no-sysroot[Do not include sysroot modules]' \
            '--cfg-test[Include test configuration]' \
            '--with-orphans[Include orphaned modules]' \
            '--with-tests[Include test modules]' \
            '--with-types[Include type nodes]' \
            '--layout[Layout algorithm]:layout:(dot neato twopi circo fdp sfdp)' \
            '--focus-on[Focus on a specific module]:module:'
          ;;
        orphans)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
            {-p,--package}'[Package to analyze]:package:' \
            '--lib[Analyze library target]' \
            '--bin[Analyze binary target]:name:' \
            '--cfg-test[Include test configuration]' \
            '--deny[Exit with error if orphans found]'
          ;;
        structure)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
            {-p,--package}'[Package to analyze]:package:' \
            '--lib[Analyze library target]' \
            '--bin[Analyze binary target]:name:' \
            '--no-fns[Hide functions]' \
            '--no-traits[Hide traits]' \
            '--no-types[Hide types]' \
            '--with-orphans[Include orphaned modules]' \
            '--with-tests[Include test modules]'
          ;;
      esac
      ;;
  esac
}

_cargo-modules "$@"
