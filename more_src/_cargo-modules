#compdef cargo-modules
# Documentation: https://github.com/regexident/cargo-modules (src/options.rs + src/command.rs clap)
# Reference accessed: 2026-05-29
# cargo-modules — visualize a Rust crate's module structure, dependencies, or orphaned files.
# Three subcommands: structure (tree), dependencies (graph for xdot), orphans (unlinked files).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'structure:print crate hierarchical structure as a tree'
  'dependencies:print crate internal dependencies as a graph (pipe to xdot)'
  'orphans:detect unlinked source files within a crate'
)

# ProjectOptions shared across all subcommands.
local -a _project
_project=(
  '(--lib --bin)--lib[analyze library target]'
  '(--lib --bin)--bin=[analyze a specific binary target]:name:'
  '(-p --package)'{-p,--package=}'[package to analyze]:package:'
  '--no-default-features[disable default features]'
  '--all-features[activate all features]'
  '*--features=[feature to activate (repeatable)]:feature:'
  '--target=[target triple]:target:'
  '--manifest-path=[path to Cargo.toml (default ".")]:file:_files -g "Cargo.toml"'
)

# GeneralOptions shared across all subcommands.
local -a _general
_general=(
  '--verbose[verbose output]'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'cargo-modules subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      structure)
        _arguments \
          $_project \
          $_general \
          '--cfg-test[include test configuration]' \
          '--with-orphans[include orphaned modules]' \
          '--with-tests[include test modules]' \
          '--with-types[include type nodes]' \
          '--no-fns[hide functions]' \
          '--no-traits[hide traits]' \
          '--no-types[hide types]' \
          '--sort-by=[sort order]:order:(name visibility kind)' \
          '--max-depth=[max module depth]:N:' \
          '--focus-on=[focus on a specific module]:module:' && ret=0
        ;;
      dependencies)
        _arguments \
          $_project \
          $_general \
          '--cfg-test[include test configuration]' \
          '--no-externs[hide extern crate items]' \
          '--no-sysroot[do not include sysroot modules]' \
          '--no-uses[hide use items]' \
          '--no-fns[hide functions]' \
          '--no-traits[hide traits]' \
          '--no-types[hide types]' \
          '--acyclic[require acyclic dependency graph]' \
          '--with-orphans[include orphaned modules]' \
          '--with-tests[include test modules]' \
          '--with-types[include type nodes]' \
          '--layout=[Graphviz layout algorithm]:layout:(dot neato twopi circo fdp sfdp)' \
          '--focus-on=[focus on a specific module]:module:' \
          '--max-depth=[max module depth]:N:' && ret=0
        ;;
      orphans)
        _arguments \
          $_project \
          $_general \
          '--cfg-test[include test configuration]' \
          '--deny[exit non-zero if any orphans are found]' && ret=0
        ;;
    esac
    ;;
esac

return ret
