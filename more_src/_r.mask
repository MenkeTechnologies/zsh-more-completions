#compdef r.mask
# Documentation: https://grass.osgeo.org/grass-stable/manuals/r.mask.html
# Creates a raster mask for limiting raster operation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[create inverse mask]' \
  '-r[remove existing mask]' \
  '--overwrite[allow output files to overwrite existing files]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  'raster=[name of raster map to use as mask]:raster:' \
  'vector=[name of vector map to use as mask]:vector:' \
  'maskcats=[raster values to use for mask]:maskcats:' \
  'layer=[layer number or name for vector features]:layer:' \
  'cats=[category values for vector]:cats:' \
  'where=[SQL WHERE conditions for vector]:where:' \
  '*:param:' && ret=0

return ret
