#compdef geth

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'account:manage accounts'
  'attach:attach to running node JS console'
  'console:start node and JS console'
  'db:low level database operations'
  'dump:dump a specific block from storage'
  'dumpconfig:export configuration values in TOML'
  'dumpgenesis:dump genesis block JSON'
  'export:export blockchain into file'
  'export-history:export blockchain history to Era archives'
  'import:import a blockchain file'
  'import-history:import an Era archive'
  'import-preimages:import preimage database'
  'init:bootstrap and initialize a new genesis block'
  'js:execute JavaScript files (deprecated)'
  'license:display license information'
  'prune-history:prune block bodies and receipts'
  'removedb:remove blockchain and state databases'
  'show-deprecated-flags:show deprecated flags'
  'snapshot:snapshot-based commands'
  'verkle:experimental verkle tree management'
  'version:print version numbers'
  'version-check:check for known security vulnerabilities'
  'wallet:manage Ethereum presale wallets'
  'help:show command help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--datadir=[data directory]:dir:_files -/' \
  '--config=[TOML config file]:file:_files' \
  '--keystore=[keystore directory]:dir:_files -/' \
  '--password=[password file]:file:_files' \
  '--networkid=[network identifier]:n:' \
  '--syncmode=[sync mode]:mode:(snap full)' \
  '--snapshot[enable snapshot]' \
  '--db.engine=[database engine]:engine:(leveldb pebble)' \
  '--http[enable HTTP RPC]' \
  '--http.addr=[HTTP RPC address]:addr:' \
  '--http.port=[HTTP RPC port]:port:' \
  '--http.api=[HTTP RPC APIs]:apis:' \
  '--http.corsdomain=[CORS domains]:domains:' \
  '--ws[enable WebSocket RPC]' \
  '--ws.addr=[WebSocket RPC address]:addr:' \
  '--ws.port=[WebSocket RPC port]:port:' \
  '--ws.api=[WebSocket RPC APIs]:apis:' \
  '--ipcdisable[disable IPC]' \
  '--ipcpath=[IPC path]:file:_files' \
  '--graphql[enable GraphQL]' \
  '--authrpc.addr=[auth RPC addr]:addr:' \
  '--authrpc.port=[auth RPC port]:port:' \
  '--authrpc.jwtsecret=[JWT secret]:file:_files' \
  '--authrpc.vhosts=[auth RPC vhosts]:vhosts:' \
  '--rpc.allow-unprotected-txs[allow unprotected txs]' \
  '--rpc.gascap=[gas cap]:n:' \
  '--rpc.txfeecap=[tx fee cap]:n:' \
  '--rpc.batch-request-limit=[batch request limit]:n:' \
  '--rpc.batch-response-max-size=[batch response max size]:n:' \
  '--rpc.evmtimeout=[EVM execution timeout]:duration:' \
  '--exec=[execute JS statement]:stmt:' \
  '--preload=[preload JS files]:files:' \
  '--jspath=[JS path]:dir:_files -/' \
  '--dev[ephemeral dev chain]' \
  '--dev.gaslimit=[dev gas limit]:n:' \
  '--dev.period=[dev block period]:secs:' \
  '--bootnodes=[bootstrap nodes]:enode:' \
  '--maxpeers=[max peers]:n:' \
  '--port=[network listening port]:port:' \
  '--nat=[NAT mapping]:nat:(any none upnp pmp extip stun)' \
  '--nodekey=[nodekey file]:file:_files' \
  '--identity=[node identity]:name:' \
  '--ethstats=[ethstats reporting]:url:' \
  '--metrics[enable metrics]' \
  '--metrics.addr=[metrics addr]:addr:' \
  '--metrics.port=[metrics port]:port:' \
  '--metrics.expensive[enable expensive metrics]' \
  '--metrics.influxdb[enable InfluxDB reporting]' \
  '--metrics.influxdb.endpoint=[InfluxDB endpoint]:url:' \
  '--metrics.influxdb.username=[InfluxDB user]:user:_users' \
  '--metrics.influxdb.password=[InfluxDB password]:password:' \
  '--miner.gaslimit=[miner gas limit]:n:' \
  '--miner.gasprice=[miner gas price]:n:' \
  '--miner.recommit=[miner recommit interval]:duration:' \
  '--miner.extradata=[miner extra data]:data:' \
  '--gcmode=[GC mode]:mode:(full archive)' \
  '--state.scheme=[state scheme]:scheme:(hash path)' \
  '--gpo.blocks=[GPO blocks]:n:' \
  '--gpo.percentile=[GPO percentile]:n:' \
  '--gpo.maxprice=[GPO max price]:n:' \
  '--gpo.ignoreprice=[GPO ignore price]:n:' \
  '--cache=[cache size MB]:n:' \
  '--cache.database=[database cache pct]:n:' \
  '--cache.trie=[trie cache pct]:n:' \
  '--cache.gc=[GC cache pct]:n:' \
  '--cache.snapshot=[snapshot cache pct]:n:' \
  '--cache.preimages[cache preimages]' \
  '--fdlimit=[file descriptor limit]:n:' \
  '--vmdebug[enable EVM debugging]' \
  '--vmtrace=[EVM trace mode]:mode:' \
  '--verbosity=[log verbosity]:n:(0 1 2 3 4 5)' \
  '--log.format=[log format]:format:(logfmt json terminal)' \
  '--log.file=[log file]:file:_files' \
  '--log.compress[compress log files]' \
  '--log.maxsize=[log max size]:n:' \
  '--log.maxbackups=[log max backups]:n:' \
  '--log.maxage=[log max age]:n:' \
  '--log.rotate[rotate log files]' \
  '--log.vmodule=[log vmodule]:spec:' \
  '--pprof[enable pprof]' \
  '--pprof.addr=[pprof addr]:addr:' \
  '--pprof.port=[pprof port]:port:' \
  '--pprof.memprofilerate=[mem profile rate]:n:' \
  '--pprof.blockprofilerate=[block profile rate]:n:' \
  '--pprof.cpuprofile=[cpu profile file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'geth subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (account)
        _values 'account action' \
          'list' 'new' 'update' 'import' && ret=0
        ;;
      (db)
        _values 'db action' \
          'inspect' 'inspect-history' 'stats' 'compact' 'get' 'put' 'delete' \
          'check-state-content' 'history' 'import' 'export' 'metadata' \
          'inspect-trie' 'verify-state' 'dump-trie-node' 'show-deleted-keys' && ret=0
        ;;
      (snapshot)
        _values 'snapshot action' \
          'prune-state' 'verify-state' 'check-dangling-storage' 'inspect-account' \
          'traverse-state' 'traverse-rawstate' 'dump' 'insecure-prune-all' && ret=0
        ;;
      (wallet)
        _values 'wallet action' 'import' && ret=0
        ;;
      (verkle)
        _values 'verkle action' \
          'verify' 'dump' 'chunk-code' && ret=0
        ;;
    esac
    ;;
esac

return ret
