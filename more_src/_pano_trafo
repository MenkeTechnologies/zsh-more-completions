#compdef pano_trafo
# Documentation: https://man.archlinux.org/man/pano_trafo.1.en
# pano_trafo: transform image<->panorama coordinates for a Hugin .pto project

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-r[reverse transformation: panorama coords to image coords]' \
  '*:pto file:_files -g "*.pto"' && ret=0

return ret
