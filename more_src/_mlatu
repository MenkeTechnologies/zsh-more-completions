#compdef mlatu
# =============================================================================
# mlatu — mlatu-lang/mlatu's "mlatu" programming
#   language — a DECLARATIVE + CONCATENATIVE
#   research language evaluated by TERM
#   REWRITING.  Programs are expressions built
#   by simple concatenation: the result of
#   `A B` is the concatenation of the
#   independent results of `A` and `B`.  Mlatu
#   is REFERENTIALLY TRANSPARENT — every
#   expression evaluates to the same normal
#   form regardless of the surrounding context
#   — and PURELY DECLARATIVE: programmers
#   write rewrite rules saying what *is*, not
#   what the implementation should *do*.
#   Implementation is Rust at the compiler /
#   editor frontend with an embedded Erlang
#   runtime driving parallel reduction.
#   Ships a structured-editor TUI for both
#   live REPL interaction and per-rule editing.
#   128th language entry in the corpus.
#
# 128TH LANGUAGE ENTRY — Mlatu closes the 3+1
# micro-cycle started after Axis 48 (NATS
# Messaging Client) closed at 1/1/1 three-
# language symmetry in R783 (TS-Node=103
# `_nats-claude-code-headless` on @nats-io/
# transport-node v3.4.0 + R782 Go=103
# `_choria` on nats-io/nats.go v1.52.0 +
# R781 Rust=103 `_arkflow` on async-nats v0.46).
#
# Distinguishing mlatu from the 127 prior
# corpus languages — closest neighbours and
# their differences:
#   - JOY / FACTOR / FORTH (`_factor`,
#     `_forth`, `_gforth`, `_pforth`): also
#     CONCATENATIVE.  Differences:
#       * Joy / Factor / Forth are IMPERATIVE
#         — primitives push/pop a stack and
#         have side-effects.  Mlatu is
#         DECLARATIVE — programs are
#         rewrite-rules in a term-rewriting
#         system; no stack mutation
#       * Joy / Factor / Forth evaluate left-
#         to-right by execution.  Mlatu
#         evaluates by NORMALIZATION — apply
#         rewrite rules until no more
#         reductions are possible, the
#         resulting term is the program's
#         meaning
#       * Joy / Factor have effects (I/O,
#         mutable state, conditionals as
#         control flow).  Mlatu has no
#         side effects — only equational
#         rules that define when one term
#         rewrites to another
#   - CAT (also concatenative + typed):
#     Cat by Christopher Diggins is
#     concatenative + statically typed +
#     imperative.  Mlatu is concatenative +
#     untyped (or rather: types are
#     defined-in-terms-of rewrite-rules,
#     not a separate type system) +
#     declarative
#   - WOLFRAM (`_wolfram`, `_wolframscript`):
#     ALSO a SYMBOLIC TERM REWRITER.
#     Differences:
#       * Wolfram is APPLICATIVE — function
#         application is written `f[x, y]`
#         with explicit head + arguments.
#         Mlatu is CONCATENATIVE — every
#         term is a sequence of words
#         glued by adjacency; no argument
#         positions
#       * Wolfram is proprietary; Mlatu is
#         open-source
#       * Wolfram's rules are pattern->expr
#         with conditionals + types
#         (`/;`, `_Integer`, etc.).  Mlatu's
#         rules are concatenative-pattern
#         -> concatenative-replacement
#   - EGEL (R780, `_egel`): closely
#     comparable!  Both are concurrent
#     (Egel via async/await, Mlatu via
#     embedded Erlang); both are term-
#     rewriting based.  Differences:
#       * Egel is APPLICATIVE (lambda +
#         pattern-matching).  Mlatu is
#         CONCATENATIVE
#       * Egel is EAGER.  Mlatu is normal-
#         order (reduce outermost first)
#       * Egel has mutable refs.  Mlatu is
#         purely declarative
#       * Egel uses GNU lightning JIT.
#         Mlatu uses the BEAM (Erlang VM)
#         for parallel reduction
#   - PROLOG (`_swipl`, `_prolog`): also
#     declarative.  Prolog is RESOLUTION-
#     BASED with SLD-resolution + unification.
#     Mlatu is REWRITING-BASED with term
#     normalization.  Prolog has cut + side
#     effects; Mlatu has neither
#   - MAUDE / OBJ family (academic term
#     rewriters): closest pure-research
#     analogue.  Maude is applicative
#     order-sorted rewriting; Mlatu is
#     concatenative untyped rewriting
#
# KEY MLATU LANGUAGE FEATURES:
#   - CONCATENATIVE — every program is a
#     sequence of words.  `A B C` means "the
#     result of A then concatenated with the
#     result of B then concatenated with the
#     result of C".  No parentheses, no
#     argument positions, no precedence
#     levels
#   - TERM REWRITING — programs are
#     evaluated by applying rewrite rules
#     until no rule matches.  Each rule has
#     the shape:
#       <PATTERN> = <REPLACEMENT>
#     where PATTERN and REPLACEMENT are
#     concatenative terms.  A rule matches
#     when the current term contains a
#     substring equal to PATTERN; the rule
#     fires by substituting REPLACEMENT
#   - DECLARATIVE — rules say "this IS that"
#     not "compute this from that".
#     Order of rule definitions does not
#     matter; if multiple rules apply, any
#     could fire.  Confluence is the
#     programmer's responsibility (mlatu
#     does not check the diamond property
#     automatically)
#   - REFERENTIAL TRANSPARENCY — same
#     subterm in different positions
#     evaluates to the same normal form.
#     Enables aggressive parallel reduction
#     (which the Erlang backend exploits
#     by farming out reductions to BEAM
#     processes)
#   - ERLANG-BACKED PARALLELISM — the
#     compiled rewrite engine sits in a
#     BEAM VM; independent subterm
#     reductions run as separate Erlang
#     processes.  Installation therefore
#     requires Rust + Erlang/OTP both on
#     PATH
#   - .ml RULE FILES — Mlatu source is
#     stored in `.ml` files containing
#     rule definitions, one per line (or
#     multi-line with explicit
#     continuations).  Files load via
#     positional arguments or
#     `:load` in the REPL
#   - .mlb BINARY RULE FILES — `mlatu
#     edit` compiles + saves the in-
#     editor rule set to a `.mlb` file
#     adjacent to the source `.ml`
#   - STRUCTURED EDITOR — `mlatu edit
#     <FILE>` opens a crossterm-based TUI
#     showing rules with both PATTERN and
#     REPLACEMENT sides editable
#     simultaneously.  Navigate between
#     rules + terms with arrow keys.
#     `Ctrl-W` saves to `.mlb`; `Esc`
#     exits.  Designed to avoid the
#     "typing the wrong bracket" failure
#     mode of a regular text editor on
#     concatenative code
#   - INTERACTIVE TUI (no subcommand) —
#     Running `mlatu` alone (or with
#     `.ml` rule files as args) starts a
#     two-pane TUI: left = current term
#     being edited, right = normalised
#     form after applying loaded rules.
#     Edits propagate live; the rewriter
#     re-runs on each keystroke
#
# CRITICAL DIRECT DEPENDENCIES (from
# Cargo.toml):
#   - combine 4.6                — parser
#                                  combinator
#                                  library
#   - crossterm 0.23 (event-     — terminal
#     stream feature)              control +
#                                  raw input
#                                  for the
#                                  structured
#                                  TUI editor
#   - tokio 1.18 (rt + macros +  — async
#     rt-multi-thread)             runtime
#   - tokio-stream 0.1           — async
#                                  stream
#                                  combinators
#   - clap 3.1 (cargo feature)   — CLI parser
#   - im 15.1                    — immutable
#                                  persistent
#                                  data
#                                  structures
#                                  (used for
#                                  the rule
#                                  set)
#   - unic-ucd-category 0.9      — Unicode
#                                  general
#                                  category
#                                  database
#                                  (for word
#                                  tokenisation)
#   - mlatu-lib (git dep)        — the
#                                  compiler +
#                                  rewriter
#                                  library
#                                  (pulled from
#                                  github.com/
#                                  mlatu-lang/
#                                  libraries)
#
# Rust + Erlang/OTP + (Windows: Clang) at build
# time.  Stable Rust does NOT compile mlatu —
# the codebase uses `#![feature(with_options)]`
# so nightly is required.
#
# UPSTREAM:
#   * Source             : https://github.com/mlatu-lang/mlatu
#   * Libraries          : https://github.com/mlatu-lang/libraries
#   * License            : https://mlatu-lang.github.io/license/
#   * Maintainer         : the mlatu-lang collective
#
# INSTALL:
#   # Prerequisites: Rust nightly + Erlang/OTP
#   rustup default nightly
#
#   # Install
#   git clone https://github.com/mlatu-lang/mlatu
#   cd mlatu
#   cargo install --path .
#
#   # On Windows: also install Clang and set
#   # LIBCLANG_PATH to its bin directory
#
# USAGE EXAMPLES:
#
#   # Start the interactive TUI with no rule
#   # file (empty rule set)
#   mlatu
#
#   # Load a rule file + start TUI
#   mlatu prelude.ml
#
#   # Load multiple rule files in order
#   mlatu prelude.ml my-rules.ml
#
#   # Open the structured rule editor
#   mlatu edit my-rules.ml
#
#   # Help (clap-default)
#   mlatu --help
#   mlatu -h
#
#   # Version (clap-default)
#   mlatu --version
#   mlatu -V
#
#   # Subcommand-specific help
#   mlatu edit --help
#
# SYNTAX EXAMPLES (.ml file):
#
#   // single-line comment with //
#
#   // Identity rule: `id` reduces to nothing
#   id =
#
#   // dup rule: `dup X` becomes `X X`
#   dup x = x x
#
#   // swap rule: `swap X Y` becomes `Y X`
#   swap x y = y x
#
#   // Church numerals:
#   //   `zero` is no rule output
#   //   `succ N` is `N succ`
#   //   `plus N M` is `M succ ... N times`
#   plus zero y = y
#   plus (succ x) y = succ (plus x y)
#
#   // Booleans encoded as projections:
#   true x y = x
#   false x y = y
#
#   // If-then-else is just function
#   // application:
#   //   `if true T F` reduces to `T`
#   //   `if false T F` reduces to `F`
#   if b t f = b t f
#
# OPTIONS (sourced directly from
# https://github.com/mlatu-lang/mlatu/blob/main/src/main.rs):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _mlatu_commands
_mlatu_commands=(
    'edit:Open the structured rule editor on a .ml file (Ctrl-W save, Esc exit)'
    'help:Print help for a subcommand'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command_or_file' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command_or_file)
        _alternative \
            'commands:mlatu command:_describe -t commands "command" _mlatu_commands' \
            'files:rule file:_files -g "*.(ml|mlb)"' \
            && ret=0
        ;;
    args)
        case $line[1] in
            edit)
                _arguments \
                    '(- *)'{-h,--help}'[show help for edit]' \
                    '1:rule file:_files -g "*.(ml|mlb)"' \
                    && ret=0
                ;;
            help)
                _arguments \
                    '1:subcommand:(edit)' \
                    && ret=0
                ;;
            *)
                _files -g "*.(ml|mlb)" && ret=0
                ;;
        esac
        ;;
esac

return ret
