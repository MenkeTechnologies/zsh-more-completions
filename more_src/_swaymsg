#compdef swaymsg
# Documentation: https://manpages.debian.org/unstable/sway/swaymsg.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swaymsg - send messages to a Sway window manager

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-r --raw)'{-r,--raw}'[use raw JSON output]' \
  '(-p --pretty)'{-p,--pretty}'[use pretty output]' \
  '(-s --socket)'{-s,--socket}'[use specific socket path]:socket:_files' \
  '(-m --monitor)'{-m,--monitor}'[monitor for responses]' \
  '(-t --type)'{-t,--type}'[message type]:type:(command get_workspaces get_outputs get_tree get_marks get_bar_config get_version get_binding_modes get_binding_state get_config get_inputs get_seats send_tick subscribe)' \
  '*:message:'
