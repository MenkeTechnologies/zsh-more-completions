#compdef ncmpcpp
# _ncmpcpp-cli — ncmpcpp NCurses Music Player Daemon client (C++); featureful MPD ncurses TUI
# upstream: https://github.com/ncmpcpp/ncmpcpp

_ncmpcpp-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-s --screen)'{-s,--screen}'+[start screen]:screen:(help playlist browser search-engine media-library playlist-editor tag-editor outputs visualizer clock server-info song-info lastfm last_fm lyrics)' \
        '(-S --slave-screen)'{-S,--slave-screen}'+[slave screen]:screen:(help playlist browser search-engine media-library playlist-editor tag-editor outputs visualizer clock server-info song-info lastfm last_fm lyrics)' \
        '(-H --host)'{-H,--host}'+[MPD host]:host:_hosts' \
        '(-p --port)'{-p,--port}'+[MPD port]:port:' \
        '(-b --bindings)'{-b,--bindings}'+[bindings file]:file:_files' \
        '--current-song[print current song]' \
        '--now-playing[print now playing format]'
}

_ncmpcpp-cli "$@"
