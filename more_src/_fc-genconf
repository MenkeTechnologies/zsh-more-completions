#compdef fc-genconf
# fontconfig: generate a language-specific config from a font

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[display font config version and exit]' \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '(-f --family)'{-f+,--family=}'[use NAME as the family]:family name' \
  '(-g --generic)'{-g+,--generic=}'[set NAME as the generic-family]:generic name' \
  '(-l --lang)'{-l+,--lang=}'[use LANG to make a language-specific conditional]:language' \
  '(-o --output)'{-o+,--output=}'[output results into FILE (default stdout)]:output file:_files' \
  '*:font path:_files' && ret=0

return ret
