#compdef kfp-launcher launcher-v2
# _kfp-launcher — Kubeflow Pipelines v2 component launcher (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/v2/cmd/launcher-v2/main.go on tip.

_kfp-launcher() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--copy=[copy this binary to destination path then exit]:dst:_files' \
        '--pipeline_name=[pipeline context name]:name:' \
        '--run_id=[pipeline run UID]:id:' \
        '--parent_dag_id=[parent DAG execution ID]:n:' \
        '--executor_type=[executor type]:type:(container importer)' \
        '--execution_id=[task execution ID]:n:' \
        '--executor_input=[JSON-encoded ExecutorInput]:json:' \
        '--component_spec=[JSON-encoded ComponentSpec]:json:' \
        '--importer_spec=[JSON-encoded ImporterSpec]:json:' \
        '--task_spec=[JSON-encoded TaskSpec]:json:' \
        '--pod_name=[Kubernetes pod name]:name:' \
        '--pod_uid=[Kubernetes pod UID]:uid:' \
        '--ml_pipeline_server_address=[ML pipeline API server host]:host:_hosts' \
        '--ml_pipeline_server_port=[ML pipeline API server port]:port:' \
        '--mlmd_server_address=[MLMD gRPC server host]:host:_hosts' \
        '--mlmd_server_port=[MLMD gRPC server port]:port:' \
        '--log_level=[log verbosity]:n:' \
        '--publish_logs=[publish component logs to object store]:bool:(true false)' \
        '--cache_disabled=[disable cache globally]:bool:(true false)' \
        '--ca_cert_path=[trusted CA cert file]:file:_files' \
        '--ml_pipeline_tls_enabled=[ML pipeline API server uses TLS]:bool:(true false)' \
        '--metadata_tls_enabled=[MLMD uses TLS]:bool:(true false)'
}

_kfp-launcher "$@"
