#compdef sleepenh
# Documentation: https://manpages.debian.org/bookworm/sleepenh/sleepenh.1.en.html
# Reference accessed: 2026-05-30
# sleepenh — Edrusb's high-precision drift-correcting sleep. Unlike sleep(1)
# which sleeps for a fixed duration, sleepenh aligns its wakeup to an
# absolute timestamp so chained invocations don't accumulate drift —
# ideal for periodic-task loops where you want exactly N seconds between
# wakes regardless of how long the work in between took.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-w --warp)'{-w,--warp}'[adjust timestamp so next call would actually sleep]' \
  '1:INITIALTIME (defaults to now):' \
  '2:TIMETOSLEEP (seconds):' \
  && ret=0

return ret
