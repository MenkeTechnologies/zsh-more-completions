#compdef lefthook

# Zsh completion for lefthook - git hooks manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install lefthook hooks'
  'uninstall:uninstall lefthook hooks'
  'add:add a hook'
  'run:run a hook or command by name'
  'version:print lefthook version'
  'dump:dump the resolved lefthook config'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[enable verbose output]' \
  '--no-colors[disable colored output]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'lefthook command' commands && ret=0
    ;;
  (args)
    local -a hook_names=(
      pre-commit commit-msg pre-push post-commit post-checkout
      post-merge pre-rebase post-rewrite prepare-commit-msg
    )
    case $words[1] in
      (install)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[reinstall hooks]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (add)
        _arguments -s -S \
          '(-d --dirs)'{-d,--dirs}'[create directories for scripts]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:hook name:compadd -a hook_names' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(-a --all-files)'{-a,--all-files}'[run on all files]' \
          '(-f --force)'{-f,--force}'[force run even if skipped]' \
          '--no-tty[disable TTY allocation]' \
          '--commands[run only specific commands]:commands' \
          '--file[run on specific files]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:hook name:compadd -a hook_names' && ret=0
        ;;
      (dump)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (version)
        ret=0
        ;;
    esac
    ;;
esac

return ret
