#compdef mri_remove_neck
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mri_remove_neck/mri_remove_neck.help.xml
# Remove the neck from a volume using an atlas registration

local ret=1

_arguments -s -S \
  ':in volume:_files' \
  ':transform:_files' \
  ':GCA atlas:_files' \
  ':out volume:_files' && ret=0

return ret
