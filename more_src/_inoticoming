#compdef inoticoming
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/inoticoming.1.html
# wait for events on a directory then trigger commands

local ret=1

_arguments -s -S \
  '--foreground[do not fork, stay in foreground and log to stderr]' \
  '--logfile=[after forking, log to filename instead of syslog]:logfile:_files' \
  '--pid-file=[write the pid of the running instance into filename]:pidfile:_files' \
  '--initialsearch[first process files already existing in the directory]' \
  '--prefix=[only trigger if the filename starts with string]:prefix' \
  '--suffix=[only trigger if the filename ends with string]:suffix' \
  '--regexp=[only trigger if the filename matches regular expression]:regexp' \
  '--chdir=[change into directory before executing the commands]:directory:_files -/' \
  '--stdout-to-log[redirect the command stdout to the logfile]' \
  '--stderr-to-log[redirect the command stderr to the logfile]' \
  '1:directory:_files -/' \
  '*::command:_command_names -e' && ret=0

return ret
