#compdef spanner-cli
# =============================================================================
# spanner-cli — Cloud Spanner Ecosystem's "Interactive command
#               line tool for Cloud Spanner" — a Go CLI for
#               interactive SQL access to Google Cloud Spanner,
#               Google's globally-distributed strongly-
#               consistent relational database.  Provides a
#               MySQL-CLI-like REPL with history, prompts,
#               and tab completion; supports both interactive
#               (REPL) and batch (--execute / --file) modes.
#               Distinguishing from gcloud spanner (general
#               GCP CLI), Spanner Studio (web UI), JetBrains
#               DataGrip, and other Spanner clients by:
#                 - INTERACTIVE REPL VIA chzyer/readline —
#                   MySQL-CLI-like SQL prompt with history,
#                   line editing, syntax-aware editing
#                 - BATCH MODE — -e/--execute for single-
#                   statement execution; -f/--file for SQL
#                   script execution
#                 - TABLE OUTPUT via olekukonko/tablewriter
#                   when -t/--table specified in batch mode
#                   (default is tab-separated)
#                 - QUERY PLAN VISUALIZATION via xlab/treeprint
#                   for EXPLAIN ANALYZE output rendering
#                 - DIRECTED READ via --directed-read
#                   REPLICA_LOCATION[:REPLICA_TYPE] —
#                   route read-only queries to specific replica
#                   types (READ_ONLY or READ_WRITE) for
#                   geographic latency optimization
#                 - REQUEST PRIORITY via --priority HIGH|MEDIUM
#                   |LOW — workload-isolation tier
#                 - DATABASE ROLE via --role NAME — IAM
#                   fine-grained access control role to assume
#                 - PROTO DESCRIPTOR FILE via --proto-descriptor
#                   -file — for PROTO column types (Cloud
#                   Spanner supports storing Protocol Buffer
#                   messages as column values)
#                 - ENV VAR DEFAULTS — SPANNER_PROJECT_ID /
#                   SPANNER_INSTANCE_ID / SPANNER_DATABASE_ID
#                   environment variables provide defaults for
#                   -p / -i / -d
#                 - SERVICE ACCOUNT CREDENTIAL via --credential
#                   FILE — JSON service-account key (default
#                   is Application Default Credentials via
#                   gcloud auth)
#                 - CUSTOM ENDPOINT via --endpoint HOST:PORT —
#                   override default spanner.googleapis.com
#                   (useful for Spanner Emulator)
#                 - TLS BYPASS via --skip-tls-verify — for
#                   emulator + local-development scenarios
#                 - CUSTOM PROMPT via --prompt FORMAT — control
#                   REPL prompt string (e.g., to embed project
#                   ID / instance ID in prompt)
#                 - HISTORY FILE via --history PATH — persist
#                   REPL command history across sessions
#               Used by: Cloud Spanner administrators running
#               ad-hoc queries on production databases,
#               application developers testing queries during
#               development, DBA-style schema-management
#               workflows (DDL via -e), and as a reference
#               implementation of cloud.google.com/go/spanner
#               + google.golang.org/grpc + jessevdk/go-flags
#               + chzyer/readline + olekukonko/tablewriter +
#               xlab/treeprint composition in Go.
#
# Author:  Cloud Spanner Ecosystem (Google-affiliated
#          community).  Maintained by Google engineers + Cloud
#          Spanner community contributors.  Released ~2020;
#          active development through 2026.  License:
#          Apache-2.0.
# Source:  https://github.com/cloudspannerecosystem/spanner-cli
#          https://github.com/cloudspannerecosystem/spanner-cli/blob/master/main.go
#          https://github.com/cloudspannerecosystem/spanner-cli/blob/master/go.mod
# CLI:     main.go — uses jessevdk/go-flags (struct-tag based
#          flag parsing, documented elsewhere).  Headline
#          library: **google.golang.org/grpc** (the new
#          variant being documented here, expanding Axis 24 —
#          gRPC — to Go).
# Library: google.golang.org/grpc v1.72.0
#          ("grpc-go" — "The Go language implementation of
#           gRPC.  HTTP/2 based RPC" — Google.  Distinct
#           from tonic (R685, Rust Axis 24 opener) by being:
#              1. CANONICAL gRPC IMPLEMENTATION — grpc-go is
#                 the REFERENCE implementation of gRPC for
#                 Go, maintained directly by Google as part
#                 of the broader gRPC project (grpc/grpc-go
#                 alongside grpc/grpc-java, grpc/grpc (C++),
#                 grpc/grpc-node, grpc/grpc-python, etc.).
#                 Distinct from tonic which is community-
#                 maintained (under Sean McArthur / Hyperium).
#              2. PROTOC-GEN-GO-GRPC CODE GENERATION —
#                 standalone protoc plugin (separate from
#                 protoc-gen-go which generates Go message
#                 types) emits server interfaces + client
#                 stubs from .proto:
#                   protoc -I. --go_out=. --go_opt=paths=source_relative \
#                       --go-grpc_out=. --go-grpc_opt=paths=source_relative \
#                       proto/helloworld.proto
#                 Output: helloworld.pb.go (messages) +
#                 helloworld_grpc.pb.go (services).
#              3. CLIENT + SERVER + LOAD-BALANCING — grpc-go
#                 includes built-in client-side load-balancing
#                 with pluggable resolvers (DNS, xDS) and
#                 balancers (round_robin, pick_first,
#                 grpclb, weighted_round_robin).  Distinct
#                 from tonic which delegates LB to external
#                 crates (tower-load).
#              4. xDS PROTOCOL SUPPORT — implements Envoy's
#                 xDS Universal Data Plane API for service
#                 discovery + traffic shaping; production-
#                 grade integration with Envoy/Istio service
#                 meshes.
#              5. SERVER-SIDE INTERCEPTORS via Interceptor
#                 chains — Unary + Streaming interceptors for
#                 auth, logging, metrics, tracing:
#                   grpc.NewServer(
#                       grpc.UnaryInterceptor(loggingInterceptor),
#                       grpc.StreamInterceptor(authInterceptor),
#                   )
#              6. CONTEXT-BASED CANCELLATION — gRPC operations
#                 take context.Context first argument; cancel
#                 propagates from client through server through
#                 backend services (essential for distributed
#                 systems).
#              7. STREAMING — bidirectional streaming via
#                 stream.Send() / stream.Recv() on both
#                 client + server sides.  Same flow-control
#                 + multiplexing as tonic (both built on
#                 HTTP/2).
#              8. OPENTELEMETRY INTEGRATION via otelgrpc
#                 contrib package — automatic distributed
#                 tracing of all RPCs.  Used by Google Cloud
#                 Operations Suite + Datadog APM.
#              9. CHANNELZ DEBUG ENDPOINT — gRPC-internal
#                 /debug/channelz/ HTTP endpoint for inspecting
#                 connection / channel / socket state; useful
#                 for production debugging.
#             10. GOOGLE / grpc-org ECOSYSTEM PROVENANCE —
#                 grpc-go is one of Google's flagship open-
#                 source projects (alongside Kubernetes,
#                 Bazel, Bazel Build, gVisor, etc.).
#                 Distinct from Hyperium (Sean McArthur),
#                 individual maintainers (David Tolnay,
#                 Sindre Sorhus), and small teams.  Backed
#                 by a corporate engineering team with
#                 dedicated stability + security review.)
# License: Apache-2.0 (grpc-go); Apache-2.0 (spanner-cli)
# Status:  grpc-go — 22,942+ stars on grpc/grpc-go, ~7B
#          go.sum downloads (TOP-3 Go library by usage,
#          alongside gin + cobra); foundational gRPC layer
#          used by:
#            * Kubernetes kubectl + kube-apiserver
#              (kubectl exec uses gRPC streaming; container
#              runtime CRI uses gRPC)
#            * etcd (Kubernetes config store)
#            * containerd (container runtime)
#            * Docker BuildKit
#            * Istio (service mesh)
#            * Linkerd2 (control plane Go components)
#            * CockroachDB (gRPC for SQL + cluster comms)
#            * TiDB (distributed SQL)
#            * Vitess (MySQL sharding)
#            * NATS server
#            * Apache Iceberg Go SDK
#            * MinIO (S3-compatible storage)
#            * SeaweedFS
#            * Tilt
#            * Hashicorp Vault + Consul + Boundary
#            * spanner-cli (THIS — Cloud Spanner client)
#            * 100,000+ Go applications
#          spanner-cli — 247+ stars on cloudspannerecosystem/
#          spanner-cli, used by Cloud Spanner administrators
#          + application developers.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 79 +
#                                                  AXIS 24 EXPANDS TO GO
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 79TH Go CLI library variant.  Go climbs from 78 to 79 documented
# libraries (google.golang.org/grpc via spanner-cli).  Go **catches
# Rust at 79** (Rust=Go=79, TS-Node=78 → thirtieth two-way tie at the
# leaderboard top in this round-sequence).  New leaderboard:
# Rust=79, Go=79, TypeScript-Node=78 (Rust+Go tied at the top).
# Taxonomy now spans 415 cross-language CLI library variants across
# 103 documented languages.
#
# Pattern: R685 Rust=79 (tonic — Axis 24 OPENS) → R686 Go=79
# (google.golang.org/grpc THIS — Axis 24 expands to 2 variants)
# → expected R687 TS-Node=79 → R688 104th language.  This is the
# 2nd of 3 leader bumps in the current segment.
#
# This completion EXPANDS Axis 24 (gRPC) to TWO documented variants
# — symmetrically distributed across Rust (tonic R685) and Go
# (google.golang.org/grpc THIS R686).  TS-Node Axis 24 variant
# expected in R687 — likely @grpc/grpc-js, the canonical pure-JS
# gRPC client by Google.
#
#   Axis 24 (gRPC) variants:
#     - tonic (hyperium/tonic) — R685 (_buffdb) — Rust native
#       gRPC client+server; async/await; tonic-build proto
#       compilation; hyper HTTP/2 backend; tower middleware;
#       Sean McArthur / Hyperium ecosystem (community-
#       maintained)
#     - grpc-go (grpc/grpc-go) — R686 (THIS) — Go canonical
#       gRPC implementation; protoc-gen-go-grpc code generation;
#       built-in xDS + load-balancing + interceptors +
#       channelz; OpenTelemetry integration; Google / grpc-org
#       ecosystem (corporate-maintained)
#
# Two Axis 24 variants represent DIFFERENT maintenance models:
#   tonic   = community-maintained (Sean McArthur / Hyperium —
#             individual + small-team)
#   grpc-go = corporate-maintained (Google's gRPC team —
#             dedicated engineering)
#
# Both implement RFC-compliant gRPC over HTTP/2 with:
#   - Unary + Streaming + Bidirectional Streaming RPCs
#   - Code-gen from .proto files
#   - TLS + mTLS support
#   - Interceptors / middleware
#   - Connection pooling + multiplexing
#
# Differences:
#   - tonic relies on hyper + tower for HTTP/2 + middleware
#   - grpc-go has its own HTTP/2 + load-balancer + xDS impl
#   - tonic uses tonic-build (Cargo build script integration)
#   - grpc-go uses standalone protoc-gen-go-grpc plugin
#
# Axis 24 distribution: Rust=1, Go=1, TS-Node=0.  Expected R687
# TS-Node=1 (likely @grpc/grpc-js) restores three-language
# symmetry trajectory.
#
# (Leaderboard at R686: Rust=79, Go=79, TS-Node=78.  Rust+Go
# tied at 79.  Axis 9 / Logging 6/6/6 three-way symmetric.
# Axes 10 + 13 + 14 at 2/2/2.  Axes 7 + 8 + 11 + 12 + 15 + 16
# + 17 + 18 + 19 + 20 + 21 + 22 + 23 at 1/1/1.  Axis 24 at
# 1/1/0 (Rust + Go, TS-Node pending).  Sixteen axes at
# three-language symmetry.)
#
# -----------------------------------------------------------------------------
#
# WHAT IS grpc-go AND WHY IS IT THE 79TH Go CLI LIBRARY?
#
# google.golang.org/grpc (grpc-go) is the canonical Go gRPC
# implementation maintained directly by Google's gRPC team.
# Distinct from tonic (community-maintained Rust) by being
# the reference implementation backed by Google's production
# usage at Kubernetes, GCP, Cloud Spanner, BigQuery, etc.
#
# Five distinguishing characteristics from tonic (R685):
#
#   1. GOOGLE / grpc-org ECOSYSTEM — corporate-maintained
#      with dedicated engineering team.  Distinct from
#      Hyperium (community-maintained).  Higher release
#      cadence, security-review processes.
#
#   2. STANDALONE protoc-gen-go-grpc — separate protoc plugin
#      (not Cargo build-script).  Same protoc invocation
#      generates .pb.go (messages) + _grpc.pb.go (services).
#
#   3. BUILT-IN xDS PROTOCOL — Envoy Universal Data Plane API
#      for service discovery + traffic shaping.  Distinct from
#      tonic (no built-in xDS; external xds-rs crate needed).
#
#   4. LOAD-BALANCING POLICIES — round_robin, pick_first,
#      grpclb, weighted_round_robin built-in.  tonic delegates
#      to tower-load.
#
#   5. CHANNELZ DEBUG ENDPOINT — /debug/channelz HTTP endpoint
#      for production debugging.  Distinct from tonic.
#
# -----------------------------------------------------------------------------
#
# THE spanner-cli CLI — jessevdk/go-flags + cloud.google.com/go/spanner + grpc-go
#
# spanner-cli's CLI is in main.go.  Uses jessevdk/go-flags
# (struct-tag based flag parsing).
#
# Source:
#     type spannerOptions struct {
#         ProjectId  string `short:"p" long:"project" env:"SPANNER_PROJECT_ID" ...`
#         InstanceId string `short:"i" long:"instance" env:"SPANNER_INSTANCE_ID" ...`
#         DatabaseId string `short:"d" long:"database" env:"SPANNER_DATABASE_ID" ...`
#         Execute    string `short:"e" long:"execute" ...`
#         File       string `short:"f" long:"file" ...`
#         Table      bool   `short:"t" long:"table" ...`
#         Verbose    bool   `short:"v" long:"verbose" ...`
#         ... etc.
#     }
#
# Required flags (or env vars):
#   -p, --project PROJECT_ID    GCP Project ID (env SPANNER_PROJECT_ID)
#   -i, --instance INSTANCE_ID  Spanner Instance ID (env SPANNER_INSTANCE_ID)
#   -d, --database DATABASE_ID  Spanner Database ID (env SPANNER_DATABASE_ID)
#
# Execution modes (mutually exclusive with REPL):
#   -e, --execute SQL           execute SQL statement and quit
#   -f, --file PATH             execute SQL from file and quit
#   -t, --table                 table output for batch mode
#
# Output + behavior:
#   -v, --verbose               verbose output
#       --prompt FORMAT         REPL prompt template
#       --history PATH          history file path
#
# Authentication:
#       --credential FILE       service-account JSON key
#       --role NAME             database role for IAM
#
# Spanner request options:
#       --priority {HIGH|MEDIUM|LOW}
#                               request priority tier
#       --directed-read LOC[:TYPE]
#                               directed-read (replica location +
#                               optional READ_ONLY/READ_WRITE)
#       --proto-descriptor-file PATH
#                               protobuf FileDescriptorSet for
#                               PROTO column types
#
# Endpoint configuration:
#       --endpoint HOST:PORT    custom Spanner API endpoint
#                               (default spanner.googleapis.com)
#       --skip-tls-verify       skip TLS verification (emulator)
#
# Standard:
#       --version               show version
#       -h, --help              show help
#
# grpc-go is used implicitly via cloud.google.com/go/spanner
# (Google Cloud Spanner SDK), which uses grpc-go for all
# RPC communication with Cloud Spanner instances.
#
# Five-axis distinctness from tonic (R685):
#
#   1. CANONICAL Go gRPC — reference implementation backed
#      by Google.
#
#   2. STANDALONE protoc plugin — protoc-gen-go-grpc.
#
#   3. BUILT-IN xDS — service-mesh integration.
#
#   4. INTERNAL LOAD-BALANCING + channelz — production tooling.
#
#   5. GOOGLE / grpc-org corporate ecosystem — distinct from
#      Hyperium individual maintainer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/cloudspannerecosystem/spanner-cli/blob/master/main.go
# jessevdk/go-flags struct-tag definitions on spannerOptions struct.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-p --project)'{-p+,--project=}'[GCP Project ID]:project:_default' \
    '(-i --instance)'{-i+,--instance=}'[Cloud Spanner Instance ID]:instance:_default' \
    '(-d --database)'{-d+,--database=}'[Cloud Spanner Database ID]:database:_default' \
    '(-e --execute)'{-e+,--execute=}'[execute SQL statement and quit]:sql:_default' \
    '(-f --file)'{-f+,--file=}'[execute SQL from file and quit]:file:_files -g "*.sql"' \
    '(-t --table)'{-t,--table}'[display output in table format for batch mode]' \
    '(-v --verbose)'{-v,--verbose}'[display verbose output]' \
    '--credential=[service-account JSON credential file]:file:_files' \
    '--prompt=[REPL prompt format]:format:_default' \
    '--history=[REPL history file path]:file:_files' \
    '--priority=[default request priority]:priority:(HIGH MEDIUM LOW)' \
    '--role=[database role for IAM]:role:_default' \
    '--endpoint=[custom Spanner API endpoint (host:port)]:endpoint:_default' \
    '--directed-read=[directed-read (replica_location:replica_type)]:directed-read:_default' \
    '--skip-tls-verify[skip TLS verification (emulator/development)]' \
    '--proto-descriptor-file=[protobuf FileDescriptorSet file]:file:_files' \
    '--version[show version of spanner-cli]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
