#compdef pgsql2shp
# Documentation: https://postgis.net/docs/manual-3.4/using_postgis_dbmanagement.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-f+[output filename]:file:_files' \
  '-h+[database host]:host:_hosts' \
  '-p+[port]:port:' \
  '-P+[password]:password:' \
  '-u+[username]:user:_users' \
  '-g+[geometry column]:column:' \
  '-b[use binary cursor]' \
  '-k[keep identifiers case]' \
  '-r[raw mode (preserve gid, no escaping)]' \
  '-m+[remap identifiers to 10-char names]:file:_files' \
  '-?[show help]' \
  '1:database:' \
  '2:table or query:' && ret=0

return ret
