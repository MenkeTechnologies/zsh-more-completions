#compdef davs2
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/davs2.1.html
# AVS2 (IEEE 1857.4) video decoder

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this instruction]' \
  '(-i --input)'{-i,--input}'+[input bitstream file path]:file:_files' \
  '(-o --output)'{-o,--output}'+[output YUV/Y4M file path]:file:_files' \
  '(-r --psnr)'{-r,--psnr}'+[reference reconstruction YUV file]:file:_files' \
  '(-t --threads)'{-t,--threads}'+[threads for decoding]:n:' \
  '(-m --md5)'{-m,--md5}'+[reference MD5 of decoded YUV]:md5:' \
  '(-v --verbose)'{-v,--verbose}'[enable decoding status every frame]' && ret=0

return ret
