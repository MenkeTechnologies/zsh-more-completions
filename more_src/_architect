#compdef architect architect-cli
# Documentation: https://github.com/architect-team/architect-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'autocomplete:display autocomplete installation instructions'
  'cluster:cluster operations'
  'clusters:manage clusters'
  'component:manage components'
  'components:list components'
  'config:get/set CLI config'
  'deploy:deploy a component'
  'destroy:destroy a deployment'
  'dev:start a local dev environment'
  'doctor:get debugging info'
  'environment:manage environments'
  'environments:list environments'
  'envs:alias for environments'
  'exec:exec a command in container'
  'help:show help'
  'init:initialize architect.yml from existing project'
  'link:link a local component to manifest'
  'login:login to Architect Cloud'
  'logout:logout'
  'logs:show logs for resource'
  'platform:manage platforms'
  'platforms:list platforms'
  'plats:alias for platforms'
  'push:push a component'
  'register:register a component'
  'scale:scale a service'
  'secrets:manage secrets'
  'task:exec a task'
  'unlink:unlink a local component'
  'unregister:unregister component'
  'update:update CLI'
  'whoami:show currently logged-in user'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'architect command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '(-e --email)'{-e+,--email=}'[email]:email:' \
          '(-p --password)'{-p+,--password=}'[password]:pw:' && ret=0 ;;
      (deploy|register|push)
        _arguments \
          '(-a --account)'{-a+,--account=}'[account name]:acct:' \
          '(-e --environment)'{-e+,--environment=}'[environment name]:env:' \
          '(-c --components)*'{-c+,--components=}'[component]:comp:' \
          '*--secret-file=[secret file]:file:_files' \
          '*-s+[secret value]:secret:' \
          '*--secret=[secret value]:secret:' \
          '*--parameter=[parameter value]:p:' \
          '(-p --parameter)*'{-p+,--parameter=}'[parameter value]:p:' \
          '--platform=[platform]:plat:' \
          '--auto-approve[auto approve]' \
          '--detached[detached mode]' \
          '--build-parallel[parallel builds]' \
          '--browser[open browser to deploy]' \
          '*--values=[values file]:file:_files' \
          '*: :_files' && ret=0 ;;
      (dev)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port]:port:' \
          '*-s+[secret value]:secret:' \
          '*--secret=[secret value]:secret:' \
          '*--secret-file=[secret file]:file:_files' \
          '(-a --account)'{-a+,--account=}'[account name]:acct:' \
          '--ssl[enable SSL]' \
          '--no-build-cache[skip build cache]' \
          '--detached[detached mode]' \
          '--debug[debug logging]' \
          '*: :_files' && ret=0 ;;
      (logs|exec|destroy|task)
        _arguments \
          '(-a --account)'{-a+,--account=}'[account]:acct:' \
          '(-e --environment)'{-e+,--environment=}'[environment]:env:' \
          '*: :' && ret=0 ;;
    esac ;;
esac

return ret
