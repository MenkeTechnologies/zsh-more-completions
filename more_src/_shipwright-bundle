#compdef shipwright-bundle
# _shipwright-bundle — Shipwright Build helper that pulls a bundle OCI image and unpacks it into the workspace
# upstream: https://github.com/shipwright-io/build
# Flags from cmd/bundle/main.go on tip.

_shipwright-bundle() {
    _arguments \
        '--help[print the help]' \
        '--image=[location of the bundle image (mandatory)]:image:' \
        '--target=[target directory to place the code]:dir:_files -/' \
        '--result-file-image-digest=[file to write the image digest]:file:_files' \
        '--result-file-source-timestamp=[file to write the source timestamp]:file:_files' \
        '--secret-path=[directory containing access credentials]:dir:_files -/' \
        '--prune[delete bundle image from registry after pull]' \
        '--show-listing[print file listing of files unpacked from the bundle]'
}

_shipwright-bundle "$@"
