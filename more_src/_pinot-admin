#compdef pinot-admin pinot-admin.sh

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'StartZookeeper:start an embedded ZooKeeper'
  'StartKafka:start an embedded Kafka'
  'StartController:start a Pinot controller'
  'StartBroker:start a Pinot broker'
  'StartServer:start a Pinot server'
  'StartMinion:start a Pinot minion'
  'StartServiceManager:start service manager'
  'StopProcess:stop a running Pinot process'
  'AddTable:add a new table'
  'AddTenant:add a new tenant'
  'AddSchema:add a new schema'
  'UpdateSchema:update an existing schema'
  'DeleteSchema:delete a schema'
  'DeleteTable:delete a table'
  'DeleteSegment:delete a segment'
  'ChangeTableState:enable/disable a table'
  'ChangeNumReplicas:change number of replicas'
  'CreateSegment:create segments from data files'
  'UploadSegment:upload a segment to controller'
  'DataImportDryRun:dry-run validation of data import'
  'GenerateData:generate sample data'
  'PostQuery:post a query to broker'
  'GetSegmentMetadata:get segment metadata'
  'BootstrapTable:bootstrap a table from configs'
  'ApplicationQuickStart:run quickstart with sample data'
  'AnonymizeData:anonymize sample data'
  'BackfillSegmentColumn:backfill a column'
  'OperateClusterConfig:operate cluster config'
  'OperateTenant:operate tenant'
  'RealtimeProvisioningHelper:realtime provisioning helper'
  'SegmentProcessorFramework:segment processor'
  'ImportData:import data into table'
  'LaunchDataIngestionJob:launch data ingestion job'
  'LaunchSparkDataIngestionJob:launch Spark data ingestion'
  'StreamAvroIntoKafka:stream Avro file into Kafka'
  'VerifyClusterStatus:verify cluster status'
  'OfflineSegmentIntervalChecker:offline segment interval checker'
  'ValidateConfig:validate Pinot config'
  'ValidateTableRetention:validate table retention'
)

_arguments -C \
  '(- *)'{-h,-help,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pinot-admin command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (StartController)
        _arguments \
          '-controllerMode+[controller mode]:mode:(DUAL HELIX_ONLY PINOT_ONLY)' \
          '-controllerHost+[host name]:host:_hosts' \
          '-controllerPort+[port]:port:' \
          '-dataDir+[data directory]:dir:_files -/' \
          '-zkAddress+[ZooKeeper address]:zk:' \
          '-clusterName+[cluster name]:name:' \
          '-configFileName+[config file]:file:_files' && ret=0
        ;;
      (StartBroker)
        _arguments \
          '-brokerHost+[host name]:host:_hosts' \
          '-brokerPort+[port]:port:' \
          '-zkAddress+[ZooKeeper address]:zk:' \
          '-clusterName+[cluster name]:name:' \
          '-configFileName+[config file]:file:_files' && ret=0
        ;;
      (StartServer)
        _arguments \
          '-serverHost+[host name]:host:_hosts' \
          '-serverPort+[port]:port:' \
          '-dataDir+[data directory]:dir:_files -/' \
          '-segmentDir+[segment directory]:dir:_files -/' \
          '-zkAddress+[ZooKeeper address]:zk:' \
          '-clusterName+[cluster name]:name:' \
          '-configFileName+[config file]:file:_files' && ret=0
        ;;
      (StartMinion)
        _arguments \
          '-minionHost+[host name]:host:_hosts' \
          '-minionPort+[port]:port:' \
          '-zkAddress+[ZooKeeper address]:zk:' \
          '-clusterName+[cluster name]:name:' \
          '-configFileName+[config file]:file:_files' && ret=0
        ;;
      (StartZookeeper)
        _arguments \
          '-zkPort+[ZK port]:port:' \
          '-dataDir+[data directory]:dir:_files -/' && ret=0
        ;;
      (AddTable)
        _arguments \
          '-tableConfigFile+[table config file]:file:_files -g "*.json"' \
          '-schemaFile+[schema file]:file:_files -g "*.json"' \
          '-controllerHost+[host]:host:_hosts' \
          '-controllerPort+[port]:port:' \
          '-exec[execute the operation]' \
          '-update[update existing table]' \
          '-validationTypesToSkip+[validation types]:types:' && ret=0
        ;;
      (AddSchema|UpdateSchema)
        _arguments \
          '-schemaFile+[schema file]:file:_files -g "*.json"' \
          '-controllerHost+[host]:host:_hosts' \
          '-controllerPort+[port]:port:' \
          '-exec[execute]' && ret=0
        ;;
      (DeleteSchema)
        _arguments \
          '-schemaName+[schema name]:name:' \
          '-controllerHost+[host]:host:_hosts' \
          '-controllerPort+[port]:port:' \
          '-exec[execute]' && ret=0
        ;;
      (DeleteTable)
        _arguments \
          '-tableName+[table name]:name:' \
          '-controllerHost+[host]:host:_hosts' \
          '-controllerPort+[port]:port:' \
          '-exec[execute]' && ret=0
        ;;
      (UploadSegment)
        _arguments \
          '-segmentDir+[segment directory]:dir:_files -/' \
          '-tableName+[table name]:name:' \
          '-controllerHost+[host]:host:_hosts' \
          '-controllerPort+[port]:port:' \
          '-exec[execute]' && ret=0
        ;;
      (CreateSegment)
        _arguments \
          '-dataDir+[data directory]:dir:_files -/' \
          '-format+[input format]:format:(CSV JSON AVRO PARQUET ORC THRIFT PROTO)' \
          '-outDir+[output directory]:dir:_files -/' \
          '-overwrite[overwrite existing]' \
          '-tableName+[table name]:name:' \
          '-segmentName+[segment name]:name:' \
          '-schemaFile+[schema file]:file:_files -g "*.json"' \
          '-readerConfigFile+[reader config]:file:_files' \
          '-numThreads+[parallel threads]:n:' \
          '-postCreationVerification[verify after creation]' && ret=0
        ;;
      (GenerateData)
        _arguments \
          '-numRecords+[number of records]:n:' \
          '-numFiles+[number of files]:n:' \
          '-schemaFile+[schema file]:file:_files -g "*.json"' \
          '-outDir+[output directory]:dir:_files -/' \
          '-overwrite[overwrite]' \
          '-format+[output format]:format:(AVRO JSON CSV)' && ret=0
        ;;
      (PostQuery)
        _arguments \
          '-brokerHost+[broker host]:host:_hosts' \
          '-brokerPort+[broker port]:port:' \
          '-query+[query]:sql:' \
          '-queryFile+[query file]:file:_files -g "*.sql"' && ret=0
        ;;
      (ChangeTableState)
        _arguments \
          '-tableName+[table name]:name:' \
          '-state+[new state]:state:(enable disable drop)' \
          '-controllerHost+[host]:host:_hosts' \
          '-controllerPort+[port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
