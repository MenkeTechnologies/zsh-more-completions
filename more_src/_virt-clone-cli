#compdef virt-clone-cli
# _virt-clone-cli — Red Hat virt-clone clone libvirt VM definitions CLI alias (virt-manager team, Python); argparse
# upstream: https://github.com/virt-manager/virt-manager

_virt-clone-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--connect=+[libvirt URI]:str:' \
        '-c+[libvirt URI]:str:' \
        '--original=+[original VM name]:str:' \
        '-o+[original VM name]:str:' \
        '--original-xml=+[xml file]:file:_files -g "*.xml"' \
        '--auto-clone[autogenerate name]' \
        '--name=+[new VM name]:str:' \
        '-n+[new VM name]:str:' \
        '--uuid=+[new uuid]:str:' \
        '-u+[new uuid]:str:' \
        '--mac=+[MAC address]:str:' \
        '-m+[MAC address]:str:' \
        '--file=+[new disk file]:file:_files -g "*.{qcow2,img,raw}"' \
        '-f+[new disk file]:file:_files -g "*.{qcow2,img,raw}"' \
        '--force-copy=+[force copy device]:str:' \
        '--skip-copy=+[skip copy device]:str:' \
        '--nonsparse[create non-sparse]' \
        '--preserve-data[preserve data]' \
        '--print-xml[print xml only]' \
        '--replace[replace existing VM]' \
        '--reflink[use btrfs reflink]' \
        '--check=+[check arg]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug]' \
        '-d[debug]' \
        '*:arg:'
}

_virt-clone-cli "$@"
