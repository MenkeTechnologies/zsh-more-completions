#compdef run_deepvariant
# Documentation: https://github.com/google/deepvariant/blob/r1.6/docs/deepvariant-quick-start.md
# DeepVariant one-command germline variant calling pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model_type=[type of model: WGS, WES, PACBIO, ONT_R104, HYBRID_PACBIO_ILLUMINA]:type:(WGS WES PACBIO ONT_R104 HYBRID_PACBIO_ILLUMINA)' \
  '--ref=[genome reference FASTA with FAI index]:fasta:_files' \
  '--reads=[aligned sorted indexed BAM file]:bam:_files' \
  '--output_vcf=[path to write the VCF file]:vcf:_files' \
  '--output_gvcf=[path to write the gVCF file]:gvcf:_files' \
  '--num_shards=[number of shards for make_examples]:int:' \
  '--regions=[space-separated regions or BED/BEDPE paths]:regions:' \
  '--sample_name=[sample name overriding BAM SM tag]:name:' \
  '--haploid_contigs=[list of non autosomal chromosomes]:contigs:' \
  '--par_regions_bed=[BED of pseudoautosomal regions]:bed:_files' \
  '--intermediate_results_dir=[directory for intermediate outputs]:dir:_files -/' \
  '--logging_dir=[directory for per-stage log files]:dir:_files -/' \
  '--customized_model=[model checkpoint for call_variants]:path:_files' \
  '--use_slim_model[the model must be a Slim model]' \
  '--make_examples_extra_args=[extra flag_name=flag_value pairs]:args:' \
  '--call_variants_extra_args=[extra flag_name=flag_value pairs]:args:' \
  '--postprocess_variants_extra_args=[extra flag_name=flag_value pairs]:args:' \
  '--postprocess_cpus=[CPUs during postprocess_variants]:int:' \
  '--report_title=[title for the VCF stats report]:title:' \
  '--vcf_stats_report[output a visual HTML report of VCF statistics]' \
  '--runtime_report[output make_examples runtime metrics report]' \
  '--use_hp_information[(deprecated) use HP information in the BAM]' \
  '--dry_run[print commands without executing them]' \
  '--version[print version number and exit]' && ret=0

return ret
