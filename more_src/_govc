_arguments -s -S -C \
  '-u=[vSphere URL]:url' \
  '-k[Skip certificate verification]' \
  '-tls-known-hosts=[TLS known hosts file]:file:_files' \
  '-tls-ca-certs=[TLS CA certificate file]:file:_files' \
  '-dc=[Datacenter]:datacenter' \
  '-ds=[Datastore]:datastore' \
  '-host=[ESX host]:host' \
  '-pool=[Resource pool]:pool' \
  '-folder=[Inventory folder]:folder' \
  '-net=[Network]:network' \
  '-json[Output as JSON]' \
  '-dump[Dump raw request/response]' \
  '-verbose[Verbose output]' \
  '-trace[Trace SOAP messages]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'govc command' commands && ret=0
    ;;
esac

return ret
