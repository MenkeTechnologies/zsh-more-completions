#compdef ossec-agent-auth

# OSSEC agent-auth: enroll an agent with manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-d[debug]' \
  '-v[verify cert with CA file]:file:_files' \
  '-x[client cert]:file:_files' \
  '-k[client key]:file:_files' \
  '-m[manager IP/host]:host:_hosts' \
  '-p[manager port (default 1515)]:port:' \
  '-A[agent name]:name:' \
  '-c[ssl cipher list]:cipher:' \
  '-G[group(s) comma separated]:group:' \
  '-P[enrollment password]:pass:' \
  '-D[runtime directory]:dir:_files -/' \
  '*::ossec-agent-auth args:_files' && ret=0
return ret
