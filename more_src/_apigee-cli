#compdef apigee-cli apigeecli apigee
# _apigee-cli — Google Apigee apigee-cli CLI command-line frontend wrapping the apigeecli command-line interface for the Apigee API management platform Google Cloud's full lifecycle API management open-source written in Go organizations environments apis api-products apps developers keystores aliases targetservers references apiproducts kvms developers sharedflows datacollectors instances debugmask debugsession iam-roles eventflows hub appgroups securityprofiles offline-tracing analytics tokens monitoring auth (Google Apigee team Srinandan Sridharan Kurt Kanaskie, Go); cobra
# upstream: https://cloud.google.com/apigee

_apigee-cli() {
    local -a sub=(
        'apis:API operations'
        'apicategories:API category operations'
        'apigroups:API group operations'
        'apidocs:API doc operations'
        'apihub:API Hub operations'
        'appgroups:app group operations'
        'apps:app operations'
        'cache:cache operations'
        'datacollectors:data collector operations'
        'datastores:data store operations'
        'debugmask:debug mask operations'
        'debugsession:debug session operations'
        'developers:developer operations'
        'envgroups:env group operations'
        'env-config:env config operations'
        'envs:environment operations'
        'eventflows:event flow operations'
        'flowhooks:flow hook operations'
        'hostsecurity:host security operations'
        'iam:IAM operations'
        'instances:instance operations'
        'keystores:keystore operations'
        'keyaliases:key alias operations'
        'kvms:KVM operations'
        'monitoring:monitoring operations'
        'offlinetraces:offline trace operations'
        'orgs:organization operations'
        'products:product operations'
        'projects:project operations'
        'references:reference operations'
        'reports:report operations'
        'securityprofiles:security profile ops'
        'securityprofilesv2:security profile v2'
        'sharedflows:shared flow operations'
        'sites:site operations'
        'spec:spec operations'
        'syncauth:sync auth operations'
        'targetservers:target server operations'
        'tokens:token operations'
        'completion:generate shell completion'
        'help:show help'
        'preferences:CLI preferences'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-a+[access token]:str:' \
        '--token=+[token]:str:' \
        '-d[disable check]' \
        '--disable-check[disable update check]' \
        '-l[no output]' \
        '--no-output[no output]' \
        '-c+[config file]:file:_files -g ".apigeecli.yml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g ".apigeecli.yml *.yaml *.yml"' \
        '--default-token[use default token]' \
        '--api[use API call]' \
        '--print-output[print output]' \
        '--metadata-token-source-account=+[email]:str:' \
        '--region=+[name]:str:' \
        '--org=+[name]:str:' \
        '-o+[org]:str:' \
        '--env=+[name]:str:' \
        '-e+[env]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--proxy=+[proxy]:str:' \
        '--file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '--rev=+[N]:n:' \
        '-r+[revision]:n:' \
        '--key-id=+[id]:str:' \
        '--service-account=+[email]:str:' \
        '--account=+[email]:str:' \
        '--description=+[text]:str:' \
        '--display-name=+[name]:str:' \
        '--type=+[t]:str:' \
        '--overrides=+[file]:file:_files -g "*.yaml *.yml"' \
        '--mfa-token=+[token]:str:' \
        '--region=+[r]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apigee subcommand' sub ;;
        args)
            case $words[1] in
                apis|apps|developers|envs|envgroups|orgs|products|projects|kvms|keystores|sharedflows|targetservers|references|hostsecurity|securityprofiles|appgroups|datacollectors|datastores|reports|sites|spec|tokens) _arguments '1:op:(list get create update delete deploy undeploy export import enable disable copy rotate generate)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_apigee-cli "$@"
