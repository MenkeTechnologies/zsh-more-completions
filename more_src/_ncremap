#compdef ncremap
# Documentation: https://nco.sourceforge.net/nco.html#ncremap
# Source: NCO ncremap — netCDF horizontal/vertical regridder and grid generator.
# Reference accessed: 2026-06-20

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --alg_typ)'{-a,--alg_typ}'+[regridding algorithm type]:alg:_default' \
    '(-d --dst_grd)'{-d,--dst_grd}'+[destination grid specification]:grd:_files' \
    '(-g --grd_dst)'{-g,--grd_dst}'+[destination grid file]:file:_files' \
    '(-G --grd_sng)'{-G,--grd_sng}'+[grid generation string descriptor]:sng:_default' \
    '(-i --in_fl)'{-i,--in_fl}'+[input file]:file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    '(-I --in_drc)'{-I,--in_drc}'+[input directory]:dir:_directories' \
    '(-m --map_fl)'{-m,--map_fl}'+[regrid weight-map file]:file:_files' \
    '(-M --mss_val)'{-M,--mss_val}'[disable missing-value handling]' \
    '(-o --out_fl)'{-o,--out_fl}'+[output file]:file:_files' \
    '(-O --out_drc)'{-O,--out_drc}'+[output directory]:dir:_directories' \
    '(-P --prc_typ)'{-P,--prc_typ}'+[processing type]:type:_default' \
    '(-R --rgr_opt)'{-R,--rgr_opt}'+[regridding options string]:opts:_default' \
    '(-s --src_grd)'{-s,--src_grd}'+[source grid specification]:grd:_files' \
    '(-v --var_lst)'{-v,--var_lst}'+[variable list to process]:vars:_default' \
    '(-V --var_rgr)'{-V,--var_rgr}'+[variables to regrid]:vars:_default' \
    '(-x --xtn_var)'{-x,--xtn_var}'+[extensive variables list]:vars:_default' \
    '--vrt_fl=[vertical-grid file]:file:_files' \
    '--vrt_grd=[vertical grid specification]:grd:_default' \
    '--d2f[convert double precision to single]' \
    '--add_fll[add fill values to output]' \
    '--nco_opt=[extra NCO operator options]:opts:_default' \
    '*:netcdf file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    && ret=0

return ret
