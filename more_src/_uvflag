#compdef uvflag
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvflag.html
# MIRIAD uvflag - flag or unflag visibility data

local ret=1

_arguments -s -S \
  'vis=[input visibility datasets]:vis:_files' \
  'select=[uv data selection]:select' \
  'line=[spectral line specification (channel/wide)]:line' \
  'edge=[edge channel selection n,m,c]:edge' \
  'flagval=[flag operation flag/f or unflag/u]:flagval:(flag f unflag u)' \
  'options=[noapply,none,brief,indicative,full,noquery,hms,decimal]:options' \
  'log=[output destination filename]:log:_files' \
  '*:visibility data:_files' && ret=0

return ret
