#compdef eva
# Documentation: https://man.archlinux.org/search?q=eva
# Reference accessed: 2026-05-16

# Zsh completion for eva - calculator REPL

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --base)'{-b,--base}'[set output base]:base:(bin oct hex)' \
  '(-f --fix)'{-f,--fix}'[set number of decimal places]:places' \
  '*:expression'
