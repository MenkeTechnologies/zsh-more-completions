#compdef susorty
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/susorty.c
# make a small 2-D common shot off-end data set to help visualize sorting

local ret=1

_arguments -s -S \
  'nt=[number of time samples]:nt' \
  'nshot=[number of shots]:nshot' \
  'dshot=[shot interval (m)]:dshot' \
  'noff=[number of offsets]:noff' \
  'doff=[offset increment (m)]:doff' \
  '*:file:_files' && ret=0

return ret
