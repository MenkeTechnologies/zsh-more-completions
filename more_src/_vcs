#compdef vcs
# Documentation: https://github.com/dirk-thomas/vcstool
# vcs - vcstool, work with multiple repositories at once

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'branch:show the current branch of each repository'
      'custom:run a custom command on each repository'
      'diff:show the diff of each repository'
      'export:export the list of repositories in YAML format'
      'import:import repositories from a YAML file via stdin'
      'log:show the log of each repository'
      'pull:bring changes from remote into each repository'
      'push:push commits of each repository'
      'remotes:show the remotes of each repository'
      'status:show the status of each repository'
      'validate:validate the YAML file of repositories'
      'help:show the help message'
    )
    _describe -t commands 'vcs command' cmds && ret=0
    ;;
  args)
    _arguments -s \
      '(-h --help)'{-h,--help}'[show help]' \
      '--debug[show debug messages]' \
      '(-s --hide-empty --skip-empty)'{-s,--hide-empty,--skip-empty}'[hide repositories with empty output]' \
      '(-n --nested)'{-n,--nested}'[search for nested repositories]' \
      '(-w --workers)'{-w,--workers}'[number of worker threads]:N:' \
      '--repos[show the list of repositories the command operates on]' \
      '--exact[export exact commit hash instead of branch]' \
      '*:path:_files -/' && ret=0
    ;;
esac

return ret
