#compdef bgplgd
# _bgplgd — OpenBSD bgplgd (FastCGI BGP looking-glass daemon; serves a simple web API that wraps bgpctl(8) queries; drops privs to _bgplgd, unveils the bgpctl binary, pledges/restricts itself)
# upstream: https://github.com/openbsd/src (usr.sbin/bgplgd)
# Flags from usr.sbin/bgplgd/bgplgd.8 on tip.

_bgplgd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-p+[chroot path]:dir:_files -/' \
        '-S+[control socket source]:file:_files' \
        '-s+[FastCGI socket]:file:_files' \
        '-U+[socket owner user]:user:_users' \
        '-V[show version + exit]'
}

_bgplgd "$@"
