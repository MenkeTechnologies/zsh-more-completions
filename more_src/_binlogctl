#compdef binlogctl
# _binlogctl — TiDB binlog cluster control CLI (pingcap/tidb-binlog)
# upstream: https://github.com/pingcap/tidb-binlog
# Flags from binlogctl/config.go.

_binlogctl() {
    local -a args
    args=(
        '(- *)-V[print version and exit]'
        '-cmd[operator command]:cmd:(generate_meta pumps drainers update-pump update-drainer pause-pump pause-drainer offline-pump offline-drainer encrypt)'
        '-node-id[node ID to operate on]:nodeid:'
        '-data-dir[meta directory path]:dir:_files -/'
        '-pd-urls[comma-separated list of PD endpoints]:urls:'
        '-ssl-ca[trusted CA file]:file:_files -g "*.pem"'
        '-ssl-cert[X509 certificate file]:file:_files -g "*.pem"'
        '-ssl-key[X509 key file]:file:_files -g "*.pem"'
        '-time-zone[time zone for savepoint file]:tz:'
        '-state[set node state]:state:(online pausing paused closing offline)'
        '-show-offline-nodes[include offline nodes in pumps/drainers listing]'
        '-text[plaintext to encrypt (for -cmd encrypt)]:text:'
    )
    _arguments -s $args
}

_binlogctl "$@"
