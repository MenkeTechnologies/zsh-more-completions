#compdef gobmp
# Documentation: https://github.com/sbezverk/gobmp
# Go-based BGP Monitoring Protocol (BMP) collector and publisher

local ret=1

_arguments -s -S \
  '--config=[path to a YAML configuration file]:config file:_files' \
  '--source-port=[TCP port to listen on for incoming BMP sessions]:port:' \
  '--performance-port=[port for pprof performance monitoring endpoints]:port:' \
  '--dump=[activate the dump publisher]:target:(console file)' \
  '--msg-file=[file for storing processed messages when --dump=file]:message file:_files' \
  '--kafka-server=[Kafka broker address for publishing BMP messages]:server\:port:' \
  '--kafka-topic-prefix=[prefix prepended to all Kafka topic names]:prefix:' \
  '--kafka-topic-retention-time-ms=[Kafka topic retention time in milliseconds]:milliseconds:' \
  '--nats-server=[NATS server URL for publishing messages]:url:' \
  '--split-af=[separate Kafka topics by address family]:bool:(true false)' \
  '--bmp-raw=[publish in OpenBMP RAW binary format]:bool:(true false)' \
  '--admin-id=[collector administrator identifier used in RAW mode]:admin id:' \
  '--v=[log verbosity level]:level:(1 2 3 4 5 6 7)' && ret=0

return ret
