#compdef packETHcli
# Documentation: https://packeth.sourceforge.net/packeth/CLI_version.html
# packETH command-line: send packets from a pcap file on an Ethernet interface

local ret=1

_arguments -s -S \
  '-m+[mode to send packet from the pcap file]:mode:(1 2 3 4 5 9)' \
  '-i+[network interface for packet operations]:interface' \
  '-f+[file name of packet in pcap format]:file:_files' \
  '-c+[sequence number of packet stored in pcap file]:number' \
  '-I+[time interval to display results]:seconds' \
  '-n+[number of packets to send (0 for infinite)]:number' \
  '-t+[duration for packet transmission]:seconds' \
  '-D+[delay between packets in nanoseconds]:ns' \
  '-d+[delay between packets in microseconds]:us' \
  '-b+[desired sending rate in kbit/s]:bandwidth' \
  '-B+[desired sending rate in Mbit/s]:bandwidth' \
  '-p+[period between steps in seconds]:seconds' \
  '-x[insert pattern a9b8c7d6 and counter inside last 10 bytes]' \
  '-q+[byte offset where the pattern should be]:offset' \
  '-w+[pattern to match]:pattern' \
  '-o+[byte offset where the incremented counter should be]:offset' \
  '-z+[rate ramp in kbit/s: startrate stoprate steprate]:rate ramp' \
  '-Z+[rate ramp in Mbit/s: startrate stoprate steprate]:rate ramp' \
  '-s+[size ramp in bytes: startsize stopsize stepsize]:size ramp' \
  '-S+[packet size for IDS test mode]:bytes' \
  '-a+[attack percentage level]:level:(0 1 2 3 4)' && ret=0

return ret
