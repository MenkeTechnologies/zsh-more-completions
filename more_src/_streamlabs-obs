#compdef streamlabs-obs
# Documentation: https://man.archlinux.org/search?q=streamlabs-obs
# Reference accessed: 2026-05-16

# Streamlabs Desktop / SLOBS launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--no-sandbox[Electron: disable sandbox]' \
  '--disable-gpu[Electron: disable GPU]' \
  '--enable-logging[Electron: enable logging]' \
  '--remote-debugging-port=[Electron: remote debugging port]:port:' \
  '--user-data-dir=[Electron user data dir]:dir:_files -/' \
  '*::streamlabs-obs args:_files' && ret=0
return ret
