}

(( $+functions[_uu-sha384sum_commands] )) ||
_uu-sha384sum_commands() {
    local commands; commands=()
    _describe -t commands 'uu-sha384sum commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-sha384sum" ]; then
    _uu-sha384sum "$@"
else
    compdef _uu-sha384sum uu-sha384sum
fi
