#compdef dremio

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'start:start the Dremio server (background)'
  'start-fg:start the Dremio server (foreground)'
  'stop:stop the Dremio server'
  'restart:restart the Dremio server'
  'status:show server status'
  'autorestart:run with auto-restart on crash'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--config=[config directory]:dir:_files -/' \
  '1: :->action' && ret=0

case $state in
  (action)
    _describe -t actions 'dremio action' actions && ret=0
    ;;
esac

return ret
