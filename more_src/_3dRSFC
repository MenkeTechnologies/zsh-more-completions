#compdef 3dRSFC
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dRSFC.html
# AFNI: resting state functional connectivity parameters

local ret=1

_arguments -s -S \
  '-despike[remove spikes from each time series first]' \
  '*-ort[orthogonalize input to columns in file]:file:_files' \
  '-dsort[orthogonalize each voxel to dataset]:fset:_files' \
  '-nodetrend[skip quadratic detrending before bandpass]' \
  '-dt[time step in seconds]:dd:' \
  '-nfft[FFT length]:N:' \
  '-norm[normalize all output series to L2 norm = 1]' \
  '-mask[apply mask dataset]:mset:_files' \
  '-automask[create mask automatically]' \
  '-blur[blur FWHM in mm]:fff:' \
  '-localPV[replace vectors with local principal vector]:radius:' \
  '-input[input dataset]:dataset:_files' \
  '-band[passband frequencies fbot ftop]:fbot:' \
  '-prefix[output dataset prefix]:prefix:' \
  '-quiet[suppress informative messages]' \
  '-no_rs_out[output parameters only]' \
  '-un_bp_out[also output un-bandpassed series]' \
  '-no_rsfa[skip RSFA parameter output]' \
  '-bp_at_end[bandpass as final step]' \
  '-notrans[skip transient checking]' \
  '-nosat[skip transient checking]' \
  '*:dataset:_files' && ret=0

return ret
