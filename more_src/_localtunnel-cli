#compdef localtunnel-cli lt
# _localtunnel-cli — localtunnel expose local server to internet CLI alias (localtunnel team, JavaScript); commander
# upstream: https://github.com/localtunnel/localtunnel

_localtunnel-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[local port]:port:' \
        '-p+[local port]:port:' \
        '--host=+[server URL]:url:_urls' \
        '-h+[server URL]:url:_urls' \
        '--subdomain=+[subdomain]:str:' \
        '-s+[subdomain]:str:' \
        '--local-host=+[host]:host:_hosts' \
        '-l+[host]:host:_hosts' \
        '--local-https[https local server]' \
        '--local-cert=+[cert file]:file:_files' \
        '--local-key=+[key file]:file:_files' \
        '--local-ca=+[ca file]:file:_files' \
        '--allow-invalid-cert[allow invalid cert]' \
        '--open[open browser]' \
        '-o[open browser]' \
        '--print-requests[print requests]' \
        '*:arg:'
}

_localtunnel-cli "$@"
