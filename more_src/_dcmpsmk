#compdef dcmpsmk
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmpsmk.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmpstat/apps/dcmpsmk.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmpstat/apps/dcmpsmk.cc OFCommandLine setup + docs/man/dcmpsmk.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(+Vl --voi-lut)'{+Vl,--voi-lut}'[use first VOI LUT if present (default)]' \
  '(+Vw --voi-window)'{+Vw,--voi-window}'[use first window center/width if present]' \
  '(-V --voi-ignore)'{-V,--voi-ignore}'[ignore VOI LUT and window center/width]' \
  '(+c --curve-activate)'{+c,--curve-activate}'[activate curve data if present (default)]' \
  '(-c --curve-ignore)'{-c,--curve-ignore}'[ignore curve data]' \
  '(+oc --overlay-copy)'{+oc,--overlay-copy}'[copy overlays if not embedded, activate otherwise (default)]' \
  '(+oa --overlay-activate)'{+oa,--overlay-activate}'[activate overlays]' \
  '(-o --overlay-ignore)'{-o,--overlay-ignore}'[ignore overlays]' \
  '(+s --shutter-activate)'{+s,--shutter-activate}'[use shutter if present in image (default)]' \
  '(-s --shutter-ignore)'{-s,--shutter-ignore}'[ignore shutter]' \
  '(+p --plut-activate)'{+p,--plut-activate}'[use presentation LUT shape if present (default)]' \
  '(-p --plut-ignore)'{-p,--plut-ignore}'[ignore presentation LUT shape]' \
  '(+l1 --layer-single)'{+l1,--layer-single}'[all curves and overlays are in one layer]' \
  '(+l2 --layer-double)'{+l2,--layer-double}'[one layer for curves, one for overlays (default)]' \
  '(+ls --layer-separate)'{+ls,--layer-separate}'[separate layers for each curve and overlay]' \
  '(-lx --location-none)'{-lx,--location-none}'[image reference without location (default)]' \
  '(-ln --location-network)'{-ln+,--location-network=}'[image reference with network location]:aetitle:' \
  '(-lm --location-media)'{-lm+,--location-media=}'[image reference with media location]:filesetID filesetUID:' \
  '--validate-std[images referenced by GSPS must belong to the same SOP class (default)]' \
  '--validate-related[images referenced by GSPS may belong to related SOP class]' \
  '--validate-relaxed[images referenced by GSPS may be any SOP class]' \
  '(+t= --write-xfer-same)'{+t=,--write-xfer-same}'[write with same TS as image file (default)]' \
  '(+te --write-xfer-little)'{+te,--write-xfer-little}'[write with explicit VR little endian TS]' \
  '(+tb --write-xfer-big)'{+tb,--write-xfer-big}'[write with explicit VR big endian TS]' \
  '(+ti --write-xfer-implicit)'{+ti,--write-xfer-implicit}'[write with implicit VR little endian TS]' \
  '*:dcmfile-in:_files'
