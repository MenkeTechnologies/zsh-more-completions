#compdef paludis

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --query)'{-q,--query}'[query the package database]' \
  '(-i --install)'{-i,--install}'[install packages]' \
  '(-u --uninstall)'{-u,--uninstall}'[uninstall packages]' \
  '(--uninstall-unused)--uninstall-unused[uninstall unused packages]' \
  '(-s --sync)'{-s,--sync}'[sync repositories]' \
  '(-r --report)'{-r,--report}'[report broken or unused packages]' \
  '(-y --contents)'{-y,--contents}'[list contents of installed packages]' \
  '(-k --executables)'{-k,--executables}'[list executables of installed packages]' \
  '(-o --owner)'{-o,--owner}'[find packages owning files]' \
  '(--config)--config[run package config phase]' \
  '(--info)--info[display Paludis info]' \
  '(--version-spec)--version-spec[print version spec]' \
  '(--regenerate-installed-cache)--regenerate-installed-cache[regenerate installed cache]' \
  '(--regenerate-installable-cache)--regenerate-installable-cache[regenerate installable cache]' \
  '--dl-deps-default=[deps default]:value:(pre pre-or-post post try-post discard)' \
  '--dl-installed-deps-pre=[deps]:value:(pre pre-or-post post try-post discard)' \
  '--dl-installed-deps-runtime=[deps]:value:(pre pre-or-post post try-post discard)' \
  '--dl-installed-deps-post=[deps]:value:(pre pre-or-post post try-post discard)' \
  '--dl-suggested=[suggestions]:value:(show install discard)' \
  '--dl-circular=[circular deps]:value:(error discard)' \
  '--continue-on-failure=[failure mode]:mode:(if-fetch-only never always if-satisfied if-independent)' \
  '--show-reasons=[show reasons]:value:(none summary full)' \
  '--show-use-descriptions=[USE descriptions]:value:(none new changed all)' \
  '--show-package-descriptions=[package descriptions]:value:(none new all)' \
  '--debug-build=[debug build]:value:(none split internal)' \
  '--checks=[checks]:value:(none default always)' \
  '--log-level=[log level]:level:(debug qa warning silent)' \
  '--no-color[disable colour output]' \
  '--config-suffix=[config suffix]:suffix:' \
  '--environment=[environment]:env:' \
  '--resume-command-template=[resume command template]:tpl:' \
  '*:package:' && ret=0

return ret
