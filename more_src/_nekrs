#compdef nekrs
# Documentation: https://github.com/Nek5000/nekRS/blob/master/src/bin/driver.hpp
# nekRS GPU-oriented spectral element CFD solver

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'=[show help; optional category]:category:(par env)' \
  '(-s --setup)'{-s,--setup}'=[case par or sess setup file]:setup file:_files -g "*.(par|sess)"' \
  '(-c --cimode)'{-c,--cimode}'=[run CI verification mode with id]:ci id:' \
  '(-b --build-only)'{-b,--build-only}'=[only JIT-build for given number of procs]:nprocs:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-a --attach)'{-a,--attach}'[attach debugger before run]' \
  '(-t --backend)'{-t,--backend}'=[compute backend]:backend:(CPU CUDA HIP DPCPP OPENCL SERIAL)' \
  '(-i --device-id)'{-i,--device-id}'=[device id or LOCAL-RANK]:device id:' \
  '(-r --output)'{-r,--output}'=[redirect output to file]:output file:_files' \
  '*:setup file:_files -g "*.(par|sess)"' && ret=0

return ret
