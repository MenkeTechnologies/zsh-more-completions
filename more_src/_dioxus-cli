#compdef dx

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'new:create a new Dioxus project'
      'init:initialize a Dioxus project in current directory'
      'serve:build and serve the project'
      'build:build the project'
      'translate:translate HTML to RSX'
      'bundle:bundle the project'
      'clean:clean build artifacts'
      'config:manage Dioxus configuration'
      'fmt:format RSX files'
      'check:check the project for issues'
      'link:link to a Dioxus project'
      'version:show version information'
    )
    _describe -t commands 'dx command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--hot-reload[enable hot reloading]' \
          '--port[port to serve on]:port:' \
          '--open[open browser after starting]' \
          '--release[build in release mode]' \
          '--platform[target platform]:platform:(web desktop mobile)' \
          '--features[cargo features to enable]:features:' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--release[build in release mode]' \
          '--platform[target platform]:platform:(web desktop mobile)' \
          '--features[cargo features to enable]:features:' \
          '--target[build target]:target:' && ret=0
        ;;
    esac
    ;;
esac

return ret
