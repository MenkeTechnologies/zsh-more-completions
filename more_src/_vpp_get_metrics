#compdef vpp_get_metrics
# Documentation: https://docs.fd.io/vpp/17.10/dd/d3e/vpp__get__metrics_8c_source.html
# retrieve metrics from a running VPP instance

local ret=1

_arguments -s -S \
  'chroot[specify a chroot directory path]:path:_directories' \
  'interval[reporting interval in seconds]:seconds' \
  'uid[set the user id (numeric or username)]:uid:_users' \
  'gid[set the group id (numeric or groupname)]:gid:_groups' && ret=0

return ret
