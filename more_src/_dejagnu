#compdef dejagnu
# Documentation: https://man.archlinux.org/search?q=dejagnu
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'report-card:produce report card'
  'runtest:run dejagnu test suite'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'dejagnu command' commands && ret=0 ;;
esac

return ret
