#compdef envv
# Documentation: https://github.com/jakewendt/envv
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for envv — shell-independent env/path helpers.
# Typical usage is `eval "$(envv …)"`; flags must precede the directive.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-e[do not escape shell metacharacters in output]' \
  '-s[emit trailing semicolons after each statement]' \
  '-h[show usage]' \
  '1:directive:(choose set local add del move)' \
  '*::args:_files' && ret=0

return ret
