#compdef btproxy
# Documentation: https://github.com/bluez/bluez/blob/master/tools/btproxy.c
# Source: BlueZ tools/btproxy.c — relay Bluetooth HCI between local controller and a TCP/Unix peer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --redirect)'{-r,--redirect}'[create local redirect]' \
    '(-c --connect)'{-c+,--connect=}'[connect to server address]:host:_hosts' \
    '(-l --listen)'{-l+,--listen=}'[use TCP server (optional address)]:addr:_hosts' \
    '(-u --unix)'{-u+,--unix=}'[use Unix server (optional path)]:path:_files' \
    '(-p --port)'{-p+,--port=}'[TCP port]:port:' \
    '(-i --index)'{-i+,--index=}'[controller index]:index:' \
    '(-a --amp)'{-a,--amp}'[create AMP controller]' \
    '(-e --ecc)'{-e,--ecc}'[emulate ECC support]' \
    '-z[skip first zero byte]' \
    '(-d --debug)'{-d,--debug}'[enable debug output]' \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
