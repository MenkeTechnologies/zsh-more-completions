#compdef seqtk
# Documentation: https://man.archlinux.org/search?q=seqtk
# Reference accessed: 2026-05-16

# seqtk: toolkit for FASTA/FASTQ manipulation
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'seq:common FASTA/FASTQ transformations'
  'comp:per-base composition'
  'sample:randomly subsample sequences'
  'subseq:extract subsequence by region BED/list'
  'trimfq:trim FASTQ by quality / fixed bases'
  'fqchk:per-base quality check'
  'mergefa:merge stacked FASTA'
  'famask:apply BED mask to FASTA'
  'dropse:drop unpaired single-end reads'
  'rename:rename sequence headers'
  'randbase:choose a random base from heterozygous bases'
  'cutN:cut sequence around long Ns'
  'gap:detect gaps in FASTA'
  'listhet:list heterozygous bases'
  'mutfa:mutate FASTA given SNP file'
  'mergepe:interleave paired-end reads'
  'split:split FASTA/FASTQ'
  'hpc:homopolymer-compressed sequence'
  'fqdiff:fastq diff'
  'pe2nm[de]:interleave or de-interleave reads'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'seqtk command' commands && ret=0 ;;
  args)
    case $line[1] in
      seq) _arguments \
        '-q[mask bases with quality below INT]:n:' \
        '-X[mask bases with quality above INT]:n:' \
        '-n[masked bases converted to char (default N)]:char:' \
        '-l[number of residues per line]:n:' \
        '-L[drop sequences shorter than INT]:n:' \
        '-c[only mask, do not change to N]' \
        '-r[reverse complement]' \
        '-A[force FASTA output (drop quality)]' \
        '-C[drop comments]' \
        '-N[drop sequences containing N]' \
        '-s[seed for random sampling]:n:' \
        '-f[sample fraction]:frac:' \
        '*:input file:_files' ;;
      sample) _arguments \
        '-s[random seed]:n:' \
        '-2[two-pass mode (lower memory)]' \
        '*:input file:_files' ;;
      subseq) _arguments \
        '-t[output TAB format]' \
        '-s[strand-aware (BED 4 column)]' \
        '-l[truncate sequence length]:n:' \
        '*:input file and region BED/list:_files' ;;
      *) _files ;;
    esac
    ret=0 ;;
esac
return ret
