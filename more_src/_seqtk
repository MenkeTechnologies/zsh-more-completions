#compdef seqtk
# Documentation: https://github.com/lh3/seqtk
# Reference accessed: 2026-05-21
# Verified: upstream seqtk.c usage() function at the URL above.
# Removed from prior file: fabricated fqdiff and pe2nm[de] subcommands
# (not present in seqtk.c). Added missing real subcommands: size, hety,
# gc, telo.

# seqtk: toolkit for FASTA/FASTQ manipulation
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'seq:common transformation of FASTA/Q'
  'size:report the number sequences and bases'
  'comp:get the nucleotide composition of FASTA/Q'
  'sample:subsample sequences'
  'subseq:extract subsequences from FASTA/Q'
  'fqchk:fastq QC (base/quality summary)'
  'mergepe:interleave two PE FASTA/Q files'
  'split:split one file into multiple smaller files'
  'trimfq:trim FASTQ using the Phred algorithm'
  'hety:regional heterozygosity'
  'gc:identify high- or low-GC regions'
  'mutfa:point mutate FASTA at specified positions'
  'mergefa:merge two FASTA/Q files'
  'famask:apply a X-coded FASTA to a source FASTA'
  'dropse:drop unpaired from interleaved PE FASTA/Q'
  'rename:rename sequence names'
  'randbase:choose a random base from hets'
  'cutN:cut sequence at long N'
  'gap:get the gap locations'
  'listhet:extract the position of each het'
  'hpc:homopolymer-compressed sequence'
  'telo:identify telomere repeats in asm or long reads'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'seqtk command' commands && ret=0 ;;
  args)
    case $line[1] in
      seq) _arguments \
        '-q[mask bases with quality below INT]:n:' \
        '-X[mask bases with quality above INT]:n:' \
        '-n[masked bases converted to char (default N)]:char:' \
        '-l[number of residues per line]:n:' \
        '-L[drop sequences shorter than INT]:n:' \
        '-c[only mask, do not change to N]' \
        '-r[reverse complement]' \
        '-A[force FASTA output (drop quality)]' \
        '-C[drop comments]' \
        '-N[drop sequences containing N]' \
        '-s[seed for random sampling]:n:' \
        '-f[sample fraction]:frac:' \
        '*:input file:_files' ;;
      sample) _arguments \
        '-s[random seed]:n:' \
        '-2[two-pass mode (lower memory)]' \
        '*:input file:_files' ;;
      subseq) _arguments \
        '-t[output TAB format]' \
        '-s[strand-aware (BED 4 column)]' \
        '-l[truncate sequence length]:n:' \
        '*:input file and region BED/list:_files' ;;
      *) _files ;;
    esac
    ret=0 ;;
esac
return ret
