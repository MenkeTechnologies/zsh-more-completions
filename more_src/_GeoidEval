#compdef GeoidEval
# Documentation: https://geographiclib.sourceforge.io/C++/doc/GeoidEval.1.html
# GeographicLib: look up geoid heights above the ellipsoid

local ret=1

_arguments -s -S \
  '-n[use named geoid model instead of egm96-5]:name:' \
  '-d[read geoid data from dir]:dir:_files -/' \
  '-l[use bilinear interpolation instead of cubic]' \
  '-a[cache the entire data set in memory]' \
  '-c[cache data bounded by south west north east]:south:' \
  '-w[toggle longitude-first flag]' \
  '-z[prefix each input line by zone]:zone:' \
  '--msltohae[convert height from geoid to ellipsoid (HAE)]' \
  '--haetomsl[convert height from ellipsoid to geoid (MSL)]' \
  '-v[print geoid model information on stderr]' \
  '--comment-delimiter[set comment delimiter]:delim:' \
  '--version[print version and exit]' \
  '(-h --help)-h[print usage and exit]' \
  '(-h --help)--help[print full documentation and exit]' \
  '--input-file[read input from file]:infile:_files' \
  '--input-string[read input from string]:string:' \
  '--line-separator[set line separator character]:linesep:' \
  '--output-file[write output to file]:outfile:_files' && ret=0

return ret
