#   typed `Producer` with `producer.connect()` /
#   `producer.send({ topic, messages, acks, timeout,
#   compression })` /
#   `producer.sendBatch({ topicMessages, ... })` /
#   `producer.transaction()` /
#   `producer.disconnect()` /
