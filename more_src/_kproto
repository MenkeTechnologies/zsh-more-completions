_kproto() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_kproto_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                consume)
                    _arguments \
                        '(-b --brokers)'{-b,--brokers}'=[Kafka brokers (CSV; env KAFKA_BROKERS)]:brokers:' \
                        '(-c --cluster)'{-c,--cluster}'=[AWS MSK cluster name or ARN]:cluster:' \
                        '(-g --group)'{-g,--group}'=[consumer group ID]:group:' \
                        '(-f --format)'{-f,--format}'=[output format]:format:(pretty compact json jsonl)' \
                        '--from-beginning[consume from beginning of the topic]' \
                        '--no-headers[hide message headers]' \
                        '--show-binary-headers[show full base64-encoded binary headers]' \
                        '--no-metadata[hide partition/offset/timestamp metadata]' \
                        '--no-color[disable colored output]' \
                        '--filter=[filter messages containing text]:text:' \
                        '--no-iam[disable IAM authentication]' \
                        '--region=[AWS region (default eu-west-1)]:region:' \
                        '--protobuf[decode messages as protobuf]' \
                        '--proto-path=[protobuf schema file]:path:_files -g "*.proto"' \
                        '--message-type=[protobuf message type]:type:' \
                        '--clear-cache[clear cached schema for the topic]' \
                        '--schema-registry=[Schema Registry URL (env SCHEMA_REGISTRY_URL)]:url:' \
                        '--schema-registry-username=[Schema Registry username]:user:' \
                        '--schema-registry-password=[Schema Registry password]:password:' \
                        '--since=[start consuming from time ago (e.g. 1h, 30m, 2d)]:time:' \
                        '--from=[start at absolute time (ISO 8601)]:timestamp:' \
                        '--to=[stop at absolute time (ISO 8601)]:timestamp:' \
                        '--max-messages=[exit after N messages]:n:' \
                        '--export=[export messages to file]:format:(csv jsonl)' \
                        '--output=[output file path]:path:_files' \
                        '*:Kafka topic:' && ret=0 ;;
                topics)
                    _arguments \
                        '(-b --brokers)'{-b,--brokers}'=[Kafka brokers (env KAFKA_BROKERS)]:brokers:' \
                        '(-c --cluster)'{-c,--cluster}'=[AWS MSK cluster]:cluster:' \
                        '--no-iam[disable IAM authentication]' \
                        '--region=[AWS region (default eu-west-1)]:region:' && ret=0 ;;
                clusters)
                    _arguments \
                        '--region=[AWS region (default eu-west-1)]:region:' && ret=0 ;;
                schema-cache)
                    _arguments \
                        '--show[show cached schemas]' \
                        '--clear=[clear cache for a topic (or all if no arg)]:topic:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kproto_commands] )) ||
_kproto_commands() {
    local -a commands
    commands=(
        'consume:consume messages from Kafka topics'
        'topics:list available topics'
        'clusters:list available MSK clusters in your AWS account'
        'schema-cache:manage protobuf schema cache'
    )
    _describe -t commands 'kproto command' commands
}

_kproto "$@"
