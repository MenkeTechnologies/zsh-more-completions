#compdef checkm
# Documentation: https://github.com/Ecogenomics/CheckM/wiki/Workflows
# CheckM: assess the quality of genomes recovered from isolates, single cells, or metagenomes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'checkm subcommand' \
      'lineage_wf[lineage-specific workflow for marker gene analysis]' \
      'taxonomy_wf[taxonomic-specific workflow]' \
      'tree[place bins in the reference genome tree]' \
      'tree_qa[assess phylogenetic markers found in each bin]' \
      'lineage_set[infer lineage-specific marker sets for each bin]' \
      'analyze[identify marker genes in bins]' \
      'qa[assess bins for contamination and completeness]' \
      'taxon_list[list available taxonomic-specific marker sets]' \
      'taxon_set[generate a taxonomic-specific marker set]' && ret=0
    _files
    ;;
esac

return ret
