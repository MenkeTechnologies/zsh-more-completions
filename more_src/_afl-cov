#compdef afl-cov
# Documentation: https://github.com/vanhauser-thc/afl-cov
# Produce code coverage results from an AFL++ fuzzing directory

local ret=1

_arguments -s -S \
  '(-e --coverage-cmd)'{-e,--coverage-cmd}'[command to exec (with args, assumes coverage support)]:cmd' \
  '(-d --afl-fuzzing-dir)'{-d,--afl-fuzzing-dir}'[top level AFL fuzzing directory]:dir:_files -/' \
  '(-c --code-dir)'{-c,--code-dir}'[directory where the code lives]:dir:_files -/' \
  '(-f --follow)'{-f,--follow}'[follow links when searching .da files]' \
  '(-O --overwrite)'{-O,--overwrite}'[overwrite existing coverage results]' \
  '--disable-cmd-redirection[disable redirection of command results to /dev/null]' \
  '--disable-lcov-web[disable generation of lcov web reports]' \
  '--disable-coverage-init[disable coverage counter init at startup]' \
  '--coverage-include-lines[include lines in zero-coverage status files]' \
  '--enable-branch-coverage[include branch coverage (may be slow)]' \
  '--live[process a live AFL directory]' \
  '--clang[clang was used for coverage compilation]' \
  '--cover-corpus[measure coverage after running all tests]' \
  '--coverage-at-exit[only calculate coverage just before exit]' \
  '--sleep[seconds to sleep between checks in live mode]:seconds' \
  '--gcov-check[check whether a binary has coverage support]' \
  '--gcov-check-bin[test a specific binary for coverage support]:bin:_files' \
  '--disable-gcov-check[disable check for coverage support]' \
  '--background[background mode]' \
  '--lcov-web-all[generate lcov web reports for all id files]' \
  '--disable-lcov-exclude-pattern[include default /usr/include pattern]' \
  '--lcov-exclude-pattern[set exclude pattern for lcov results]:pattern' \
  '--func-search[search for coverage of a function]:func' \
  '--line-search[search for coverage of a line number]:line' \
  '--src-file[restrict search to a source file]:file:_files' \
  '--afl-queue-id-limit[limit id files processed in the AFL queue]:limit' \
  '--ignore-core-pattern[ignore core_pattern in live mode]' \
  '--lcov-path[path to lcov command]:path:_files' \
  '--genhtml-path[path to genhtml command]:path:_files' \
  '--readelf-path[path to readelf command]:path:_files' \
  '--stop-afl[stop running afl-fuzz instances for the dir]' \
  '--validate-args[validate args and exit]' \
  '--afl-file[filepath passed to AFL with -f]:file:_files' \
  '(-T --timeout)'{-T,--timeout}'[timeout (default 5 seconds)]:seconds' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' && ret=0

return ret
