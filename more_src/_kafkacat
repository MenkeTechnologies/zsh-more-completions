#compdef kafkacat

# Zsh completion for kafkacat - generic Kafka producer/consumer (legacy name; kcat)

local -a arguments

arguments=(
  '-P[producer mode]'
  '-C[consumer mode]'
  '-G[high-level consumer group mode]:group id:'
  '-L[metadata list mode]'
  '-Q[query mode]'
  '-t[topic]:topic:'
  '-p[partition]:partition:'
  '-b[broker address list]:brokers:'
  '-D[delimiter]:char:'
  '-K[key delimiter]:char:'
  '-c[exit after consuming N messages]:count:'
  '-m[fixed timeout]:seconds:'
  '-F[file with configuration properties]:file:_files'
  '-X[set property]:property:'
  '-Y[Go-like key=value format]:key=val:'
  '-T[consume and produce in pipe mode]'
  '-l[input file (one msg per line)]:file:_files'
  '-o[consume offset]:offset:(beginning end stored)'
  '-e[exit successfully at end of topic]'
  '-u[unbuffered output]'
  '-q[quiet mode]'
  '-v[verbose output]'
  '-V[show version]'
  '-h[show help information]'
  '-s[serde spec]:spec:'
  '-f[output formatting string]:format:'
  '-J[JSON output]'
  '-r[schema registry URL]:url:'
  '-Z[print NULL values as empty strings]'
  '-U[unionize offsets]'
)

_arguments -s $arguments
