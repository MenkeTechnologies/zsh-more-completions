#compdef langsmith-cli
# Documentation: https://github.com/langchain-ai/langsmith-cli
# Reference accessed: 2026-05-23
# Verified: langsmith-cli --help (pip langsmith-cli package).

# Zsh completion for langsmith-cli - context-efficient LangSmith agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--json[strict JSON output for agents]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'langsmith-cli command' \
      'annotation-queues[manage annotation queues]' \
      'auth[manage authentication]' \
      'datasets[manage datasets]' \
      'examples[manage dataset examples]' \
      'experiments[view experiment results]' \
      'feedback[manage run feedback]' \
      'projects[manage projects]' \
      'prompts[manage prompts]' \
      'runs[inspect and filter traces]' \
      'self[installation and agent skill docs]' && ret=0
    ;;
  args)
    case $line[1] in
      runs)
        if (( CURRENT == 3 )); then
          _values 'runs command' \
            'list[list recent runs]' \
            'get[get a single run]' \
            'get-latest[get most recent run]' \
            'search[full-text search runs]' \
            'export[export runs to directory]' \
            'stats[aggregated project metrics]' \
            'analyze[analyze runs by tags/metadata]' \
            'cache[manage local JSONL cache]' \
            'describe[field statistics]' \
            'fields[discover run fields]' \
            'metadata-keys[list metadata keys]' \
            'tags[discover tag patterns]' \
            'usage[token usage over time]' \
            'pricing[model pricing coverage]' \
            'sample[stratified sampling]' \
            'open[open run in LangSmith UI]' \
            'view-file[view runs from JSONL]' && ret=0
        fi
        ;;
      self)
        if (( CURRENT == 3 )); then
          _values 'self command' \
            'detect[show install details]' \
            'skill[print agent usage guide]' \
            'update[update langsmith-cli]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
