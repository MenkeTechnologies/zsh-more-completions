#compdef lazydocker
# Documentation: https://github.com/jesseduffield/lazydocker/blob/master/main.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lazydocker (docker TUI). Flag set taken from main.go:
# flaggy.Bool/StringSlice/String. -d means --debug, -f means --file (compose
# files, repeatable), -p means --project (compose project name).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[print the current default config]' \
  '(-d --debug)'{-d,--debug}'[run in debug mode]' \
  '*'{-f,--file}'[alternate compose file (repeatable)]:file:_files' \
  '(-p --project)'{-p,--project}'[docker compose project name]:name:' \
  '--version[show version]' \
  '(- *)'{-h,--help}'[show help]' && ret=0

return ret
