#compdef fzanalyzer
# GMT supplements/gsfml — analyze fracture zone cross-profiles via blend model

local ret=1

_arguments -s \
  '-A+[asymmetry blending min/max/inc]:opts:_default' \
  '-C+[compression model search min/max/inc]:opts:_default' \
  '-D+[central corridor width in km]:width:_default' \
  '-F+[resampled FZ track lines file]:file:_files' \
  '-I+[select FZ id and optional profile]:id:_default' \
  '-S+[output parameters as shell script b|c]:shell:(b c)' \
  '-T+[output file name prefix]:prefix:_default' \
  '-W+[cross-FZ width search min/max/inc]:opts:_default' \
  '*-V[verbose (stackable)]' \
  '-bo+[binary output format]:format:_default' \
  '-do+[replace NaN output with nodata]:nodata:_default' \
  '-i+[input column selection]:cols:_default' \
  '-o+[output column selection]:cols:_default' \
  '-q+[row/data limits]:limits:_default' \
  '*:input table:_files' \
  && ret=0

return ret
