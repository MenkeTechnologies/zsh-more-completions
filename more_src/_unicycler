#compdef unicycler
# Documentation: https://github.com/rrwick/Unicycler
# hybrid assembly pipeline for bacterial genomes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-1 --short1)'{-1,--short1}'+[FASTQ of first short reads]:file:_files' \
  '(-2 --short2)'{-2,--short2}'+[FASTQ of second short reads]:file:_files' \
  '(-s --unpaired)'{-s,--unpaired}'+[FASTQ of unpaired short reads]:file:_files' \
  '(-l --long)'{-l,--long}'+[FASTQ/FASTA of long reads]:file:_files' \
  '(-o --out)'{-o,--out}'+[output directory]:dir:_files -/' \
  '(-t --threads)'{-t,--threads}'+[number of threads]:threads' \
  '--mode=[bridging strategy]:mode:(conservative normal bold)' \
  '--verbosity=[output detail level]:level:(0 1 2 3)' \
  '--min_fasta_length=[minimum contig length for FASTA output]:length' \
  '--keep=[file retention level]:level:(0 1 2 3)' \
  '--linear_seqs=[expected number of linear sequences]:count' \
  '--kmers=[comma-separated k-mer sizes]:kmers' \
  '--kmer_count=[number of k-mer steps]:count' \
  '--depth_filter=[contig depth threshold fraction]:fraction' \
  '--largest_component[keep only largest graph component]' \
  '--spades_path=[path to SPAdes executable]:file:_files' \
  '--racon_path=[path to Racon executable]:file:_files' \
  '--no_miniasm[skip miniasm+Racon bridging]' \
  '--existing_long_read_assembly=[use pre-prepared long-read assembly]:file:_files' \
  '--min_bridge_qual=[bridge quality threshold]:qual' \
  '--no_simple_bridges[skip simple long-read bridging]' \
  '--no_long_read_alignment[skip alignment-based bridging]' \
  '--contamination=[FASTA file of known contaminants]:file:_files' \
  '--min_component_size=[minimum component size in bp]:bp' \
  '--min_dead_end_size=[minimum dead-end size in bp]:bp' \
  '--no_rotate[skip circular contig rotation]' \
  '--start_genes=[FASTA file of genes for rotation start]:file:_files' \
  '--makeblastdb_path=[path to makeblastdb executable]:file:_files' \
  '--tblastn_path=[path to tblastn executable]:file:_files' && ret=0

return ret
