#compdef kwctl

# Zsh completion for kwctl - Kubewarden policy CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'annotate:Annotate a WebAssembly module with Kubewarden metadata'
      'bench:Benchmark a policy'
      'completions:Generate shell completions'
      'digest:Compute digest of a policy'
      'inspect:Inspect a policy'
      'policies:List downloaded policies'
      'pull:Pull a policy from a registry'
      'push:Push a policy to a registry'
      'rm:Remove a downloaded policy'
      'run:Run a policy'
      'scaffold:Scaffold a policy project'
      'verify:Verify a policy'
      'version:Print version information'
      'help:Print help for a command'
    )
    _describe -t commands 'kwctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      pull|push|inspect|verify|digest|run|bench|annotate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:policy URI' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:shell:(bash fish zsh)' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:policy' && ret=0
        ;;
      help)
        local -a commands=(
          'annotate:Annotate a WebAssembly module'
          'bench:Benchmark a policy'
          'completions:Generate shell completions'
          'digest:Compute digest of a policy'
          'inspect:Inspect a policy'
          'policies:List downloaded policies'
          'pull:Pull a policy'
          'push:Push a policy'
          'rm:Remove a policy'
          'run:Run a policy'
          'scaffold:Scaffold a project'
          'verify:Verify a policy'
          'version:Print version'
        )
        _describe -t commands 'kwctl command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
