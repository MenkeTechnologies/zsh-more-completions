#compdef kwctl
# Documentation: https://docs.kubewarden.io/1.21/reference/kwctl-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kwctl (kubewarden/kwctl). Subcommands taken from the Kubewarden 1.21
# CLI reference. Removed from prior file: invented `completions`/`completion`
# spelling (real form: `completions`), `policies`, `version`, and the
# `digest` command's flag set; also fixed missing subcommands `info`,
# `load`, `save`, `manifest`, `verify`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'annotate:add Kubewarden metadata to a WebAssembly module'
      'bench:benchmark a Kubewarden policy'
      'completions:generate shell completions'
      'digest:compute digest of a policy'
      'docs:generate markdown documentation for kwctl commands'
      'info:display system info'
      'inspect:inspect a downloaded policy'
      'load:import a policy from a compressed archive'
      'manifest:generate Kubernetes manifest for a policy'
      'policies:list downloaded policies'
      'pull:pull a policy from a registry'
      'push:publish a policy to an OCI registry'
      'rm:remove a downloaded policy'
      'run:run a policy locally against an AdmissionReview'
      'save:export a policy to a compressed archive'
      'scaffold:scaffold policy-related resources'
      'verify:verify a policy using Sigstore'
    )
    _describe -t commands 'kwctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      annotate)
        _arguments -s -S \
          '(-m --metadata-path)'{-m+,--metadata-path=}'[metadata file]:file:_files' \
          '(-o --output-path)'{-o+,--output-path=}'[output path]:file:_files' \
          '(-u --usage-path)'{-u+,--usage-path=}'[usage path]:file:_files' \
          '*:policy WASM file:_files -g "*.wasm"' && ret=0
        ;;
      bench)
        _arguments -s -S \
          '(-r --request-path)'{-r+,--request-path=}'[admission request file]:file:_files' \
          '--num-samples=[number of samples]:n:' \
          '--num-resamples=[number of resamples]:n:' \
          '--measurement-time=[measurement time]:seconds:' \
          '--warm-up-time=[warm up time]:seconds:' \
          '(-e --execution-mode)'{-e+,--execution-mode=}'[execution mode]:mode:' \
          '*:policy URI:' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '(-s --shell)'{-s+,--shell=}'[target shell]:shell:(bash elvish fish powershell zsh)' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '(-o --output-path)'{-o+,--output-path=}'[output path]:file:_files' \
          '(-k --verification-key)'{-k+,--verification-key=}'[Sigstore key]:file:_files' \
          '--verification-config-path=[Sigstore verification config]:file:_files' \
          '*:policy URI:' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(text json)' \
          '*:policy URI:' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output format]:format:(yaml)' \
          '--show-signatures[show Sigstore signatures]' \
          '*:policy URI:' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-r --request-path)'{-r+,--request-path=}'[admission request file]:file:_files' \
          '(-s --settings-path)'{-s+,--settings-path=}'[settings YAML/JSON]:file:_files' \
          '--settings-json=[settings as JSON literal]:json:' \
          '(-e --execution-mode)'{-e+,--execution-mode=}'[execution mode]:mode:' \
          '*:policy URI:' && ret=0
        ;;
      save)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output archive]:file:_files' \
          '*:policy URI:' && ret=0
        ;;
      load)
        _arguments -s -S \
          '--input=[input archive]:file:_files' && ret=0
        ;;
      docs)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '(-k --verification-key)'{-k+,--verification-key=}'[Sigstore key]:file:_files' \
          '--verification-config-path=[Sigstore verification config]:file:_files' \
          '*:policy URI:' && ret=0
        ;;
      scaffold)
        _arguments -s -S \
          '1:subcommand:(admission-request artifacthub manifest vap verification-config)' && ret=0
        ;;
      digest|rm|policies|info)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
