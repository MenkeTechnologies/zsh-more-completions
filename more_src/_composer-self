#compdef composer-self composer-self-update composer.phar-self-update
# _composer-self — Composer composer-self-update CLI subcommand for upgrading the Composer PHP dependency manager itself rolling back to a previous version or pinning to a specific tagged release (composer team, PHP); Symfony Console
# upstream: https://github.com/composer/composer

_composer-self() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[non-interactive]' \
        '--no-interaction[non-interactive]' \
        '--rollback[rollback to previous version]' \
        '-r[rollback to previous version]' \
        '--clean-backups[clean backups]' \
        '--no-progress[disable progress]' \
        '--no-plugins[disable plugins]' \
        '--no-scripts[disable scripts]' \
        '--update-keys[update GPG keys]' \
        '--stable[use stable channel]' \
        '--snapshot[use snapshot channel]' \
        '--preview[use preview channel]' \
        '--1[force major version 1]' \
        '--2[force major version 2]' \
        '--2.2[stay on long-term-support 2.2]' \
        '--set-channel-only[only set channel]' \
        '--disable-tls[disable TLS]' \
        '--cafile=+[file]:file:_files -g "*.pem *.crt"' \
        '--capath=+[dir]:dir:_files -/' \
        '*:target version:'
}

_composer-self "$@"
