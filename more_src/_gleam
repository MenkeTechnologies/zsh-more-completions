#compdef gleam

# Zsh completion for Gleam (programming language)

_gleam() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'add:add new project dependencies'
    'build:build the project'
    'check:type check the project'
    'clean:clean build artifacts'
    'deps:work with the project dependencies'
    'docs:work with project documentation'
    'export:export something useful from the Gleam project'
    'fix:rewrite deprecated Gleam code'
    'format:format source code'
    'hex:work with the Hex package manager'
    'lsp:run the language server, to be used by editors'
    'new:create a new project'
    'publish:publish the project to Hex'
    'remove:remove project dependencies'
    'run:run the project'
    'shell:start an Erlang shell'
    'test:run the project tests'
    'update:update dependency packages to their latest versions'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'gleam command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        new)
          _arguments -s -S \
            '--name=[name of the project]:name:' \
            '--description=[project description]:description:' \
            '--skip-git[skip git initialization]' \
            '--skip-github[skip GitHub Actions CI files]' \
            '--template=[project template]:template:(lib app)' \
            '1:project name:' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--target=[target platform]:target:(erlang javascript)' \
            '--warnings-as-errors[treat warnings as errors]' \
            '--no-print-progress[do not print progress messages]' \
            && ret=0
          ;;
        check)
          _arguments -s -S \
            '--target=[target platform]:target:(erlang javascript)' \
            && ret=0
          ;;
        run)
          _arguments -s -S \
            '-m+[the module to run]:module:' \
            '--module=[the module to run]:module:' \
            '--target=[target platform]:target:(erlang javascript)' \
            '--runtime=[runtime to use]:runtime:(nodejs deno bun)' \
            '--no-print-progress[do not print progress messages]' \
            '--warnings-as-errors[treat warnings as errors]' \
            '*:arguments:' \
            && ret=0
          ;;
        test)
          _arguments -s -S \
            '--target=[target platform]:target:(erlang javascript)' \
            '--runtime=[runtime to use]:runtime:(nodejs deno bun)' \
            '--no-print-progress[do not print progress messages]' \
            '--warnings-as-errors[treat warnings as errors]' \
            '*:arguments:' \
            && ret=0
          ;;
        add)
          _arguments -s -S \
            '--dev[add as dev dependency]' \
            '1:package name:' \
            && ret=0
          ;;
        remove)
          _arguments -s -S \
            '1:package name:' \
            && ret=0
          ;;
        format)
          _arguments -s -S \
            '--check[check if files are formatted without changing them]' \
            '--stdin[read from stdin and output to stdout]' \
            '*:files:_files -g "*.gleam"' \
            && ret=0
          ;;
        deps)
          _arguments -s -S \
            '1:subcommand:(list download update)' \
            && ret=0
          ;;
        docs)
          _arguments -s -S \
            '1:subcommand:(build publish remove)' \
            && ret=0
          ;;
        hex)
          _arguments -s -S \
            '1:subcommand:(retire unretire revert)' \
            && ret=0
          ;;
        export)
          _arguments -s -S \
            '1:what:(erlang-shipment hex-tarball javascript-prelude typescript-declarations package-interface)' \
            && ret=0
          ;;
        publish)
          _arguments -s -S \
            '--replace[replace an existing version]' \
            '-y[skip confirmation]' \
            '--yes[skip confirmation]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[print version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_gleam "$@"
