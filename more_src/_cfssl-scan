#compdef cfssl-scan

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-family[scanner family to use]:family:(Broad Connectivity TLSHandshake TLSSession PKI)' \
  '-scanner[specific scanner to use]:scanner:' \
  '-timeout[scan timeout]:duration:' \
  '-ip[IP address to connect to]:ip:' \
  '-ca-bundle[CA bundle file]:file:_files' \
  '-exhaustive[test all ciphersuites]' \
  '1:host:' \
  && ret=0

return ret
