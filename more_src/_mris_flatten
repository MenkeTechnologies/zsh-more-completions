#compdef mris_flatten
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_flatten
# Flatten a surface patch

local ret=1

_arguments -s -S \
  '-w[write out the surface every # of iterations]:iterations:' \
  '-distances[neighborhood size and # of vertices at each distance]:nbhd:nvertices:' \
  '-complete[minimize the complete distance distortion matrix]' \
  '*:patch:_files' && ret=0

return ret
