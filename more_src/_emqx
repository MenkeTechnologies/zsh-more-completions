#compdef emqx

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start EMQX in daemon mode'
      'stop:stop the running EMQX node'
      'restart:restart the running EMQX node'
      'console:start EMQX in interactive console mode'
      'foreground:start EMQX in foreground mode'
      'ping:ping the running EMQX node'
      'ctl:administration commands'
      'remote_console:connect to remote console of running node'
      'attach:attach to running node'
      'ertspath:print Erlang runtime path'
      'root_dir:print EMQX root directory'
      'eval:evaluate an Erlang expression'
      'check_conf:check configuration file'
      'version:print version'
    )
    _describe -t commands 'emqx command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      ctl)
        if (( CURRENT == 2 )); then
          local -a ctl_cmds=(
            'status:show broker status'
            'broker:show broker info'
            'cluster:cluster management'
            'clients:list client connections'
            'topics:list topics'
            'subscriptions:list subscriptions'
            'plugins:plugin management'
            'listeners:listener management'
            'mnesia:mnesia database info'
            'trace:trace management'
            'log:log management'
            'mgmt:management API'
          )
          _describe -t commands 'ctl command' ctl_cmds && ret=0
        fi
        ;;
      eval)
        _message 'Erlang expression'
        ;;
    esac
    ;;
esac

return ret
