#compdef kafka-acls
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/AclCommand.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--bootstrap-controller[Controller to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--add[Add ACLs]'
    '--remove[Remove ACLs]'
    '--list[List ACLs]'
    '--cluster[Add/remove cluster ACLs]'
    '--topic[Topic to add/remove ACLs for]:topic:'
    '--group[Consumer group to add/remove ACLs for]:group:'
    '--transactional-id[Transactional ID to add/remove ACLs for]:id:'
    '--delegation-token[Delegation token to add/remove ACLs for]:token:'
    '--resource-pattern-type[Resource pattern type filter]:type:(any match literal prefixed)'
    '--allow-principal[Principal to allow]:principal:'
    '--deny-principal[Principal to deny]:principal:'
    '--principal[Principal to filter when listing ACLs]:principal:'
    '--user-principal[User principal for the resource]:principal:'
    '--allow-host[Host to allow access from]:host:'
    '--deny-host[Host to deny access from]:host:'
    '--operation[Operation to allow or deny]:operation:(All Read Write Create Delete Alter Describe ClusterAction DescribeConfigs AlterConfigs IdempotentWrite CreateTokens DescribeTokens)'
    '--producer[Shortcut to add/remove ACLs for producer role]'
    '--consumer[Shortcut to add/remove ACLs for consumer role]'
    '--idempotent[Enable idempotence for the producer]'
    '--force[Assume yes to all queries and do not prompt]'
)

_arguments -s -S $arguments
