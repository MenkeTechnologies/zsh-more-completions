#compdef gnatmem

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b[print only matching backtrace]' \
  '-i+[max backtrace depth]:n:' \
  '-m+[memory threshold KB]:kb:' \
  '-n+[number of allocations threshold]:n:' \
  '-q[quiet]' \
  '-s[print storage size only]' \
  '-t+[output text file]:file:_files' \
  '*:program_or_dump:_files' && ret=0

return ret
