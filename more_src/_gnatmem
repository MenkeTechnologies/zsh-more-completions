#compdef gnatmem
# Documentation: https://docs.adacore.com/live/wave/gnat_ugn/html/gnat_ugn/gnat_ugn/gnat_and_program_execution.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b[print only matching backtrace]' \
  '-i+[max backtrace depth]:n:' \
  '-m+[memory threshold KB]:kb:' \
  '-n+[number of allocations threshold]:n:' \
  '-q[quiet]' \
  '-s[print storage size only]' \
  '-t+[output text file]:file:_files' \
  '*:program_or_dump:_files' && ret=0

return ret
