#compdef fixit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'lint:lint files for issues'
      'fix:automatically fix lint issues'
      'test:test lint rules'
    )
    _describe -t commands 'fixit command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (lint|fix)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*--rules=[specify rules to use]:rule' \
          '--config-file=[path to config file]:file:_files' \
          '--diff[show diff of changes]' \
          '*:path:_files' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
