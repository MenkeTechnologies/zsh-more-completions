#compdef sfintbin
# Documentation: http://www.ahay.org/RSF/sfintbin.html
# Madagascar: data binning by trace sorting

local ret=1

_arguments -s \
  'head=[header file]:file:_files' \
  'xkey=[x-axis header key number (default fldr)]:xkey' \
  'ykey=[y-axis header key number (default tracf)]:ykey' \
  'xk=[x key name]:xk' \
  'yk=[y key name]:yk' \
  'xmin=[minimum x bin boundary]:xmin' \
  'xmax=[maximum x bin boundary]:xmax' \
  'ymin=[minimum y bin boundary]:ymin' \
  'ymax=[maximum y bin boundary]:ymax' \
  'mask=[output mask file]:file:_files' \
  '*:rsf file:_files' && ret=0

return ret
