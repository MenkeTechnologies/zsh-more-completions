#compdef dpocket
# Documentation: https://github.com/Discngine/fpocket/blob/master/doc/MANUAL.md
# dpocket - extract physico-chemical descriptors of pockets.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[input file: PDB paths + ligand codes, tab-separated]:file:_files' \
  '-o+[output file prefix]:prefix:' \
  '-e[use first explicit interface definition]' \
  '-E[use second explicit interface definition]' \
  '-d+[distance criteria for explicit pocket]:float:' \
  '*:file:_files' && ret=0

return ret
