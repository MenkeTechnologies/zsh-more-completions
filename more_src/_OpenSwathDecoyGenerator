#compdef OpenSwathDecoyGenerator
# Documentation: https://www.openms.org/documentation/html/TOPP_OpenSwathDecoyGenerator.html
# OpenMS: generates decoy transitions for OpenSWATH assay libraries

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input file (tsv, mrm, pqp, TraML)]:file:_files' \
  '-in_type[input file type]:type:(tsv mrm pqp TraML)' \
  '-out[output file (tsv, pqp, TraML)]:file:_files' \
  '-out_type[output file type]:type:(tsv pqp TraML)' \
  '-method[decoy generation method]:method:(shuffle pseudo-reverse reverse shift)' \
  '-decoy_tag[prefix for decoy identifiers]:tag:' \
  '-switchKR[toggle terminal K and R switching]:bool:(true false)' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
