#compdef cyrus-ipurge
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/ipurge.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org ipurge(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-ipurge: expire messages from Cyrus mailboxes by age or size
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-f --include-user-mailboxes)'{-f,--include-user-mailboxes}'[also examine mailboxes below INBOX.* and user.*]' \
  '-d[age of message in days]:days:' \
  '-b[size of message in bytes]:bytes:' \
  '-k[size of message in Kbytes]:kbytes:' \
  '-m[size of message in Mbytes]:mbytes:' \
  '(-x --exact-match)'{-x,--exact-match}'[exact match on age or size]' \
  '(-X --delivery-time)'{-X,--delivery-time}'[use delivery time instead of Date header]' \
  '(-i --invert-match)'{-i,--invert-match}'[invert match logic]' \
  '(-s --skip-flagged)'{-s,--skip-flagged}'[skip messages with \\Flagged set]' \
  '(-o --only-deleted)'{-o,--only-deleted}'[only purge messages with \\Deleted set]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry-run: only print matching messages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:mailbox:' && ret=0
return ret
