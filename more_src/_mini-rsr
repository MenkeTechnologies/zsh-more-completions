#compdef mini-rsr coot-mini-rsr
# Documentation: https://manpages.debian.org/testing/coot/coot-mini-rsr.1.en.html
# Coot mini-rsr - real-space refinement of a residue range

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '--pdbin[input coordinates file]:pdb file:_files' \
  '--hklin[input MTZ reflection data file]:mtz file:_files' \
  '--mapin[input CCP4-format map file]:map file:_files' \
  '--pdbout[output coordinates file]:pdb file:_files' \
  '--dictionary[mmCIF/pdbx restraint dictionary file]:dictionary file:_files' \
  '--f[structure factor column label]:F label:' \
  '--phi[phase column label]:PHI label:' \
  '--resno-start[starting residue number]:res_no_low:' \
  '--resno-end[ending residue number]:res_no_high:' \
  '--residue-number[single residue number]:res_no:' \
  '--residues-around[refine residues surrounding given number]:res_no:' \
  '--chain-id[protein chain identifier]:chain-id:' \
  '--weight[weighting factor for refinement]:weight:' \
  '--radius[refinement radius]:radius:' \
  '--rama[apply Ramachandran restraints]' \
  '--torsions[apply torsion angle restraints]' \
  '--no-planar-peptide-restraints[disable peptide planarity restraints]' \
  '--no-trans-peptide-restraints[disable trans-peptide restraints]' \
  '--tabulate-distortions[report geometry deviations]' \
  '--correlations[calculate map correlations]' \
  '*:file:_files' && ret=0

return ret
