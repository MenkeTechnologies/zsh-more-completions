#compdef xnviewmp

# XnView MP: cross-platform photo viewer/converter (Qt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--start-in=[start in folder]:dir:_files -/' \
  '--browse-mode[start in file browser]' \
  '--no-splash[skip splash screen]' \
  '*:image file or folder:_files' && ret=0
return ret
