#compdef xnviewmp
# Documentation: https://man.archlinux.org/search?q=xnviewmp
# Reference accessed: 2026-05-16

# XnView MP: image viewer / converter (Qt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--fullscreen[start in fullscreen]' \
  '--slideshow[start slideshow]' \
  '*:files / folders:_files' && ret=0
return ret
