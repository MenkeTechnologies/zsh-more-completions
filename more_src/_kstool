#compdef kstool
# _kstool — Keystone assembler driver (keystone-engine/keystone)
# upstream: https://github.com/keystone-engine/keystone
# Flags from kstool/kstool.cpp (getopt).

_kstool() {
    local -a archs
    archs=(
        x16 x32 x64 x16att x32att x64att x16nasm x32nasm x64nasm
        arm armbe thumb thumbbe armv8 armv8be thumbv8 thumbv8be
        arm64 mips mipsbe mips64 mips64be
        ppc32be ppc64 ppc64be sparc sparcbe sparc64be
        systemz hexagon
    )
    local -a args
    args=(
        '(- *)-h[show help]'
        '-b[emit raw binary bytes (no comma between bytes)]'
        "1:arch+mode:($archs)"
        '2:assembly string:'
        '3:start address (hex):'
    )
    _arguments -s $args
}

_kstool "$@"
