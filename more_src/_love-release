#compdef love-release
# Documentation: https://github.com/MisterDA/love-release
# Make LOVE (love2d) game releases easier

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '-D[create a Debian package]' \
  '-M[create a macOS application]' \
  '-W[create a Windows executable]:bits:(32 64)' \
  '(-a --author)'{-a,--author}'[author full name]:author' \
  '(-d --desc)'{-d,--desc}'[project description]:desc' \
  '(-e --email)'{-e,--email}'[author email]:email' \
  '(-t --title)'{-t,--title}'[project title]:title' \
  '(-u --url)'{-u,--url}'[project homepage URL]:url' \
  '-v[project version]:version' \
  '--uti[project Uniform Type Identifier]:uti' \
  '(-l --love)'{-l,--love}'[LOVE version to use]:version' \
  '(-p --package)'{-p,--package}'[package and command name]:package' \
  '*'{-x,--exclude}'[exclude file patterns]:pattern' \
  '-b[compile new or updated files to LuaJIT bytecode]' \
  '*:dir:_files -/' && ret=0

return ret
