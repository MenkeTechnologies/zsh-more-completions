#compdef strongswan charon-cmd
# Documentation: https://manpages.debian.org/bookworm/strongswan-starter/ipsec.8.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm ipsec(8)/strongswan(8) and charon-cmd(8)
# manpages. Subcommands for the ipsec/strongswan control wrapper and
# the charon-cmd authentication client both match upstream.
# Removed from prior file: bogus man.archlinux.org search URL.
# Fixed: removed unverified charon-cmd flags (--ecdsa, --ca, --server,
# --port, --xauth-name, --xauth-password, --initiate). Replaced
# --proposal with the documented --ike-proposal/--esp-proposal/
# --ah-proposal trio, and --xauth-name with --xauth-username.

local curcontext="$curcontext" state line ret=1

case $service in
  (strongswan)
    local -a commands
    commands=(
      'start:parse ipsec.conf and start the IKE daemon'
      'stop:terminate IPsec connections and daemon'
      'restart:stop then start service'
      'reload:reload configuration (SIGUSR1)'
      'update:reload after configuration change (SIGHUP)'
      'up:initiate a connection'
      'down:terminate a connection'
      'route:insert IPsec policy in kernel'
      'unroute:remove IPsec policy'
      'status:concise connection status'
      'statusall:detailed connection status'
      'leases:show pool leases'
      'listalgs:list available algorithms'
      'listpubkeys:list raw public keys'
      'listcerts:list certificates'
      'listcacerts:list CA certs'
      'listaacerts:list AA certs'
      'listocspcerts:list OCSP certs'
      'listacerts:list attribute certs'
      'listgroups:list groups'
      'listcainfos:list CA info records'
      'listcrls:list CRLs'
      'listocsp:list OCSP'
      'listplugins:list plugins'
      'listcounters:list counters'
      'listall:list everything'
      'rereadsecrets:reread secrets'
      'rereadcacerts:reread CA certs'
      'rereadaacerts:reread AA certs'
      'rereadocspcerts:reread OCSP certs'
      'rereadacerts:reread attribute certs'
      'rereadcrls:reread CRLs'
      'rereadall:reread all'
      'resetcounters:reset counters'
      'purgecerts:purge certs'
      'purgecrls:purge CRLs'
      'purgeike:purge IKE SAs'
      'purgeocsp:purge OCSP'
    )
    _arguments -C \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '(- *)--copyright[show copyright]' \
      '--directory[show install directory]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'strongswan command' commands && ret=0 ;;
      (args) _arguments '*: :' && ret=0 ;;
    esac ;;
  (charon-cmd)
    _arguments -C \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '--debug=[debug level]:n:' \
      '--host=[remote host]:host:_hosts' \
      '--identity=[identity]:id:' \
      '--remote-identity=[remote identity]:id:' \
      '--eap-identity=[EAP identity]:id:' \
      '--xauth-username=[XAuth username]:user:' \
      '*--cert=[certificate]:file:_files' \
      '--rsa=[RSA private key]:file:_files' \
      '--p12=[PKCS#12 file]:file:_files' \
      '--agent=[ssh-agent socket]:socket:_files' \
      '--profile=[connection profile]:p:(ikev2-pub ikev2-eap ikev2-byod-eap ikev1-pub-am ikev1-pub-mm ikev1-eap-am ikev1-xauth-am ikev1-xauth-mm ikev1-xauth-rsa-am ikev1-xauth-rsa-mm ikev1-hybrid-am ikev1-hybrid-mm)' \
      '*--local-ts=[local traffic selector]:ts:' \
      '*--remote-ts=[remote traffic selector]:ts:' \
      '*--ike-proposal=[IKE proposal]:p:' \
      '*--esp-proposal=[ESP proposal]:p:' \
      '*--ah-proposal=[AH proposal]:p:' \
      '*: :' && ret=0 ;;
esac

return ret
