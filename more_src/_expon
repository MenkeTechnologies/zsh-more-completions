#compdef expon
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss47.html
# KAPPA: takes the exponential (specified base) of an NDF

local ret=1

_arguments -s \
  'BASE=[base of the exponential (or Natural)]:base' \
  'IN=[input NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
