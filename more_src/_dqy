#compdef dqy
# Documentation: https://github.com/dandyvica/dqy
# A DNS query tool inspired by dig, drill and dog

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--tcp[use TCP protocol instead of default UDP]' \
  '--dot[use DNS over TLS on port 853]' \
  '--https[use DNS over HTTPS on port 443]' \
  '--doq[use DNS over QUIC on port 853]' \
  '--stats[display statistics about the query]' \
  '--json[output results in JSON format]' \
  '--json-pretty[output results in formatted JSON]' \
  '--no-colors[disable colored output]' \
  '-4[force IPv4 transport]' \
  '-6[force IPv6 transport]' \
  '*-v[increase logging verbosity (info to trace)]' \
  '--puny[display domain names in punycode format]' \
  '--timeout=[set network timeout in milliseconds]:ms' \
  '--port=[specify a custom port number]:port' \
  '--alpn[set ALPN protocol for DoT]' \
  '--sni=[add SNI for TLS connections]:name' \
  '--cert=[add PEM self-signed certificate]:file:_files' \
  '--wq=[save raw query bytes to file]:file:_files' \
  '--wr=[save raw response bytes to file]:file:_files' \
  '--log=[save debug output to file]:file:_files' \
  '-l[execute Lua script for custom output formatting]:file:_files' \
  '*:query:_default' && ret=0

return ret
