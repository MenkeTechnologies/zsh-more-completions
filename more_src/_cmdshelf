#compdef cmdshelf
# Documentation: https://github.com/toshi0383/cmdshelf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'remote:manage remote sources (add/remove/list)'
  'run:execute a script from your shelf'
  'list:list available scripts'
  'ls:list available scripts (alias)'
  'cat:print contents of a script'
  'update:refresh all registered remotes'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'cmdshelf command' commands && ret=0 ;;
  args)
    case $line[1] in
      remote)
        _values 'remote action' 'add' 'remove' 'list' && ret=0 ;;
      list|ls)
        _arguments '--path[show absolute file paths]' && ret=0 ;;
    esac ;;
esac

return ret
