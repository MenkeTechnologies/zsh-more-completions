#compdef cmdshelf

# Zsh completion for cmdshelf
# Upstream: Better scripting life with cmdshelf
# Conservative fallback — run `cmdshelf --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
