#compdef pspp-dump-sav
# Documentation: https://manpages.debian.org/testing/pspp/pspp-dump-sav.1.en.html
# pspp-dump-sav - dissect and display SPSS system files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage message]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-d --data)'{-d-,--data=-}'[print the data as well, optionally limited to maxcases]::maxcases:' \
  '*:system file:_files' && ret=0

return ret
