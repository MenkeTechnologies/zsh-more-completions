# Reference accessed: 2026-05-31 via gh api.
#
# iapws CLI surface (decoded source-direct):
#   Subcommands (from select case on get_subcommand()):
#     kh    Compute Henry's constant for gases in H2O/D2O
#       -T VAL_LIST  / --temperature VAL_LIST   (default: 25.0)
#       -f VAL_LIST  / --fugacity VAL_LIST       (default: 1)
#       -g GAS_LIST  / --gas GAS_LIST            (default: O2)
#       --D2O                                    (heavy water)
#       --listgases                              (list and exit)
#     kd    Compute vapor-liquid distribution constant
#       -T / --temperature  (default: 25.0)
#       -x / --x2           (default: 1.0d-9)
#       -g / --gas          (default: H2)
#       --D2O
#       --listgases
#     psat  Compute saturation pressure at temperature
#       -T / --temperature  (default: 25.0)
#     Tsat  Compute saturation temperature at pressure
#       -p / --pressure     (default: 1.0)
#     wp    Compute water properties
#       -T / --temperature  (default: 25.0)
#       -p / --pressure     (default: 1.0)
#       -F / --psat         (boolean: include psat?)
#
# Global (auto-injected by M_CLI2):
#   -h / --help              auto-help
#   -V / --version           auto-version
#   @file.rsp                response-file expansion
#                            (enabled by set_mode('response_file'))
#
# Gas values: He, Ne, Ar, Kr, Xe, H2, D2, N2, O2,
# CO, CO2, H2S, CH4, C2H6, SF6, H2O, D2O (from
# get_mm function at main.f90:240-280).
#
# iapws is a Fortran CLI for computing properties
# of light and heavy water according to the IAPWS
# (International Association for the Properties of
# Water and Steam) formulations — fundamental
# thermodynamic data used in steam-turbine
# engineering and atmospheric science.  Authored
# by Milan Skocic (7 GH stars).  Sister tools:
# coolprop (broader fluid-property C++ library, not
# in corpus), refprop (NIST REFPROP, proprietary).
#
# Critical extraction note: iapws uses **Fortran
# `M_CLI2` library** at main.f90:3 — corpus's
# **first documented Fortran CLI library**.
# M_CLI2 (urbanjost/M_CLI2) is the de-facto
# modern Fortran CLI library, distributed via
# fpm (Fortran Package Manager — itself in corpus
# as `_fpm`).  Distinct from `iso_fortran_env`
# command_argument_count + get_command_argument
# (Fortran 2003 stdlib for raw argv access; no
# parsing — caller writes manual loops).  M_CLI2
# provides: single-string-packed spec, named-
# import-with-rename via `=>`, response-file
# expansion (`@file.rsp`), automatic help/version
# generation, type-coercion via `get_args` /
# `iget` / `dgets` / `lget`, comma-separated
# value parsing into arrays.  Extends cross-
# language CLI taxonomy to FORTY-NINE library
# variants: Rust (6), Go (4), Python (3),
# Crystal 1 OptionParser (R269), Haskell (R270),
# OCaml (R271), C (R272), Java (R276),
# Kotlin (R277), Scala (R278), Dart (R279),
# Ruby (R280), Perl (R281), PHP (R282),
# Swift (R283), F# (R284), Lua (R285), C# (R286),
# Nim 1 parseopt (R287), Zig (R288), D (R289),
# Racket (R290), Common Lisp 1 (R291),
# Erlang (R292), Tcl (R293), Pharo Smalltalk (R294),
# Common Lisp 2 clingon (R295), Julia (R296),
# SWI-Prolog optparse (R297), Pony stdlib cli (R298),
# Crystal 2 Admiral (R299), V stdlib `flag` (R300),
# Nim 2 cligen (R301), Clojure babashka.cli (R302),
# Gleam Glint (R303), Ada GNAT.Command_Line (R304),
# C++ CLI11 (R305), Elixir Optimus (R306), Vala
# GLib.OptionContext (R307), Hare stdlib getopt
# (R308), Standard ML stdlib GetOpt (R309),
# **Fortran M_CLI2** (R310 — NEW).  **MAJOR
# PATTERN MILESTONE**: 49 cross-language CLI
# library variants documented.  Fortran joins the
# taxonomy as one of the oldest languages with
# active CLI tooling (Fortran 77 / 90 / 95 / 2003
# / 2008 / 2018 / 2023 evolution).
#
# Critical extraction note: iapws uses **M_CLI2
# single-string-packed spec via `set_args(SPEC_
# STRING, HELP, VERSION)`** at main.f90:171 et
# seq — `set_args('--temperature:T 25.0 --fugacity:
# f 1 --gas:g O2 --D2O --listgases', help_text,
# version_text)`.  The SPEC STRING contains ALL
# flags with their defaults inline.  Syntax:
#   `--long:short DEFAULT`  ← option with default
#   `--long:short`          ← option (no default)
#   `--long`                ← boolean flag
#   `--long DEFAULT`        ← option with default (no short)
# The `:` is the LONG-SHORT-ALIAS SEPARATOR.
# Boolean flags are toggled by presence.  Distinct
# from R272 C POSIX getopt (option-string `"a:b:cd"`
# — short flags only), R301 Nim cligen (proc-
# signature), R304 Ada postfix-marker (`-X:`),
# R307 Vala GLib (OptionEntry struct table), R308
# Hare (tagged-union array).  M_CLI2's SINGLE-
# STRING SPEC is UNIQUE: ALL the flag metadata
# lives in ONE compact string.  Corpus's **first
# documented single-string-packed-spec CLI
# pattern**.
#
# Critical extraction note: iapws uses **Fortran
# `args=>unnamed` rename-on-import** at main.f90:3
# — `use M_CLI2, only: ..., args=>unnamed, ...`.
# Fortran's `use, only:` IMPORT directive accepts
# `LOCAL_NAME=>ORIGINAL_NAME` rename mappings.
# Here `unnamed` (M_CLI2's internal positional-
# args array) is renamed to `args` in the
# importing scope.  Distinct from R302 Clojure
# babashka.cli (`:as cli` namespace alias), R303
# Gleam Glint (no rename), R307 Vala GLib (no
# rename — `using` brings the entire namespace),
# R308 Hare (no rename — `use getopt;` brings
# entire module).  Fortran's approach: PER-NAME
# RENAME at IMPORT TIME — finer-grained than
# whole-namespace aliasing.  Corpus's **first
# documented named-import-with-rename CLI
# pattern**.
#
# Critical extraction note: iapws uses **M_CLI2
# `set_mode('strict')` + `set_mode('response_
# file')` configuration** at main.f90:165-166 —
# `'strict'` mode REJECTS unknown flags;
# `'response_file'` enables `@file.rsp` SHELL-
# RESPONSE-FILE expansion (argv tokens like
# `@options.rsp` are replaced with the file's
# contents line-by-line).  Distinct from R304
# Ada GNAT.Command_Line (no response-file
# support), R307 Vala GLib (`oc.parse(ref args)`
# no mode), R308 Hare (single mode), R309 SML
# GetOpt (tri-state argOrder).  M_CLI2's
# response-file feature is a UNIX ARGUMENT-FILE
# convention from `gcc @file` and `javac @file`.
# Corpus's **first documented response-file-
# expansion CLI pattern**.
#
# Critical extraction note: iapws uses **M_CLI2
# typed-retrieval functions `get_args` / `iget`
# / `dgets` / `lget`** at main.f90:173-188 —
# different functions for different return types:
#   `get_args(NAME, target_array)`  ← typed by target
#   `iget(NAME)`                    ← integer scalar
#   `lget(NAME)`                    ← logical (bool)
#   `dgets(NAME)`                   ← allocatable double array
# Distinct from R301 Nim cligen (parsed values
# returned directly via dispatch), R302 Clojure
# babashka.cli (single parsed-opts map), R303
# Gleam Glint (typed accessor functions via
# use-callback closure), R305 C++ CLI11 (reference-
# bound at spec time), R306 Elixir Optimus
# (ParseResult struct with options/args fields),
# R308 Hare (anonymous tuple `opt.0`/`opt.1`).
# M_CLI2's approach: TYPE-NAMED ACCESSOR FUNCTIONS
# — sister to R311 Ada (Get_Integer/Get_String
# from GNAT.Command_Line.Get_Command_Line) but
# Fortran's accessors are GLOBAL-MODULE functions
# rather than module-instance methods.  Corpus's
# **first documented type-named-accessor-function
# CLI pattern**.
#
# Critical extraction note: iapws uses **Fortran
# `select case (cmd) case ("kh") case ("kd") ...
# case default` subcommand dispatch** at main.f90:
# 169-228 — each subcommand arm RE-CALLS
# `set_args` with a FRESH SPEC describing THAT
# SUBCOMMAND'S flags.  Distinct from R302 Clojure
# babashka.cli (data-vector dispatch via `cli/
# dispatch` walks the command list once), R303
# Gleam Glint (each `glint.add(at:, do:)` builds
# the tree at spec time, then `glint.execute`
# walks it), R306 Elixir Optimus (single
# `Optimus.parse!` returns atom-path tuple), R307
# Vala GLib (no subcommand support natively).
# M_CLI2's approach: CALLER-DRIVEN PER-SUBCOMMAND
# RE-SPEC — each subcommand has its OWN set_args
# call inside its case arm.  Corpus's **first
# documented per-arm-respec CLI dispatch pattern**.
#
# Hunt-skip notes: skipped `_fpm` (Fortran Package
# Manager, already in corpus + blacklisted — uses
# M_CLI2 too but more complex 442-line CLI
# surface).  Skipped `_crest` (317 stars — uses
# HANDWRITTEN argv loops with `==` comparisons,
# not M_CLI2; deferred until handwritten-parser-
# pattern round).  Skipped `_unison` (DUP with
# stock zsh).  Probed `victorsndvg/FEconv` (107
# stars, FE format converter — uses M_CLI2 but
# spec is split across module_args.f90 and
# module_feconv.f90; harder to extract source-
# direct), `MilanSkocic/iapws` (CHOSEN — 7 stars,
# 5 subcommands in single 442-line main.f90,
# exercises EVERY MAJOR M_CLI2 PATTERN), `urbanjost/
# M_CLI2/example/demo3.f90` (THE LIBRARY ITSELF
# example; not a real binary), `djean032/zfit_fort`
# (0 stars, too small), `urbanjost/general-purpose-
# fortran` (UTILITY DEMOS, not a single binary).
# Lean detour from R309: skipped further Lean tools
# pending standalone-binary Cli-library example.
# Chose iapws: SINGLE-FILE 442-line CLI with 5
# subcommands (kh, kd, psat, Tsat, wp), exercises
# EVERY MAJOR M_CLI2 PATTERN (set_args single-
# string-packed spec, set_mode response-file
# expansion, get_subcommand for dispatch, get_args
# / iget / lget / dgets typed retrievers, args=>
# unnamed import rename, comma-separated value
# parsing), real numerical-computing binary
# distributed via fpm registry.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Gas-name completion candidates from get_mm at
# main.f90:240-280
local -a iapws_gases=(
  'He:Helium'
  'Ne:Neon'
  'Ar:Argon'
  'Kr:Krypton'
  'Xe:Xenon'
  'H2:Hydrogen gas'
  'D2:Deuterium gas'
  'N2:Nitrogen gas'
  'O2:Oxygen gas (DEFAULT for kh)'
  'CO:Carbon monoxide'
  'CO2:Carbon dioxide'
  'H2S:Hydrogen sulfide'
  'CH4:Methane'
  'C2H6:Ethane'
  'SF6:Sulfur hexafluoride'
  'H2O:Light water'
  'D2O:Heavy water'
)
# 5 subcommands from select case at main.f90:169-228
local -a iapws_subcmds=(
  'kh:Henry constant for gases in H2O/D2O'
  'kd:Vapor-liquid distribution constant'
  'psat:Saturation pressure at temperature'
  'Tsat:Saturation temperature at pressure'
  'wp:Water properties at temperature and pressure'
)

_arguments -C \
  '(- *)'{-h,--help}'[display M_CLI2 auto-generated help]' \
  '(- *)'{-V,--version}'[display version information]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'iapws subcommand' iapws_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      kh)
        _arguments -s -S \
          '(-T --temperature)'{-T+,--temperature=}'[temperature(s) in degC, comma-separated (default: 25.0)]:degC list:' \
          '(-f --fugacity)'{-f+,--fugacity=}'[fugacity values, comma-separated (default: 1)]:fugacity list:' \
          '(-g --gas)'{-g+,--gas=}'[gas formula(s), comma-separated (default: O2)]:gas:->gases' \
          '--D2O[compute for heavy water D2O instead of H2O]' \
          '--listgases[list valid gases for the chosen solvent and exit]' \
          '(-h --help)'{-h,--help}'[help]' && ret=0
        ;;
      kd)
        _arguments -s -S \
          '(-T --temperature)'{-T+,--temperature=}'[temperature(s) in degC, comma-separated (default: 25.0)]:degC list:' \
          '(-x --x2)'{-x+,--x2=}'[mole-fraction values, comma-separated (default: 1.0d-9)]:x2 list:' \
          '(-g --gas)'{-g+,--gas=}'[gas formula(s), comma-separated (default: H2)]:gas:->gases' \
          '--D2O[compute for heavy water D2O instead of H2O]' \
          '--listgases[list valid gases for the chosen solvent and exit]' \
          '(-h --help)'{-h,--help}'[help]' && ret=0
        ;;
      psat)
        _arguments -s -S \
          '(-T --temperature)'{-T+,--temperature=}'[temperature(s) in degC, comma-separated (default: 25.0)]:degC list:' \
          '(-h --help)'{-h,--help}'[help]' && ret=0
        ;;
      Tsat)
        _arguments -s -S \
          '(-p --pressure)'{-p+,--pressure=}'[pressure(s) in bar, comma-separated (default: 1.0)]:bar list:' \
          '(-h --help)'{-h,--help}'[help]' && ret=0
        ;;
      wp)
        _arguments -s -S \
          '(-T --temperature)'{-T+,--temperature=}'[temperature(s) in degC, comma-separated (default: 25.0)]:degC list:' \
          '(-p --pressure)'{-p+,--pressure=}'[pressure(s) in bar, comma-separated (default: 1.0)]:bar list:' \
          '(-F --psat)'{-F,--psat}'[include psat in output]' \
          '(-h --help)'{-h,--help}'[help]' && ret=0
        ;;
    esac
    case $state in
      gases)
        _describe -t gas_kinds 'gas formula' iapws_gases && ret=0
        ;;
    esac
    ;;
esac

return ret
