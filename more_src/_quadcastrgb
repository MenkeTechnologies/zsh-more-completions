#compdef quadcastrgb
# Documentation: https://github.com/Ors1mer/QuadcastRGB
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for QuadcastRGB - HyperX QuadCast S / Duocast RGB CLI

local curcontext="$curcontext" state line ret=1

local -a modes=(
  'solid:constant color'
  'blink:blinking effect'
  'cycle:rainbow cycling'
  'wave:wave animation'
  'lightning:lightning effect'
  'pulse:pulsing effect'
)

_arguments -s -S \
  '-a[apply to whole microphone]' \
  '-u[upper diode section]' \
  '-l[lower diode section]' \
  '-b[brightness]:brightness:' \
  '1:mode:->mode' \
  '*: :' && ret=0

case $state in
  mode)
    _describe -t modes 'quadcastrgb mode' modes && ret=0
    ;;
esac

return ret
