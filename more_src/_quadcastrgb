#compdef quadcastrgb

# Zsh completion for HyperX QuadCast S / Duocast RGB CLI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:args:{ _message "device index / RGB mode — see quadcastrgb -h" }' && ret=0

return ret
