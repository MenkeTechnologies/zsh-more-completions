#compdef density
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/density.html
# density - Draw a nucleic acid density plot

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-seqall[input nucleotide sequence(s)]:file:_files' \
  '-graph[output graphics format]:device:' \
  '-outfile[output report file]:file:_files' \
  '-window[sliding window length]:size:' \
  '-display[visualization type]:display:(Dual Quad none)' \
  '-sbegin1[sequence start position]:pos:' \
  '-send1[sequence end position]:pos:' \
  '-sreverse1[reverse the sequence]' \
  '-sformat1[input sequence format]:format:' \
  '-gtitle[graph title]:title:' \
  '-gsubtitle[graph subtitle]:subtitle:' \
  '-gxtitle[graph x-axis title]:title:' \
  '-gytitle[graph y-axis title]:title:' \
  '-rformat[report format]:format:' \
  '-raccshow[show accession in report]' \
  '-rdesshow[show description in report]' \
  '-auto[turn off prompts]' \
  '-verbose[report command line options]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
