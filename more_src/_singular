#compdef Singular singular
# Documentation: https://manpages.opensuse.org/Tumbleweed/singular/Singular.1.en.html
# Reference accessed: 2026-05-21
# Verified: openSUSE Tumbleweed Singular(1) man page.

_arguments -s \
  '(-b --batch)'{-b,--batch}'[batch mode (requires --link/--MPhost/--MPport)]' \
  '(-c --execute)'{-c,--execute}'=[execute STRING on start-up]:string:' \
  '(-d --sdb)'{-d,--sdb}'[enable source code debugger (experimental)]' \
  '(-e --echo)'{-e,--echo}'=[set echo variable to integer VAL]:val:' \
  '(- *)'{-h,--help}'[print help and exit]' \
  '(-p --profile)'{-p,--profile}'[collect profiling data in smon.out]' \
  '(-q --quiet)'{-q,--quiet}'[no start-up banner / lib load messages]' \
  '(-r --random)'{-r,--random}'=[seed random generator with SEED]:n:' \
  '(-t --no-tty)'{-t,--no-tty}'[do not redefine terminal characteristics]' \
  '(-u --user-option)'{-u,--user-option}'=[return STRING via system("--user-option")]:string:' \
  '(- *)'{-v,--version}'[print extended version and configuration info]' \
  '--allow-net[fetch help pages from internet]' \
  '--browser=[browser for help pages]:browser:' \
  '--cntrlc=[automatic response for CTRL-C prompts]:char:' \
  '--emacs[configure for emacs integration]' \
  '--log=[log all input to LOGFILE]:file:_files' \
  '--no-stdlib[do not load standard.lib at startup]' \
  '--no-rc[do not execute .singularrc files]' \
  '--no-warn[suppress warning messages]' \
  '--no-out[suppress all output]' \
  '--no-shell[restricted mode (no shell escapes or links)]' \
  '--min-time=[hide timing info below SECS seconds]:secs:' \
  '--cpus=[limit CPU usage]:n:' \
  '--threads=[limit thread count]:n:' \
  '--flint-threads=[limit flint library threads]:n:' \
  '--MPport=[set MP connection port]:port:' \
  '--MPhost=[set MP connection host]:host:' \
  '--link=[set connection method]:link:' \
  '--ticks-per-sec=[set timer granularity]:ticks:' \
  '--dump-versiontuple[display version tuple and exit]' \
  '*:file:_files'
