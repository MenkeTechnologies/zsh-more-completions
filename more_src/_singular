#compdef Singular singular
# Documentation: https://man.archlinux.org/search?q=Singular
# Reference accessed: 2026-05-16

_arguments -s \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '(-c --execute)'{-c,--execute}'=[code]:cmd:' \
  '(-d --sdb)'{-d,--sdb}'[debugger]' \
  '(-e --echo)'{-e,--echo}'=[echo level]:n:' \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --profile)'{-p,--profile}'[profile]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-r --random)'{-r,--random}'=[seed]:n:' \
  '(-t --no-tty)'{-t,--no-tty}'[no tty]' \
  '(-u --user-option)'{-u,--user-option}'=[user option]:str:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--allow-net[allow net]' \
  '--browser=[browser]:browser:' \
  '--cntrlc=[CTRL-C answer]:char:' \
  '--emacs[emacs mode]' \
  '--no-stdlib[no stdlib]' \
  '--no-rc[no .singularrc]' \
  '--no-warn[no warnings]' \
  '--no-out[no output]' \
  '--no-shell[no shell]' \
  '--min-time=[seconds]:n:' \
  '--cpus=[CPUs]:n:' \
  '--threads=[threads]:n:' \
  '--flint-threads=[flint threads]:n:' \
  '--MPport=[MP port]:port:' \
  '--MPhost=[MP host]:host:' \
  '--link=[link type]:type:' \
  '--ticks-per-sec=[ticks]:n:' \
  '*:file:_files'
