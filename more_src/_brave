#compdef brave brave-browser brave-browser-stable brave-browser-beta brave-browser-nightly
# Documentation: https://support.brave.app/hc/en-us/articles/360044860011
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--incognito[private window]' \
  '--tor[open a Tor window]' \
  '--new-window[open in a new window]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--no-default-browser-check[skip default browser check]' \
  '--no-first-run[skip first-run dialog]' \
  '--disable-gpu[disable GPU acceleration]' \
  '--user-data-dir=[user data directory]:dir:_files -/' \
  '--profile-directory=[profile name]:profile:' \
  '--proxy-server=[HTTP proxy server]:url:' \
  '--proxy-bypass-list=[proxy bypass]:list:' \
  '--proxy-pac-url=[PAC URL]:url:' \
  '--lang=[UI language]:lang:' \
  '--remote-debugging-port=[remote debugging port]:port:' \
  '--remote-debugging-address=[remote debugging host]:host:_hosts' \
  '--app=[run as web app for URL]:url:' \
  '--ozone-platform=[Ozone platform]:platform:(wayland x11 auto)' \
  '--enable-features=[enable Chromium features]:features:' \
  '--disable-features=[disable Chromium features]:features:' \
  '--password-store=[secret store]:store:(basic gnome-libsecret kwallet5 kwallet6)' \
  '--start-fullscreen[start fullscreen]' \
  '--start-maximized[start maximized]' \
  '--kiosk[run in kiosk mode]' \
  '--reset-variation-state[reset variation state]' \
  '*:url_or_file:_files' && ret=0

return ret
