#compdef brctl
# Documentation: man brctl(8)
# Source: shemminger/bridge-utils brctl/brctl_cmd.c (master) — Linux ethernet bridge admin (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'addbr:create a new bridge'
    'delbr:delete a bridge'
    'addif:add interface to bridge'
    'delif:remove interface from bridge'
    'hairpin:turn hairpin on/off for a port'
    'setageing:set ageing time'
    'setbridgeprio:set bridge priority'
    'setfd:set bridge forward delay'
    'sethello:set hello time'
    'setmaxage:set max message age'
    'setpathcost:set path cost'
    'setportprio:set port priority'
    'show:list bridges'
    'showmacs:show MAC address learning table'
    'showstp:show STP info'
    'stp:turn STP on/off'
)

_arguments -s -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:command:->cmd' \
    '2::bridge:_net_interfaces' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'brctl command' cmds && ret=0 ;;
esac

return ret
