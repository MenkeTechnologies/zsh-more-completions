#compdef brctl
# _brctl — Linux bridge-utils brctl (legacy Linux ethernet bridge control: addbr/delbr a bridge, addif/delif a port, show/showmacs/showstp; tune ageing/hello/maxage/fd/pathcost/priority; toggle STP)
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/shemminger/bridge-utils.git
# Subcommands from bridge-utils brctl/brctl.c on tip.

_brctl() {
    _arguments \
        '1:command:(addbr delbr addif delif show showmacs showstp setageing setbridgeprio setfd sethello setmaxage setpathcost setportprio stp setbridgemcastsnoop hairpin)' \
        '*::arg:'
}

_brctl "$@"
