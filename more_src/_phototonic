#compdef phototonic
# Documentation: https://man.archlinux.org/search?q=phototonic
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:image:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.cr2 *.nef *.arw *.dng *.raw *.heic *.heif"' && ret=0

return ret
