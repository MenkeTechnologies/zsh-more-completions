#compdef ctl
# Documentation: https://github.com/melbahja/ctl
# Reference accessed: 2026-05-17
# Verified: melbahja/ctl systemd wrapper (Go). Not ACES CTL color
# transformation language (which has no standalone `ctl` binary).
# Removed from prior file: bogus man.archlinux.org search URL;
# malformed brace expansion `{{...}}` (zsh _arguments syntax error);
# stray non-comment "ACES CTL color transformation language" line.

# ctl: melbahja/ctl systemd wrapper
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'status:wrap systemctl unit status'
  'log:wrap journalctl'
  'mount:wrap systemd-mount'
  'run:wrap systemd-run'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--system[system mode]' \
  '--user[user mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (log) _arguments '--boot[current boot only]' && ret=0 ;;
      (run) _arguments '--scope[run as scope]' && ret=0 ;;
    esac
    ;;
esac
return ret
