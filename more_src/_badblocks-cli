#compdef badblocks-cli
# _badblocks-cli — Theodore Ts'o badblocks search disk for bad sectors CLI alias (e2fsprogs team, C); custom argparse
# upstream: https://github.com/tytso/e2fsprogs

_badblocks-cli() {
    _arguments \
        '--help[show help]' \
        '-V[show version]' \
        '-b+[block size bytes]:n:' \
        '-c+[blocks at once]:n:' \
        '-d+[ms delay between reads]:n:' \
        '-e+[max bad blocks]:n:' \
        '-f[force]' \
        '-i+[input bad blocks file]:file:_files' \
        '-o+[output bad blocks file]:file:_files' \
        '-p+[passes]:n:' \
        '-s[show progress]' \
        '-t+[test pattern]:str:' \
        '-v[verbose]' \
        '-w[write-mode test (destructive)]' \
        '-n[non-destructive read-write test]' \
        '-X[expert mode]' \
        '-B[use buffered I/O]' \
        '*:device:_files -g "/dev/{sd,hd,nvme}*"'
}

_badblocks-cli "$@"
