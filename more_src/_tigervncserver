#compdef tigervncserver vncserver

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-list[list running TigerVNC servers]' \
  '-kill[kill the TigerVNC server]' \
  '-cleanstale[clean stale files first]' \
  '-useold[only start if not already running]' \
  '-autokill[kill server when session script exits]' \
  '-fg[run in foreground]' \
  '-dry-run[only perform safety checks]' \
  '-verbose[verbose/debug output]' \
  '-version[show version]' \
  '-noxstartup[do not run xstartup]' \
  '-xstartup=[xstartup file]:file:_files' \
  '-rfbport=[TCP port (default 5900+disp)]:port:' \
  '-localhost=[bind only to localhost]:bool:(yes no)' \
  '-SecurityTypes=[security types]:types:(None VncAuth Plain TLSNone TLSVnc TLSPlain X509None X509Vnc X509Plain)' \
  '-sec-types=[security types (alt)]:types:(None VncAuth Plain TLSNone TLSVnc TLSPlain X509None X509Vnc X509Plain)' \
  '-PasswordFile=[VNC password file]:file:_files' \
  '-PlainUsers=[allowed PlainUsers]:users:_users' \
  '-X509Cert=[X.509 certificate]:file:_files' \
  '-X509Key=[X.509 key]:file:_files' \
  '-geometry=[screen geometry WxH]:WxH:' \
  '-depth=[color depth]:n:(8 16 24 32)' \
  '-pixelformat=[pixel format]:fmt:' \
  '-name=[session name]:name:' \
  '-AllowOverride=[allowed overrides]:options:' \
  '-AcceptKeyEvents=[accept key events]:bool:(0 1)' \
  '-AcceptPointerEvents=[accept pointer events]:bool:(0 1)' \
  '-AcceptCutText=[accept cut text]:bool:(0 1)' \
  '-SendCutText=[send cut text]:bool:(0 1)' \
  '-AcceptSetDesktopSize=[accept SetDesktopSize]:bool:(0 1)' \
  '-DisconnectClients=[disconnect existing clients]:bool:(0 1)' \
  '-AlwaysShared[always shared]' \
  '-NeverShared[never shared]' \
  '*:display_number:' && ret=0

return ret
