_arguments -n : \
  '(-c --config)'{-c,--config}'=[configuration file path]:file:_files' \
  '(-h --host)'{-h,--host}'=[bind host]' \
  '(-p --port)'{-p,--port}'=[bind port]' \
  '--cleanup_cycle=[days for cleanup cycle]:days' \
  '--work_dir=[working directory]:WorkDir:_files -/' \
  '--server_url=[ukigumo-server URL]' \
  '--timeout=[timeout in seconds]:seconds' \
  '--ignore_github_tags[ignore GitHub tag push events]' \
  '--force_git_url[always use Git URL]' \
  '--skip_if_unmodified[skip testing if repository unchanged]' \
  '*: :()'

