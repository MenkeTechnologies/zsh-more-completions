#compdef dmenu dmenu_run dmenu_path
# _dmenu — Suckless dmenu dynamic X11 menu for application launcher (suckless team, C); getopt
# upstream: https://tools.suckless.org/dmenu/

_dmenu() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-b[appear at bottom]' \
        '-c[centered]' \
        '-f[fast startup]' \
        '-i[case insensitive]' \
        '-l+[lines]:n:' \
        '-m+[monitor]:n:' \
        '-p+[prompt]:str:' \
        '-fn+[font]:font:' \
        '-nb+[normal bg]:color:' \
        '-nf+[normal fg]:color:' \
        '-sb+[selected bg]:color:' \
        '-sf+[selected fg]:color:' \
        '-w+[window id]:wid:' \
        '-x+[x offset]:n:' \
        '-y+[y offset]:n:' \
        '-z+[width]:n:' \
        '-bw+[border width]:n:' \
        '-P[password prompt]'
}

_dmenu "$@"
