#compdef stateset
# Documentation: https://github.com/stateset/icommerce-quickstart
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Source: stack/stateset bash orchestrator in stateset/icommerce-quickstart

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'up:start anvil + deploy + seed FX + bridges'
  'down:stop anvil + bridges'
  'status:process state'
  'show:on-chain state (SSDC supply, NAV, FX freshness)'
  'deploy:forge script DeployLocal --broadcast'
  'deploy\:sepolia:forge script DeploySepolia --broadcast --verify'
  'seed-fx:refresh EUR/GBP/JPY/MXN quotes on FxOracle'
  'bridges:start on-ramp + off-ramp bridges'
  'bridges\:stop:stop bridges'
  'demo:run a demo (lifecycle|realmoney|verify)'
  'audit:verify-receipt against a path'
  'receipts:list receipt JSON files in the repo'
  'test:contracts + bridges + demos'
  'gates:run every non-chain CI gate locally'
  'bench:forge gas reports'
  'bench\:snapshot:regenerate .gas-snapshot'
  'bench\:diff:diff against committed snapshot'
  'doctor:health check (--fix to auto-remediate)'
  'version:print versions'
  'clean:remove build/runtime artifacts'
  'completion:emit shell completion (bash|zsh)'
  'help:show help'
)

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'stateset command' commands && ret=0 ;;
  args)
    case ${line[1]} in
      demo) _values 'demo' 'lifecycle' 'realmoney' 'verify' && ret=0 ;;
      completion) _values 'shell' 'bash' 'zsh' && ret=0 ;;
      audit) _arguments '*:receipt file:_files -g "*.json"' && ret=0 ;;
      doctor) _arguments '--fix[auto-remediate]' && ret=0 ;;
      clean) _arguments '--all[also remove contracts/lib]' && ret=0 ;;
    esac
    ;;
esac

return ret
