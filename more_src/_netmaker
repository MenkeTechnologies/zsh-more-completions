#compdef netmaker netclient
# Documentation: https://github.com/gravitl/netclient
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_netmaker_commands() {
  local -a commands=(
    'completion:generate shell completions'
    'connect:connect to a joined network'
    'daemon:run netclient as daemon'
    'disconnect:disconnect from a joined network'
    'help:help about any command'
    'install:install netclient binary and systemd unit'
    'join:join a network'
    'leave:leave a network'
    'list:list joined networks'
    'pull:pull latest network config from server'
    'uninstall:uninstall netclient'
    'version:show version'
  )
  _describe -t commands 'netmaker command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'=[log verbosity level]:level:(0 1 2 3 4)' \
  '--config=[config file]:file:_files' \
  '1:command:_netmaker_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      join)
        _arguments -s -S \
          '(-t --token)'{-t,--token}'=[enrollment token]:token:' \
          '(-n --network)'{-n,--network}'=[network name]:name:' \
          '(-u --user)'{-u,--user}'=[username]:user:_users' \
          '(-s --server)'{-s,--server}'=[server/API endpoint]:url:_urls' && ret=0
        ;;
      leave)
        _arguments -s -S \
          '(-n --network)'{-n,--network}'=[network name]:name:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
