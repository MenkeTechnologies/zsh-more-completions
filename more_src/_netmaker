#compdef netmaker

local curcontext="$curcontext" state line ret=1

_netmaker_commands() {
  local -a commands=(
    'completion:generate shell completions'
    'join:join a network'
    'leave:leave a network'
    'list:list networks'
    'pull:pull latest network config'
    'push:push local config to server'
    'connect:connect to the network'
    'disconnect:disconnect from the network'
    'daemon:run as daemon'
    'install:install netclient'
    'uninstall:uninstall netclient'
    'server:run the netmaker server'
  )
  _describe -t commands 'netmaker command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbosity[log verbosity level]:level:(0 1 2 3 4)' \
  '1:command:_netmaker_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      join)
        _arguments -s -S \
          '--token[enrollment token]:token' \
          '--network[network name]:name' \
          '--endpoint[endpoint IP]:ip' \
          '--port[port]:port' \
          '--name[node name]:name' \
          '--dns[enable DNS]:enabled:(on off)' && ret=0
        ;;
      leave)
        _arguments -s -S \
          '--network[network name]:name' \
          '--force[force leave]' && ret=0
        ;;
      server)
        _arguments -s -S \
          '--config[config file]:file:_files' \
          '--masterkey[master key]:key' \
          '--api-port[API port]:port' \
          '--dns-mode[enable DNS mode]' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
