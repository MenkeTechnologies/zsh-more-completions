#compdef git-recent

# Zsh completion for git recent (show recent branches)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-n --count)'{-n,--count}'[number of branches to show]:count:' \
  '--no-color[disable color output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
