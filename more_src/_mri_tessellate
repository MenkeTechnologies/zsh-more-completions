#compdef mri_tessellate
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_tessellate
# FreeSurfer: tessellate a label within a volume into a surface

local ret=1

_arguments -s -S \
  '-a[tessellate the surface of all voxels with different labels]' \
  '-n[save surface with real RAS coordinates]' \
  '1:input volume:_files' \
  '2:label value (127 rh, 255 lh)' \
  '3:output surface:_files' && ret=0

return ret
