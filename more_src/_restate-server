#compdef restate-server
# Documentation: https://docs.restate.dev/operate/configuration/server/
# restate-server - Restate durable execution server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config-file=[path to TOML config file]:file:_files' \
  '--node-name=[unique node name]:name' \
  '--force-node-id=[force a specific node id]:id' \
  '--cluster-name=[cluster name]:name' \
  '--base-dir=[base working directory]:dir:_files -/' \
  '--bind-address=[address to bind on]:address' \
  '--advertised-address=[address advertised to peers]:address' \
  '*--roles=[server roles to run]:role' \
  '--auto-provision[auto-provision the cluster]' \
  '--production[use production configuration profile]' \
  '--no-logo[do not print the restate logo on startup]' \
  '--dump-config[dump the loaded config to stdout and exit]' \
  '--metadata-migration-mode[run in metadata migration mode]' && ret=0

return ret
