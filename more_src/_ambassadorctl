#compdef ambassadorctl
# _ambassadorctl — Ambassador Labs Ambassador Edge Stack control CLI (Ambassador Labs, Go); spf13/cobra
# upstream: https://github.com/emissary-ingress/emissary

_ambassadorctl() {
    local -a sub=(
        'config:configuration commands'
        'cluster:cluster commands'
        'connect:connect to Ambassador Cloud'
        'gateway:gateway management'
        'install:install Ambassador Edge Stack'
        'license:license commands'
        'login:login to Ambassador Cloud'
        'logout:logout'
        'serve:start ambassador server'
        'status:show status'
        'sync:sync config to cloud'
        'tunnel:tunnel traffic'
        'uninstall:uninstall'
        'upgrade:upgrade Ambassador'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ambassadorctl subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--license=+[license key]:str:' \
                    '--version=+[version]:str:' \
                    '--registry=+[image registry]:str:' \
                    '--namespace=+[namespace]:str:' \
                    '--values=+[values yaml]:file:_files' \
                    '--no-license-prompt[no license prompt]' ;;
                config) _arguments \
                    '1:cmd:(set get validate)' \
                    '*:arg:' ;;
                gateway) _arguments \
                    '1:cmd:(list set get)' \
                    '*:arg:' ;;
                license) _arguments \
                    '1:cmd:(activate show update)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ambassadorctl "$@"
