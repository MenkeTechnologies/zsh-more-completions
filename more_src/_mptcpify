#compdef mptcpify mptcpify-bpfcc
# _mptcpify — force applications to use MPTCP instead of TCP (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/mptcpify.py (argparse).

_mptcpify() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-t --targets)'{-t+,--targets=}'[comma-separated process names (e.g. iperf3,rsync)]:targets:'
    )
    _arguments $args
}

_mptcpify "$@"
