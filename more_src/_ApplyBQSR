#compdef ApplyBQSR
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037055712-ApplyBQSR
# GATK4: apply base quality score recalibration to a BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[write output to this file]:file:_files' \
  '--bqsr-recal-file[input recalibration table for BQSR]:file:_files' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '*:options:_files' && ret=0

return ret
