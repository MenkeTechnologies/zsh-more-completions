#compdef crm_report

# Pacemaker crm_report: collect logs and configuration for support
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[verbose]' \
  '-d[do not delete intermediate files]' \
  '-l[log file path]:file:_files' \
  '-L[log search pattern]:pattern:' \
  '-c[cluster type]:type:(corosync heartbeat openais cman)' \
  '-n[node list, space separated]:nodes:' \
  '-u[SSH user]:user:' \
  '-D[output directory]:dir:_files -/' \
  '-f[from time (YYYY-MM-DD HH:MM)]:time:' \
  '-t[to time (YYYY-MM-DD HH:MM)]:time:' \
  '-T[ticket id]:ticket:' \
  '-e[email log to address]:email:' \
  '-A[include user-mode tools log]' \
  '-M[include corosync.log]' \
  '-S[single-node run only]' \
  '-x[extra options]:opts:' \
  '*:report tarball name:_files' && ret=0
return ret
