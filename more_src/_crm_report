#compdef crm_report
# Documentation: https://www.mankier.com/8/crm_report
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_report: gather Pacemaker cluster diagnostic data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display this message]' \
  '(- *)'{-v,--version}'[display software version]' \
  '(- *)--features[display software features]' \
  '*-V[increase verbosity]' \
  '(-f --from)'{-f+,--from=}'[time before issues began (YYYY-M-D H:M:S)]:datetime:' \
  '(-t --to)'{-t+,--to=}'[time when issues were resolved]:datetime:' \
  '(-T --cts)'{-T+,--cts=}'[CTS test or set to extract]:test:' \
  '--cts-log=[CTS master logfile]:file:_files' \
  '(-n --nodes)'{-n+,--nodes=}'[explicit list of cluster nodes]:nodes:' \
  '-M[do not search for cluster logs]' \
  '*'{-l+,--logfile=}'[log file to collect]:file:_files' \
  '*-p+[additional regex to mask variables]:pattern:' \
  '*-L+[additional regex to match in log files]:pattern:' \
  '(-S --single-node)'{-S,--single-node}'[do not collect from other nodes]' \
  '(-c --cluster)'{-c+,--cluster=}'[force cluster type]:type:(corosync heartbeat openais)' \
  '(-C --corosync)'{-C,--corosync}'[force cluster type to corosync]' \
  '(-u --user)'{-u+,--user=}'[username for collecting from other nodes]:user:_users' \
  '(-D --max-depth)'{-D+,--max-depth=}'[search depth for locating files]:n:' \
  '(-e --rsh)'{-e+,--rsh=}'[command to run on other nodes]:cmd:' \
  '(-d --as-directory)'{-d,--as-directory}'[leave result as directory tree]' \
  '--sos-mode[use defaults suitable for sosreport]' \
  '--dest=[custom destination directory or file name]:dest:_files' \
  '*:destination dir or tarball:_files' && ret=0
return ret
