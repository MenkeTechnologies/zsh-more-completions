#compdef crm_report
# Documentation: https://man.archlinux.org/search?q=crm_report
# Reference accessed: 2026-05-16

# crm_report: gather cluster diagnostic data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[verbose]' \
  '-v[verbose]' \
  '-d[destination directory (also accepts tarball name)]:dest:_files' \
  '-n[explicit list of nodes]:nodes:' \
  '-l[log file path]:file:_files' \
  '-L[gather only the local node]' \
  '-c[corosync config file]:file:_files' \
  '-C[cluster type]:type:(corosync heartbeat openais)' \
  '-f[from-time]:datetime:' \
  '-t[to-time]:datetime:' \
  '-T[time spec (test)]:spec:' \
  '-D[do not generate a digest]' \
  '-M[mask sensitive items]' \
  '-S[skip running collection (offline only)]' \
  '-u[ssh user]:user:_users' \
  '-X[extra ssh options]:opts:' \
  '*:destination dir or tarball:_files' && ret=0
return ret
