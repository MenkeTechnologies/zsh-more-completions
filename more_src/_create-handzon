#compdef create-handzon
# Documentation: https://www.npmjs.com/package/create-handzon
# Reference accessed: 2026-05-23
# Verified: npm view create-handzon bin; npm readme Subcommands section.

# Zsh completion for create-handzon - Handzon tutorial site scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-y --yes)'{-y,--yes}'[skip prompts and accept defaults]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' new step skills && ret=0
    ;;
  args)
    case $line[1] in
      new|step|skills)
        _arguments -C           '(-y --yes)'{-y,--yes}'[skip prompts and accept defaults]' && ret=0
        ;;
      *)
        _arguments -C           '(-y --yes)'{-y,--yes}'[skip prompts and accept defaults]'           ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
