#compdef cu++filt
# _cu++flt — NVIDIA cu++filt CUDA C++ symbol demangler companion to nvdisasm and cuobjdump (NVIDIA team, C++); custom argparse
# upstream: https://docs.nvidia.com/cuda/cuda-binary-utilities/

_cu++flt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-_[skip leading underscore]' \
        '--strip-underscore[skip leading underscore]' \
        '-n[no leading underscore]' \
        '--no-strip-underscore[no leading underscore]' \
        '-p[print no arguments]' \
        '--no-params[print no arguments]' \
        '-i+[input file]:file:_files' \
        '--input=+[input file]:file:_files' \
        '*:symbol:'
}

_cu++flt "$@"
