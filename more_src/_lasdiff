#compdef lasdiff
# LAStools: compare two LAS/LAZ files and report differences

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help output]' \
  '-version[report tool version]' \
  '-gui[launch with GUI]' \
  '(-v -verbose)'{-v,-verbose}'[print extra information]' \
  '-vv[print even more detailed information]' \
  '-silent[output only errors or warnings]' \
  '-quiet[suppress all output]' \
  '-force[continue despite serious warnings]' \
  '-errors_ignore[continue despite errors]' \
  '-print_log_stats[display additional statistics]' \
  '-random_seeks[perform 10 random seeks every 25k points]' \
  '-shutup+[stop reporting after n differences (default 5)]:n' \
  '-week_to_adjusted+[convert GPS week timestamps to adjusted standard]:week' \
  '-wildcards+[process files in list m against list n]:list' \
  '*-i+[input file or pattern]:input:_files -g "*.(las|laz|txt|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge input files]' \
  '-stdin[read from standard input]' \
  '-stdout[output to standard output]' \
  '-iparse+[define text input field parsing]:parse string' \
  '-oparse+[specify ASCII output format]:parse string' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|txt|LAS|LAZ)"' && ret=0

return ret
