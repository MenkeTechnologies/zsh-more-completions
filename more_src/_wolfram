#compdef wolfram WolframEngine
# _wolfram — Wolfram Research wolfram free Wolfram Engine for developers entry point and command line interpreter (wolfram team, C++); custom argparse
# upstream: https://www.wolfram.com/engine/

_wolfram() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-script[evaluate file as script]' \
        '-noprompt[no prompts]' \
        '-rawterm[raw terminal mode]' \
        '-noinit[no init]' \
        '-pwfile=+[password file]:file:_files' \
        '-pwgen[generate password]' \
        '-machineid[print machine id]' \
        '-mathlink[run in mathlink server mode]' \
        '-run=+[expression]:str:' \
        '-evaluate=+[expression]:str:' \
        '-f+[file]:file:_files -g "*.wls *.wl *.m"' \
        '-encoding=+[encoding]:e:(UTF8 ASCII Latin1 Native)' \
        '-format=+[output format]:f:(InputForm StandardForm OutputForm UnicodeBoxForm)' \
        '-charset=+[charset]:str:' \
        '-username=+[user]:user:_users' \
        '-password=+[password]:str:' \
        '-cloudbase=+[cloud url]:url:_urls' \
        '-cloudconnect[connect to cloud]' \
        '-local[run locally]' \
        '-activate[activate]' \
        '-deactivate[deactivate]' \
        '-uninstall[uninstall]' \
        '*:notebook or script:_files -g "*.nb *.wls *.wl *.m *.cdf"'
}

_wolfram "$@"
