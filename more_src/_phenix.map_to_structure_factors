#compdef phenix.map_to_structure_factors
# Phenix: convert a CCP4/MRC map to MTZ structure factors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'd_min=[resolution of output structure factors]:res:' \
  'output_file_name=[output MTZ filename]:file:_files' \
  'resolution_factor=[scale factor for resolution estimation]:factor:' \
  'scale_max=[maximum amplitude value]:max:' \
  'k_blur=[scale applied to HL coefficients]:k:' \
  'b_blur=[blurring applied to HL coefficients]:b:' \
  'box=[generate full box of coefficients]:bool:(True False)' \
  'keep_origin=[preserve input map origin]:bool:(True False)' \
  'output_origin_grid_units=[output origin in grid units]:units:' \
  'map_file=[input map filename]:file:_files -g "*.(ccp4|map|mrc)"' \
  '*:map file:_files -g "*.(ccp4|map|mrc)"' && ret=0

return ret
