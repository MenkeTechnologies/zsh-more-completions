#compdef fly
# _concourse-fly — Concourse CI fly CLI (Concourse + Pivotal, Go); login, view, trigger Concourse pipelines
# upstream: https://github.com/concourse/concourse

_concourse-fly() {
    local -a sub=(
        'abort-build:abort a build'
        'active-users:list active users'
        'archive-pipeline:archive a pipeline'
        'builds:show builds'
        'check-resource:check a resource'
        'check-resource-type:check a resource type'
        'checklist:checklist commands'
        'clear-resource-cache:clear resource cache'
        'clear-task-cache:clear task cache'
        'clear-versions:clear versions'
        'completion:print shell completion'
        'containers:list containers'
        'curl:curl with auth'
        'destroy-pipeline:destroy a pipeline'
        'destroy-team:destroy a team'
        'edit-target:edit target'
        'execute:execute one-off task'
        'expose-pipeline:expose a pipeline'
        'format-pipeline:format a pipeline'
        'get-pipeline:get a pipeline'
        'get-team:get team config'
        'help:show help'
        'hide-pipeline:hide a pipeline'
        'hijack:hijack a container'
        'intercept:alias for hijack'
        'jobs:list jobs'
        'login:login to Concourse'
        'logout:logout'
        'order-pipelines:order pipelines'
        'pause-job:pause a job'
        'pause-pipeline:pause a pipeline'
        'pause-resource:pause a resource'
        'pipelines:list pipelines'
        'prune-worker:prune a worker'
        'projects:list projects'
        'resource-versions:list resource versions'
        'resources:list resources'
        'rename-pipeline:rename a pipeline'
        'rename-team:rename a team'
        'schedule-job:schedule a job'
        'set-pipeline:set a pipeline'
        'set-team:create or update a team'
        'sp:alias for set-pipeline'
        'sync:download latest fly to PATH'
        'targets:list targets'
        'team-users:list team users'
        'teams:list teams'
        'trigger-job:trigger a job'
        'unpause-job:unpause a job'
        'unpause-pipeline:unpause a pipeline'
        'unpause-resource:unpause a resource'
        'unpin-resource:unpin a resource'
        'userinfo:show current user info'
        'validate-pipeline:validate pipeline yaml'
        'volumes:list volumes'
        'watch:watch a build'
        'workers:list workers'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-t+[target]:target:' \
        '--target+[target]:target:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--print-table-headers[print table headers]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fly subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '-c+[concourse URL]:url:_urls' \
                    '--concourse-url+[concourse URL]:url:_urls' \
                    '-u+[username]:user:' \
                    '--username+[username]:user:' \
                    '-p+[password]:pass:' \
                    '--password+[password]:pass:' \
                    '-n+[team name]:team:' \
                    '--team-name+[team name]:team:' \
                    '-k[skip TLS verify]' \
                    '--insecure[skip TLS verify]' \
                    '--client-cert+[client cert]:file:_files' \
                    '--client-key+[client key]:file:_files' \
                    '--ca-cert+[CA cert]:file:_files' \
                    '--browser-only[browser only]' \
                    '-b[browser only]' \
                    '-o+[OIDC issuer]:str:' \
                    '--open-browser[open browser]' ;;
                set-pipeline|sp) _arguments \
                    '-p+[pipeline name]:name:' \
                    '--pipeline+[pipeline name]:name:' \
                    '-c+[pipeline config file]:file:_files' \
                    '--config+[pipeline config file]:file:_files' \
                    '-l+[load vars from file]:file:_files' \
                    '--load-vars-from+[load vars from file]:file:_files' \
                    '-v+[var]:KEY=VAL:' \
                    '--var+[var]:KEY=VAL:' \
                    '--yaml-var+[yaml var]:KEY=VAL:' \
                    '--instance-var+[instance var]:KEY=VAL:' \
                    '--check-creds[check credentials]' \
                    '-n[no confirm]' \
                    '--non-interactive[no confirm]' \
                    '--team+[team name]:team:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_concourse-fly "$@"
