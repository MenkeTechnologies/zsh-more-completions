#compdef timeplusd-client
# Documentation: https://docs.timeplus.com/timeplusd-client
# Timeplus timeplusd SQL client (ClickHouse client fork)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-h --host)'{-h,--host}'=[server hostname or IP]:host:_hosts' \
  '--port=[native TCP port]:port' \
  '(-u --user)'{-u,--user}'=[user name]:user' \
  '--password=[password]:password' \
  '--ask-password[prompt for the password]' \
  '(-d --database)'{-d,--database}'=[default database]:database' \
  '(-q --query)'{-q,--query}'=[query string for batch mode]:query' \
  '--queries-file=[path to a file with queries to run]:file:_files' \
  '(-m --multiline)'{-m,--multiline}'[allow multi-line queries in interactive mode]' \
  '(-n --multiquery)'{-n,--multiquery}'[allow multiple semicolon-separated queries]' \
  '(-f --format)'{-f,--format}'=[default output format]:format' \
  '(-E --vertical)'{-E,--vertical}'[alias for --format=Vertical]' \
  '(-t --time)'{-t,--time}'[print query time to stderr in batch mode]' \
  '--stacktrace[print the server stack trace on exceptions]' \
  '--secure[connect over TLS]' \
  '--config-file=[path to a config file]:file:_files' \
  '--history_file=[path to the history file]:file:_files' \
  '--hardware-utilization[include hardware stats in the progress bar]' \
  '--print-profile-events[emit ProfileEvents packets]' \
  '--profile-events-delay-ms=[delay between ProfileEvents packets]:ms' && ret=0

return ret
