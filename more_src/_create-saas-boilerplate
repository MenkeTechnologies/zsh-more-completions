#compdef create-saas-boilerplate
# Documentation: https://www.npmjs.com/package/create-saas-boilerplate
# Reference accessed: 2026-05-24
# Verified: npm view create-saas-boilerplate bin; npx create-saas-boilerplate --help output.

# Zsh completion for create-saas-boilerplate - SaaS Boilerplate project initializer

local curcontext="$curcontext" state line ret=1

_arguments -C   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' init && ret=0
    ;;
  args)
    _arguments -C       '--skipSystemCheck[skip system check]'       ':project directory:_directories' && ret=0
    ;;
esac

return ret
