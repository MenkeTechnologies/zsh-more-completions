#compdef pamcat
# Documentation: man pamcat (Netpbm)
# Source: Netpbm pamcat — concatenate Netpbm images left-right or top-bottom.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-leftright -lr -topbottom -tb)'{-leftright,-lr}'[concatenate left to right]' \
    '(-leftright -lr -topbottom -tb)'{-topbottom,-tb}'[concatenate top to bottom]' \
    '(-white -black)-white[fill background with white]' \
    '(-white -black)-black[fill background with black]' \
    '(-jtop -jbottom -jcenter)-jtop[justify top]' \
    '(-jtop -jbottom -jcenter)-jbottom[justify bottom]' \
    '(-jtop -jbottom -jleft -jright -jcenter)-jcenter[justify center]' \
    '(-jleft -jright)-jleft[justify left]' \
    '(-jleft -jright)-jright[justify right]' \
    '-listfile=[file with list of input filenames]:file:_files' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
