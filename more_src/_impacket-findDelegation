#compdef impacket-findDelegation

# Impacket findDelegation.py: enumerate delegation rights via LDAP
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-target-domain[target domain to query]:domain:' \
  '-target[FQDN of target machine]:target:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '-ts[print timestamps]' \
  '*:domain/user[:password]:' && ret=0
return ret
