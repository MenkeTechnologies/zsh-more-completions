#compdef kor
# Documentation: https://github.com/yonahd/kor
# Reference accessed: 2026-05-19
# Verified: upstream README Global Flags block + Supported Resources list.

# Zsh completion for kor - a tool to discover unused Kubernetes resources.
# Corrected: -n is --include-namespaces (not --namespace), short forms
# added (-e/-l/-k/-o/-v), removed invented --context, added missing
# subcommands and --show-reason/--ignore-owner-references.

local curcontext="$curcontext" state line ret=1

_kor_commands() {
  local -a commands=(
    'all:get unused resources of all types'
    'configmap:get unused configmaps'
    'secret:get unused secrets'
    'service:get unused services'
    'serviceaccount:get unused service accounts'
    'deployment:get unused deployments'
    'statefulset:get unused statefulsets'
    'role:get unused roles'
    'clusterrole:get unused cluster roles'
    'clusterrolebinding:get unused cluster role bindings'
    'rolebinding:get unused role bindings'
    'hpa:get unused hpas'
    'pod:get unused pods'
    'pvc:get unused pvcs'
    'pv:get unused persistent volumes'
    'storageclass:get unused storage classes'
    'ingress:get unused ingresses'
    'pdb:get unused pod disruption budgets'
    'crd:get unused custom resource definitions'
    'job:get unused jobs'
    'replicaset:get unused replicasets'
    'daemonset:get unused daemonsets'
    'volumeattachment:get unused volume attachments'
    'priorityclass:get unused priority classes'
    'finalizer:get resources with unresolvable finalizers'
    'networkpolicy:get unused network policies'
    'exporter:expose unused resources metrics'
    'version:print version'
    'help:help about any command'
    'completion:generate shell completion'
  )
  _describe -t commands 'kor command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --include-namespaces)'{-n+,--include-namespaces=}'[namespaces to run on, comma-separated]:namespaces:' \
  '(-e --exclude-namespaces)'{-e+,--exclude-namespaces=}'[namespaces to exclude, comma-separated]:namespaces:' \
  '(-k --kubeconfig)'{-k+,--kubeconfig=}'[path to kubeconfig file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output (print empty namespaces)]' \
  '--group-by=[group output by]:group:(namespace resource)' \
  '--include-labels=[selector to filter in]:labels:' \
  '(-l --exclude-labels)'{-l+,--exclude-labels=}'[selector to filter out]:labels:' \
  '--newer-than=[max age of resources considered unused]:duration:' \
  '--older-than=[min age of resources considered unused]:duration:' \
  '--delete[delete found unused resources]' \
  '--no-interactive[do not prompt for confirmation when deleting]' \
  '--show-reason[print reason resource is considered unused]' \
  '--ignore-owner-references[skip resources that have ownerReferences set]' \
  '--slack-webhook-url=[slack webhook URL]:url:' \
  '--slack-channel=[slack channel]:channel:' \
  '--slack-auth-token=[slack auth token]:token:' \
  '1: :_kor_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
