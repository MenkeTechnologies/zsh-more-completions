#compdef kor

# Zsh completion for kor - a tool to discover unused Kubernetes resources

local curcontext="$curcontext" state line ret=1

_kor_commands() {
  local -a commands=(
    'all:get unused resources of all types'
    'configmap:get unused configmaps'
    'secret:get unused secrets'
    'service:get unused services'
    'serviceaccount:get unused service accounts'
    'deployment:get unused deployments'
    'statefulset:get unused statefulsets'
    'role:get unused roles'
    'hpa:get unused hpas'
    'pvc:get unused pvcs'
    'ingress:get unused ingresses'
    'pdb:get unused pod disruption budgets'
    'job:get unused jobs'
    'replicaset:get unused replicasets'
    'exporter:expose unused resources metrics'
    'version:print version'
    'help:help about any command'
    'completion:generate shell completion'
  )
  _describe -t commands 'kor command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'[namespaces to run on]:namespace' \
  '(-e --exclude-namespaces)'{-e,--exclude-namespaces}'[namespaces to exclude]:namespaces' \
  '--kubeconfig[path to kubeconfig file]:file:_files' \
  '--context[kubeconfig context]:context' \
  '--output[output format]:format:(table json yaml)' \
  '--group-by[group by]:group:(namespace resource)' \
  '--slack-webhook-url[slack webhook URL]:url' \
  '--slack-channel[slack channel]:channel' \
  '--slack-auth-token[slack auth token]:token' \
  '--verbose[verbose output]' \
  '--delete[delete found unused resources]' \
  '--no-interactive[do not ask for confirmation before deletion]' \
  '--include-labels[filter by labels]:labels' \
  '--exclude-labels[exclude by labels]:labels' \
  '--newer-than[only resources newer than duration]:duration' \
  '--older-than[only resources older than duration]:duration' \
  '1: :_kor_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
