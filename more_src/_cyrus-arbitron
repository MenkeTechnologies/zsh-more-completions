#compdef cyrus-arbitron
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/arbitron.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org arbitron(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-arbitron: report Cyrus mailbox reader usage statistics
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-D[date range mmddyyyy or mmddyyyy:mmddyyyy]:range:' \
  '-d[count readers seen within past N days]:days:' \
  '(-l --detailed)'{-l,--detailed}'[detailed CSV output]' \
  '(-o --no-subscribers)'{-o,--no-subscribers}'[exclude subscribers (old behavior)]' \
  '(-p --prune-seen)'{-p+,--prune-seen=}'[prune \\Seen for users idle this many months]:months:' \
  '(-u --include-userids)'{-u,--include-userids}'[include reader userids in report]' && ret=0
return ret
