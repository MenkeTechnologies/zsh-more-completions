#compdef erlperf
# Documentation: https://github.com/max-au/erlperf/blob/master/README.md
# Erlang benchmarking and performance measurement suite

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-c --concurrency)'{-c,--concurrency}'+[number of concurrent worker processes]:count' \
  '(-d --duration)'{-d,--duration}'+[sample duration in milliseconds]:ms' \
  '(-s --samples)'{-s,--samples}'+[number of samples to collect]:count' \
  '(-w --warmup)'{-w,--warmup}'+[warmup time in seconds]:seconds' \
  '(-r --report)'{-r,--report}'+[report format]:format:(basic extended full)' \
  '(-v --verbose)'{-v,--verbose}'[display progress with system metrics]' \
  '-q[quiet mode, minimal output]' \
  '(-i --isolated)'{-i,--isolated}'[spawn separate Erlang VM for each benchmark]' \
  '*-pa+[add code path for compiled modules]:dir:_files -/' \
  '--init=[setup code executed once when job starts]:code' \
  '--init_runner=[setup code executed on each worker startup]:code' \
  '--done=[cleanup code executed when job stops]:code' \
  '--label=[custom label overriding code in reports]:label' \
  '(-l --loop)'{-l,--loop}'+[iterations for timed mode]:iterations' \
  '(-t --timed)'{-t,--timed}'[enable timed mode with iterations]' \
  '--squeeze[concurrency estimation mode]' \
  '--max=[maximum concurrency limit]:count' \
  '--min=[minimum concurrency]:count' \
  '--step=[concurrency increment step]:count' \
  '--cv=[coefficient of variation threshold]:value' \
  '--start=[initial concurrency level]:count' \
  '--json[output results in JSON format]' \
  '*:code:_files' && ret=0

return ret
