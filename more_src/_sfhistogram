#compdef sfhistogram
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mhistogram.c
# Madagascar: compute a histogram of integer- or float-valued input data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'n1=[number of histogram samples]:count' \
  'o1=[histogram origin]:value' \
  'd1=[histogram sampling]:value' \
  '*:RSF file:_files' && ret=0

return ret
