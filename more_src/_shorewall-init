#compdef shorewall-init
# Documentation: https://manpages.debian.org/testing/shorewall/shorewall-init.8.en.html
# Reference accessed: 2026-05-17
# Verified: Debian shorewall-init(8) — init/systemd unit wrapper
# that secures network before networking is up. Real subcommands:
# start, stop only. (Init-script extras like status/restart/
# try-restart/force-reload/reload are systemd-injected, not
# upstream-shorewall-init flags.)
# Removed from prior file: bogus man.archlinux.org search URL.

local ret=1
_arguments \
  '1:command:(start stop)' && ret=0
return ret
