#compdef shorewall-init
# Documentation: https://shorewall.org/manpages/shorewall-init.html
# Reference accessed: 2026-05-21
# Verified: upstream shorewall-init manpage at the URL above — synopsis is
# "shorewall-init [start|stop]". No other commands or options.

local ret=1
_arguments \
  '1:command:(start stop)' && ret=0
return ret
