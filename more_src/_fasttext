#compdef fasttext
# Documentation: https://fasttext.cc/docs/en/options.html
# fastText library for text classification and word vectors

local ret=1

_arguments -s -S \
  '-input[training file path]:file:_files' \
  '-output[output file path]:prefix' \
  '-minCount[minimal number of word occurrences]:n' \
  '-minCountLabel[minimal number of label occurrences]:n' \
  '-wordNgrams[max length of word ngram]:n' \
  '-bucket[number of buckets]:n' \
  '-minn[min length of char ngram]:n' \
  '-maxn[max length of char ngram]:n' \
  '-t[sampling threshold]:t' \
  '-label[labels prefix]:prefix' \
  '-lr[learning rate]:lr' \
  '-lrUpdateRate[rate of updates for the learning rate]:n' \
  '-dim[size of word vectors]:n' \
  '-ws[size of the context window]:n' \
  '-epoch[number of epochs]:n' \
  '-neg[number of negatives sampled]:n' \
  '-loss[loss function]:loss:(ns hs softmax ova)' \
  '-thread[number of threads]:n' \
  '-pretrainedVectors[pretrained word vectors for supervised learning]:file:_files' \
  '-saveOutput[whether output params should be saved]:bool:(0 1)' \
  '-cutoff[number of words and ngrams to retain]:n' \
  '-retrain[finetune embeddings if a cutoff is applied]:bool:(0 1)' \
  '-qnorm[quantizing the norm separately]:bool:(0 1)' \
  '-qout[quantizing the classifier]:bool:(0 1)' \
  '-dsub[size of each sub-vector]:n' \
  '-autotune-validation[validation file to be used for evaluation]:file:_files' \
  '-autotune-metric[metric objective]:metric' \
  '-autotune-predictions[number of predictions used for evaluation]:n' \
  '-autotune-duration[maximum duration in seconds]:secs' \
  '-autotune-modelsize[constraint model file size]:size' \
  '1:command:(supervised skipgram cbow predict predict-prob test test-label quantize print-word-vectors print-sentence-vectors print-ngrams nn analogies dump)' \
  '*:file:_files' && ret=0

return ret
