#compdef lyx

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-userdir+[user directory]:dir:_files -/' \
  '-sysdir+[system directory]:dir:_files -/' \
  '-geometry+[X11 geometry]:geom:' \
  '-dbg+[enable debug categories]:cats:' \
  '-x+[execute LFUN]:lfun:' \
  '--execute=[execute LFUN]:lfun:' \
  '-e+[export format]:format:(latex pdflatex xelatex luatex pdf pdf2 pdf3 pdf4 pdf5 html docbook docbook5 odt epub txt xhtml)' \
  '--export=[export format]:format:(latex pdflatex xelatex luatex pdf pdf2 pdf3 pdf4 pdf5 html docbook docbook5 odt epub txt xhtml)' \
  '-E+[export to format and exit]:fmt_out:' \
  '--export-to=[export to format and exit]:fmt_out:' \
  '-i+[import format from file]:fmt_file:' \
  '--import=[import format from file]:fmt_file:' \
  '-f+[force overwrite]:bool:(all main none)' \
  '--force-overwrite=[force overwrite]:bool:(all main none)' \
  '-batch[exit after processing files]' \
  '-version[print version and exit]' \
  '-remote[attempt to use running LyX instance]' \
  '*:lyx_file:_files -g "*.{lyx,tex,lyx.bak}"' && ret=0

return ret
