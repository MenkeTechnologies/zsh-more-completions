#compdef cestats
# Documentation: https://biobb-amber.readthedocs.io/en/latest/cphstats.html
# AmberTools: compute statistics from constant Redox potential MD ceout files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-O[allow existing outputs to be overwritten]' \
  '(-i --cein)'{-i,--cein}'+[input cein file with titrating residue info]:file:_files' \
  '(-o --calceo-output)'{-o,--calceo-output}'+[calceo-style output file]:file:_files' \
  '--population=[output file for redox state populations]:file:_files' \
  '--chunk=[compute Eo over chunks of WINDOW steps]:window' \
  '--chunk-out=[chunk output file]:file:_files' \
  '--cumulative[compute cumulative average time series]' \
  '--cumulative-out=[cumulative output file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'+[verbosity level]:level' \
  '(-n --interval)'{-n,--interval}'+[interval between time series points]:interval' \
  '(-p --reduced)'{-p,--reduced}'[print fraction reduced]' \
  '(-d --oxidized)'{-d,--oxidized}'[print fraction oxidized]' \
  '--calceo[trigger calceo-style output]' \
  '--no-calceo[disable calceo-style output]' \
  '--fix-remd=[re-order ceout files from an E-REMD run]:prefix' \
  '*-c+[conditional probability condition]:condition' \
  '--conditional-output=[conditional probability output file]:file:_files' \
  '--chunk-conditional=[conditional chunk output file]:file:_files' && ret=0

return ret
