#compdef nix-visualize
# Documentation: https://github.com/craigmbooth/nix-visualize
# generate a dependency graph image of a Nix store object

local ret=1

_arguments -s -S \
  '(-h --help)-h[show help]' \
  '(-c --configfile)'{-c,--configfile}'[configuration file in .ini format]:file:_files' \
  '(-s --configsection)'{-s,--configsection}'[configuration section to use]:section:' \
  '(-o --output)'{-o,--output}'[output filename; extension sets format]:file:_files' \
  '--verbose[print extra information to stdout]' \
  '--no-verbose[disable verbose output]' \
  '*:store path:_files -/' && ret=0

return ret
