#compdef ot-ctl
# Documentation: https://openthread.io/reference/cli/commands
# ot-ctl: OpenThread Border Router CLI client

local ret=1
local -a cmds
cmds=(
  'help:list CLI commands'
  'ifconfig:manage the Thread interface (up/down)'
  'thread:control Thread protocol operation (start/stop)'
  'state:get or set the device role'
  'dataset:view and manage operational datasets'
  'channel:get or set the IEEE 802.15.4 channel'
  'panid:get or set the PAN ID'
  'extpanid:get or set the extended PAN ID'
  'networkname:get or set the Thread network name'
  'networkkey:get or set the network key'
  'masterkey:get or set the network master key'
  'commissioner:manage the Commissioner role'
  'joiner:manage the Joiner role'
  'scan:perform an IEEE 802.15.4 active scan'
  'ipaddr:get or manage Thread interface IPv6 addresses'
  'ping:send an ICMPv6 echo request'
  'router:show Thread router information'
  'child:show child information'
  'neighbor:show neighbor information'
  'rloc16:get the RLOC16 of the device'
  'leaderdata:show the leader data'
  'eui64:get the factory-assigned IEEE EUI-64'
  'mode:get or set the Thread device mode'
  'pskc:get or set the pre-shared commissioner key'
  'factoryreset:erase settings and reset to factory defaults'
  'reset:reset the OpenThread stack'
  'version:print the OpenThread version'
)

_arguments -s -S \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'ot-ctl command' cmds && ret=0 ;;
esac

return ret
