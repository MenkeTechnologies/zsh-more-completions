#compdef ziglint

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'upgrade:upgrade ziglint to the latest release'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--check-format[require zig fmt clean code]' \
  '--max-line-length=[max line length]:n:' \
  '--dupe-import[disallow duplicate imports]' \
  '--file-as-struct[require file-as-struct convention]' \
  '--banned-comment-phrases=[comma-separated banned comment phrases]:phrases:' \
  '--exclude=[comma-separated excluded paths]:paths:_files' \
  '--include=[comma-separated included paths]:paths:_files' \
  '--include-gitignored[lint files ignored by .gitignore]' \
  '--zig-lib-path=[path to Zig standard library]:dir:_files -/' \
  '*--only=[lint only specific rule (repeatable)]:rule:' \
  '*--ignore=[ignore specific rule (repeatable)]:rule:' \
  '--config=[config file]:file:_files' \
  '--no-color[disable colored output]' \
  '1: :->cmd' \
  '*: :_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'ziglint command' commands && ret=0 ;;
esac

return ret
