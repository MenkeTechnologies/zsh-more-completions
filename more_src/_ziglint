#compdef ziglint
# Documentation: https://github.com/AnnikaCodes/ziglint
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated flags --banned-comment-phrases,
#   --zig-lib-path, --only, --ignore, --config, --no-color (not documented
#   upstream).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'upgrade:check for and install newer versions'
  'help:view basic usage information'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--check-format[enable formatting checks (zig fmt clean code)]' \
  '--max-line-length=[set maximum line length (default 100)]:n:' \
  '--dupe-import[check for duplicate imports]' \
  '--file-as-struct[validate file naming conventions]' \
  '--exclude=[exclude files from linting]:paths:_files' \
  '--include=[include previously excluded files]:paths:_files' \
  '--include-gitignored[override default .gitignore exclusions]' \
  '1: :->cmd' \
  '*: :_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'ziglint command' commands && ret=0 ;;
esac

return ret
