#compdef yubihsm-connector
# _yubihsm-connector — Yubico yubihsm-connector CLI HTTP USB bridge daemon proxying authenticated YubiHSM2 USB device sessions to network HTTP clients yubihsm-shell pkcs11-tool gpg-agent piv-agent across many concurrent processes for shared-HSM workflows (Yubico team, Go); cobra
# upstream: https://github.com/Yubico/yubihsm-connector

_yubihsm-connector() {
    local -a sub=(
        'version:print version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-d[debug]' \
        '--debug[debug]' \
        '-l+[listen]:str:' \
        '--listen=+[host:port]:str:' \
        '--cert=+[certificate]:file:_files -g "*.pem *.crt *.cer"' \
        '--key=+[private key]:file:_files -g "*.key *.pem"' \
        '--syslog[log to syslog]' \
        '--seccomp[enable seccomp]' \
        '-s+[serial]:str:' \
        '--serial=+[serial]:str:' \
        '--soft-restart-timeout=+[sec]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yubihsm-connector subcommand' sub ;;
    esac
}

_yubihsm-connector "$@"
