#compdef nodegc nodegc-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/nodegc.sh wraps `ugc.py -l node "$@"`)
# Reference accessed: 2026-05-29
# nodegc — bash wrapper that pins `ugc -l node` for Node.js V8 GC event tracing (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

# Inherits ugc flag set MINUS -l/--language (hardcoded to "node" upstream).
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '(-m --milliseconds)'{-m,--milliseconds}'[report times in milliseconds (default microseconds)]' \
  '(-M --minimum)'{-M,--minimum=}'[display only GCs longer than N ms (default 0)]:ms:' \
  '(-F --filter)'{-F,--filter=}'[display only GCs whose description contains this text]:text:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (Node.js process id to attach to):_pids' \
  && ret=0

return ret
