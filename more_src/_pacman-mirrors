#compdef pacman-mirrors
# Documentation: https://man.archlinux.org/search?q=pacman-mirrors
# Reference accessed: 2026-05-16

_arguments -s \
  '(-i --interactive)'{-i,--interactive}'[interactive]' \
  '(-f --fasttrack)'{-f,--fasttrack}'=[number]:n:' \
  '*'{-c,--country}'=[country]:country:' \
  '(-z --timezone -zone)'{-z,--timezone,-zone}'[timezone]' \
  '--continent[continent]' \
  '(-a --api)'{-a,--api}'[API mode]' \
  '(-S -B --set-branch)'{-S,-B,--set-branch}'=[branch]:branch:(stable testing unstable)' \
  '(-p --prefix)'{-p,--prefix}'=[prefix]:prefix:' \
  '*'{-P,--proto,--protocols}'=[proto]:proto:(all http https ftp ftps)' \
  '(-R --re-branch)'{-R,--re-branch}'[re-branch]' \
  '(-U --url)'{-U,--url}'=[URL]:url:' \
  '(-G --get-branch)'{-G,--get-branch}'[get branch]' \
  '(-d --default)'{-d,--default}'[default]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --list --country-list)'{-l,--list,--country-list}'[list]' \
  '(-lc --country-config)'{-lc,--country-config}'[country config]' \
  '(-m --method)'{-m,--method}'=[method]:method:(rank random)' \
  '(-n --no-mirrorlist)'{-n,--no-mirrorlist}'[no mirrorlist]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --no-status)'{-s,--no-status}'[no status]' \
  '(-t --timeout)'{-t,--timeout}'=[seconds]:n:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-color[no color]' \
  '--interval=[interval]:n:' \
  '-g[generate]' \
  '--status[status]'
