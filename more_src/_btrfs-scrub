#compdef btrfs-scrub
# _btrfs-scrub — btrfs-progs btrfs scrub (verify all data + metadata checksums and rewrite from good copies on a btrfs mount; start/status/cancel/resume subcommands, -B foreground+verbose, -B blocking, -c io class, -n io prio, -d per-device stats, -q quiet, -R raw counters)
# upstream: https://github.com/kdave/btrfs-progs
# Subcommands from btrfs-progs cmds/scrub.c on tip.

_btrfs-scrub() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'scrub command' '(start status cancel resume)' ;;
        args)
            _arguments \
                '-B[run foreground, block]' \
                '-d[per-device]' \
                '-q[quiet]' \
                '-r[read-only]' \
                '-R[raw counters]' \
                '-c+[io class]:class:(0 1 2 3)' \
                '-n+[io priority]:prio:(0 1 2 3 4 5 6 7)' \
                '-f[force]' \
                '*:filesystem or device:_files'
            ;;
    esac
}

_btrfs-scrub "$@"
