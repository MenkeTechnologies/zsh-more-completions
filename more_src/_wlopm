#compdef wlopm
# Documentation: https://git.sr.ht/~leon_plickat/wlopm
# Reference accessed: 2026-05-21
# Verified: usage[] string and argv parsing in upstream wlopm.c at the URL
# above.

local curcontext="$curcontext" state line ret=1

_wlopm_outputs() {
  local -a outs
  outs=(${(f)"$(command wlopm 2>/dev/null | awk '{print $1}')"})
  if (( ${#outs} )); then
    _values 'wayland output' $outs
  else
    _message 'wayland output name'
  fi
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[use JSON output format]' \
  '*--on[set output power mode on]:output:_wlopm_outputs' \
  '*--off[set output power mode off]:output:_wlopm_outputs' \
  '*--toggle[toggle output power mode]:output:_wlopm_outputs' && ret=0

return ret
