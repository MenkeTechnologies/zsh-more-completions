#compdef wlopm

local curcontext="$curcontext" state line ret=1

local -a outputs
outputs=(${(f)"$(wlopm 2>/dev/null | awk '{print $1}')"})

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--on+[turn output on]:output:($outputs)' \
  '--off+[turn output off]:output:($outputs)' \
  '--toggle+[toggle output]:output:($outputs)' \
  '-j[output JSON]' && ret=0

return ret
