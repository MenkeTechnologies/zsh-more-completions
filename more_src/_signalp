#compdef signalp signalp6 signalp7
# _signalp — DTU Henrik Nielsen SignalP signal peptide cleavage site prediction using deep learning (DTU team, Python); argparse
# upstream: https://services.healthtech.dtu.dk/services/SignalP-6.0/

_signalp() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-f+[input fasta]:file:_files -g "*.fa *.fasta *.faa"' \
        '--fastafile=+[input fasta]:file:_files -g "*.fa *.fasta *.faa"' \
        '-o+[output dir]:dir:_files -/' \
        '--output_dir=+[output dir]:dir:_files -/' \
        '-org+[organism]:o:(eukarya gram-negative gram-positive archaea other)' \
        '--organism=+[organism]:o:(eukarya gram-negative gram-positive archaea other)' \
        '-format+[output format]:f:(txt csv png eps all)' \
        '--format=+[output format]:f:(txt csv png eps all)' \
        '-mode+[mode]:m:(fast slow slow-sequential)' \
        '--mode=+[mode]:m:(fast slow slow-sequential)' \
        '-bsize+[batch size]:n:' \
        '--batch_size=+[batch size]:n:' \
        '-tll+[truncation length]:n:' \
        '--torch_num_threads=+[N]:n:' \
        '--write_procs[write procs]' \
        '--no-output-png[no png output]' \
        '--no-output-eps[no eps output]' \
        '--no-write[no write]' \
        '--filter-pred-pp[filter predictions PP]' \
        '--input_type=+[type]:t:(amino acid)' \
        '--cs_predicted=+[bool]:b:(true false)' \
        '--gpu[use GPU]'
}

_signalp "$@"
