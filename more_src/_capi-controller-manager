#compdef capi-controller-manager

# Cluster API controller manager (CAPI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--enable-leader-election[enable leader election]' \
  '--leader-elect-lease-duration=[lease duration]:duration:' \
  '--leader-elect-renew-deadline=[renew deadline]:duration:' \
  '--leader-elect-retry-period=[retry period]:duration:' \
  '--namespace=[namespace]:ns:' \
  '--metrics-bind-addr=[metrics bind address]:addr:' \
  '--health-addr=[health probe bind address]:addr:' \
  '--webhook-port=[webhook port]:port:' \
  '--webhook-cert-dir=[webhook cert directory]:dir:_files -/' \
  '--profiler-address=[profiler address]:addr:' \
  '--feature-gates=[feature gates]:gates:' \
  '--diagnostics-address=[diagnostics address]:addr:' \
  '--insecure-diagnostics[insecure diagnostics]' \
  '--v=[log level]:n:' \
  '--logtostderr[log to stderr]' \
  '*::capi-controller-manager args:_files' && ret=0
return ret
