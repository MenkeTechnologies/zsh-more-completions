#compdef so-rule
# _so-rule — Security Onion so-rule CLI for managing Suricata and Zeek detection rules enabling disabling modifying searching and pushing custom rulesets across distributed sensor cluster (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-rule() {
    local -a sub=(
        'enable:enable rule by SID'
        'disable:disable rule by SID'
        'modify:modify rule'
        'add:add new rule'
        'delete:delete rule'
        'search:search for rules'
        'list:list active rules'
        'push:push rules to sensors'
        'reload:reload rules'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-f+[force]' \
        '--force[force]' \
        '--ruleset=+[r]:r:(suricata zeek)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-rule subcommand' sub ;;
        args)
            case $words[1] in
                enable|disable|delete) _arguments \
                    '--sid=+[N]:n:' \
                    '*:SID:' ;;
                modify) _arguments \
                    '--sid=+[N]:n:' \
                    '--field=+[name]:str:' \
                    '--value=+[value]:str:' \
                    '*:SID:' ;;
                add) _arguments \
                    '--file=+[file]:file:_files -g "*.rules *.rule"' \
                    '*:rule:' ;;
                search) _arguments \
                    '--pattern=+[regex]:str:' \
                    '--category=+[cat]:str:' ;;
            esac
            ;;
    esac
}

_so-rule "$@"
