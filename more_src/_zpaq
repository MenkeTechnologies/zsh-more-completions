#compdef zpaq

# Zsh completion for zpaq - journaling archiver

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add or update files to archive'
  'extract:extract files from archive'
  'list:list archive contents'
  'compare:compare archive with filesystem'
  'purge:delete old versions from archive'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zpaq command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (add)
        _arguments -s -S \
          '-key=[set encryption key]:key' \
          '-method=[set compression method]:method:(0 1 2 3 4 5)' \
          '-force[force overwrite without confirmation]' \
          '-noattributes[do not store file attributes]' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-since=[include only files newer than version]:version' \
          '-until=[include only files up to version]:version' \
          '-threads=[number of threads]:threads' \
          '-to=[prepend prefix to internal filenames]:prefix' \
          '-fragment=[set fragment size]:size' \
          '-index=[create index file]:file:_files' \
          '-summary=[show summary at level]:level:(1 2)' \
          '-test[verify archive after update]' \
          '1:archive:_files -g "*.zpaq"' \
          '*:files:_files' && ret=0
        ;;
      (extract)
        _arguments -s -S \
          '-key=[set decryption key]:key' \
          '-force[force overwrite existing files]' \
          '-noattributes[do not restore file attributes]' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-since=[extract only files newer than version]:version' \
          '-until=[extract only files up to version]:version' \
          '-threads=[number of threads]:threads' \
          '-to=[extract to specified directory]:directory:_files -/' \
          '-summary=[show summary at level]:level:(1 2)' \
          '1:archive:_files -g "*.zpaq"' \
          '*:files' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '-key=[set decryption key]:key' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-since=[list only files newer than version]:version' \
          '-until=[list only files up to version]:version' \
          '-summary=[show summary at level]:level:(1 2)' \
          '-all[show all versions]' \
          '1:archive:_files -g "*.zpaq"' && ret=0
        ;;
      (compare)
        _arguments -s -S \
          '-key=[set decryption key]:key' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-to=[compare against specified directory]:directory:_files -/' \
          '1:archive:_files -g "*.zpaq"' && ret=0
        ;;
      (purge)
        _arguments -s -S \
          '-key=[set decryption key]:key' \
          '-to=[write purged archive to new file]:file:_files -g "*.zpaq"' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-since=[keep only versions since]:version' \
          '-until=[keep only versions up to]:version' \
          '-threads=[number of threads]:threads' \
          '1:archive:_files -g "*.zpaq"' && ret=0
        ;;
    esac
    ;;
esac

return ret
