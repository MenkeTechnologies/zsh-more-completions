#compdef bthcid
# Documentation: man bthcid(8)
# Source: netbsd/src usr.sbin/bthcid — Bluetooth link key/PIN daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[local device address (default BDADDR_ANY)]:device:_default' \
    '-f[run in foreground]' \
    '(- *)-h[display usage message]' \
    '-m+[file mode bits for PIN client socket (default 0660)]:mode:_default' \
    '-n[do not listen for PIN clients]' \
    '-s+[socket path for PIN clients (default /var/run/bthcid)]:socket:_files' \
    && ret=0

return ret
