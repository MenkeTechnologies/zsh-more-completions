#compdef sfewefd2d
# Documentation: http://www.ahay.org/RSF/sfewefd2d.html
# Madagascar: 2-D elastic time-domain finite-difference modeling

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'dabc=[absorbing BC]' \
  'free=[free surface flag]' \
  'jdata=[# of t steps at which to save receiver data]' \
  'jsnap=[# of t steps at which to save wavefield]' \
  'nbell=[bell size]' \
  'opot=[output potentials]' \
  'snap=[wavefield snapshots flag]' \
  'ssou=[stress source]' \
  'verb=[verbosity flag]' \
  'nqx=[saved wfld window nx]' \
  'nqz=[saved wfld window nz]' \
  'oqx=[saved wfld window ox]' \
  'oqz=[saved wfld window oz]' \
  'ccc=[stiffness tensor input file]:file:_files' \
  'den=[density input file]:file:_files' \
  'sou=[source coordinates input file]:file:_files' \
  'rec=[receiver coordinates input file]:file:_files' \
  'wfl=[wavefield output file]:file:_files' \
  '*:RSF file:_files' && ret=0

return ret
