#compdef purge_dups
# Documentation: https://github.com/dfguan/purge_dups
# haplotypic duplication identification tool for genome assemblies

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-2[enable 2 rounds of chaining]' \
  '-a+[minimum alignment score]:score' \
  '-b+[minimum max match score]:score' \
  '-c+[base-level coverage file]:file:_files' \
  '-T+[cutoffs file]:file:_files' \
  '-f+[minimum fraction of haploid/diploid/bad/repetitive bases]:fraction' \
  '-m+[minimum matching bases for chaining]:bases' \
  '-M+[maximum gap size for chaining]:size' \
  '-G+[maximum gap size for 2nd round chaining]:size' \
  '-l+[minimum chaining score for a match]:score' \
  '-E+[maximum extension for contig ends]:ext' \
  '-r[toggle read-to-reference alignment mode]' \
  ':paf file:_files' && ret=0

return ret
