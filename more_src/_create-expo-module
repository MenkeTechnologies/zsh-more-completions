#compdef create-expo-module
# Documentation: https://docs.expo.dev/more/create-expo-module/
# Reference accessed: 2026-05-23
# Verified: npm view create-expo-module bin; Expo create-expo-module reference at the URL above.

# Zsh completion for create-expo-module - Expo native module scaffolder

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add-platform-support:add platform support to an existing module'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '(-s --source)'{-s,--source=}'[local template directory]:directory:_directories'   '--with-readme[include README.md]'   '--with-changelog[include CHANGELOG.md]'   '--no-example[skip creating the example app]'   '--local[create a local module in the current project]'   '--barrel[generate index.ts barrel file for local modules]'   '--name=[native module name]:name:'   '--description=[module description]:description:'   '--package=[Android package name]:package:'   '--author-name=[author name]:name:'   '--author-email=[author email]:email:'   '--author-url=[author profile URL]:url:'   '--repo=[repository URL]:url:'   '--license=[license identifier]:license:'   '--module-version=[initial package version]:version:'   '(-p --platform)'{-p,--platform=}'[target platforms]:platform:(android apple web)'   '--features=[feature examples]:feature:(Constant Function AsyncFunction Event View ViewEvent SharedObject all)'   '--full-example[include all feature examples]'   '--package-manager=[package manager]:manager:(npm pnpm yarn bun)'   '1: :->cmd'   '*: :->rest' && ret=0

case $state in
  (cmd)
    _describe -t commands 'create-expo-module command' commands && ret=0
    ;;
  (rest)
    _arguments '*::args:' && ret=0
    ;;
esac

return ret
