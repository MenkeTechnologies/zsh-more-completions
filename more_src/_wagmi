#compdef wagmi
# Documentation: https://man.archlinux.org/search?q=wagmi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:create a new wagmi.config configuration file'
  'generate:generate code from contracts and plugins'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "wagmi.config.{ts,js,mts,mjs,cts,cjs}"' \
  '(-r --root)'{-r+,--root=}'[root directory for resolving config]:dir:_files -/' \
  '(-w --watch)'{-w,--watch}'[watch for file changes]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wagmi command' commands && ret=0 ;;
esac

return ret
