#compdef pct

# Zsh completion for pct - Proxmox VE container management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list containers'
  'create:create or restore a container'
  'destroy:destroy a container'
  'start:start a container'
  'stop:stop a container'
  'shutdown:shutdown a container'
  'reboot:reboot a container'
  'suspend:suspend a container'
  'resume:resume a suspended container'
  'status:show container status'
  'config:show container configuration'
  'set:set container options'
  'clone:clone a container'
  'migrate:migrate a container to another node'
  'move-volume:move a volume to different storage'
  'resize:resize a container volume'
  'template:create a template'
  'snapshot:create a snapshot'
  'rollback:rollback to a snapshot'
  'delsnapshot:delete a snapshot'
  'listsnapshot:list snapshots'
  'enter:enter the container namespace'
  'exec:execute a command in a container'
  'console:open a console to the container'
  'push:push a file to the container'
  'pull:pull a file from the container'
  'mount:mount the container filesystem'
  'unmount:unmount the container filesystem'
  'pending:show pending configuration changes'
  'unlock:unlock a container'
  'cpusets:show CPU sets'
  'fstrim:run fstrim on a container'
  'df:show disk usage'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pct command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '1:CTID' \
          '2:OS template:_files' \
          '--hostname=[container hostname]:hostname' \
          '--memory=[memory in MB]:MB' \
          '--swap=[swap in MB]:MB' \
          '--cores=[CPU cores]:count' \
          '--cpulimit=[CPU limit]:limit' \
          '--cpuunits=[CPU weight]:weight' \
          '--rootfs=[root filesystem]:config' \
          '--mp*=[mount point]:config' \
          '--net*=[network device]:config' \
          '--nameserver=[DNS nameserver]:IP address' \
          '--searchdomain=[DNS search domain]:domain' \
          '--ostype=[OS type]:type:(debian ubuntu centos fedora opensuse archlinux alpine gentoo nixos unmanaged)' \
          '--password=[root password]:password' \
          '--ssh-public-keys=[SSH public keys file]:file:_files' \
          '--storage=[default storage]:storage' \
          '--pool=[resource pool]:pool' \
          '--onboot=[start on boot]:enable:(0 1)' \
          '--start=[start after creation]:enable:(0 1)' \
          '--unprivileged=[make unprivileged container]:enable:(0 1)' \
          '--features=[container features]:features' \
          '--description=[description]:text' \
          '--tags=[tags]:tags' \
          '--arch=[architecture]:arch:(amd64 i386 arm64 armhf)' \
          '--cmode=[console mode]:mode:(console shell tty)' \
          '--protection=[protection from removal]:enable:(0 1)' \
          '--restore[restore from backup]' \
          '--force[allow overwriting existing data]' && ret=0
        ;;
      (start|stop|shutdown|reboot|suspend|resume|status|config|destroy|pending|unlock|mount|unmount|fstrim|df)
        _arguments -s -S '1:CTID' && ret=0
        ;;
      (set)
        _arguments -s -S \
          '1:CTID' \
          '--hostname=[container hostname]:hostname' \
          '--memory=[memory in MB]:MB' \
          '--swap=[swap in MB]:MB' \
          '--cores=[CPU cores]:count' \
          '--cpulimit=[CPU limit]:limit' \
          '--cpuunits=[CPU weight]:weight' \
          '--nameserver=[DNS nameserver]:IP address' \
          '--searchdomain=[DNS search domain]:domain' \
          '--onboot=[start on boot]:enable:(0 1)' \
          '--description=[description]:text' \
          '--tags=[tags]:tags' \
          '--protection=[protection from removal]:enable:(0 1)' \
          '--net*=[network device]:config' \
          '--mp*=[mount point]:config' \
          '--delete=[delete specified settings]:settings' && ret=0
        ;;
      (clone)
        _arguments -s -S \
          '1:source CTID' \
          '2:new CTID' \
          '--hostname=[new container hostname]:hostname' \
          '--full[create full copy]' \
          '--target=[target node]:node' \
          '--storage=[target storage]:storage' \
          '--pool=[resource pool]:pool' \
          '--snapname=[snapshot to clone from]:snapshot' && ret=0
        ;;
      (migrate)
        _arguments -s -S \
          '1:CTID' \
          '2:target node' \
          '--online[use online migration]' \
          '--restart[restart container on target]' \
          '--force[force migration]' \
          '--with-local-disks[migrate local disks]' \
          '--targetstorage=[target storage]:storage' && ret=0
        ;;
      (resize)
        _arguments -s -S \
          '1:CTID' \
          '2:disk:' \
          '3:size:' && ret=0
        ;;
      (enter|console)
        _arguments -s -S '1:CTID' && ret=0
        ;;
      (exec)
        _arguments -s -S \
          '1:CTID' \
          '*:command' && ret=0
        ;;
      (push)
        _arguments -s -S \
          '1:CTID' \
          '2:local file:_files' \
          '3:container path' \
          '--perms=[file permissions]:perms' \
          '--user=[file owner user]:user' \
          '--group=[file owner group]:group' && ret=0
        ;;
      (pull)
        _arguments -s -S \
          '1:CTID' \
          '2:container path' \
          '3:local file:_files' \
          '--perms=[file permissions]:perms' && ret=0
        ;;
      (snapshot)
        _arguments -s -S \
          '1:CTID' \
          '2:snapshot name' \
          '--description=[snapshot description]:text' && ret=0
        ;;
      (rollback)
        _arguments -s -S \
          '1:CTID' \
          '2:snapshot name' && ret=0
        ;;
      (delsnapshot)
        _arguments -s -S \
          '1:CTID' \
          '2:snapshot name' \
          '--force[force deletion]' && ret=0
        ;;
      (listsnapshot)
        _arguments -s -S '1:CTID' && ret=0
        ;;
      (template)
        _arguments -s -S '1:CTID' && ret=0
        ;;
      (move-volume)
        _arguments -s -S \
          '1:CTID' \
          '2:volume:' \
          '--storage=[target storage]:storage' \
          '--delete=[delete original]:enable:(0 1)' && ret=0
        ;;
    esac
    ;;
esac

return ret
