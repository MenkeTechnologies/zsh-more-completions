#compdef influxd-data
# Documentation: https://man.archlinux.org/search?q=influxd-data
# Reference accessed: 2026-05-16

# influxd-data: data node for InfluxDB Enterprise
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-config=[config file]:file:_files' \
  '-pidfile=[pid file]:file:_files' \
  '-cpuprofile=[CPU profile]:file:_files' \
  '-memprofile=[memory profile]:file:_files' \
  '-hostname=[hostname]:host:_hosts' \
  '-bind=[bind addr]:addr:' \
  '-auth-type=[auth type]:type:(none basic jwt)' \
  '-user=[user]:user:_users' \
  '-password=[password]:pass:' \
  '*::influxd-data args:_files' && ret=0
return ret
