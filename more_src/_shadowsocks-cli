#compdef shadowsocks-cli shadowsocks ss-server ss-local ss-redir ss-tunnel ss-manager
# _shadowsocks-cli — shadowsocks-libev secure SOCKS5 proxy CLI alias (shadowsocks team, C); custom argparse
# upstream: https://github.com/shadowsocks/shadowsocks-libev

_shadowsocks-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "*.json"' \
        '-s+[server hostname/IP]:host:_hosts' \
        '-p+[server port]:port:' \
        '-l+[local port]:port:' \
        '-k+[password]:str:' \
        '-m+[encryption method]:m:(aes-128-gcm aes-192-gcm aes-256-gcm aes-128-cfb aes-192-cfb aes-256-cfb aes-128-ctr aes-192-ctr aes-256-ctr camellia-128-cfb camellia-192-cfb camellia-256-cfb chacha20-ietf chacha20-ietf-poly1305 xchacha20-ietf-poly1305 rc4-md5)' \
        '-t+[timeout seconds]:n:' \
        '-a+[run as user]:_users' \
        '-i+[interface]:_net_interfaces' \
        '-b+[local address]:str:' \
        '-u[enable UDP relay]' \
        '-U[enable UDP relay and disable TCP]' \
        '-T[use tproxy]' \
        '-L+[tunnel address]:str:' \
        '-d+[DNS server]:str:' \
        '-f+[pid file]:file:_files' \
        '-6[prefer IPv6]' \
        '--mtu=+[mtu]:n:' \
        '--fast-open[enable TCP fast open]' \
        '--reuse-port[enable SO_REUSEPORT]' \
        '--no-delay[enable TCP_NODELAY]' \
        '--mptcp[enable Multipath TCP]' \
        '--key=+[base64 key]:str:' \
        '--plugin=+[obfs plugin]:str:' \
        '--plugin-opts=+[plugin options]:str:' \
        '--manager-address=+[manager socket]:str:' \
        '--executable=+[path]:file:_files' \
        '*:arg:'
}

_shadowsocks-cli "$@"
