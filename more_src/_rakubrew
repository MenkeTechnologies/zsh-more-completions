#compdef rakubrew
# _rakubrew — Raku / Rakudo environment manager (Raku/App-Rakubrew)
# upstream: https://github.com/Raku/App-Rakubrew
# Subcommands from script/rakubrew SYNOPSIS.

_rakubrew() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)help[show help]' \
        '1: :_rakubrew_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                version|current)
                    _arguments '--short[print only the version itself]' && ret=0 ;;
                global|switch|local|nuke|unregister|test)
                    _arguments '1:Rakudo version:' && ret=0 ;;
                shell)
                    _arguments \
                        '--unset[clear the per-shell Rakudo version]' \
                        '1:Rakudo version (optional):' && ret=0 ;;
                build)
                    _arguments \
                        '--configure-opts=[options forwarded to Rakudo configure]:opts:' \
                        '1:backend (moar / jvm / js):(moar jvm js)' \
                        '2:tag, branch or sha-1:' && ret=0 ;;
                triple)
                    _arguments \
                        '1:rakudo version:' \
                        '2:nqp version:' \
                        '3:moar version:' && ret=0 ;;
                register)
                    _arguments \
                        '1:name:' \
                        '2:path to existing Rakudo install:_files -/' && ret=0 ;;
                build-zef)
                    _arguments '1:zef version:' && ret=0 ;;
                download)
                    _arguments \
                        '1:backend:(moar jvm js)' \
                        '2:Rakudo version:' && ret=0 ;;
                exec)
                    _arguments \
                        '--with=[run with the specified Rakudo version]:version:' \
                        '1:executable:_command_names -e' \
                        '*::args:' && ret=0 ;;
                which|whence)
                    _arguments \
                        '--path[print full path]' \
                        '1:executable:' && ret=0 ;;
                mode)
                    _arguments '1: :(env shim)' && ret=0 ;;
                self-upgrade|init|rehash|versions|list|available|list-available|home|rakubrew-version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_rakubrew_commands] )) ||
_rakubrew_commands() {
    local -a commands
    commands=(
        'version:show the currently active Rakudo version'
        'current:alias of version'
        'versions:list installed Rakudo installations'
        'list:alias of versions'
        'global:set the globally active Rakudo version'
        'switch:alias of global'
        'shell:set the per-shell Rakudo version'
        'local:set the per-directory Rakudo version'
        'nuke:remove an installed Rakudo version'
        'unregister:alias of nuke'
        'rehash:re-create shims for installed executables'
        'available:list all available Rakudo versions'
        'list-available:alias of available'
        'build:build a Rakudo from source'
        'triple:install a specific rakudo / nqp / moar triple'
        'register:register an externally-installed Rakudo'
        'build-zef:build / install zef'
        'download:download a pre-built Rakudo'
        'exec:run an executable under a specific Rakudo version'
        'which:print the path of the active Rakudo executable'
        'whence:print which version provides an executable'
        'mode:switch between env and shim mode'
        'self-upgrade:upgrade rakubrew itself'
        'init:initialize rakubrew shell integration'
        'test:run the Rakudo test suite'
        'home:print the rakubrew home directory'
        'rakubrew-version:print the rakubrew version'
        'help:show help'
    )
    _describe -t commands 'rakubrew command' commands
}

_rakubrew "$@"
