#compdef liftUp
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: lift coordinates of a file from contig to chromosome

local ret=1

_arguments -s -S \
  '-nohead[no header written for .psl files]' \
  '-dots=[output a dot every N lines processed]:n' \
  '-pslQ[lift query (rather than target) side of psl]' \
  '-axtQ[lift query (rather than target) side of axt]' \
  '-chainQ[lift query (rather than target) side of chain]' \
  '-netQ[lift query (rather than target) side of net]' \
  '-wabaQ[lift query side of waba alignment]' \
  '-nosort[do not sort bed, gff, or gdup files, to save memory]' \
  '-gapsize[change contig gapsize from default]:n' \
  '-ignoreVersions[ignore NCBI-style version number in sequence ids]' \
  '-extGenePred[lift extended genePred]' \
  '-type=[specify file type]:type' \
  '1:dest file:_files' \
  '2:lift spec:_files' \
  '3:how:(carry drop warn error)' \
  '*:source file:_files' && ret=0

return ret
