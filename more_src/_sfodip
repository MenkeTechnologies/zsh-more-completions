#compdef sfodip
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: omnidirectional dip estimation

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'niter=[number of iterations]:niter:' \
  'liter=[number of linear iterations]:liter:' \
  'rect1=[dip smoothness on first axis]:rect1:' \
  'rect2=[dip smoothness on second axis]:rect2:' \
  'eta=[steplength factor]:eta:' \
  'dip0=[initial dip]:dip0:' \
  'radius=[interpolation radius]:radius:' \
  'n=[number of outer iterations]:n:' \
  'm=[number of inner iterations]:m:' \
  'interp=[interpolation (maxflat/lagrange/bspline)]:interp:(maxflat lagrange bspline)' \
  'slope=[estimate slope instead of dip (y/n)]:slope:(y n)' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
