#compdef menhir
# Documentation: https://man.archlinux.org/search?q=menhir
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--base=[base name]:name:' \
  '--cmly[generate .cmly file]' \
  '--canonical[canonical LR(1)]' \
  '--coq[generate Coq output]' \
  '--coq-no-actions[Coq without semantic actions]' \
  '--coq-no-complete[Coq without completeness]' \
  '--depend[output deps in OCaml format]' \
  '--dump[dump tables]' \
  '--explain[explain conflicts]' \
  '--external-tokens=[external token module]:module:' \
  '--graph[output automaton graph]' \
  '--infer[run ocamlc -i to infer]' \
  '--infer-write-query=[write infer query]:file:_files' \
  '--infer-read-reply=[read infer reply]:file:_files' \
  '--inspection[generate inspection API]' \
  '--interpret[interpret the grammar]' \
  '--interpret-show-cst[show CST in interpret]' \
  '--lalr[LALR(1)]' \
  '--list-errors[list error states]' \
  '--log-automaton=[log automaton]:n:' \
  '--log-code=[log code]:n:' \
  '--log-grammar=[log grammar]:n:' \
  '--no-code-inlining[no code inlining]' \
  '--no-inline[no rule inlining]' \
  '--no-pager[no pager algorithm]' \
  '--no-stdlib[do not load stdlib]' \
  '--ocamlc=[ocamlc command]:cmd:_command_names' \
  '--ocamldep=[ocamldep command]:cmd:_command_names' \
  '--only-preprocess[only run preprocessor]' \
  '--only-preprocess-u[only preprocess (unstructured)]' \
  '--only-tokens[only generate tokens]' \
  '--raw-depend[output raw deps]' \
  '--require-aliases[require aliases]' \
  '--strict[strict mode]' \
  '--suggest-comp-flags[suggest compile flags]' \
  '--suggest-link-flags-byte[suggest byte link flags]' \
  '--suggest-link-flags-opt[suggest opt link flags]' \
  '--suggest-menhirLib[suggest MenhirLib path]' \
  '--suggest-ocamlfind[suggest ocamlfind]' \
  '--summary[summary information]' \
  '--table[table-based parser]' \
  '--timings[print timings]' \
  '--trace[generate trace functions]' \
  '--unused-precedence-levels[allow unused precedence levels]' \
  '--unused-tokens[allow unused tokens]' \
  '--version[print version]' \
  '--update-errors=[update error states]:file:_files' \
  '--compile-errors=[compile error states]:file:_files' \
  '*:grammar:_files -g "*.mly"' && ret=0

return ret
