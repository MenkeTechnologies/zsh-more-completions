#compdef snowpack

# Zsh completion for snowpack - Frontend build tool

_snowpack_commands() {
  local -a commands=(
    'dev:start development server'
    'build:build for production'
    'init:create a new project'
    'add:add a package'
    'rm:remove a package'
  )
  _describe -t commands 'snowpack command' commands
}

_snowpack_dev() {
  _arguments \
    '--config[specify config file]:file:_files' \
    '--port[specify port]:port:' \
    '--hostname[specify hostname]:hostname:' \
    '--open[open browser to URL]:url:' \
    '--output[specify output directory]:directory:_directories' \
    '--reload[clear cache on startup]' \
    '--verbose[enable verbose output]' \
    '--quiet[suppress output]' \
    '--secure[enable HTTPS]' \
    '--polyfill-node[polyfill Node.js built-ins]'
}

_snowpack_build() {
  _arguments \
    '--config[specify config file]:file:_files' \
    '--watch[watch for changes and rebuild]' \
    '--verbose[enable verbose output]' \
    '--quiet[suppress output]' \
    '--clean[clean output directory before build]'
}

_snowpack_init() {
  _arguments \
    '--template[use a starter template]:template name:' \
    '--verbose[enable verbose output]' \
    '--quiet[suppress output]'
}

_snowpack() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:_snowpack_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        dev)
          _snowpack_dev
          ;;
        build)
          _snowpack_build
          ;;
        init)
          _snowpack_init
          ;;
        add)
          _arguments '*:package name:'
          ;;
        rm)
          _arguments '*:package name:'
          ;;
      esac
      ;;
  esac
}

_snowpack "$@"
