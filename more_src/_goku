#compdef goku gokuw
# Documentation: https://github.com/yqrashawn/GokuRakuJoudo (src/karabiner_configurator/core.clj cli/parse-opts)
# Reference accessed: 2026-05-29
# Goku — Karabiner-Elements configurator using EDN DSL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-l,--log}'[open the goku log file]' \
  '(- *)--where-is-my-config[show config file path]' \
  '(-c --config)'{-c,--config=}'[EDN config file path]:file:_files -g "*.edn"' \
  '(-d --dry-run -A --dry-run-all)'{-d,--dry-run}'[output modified profile config to stdout instead of updating karabiner.json]' \
  '(-d --dry-run -A --dry-run-all)'{-A,--dry-run-all}'[output entire resulting config to stdout instead of updating karabiner.json]' && ret=0

return ret
