#compdef autosp
# Documentation: autosp --help (autosp 2025)
# Source: TeX autosp — MusiXTeX automatic-spacing pre-processor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-d --dotted)'{-d,--dotted}'[include dotted-rhythm support]' \
    '(-l --log)'{-l,--log}'[write log file]' \
    '1:input MusiXTeX (.aspc):_files -g "*.aspc"' \
    '2:output TeX file:_files -g "*.tex"' \
    && ret=0

return ret
