#compdef rps
# Documentation: https://pub.dev/packages/rps
# rps - run scripts defined in pubspec.yaml for Dart/Flutter projects

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(-h --help)'{-h,--help}'[display help information]' \
  '--version[show version number]' \
  '(-u --upgrade)'{-u,--upgrade}'[update rps to the latest version]' \
  '1:command:(ls run)' \
  '*::script:' && ret=0

return ret
