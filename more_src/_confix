#compdef confix
# Documentation: upstream README at github.com/cosmos/cosmos-sdk/tree/main/tools/confix
# Reference accessed: 2026-05-30
# Cosmos SDK confix — TOML configuration management for Cosmos SDK
# applications (app.toml + client.toml). Based on CometBFT RFC 019.
# Sister-binary to existing _cosmovisor coverage.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'get:retrieve a configuration value from app.toml or client.toml'
  'set:set a configuration value in app.toml or client.toml'
  'migrate:migrate a configuration file to a newer Cosmos SDK version'
  'diff:compare current config against defaults for a given version'
  'view:display configuration file contents'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'confix subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      get|set)
        _arguments \
          '1:TOML file:_files -g "*.toml"' \
          '2:key (e.g. pruning):' \
          '3:value (set only):' && ret=0
        ;;
      migrate|diff)
        _arguments \
          '--client[operate on client.toml instead of app.toml]' \
          '1:version:' \
          '2:TOML file:_files -g "*.toml"' && ret=0
        ;;
      view)
        _arguments \
          '1:TOML file:_files -g "*.toml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
