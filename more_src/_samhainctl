#compdef samhainctl
# Documentation: https://man.archlinux.org/search?q=samhainctl
# Reference accessed: 2026-05-16

# samhainctl: control / status helper for Samhain HIDS
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart status update reload force-stop check init init-database)' \
  '*::samhainctl args:_files' && ret=0
return ret
