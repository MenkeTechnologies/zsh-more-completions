#compdef dmtabfilt
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmtabfilt.html
# Apply a sliding-window filter function to a table column

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input filename]:infile:_files' \
  'colname=[column name to filter]:colname:' \
  'outfile=[output filename]:outfile:_files' \
  'function=[filter function to apply]:function:(min max mean median sum count sigma extreme range variance)' \
  'mask=[mask of adjacent rows to include]:mask:' \
  'clobber=[remove output if it exists]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
