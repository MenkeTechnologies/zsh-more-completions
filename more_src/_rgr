#compdef rgr
# Documentation: https://man.archlinux.org/search?q=rgr
# Reference accessed: 2026-05-16

# https://github.com/acheronfail/repgrep — argument shape matches ripgrep; use rg completions when available

local curcontext="$curcontext" ret=1

if (( $+functions[_rg] )); then
  _rg "$@"
  ret=$?
else
  _arguments '*::ripgrep-style arguments:_default' && ret=0
fi

return ret
