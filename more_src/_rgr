#compdef rgr
# Documentation: https://github.com/acheronfail/repgrep
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# repgrep is an interactive ripgrep replacer; it accepts ripgrep arguments,
# so we delegate to _rg if available, otherwise fall back to default file
# completion. README directs users to `rgr --help` for full flag info.

local curcontext="$curcontext" ret=1

if (( $+functions[_rg] )); then
  _rg "$@"
  ret=$?
else
  _arguments '*::ripgrep-style arguments:_default' && ret=0
fi

return ret
