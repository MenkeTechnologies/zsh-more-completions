#compdef clevis-encrypt-http
# Documentation: https://manpages.debian.org/testing/clevis/clevis-encrypt-http.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# clevis encrypt http: encrypt plaintext to a URL-based key escrow (HTTP/HTTPS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:JWE config JSON (e.g. {"url":"http://server/key"}):' && ret=0
return ret
