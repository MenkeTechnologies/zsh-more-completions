#compdef clevis-encrypt-http
# Documentation: https://man.archlinux.org/search?q=clevis-encrypt-http
# Reference accessed: 2026-05-16

# clevis encrypt http: encrypt plaintext to a URL-based key escrow (HTTP/HTTPS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:JWE config JSON (e.g. {"url":"http://server/key"}):' && ret=0
return ret
