#compdef jed jed-script xjed
# Documentation: https://man.archlinux.org/search?q=jed
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--secure[run in secure mode]' \
  '--batch[batch (non-interactive)]' \
  '--script[script mode]' \
  '-2[split window into two]' \
  '-i+[insert file before reading]:file:_files' \
  '-l+[load S-Lang file]:file:_files -g "*.sl"' \
  '-f+[run S-Lang function]:fn:' \
  '-g+[goto line]:n:' \
  '-s+[goto string]:str:' \
  '-n[do not load .jedrc]' \
  '+[do not look for site-init.sl]' \
  '*: :_files' && ret=0

return ret
