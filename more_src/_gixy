#compdef gixy
# Documentation: https://man.archlinux.org/search?q=gixy
# Reference accessed: 2026-05-16

# https://github.com/yandex/gixy — ConfigArgParse (gixy/cli/main.py, argparser.py)
_arguments -s -S   '(-h --help)'{-h,--help}'[help]'   '(-v --version)'{-v,--version}'[version]'   '(-c --config)'{-c,--config}'=-[config file]:file:_files'   '--write-config[path to write merged config]:file:_files'   '-l+[raise minimum severity (-l LOW, -ll MEDIUM, -lll HIGH)]'   '(-f --format)'{-f,--format}'=-[report format]:format:(console text ansi json)'   '(-o --output)'{-o,--output}'=-[write report]:file:_files'   '(-d --debug)'{-d,--debug}'[debug logging]'   '--tests=-[comma-separated tests to run]'   '--skips=-[comma-separated tests to skip]'   '--disable-includes[do not follow include directives]'   '*:nginx config:_files'
