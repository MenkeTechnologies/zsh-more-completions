#compdef strapi

# Zsh completion for Strapi - headless CMS

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new Strapi project'
  'develop:start Strapi in development mode'
  'start:start Strapi in production mode'
  'build:build Strapi admin panel'
  'deploy:deploy Strapi'
  'export:export data from Strapi'
  'import:import data to Strapi'
  'transfer:transfer data between Strapi instances'
  'report:get debugging information'
  'version:show version'
  'help:show help'
  'console:open interactive console'
  'routes:list API routes'
  'policies:list policies'
  'middlewares:list middlewares'
  'content-types:list content types'
  'hooks:list hooks'
  'controllers:list controllers'
  'services:list services'
  'install:install a Strapi plugin'
  'uninstall:uninstall a Strapi plugin'
  'generate:generate code'
  'templates:generate template'
  'ts:manage TypeScript configuration'
  'telemetry:manage telemetry'
  'admin:manage admin users'
  'configuration:manage configuration'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'strapi command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      new)
        _arguments \
          '--quickstart[quickstart mode]' \
          '--template=[template]:template:' \
          '--typescript[use TypeScript]' \
          '--no-run[do not start after creation]' \
          '--dbclient=[database client]:client:(sqlite mysql postgres)' \
          '--dbhost=[database host]:host:_hosts' \
          '--dbport=[database port]:port:' \
          '--dbname=[database name]:name:' \
          '--dbusername=[database username]:username:' \
          '--dbpassword=[database password]:password:' \
          '1:project name:'
        ;;
      develop)
        _arguments \
          '--watch-admin[watch admin panel for changes]' \
          '--browser=[open browser]:bool:(true false)' \
          '--polling[use polling for file watching]'
        ;;
      build)
        _arguments \
          '--clean[clean build directory first]' \
          '--no-optimization[skip admin optimization]'
        ;;
      export)
        _arguments \
          '--file=[output file]:file:_files' \
          '--key=[encryption key]:key:' \
          '--no-encrypt[skip encryption]' \
          '--no-compress[skip compression]' \
          '--only=[export only specific content]:content:(content files config)'
        ;;
    esac
    ;;
esac

return ret
