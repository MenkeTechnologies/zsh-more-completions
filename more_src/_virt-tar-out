#compdef virt-tar-out
# _virt-tar-out — libguestfs virt-tar-out (write a tar archive containing an in-guest directory of a libvirt VM image; -a disk, -d domain, -c libvirt URI, -m mount spec, --format disk format; positional in-guest directory followed by output tar)
# upstream: https://github.com/libguestfs/libguestfs (cat)
# Flags from libguestfs cat/cat.ml (tar variants) on tip.

_virt-tar-out() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*-m+[mount spec]:mountspec:' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)' \
        '1:in-guest directory:' \
        '2:output tar:_files -g "*.(tar|tar.gz|tar.xz|tar.bz2|tar.zst|tgz)"'
}

_virt-tar-out "$@"
