#compdef anisoanl
# CCP4: analyse anisotropic displacement parameters and fit TLS tensors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input PDB file with anisotropic U values]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'TLSIN[input TLS group definitions]:tls:_files' \
  'XYZOUT[output coordinates with residual U values]:output:_files' \
  'TLSOUT[output fitted TLS tensors]:output:_files' \
  'PSOUT[output PostScript plot]:output:_files' \
  '*:keyword:(FITTLS RIGIDBODY PLOT MAINCHAIN VERBOSE END)' && ret=0

return ret
