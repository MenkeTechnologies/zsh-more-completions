#compdef fiftyone

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'app:manage the FiftyOne App'
  'datasets:manage datasets'
  'zoo:manage the FiftyOne Zoo'
  'migrate:run database migrations'
  'utils:utility commands'
  'config:manage configuration'
  'constants:print package constants'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'fiftyone command' commands && ret=0
    ;;
  args)
    case $line[1] in
      app)
        _arguments -s -S \
          '1:action:(launch connect config)' \
          '--port[port number]:port:' \
          '--address[bind address]:address:' \
          '--remote[connect to remote session]' \
          '--help[show help]' && ret=0
        ;;
      datasets)
        _arguments -s -S \
          '1:action:(list info create delete head tail stats)' \
          '--name[dataset name]:name:' \
          '--help[show help]' && ret=0
        ;;
      zoo)
        _arguments -s -S \
          '1:action:(datasets models list info download load)' \
          '--name[name]:name:' \
          '--split[split]:split:(train test validation)' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
