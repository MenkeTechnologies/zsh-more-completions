#compdef fdtgrep
# Documentation: https://github.com/u-boot/u-boot/blob/master/tools/fdtgrep.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fdtgrep: grep a flattened devicetree file (U-Boot tools).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --show-address)'{-a,--show-address}'[display memory addresses]' \
  '(-f --show-offset)'{-f,--show-offset}'[display offset values]' \
  '(-H --show-header)'{-H,--show-header}'[output FDT header information]' \
  '(-I --show-version)'{-I,--show-version}'[show version string in output]' \
  '(-A --colour)'{-A,--colour}'[use ANSI colour in output]' \
  '(-d --diff)'{-d,--diff}'[display +/- diff markers]' \
  '(-c --include-compat)'{-c+,--include-compat=}'[include nodes matching compatible string]:compat:' \
  '(-C --exclude-compat)'{-C+,--exclude-compat=}'[exclude nodes matching compatible string]:compat:' \
  '(-g --include-match)'{-g+,--include-match=}'[include matching property values]:value:' \
  '(-G --exclude-match)'{-G+,--exclude-match=}'[exclude matching property values]:value:' \
  '*'{-n+,--include-node=}'[include specified node names]:node:' \
  '*'{-N+,--exclude-node=}'[exclude specified node names]:node:' \
  '*'{-p+,--include-prop=}'[include specified properties]:property:' \
  '*'{-P+,--exclude-prop=}'[exclude specified properties]:property:' \
  '(-b --include-node-with-prop)'{-b+,--include-node-with-prop=}'[include nodes with given property]:property:' \
  '(-o --out)'{-o+,--out=}'[output filename]:file:_files' \
  '(-O --out-format)'{-O+,--out-format=}'[output format]:fmt:(dts dtb bin)' \
  '(-m --include-mem)'{-m,--include-mem}'[include memory reservation map]' \
  '(-r --remove-strings)'{-r,--remove-strings}'[strip unused strings from output]' \
  '(-R --include-root)'{-R,--include-root}'[include root node in output]' \
  '(-l --list-regions)'{-l,--list-regions}'[display region list]' \
  '(-L --list-strings)'{-L,--list-strings}'[display string table contents]' \
  '*:dtb file:_files -g "*.dtb"' && ret=0
return ret
