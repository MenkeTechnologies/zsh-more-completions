#compdef mullvad-problem-report
# _mullvad-problem-report — Mullvad VPN problem report collector (mullvad/mullvadvpn-app)
# upstream: https://github.com/mullvad/mullvadvpn-app
# Subcommands from mullvad-problem-report/src/main.rs (clap).

_mullvad-problem-report() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'collect:collect problem report to a single file'
                'send:send a previously collected report'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                collect)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[destination file (- for stdout)]:file:_files' \
                        '*--redact=[string to redact from report]:string:' \
                        '*:extra log:_files'
                    ;;
                send)
                    _arguments \
                        '(-r --report)'{-r+,--report=}'[previously collected report]:file:_files' \
                        '(-e --email)'{-e+,--email=}'[email to attach]:email:' \
                        '(-m --message)'{-m+,--message=}'[message body]:text:'
                    ;;
            esac
            ;;
    esac
}

_mullvad-problem-report "$@"
