#compdef SamToFastq
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/SamToFastq.java
# Picard: extract read sequences and qualities from a BAM/SAM into FASTQ

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '(-F --FASTQ)'{-F,--FASTQ}'=[output FASTQ (first end)]:file:_files' \
  '(-F2 --SECOND_END_FASTQ)'{-F2,--SECOND_END_FASTQ}'=[output FASTQ for second end]:file:_files' \
  '(-FU --UNPAIRED_FASTQ)'{-FU,--UNPAIRED_FASTQ}'=[output FASTQ for unpaired reads]:file:_files' \
  '(-OPRG --OUTPUT_PER_RG)'{-OPRG,--OUTPUT_PER_RG}'=[output a FASTQ per read group]:b:(true false)' \
  '(-GZOPRG --COMPRESS_OUTPUTS_PER_RG)'{-GZOPRG,--COMPRESS_OUTPUTS_PER_RG}'=[gzip per-read-group outputs]:b:(true false)' \
  '(-RGT --RG_TAG)'{-RGT,--RG_TAG}'=[read group tag for per-RG output]:tag:(PU ID)' \
  '(-ODIR --OUTPUT_DIR)'{-ODIR,--OUTPUT_DIR}'=[output directory for per-RG FASTQ]:dir:_files -/' \
  '(-RC --RE_REVERSE)'{-RC,--RE_REVERSE}'=[re-reverse reverse-strand reads]:b:(true false)' \
  '(-INTER --INTERLEAVE)'{-INTER,--INTERLEAVE}'=[interleaved FASTQ for paired reads]:b:(true false)' \
  '(-NON_PF --INCLUDE_NON_PF_READS)'{-NON_PF,--INCLUDE_NON_PF_READS}'=[include non-PF reads]:b:(true false)' \
  '(-CLIP_ATTR --CLIPPING_ATTRIBUTE)'{-CLIP_ATTR,--CLIPPING_ATTRIBUTE}'=[SAM attribute storing clip position]:attr:' \
  '(-CLIP_ACT --CLIPPING_ACTION)'{-CLIP_ACT,--CLIPPING_ACTION}'=[action for clipped reads]:act:' \
  '(-CLIP_MIN --CLIPPING_MIN_LENGTH)'{-CLIP_MIN,--CLIPPING_MIN_LENGTH}'=[min read length after clipping]:n:' \
  '(-R1_TRIM --READ1_TRIM)'{-R1_TRIM,--READ1_TRIM}'=[bases to trim from start of read 1]:n:' \
  '(-R1_MAX_BASES --READ1_MAX_BASES_TO_WRITE)'{-R1_MAX_BASES,--READ1_MAX_BASES_TO_WRITE}'=[max bases from read 1]:n:' \
  '(-R2_TRIM --READ2_TRIM)'{-R2_TRIM,--READ2_TRIM}'=[bases to trim from start of read 2]:n:' \
  '(-R2_MAX_BASES --READ2_MAX_BASES_TO_WRITE)'{-R2_MAX_BASES,--READ2_MAX_BASES_TO_WRITE}'=[max bases from read 2]:n:' \
  '(-Q --QUALITY)'{-Q,--QUALITY}'=[Phred quality threshold for end-trimming]:n:' \
  '--INCLUDE_NON_PRIMARY_ALIGNMENTS=[include secondary/supplementary alignments]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
