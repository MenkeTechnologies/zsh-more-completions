#compdef condor_vacate

# condor_vacate: gracefully vacate one or more execute nodes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-name[startd name]:name:' \
  '-fast[fast vacate (no checkpoint)]' \
  '-peaceful[peaceful vacate (drain)]' \
  '-graceful[graceful vacate (default)]' \
  '-all[vacate all hosts in pool]' \
  '-addr[address]:sinful:' \
  '-constraint[constraint expression]:expr:' \
  '*:host:_hosts' && ret=0
return ret
