#compdef condor_vacate
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_vacate.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-graceful[graceful soft-kill (default)]' \
  '-fast[hard-kill without graceful shutdown]' \
  '-debug[send debugging output to stderr]' \
  '-pool[central manager host[:port]]:pool:' \
  '-name[target machine hostname]:hostname:_hosts' \
  '-addr[machine address]:sinful:' \
  '-constraint[ClassAd expression]:expr:' \
  '-all[target all machines in pool]' \
  '*:host:_hosts' && ret=0
return ret
