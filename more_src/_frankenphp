#compdef frankenphp
# Documentation: https://man.archlinux.org/search?q=frankenphp
# Reference accessed: 2026-05-16

# FrankenPHP — embeds PHP via Go runner; `frankenphp run|php-config|phpize` etc. (see dunglas/frankenphp `frankenphp --help`).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'run:start worker mode'
  'php-config:print php-config–like flags'
  'phpize:prepare build'
  'build-embed:emit libs for embedding'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'frankenphp' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
