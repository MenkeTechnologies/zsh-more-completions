#compdef cmake-annotate
# Documentation: https://cmake-format.readthedocs.io/en/latest/cmake-annotate.html
# cmakelang utility that re-emits cmake listfiles with semantic annotations in HTML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(page stub iframe)' \
  '(-o --outfile-path)'{-o,--outfile-path}'=[output file path (default stdout)]:outfile:_files' \
  '(-c --config-file)'{-c,--config-file}'=[path to configuration file]:config:_files' \
  '*:infile:_files' && ret=0

return ret
