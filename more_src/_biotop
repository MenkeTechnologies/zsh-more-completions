#compdef biotop biotop-bpfcc
# _biotop — top-style block I/O activity per process (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/biotop.py (argparse).

_biotop() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-C --noclear)'{-C,--noclear}'[do not clear the screen between intervals]'
        '(-r --maxrows)'{-r+,--maxrows=}'[max rows to display]:n:'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_biotop "$@"
