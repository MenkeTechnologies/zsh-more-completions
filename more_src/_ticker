#compdef ticker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config+[path to config file]:config:_files -g "*.{yml,yaml}(-.)"' \
  '-w+[comma-separated list of stock symbols to watch]:symbols:' \
  '--show-fundamentals[show fundamental stock data]' \
  '--show-holdings[show holdings]' \
  '--show-separator[show separator between stocks]' \
  '--show-tags[show stock tags]' \
  '--show-summary[show portfolio summary]' \
  '--sort+[sort order]:order:(alpha value change changepercent)' \
  '--proxy+[proxy URL]:URL:' \
  '--interval+[refresh interval]:seconds:' && ret=0

return ret
