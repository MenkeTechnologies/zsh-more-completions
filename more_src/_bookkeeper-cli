#compdef bookkeeper-cli bkctl
# _bookkeeper-cli — Apache BookKeeper bookkeeper-cli bkctl CLI command-line frontend wrapping the Apache BookKeeper distributed log storage service used by Apache Pulsar Apache DistributedLog providing bookie ledger metadata zookeeper-recover-cluster-info auto-recovery cluster-summary stats bookies update-cookie format-bookie-shell admin-bookieops shutdown-rejection (Apache BookKeeper team, Java); custom argparse
# upstream: https://bookkeeper.apache.org/

_bookkeeper-cli() {
    local -a sub=(
        'bookie:bookie operations'
        'ledger:ledger operations'
        'metadata:metadata operations'
        'cluster:cluster operations'
        'autorecovery:auto-recovery operations'
        'stats:statistics operations'
        'admin:admin operations'
        'zookeeper:ZooKeeper operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "bk_server.conf *.conf"' \
        '--config=+[file]:file:_files -g "*.conf"' \
        '--zookeeper=+[host:port]:str:' \
        '--ledgers-root-path=+[path]:str:' \
        '--metadata-service-uri=+[uri]:str:' \
        '--bookies=+[list]:str:' \
        '--quiet[quiet]' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bookkeeper-cli subcommand' sub ;;
        args)
            case $words[1] in
                bookie) _arguments '1:op:(list info format quarantine recover sandbox decommission convert sanity-check book-formula info-status check-shutdown)' '*:bookie addr:' ;;
                ledger) _arguments '1:op:(list show recover bench delete repair force-delete repair-bin)' '*:ledger id:' ;;
                cluster) _arguments '1:op:(list summary listunderreplicated rebalance)' ;;
                autorecovery) _arguments '1:op:(start stop status)' ;;
            esac
            ;;
    esac
}

_bookkeeper-cli "$@"
