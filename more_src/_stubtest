#compdef stubtest
# mypy stub testing tool

local ret=1

_arguments -s -S \
  '--concise[print concise output]' \
  '--ignore-missing-stub[ignore missing stubs]' \
  '--ignore-positional-only[ignore positional-only differences]' \
  '--allowlist=[allowlist file]:file:_files' \
  '--generate-allowlist[generate allowlist from failures]' \
  '--mypy-config-file=[mypy config file]:file:_files' \
  '--custom-typeshed-dir=[custom typeshed directory]:directory:_files -/' \
  '--check-typeshed[check typeshed stubs]' \
  '--python-executable=[Python executable]:executable:_files' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:modules:' && ret=0

return ret
