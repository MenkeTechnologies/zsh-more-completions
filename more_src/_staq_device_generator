#compdef staq_device_generator
# Documentation: https://github.com/softwareQinc/staq/wiki/The-staq-tool-suite
# staq tool: generate device coupling configurations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-r[rectangular lattice layout]:rows' \
  '-c[circular layout]:qubits' \
  '-l[linear layout]:qubits' \
  '*::subcommand:(graph)' && ret=0

return ret
