#compdef slsa-verifier

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'verify-artifact:verify provenance of a software artifact'
  'verify-image:verify provenance of a container image'
  'verify-npm-package:verify provenance of an npm package'
  'verify-vsa:verify a Verified Software Attestation'
  'version:display version'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      verify-artifact)
        _arguments \
          '--provenance-path=[path to provenance file]:provenance file:_files' \
          '--source-uri=[expected source repository URI]:URI' \
          '--source-tag=[expected source tag]:tag' \
          '--source-versioned-tag=[expected source versioned tag]:tag' \
          '--source-branch=[expected source branch]:branch' \
          '--builder-id=[expected builder ID]:ID' \
          '--build-workflow-input=[expected workflow inputs]:key=value' \
          '--print-provenance[print the verified provenance]' \
          '*:artifact:_files' && ret=0
        ;;
      verify-image)
        _arguments \
          '--source-uri=[expected source repository URI]:URI' \
          '--source-tag=[expected source tag]:tag' \
          '--source-versioned-tag=[expected source versioned tag]:tag' \
          '--source-branch=[expected source branch]:branch' \
          '--builder-id=[expected builder ID]:ID' \
          '--build-workflow-input=[expected workflow inputs]:key=value' \
          '--print-provenance[print the verified provenance]' \
          '1:image reference' && ret=0
        ;;
      verify-npm-package)
        _arguments \
          '--attestations-path=[path to attestations]:file:_files' \
          '--builder-id=[expected builder ID]:ID' \
          '--package-name=[expected package name]:name' \
          '--package-version=[expected package version]:version' \
          '--source-uri=[expected source repository URI]:URI' \
          '--print-provenance[print the verified provenance]' \
          '*:package tarball:_files -g "*.tgz"' && ret=0
        ;;
    esac
    ;;
esac

return ret
