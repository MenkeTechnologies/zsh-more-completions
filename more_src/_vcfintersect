#compdef vcfintersect
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfintersect.md
# Intersect, subtract, or union VCF records against BED, region, or another VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bed)'{-b,--bed}'[use intervals provided by this BED file]:BED file:_files -g "*.bed"' \
  '*'{-R,--region}'[use 1-based tabix-style region (e.g. chrZ:10-20)]:region' \
  '(-S --start-only)'{-S,--start-only}'[use only the start position to determine overlap]' \
  '(-v --invert)'{-v,--invert}'[invert selection, printing only records not otherwise printed]' \
  '(-i --intersect-vcf)'{-i,--intersect-vcf}'[use this VCF for set intersection generation]:VCF file:_files -g "*.(vcf|vcf.gz)"' \
  '(-u --union-vcf)'{-u,--union-vcf}'[use this VCF for set union generation]:VCF file:_files -g "*.(vcf|vcf.gz)"' \
  '(-w --window-size)'{-w,--window-size}'[compare records up to this many bp away (default 30)]:bp' \
  '(-r --reference)'{-r,--reference}'[FASTA reference file (required with -i and -u)]:FASTA file:_files' \
  '(-l --loci)'{-l,--loci}'[output whole loci when one alternate allele matches]' \
  '(-m --ref-match)'{-m,--ref-match}'[intersect on the basis of record REF string]' \
  '(-t --tag)'{-t,--tag}'[attach TAG to each record info field if it intersects]:tag' \
  '(-V --tag-value)'{-V,--tag-value}'[value to indicate a passing allele (default PASS)]:value' \
  '(-M --merge-from)'{-M,--merge-from}'[merge source tag]:tag' \
  '(-T --merge-to)'{-T,--merge-to}'[merge destination tag]:tag' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
