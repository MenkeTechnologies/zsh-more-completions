#compdef v.import
# GRASS GIS: import vector data with reprojection on the fly

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f[list supported OGR formats and exit]' \
  '-l[list available OGR layers and exit]' \
  '-o[override projection check]' \
  '--overwrite[allow output to overwrite existing files]' \
  '--verbose[verbose output]' \
  '--quiet[quiet output]' \
  '--input=[OGR datasource to import]:datasource:_files' \
  '--layer=[OGR layer name(s)]:layer:' \
  '--output=[output vector map]:name:' \
  '--extent=[output extent]:extent:(input region)' \
  '--encoding=[encoding for attribute data]:encoding:' \
  '--snap=[snapping threshold for boundaries]:snap:' \
  '--epsg=[EPSG projection code]:epsg:' \
  '--datum_trans=[datum transform parameters index]:datum_trans:' && ret=0

return ret
