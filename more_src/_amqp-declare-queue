#compdef amqp-declare-queue
# Documentation: https://man.archlinux.org/search?q=amqp-declare-queue
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--usage[show usage]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-S --server)'{-S,--server}'+[broker host[:port]]:server:_hosts' \
  '--port=[broker port]:port:' \
  '(-u --url)'{-u,--url}'+[broker URL]:url:' \
  '--vhost=[virtual host]:vhost:' \
  '--username=[username]:user:' \
  '--password=[password]:pw:' \
  '--ssl[use TLS]' \
  '--cacert=[CA certificate]:file:_files' \
  '--cert=[client cert]:file:_files' \
  '--key=[client key]:file:_files' \
  '--verify[verify peer]' \
  '--heartbeat=[heartbeat seconds]:sec:' \
  '(-q --queue)'{-q,--queue}'+[queue name (or anonymous)]:name:' \
  '(-d --durable)'{-d,--durable}'[durable queue]' \
  '(-x --exclusive)'{-x,--exclusive}'[exclusive queue]' \
  '(-a --auto-delete)'{-a,--auto-delete}'[auto-delete when not in use]' \
  '(-p --passive)'{-p,--passive}'[passive declare (existence check)]' && ret=0

return ret
