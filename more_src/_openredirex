#compdef openredirex
# Documentation: https://github.com/devanshbatham/OpenRedireX
# Fuzzer for detecting open redirect vulnerabilities.

local ret=1

_arguments -s -S \
  '(-p --payloads)'{-p,--payloads}'[file with a list of payloads]:file:_files' \
  '(-k --keyword)'{-k,--keyword}'[keyword in URLs to replace with payload (default FUZZ)]:keyword' \
  '(-c --concurrency)'{-c,--concurrency}'[number of concurrent tasks (default 100)]:concurrency' && ret=0

return ret
