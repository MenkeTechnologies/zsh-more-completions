#compdef pdfresurrect

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-i[show document info]' \
  '-q[suppress non-essential output]' \
  '-w[write extracted versions]' \
  '-s[summary mode]' \
  '-h[show help]' \
  '-v[show version]' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
