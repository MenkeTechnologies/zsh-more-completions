#compdef sfclpf
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: local prediction filter for complex numbers (n-dimensional)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'niter=[number of iterations]:niter:' \
  'pred=[output prediction file]:pred:_files' \
  'rect1=[smoothing radius on first axis]:rect1:' \
  'rect2=[smoothing radius on second axis]:rect2:' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
