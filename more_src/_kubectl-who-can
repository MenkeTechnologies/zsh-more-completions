#compdef kubectl-who-can

# Zsh completion for kubectl-who-can - RBAC permissions check for Kubernetes

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[check in all namespaces]' \
  '(-n --namespace)'{-n,--namespace}'[namespace to check]:namespace' \
  '(-o --output)'{-o,--output}'[output format]:format:(json wide)' \
  '--subresource=[SubResource to check]:subresource' \
  '--cluster-roles[include cluster roles in output]' \
  '--no-headers[do not print headers]' \
  '1:verb:(get list watch create update patch delete deletecollection)' \
  '2:resource:(pods deployments services configmaps secrets nodes namespaces statefulsets daemonsets replicasets jobs cronjobs ingresses persistentvolumeclaims persistentvolumes serviceaccounts roles rolebindings clusterroles clusterrolebindings)' && ret=0

return ret
