#compdef imwcs
# _imwcs — fit/update WCS in a FITS image using a star catalog (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from imwcs.c (single-letter getopt-style).

_imwcs() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a+[initial rotation angle (deg)]:deg:' \
        '-b+[B1950 reference coords]:coords:' \
        '-c+[reference catalog]:cat:(ub1 ub2 ucac4 ucac3 ucac2 gsc2 gsc tycho2 tycho 2mass usno-a2 usno-b1 sao ppm act bsc hip)' \
        '-d+[DAOFIND star file]:file:_files' \
        '-e[erase WCS projection from image header]' \
        '-f[write FITS file]' \
        '-g+[Guide Star object class]:cls:' \
        '-h+[max reference stars]:n:' \
        '-i+[image-star minimum peak]:val:' \
        '-j+[J2000 reference coords]:coords:' \
        '-k+[reference catalog magnitude column]:n:' \
        '-l[left-right reflection before rotating]' \
        '-m+[limiting reference magnitude]:mag:' \
        '-n+[parameters to fit]:n:' \
        '-o+[output image filename]:file:_files' \
        '-p+[initial plate scale (arcsec/pixel)]:scale:' \
        '-q+[refit options (b/i/n/r/s/t/p/8)]:opts:' \
        '*:FITS image:_files -g "*.(fits|fit|fts|imh)"'
}

_imwcs "$@"
