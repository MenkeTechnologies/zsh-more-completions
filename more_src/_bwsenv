#compdef bwsenv
# Documentation: https://github.com/vjrasane/bitwarden-secrets-manager-env
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bwsenv - Bitwarden Secrets Manager env loader (zsh function wrapper).
# Recognized flags parsed by the upstream function:
#   -v|--version, -h|--help, -c|--config <file>,
#   --project <id>, --access-token <token>

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '--project[Bitwarden Secrets Manager project id]:project id:' \
  '--access-token[Bitwarden Secrets Manager access token]:token:'
