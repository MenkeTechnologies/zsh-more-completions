#compdef otbcli_CompareImages
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_CompareImages.html
# Orfeo ToolBox: compute MSE, MAE and PSNR between two images

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-ref.in[image used as reference]:image:_files' \
  '-ref.channel[used channel for the reference image]:value:' \
  '-meas.in[image used as measured]:image:_files' \
  '-meas.channel[used channel for the measured image]:value:' \
  '-roi.startx[ROI start x position]:value:' \
  '-roi.starty[ROI start y position]:value:' \
  '-roi.sizex[size along x in pixels]:value:' \
  '-roi.sizey[size along y in pixels]:value:' \
  '-mse[mean squared error value]:value:' \
  '-mae[mean absolute error value]:value:' \
  '-psnr[peak signal to noise ratio value]:value:' \
  '-count[number of differing pixels]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
