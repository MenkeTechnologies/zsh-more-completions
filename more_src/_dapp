#compdef dapp

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile the project'
  'test:run the test suite'
  'debug:step through a failing test interactively'
  'create:deploy a contract'
  'address:compute contract address'
  'install:install a dapp package'
  'update:update dapp packages'
  'upgrade:upgrade dapp-tools'
  'init:initialize a new project'
  'clean:remove build artifacts'
  'verify-contract:verify on Etherscan'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'dapp command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          '--extract[extract a single contract]' \
          '--optimize[enable optimizer]' \
          '--optimize-runs[optimizer runs]:runs:' \
          '--via-ir[use IR pipeline]' \
          '--help[show help]' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--match[test pattern]:pattern:' \
          '--verbosity[verbosity level]:level:(1 2 3)' \
          '--fuzz-runs[fuzz iterations]:count:' \
          '--depth[symbolic depth]:depth:' \
          '--replay[replay recorded failures]' \
          '--rpc-url[fork RPC URL]:url:' \
          '--rpc-block[fork block number]:block:' \
          '--cache[cache RPC calls]:path:_files' \
          '--smttimeout[SMT timeout]:seconds:' \
          '--solver[SMT solver]:solver:(z3 cvc5)' \
          '--help[show help]' && ret=0
        ;;
      create)
        _arguments -s -S \
          '--rpc-url[RPC URL]:url:' \
          '--value[ETH value]:value:' \
          '--gas[gas limit]:gas:' \
          '--from[sender]:address:' \
          '--password[password]:password:' \
          '1:contract-type:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
