#compdef bulkai
# ============================================================================
# _bulkai — zsh completion for igolaizola/bulkai, "AI image generation in
#            bulk automatically" — a Discord-bot-driver that pushes prompts
#            to Midjourney / Niji / Replicate through Discord and harvests
#            the generated images at scale (Go=143 leader bump continuing
#            Axis 88 Discord SDK / discordgo)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/igolaizola/bulkai
#   Maintainer : Iñigo Garcia Olaizola (igolaizola)
#   License    : MIT
#   Stars      : 226
#   Language   : Go
#   Module     : github.com/igolaizola/bulkai
#   Binary     : bulkai  (cmd/bulkai/main.go ffcli.Command
#                          ShortUsage = "bulkai [flags]
#                          <subcommand>")
#   Last push  : 2025-03-13
#
# WHAT IT IS
#   bulkai is a Discord-API-driven workflow tool for "AI image
#   generation in bulk automatically".  It logs into a Discord
#   account (or bot) with a long-lived session token, posts a
#   sequence of prompts to a configured Midjourney / Niji / Pi
#   channel or DM, watches the bot's responses through the
#   gateway, runs upscale/variation interactions on each result,
#   downloads the final images to a configurable output
#   directory, generates HTML thumbnails for review, and can
#   optionally hand off to Replicate via API for non-Discord
#   models.  Includes companion tooling to mint a fresh session
#   via Chrome (`create-session`) and to refresh expired Discord
#   CDN URLs in previously-generated outputs (`refresh`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/bulkai/main.go —
#                       peterbourgon/ff/v3/ffcli command tree,
#                       not cobra or urfave/cli)
#   bulkai <SUBCOMMAND> [flags...]
#
#   Subcommands:
#     generate                       Generate images in bulk
#       --config <FILE>                Config file
#                                      [default: bulkai.yaml]
#       --bot <NAME>                   Bot name
#       --prompt <P>                   Prompt (repeatable)
#       --proxy <ADDR>                 Proxy address
#       --output <DIR>                 Output directory
#                                      [default: output]
#       --album <ID>                   Album id
#       --prefix <STR>                 Prefix added to every
#                                      prompt
#       --suffix <STR>                 Suffix added to every
#                                      prompt
#       --variation                    Generate variations
#       --download                     Download images
#                                      [default: true]
#       --upscale                      Upscale images
#                                      [default: true]
#       --thumbnail                    Generate thumbnails
#                                      [default: true]
#       --html                         Generate HTML index files
#                                      [default: true]
#       --channel <GUID/CHANNEL>       Channel id (if missing,
#                                      DMs are used)
#       --concurrency <N>              Concurrency
#                                      [default: 3]
#       --wait <DUR>                   Inter-prompt wait
#       --debug                        Debug mode
#       --replicate-token <T>          Replicate API token
#       --midjourney-cdn               Use Midjourney CDN
#                                      instead of Discord CDN
#       --session <FILE>               Session config file
#                                      [default: session.yaml]
#       --user-agent <UA>              Session user agent
#       --ja3 <FP>                     Session JA3 fingerprint
#       --language <LANG>              Session language
#       --token <T>                    Discord authentication
#                                      token
#       --super-properties <SP>        Session super properties
#       --locale <L>                   Session locale
#       --cookie <C>                   Session cookie
#
#     create-session                 Create session using Chrome
#       --config <FILE>                Config file
#       --output <FILE>                Output session file
#                                      [default: session.yaml]
#       --proxy <ADDR>                 Proxy server
#       --profile                      Use existing Chrome
#                                      profile
#
#     refresh                        Refresh expired Discord CDN
#                                    URLs in an output file
#       --config <FILE>                Config file
#       --proxy <ADDR>                 Proxy address
#       --input <FILE>                 Input file
#                                      [default: input]
#       --output <FILE>                Output file
#                                      [default: output]
#       --wait <DUR>                   Inter-request wait
#       --debug                        Debug mode
#       --session <FILE>               Session config file
#                                      [default: session.yaml]
#       --user-agent / --ja3 / --language / --token /
#       --super-properties / --locale / --cookie
#                                      (same session-override
#                                      flags as `generate`)
#
#     version                        Print version
#
#   Standard ff/v3/ffcli auto-flags:
#     -h, --help                     Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/bwmarrin/discordgo v0.28.1`
#   declared in go.mod — `github.com/bwmarrin/discordgo` is THE
#   canonical Go Discord library maintained by Bruce Marriner
#   (bwmarrin/discordgo, 5.3K+ stars).  discordgo is the Go
#   counterpart of serenity-rs / discord.js / discord.py:  it
#   exposes `discordgo.New("Bot " + token)`,
#   `discordgo.Session` with `Open`/`Close`/`AddHandler`, the
#   complete Discord Gateway v10 opcode + intent surface,
#   message-create/message-update/interaction-create/
#   message-reaction-add/voice-state-update typed event payloads,
#   typed model objects (Channel, Guild, Member, Message,
#   MessageEmbed, MessageComponent, Interaction,
#   ApplicationCommand, AutocompleteValue, Attachment, Modal),
#   the slash-command / button / select / modal interaction
#   handlers, REST helpers (`ChannelMessageSend`,
#   `MessageReactionAdd`, `ChannelMessageEdit`,
#   `MessageInteractionRespond`, `WebhookExecute`), rate-limit-
#   aware HTTP, the voice-receive/voice-send pipeline, and a
#   sharding-ready `ShardManager`-style design.  bulkai's
#   `pkg/discord` package wraps `discordgo.Session` to drive the
#   Midjourney bot through typed interactions and to harvest
#   each generated image from `MessageCreate` events with
#   embedded attachments.  Verified via:
#     gh api repos/igolaizola/bulkai/contents/go.mod
#       → github.com/bwmarrin/discordgo v0.28.1
#       → github.com/peterbourgon/ff/v3 (for the ffcli CLI tree)
#       → module github.com/igolaizola/bulkai
#     gh api repos/igolaizola/bulkai/contents/cmd/bulkai/main.go
#       → return &ffcli.Command{
#           Subcommands: [newGenerateCommand(),
#                          newCreateSessionCommand(),
#                          newRefreshCommand(),
#                          newVersionCommand()]
#         }
#   This entry is the Go=143 leader bump that continues Axis 88
#   (Discord SDK / serenity) opened at R941 with Rust=serenity
#   via openabdev/openab.
#
#   No completion for `bulkai` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_bulkai() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_bulkai_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                generate)
                    _arguments \
                        '--config=[config file (default bulkai.yaml)]:file:_files -g "*.yaml"' \
                        '--bot=[bot name]:bot:' \
                        '*--prompt=[prompt (repeatable)]:prompt:' \
                        '--proxy=[proxy address]:addr:' \
                        '--output=[output directory (default output)]:dir:_files -/' \
                        '--album=[album id]:id:' \
                        '--prefix=[prompt prefix]:prefix:' \
                        '--suffix=[prompt suffix]:suffix:' \
                        '--variation[generate variations]' \
                        '--download[download images]' \
                        '--upscale[upscale images]' \
                        '--thumbnail[generate thumbnails]' \
                        '--html[generate HTML index files]' \
                        '--channel=[channel guid/channel id]:channel:' \
                        '--concurrency=[concurrency (default 3)]:n:' \
                        '--wait=[inter-prompt wait]:duration:' \
                        '--debug[debug mode]' \
                        '--replicate-token=[Replicate API token]:token:' \
                        '--midjourney-cdn[use Midjourney CDN instead of Discord CDN]' \
                        '--session=[session config file (default session.yaml)]:file:_files -g "*.yaml"' \
                        '--user-agent=[session user agent]:ua:' \
                        '--ja3=[session JA3 fingerprint]:fp:' \
                        '--language=[session language]:lang:' \
                        '--token=[Discord authentication token]:token:' \
                        '--super-properties=[session super properties]:sp:' \
                        '--locale=[session locale]:locale:' \
                        '--cookie=[session cookie]:cookie:' && ret=0 ;;
                create-session)
                    _arguments \
                        '--config=[config file]:file:_files' \
                        '--output=[output session file (default session.yaml)]:file:_files -g "*.yaml"' \
                        '--proxy=[proxy server]:addr:' \
                        '--profile[use existing Chrome profile]' && ret=0 ;;
                refresh)
                    _arguments \
                        '--config=[config file]:file:_files' \
                        '--proxy=[proxy address]:addr:' \
                        '--input=[input file (default input)]:file:_files' \
                        '--output=[output file (default output)]:file:_files' \
                        '--wait=[inter-request wait]:duration:' \
                        '--debug[debug mode]' \
                        '--session=[session config (default session.yaml)]:file:_files -g "*.yaml"' \
                        '--user-agent=[session user agent]:ua:' \
                        '--ja3=[session JA3 fingerprint]:fp:' \
                        '--language=[session language]:lang:' \
                        '--token=[Discord authentication token]:token:' \
                        '--super-properties=[session super properties]:sp:' \
                        '--locale=[session locale]:locale:' \
                        '--cookie=[session cookie]:cookie:' && ret=0 ;;
                version)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_bulkai_commands] )) ||
_bulkai_commands() {
    local -a commands
    commands=(
        'generate:generate images in bulk'
        'create-session:create a session using Chrome'
        'refresh:refresh expired Discord CDN URLs'
        'version:print version'
    )
    _describe -t commands 'bulkai command' commands
}

_bulkai "$@"
