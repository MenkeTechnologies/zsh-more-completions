#compdef chronyd
# Documentation: https://chrony-project.org/doc/4.8/chronyd.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chronyd: chrony NTP daemon

_arguments -s -S \
  '-4[resolve hostnames to IPv4 only]' \
  '-6[resolve hostnames to IPv6 only]' \
  '-f+[specify config file]:config file:_files' \
  '-n[do not detach from terminal]' \
  '-d[do not detach, log to terminal]' \
  '-l+[log to specified file]:log file:_files' \
  '-L+[set minimum message severity level]:level:(0 1 2 3)' \
  '-p[print configuration and exit]' \
  '-P+[set real-time scheduler priority]:priority:' \
  '-q[set clock once and exit]' \
  '-Q[log offset without setting clock]' \
  '-r[reload sample history files]' \
  '-R[ignore initstepslew and makestep directives]' \
  '-s[set system clock from RTC]' \
  '-t+[exit after seconds]:seconds:' \
  '-u+[run as user]:user:_users' \
  '-U[disable root privilege checks]' \
  '-F+[seccomp filter level]:level:(-1 0 1 2)' \
  '-m[lock daemon into RAM]' \
  '-x[do not control system clock]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
