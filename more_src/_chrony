#compdef chronyd

# Zsh completion for chronyd - chrony NTP daemon

_arguments -s -S \
  '-4[resolve hostnames to IPv4 only]' \
  '-6[resolve hostnames to IPv6 only]' \
  '-f+[specify config file]:config file:_files' \
  '-n[do not detach from terminal]' \
  '-d[do not detach, log to stderr, and allow debug commands]' \
  '-l+[log to specified file]:log file:_files' \
  '-L+[log level]:level:(0 1 2)' \
  '-p[print configuration and exit]' \
  '-P+[set process priority]:priority:' \
  '-q[set clock once and exit]' \
  '-Q[log offset without setting clock]' \
  '-r[reload sample histories if any]' \
  '-R[do not restore state from driftfile]' \
  '-s[set system time from RTC]' \
  '-t+[set inactivity timeout]:seconds:' \
  '-u+[run as user]:user:_users' \
  '-U+[set clock update flag]:flag:(0 1)' \
  '-F+[set seccomp filter level]:level:(-1 0 1 2)' \
  '-x[do not control system clock]' \
  '--version[show version]' \
  '--help[show help]'
