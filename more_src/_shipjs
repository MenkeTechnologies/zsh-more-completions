#compdef shipjs

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'setup:interactive project setup wizard'
  'prepare:bump version, update changelog, open PR'
  'trigger:run release after PR merge'
  'release:execute configured release'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'shipjs subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (setup|trigger)
        _arguments \
          '(-d --dir)'{-d,--dir=}'[repo path]:dir:_files -/' \
          '(-D --dry-run)'{-D,--dry-run}'[dry run]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      (prepare)
        _arguments \
          '(-d --dir)'{-d,--dir=}'[repo path]:dir:_files -/' \
          '(-D --dry-run)'{-D,--dry-run}'[dry run]' \
          '(-y --yes)'{-y,--yes}'[skip prompts]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
