#compdef pdb_wc
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Summarizes the contents of a PDB file, like the wc command

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[summary option string combining m c r a h o i, e.g. -mcra]:options (m=models c=chains r=residues a=atoms h=hetatm o=altloc i=icode)' \
  '*:PDB file:_files' && ret=0

return ret
