#compdef carvel
# _carvel — Carvel CLI tools collection (VMware, Go); dispatcher for ytt, kbld, kapp, imgpkg, vendir
# upstream: https://carvel.dev

_carvel() {
    local -a sub=(
        'ytt:YAML templating tool'
        'kbld:image resolution + build tool'
        'kapp:app k8s deployment tool'
        'imgpkg:package + relocate images'
        'vendir:fetch and lock sources'
        'kwt:network workflow tool'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'carvel subcommand' sub ;;
    esac
}

_carvel "$@"
