#compdef genkernel

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:action:->actions' \
  '--help[show help]' \
  '--version[show version]' \
  '--config=[configuration file]:config:_files' \
  '--logfile=[log file]:file:_files' \
  '--loglevel=[log level]:level:(0 1 2 3 4 5)' \
  '--color[use color output]' \
  '--no-color[disable color output]' \
  '--cleanup[clean up temporary directories]' \
  '--no-cleanup[do not clean up temporary directories]' \
  '--kerneldir=[kernel source directory]:dir:_files -/' \
  '--kernel-config=[kernel config file]:config:_files' \
  '--kernel-outputdir=[kernel output directory]:dir:_files -/' \
  '--makeopts=[make options]:options:' \
  '--nice=[nice value]:nice value:' \
  '--kernel-append-localversion=[append to kernel localversion]:string:' \
  '--kernel-localversion=[set kernel localversion]:string:' \
  '--kernel-cross-compile=[cross compilation prefix]:prefix:' \
  '--kernel-ar=[archiver]:archiver:_command_names' \
  '--kernel-as=[assembler]:assembler:_command_names' \
  '--kernel-cc=[C compiler]:compiler:_command_names' \
  '--kernel-ld=[linker]:linker:_command_names' \
  '--kernel-make=[make command]:make:_command_names' \
  '--bootdir=[boot directory]:dir:_files -/' \
  '--module-prefix=[module install prefix]:prefix:_files -/' \
  '--menuconfig[run menuconfig]' \
  '--no-menuconfig[do not run menuconfig]' \
  '--gconfig[run gconfig]' \
  '--xconfig[run xconfig]' \
  '--nconfig[run nconfig]' \
  '--save-config[save kernel config]' \
  '--no-save-config[do not save kernel config]' \
  '--oldconfig[run oldconfig]' \
  '--install[install kernel and modules]' \
  '--no-install[do not install]' \
  '--symlink[create symlinks]' \
  '--no-symlink[do not create symlinks]' \
  '--ramdisk-modules[include modules in initramfs]' \
  '--no-ramdisk-modules[do not include modules]' \
  '--all-ramdisk-modules[include all modules]' \
  '--firmware[copy firmware]' \
  '--no-firmware[do not copy firmware]' \
  '--firmware-dir=[firmware directory]:dir:_files -/' \
  '--firmware-files=[specific firmware files]:files:' \
  '--compress-initramfs[compress initramfs]' \
  '--no-compress-initramfs[do not compress]' \
  '--compress-initramfs-type=[compression type]:type:(gzip bzip2 lzma xz lz4 zstd)' \
  '--lvm[include LVM support]' \
  '--no-lvm[exclude LVM support]' \
  '--mdadm[include mdadm support]' \
  '--no-mdadm[exclude mdadm support]' \
  '--dmraid[include dmraid support]' \
  '--no-dmraid[exclude dmraid support]' \
  '--luks[include LUKS support]' \
  '--no-luks[exclude LUKS support]' \
  '--gpg[include GPG support]' \
  '--no-gpg[exclude GPG support]' \
  '--btrfs[include btrfs support]' \
  '--no-btrfs[exclude btrfs support]' \
  '--zfs[include ZFS support]' \
  '--no-zfs[exclude ZFS support]' \
  '--multipath[include multipath support]' \
  '--no-multipath[exclude multipath support]' \
  '--iscsi[include iSCSI support]' \
  '--no-iscsi[exclude iSCSI support]' \
  '--ssh[include SSH in initramfs]' \
  '--no-ssh[exclude SSH]' \
  '--bootloader=[bootloader to update]:bootloader:(grub grub2)' \
  '--mountboot[mount /boot]' \
  '--no-mountboot[do not mount /boot]' \
  '*:: :->args' && ret=0

case $state in
  (actions)
    local -a actions=(
      'all:build kernel, modules, and initramfs'
      'bzImage:build kernel image'
      'initramfs:build initramfs only'
      'kernel:build kernel only'
      'ramdisk:build ramdisk'
    )
    _describe -t actions 'action' actions && ret=0
    ;;
esac

return ret
