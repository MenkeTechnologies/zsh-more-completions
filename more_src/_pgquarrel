#compdef pgquarrel
# _pgquarrel — compare PostgreSQL database schemas (eulerto/pgquarrel)
# upstream: https://github.com/eulerto/pgquarrel
# Flags from src/quarrel.c (getopt_long).

_pgquarrel() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(ini|cfg|conf)"' \
        '(-f --file)'{-f+,--file=}'[output SQL file]:file:_files -g "*.sql"' \
        '(-s --summary)'{-s,--summary}'[print summary of changes]' \
        '(-t --single-transaction)'{-t,--single-transaction}'[wrap output in a single transaction]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '--ignore-version[ignore PostgreSQL version mismatch]' \
        '--temp-directory=[temp directory]:dir:_files -/' \
        '--source-dbname=[source database]:db:' \
        '--source-host=[source host]:host:_hosts' \
        '--source-port=[source port]:port:' \
        '--source-username=[source user]:user:_users' \
        '--source-no-password[never prompt for source password]' \
        '--target-dbname=[target database]:db:' \
        '--target-host=[target host]:host:_hosts' \
        '--target-port=[target port]:port:' \
        '--target-username=[target user]:user:_users' \
        '--target-no-password[never prompt for target password]' \
        '--include-schema=[only include schemas]:list:' \
        '--exclude-schema=[exclude schemas]:list:' \
        '--aggregate=[diff aggregates]:bool:(true false)' \
        '--cast=[diff casts]:bool:(true false)' \
        '--collation=[diff collations]:bool:(true false)' \
        '--comment=[diff comments]:bool:(true false)' \
        '--conversion=[diff conversions]:bool:(true false)' \
        '--domain=[diff domains]:bool:(true false)' \
        '--event-trigger=[diff event triggers]:bool:(true false)' \
        '--extension=[diff extensions]:bool:(true false)' \
        '--fdw=[diff foreign data wrappers]:bool:(true false)' \
        '--foreign-table=[diff foreign tables]:bool:(true false)' \
        '--function=[diff functions]:bool:(true false)' \
        '--index=[diff indexes]:bool:(true false)' \
        '--language=[diff procedural languages]:bool:(true false)' \
        '--materialized-view=[diff materialized views]:bool:(true false)' \
        '--operator=[diff operators]:bool:(true false)' \
        '--owner=[diff ownership]:bool:(true false)' \
        '--privileges=[diff GRANT/REVOKE]:bool:(true false)' \
        '--procedure=[diff procedures]:bool:(true false)' \
        '--publication=[diff publications]:bool:(true false)' \
        '--rule=[diff rules]:bool:(true false)' \
        '--schema=[diff schemas]:bool:(true false)' \
        '--security-labels=[diff security labels]:bool:(true false)' \
        '--sequence=[diff sequences]:bool:(true false)' \
        '--statistics=[diff extended statistics]:bool:(true false)' \
        '--subscription=[diff subscriptions]:bool:(true false)' \
        '--table=[diff tables]:bool:(true false)' \
        '--text-search=[diff text search objects]:bool:(true false)' \
        '--transform=[diff transforms]:bool:(true false)' \
        '--trigger=[diff triggers]:bool:(true false)' \
        '--type=[diff types]:bool:(true false)' \
        '--view=[diff views]:bool:(true false)'
}

_pgquarrel "$@"
