#compdef centrifugo

# Zsh completion for Centrifugo - real-time messaging server

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a centrifugo_global_flags
centrifugo_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '(-c --config)'{-c+,--config=}'[path to config file]:config file:_files -g "*.{json,yaml,yml,toml}"'
  '(-e --engine)'{-e+,--engine=}'[engine to use]:engine:(memory redis tarantool)'
  '(-p --port)'{-p+,--port=}'[HTTP server port]:port:'
  '(-a --address)'{-a+,--address=}'[interface to listen on]:address:'
  '--internal-port=[port for internal endpoints]:port:'
  '--grpc-port=[GRPC server port]:port:'
  '--grpc-address=[GRPC server address]:address:'
  '--admin[enable admin web interface]'
  '--admin-password=[admin password]:password:'
  '--admin-secret=[admin secret key]:secret:'
  '--admin-insecure[use insecure admin mode (no auth)]'
  '--api-insecure[use insecure API mode (no auth)]'
  '--client-insecure[start in insecure client mode]'
  '--log-level=[set log level]:level:(trace debug info warn error)'
  '--log-file=[log file path]:file:_files'
  '--pid-file=[path to PID file]:file:_files'
  '--name=[unique node name]:name:'
  '--debug[enable debug endpoints]'
  '--health[enable health check endpoint]'
  '--swagger[enable Swagger UI]'
  '--tls[enable TLS]'
  '--tls-cert=[path to TLS certificate file]:cert:_files'
  '--tls-key=[path to TLS key file]:key:_files'
  '--tls-root-ca=[path to TLS root CA file]:ca:_files'
  '--tls-client-ca=[path to TLS client CA file]:ca:_files'
  '--tls-insecure[skip TLS verification]'
)

_arguments -s -S -C \
  "${centrifugo_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'serve:run Centrifugo server'
      'genconfig:generate minimal configuration file'
      'gentoken:generate connection JWT token'
      'checkconfig:check configuration file'
      'checktoken:check connection JWT token'
      'default-config:generate full default configuration'
      'version:show version information'
    )
    _describe -t commands 'centrifugo commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      serve)
        _arguments -s -S \
          "${centrifugo_global_flags[@]}" && ret=0
        ;;
      genconfig)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c+,--config=}'[path to output config file]:file:_files' && ret=0
        ;;
      gentoken)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c+,--config=}'[path to config file]:config file:_files -g "*.{json,yaml,yml,toml}"' \
          '--user=[user ID]:user:' \
          '--ttl=[token TTL in seconds]:seconds:' && ret=0
        ;;
      checkconfig)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c+,--config=}'[path to config file]:config file:_files -g "*.{json,yaml,yml,toml}"' && ret=0
        ;;
      checktoken)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c+,--config=}'[path to config file]:config file:_files -g "*.{json,yaml,yml,toml}"' \
          '1:token:' && ret=0
        ;;
      default-config)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S "${centrifugo_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret