#compdef carton
# Documentation: https://github.com/perl-carton/carton
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Perl module dependency manager).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install modules from cpanfile'
  'update:update installed modules'
  'show:show installed module info'
  'list:list installed modules'
  'check:check dependency satisfaction'
  'exec:execute command with carton-managed lib paths'
  'bundle:bundle dependency tarballs into vendor/cache'
  'version:show carton version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'carton command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--deployment[install exact versions from snapshot, no CPAN fallback]' \
          '--cached[use locally bundled modules]' \
          '--without=[skip phase(s) csv]:phases:' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
