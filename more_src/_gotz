#compdef gotz

# https://github.com/merschformann/gotz — Go flag package (core/args.go)
_arguments -s -S \
  '-version[print version and exit]' \
  '-time=-[anchor clock at this local time]:time:' \
  '-timezones=-[comma-separated IANA zones or Name\:Zone pairs]:zones:' \
  '-symbols=-[rectangles sun-moon mono blocks custom]:mode:(rectangles sun-moon mono blocks custom)' \
  '-tics=-[show axis tics true/false]:bool:(true false)' \
  '-stretch=-[stretch to terminal width true/false]:bool:(true false)' \
  '-inline=-[inline time info and bars true/false]:bool:(true false)' \
  '-colorize=-[color symbols true/false]:bool:(true false)' \
  '-hours12=-[12-hour clock true/false]:bool:(true false)' \
  '-live=-[continuously update display true/false]:bool:(true false)' \
  '-sorting=-[timezone sort mode]:mode:(none offset name)' \
  '-sort-local-top=-[keep local zone first true/false]:bool:(true false)' \
  '*:time operand (if first char is digit):_default'
