#compdef grub-mknetdir
# _grub-mknetdir — GRUB grub-mknetdir (assemble a network-boot tree under --net-directory for use over TFTP/HTTP; --subdir relative output subdir, --net-directory webroot, --modules module list, --themes themes, --fonts fonts, --locales locales, -O target, --grub-mkimage path, --core-compress, -V version, -h help)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mknetdir.in on tip.

_grub-mknetdir() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--subdir+[relative subdir]:subdir:' \
        '--net-directory+[webroot]:dir:_files -/' \
        '--modules+[modules]:modules:' \
        '--themes+[themes]:themes:' \
        '--fonts+[fonts]:fonts:' \
        '--locales+[locales]:locales:' \
        '-O+[target]:fmt:(i386-pc i386-efi x86_64-efi arm-efi arm64-efi powerpc-ieee1275 riscv32-efi riscv64-efi)' \
        '--grub-mkimage+[path]:file:_files' \
        '--core-compress+[compression]:comp:(no xz gz lzo)'
}

_grub-mknetdir "$@"
