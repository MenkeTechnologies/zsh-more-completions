#compdef mkbundle

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[CA bundle output file]:file:_files' \
  '-nss-lib[path to libnssckbi.so]:file:_files' \
  '-int-bundle-out[intermediate bundle output]:file:_files' \
  '-metadata-out[metadata output]:file:_files' \
  '-flavor[bundle flavor]:flavor:(ubiquitous optimal force)' \
  && ret=0

return ret
