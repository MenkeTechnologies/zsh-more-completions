#compdef aptible
# _aptible — Aptible PaaS deployment CLI
# upstream: https://github.com/aptible/aptible-cli

_aptible() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'apps:list apps in an environment'
                'apps:create:create a new app'
                'config:view app configuration'
                'config:set:set environment variables'
                'config:unset:unset environment variables'
                'db:backup:back up a database'
                'db:clone:clone a database'
                'db:create:create a managed database'
                'db:deprovision:deprovision a database'
                'db:list:list databases'
                'db:reload:reload a database'
                'db:restart:restart a database'
                'db:tunnel:create a tunnel to a database'
                'db:url:show database connection URL'
                'deploy:deploy an app'
                'domains:list custom domains'
                'endpoints:list:list endpoints'
                'environment:list environments'
                'log_drain:create:create a log drain'
                'login:log in to Aptible'
                'logs:stream app logs'
                'operation:cancel:cancel an operation'
                'rebuild:rebuild an app'
                'restart:restart an app or service'
                'ssh:SSH into an app container'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                deploy)
                    _arguments \
                        '--app=[app handle]:app:' \
                        '--environment=[environment handle]:environment:' \
                        '--docker-image=[Docker image]:image:' \
                        '--git-commitish=[git ref to deploy]:ref:'
                    ;;
                db:create)
                    _arguments \
                        '--type=[database type]:type:(postgresql mysql redis mongodb elasticsearch rabbitmq)' \
                        '--version=[database version]:version:' \
                        '--environment=[environment handle]:environment:' \
                        '--container-size=[container size in MB]:size:' \
                        '--disk-size=[disk size in GB]:size:' \
                        '1:database handle:'
                    ;;
                db:tunnel)
                    _arguments \
                        '(-p --port)'{-p,--port=}'[local tunnel port]:port:' \
                        '--environment=[environment handle]:environment:' \
                        '1:database handle:'
                    ;;
                logs)
                    _arguments \
                        '--app=[app handle]:app:' \
                        '--environment=[environment handle]:environment:'
                    ;;
                ssh)
                    _arguments \
                        '--app=[app handle]:app:' \
                        '--environment=[environment handle]:environment:'
                    ;;
                login)
                    _arguments \
                        '--email=[email address]:email:' \
                        '--password=[password]:password:' \
                        '--lifetime=[token lifetime]:duration:'
                    ;;
            esac
            ;;
    esac
}

_aptible "$@"
