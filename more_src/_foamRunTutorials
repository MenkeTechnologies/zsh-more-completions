#compdef foamRunTutorials
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamRunTutorials — recursively execute Allrun scripts in tutorial directory trees.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-skipFirst -s)'{-skipFirst,-s}'[do not execute the first Allrun script]' \
    '(-test -t)'{-test,-t}'[run test loop]' \
    '*:tutorial directory:_directories' \
    && ret=0

return ret
