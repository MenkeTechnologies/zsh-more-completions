#compdef helvum
# Documentation: https://man.archlinux.org/search?q=helvum
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
