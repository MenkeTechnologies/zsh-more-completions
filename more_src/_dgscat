#compdef dgscat
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/dgscat.1.html
# PT-Scotch: scatter a centralized source graph into a distributed one

local ret=1

_arguments -s \
  '-c[check consistency of input graph after loading]' \
  '-h[display help]' \
  '-r-[set root process for centralized files (default 0)]:pnum' \
  '-V[display version and copyright]' \
  '*:file:_files' && ret=0

return ret
