#compdef cage

# Zsh completion for cage - Wayland kiosk compositor

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d)'-d'[enable debug mode]' \
  '(-r)'-r'[allow rotating the output]' \
  '(-s)'-s'[allow VT switching]' \
  '(-m)'-m'[disable hardware cursors]' \
  '(--)--[end of options]' \
  '1:application:_command_names' \
  '*:arguments'
