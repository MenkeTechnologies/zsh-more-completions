#compdef cage
# Documentation: https://man.archlinux.org/man/cage.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cage: Wayland kiosk compositor (Hjdskes/cage). Manpage documents only
# short single-dash flags (no long forms). cage forwards the trailing
# command line to the application it launches via "--".

_arguments \
  '(- *)-h[show help]' \
  '(- *)-v[show version and exit]' \
  '-d[disable client-side decorations when feasible]' \
  '-D[enable debug logging]' \
  '-m[multi-output mode]:mode:(last extend)' \
  '-s[allow VT switching]' \
  '(--)--[end of options; remainder is APP and args]' \
  '1:application:_command_names -e' \
  '*:argument:'
