#compdef pdal

# Zsh completion for pdal - Point Data Abstraction Library

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'info:dump information about a point cloud file'
  'translate:convert point cloud data'
  'pipeline:execute a pipeline'
  'merge:merge multiple point cloud files'
  'split:split a point cloud file'
  'sort:sort a point cloud file'
  'tindex:create a tile index'
  'tile:create tiled output'
  'density:compute density of point cloud'
  'ground:classify ground points'
  'hausdorff:compute Hausdorff distance between two point clouds'
  'chamfer:compute Chamfer distance between two point clouds'
  'random:generate random point cloud'
  'eval:evaluate classification results'
)

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--drivers[show available drivers]' \
  '--options=[show options for a driver]:driver' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'pdal command' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      info)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '--all[dump all info]' \
          '--metadata[dump file metadata]' \
          '--schema[dump data schema]' \
          '--stats[compute and dump statistics]' \
          '--boundary[compute and dump boundary]' \
          '--dimensions=[dimensions to include]:dimensions' \
          '--enumerate=[enumerate values for dimension]:dimension' \
          '--summary[dump summary information]' \
          '-p+[point to dump]:point index' \
          '--query=[return points near location]:x,y,z/count' \
          '--readers.las.filename=[input filename]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '--stdin[read pipeline from stdin]' \
          '1:input file:_files' && ret=0
        ;;
      translate)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-f --filter)'{-f,--filter}'=[filter type]:filter' \
          '(-r --reader)'{-r,--reader}'=[reader type]:reader' \
          '(-w --writer)'{-w,--writer}'=[writer type]:writer' \
          '--json=[inline pipeline JSON]:json' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '--stdin[read pipeline from stdin]' \
          '1:input file:_files' \
          '2:output file:_files' && ret=0
        ;;
      pipeline)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[pipeline file]:file:_files -g "*.json"' \
          '--metadata=[metadata file]:file:_files' \
          '--pipeline-serialization=[pipeline serialization]:format:(json)' \
          '--progress=[progress file]:file:_files' \
          '--stdin[read pipeline from stdin]' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:pipeline file:_files -g "*.json"' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '*:input files:_files' && ret=0
        ;;
      split)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '--length=[edge length for splitting]:length' \
          '--capacity=[maximum number of points per file]:count' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:input file:_files' \
          '2:output file:_files' && ret=0
        ;;
      sort)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '--dimension=[dimension to sort on]:dimension:(X Y Z GpsTime)' \
          '--order=[sort order]:order:(ASC DESC)' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:input file:_files' \
          '2:output file:_files' && ret=0
        ;;
      tindex)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--merge[merge the tile index]' \
          '--lyr_name=[layer name]:name' \
          '--tindex_name=[tile index column name]:name' \
          '--ogrdriver=[OGR driver]:driver:(ESRI_Shapefile SQLite GeoJSON GPKG)' \
          '--t_srs=[target SRS]:SRS' \
          '--a_srs=[assign SRS]:SRS' \
          '--src_srs_name=[source SRS column name]:name' \
          '--stdin[read filenames from stdin]' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:index file:_files' \
          '*:input files:_files' && ret=0
        ;;
      tile)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output directory]:directory:_directories' \
          '--length=[tile length]:length' \
          '--origin_x=[tile origin X]:value' \
          '--origin_y=[tile origin Y]:value' \
          '--buffer=[tile buffer size]:size' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:input file:_files' \
          '2:output directory:_directories' && ret=0
        ;;
      density)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output raster file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:input file:_files' \
          '2:output file:_files' && ret=0
        ;;
      ground)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '--max_window_size=[max window size]:size' \
          '--slope=[slope]:value' \
          '--max_distance=[max distance]:value' \
          '--initial_distance=[initial distance]:value' \
          '--cell_size=[cell size]:value' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:input file:_files' \
          '2:output file:_files' && ret=0
        ;;
      hausdorff)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[candidate file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:source file:_files' \
          '2:candidate file:_files' && ret=0
        ;;
      chamfer)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[input file]:file:_files' \
          '(-o --output)'{-o,--output}'=[candidate file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:source file:_files' \
          '2:candidate file:_files' && ret=0
        ;;
      random)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '--count=[number of points]:count' \
          '--bounds=[bounds for random points]:bounds' \
          '--mean=[mean for normal distribution]:value' \
          '--stdev=[standard deviation]:value' \
          '--distribution=[distribution type]:type:(uniform normal)' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:output file:_files' && ret=0
        ;;
      eval)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-i --input)'{-i,--input}'=[predicted file]:file:_files' \
          '(-o --output)'{-o,--output}'=[reference file]:file:_files' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '1:predicted file:_files' \
          '2:reference file:_files' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3 4 5 6 7 8)' \
          '*:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
