#compdef jupyter-kernelspec
# Documentation: https://github.com/jupyter/jupyter_client/blob/main/jupyter_client/kernelspecapp.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: added the real 'provisioners' subcommand
# and --missing/--debug flags; fixed malformed --log-level value spec.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
    'list:List installed kernel specifications'
    'install:Install a kernel specification directory'
    'uninstall:Alias for remove'
    'remove:Remove one or more Jupyter kernelspecs'
    'install-self:DEPRECATED install the IPython kernel spec'
    'provisioners:List available provisioners'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::options:->options' && ret=0

case $state in
    subcmd)
        _describe -t commands 'jupyter-kernelspec subcommand' subcmds && ret=0
        ;;
    options)
        case $words[1] in
            list)
                _arguments \
                    '--json[Output spec name and location as machine-readable JSON]' \
                    '--missing[Output only missing kernels]' \
                    '--debug[Set log level to DEBUG]' \
                    '--log-level=[Set the log level]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '--config=[Load config file]:config file:_files'
                ;;
            install)
                _arguments \
                    '--user[Install to the per-user kernel registry]' \
                    '--name=[Install kernel spec with this name]:name' \
                    '--prefix=[Specify a prefix to install to]:prefix:_directories' \
                    '--replace[Replace any existing kernel spec with this name]' \
                    '--sys-prefix[Install to Python sys.prefix]' \
                    '--debug[Set log level to DEBUG]' \
                    '--log-level=[Set the log level]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '--config=[Load config file]:config file:_files' \
                    '*:kernel directory:_directories'
                ;;
            uninstall|remove)
                _arguments \
                    '(-f --force)'{-f,--force}'[Force removal, do not prompt]' \
                    '--missing[Remove missing kernels]' \
                    '--debug[Set log level to DEBUG]' \
                    '--log-level=[Set the log level]:level:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '--config=[Load config file]:config file:_files' \
                    '*:kernel name'
                ;;
            install-self)
                _arguments \
                    '--user[Install to the per-user kernel registry]' \
                    '--debug[Set log level to DEBUG]'
                ;;
        esac
        ;;
esac

return ret
