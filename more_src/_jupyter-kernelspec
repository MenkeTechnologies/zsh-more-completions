#compdef jupyter-kernelspec

local -a subcmds

subcmds=(
    'list:List installed kernel specifications'
    'install:Install a kernel specification directory'
    'uninstall:Alias for remove'
    'remove:Remove one or more Jupyter kernelspecs'
    'install-self:DEPRECATED install the IPython kernel spec'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'jupyter-kernelspec subcommand' subcmds
        ;;
    options)
        case $words[1] in
            list)
                _arguments \
                    '--json[Output as JSON]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '--config=[Load config file]:config file:_files'
                ;;
            install)
                _arguments \
                    '--user[Install to the per-user kernel directory]' \
                    '--name=[Install kernel spec with this name]:name' \
                    '--prefix=[Prefix to install to]:prefix:_directories' \
                    '--replace[Replace an existing spec]' \
                    '--sys-prefix[Install to the sys.prefix kernel directory]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '--config=[Load config file]:config file:_files' \
                    '*:kernel directory:_directories'
                ;;
            uninstall|remove)
                _arguments \
                    '-f[Force removal without confirmation]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '--config=[Load config file]:config file:_files' \
                    '*:kernel name'
                ;;
        esac
        ;;
esac
