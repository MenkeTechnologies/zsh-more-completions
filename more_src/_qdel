#compdef qdel
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/qdel.1B.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# qdel: delete a PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-m[message]:msg:' \
  '-W[wait]:delay:' \
  '-p[purge]' \
  '*:jobid:' && ret=0
return ret
