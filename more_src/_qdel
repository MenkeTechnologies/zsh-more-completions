#compdef qdel
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/qdel.1B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qdel: delete a PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[print version and exit]' \
  '-m+[include comment in mail]:message:' \
  '-W+[delay between SIGTERM and SIGKILL]:delay:' \
  '-c[clean up unreported jobs from server]' \
  '-p[forcibly purge job from server]' \
  '*:jobid:' && ret=0
return ret
