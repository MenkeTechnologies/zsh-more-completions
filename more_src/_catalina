#compdef catalina catalina.sh

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'debug:start in debugger mode'
  'jpda:start under JPDA debugger'
  'run:start in current window (foreground)'
  'start:start in separate window (background)'
  'stop:stop the running Tomcat instance'
  'configtest:test that the configuration is valid'
  'version:show Tomcat version info'
  'threaddump:print stack trace of all threads'
  'statuslog:show server status log'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'catalina subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (debug|run|start)
        _arguments \
          '-security[run with security manager]' && ret=0
        ;;
      (stop)
        _arguments \
          '1::seconds to wait:' \
          '-force[kill process if it does not die]' && ret=0
        ;;
      (jpda)
        _arguments \
          '1::sub-action:(start)' \
          '-security[run with security manager]' && ret=0
        ;;
    esac
    ;;
esac

return ret
