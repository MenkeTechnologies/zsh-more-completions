#compdef SurfMeasures
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfMeasures.html
# Compute measures from surface datasets

local ret=1

_arguments -s \
  '-spec[SUMA spec file]:spec file:_files' \
  '-surf_A[first surface name from spec]:surface' \
  '-surf_B[second surface name from spec]:surface' \
  '-out_1D[write output to 1D ASCII file]:file:_files' \
  '-out[write output to surface dataset]:file:_files' \
  '*-func[measurement function to compute]:function' \
  '-cmask[mask to restrict processed nodes]:mask' \
  '-nodes_1D[limit output to listed nodes]:file:_files' \
  '-sv[associated AFNI anatomical volume]:dataset:_files' \
  '-debug[diagnostic verbosity level]:level' \
  '-dnode[show detail for a node]:node' \
  '-info_all[show all aggregate surface info]' \
  '-info_area[total triangulated surface area]' \
  '-info_thick[min/max thickness between surfaces]' \
  '-info_vol[volume between two surfaces]' \
  '-info_volg[volume via Gauss theorem]' \
  '-info_norms[normal vector angle statistics]' \
  '-help[display help]' \
  '-hist[revision history]' \
  '-ver[version info]' && ret=0

return ret
