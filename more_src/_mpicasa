#compdef mpicasa
# Documentation: https://casadocs.readthedocs.io/en/v6.4.3/notebooks/parallel-processing.html
# CASA MPI wrapper to run casa in parallel (OpenMPI mpirun pass-through)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-n[number of MPI processes]:processes' \
  '(-hostfile --hostfile)'{-hostfile,--hostfile}'[file listing cluster nodes and slots]:host file:_files' \
  '*-x[export environment variable to all nodes]:env var' \
  '--map-by[mapping policy for processes]:policy:(slot hwthread core socket numa node)' \
  '--bind-to[binding policy for processes]:policy:(none hwthread core socket numa node)' \
  '--report-bindings[report process bindings to stderr]' \
  '--allow-run-as-root[permit execution as root user]' \
  '--app[provide an appfile (overrides other options)]:app file:_files' \
  '*:casa executable:_files' && ret=0

return ret
