#compdef MapAlignerIdentification
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: align maps based on peptide identifications

local ret=1

_arguments -s -S \
  '*-in[input files to align]:input file:_files' \
  '*-out[output files]:output file:_files' \
  '*-trafo_out[transformation descriptions (trafoXML)]:file:_files' \
  '-in_spectra_files[mzML spectra files to transform alongside]:file:_files' \
  '-out_spectra_files[output mzML files for transformed spectra]:file:_files' \
  '-design[experimental design file (TSV)]:file:_files' \
  '-reference:file[file to serve as alignment reference]:file:_files' \
  '-reference:index[input file index to use as reference]:n:' \
  '-store_original_rt[preserve original retention times as metadata]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
