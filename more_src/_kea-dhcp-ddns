#compdef kea-dhcp-ddns
# Documentation: https://man.archlinux.org/search?q=kea-dhcp-ddns
# Reference accessed: 2026-05-16

# kea-dhcp-ddns: Kea DDNS forwarder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[print version]' \
  '-V[print extended version]' \
  '-W[print extended version with file list]' \
  '-d[debug mode (foreground)]' \
  '-c[config file]:file:_files -g "*.(conf|json)"' \
  '-t[test config file, do not start]:file:_files -g "*.(conf|json)"' \
  '-X[debug exit]' \
  '*::kea-dhcp-ddns args:_files' && ret=0
return ret
