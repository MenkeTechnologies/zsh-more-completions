#compdef caldb
# Documentation: https://dragons.readthedocs.io/projects/recipe-system-users-manual/en/stable/caldb.html
# DRAGONS: manage the local calibration database

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --walk)'{-k,--walk}'[explore directories recursively]' \
  '(-c --config)'{-c,--config}'[path to the config file]:config:_files' \
  '(-d --database)'{-d,--database}'[path to the database file]:database:_files' \
  '(-v --verbose)'{-v,--verbose}'[give information about operations]' \
  '1:subcommand:(init list add remove config)' \
  '*:file:_files' && ret=0

return ret
