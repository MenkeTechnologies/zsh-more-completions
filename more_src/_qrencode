#compdef qrencode
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/qrencode.1.html
# Reference accessed: 2026-05-20
# Verified: local `qrencode --help` (qrencode 4.1.1).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '(-r --read-from)'{-r,--read-from=}'[read input from file]:file:_files' \
  '(-s --size)'{-s,--size=}'[module size in pixels]:size:' \
  '(-l --level)'{-l,--level=}'[error correction level]:level:(L M Q H)' \
  '(-v --symversion)'{-v,--symversion=}'[symbol version (1-40)]:version:' \
  '(-m --margin)'{-m,--margin=}'[margin width]:width:' \
  '(-d --dpi)'{-d,--dpi=}'[DPI for bitmap output]:dpi:' \
  '(-t --type)'{-t,--type=}'[output format]:format:(PNG PNG32 EPS SVG XPM ANSI ANSI256 ASCII ASCIIi UTF8 UTF8i ANSIUTF8 ANSIUTF8i ANSI256UTF8)' \
  '(-S --structured)'{-S,--structured}'[structured append mode]' \
  '(-k --kanji)'{-k,--kanji}'[assume Kanji (shift-jis) encoding]' \
  '(-c --casesensitive)'{-c,--casesensitive}'[encode lower-case alphabet characters]' \
  '(-i --ignorecase)'{-i,--ignorecase}'[ignore case]' \
  '(-8 --8bit)'{-8,--8bit}'[encode entire data in 8-bit mode]' \
  '(-M --micro)'{-M,--micro}'[encode in a Micro QR Code]' \
  '--rle[enable run-length encoding for SVG]' \
  '--svg-path[use single path element for SVG]' \
  '--inline[generate SVG without the XML tag]' \
  '--strict-version[disable automatic version number adjustment]' \
  '--foreground=[foreground color (RRGGBB or RRGGBBAA hex)]:color:' \
  '--background=[background color (RRGGBB or RRGGBBAA hex)]:color:' \
  '--verbose[display verbose information to stderr]' \
  '*:data to encode:' && ret=0

return ret
