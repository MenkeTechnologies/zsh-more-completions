#compdef restrain
# Documentation: https://www.ccp4.ac.uk/html/restrain.html
# CCP4 RESTRAIN - restrained structure factor least squares refinement

local ret=1

_arguments -s -S \
  'XYZIN[input coordinate file (PDB)]:file:_files' \
  'TLSIN[input group thermal parameters]:file:_files' \
  'HKLIN[input reflection file (MTZ)]:file:_files' \
  'REFIN[input reflection file (formatted)]:file:_files' \
  'XYZOUT[output coordinate file]:file:_files' \
  'TLSOUT[output thermal parameters]:file:_files' \
  'HKLOUT[output reflection file (MTZ)]:file:_files' \
  'REFOUT[output reflection file (formatted)]:file:_files' \
  'MATOUT[full normal matrix for error estimation]:file:_files' \
  'DESOUT[restraint design matrix]:file:_files' \
  '*:keyword:(TITLE PNAME DNAME DICTION LABIN LABOUT FORMAT ANISO NCSYMM OCCUP RIGID SYMMETRY XTRDIST XTRPLAN STEER)' && ret=0

return ret
