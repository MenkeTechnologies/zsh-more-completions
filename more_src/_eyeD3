#compdef eyeD3

# Zsh completion for eyeD3 - audio file tag editor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-a,--artist}'+[set artist]:artist' \
  {-A,--album}'+[set album]:album' \
  {-b,--album-artist}'+[set album artist]:artist' \
  {-t,--title}'+[set title]:title' \
  {-n,--track-num}'+[set track number]:track number' \
  {-N,--track-total}'+[set track total]:total tracks' \
  {-d,--disc-num}'+[set disc number]:disc number' \
  {-D,--disc-total}'+[set disc total]:total discs' \
  {-G,--genre}'+[set genre]:genre' \
  {-Y,--release-year}'+[set release year]:year' \
  {-c,--comment}'+[set comment]:text' \
  '--add-image+[add image (FILE\:TYPE[\:DESCRIPTION])]:image spec:_files' \
  '--remove-all-images[remove all images]' \
  '--write-images+[write images to directory]:directory:_directories' \
  '--to-v1.1[convert to v1.1]' \
  '--to-v2.3[convert to v2.3]' \
  '--to-v2.4[convert to v2.4]' \
  {-r,--remove-all}'[remove all tags]' \
  '--encoding+[set encoding]:encoding:(latin1 utf8 utf16 utf16-be)' \
  {-l,--list-genres}'[list all genres]' \
  '--no-tagging-time-frame[disable tagging time frame]' \
  '--no-color[disable color output]' \
  '--force-update[force tag update]' \
  '--preserve-file-times[preserve file modification times]' \
  {-v,--verbose}'[verbose output]' \
  {-Q,--quiet}'[quiet output]' \
  '*:audio files:_files -g "*.{mp3,mp2,mp1}"'
