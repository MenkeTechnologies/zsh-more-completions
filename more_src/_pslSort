#compdef pslSort
# UCSC kent: merge and sort psCluster .psl output files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-nohead[do not write psl header]' \
  '-verbose=[set verbosity level]:level:' \
  ':how:(dirs dirs1 dirs2 g2g g2g1 g2g2)' \
  ':out file:_files' \
  ':temp dir:_files -/' \
  '*:input dir or file:_files' && ret=0

return ret
