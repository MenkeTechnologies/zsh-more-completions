#compdef multiphaseEulerFoam
# OpenFOAM: solver for a system of any number of compressible fluid phases

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print the usage]' \
  '-postProcess[execute functionObjects only]' \
  '-dict=[read functions dictionary from specified location (with -postProcess)]:file:_files' \
  '-field=[field to be processed, eg U (with -postProcess)]:field' \
  '-fields=[list of fields to be processed (with -postProcess)]:fields' \
  '-func=[functionObject to execute (with -postProcess)]:func' \
  '-funcs=[functionObjects to execute (with -postProcess)]:funcs' \
  '-list[list available configured functionObjects (with -postProcess)]' \
  '-constant[include the constant/ dir in the times list (with -postProcess)]' \
  '-noZero[exclude the 0/ dir from the times list (with -postProcess)]' \
  '-latestTime[select the latest time (with -postProcess)]' \
  '-time=[comma-separated time ranges (with -postProcess)]:ranges' \
  '-case=[specify alternate case directory (default cwd)]:dir:_files -/' \
  '-region=[specify alternative mesh region]:name' \
  '-parallel[run in parallel]' \
  '-roots=[slave root directories for distributed running]:roots' \
  '-hostRoots=[slave root directories per host for distributed running]:hostRoots' \
  '-fileHandler=[override the fileHandler]:handler:(collated uncollated masterUncollated)' \
  '-libs=[pre-load libraries]:libs' \
  '-doc[display application documentation in browser]' \
  '-srcDoc[display source code in browser]' && ret=0

return ret
