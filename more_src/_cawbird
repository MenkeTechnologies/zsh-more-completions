#compdef cawbird
# _cawbird — Cawbird Twitter / X GTK desktop client (IBBoard/cawbird)
# upstream: https://github.com/IBBoard/cawbird
# Flags from data/cawbird.1.

_cawbird() {
    local -a args
    args=(
        '--tweet=[open the compose dialog with the given @screen_name pre-filled]:screen_name:'
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
    )
    _arguments -s -S $args
}

_cawbird "$@"
