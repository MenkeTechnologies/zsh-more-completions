#compdef suricata

# completions for Suricata IDS/IPS/NSM engine

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-V,--version}'[show version]'
  '-c+[configuration file]:file:_files'
  '-T[test configuration]'
  '-i+[capture from network interface]:interface:_net_interfaces'
  '-r+[read pcap file]:file:_files -g "*.pcap(-.)"'
  '-q+[inline IPS mode using NFQUEUE]:queue number'
  '-s+[path to signature file]:file:_files'
  '-S+[path to signature file (exclusive)]:file:_files'
  '-l+[default log directory]:directory:_directories'
  '-D[run as daemon]'
  '--pidfile=[PID file]:file:_files'
  '-v[increase verbosity]'
  '--runmode=[set run mode]:mode:(single autofp workers)'
  '--unix-socket=[unix socket path]:path:_files'
  '--pcap=[capture from interface or file]:interface or file'
  '--pcap-buffer-size=[set pcap buffer size]:bytes'
  '--af-packet=[capture using AF_PACKET]:interface:_net_interfaces'
  '--netmap=[capture using netmap]:interface:_net_interfaces'
  '--pfring=[capture using PF_RING]:interface:_net_interfaces'
  '--simulate-ips[simulate IPS mode]'
  '--init-errors-fatal[exit on rule loading errors]'
  '--disable-detection[disable detection engine]'
  '--dump-config[dump running configuration]'
  '--dump-features[dump features and exit]'
  '--build-info[show build info and exit]'
  '--list-app-layer-protos[list app-layer protocols]'
  '--list-keywords=[list rule keywords]:type:(all csv)'
  '--list-runmodes[list available run modes]'
  '-u[run unit tests]'
  '-U+[run specific unit test]:test name'
  '--fatal-unittests[enable fatal unit tests]'
  '--engine-analysis[print engine analysis]'
  '--set=[override config value]:key=value'
  '-k+[force checksum check]:mode:(all none)'
  '--user=[run as user]:user:_users'
  '--group=[run as group]:group:_groups'
  '--erf-in=[read ERF file]:file:_files'
  '*:file:_files'
)

_arguments -s -S $arguments
