#compdef jump

# Zsh completion for jump — https://github.com/gsamokovarov/jump (cmd/*.go registry)

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  '--help:show this screen'
  '--version:show version'
  'cd:fuzzy match a directory to jump to'
  'clean:clean database of non-existent entries'
  'forget:remove cwd from the database'
  'hint:hint relevant paths for jumping'
  'import:import autojump or z scores'
  'pin:pin cwd to a search term'
  'pins:list pinned search terms'
  'settings:configure jump'
  'shell:print shell integration script'
  'top:list directories by score'
  'unpin:unpin a search term'
)

_arguments -C -s -S \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'jump command' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      --help | --version) ;;
      cd | hint)
        _message -e 'search term' && ret=0
        ;;
      clean | forget | pins | top) ;;
      import)
        compset -n 2
        _values 'importer' autojump z && ret=0
        ;;
      pin | unpin)
        _message -e 'search term' && ret=0
        ;;
      shell)
        compset -n 2
        _arguments -s -S \
          '--bind=-[name of jump function]:bind:(j)' \
          '*::shell:_values -s shells bash zsh sh fish dash csh tcsh ksh' && ret=0
        ;;
      settings)
        compset -n 2
        _arguments -s -S \
          '--reset[reset settings to defaults]' \
          '--space=-[how spaces work in searches]:space:(slash ignore)' \
          '--preserve=-[keep entries for missing dirs]:preserve:(true false)' && ret=0
        ;;
      *)
        _message -e 'search term' && ret=0
        ;;
    esac
    ;;
esac

return ret
