#compdef ace2sam
# Documentation: https://raw.githubusercontent.com/samtools/samtools/develop/misc/ace2sam.c
# Convert an ACE assembly file to headerless SAM

local ret=1

_arguments -s -S \
  '-p[output padded SAM]' \
  '-c[write the contig sequence in SAM]' \
  '*:ace file:_files' && ret=0

return ret
