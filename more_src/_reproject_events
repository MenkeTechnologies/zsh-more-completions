#compdef reproject_events
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/reproject_events.html
# Regrid an event file to a different tangent point

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input dataset/block specification]:file:_files' \
  'outfile=[output dataset filename]:file:_files' \
  'match=[coordinate system to match to]:match:' \
  'aspect=[aspect file, value can be none or a stack]:aspect:' \
  'random=[random seed for 0.5-pixel randomization]:seed:' \
  'geompar=[the name of the Pixlib Geometry parameter file]:file:_files' \
  'verbose=[controls screen output information]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite output if it exists]:clobber:(yes no)' && ret=0

return ret
