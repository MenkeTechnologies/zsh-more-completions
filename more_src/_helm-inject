#compdef helm-inject
# Documentation: https://github.com/maorfr/helm-inject
# helm inject: inject additional configurations during a Helm upgrade

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--command=[injection command to be used]:command:' \
  '--debug[enable verbose output]' \
  '--dry-run[simulate an upgrade]' \
  '*--inject-flags=[flags to pass to injector (no leading --)]:flag:' \
  '--injector=[injector to use]:injector:' \
  '(-i --install)'{-i,--install}'[install if release does not exist]' \
  '--kubecontext=[name of the kubeconfig context to use]:context:' \
  '--namespace=[namespace for the release]:namespace:' \
  '1:command:(upgrade)' \
  '*::arg:_files' && ret=0

return ret
