#compdef umi_tools
# Documentation: https://umi-tools.readthedocs.io/en/latest/QUICK_START.html
# umi_tools - tools for handling Unique Molecular Identifiers

local ret=1
local -a subcmds

subcmds=(
  'whitelist:identify true cell barcodes'
  'extract:move UMI/cell barcode from read into read name'
  'dedup:deduplicate reads using UMI and mapping coordinates'
  'group:group PCR duplicates without deduplicating'
  'count:count reads per gene using UMIs'
  'count_tab:count UMIs from a tab-delimited input'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- :)--version[print version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'umi_tools command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      whitelist)
        _arguments -s \
          '--bc-pattern=[barcode pattern on read 1]:pattern:' \
          '--bc-pattern2=[barcode pattern on read 2]:pattern:' \
          '--extract-method=[barcode extraction method]:method:(string regex)' \
          '--method=[counting method]:method:(reads umis)' \
          '--knee-method=[knee detection method]:method:(distance density)' \
          '--set-cell-number=[explicit number of accepted barcodes]:n:' \
          '--expect-cells=[upper limit estimate of cells]:n:' \
          '--allow-threshold-error[warn instead of error on no threshold]' \
          '--plot-prefix=[prefix for diagnostic plots]:prefix:' \
          '--error-correct-threshold=[hamming distance for correction]:n:' \
          '--ed-above-threshold=[handle barcodes above threshold]:mode:(discard correct)' \
          '--subset-reads=[use first N reads]:n:' \
          '--3prime[barcode at 3 prime end]' \
          '(-I --stdin)'{-I,--stdin}'=[input file]:file:_files' \
          '(-S --stdout)'{-S,--stdout}'=[output file]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      extract)
        _arguments -s \
          '--bc-pattern=[barcode pattern on read 1]:pattern:' \
          '--bc-pattern2=[barcode pattern on read 2]:pattern:' \
          '--extract-method=[barcode extraction method]:method:(string regex)' \
          '--read2-in=[input filename for read 2]:file:_files' \
          '--read2-out=[output filename for read 2]:file:_files' \
          '--filtered-out=[output for unmatched reads]:file:_files' \
          '--filtered-out2=[output for unmatched read 2]:file:_files' \
          '--suppress-stats[suppress statistics output]' \
          '(-I --stdin)'{-I,--stdin}'=[input file]:file:_files' \
          '(-S --stdout)'{-S,--stdout}'=[output file]:file:_files' \
          '(-L --log)'{-L,--log}'=[log file]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      dedup|count|count_tab)
        _arguments -s \
          '--method=[UMI grouping method]:method:(unique percentile cluster adjacency directional)' \
          '--edit-distance-threshold=[edit distance threshold]:n:' \
          '--ignore-umi[group reads by mapping coordinates only]' \
          '--read-length[use read length as dedup criterion]' \
          '--spliced-is-unique[treat spliced/unspliced as unique]' \
          '--soft-clip-threshold=[soft-clipped bases to treat as spliced]:n:' \
          '--extract-umi-method=[how barcodes are encoded]:method:(read_id tag umis)' \
          '--umi-separator=[separator between read id and UMI]:sep:' \
          '--umi-tag=[BAM tag containing UMI]:tag:' \
          '--umi-tag-split=[split UMI tag, take first element]:delim:' \
          '--umi-tag-delimiter=[concatenate delimited UMI elements]:delim:' \
          '--cell-tag=[BAM tag containing cell barcode]:tag:' \
          '--cell-tag-split=[split cell barcode tag]:delim:' \
          '--cell-tag-delimiter=[concatenate delimited cell barcode]:delim:' \
          '--per-cell[group reads sharing cell barcode]' \
          '--per-gene[group reads with identical genes]' \
          '--gene-tag=[BAM tag encoding gene]:tag:' \
          '--assigned-status-tag=[tag describing read-to-gene assignment]:tag:' \
          '--skip-tags-regex=[skip reads matching regex]:regex:' \
          '--per-contig[deduplicate per contig]' \
          '--gene-transcript-map=[gene-to-transcript map file]:file:_files' \
          '--paired[handle paired-end BAM]' \
          '--mapping-quality=[minimum MAPQ]:mapq:' \
          '--unmapped-reads=[handle unmapped reads]:mode:(discard use output)' \
          '--chimeric-pairs=[handle chimeric pairs]:mode:(discard use output)' \
          '--unpaired-reads=[handle unpaired reads]:mode:(discard use output)' \
          '--multimapping-detection-method=[multimapping tags]:tags:(NH X0 XT)' \
          '--output-stats=[generate statistics files]:prefix:' \
          '--in-format=[input file format]:format:' \
          '--reference-filename=[reference genome for CRAM]:file:_files' \
          '--subset=[consider random fraction of reads]:frac:' \
          '--chrom=[process single chromosome]:chrom:' \
          '(-I --stdin)'{-I,--stdin}'=[input file]:file:_files' \
          '(-S --stdout)'{-S,--stdout}'=[output file]:file:_files' \
          '(-L --log)'{-L,--log}'=[log file]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      group)
        _arguments -s \
          '--method=[UMI grouping method]:method:(unique percentile cluster adjacency directional)' \
          '--edit-distance-threshold=[edit distance threshold]:n:' \
          '--per-cell[group reads sharing cell barcode]' \
          '--per-gene[group reads with identical genes]' \
          '--gene-tag=[BAM tag encoding gene]:tag:' \
          '--umi-group-tag=[tag to store UMI group]:tag:' \
          '--group-out=[flatfile mapping reads to groups]:file:_files' \
          '--output-bam[output a BAM file]' \
          '--paired[handle paired-end BAM]' \
          '(-I --stdin)'{-I,--stdin}'=[input file]:file:_files' \
          '(-S --stdout)'{-S,--stdout}'=[output file]:file:_files' \
          '(-L --log)'{-L,--log}'=[log file]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
