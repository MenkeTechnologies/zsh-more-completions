#compdef metabat1
# Documentation: https://bitbucket.org/berkeleylab/metabat/src/master/README.md
# MetaBAT 1 - original metagenome binning algorithm

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --inFile)'{-i,--inFile}'=[input contigs fasta (required)]:file:_files' \
  '(-o --outFile)'{-o,--outFile}'=[base name for output bins (required)]:path:_files' \
  '(-a --abdFile)'{-a,--abdFile}'=[coverage depth file]:file:_files' \
  '--cvExt[use coverage file without variance]' \
  '--fullHeader[preserve complete fasta headers]' \
  '(-p --pairFile)'{-p,--pairFile}'=[paired contigs file]:file:_files' \
  '--p1=[probability cutoff for preparing binning (default 0)]:p' \
  '--p2=[probability cutoff for binning (default 0)]:p' \
  '--minProb=[minimum probability for binning consideration]:p' \
  '--minBinned=[minimum proportion of already binned neighbors]:p' \
  '--verysensitive[preset for very sensitive binning]' \
  '--sensitive[preset for sensitive binning]' \
  '--specific[preset for specific binning]' \
  '--veryspecific[preset for very specific binning]' \
  '--superspecific[preset for super specific binning]' \
  '--minCorr=[minimum correlation for binning]:corr' \
  '--minSamples=[minimum samples for correlation]:n' \
  '(-x --minCV)'{-x,--minCV}'=[minimum mean coverage per library (default 1)]:cov' \
  '--minCVSum=[minimum total coverage across libraries]:cov' \
  '(-s --minClsSize)'{-s,--minClsSize}'=[minimum output bin size]:size' \
  '(-m --minContig)'{-m,--minContig}'=[minimum contig size for binning]:size' \
  '--minContigByCorr=[minimum contig size by correlation]:size' \
  '(-t --numThreads)'{-t,--numThreads}'=[number of threads, 0=all]:threads' \
  '--minShared=[minimum shared percent for distance]:pct' \
  '--fuzzy[binning with fuzzy clustering]' \
  '(-l --onlyLabel)'{-l,--onlyLabel}'[output sequence names only]' \
  '(-S --sumLowCV)'{-S,--sumLowCV}'[sum coverage of low coverage contigs]' \
  '(-V --maxVarRatio)'{-V,--maxVarRatio}'=[maximum variance/mean ratio]:ratio' \
  '--saveTNF=[save tetranucleotide frequency file]:file:_files' \
  '--saveDistance=[save distance file]:file:_files' \
  '--saveCls[save cluster assignments]' \
  '--unbinned[generate file for unbinned contigs]' \
  '--noBinOut[skip individual bin file output]' \
  '-B+[number of bootstrapping runs]:n' \
  '--pB=[proportion of bootstrap support]:p' \
  '--seed=[random seed, 0=random]:seed' \
  '--keep[keep intermediate files]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' && ret=0

return ret
