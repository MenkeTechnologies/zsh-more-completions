#compdef oil osh ysh
# Documentation: https://github.com/oilshell/oil
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-c+[execute command string]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-n[check syntax without executing]' \
  '-o+[set shell option]:option:(errexit nounset pipefail xtrace)' \
  '+o+[unset shell option]:option:(errexit nounset pipefail xtrace)' \
  '-O+[set Oil option]:option:(parse_at parse_brace parse_paren parse_triple_quote command_sub_errexit process_sub_fail strict_word_eval)' \
  '+O+[unset Oil option]:option:' \
  '-x[print commands before execution]' \
  '-v[print input as read]' \
  '-e[exit on error]' \
  '-u[error on unset variables]' \
  '-s[read from stdin]' \
  '--rcfile=[use alternate rc file]:file:_files' \
  '--rcdir=[rc directory]:dir:_files -/' \
  '--norc[do not read rc files]' \
  '--headless[run in headless mode]' \
  '--tool=[run built-in tool]:tool:(cat syntax-tree fmt)' \
  '*:script:_files' && ret=0

return ret
