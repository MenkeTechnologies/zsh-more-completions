#compdef so-import-evtx
# _so-import-evtx — Security Onion so-import-evtx CLI for ingesting Windows Event Log .evtx files via Sysmon-like parsing through Logstash into Elasticsearch with Hunt/Kibana ready timeline annotations (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-import-evtx() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-r+[replay time]:str:' \
        '--replay-time=+[replay time]:str:' \
        '-t+[delta seconds]:n:' \
        '--time-delta=+[delta seconds]:n:' \
        '-i+[index name]:str:' \
        '--index=+[index name]:str:' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-c+[count limit]:n:' \
        '--count=+[count limit]:n:' \
        '--source-type=+[t]:t:(sysmon security application system setup forwarded powershell windows-defender)' \
        '--tag=+[csv]:str:' \
        '--no-elastic[no Elasticsearch]' \
        '--no-logstash[no Logstash]' \
        '--no-confirm[no confirm]' \
        '--keep-temp[keep temp dir]' \
        '*:evtx file:_files -g "*.evtx *.EVTX"'
}

_so-import-evtx "$@"
