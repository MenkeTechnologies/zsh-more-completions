#compdef kroki
# Documentation: https://man.archlinux.org/search?q=kroki
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'convert:convert a diagram file'
      'version:show version information'
      'help:show help for a command'
    )
    _describe -t commands 'kroki command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      convert)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(svg png pdf jpeg base64)' \
          '(-t --type)'{-t,--type}'[diagram type]:type:(plantuml mermaid graphviz ditaa c4plantuml d2 dbml erd excalidraw nomnoml pikchr structurizr svgbob umlet vega vegalite wavedrom wireviz)' \
          '(-o --output)'{-o,--output}'[output file]:output file:_files' \
          '(-c --config)'{-c,--config}'[configuration file]:config file:_files' \
          '*:input file:_files' && ret=0
        ;;
      help)
        local -a commands=(convert version help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
