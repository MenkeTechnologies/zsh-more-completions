#compdef ripit

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --coder)'{-c,--coder}'+[encoder]:enc:(0 1 2 3 4 5)' \
  '(-q --quality)'{-q,--quality}'+[encoder quality]:q:' \
  '(-D --dirtemplate)'{-D,--dirtemplate}'+[directory template]:tpl:' \
  '(-A --albumtemplate)'{-A,--albumtemplate}'+[album template]:tpl:' \
  '(-l --lameencopt)'{-l,--lameencopt}'+[lame options]:opts:' \
  '(-o --vorbizeropt)'{-o,--vorbizeropt}'+[oggenc options]:opts:' \
  '(-O --flacopt)'{-O,--flacopt}'+[flac options]:opts:' \
  '(-y --musepackopt)'{-y,--musepackopt}'+[mpcenc options]:opts:' \
  '(-Y --opusencopt)'{-Y,--opusencopt}'+[opusenc options]:opts:' \
  '(-d --dev)'{-d,--dev}'+[CD device]:dev:_files -g "/dev/*"' \
  '(-r --rip)'{-r,--rip}'+[ripping method]:method:(cdparanoia cdda2wav dagrab dd icedax)' \
  '(-s --scsi)'{-s,--scsi}'+[SCSI device]:dev:' \
  '(-b --bitrate)'{-b,--bitrate}'+[bitrate]:bitrate:' \
  '(-B --vbrmode)'{-B,--vbrmode}'+[VBR mode]:mode:' \
  '(-V --verify)'{-V,--verify}'[verify integrity after encoding]' \
  '(-e --eject)'{-e,--eject}'[eject after rip]' \
  '(-x --execmd)'{-x,--execmd}'+[exec command after each track]:cmd:' \
  '(-X --execmdall)'{-X,--execmdall}'+[exec command after ripping all]:cmd:' \
  '(-i --interaction)'{-i,--interaction}'+[interaction level]:level:(0 1)' \
  '(-S --quitnodb)'{-S,--quitnodb}'[quit if no db match]' \
  '(-Q --quitnoerr)'{-Q,--quitnoerr}'[quit on ripper error]' \
  '(-U --nice)'{-U,--nice}'+[nice level]:nice:' && ret=0

return ret
