#compdef rocprim-test rocprim-benchmark
# _rocprim — AMD ROCm rocPRIM parallel primitives library reduce scan sort merge for HIP architectures test/bench runners (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocPRIM

_rocprim() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '--algorithm=+[algorithm]:a:(reduce scan sort merge select unique partition discontinuity transform radix_sort merge_sort device_segmented_reduce device_segmented_scan device_run_length_encode device_histogram)' \
        '--input-type=+[type]:t:(int uint int64 uint64 float double half int8 uint8 short ushort)' \
        '--output-type=+[type]:t:(int uint int64 uint64 float double half int8 uint8 short ushort)' \
        '--key-type=+[type]:t:(int uint int64 uint64 float double half int8 uint8 short ushort)' \
        '--value-type=+[type]:t:(int uint int64 uint64 float double half int8 uint8 short ushort)' \
        '--size=+[N]:n:' \
        '--trials=+[N]:n:' \
        '--bench=+[bench name]:str:' \
        '--seed=+[seed]:n:' \
        '--device=+[id]:n:' \
        '--threads=+[N]:n:' \
        '--blocks=+[N]:n:' \
        '--scan-mode=+[mode]:m:(inclusive exclusive)' \
        '--sort-mode=+[mode]:m:(ascending descending)' \
        '--radix=+[bits]:n:'
}

_rocprim "$@"
