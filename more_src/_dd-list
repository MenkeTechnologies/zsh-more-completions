#compdef dd-list
# Documentation: https://manpages.debian.org/dd-list
# Source: debian/devscripts scripts/dd-list.pl — list Debian package maintainers (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    {-i,--stdin}'[read package names from stdin]' \
    {-d,--dctrl}'[read Packages-style input from stdin]' \
    '*'{-s+,--sources=}'[Sources.gz file to read]:file:_files -g "*.{gz,xz,bz2,Packages,Sources}"' \
    '(--no-uploaders)'{-u,--uploaders}'[also list uploaders]' \
    '--no-uploaders[skip uploaders]' \
    {-z,--uncompress}'[uncompress source files (.gz/.xz/.bz2)]' \
    {-b,--print-binary}'[print binary package names too]' \
    '*:package names:_default' \
    && ret=0

return ret
