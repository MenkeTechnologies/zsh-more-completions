#compdef mktorrent

# Zsh completion for mktorrent - create BitTorrent metainfo files

_arguments \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --announce)'{-a,--announce}'[specify announce URL]:URL' \
  '(-c --comment)'{-c,--comment}'[add comment to metainfo]:comment' \
  '(-d --no-date)'{-d,--no-date}'[do not write creation date]' \
  '(-e --exclude)'{-e,--exclude}'[exclude pattern]:pattern' \
  '(-l --piece-length)'{-l,--piece-length}'[piece length power of 2]:power (15-28)' \
  '(-n --name)'{-n,--name}'[set name of torrent]:name' \
  '(-o --output)'{-o,--output}'[set output filename]:file:_files -g "*.torrent"' \
  '(-p --private)'{-p,--private}'[set private flag]' \
  '(-s --source)'{-s,--source}'[set source string]:source' \
  '(-t --threads)'{-t,--threads}'[number of hashing threads]:threads' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-w --web-seed)'{-w,--web-seed}'[add web seed URL]:URL' \
  '*:file or directory:_files'
