#compdef cilium-sysctlfix
# _cilium-sysctlfix — Cilium init-container helper that drops 99-zzz-override_cilium.conf into /etc/sysctl.d and restarts systemd-sysctl
# upstream: https://github.com/cilium/cilium
# Flags from tools/sysctlfix/main.go on tip.

_cilium-sysctlfix() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--sysctl-conf-dir=[sysctl config directory]:dir:_files -/' \
        '--sysctl-config-file=[cilium sysctl overwrites filename]:file:' \
        '--systemd-sysctl-unit=[systemd sysctl unit to reload]:unit:'
}

_cilium-sysctlfix "$@"
