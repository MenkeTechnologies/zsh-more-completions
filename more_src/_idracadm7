#compdef idracadm7

# Dell iDRAC racadm CLI 7 (iDRAC7+)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-r[remote iDRAC]:ip:' \
  '-u[username]:user:' \
  '-p[password]:pwd:' \
  '-i[interactive password]' \
  '-S[no SSL verify]' \
  '*::racadm7 subcommand:_files' && ret=0
return ret
