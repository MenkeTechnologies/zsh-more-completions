#compdef suramp
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/tapering/suramp.c
# SURAMP - linearly taper the start and/or end of traces to zero

local ret=1

_arguments -s -S \
  'tmin=[end of starting ramp (sec)]:t:' \
  'tmax=[beginning of ending ramp (sec)]:t:' \
  '*:SU file:_files' && ret=0

return ret
