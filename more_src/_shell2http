#compdef shell2http

# Zsh completion for shell2http - serve shell commands via HTTP

_arguments -s -S \
  '-port[port to listen on]:port:' \
  '-host[host to listen on]:host:' \
  '-form[parse query/form params as env vars]' \
  '-cgi[enable CGI-like mode]' \
  '-export-vars[export environment variables]:vars:' \
  '-export-all-vars[export all environment variables]' \
  '-shell[shell interpreter]:shell:_files' \
  '-cert[TLS certificate file]:file:_files' \
  '-key[TLS key file]:file:_files' \
  '-basic-auth[HTTP basic auth (user:pass)]:credentials:' \
  '-timeout[command execution timeout]:seconds:' \
  '-include-stderr[include stderr in response]' \
  '-no-index[do not generate index page]' \
  '-add-exit[add /exit route to shutdown]' \
  '-one-thread[run commands in single thread]' \
  '-show-errors[show errors in HTTP response]' \
  '-cache[cache command results]:seconds:' \
  '-log[log file path]:file:_files' \
  '-version[show version]' \
  '*:route command pair:' && return 0
