#compdef shell2http
# Documentation: https://github.com/msoap/shell2http
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for shell2http - serve shell commands via HTTP

_arguments -s -S \
  '-port[port to listen on (0 for random)]:port:' \
  '-host[host IP to bind on]:host:' \
  '-form[parse query/form params as env vars]' \
  '-form-check[regexp validation for form fields]:regexp:' \
  '-cgi[enable CGI-like mode]' \
  '-export-vars[export environment variables (comma-separated)]:vars:' \
  '-export-all-vars[export all environment variables]' \
  '-shell[shell interpreter]:shell:_files' \
  '-cert[SSL certificate path]:file:_files' \
  '-key[SSL private key path]:file:_files' \
  '-basic-auth[HTTP basic auth (user:pass)]:credentials:' \
  '-timeout[command execution timeout (seconds)]:seconds:' \
  '-include-stderr[include stderr in output]' \
  '-no-index[disable index page generation]' \
  '-add-exit[add /exit route to shutdown]' \
  '-one-thread[run commands single-threaded]' \
  '-show-errors[show stdout despite non-zero exit codes]' \
  '-500[return HTTP 500 on non-zero exit]' \
  '-cache[cache command output (seconds)]:seconds:' \
  '-log[log output file]:file:_files' \
  '-no-log-timestamp[remove timestamps from logs]' \
  '-version[show version]' \
  '-help[show help]' \
  '*:route command pair:' && return 0
