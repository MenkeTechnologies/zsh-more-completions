#compdef qalter
# Documentation: https://linux.die.net/man/1/qalter-torque
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# qalter: modify a PBS/TORQUE job's attributes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-a[execution date]:datetime:' \
  '-A[account]:account:' \
  '-c[checkpoint]:val:(n s c)' \
  '-e[stderr]:file:_files' \
  '-h[hold type]:val:(u o s)' \
  '-j[join out/err]:val:(eo oe)' \
  '-k[keep stdout/err]:val:(e o eo oe n)' \
  '-l[resource]:resource:' \
  '-m[mail events]:events:(a b e n)' \
  '-M[mail addresses]:list:' \
  '-N[job name]:name:' \
  '-o[stdout]:file:_files' \
  '-p[priority]:n:' \
  '-r[rerunable]:val:(y n)' \
  '-S[shell]:shell:_command_names' \
  '-u[user@host list]:list:' \
  '-W[attribute]:attr=value:' \
  '*:jobid:' && ret=0
return ret
