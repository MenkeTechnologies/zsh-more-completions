#compdef Rdconv
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/tools/html/Rdconv.html
# R CMD Rdconv: convert an R documentation (Rd) file to other formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '(-t --type)'{-t,--type=}'[convert to format TYPE]:type:(txt html latex example)' \
  '--encoding=[use enc as the output encoding]:encoding:' \
  '--package=[use pkg as the package name]:package:' \
  '(-o --output)'{-o,--output=}'[use OUT as the output file]:file:_files' \
  '--os=[assume OS NAME]:os:(unix windows)' \
  '--OS=[the same as --os]:os:(unix windows)' \
  '--RdMacros=[packages from which to get Rd macros]:pkglist:' \
  '*:file:_files' && ret=0

return ret
