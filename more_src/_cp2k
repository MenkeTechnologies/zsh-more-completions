#compdef cp2k cp2k.popt cp2k.psmp cp2k.sopt cp2k.ssmp cp2k.pdbg cp2k.sdbg cp2k.cuda
# _cp2k — Jürg Hutter cp2k flexible suite for atomistic simulations DFT Born-Oppenheimer MD Monte Carlo (cp2k team, Fortran); custom argparse
# upstream: https://github.com/cp2k/cp2k

_cp2k() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-V[verbose]' \
        '--verbose[verbose]' \
        '-i+[input file]:file:_files -g "*.inp *.cp2k"' \
        '--input=+[input file]:file:_files -g "*.inp *.cp2k"' \
        '-o+[output file]:file:_files -g "*.out *.log"' \
        '--output=+[output file]:file:_files -g "*.out *.log"' \
        '-r+[restart file]:file:_files -g "*.restart"' \
        '--restart=+[restart file]:file:_files -g "*.restart"' \
        '-arch+[arch file]:file:_files' \
        '--arch=+[arch file]:file:_files' \
        '-mpi[force MPI mode]' \
        '--mpi[force MPI mode]' \
        '-omp[OpenMP threads]' \
        '--omp[OpenMP threads]' \
        '-shell[run in shell mode]' \
        '--shell[run in shell mode]' \
        '-c[check input only]' \
        '--check[check input only]' \
        '-e+[run mode]:m:(opt nve nvt npt npe md ehrenfest_dyn vib pint geo_opt cell_opt mc tmc energy energy_force)' \
        '--run-type=+[run mode]:m:(opt nve nvt npt npe md ehrenfest_dyn vib pint geo_opt cell_opt mc tmc energy energy_force)' \
        '-p+[mode]:m:(parallel serial)' \
        '--parallel=+[mode]:m:(parallel serial)' \
        '-nproc=+[N]:n:' \
        '--nproc=+[N]:n:' \
        '-t+[wall time]:str:' \
        '--wall-time=+[wall time]:str:' \
        '*:input file:_files -g "*.inp *.cp2k"'
}

_cp2k "$@"
