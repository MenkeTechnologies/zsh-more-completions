#compdef pycln
# Documentation: https://man.archlinux.org/search?q=pycln
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(--config)--config=[read configuration file]:file:_files' \
  '*--skip-imports=[comma-separated module names to skip globally]:imports' \
  '(--include -i)'{--include,-i}'=[regex for paths to include]:pattern' \
  '(--exclude -e)'{--exclude,-e}'=[regex for paths to exclude]:pattern' \
  '(--extend-exclude -ee)'{--extend-exclude,-ee}'=[extra exclude regex]:pattern' \
  '(--all -a)'{--all,-a}'[remove all unused imports (not just side-effect safe)]' \
  '(--check -c)'{--check,-c}'[check only; do not write]' \
  '(--diff -d)'{--diff,-d}'[print unified diff instead of writing]' \
  '(--verbose -v)'{--verbose,-v}'[verbose stderr messages]' \
  '(--quiet -q)'{--quiet,-q}'[reduce stderr output]' \
  '(--silence -s)'{--silence,-s}'[silence stdout and stderr]' \
  '(--expand-stars -x)'{--expand-stars,-x}'[expand star imports when resolvable]' \
  '--no-gitignore[do not honor .gitignore]' \
  '--disable-all-dunder-policy[treat __init__.py like regular modules]' \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]' \
  '*:path:_files'
