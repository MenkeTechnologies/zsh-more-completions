#compdef selene
# Documentation: https://kampfkarren.github.io/selene/cli/usage.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for selene - Lua linter

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '--allow-warnings[pass when only warnings occur]' \
  '--no-exclude[ignore excludes defined in config]' \
  '(-n --no-summary)'{-n,--no-summary}'[suppress summary information]' \
  '(-q --quiet)'{-q,--quiet}'[show only essential information]' \
  '--config=[path to configuration file]:file:_files' \
  '--color=[when to use color]:when:(Always Auto Never)' \
  '--display-style=[output format]:style:(Json Json2 Rich Quiet)' \
  '--num-threads=[number of threads]:number:' \
  '--pattern=[glob pattern to match files]:pattern:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'generate-roblox-std:generate a Roblox standard library file'
      'update-roblox-std:update the Roblox standard library file'
      'upgrade-std:upgrade an older selene standard library file'
      'help:print help'
    )
    _describe -t commands 'selene subcommand' commands
    _alternative 'files:file:_files' && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
