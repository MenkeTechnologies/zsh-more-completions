#compdef selene

# Zsh completion for selene - Lua linter

_arguments -s -S \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)'{-V,--version}'[print version]' \
    '--config=[path to configuration file]:file:_files' \
    '--color=[when to use color]:when:(always auto never)' \
    '--display-style=[how to display lint diagnostics]:style:(json json2 quiet rich)' \
    '--num-threads=[number of threads to use]:number:' \
    '--pattern=[glob pattern to match files]:pattern:' \
    '*--allow=[allow a lint]:lint name:' \
    '*--deny=[deny a lint]:lint name:' \
    '*--warn=[warn on a lint]:lint name:' \
    '--no-exclude[do not respect .gitignore and other ignore files]' \
    '(-q --quiet)'{-q,--quiet}'[suppress all output]' \
    '*:file:_files'
