#compdef bpfman bpfctl
# Documentation: https://bpfman.io/main/getting-started/cli-guide/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'load:load eBPF program'
  'unload:unload eBPF program by id'
  'attach:attach eBPF program to hook point'
  'detach:detach eBPF program by link id'
  'list:list loaded eBPF programs/links'
  'get:get program or link details'
  'image:eBPF bytecode image commands'
  'system:system level commands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'bpfman command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (load) _values 'subcommand' 'file' 'image' && ret=0 ;;
      (image) _values 'subcommand' 'pull' 'build' 'generate-build-args' 'sign' 'verify' && ret=0 ;;
      (attach) _values 'hook' 'xdp' 'tc' 'tcx' 'tracepoint' 'kprobe' 'uprobe' 'fentry' 'fexit' && ret=0 ;;
      (system) _values 'subcommand' 'service' 'config' && ret=0 ;;
      (list)
        _arguments \
          '--metadata-selector=[metadata key=value selector]:sel:' \
          '--application=[application name]:app:' \
          '--program-type=[program type filter]:type:' && ret=0 ;;
      (unload|get|detach) _arguments '*:id:' && ret=0 ;;
    esac ;;
esac

return ret
