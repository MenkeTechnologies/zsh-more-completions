#compdef nvidia-modprobe

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --nvidiactl-device-minor)'{-c,--nvidiactl-device-minor}'+[ctl minor]:n:' \
  '(-u --nvidia-uvm-device)'{-u,--nvidia-uvm-device}'+[UVM minor]:n:' \
  '(-m --nvidia-modeset-device)'{-m,--nvidia-modeset-device}'+[modeset minor]:n:' \
  '(-i --nvidia-frontend-device)'{-i,--nvidia-frontend-device}'+[frontend device]:n:' \
  '(-g --gpu)'{-g,--gpu}'+[GPU index]:n:' \
  '(--vgpu-vfio-mdev)--vgpu-vfio-mdev=+[create vGPU VFIO mdev]:cfg:' \
  '(--module-instance)--module-instance=+[module instance]:n:' \
  '(-f --force-fast-tasks)'{-f,--force-fast-tasks}'[fast tasks]' && ret=0

return ret
