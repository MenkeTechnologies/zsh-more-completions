#compdef otbcli_SplitImage
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SplitImage.html
# Orfeo ToolBox: split a multiband image into single-band images

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input multiband image filename]:image:_files' \
  '-out[output prefix and extension for mono-band images]:output:_files' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
