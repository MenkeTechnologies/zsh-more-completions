#compdef cert-manager-openshift-routes openshift-routes
# _cert-manager-openshift-routes — cert-manager OpenShift Route TLS controller
# upstream: https://github.com/cert-manager/openshift-routes
# Flags from internal/cmd/app/options/options.go on tip.

_cert-manager-openshift-routes() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --log-level)'{-v,--log-level=}'[log verbosity (0-5)]:n:' \
        '--readiness-probe-port=[health/ready probe port]:port:' \
        '--readiness-probe-path=[health/ready probe path]:path:' \
        '--metrics-port=[metrics bind port]:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_cert-manager-openshift-routes "$@"
