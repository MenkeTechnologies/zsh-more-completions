#compdef fasebin
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/fasebin.html
# Build phase-resolved spectra (phase-binned PHA) for a pulsar

local ret=1

_arguments -s -S \
  'orbitfile=[orbit ephemeris file]:orbitfile:_files' \
  'sourcename=[B or J name of the object]:sourcename:' \
  'datafile=[input data file or list of files]:datafile:_files' \
  'outfile=[output phase-binned PHA file]:outfile:_files' \
  'gtifile=[GTI file to apply]:gtifile:_files' \
  'respfile=[response matrix filename for header]:respfile:_files' \
  'roff=[dispersion measure time offset in sec]:roff:' \
  'nph=[number of phase bins]:nph:' \
  'binary=[source is a binary pulsar]:binary:(yes no)' \
  'l1only=[use only layer 1 for GoodXenon]:l1only:(yes no)' \
  'propane=[use only propane data]:propane:(yes no)' \
  'debug=[enable debugging output]:debug:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
