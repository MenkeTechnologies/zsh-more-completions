#compdef battle-tanks btanks
# Documentation: https://github.com/whoozle/btanks/blob/master/engine/src/game.cpp
# Reference accessed: 2026-05-16
# Verified: engine/src/game.cpp + engine/src/window.cpp argv loops
# Removed from prior file: -h (no short handler in source), --no-fullscreen
# (not in source), --fullscreen (real is --fs), -w/-H (not real; -0..-5
# resolution presets are used instead), --vehicle= (not in source).

# Battle Tanks: cross-platform 2D battle tank action game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--connect=[connect to host as mp-client]:host:_hosts' \
  '--bind=[bind to local address]:host:' \
  '--lang=[interface language (2-letter ISO)]:lang:(en ru de fr it es pl)' \
  '--map=[comma-separated map list]:maps:' \
  '--no-sound[disable sound]' \
  '--sound[enable sound]' \
  '--xmas[enable xmas mode]' \
  '--no-xmas[disable xmas mode]' \
  '--server[switch to server mode (no GUI)]' \
  '--ai=[add prespawned AI players]:n:' \
  '--game-type=[force game type]:type:(deathmatch team-deathmatch ctf)' \
  '--time-limit=[time limit in seconds]:seconds:' \
  '--port=[server port (default 27255)]:port:' \
  '--log=[log file]:file:_files' \
  '--fs[fullscreen]' \
  '--no-gl[disable OpenGL]' \
  '--force-gl[force OpenGL]' \
  '--force-soft-gl[force software OpenGL]' \
  '--no-dx[disable DirectX]' \
  '--vsync[enable vsync]' \
  '--fsaa[enable FSAA]' \
  '--no-joystick[disable joystick]' \
  '-0[resolution 640x480]' \
  '-1[resolution 800x600]' \
  '-2[resolution 1024x768]' \
  '-3[resolution 1152x864]' \
  '-4[resolution 1280x1024]' \
  '-5[resolution 1920x1080]' \
  '*::extra args:_files' && ret=0
return ret
