#compdef wallrnd
# Documentation: https://github.com/Vanille-N/wallrnd
# Source: Vanille-N/wallrnd — pure-Rust random abstract time-aware wallpaper generator.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--config=[path to wallrnd.toml]:file:_files -g "*.toml"' \
    '--image=[output SVG file path]:file:_files' \
    '--set[apply the generated wallpaper to the desktop]' \
    '--nice[lower process priority]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
