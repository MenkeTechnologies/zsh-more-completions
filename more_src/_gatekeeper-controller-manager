#compdef gatekeeper-controller-manager gatekeeper-audit
# _gatekeeper-controller-manager — OPA Gatekeeper admission/audit controller
# upstream: https://github.com/open-policy-agent/gatekeeper
# Flags from main.go + pkg/audit/manager.go on tip.

_gatekeeper-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-file=[log file (default: stderr)]:file:_files' \
        '--log-level=[minimum log level]:level:(DEBUG INFO WARNING ERROR)' \
        '--log-level-key=[JSON key for log level field]:key:' \
        '--log-level-encoder=[encoder for log level field]:enc:(lower capital color capitalcolor)' \
        '--health-addr=[health endpoint bind host\:port]:host\:port:' \
        '--metrics-addr=[metrics endpoint bind host\:port]:host\:port:' \
        '--port=[webhook bind port]:port:' \
        '--host=[webhook server bind host]:host:' \
        '--cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--disable-cert-rotation[disable auto webhook TLS cert/key rotation]' \
        '--enable-pprof[enable pprof profiling]' \
        '--pprof-port=[pprof port]:port:' \
        '--cert-service-name=[service name for generating TLS cert hostname]:name:' \
        '--enable-tls-healthcheck[probe webhook API with cert in certDir]' \
        '--enable-k8s-native-validation=[enable ValidatingAdmissionPolicy driver]:bool:(true false)' \
        '--external-data-provider-response-cache-ttl=[external data provider response cache TTL]:dur:' \
        '--enable-referential-rules=[enable referential constraint rules]:bool:(true false)' \
        '--shutdown-delay=[seconds to delay shutdown after termination event]:s:' \
        '*--disable-opa-builtin=[OPA built-in function to disable (repeatable)]:name:' \
        '--audit-interval=[audit interval (s, 0=disable)]:s:' \
        '--constraint-violations-limit=[max violations recorded per Constraint]:n:' \
        '--audit-chunk-size=[K8s API list chunk size during audit]:n:' \
        '--audit-from-cache[audit from internal cache instead of API server]' \
        '--emit-audit-events[emit Kubernetes events for each violation]' \
        '--audit-events-involved-namespace[emit events in the involved object namespace]' \
        '--audit-match-kind-only[only audit kinds present in Constraints]' \
        '--api-cache-dir=[directory for audit-from-API cache]:dir:_files -/' \
        '--log-stats-audit[log stats metrics for audit run]' \
        '--operation=[gatekeeper operations to run (csv)]:csv:(audit webhook mutation-controller status status-controller mutation-status mutation-webhook generate-vap generate-vap-binding)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gatekeeper-controller-manager "$@"
