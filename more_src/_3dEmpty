#compdef 3dEmpty
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dEmpty.html
# AFNI make an empty dataset .HEAD file

local ret=1

_arguments -s -S \
  '-prefix[output file prefix name]:prefix:' \
  '-nxyz[number of voxels along each axis]:x:' \
  '-geometry[3D grid geometry MATRIX string]:matrix:' \
  '-nt[number of time points]:nt:' \
  '*:dataset:_files' && ret=0

return ret
