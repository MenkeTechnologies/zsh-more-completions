#compdef powerfulseal seal
# _powerfulseal — Kubernetes chaos engineering tool (powerfulseal/powerfulseal)
# upstream: https://github.com/powerfulseal/powerfulseal
# Flags from powerfulseal/cli/__main__.py (argparse).

_powerfulseal() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--config=[config file]:file:_files -g "*.(yml|yaml)"' \
        '--policy-file=[policy YAML file]:file:_files -g "*.(yml|yaml)"' \
        '--silent[silent output]' \
        '*-v[increase verbosity]' \
        '*--verbose[increase verbosity]' \
        '--inventory-file=[ssh inventory file]:file:_files' \
        '--inventory-kubernetes[fetch inventory from Kubernetes]' \
        '--kubeconfig=[kubeconfig path]:file:_files' \
        '--kubernetes-namespace=[K8s namespace]:ns:' \
        '--execution-mode=[failure injection mode]:mode:(kubernetes ssh)' \
        '--remote-user=[SSH remote user]:user:_users' \
        '--ssh-allow-missing-host-keys[allow missing SSH host keys]' \
        '--ssh-path-to-private-key=[SSH key path]:file:_files' \
        '--ssh-password=[SSH password]:password:' \
        '--ssh-kill-command=[command to kill docker container]:cmd:' \
        '--override-ssh-host=[override SSH host]:host:_hosts' \
        '--use-private-ip[use node private IP]' \
        '--openstack[use OpenStack driver]' \
        '--openstack-cloud-name=[OpenStack cloud name]:cloud:' \
        '--aws[use AWS driver]' \
        '--azure[use Azure driver]' \
        '--azure-resource-group-name=[Azure resource group]:rg:' \
        '--azure-node-resource-group-name=[Azure node resource group]:rg:' \
        '--gcp[use GCP driver]' \
        '--gcp-config-file=[GCP config file]:file:_files' \
        '--no-cloud[do not use a cloud driver]' \
        '--headless[run without web UI]' \
        '--host=[web UI host]:host:_hosts' \
        '--port=[web UI port]:port:' \
        '--accept-proxy-headers[trust X-Forwarded-* headers]' \
        '--stdout-collector[emit metrics to stdout]' \
        '--prometheus-collector[emit metrics to Prometheus]' \
        '--prometheus-host=[Prometheus bind host]:host:' \
        '--prometheus-port=[Prometheus bind port]:port:' \
        '--datadog-collector[emit metrics to Datadog]' \
        '--min-seconds-between-runs=[min seconds between policy runs]:n:' \
        '--max-seconds-between-runs=[max seconds between policy runs]:n:'
}

_powerfulseal "$@"
