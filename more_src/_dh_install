#compdef dh_install
# Documentation: https://manpages.debian.org/dh_install
# Source: Debian/debhelper dh_install — install files into package build directories (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '-A[apply files to all -p packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '--autodest[determine destination automatically]' \
    '--list-missing[list missing files]' \
    '--fail-missing[fail on missing files]' \
    '--sourcedir=-[source directory]:dir:_files -/' \
    '--remaining-packages[only handle packages not yet processed]' \
    '*-O+[passthrough option]:opt:_default' \
    '*:file or glob:_files' \
    && ret=0

return ret
