#compdef swag

# Zsh completion for swag (Go Swagger documentation generator)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Create docs.go and swagger spec from source'
      'fmt:Format swag comments'
    )
    _describe -t commands 'swag command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-g+[Go file path where the main function is]:file:_files' \
          '--generalInfo=[Go file path where the main function is]:file:_files' \
          '-d+[Directories to parse]:dirs' \
          '--dir=[Directories to parse]:dirs' \
          '--exclude=[Exclude directories from parsing]:dirs' \
          '-p+[Property naming strategy]:strategy:(snakecase camelcase pascalcase)' \
          '--propertyStrategy=[Property naming strategy]:strategy:(snakecase camelcase pascalcase)' \
          '-o+[Output directory for generated files]:dir:_directories' \
          '--output=[Output directory for generated files]:dir:_directories' \
          '--outputTypes=[Output types of generated files]:types' \
          '--overridesFile=[File to override types]:file:_files' \
          '--parseVendor[Parse files in vendor directory]' \
          '--parseDependency[Parse go files inside dependency folder]' \
          '--parseDependencyLevel=[Parse dependency level]:level' \
          '--parseInternal[Parse go files in internal packages]' \
          '--generatedTime[Generate timestamp at the top of docs.go]' \
          '--parseDepth=[Dependency parse depth]:depth' \
          '--requiredByDefault[Set required for all fields by default]' \
          '--instanceName=[Set instance name for swagger doc]:name' \
          '--markdownFilesDir=[Directory for markdown description files]:dir:_directories' \
          '--codeExampleFilesDir=[Directory for code example files]:dir:_directories' \
          '--parseGoList[Parse dependency via go list]' \
          '--tags=[Comma-separated list of tags to filter]:tags' \
          '--templateDelims=[Custom template delimiters]:delims' \
          '--collectionFormat=[Collection format]:format:(csv pipes tsv ssv multi)' \
          '--packageName=[Custom package name]:name' \
          '--state=[Initial state for state machine]:state' \
          '--quiet[Make init less verbose]' \
          '-q[Make init less verbose]' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-d+[Directories to format]:dirs' \
          '--dir=[Directories to format]:dirs' \
          '--exclude=[Exclude directories]:dirs' \
          '-g+[Go file path to format]:file:_files' \
          '--generalInfo=[Go file path to format]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
