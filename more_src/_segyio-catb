#compdef segyio-catb
# Documentation: https://github.com/equinor/segyio/blob/main/applications/segyio-catb.c
# segyio: concatenate SEG-Y binary header in seismic unix format

local ret=1

_arguments -s -S \
  '(-d --description)'{-d,--description}'[print with byte offset and field description]' \
  '(-n --nonzero)'{-n,--nonzero}'[only print fields with non-zero values]' \
  '--version[output version information and exit]' \
  '--help[display this help and exit]' \
  '*:SEG-Y file:_files' && ret=0

return ret
