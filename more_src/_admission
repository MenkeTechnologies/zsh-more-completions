#compdef admission
# _admission — KubeEdge cloud-side admission webhook (kubeedge/kubeedge)
# upstream: https://github.com/kubeedge/kubeedge
# Flags from cloud/cmd/admission/app/options/options.go on tip.

_admission() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--master=[Kubernetes apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--tls-cert-file=[x509 server certificate]:file:_files' \
        '--tls-private-key-file=[x509 server private key]:file:_files' \
        '--ca-cert-file=[CA certificate for client auth]:file:_files' \
        '--port=[admission webhook bind port]:port:' \
        '--webhook-namespace=[webhook service namespace]:ns:' \
        '--webhook-service-name=[webhook service name]:name:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[also log to stderr]' \
        '--stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[per-module verbosity (pattern=N,...)]:spec:'
}

_admission "$@"
