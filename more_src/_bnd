#compdef bnd

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'action:execute action'
  'add:add to project'
  'baseline:compare jars to baseline'
  'bash:start bash session'
  'bnd:bnd command'
  'bootstrap:bootstrap workspace'
  'bsn2url:convert bsn to url'
  'build:build a bnd project'
  'buildtool:build tool'
  'buildx:build experimental'
  'bump:bump version'
  'changes:show changes'
  'classpath:show classpath'
  'classtoresource:convert class to resource'
  'clean:clean project'
  'collect:collect items'
  'com:com helper'
  'compile:compile sources'
  'convert:convert artifacts'
  'copy:copy resources'
  'create:create project'
  'debug:debug a bundle'
  'defaults:show defaults'
  'deliverables:show deliverables'
  'dependencies:show dependencies'
  'dev:dev mode'
  'diff:diff bundles'
  'digest:compute digest'
  'do:perform actions'
  'eclipse:eclipse helpers'
  'ees:execution env stmts'
  'export:export bundle'
  'exportreport:export report'
  'extract:extract bundle'
  'find:find resources'
  'flatten:flatten dependencies'
  'generate:generate sources'
  'generatemanual:generate manual'
  'gmd:GMD helper'
  'graph:dependency graph'
  'grep:grep bundles'
  'index:create index'
  'info:show info'
  'junit:run junit tests'
  'macro:expand macros'
  'maven:maven helpers'
  'mbr:multi-bundle release'
  'nexus:nexus repo helpers'
  'package:create package'
  'packagetoresource:package to resource'
  'plugins:plugin operations'
  'print:print bundle info'
  'profile:profile operations'
  'project:project operations'
  'properties:print properties'
  'release:release a bundle'
  'remote:remote operations'
  'remove:remove items'
  'repo:repository operations'
  'resolve:resolve a project'
  'run:run a bndrun'
  'runtests:run tests'
  'schema:schema operations'
  'select:select items'
  'settings:show settings'
  'shell:start shell'
  'source:source operations'
  'sync:sync workspace'
  'syntax:check syntax'
  'test:run tests'
  'type:show type'
  'verify:verify bundle'
  'version:show version'
  'view:view bundle'
  'wrap:wrap a jar as OSGi bundle'
  'xmlrepodiff:diff xml repos'
  'xref:cross-reference'
)

_arguments -C \
  '(-b --base)'{-b,--base=}'[base directory]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-e --exceptions)'{-e,--exceptions}'[print exception traces]' \
  '(-f --failok)'{-f,--failok}'[failures as warnings]' \
  '(-i --ignore)'{-i,--ignore=}'[ignore patterns]:patterns:' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '(-p --pedantic)'{-p,--pedantic}'[pedantic mode]' \
  '(-s --secret)'{-s,--secret=}'[settings password]:secret:' \
  '(-t --trace)'{-t,--trace}'[trace progress]' \
  '(-w --workspace)'{-w,--workspace}'[use workspace]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bnd subcommand' subcommands && ret=0
    ;;
esac

return ret
