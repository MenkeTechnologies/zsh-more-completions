#compdef atdcat
# _atdcat — pretty-print/convert ATD type definitions (ahrefs/atd)
# upstream: https://github.com/ahrefs/atd
# Flags from atdcat/src/atdcat.ml (Arg.parse spec).

_atdcat() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-o+[output file path]:file:_files' \
        '-x[expand type definitions]' \
        '-xk[expand keeping polymorphic types]' \
        '-xd[expand with debug info]' \
        '-i[short for -if -iv (inherit fields and variants)]' \
        '-if[inherit fields across module]' \
        '-iv[inherit variants across module]' \
        '-jsonschema=[emit JSON Schema for ROOT type]:root type:' \
        '-jsonschema-no-additional-properties[disallow additional JSON object properties]' \
        '-jsonschema-version=[JSON Schema draft to emit]:draft:(draft-2019-09 draft-2020-12)' \
        '-ml=[emit OCaml module with NAME]:name:' \
        '-html-doc[render docstrings as HTML]' \
        '-remove-wraps[remove ATD wrap constructs in output]' \
        '-strip=[strip ANNOTATION-SECTION (comma-separated)]:sections:' \
        '-strip-all[strip all annotations]' \
        '*:atd file:_files -g "*.atd"'
}

_atdcat "$@"
