#compdef zhmcclient zhmc
# Documentation: https://zhmccli.readthedocs.io/en/stable/
# Reference accessed: 2026-05-16
# Verified: zhmccli readthedocs CLI reference. NOTE: pip package
# `zhmcclient` is library-only with no CLI; the CLI is shipped by
# `zhmccli` and installs binary `zhmc`. Both names completed here for
# compatibility.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h/--help/--version stubs missing real flag table.

# zhmc: IBM Z Hardware Management Console CLI
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'adapter:manage adapters'
  'capacitygroup:manage capacity groups'
  'cpc:manage CPCs'
  'hba:manage HBAs'
  'help:show help'
  'info:show session info'
  'lpar:manage LPARs'
  'metrics:metrics'
  'nic:manage NICs'
  'partition:manage partitions'
  'passwordrule:manage password rules'
  'port:manage ports'
  'repl:interactive REPL'
  'session:manage sessions'
  'storagegroup:manage storage groups'
  'storagevolume:manage storage volumes'
  'user:manage users'
  'userrole:manage user roles'
  'vfunction:manage virtual functions'
  'vstorageresource:manage virtual storage resources'
  'vswitch:manage virtual switches'
)

_arguments -C \
  '(-h --host)'{-h+,--host=}'[HMC host]:host:_hosts' \
  '(-u --userid)'{-u+,--userid=}'[user ID]:user:' \
  '(-p --password)'{-p+,--password=}'[password]:pw:' \
  '(-n --no-verify)'{-n,--no-verify}'[skip CA verification]' \
  '(-c --ca-certs)'{-c+,--ca-certs=}'[CA cert file/dir]:path:_files' \
  '(-o --output-format)'{-o+,--output-format=}'[output format]:fmt:(table plain simple psql rst mediawiki html latex json csv)' \
  '(-x --transpose)'{-x,--transpose}'[transpose table]' \
  '(-e --error-format)'{-e+,--error-format=}'[error format]:fmt:(msg def)' \
  '(-t --timestats)'{-t,--timestats}'[time stats]' \
  '*--log=[COMPONENT=LEVEL]:logspec:' \
  '--log-dest=[log destination]:dest:(stderr syslog none)' \
  '--syslog-facility=[syslog facility]:facility:' \
  '--version[show version]' \
  '--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zhmc command' commands && ret=0 ;;
esac
return ret
