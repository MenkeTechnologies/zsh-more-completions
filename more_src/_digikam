#compdef digikam
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/digikam.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# digiKam photo management application command-line options.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[desktop entry base file name]:file:_files' \
  '--database-directory=[SQLite database directory]:dir:_directories' \
  '--download-from=[open camera dialog at path]:path' \
  '--download-from-udi=[open camera dialog for device with Solid UDI]:udi' \
  '--detect-camera[auto-detect and open connected gphoto2 camera]' && ret=0

return ret
