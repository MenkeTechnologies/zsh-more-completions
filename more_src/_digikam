#compdef digikam

# Zsh completion for digikam - digiKam photo management

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--database-directory=[database directory]:dir:_directories' \
  '--download-from=[camera to download from]:camera' \
  '--download-from-udi=[download from UDI device]:device' \
  '--detect-camera[detect connected cameras]' \
  '--database-backend=[database backend]:backend:(sqlite mysql)' \
  '--config=[configuration file]:file:_files' \
  '*:file:_files -g "*.{jpg,jpeg,png,tif,tiff,raw,cr2,cr3,nef,arw,orf,raf,dng,rw2,pef,srw}"' && ret=0

return ret
