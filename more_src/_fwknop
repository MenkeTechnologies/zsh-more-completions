#compdef fwknop

# Zsh completion for fwknop (Single Packet Authorization client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-A --access)'{-A,--access}'=[Specify access string (proto/port)]:access string' \
  '(-a --allow-ip)'{-a,--allow-ip}'=[Specify IP to allow through the firewall]:ip address' \
  '(-D --destination)'{-D,--destination}'=[Set the SPA destination server]:host' \
  '(-p --server-port)'{-p,--server-port}'=[Set the server port for SPA packet]:port' \
  '(-P --server-proto)'{-P,--server-proto}'=[Set the protocol for SPA packet]:protocol:(udp tcp http)' \
  '(-s --source-ip)'{-s,--source-ip}'[Use the source IP of the SPA packet]' \
  '(-R --resolve-ip-https)'{-R,--resolve-ip-https}'[Resolve external IP via HTTPS]' \
  '(-N --nat-access)'{-N,--nat-access}'=[NAT access string]:nat access' \
  '(-n --named-config)'{-n,--named-config}'=[Use a named stanza from .fwknoprc]:stanza name' \
  '--rc-file=[Specify path to .fwknoprc file]:file:_files' \
  '(-k --key-gen)'{-k,--key-gen}'[Generate SPA encryption and HMAC keys]' \
  '--key-gen-file=[Write generated keys to file]:file:_files' \
  '--use-hmac[Use HMAC authentication]' \
  '(-B --save-packet)'{-B,--save-packet}'=[Save SPA packet to file]:file:_files' \
  '(-b --save-packet-append)'{-b,--save-packet-append}'=[Append SPA packet to file]:file:_files' \
  '--gpg-encryption[Use GPG encryption for SPA packet]' \
  '--gpg-recipient-key=[Specify GPG recipient key ID]:key id' \
  '--gpg-signer-key=[Specify GPG signer key ID]:key id' \
  '--gpg-home-dir=[Specify GPG home directory]:dir:_files -/' \
  '--gpg-agent[Use GPG agent for signing]' \
  '--no-save-args[Do not save arguments to .fwknoprc]' \
  '(-f --fw-timeout)'{-f,--fw-timeout}'=[Set firewall rule timeout]:seconds' \
  '(-l --last-cmd)'{-l,--last-cmd}'[Run the last fwknop command]' \
  '--server-cmd=[Execute a command on the server side]:command' \
  '(-T --test)'{-T,--test}'[Build SPA packet but do not send]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose mode]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '(-h --help)'{-h,--help}'[Print help]' && ret=0

return ret
