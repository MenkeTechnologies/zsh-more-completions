#compdef claudio-cli
# Documentation: https://www.npmjs.com/package/claudio-cli
# Reference accessed: 2026-05-23
# Verified: npx claudio-cli --help.

# Zsh completion for claudio-cli - Claudio Pipe AI dev orchestration CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate with GitHub OAuth'
  'logout:clear current session'
  'work:work on current tasks in selected repository'
  'imagination:run Claudio in imagination mode'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[emit verbose diagnostic output]' \
  '--json[output raw JSON lines]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'claudio-cli command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
