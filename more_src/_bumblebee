#compdef bumblebee bee-cli
# _bumblebee — Solo.io BumbleBee eBPF tool packager CLI (Solo.io, Go); spf13/cobra
# upstream: https://github.com/solo-io/bumblebee

_bumblebee() {
    local -a sub=(
        'build:build BPF program OCI image'
        'list:list bpf programs in image'
        'login:login to OCI registry'
        'package:package BPF program'
        'push:push BPF image to registry'
        'pull:pull BPF image'
        'run:run BPF program'
        'tag:tag BPF image'
        'init:scaffold a new BPF project'
        'describe:describe a BPF image'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bumblebee subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '1:file:_files -g "*.c"' \
                    '-t+[image tag]:tag:' \
                    '--build-image=+[builder image]:image:' \
                    '--build-script=+[build script]:file:_files' \
                    '--builder=+[builder cmd]:cmd:' \
                    '--source=+[source dir]:dir:_files -/' ;;
                run) _arguments \
                    '1:image-or-file:' \
                    '--filter=+[filter]:str:' \
                    '--log-level=+[log level]:level:(trace debug info warn error)' \
                    '--no-stats[no stats]' \
                    '--prom-bind=+[prometheus bind addr]:addr:' \
                    '--pin-maps=+[pin maps]:str:' \
                    '--pin-progs=+[pin programs]:str:' \
                    '--bpffs=+[bpffs path]:dir:_files -/' \
                    '--cgroup=+[cgroup path]:dir:_files -/' \
                    '--detach[run detached]' \
                    '-d[run detached]' ;;
                push|pull|tag|describe|list) _arguments '1:image:' ;;
                login) _arguments \
                    '1:registry:' \
                    '--username=+[username]:str:_users' \
                    '-u+[username]:str:_users' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--password-stdin[password from stdin]' ;;
                init) _arguments \
                    '1:project-name:' \
                    '--language=+[language]:lang:(c rust)' \
                    '--program-type=+[program type]:type:(network file process)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_bumblebee "$@"
