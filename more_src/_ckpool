#compdef ckpool
# _ckpool — Con Kolivas ckpool ultra-low-latency Bitcoin mining pool server CLI for managing the standalone Stratum pool process pool worker shares accept reject reward share-difficulty target failover backup proxy mode logging (ckolivas team, C); getopt
# upstream: https://github.com/ckolivas/ckpool

_ckpool() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[config file]:file:_files -g "*.conf ckpool.conf"' \
        '--config=+[config file]:file:_files -g "*.conf ckpool.conf"' \
        '-d+[daemon mode]' \
        '--daemon[daemon mode]' \
        '-D+[debug level]:n:(0 1 2 3 4 5 6 7)' \
        '--debug=+[debug level]:n:(0 1 2 3 4 5 6 7)' \
        '-l+[log level]:l:(emerg alert crit err warning notice info debug)' \
        '--loglevel=+[log level]:l:(emerg alert crit err warning notice info debug)' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-N[node mode]' \
        '--node[node mode]' \
        '-p[passthrough mode]' \
        '--passthrough[passthrough mode]' \
        '-P[proxy mode]' \
        '--proxy[proxy mode]' \
        '-R[redirect mode]' \
        '--redirect[redirect mode]' \
        '-s+[socket dir]:dir:_files -/' \
        '--socket-dir=+[socket dir]:dir:_files -/' \
        '-L[log shares]' \
        '--log-shares[log shares]' \
        '-A[handle ASIC boost]' \
        '--asicboost[handle ASIC boost]' \
        '-B[skip btcd test]' \
        '--standalone[standalone]' \
        '-T+[trusted upstream]:str:' \
        '--trusted-server=+[trusted upstream]:str:' \
        '-w[reject low-diff shares]' \
        '--worker-diff[reject low-diff shares]' \
        '-S+[start difficulty]:n:' \
        '--starting-diff=+[start difficulty]:n:'
}

_ckpool "$@"
