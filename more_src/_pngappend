#compdef pngappend
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/fslwiki/Miscvis
# FSL: append PNG/GIF images horizontally or vertically with optional gaps

local ret=1

# Usage: pngappend <input> <+|-> [n] <input> ... <output>
# '+' appends horizontally, '-' appends vertically, optional [n] = gap pixels
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:image or +/-:_files' && ret=0

return ret
