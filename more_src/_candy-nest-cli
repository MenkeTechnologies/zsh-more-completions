#compdef candy-nest-cli
# Documentation: https://dev.to/ashish_kushwaha/automating-nestjs-microservice-setup-with-candy-nest-cli-2ig9
# Reference accessed: 2026-05-23
# Verified: candy-nest-cli init/add usage from project docs.

# Zsh completion for candy-nest-cli - NestJS microservice scaffolding CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'candy-nest-cli command' \
      'init[initialize new microservice project]' \
      'add[add feature to existing project]' && ret=0
    ;;
  args)
    case $line[1] in
      (init)
        _arguments \
          '--all[enable all options without prompts]' \
          ':project-name:' && ret=0
        ;;
      (add)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
