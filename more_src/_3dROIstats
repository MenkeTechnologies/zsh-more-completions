#compdef 3dROIstats
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dROIstats.html
# AFNI compute per-ROI statistics from a mask of region values

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-mask[mask dataset and optional sub-brick]:dataset:_files' \
  '-mask_f2short[convert float mask to short integers]' \
  '-numROI[set expected ROI count]:n' \
  '-zerofill[fill missing ROIs with value]:ZF' \
  '-roisel[select specific ROIs from file]:file:_files' \
  '-quiet[suppress column and row labels]' \
  '-longnames[display full sub-brick names]' \
  '-nobriklab[omit sub-brick labels]' \
  '-1Dformat[output as 1D with commented labels]' \
  '-1DRformat[output as 1D R-compatible]' \
  '-float_format[float output style]:form:(float pretty sci)' \
  '-float_format_sep[float separator character]:sep' \
  '-nzmean[mean of non-zero voxels only]' \
  '-nzsum[sum of non-zero voxels]' \
  '-nzvoxels[count of non-zero voxels]' \
  '-nzvolume[volume of non-zero voxels]' \
  '-minmax[minimum and maximum values]' \
  '-nzminmax[min/max of non-zero voxels]' \
  '-sigma[standard deviation]' \
  '-nzsigma[standard deviation of non-zero voxels]' \
  '-median[median value]' \
  '-nzmedian[median of non-zero voxels]' \
  '-mode[mode for integral datasets]' \
  '-nzmode[mode of non-zero voxels]' \
  '-pcxyz[principal component directions]' \
  '-nzpcxyz[principal components excluding zeros]' \
  '-nomeanout[exclude mean from output]' \
  '-summary[output grand mean summary only]' \
  '-key[include ROI integer key in output]' \
  '-debug[display debugging information]' \
  '*:dataset:_files' && ret=0

return ret
