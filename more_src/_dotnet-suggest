#compdef dotnet-suggest

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'get:get suggestions for a partial command line'
  'list:list registered executables that provide suggestions'
  'register:register an executable as a suggestion provider'
  'script:generate shell integration script'
  'completion-script:alias for script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'dotnet-suggest command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get)
        _arguments \
          '(-e --executable)'{-e+,--executable=}'[executable path]:file:_files' \
          '(-p --position)'{-p+,--position=}'[cursor position]:n:' \
          '*::input:' && ret=0 ;;
      (register)
        _arguments \
          '--command-path=[command path]:path:_files' \
          '--suggestion-command=[suggestion command]:cmd:' && ret=0 ;;
      (script|completion-script)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
