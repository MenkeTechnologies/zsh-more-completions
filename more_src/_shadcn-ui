#compdef shadcn shadcn-ui

_shadcn-ui() {
    local line state
    local -a commands
    commands=(
        'init:Initialize project and install dependencies'
        'add:Add a component to your project'
        'diff:Check for updates and diffs in components'
    )

    _arguments -C \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'shadcn command' commands
            ;;
        args)
            case $line[1] in
                add)
                    _arguments '--all[Add all available components]' '--overwrite[Overwrite existing files]' '*:component:'
                    ;;
            esac
            ;;
    esac
}

_shadcn-ui "$@"
