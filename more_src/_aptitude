#compdef aptitude
# Documentation: https://manpages.debian.org/aptitude
# Source: SamB/aptitude src/main.cc — Debian high-level package manager front-end (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    {-F+,--display-format=}'[result display format]:format:_default' \
    '(-q --quiet)'{-q,--quiet}'[quiet output (stackable)]' \
    {-w+,--width=}'[output width]:width:_default' \
    '(-s --simulate)'{-s,--simulate}'[simulate (no changes)]' \
    '--allow-untrusted[allow installing untrusted packages]' \
    '(-r --with-recommends)'{-r,--with-recommends}'[install recommended packages]' \
    '(-R --without-recommends)'{-R,--without-recommends}'[do not install recommended packages]' \
    '(-d --download-only)'{-d,--download-only}'[only download, do not install]' \
    '(-y --assume-yes)'{-y,--assume-yes}'[assume yes for all prompts]' \
    '*'{-v,--verbose}'[verbose output (stackable)]' \
    '(-V --show-versions)'{-V,--show-versions}'[show versions]' \
    '(-D --show-deps)'{-D,--show-deps}'[show dependencies]' \
    '(-W --show-why)'{-W,--show-why}'[show why packages are being acted on]' \
    '(-P --prompt)'{-P,--prompt}'[prompt before action]' \
    {-O+,--sort=}'[sort criterion]:order:_default' \
    {-t+,--target-release=}'[target release]:release:_default' \
    '--disable-columns[disable column formatting]' \
    '(--allow-new-installs)--no-new-installs[allow no new installs]' \
    '(--allow-new-upgrades)--no-new-upgrades[allow no new upgrades]' \
    '(--no-new-installs)--allow-new-installs[allow new installs]' \
    '(--no-new-upgrades)--allow-new-upgrades[allow new upgrades]' \
    '(--full-resolver)--safe-resolver[use safe resolver]' \
    '(--safe-resolver)--full-resolver[use full resolver]' \
    '(--no-show-resolver-actions)--show-resolver-actions[show resolver actions]' \
    '(--show-resolver-actions)--no-show-resolver-actions[suppress resolver actions]' \
    '--visual-preview[show ncurses preview]' \
    '--schedule-only[queue actions but do not perform them]' \
    '--purge-unused[purge unused packages]' \
    '*--add-user-tag=-[add user tag]:tag:_default' \
    '*--add-user-tag-to=-[add user tag to packages]:tag,pattern:_default' \
    '*--remove-user-tag=-[remove user tag]:tag:_default' \
    '*--remove-user-tag-from=-[remove user tag from packages]:tag,pattern:_default' \
    '(--not-arch-only)--arch-only[architecture-dependent packages only]' \
    '(--arch-only)--not-arch-only[architecture-independent packages only]' \
    '(--no-gui)--gui[start GTK GUI]' \
    '(--gui)--no-gui[do not start GUI]' \
    '(--no-qt)--qt[start Qt GUI]' \
    '(--qt)--no-qt[do not start Qt GUI]' \
    '--log-level=-[log level]:level:(off fatal error warn info debug trace)' \
    '--log-file=-[log file]:file:_files' \
    '--log-config-file=-[log4cxx config file]:file:_files' \
    '--log-resolver[log resolver actions]' \
    '--show-summary=-[show summary]::level:(first-package second-package both-packages)' \
    '--autoclean-on-startup[autoclean on startup]' \
    '--clean-on-startup[clean on startup]' \
    '--group-by=-[group results by]:criterion:_default' \
    '--show-package-names=-[control package name display]:mode:(always auto never)' \
    '--new-gui[start new GUI]' \
    '1:command:(install remove purge hold unhold markauto unmarkauto forbid-version update upgrade safe-upgrade full-upgrade build-dep forget-new search show why why-not clean autoclean changelog download keep-all reinstall add-user-tag remove-user-tag list)' \
    '*::command args:_default' \
    && ret=0

return ret
