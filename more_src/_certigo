#compdef certigo

local -a subcommands
subcommands=(
  'connect:Connect to a server and print its certificate chain'
  'dump:Dump certificates from a file'
  'verify:Verify a certificate chain'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      connect)
        _arguments \
          '(-h --help)'{-h,--help}'[Show help]' \
          '--pem[Print PEM-encoded certificates]' \
          '--json[Print JSON-encoded output]' \
          '--first[Only show the first certificate]' \
          '--timeout=[Connection timeout in seconds]:seconds:' \
          '--name=[Override server name for SNI]:hostname:' \
          '--ca=[CA bundle file]:file:_files' \
          '--cert=[Client certificate]:file:_files' \
          '--key=[Client private key]:file:_files' \
          '--start-tls=[Use STARTTLS protocol]:protocol:(smtp imap ftp ldap)' \
          '--identity=[PKCS12 identity file]:file:_files' \
          '1:host\:port:'
        ;;
      dump)
        _arguments \
          '(-h --help)'{-h,--help}'[Show help]' \
          '--pem[Print PEM-encoded certificates]' \
          '--json[Print JSON-encoded output]' \
          '--first[Only show the first certificate]' \
          '*:certificate file:_files'
        ;;
      verify)
        _arguments \
          '(-h --help)'{-h,--help}'[Show help]' \
          '--name=[Expected server name]:hostname:' \
          '--ca=[CA bundle file]:file:_files' \
          '--json[Print JSON-encoded output]' \
          '*:certificate file:_files'
        ;;
    esac
    ;;
esac
