#compdef phase_common
# Documentation: https://gensoft.pasteur.fr/docs/shapeit5/5.1.1/phase_common.html
# SHAPEIT5 phase_common: phase common variants (formerly SHAPEIT4)

local ret=1

_arguments -s -S \
  '--help[produce help message]' \
  '--seed=[random number generator seed]:int' \
  '(-T --thread)'{-T,--thread}'=[number of threads used]:int' \
  '(-I --input)'{-I,--input}'=[genotypes to be phased in VCF/BCF/XCF format]:file:_files' \
  '(-H --reference)'{-H,--reference}'=[reference panel of haplotypes]:file:_files' \
  '(-S --scaffold)'{-S,--scaffold}'=[scaffold of haplotypes]:file:_files' \
  '(-M --map)'{-M,--map}'=[genetic map]:file:_files' \
  '--pedigree=[pedigree information (offspring father mother triplets)]:file:_files' \
  '--haploids=[list of haploid samples]:file:_files' \
  '(-R --region)'{-R,--region}'=[target region]:region' \
  '--filter-snp[only consider SNPs]' \
  '--filter-maf=[filter variants with MAF above threshold]:float' \
  '--mcmc-iterations=[iteration scheme]:scheme' \
  '--mcmc-prune=[pruning threshold for genotype graphs]:float' \
  '--mcmc-noinit[disable PBWT initialization]' \
  '--pbwt-modulo=[storage frequency of indexes in cM]:float' \
  '--pbwt-depth=[depth of indexes to condition on]:int' \
  '--pbwt-mac=[minimal minor allele count threshold]:int' \
  '--pbwt-mdr=[maximum missing data rate]:float' \
  '--pbwt-window=[window size for PBWT selection]:int' \
  '--hmm-window=[minimal phasing window size in cM]:int' \
  '--hmm-ne=[effective size of the population]:int' \
  '(-O --output)'{-O,--output}'=[phased haplotypes in VCF/BCF/XCF format]:file:_files' \
  '--output-format=[output format]:format:(bcf graph bh)' \
  '--log=[log file]:file:_files' && ret=0

return ret
