#compdef wcsattrib
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss204.html
# KAPPA: manage attribute values associated with the WCS component of an NDF

local ret=1

_arguments -s \
  'MODE=[operation to perform]:mode:(Clear Get MSet Set Test)' \
  'NAME=[attribute name]:name' \
  'NDF=[NDF to modify or read]:NDF:_files' \
  'NEWVAL=[new value to assign for Set]:newval' \
  'REMAP=[adjust inter-Frame Mappings]:remap:(TRUE FALSE)' \
  'SETTING=[attribute=value pairs for MSet]:setting' \
  '*:NDF:_files' && ret=0

return ret
