#compdef wastral
# Documentation: https://github.com/chaoszhang/ASTER/blob/master/tutorial/wastral.md
# Weighted ASTRAL species tree estimation (ASTER package)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-a+[mapping file for individual-to-species associations]:map:_files' \
  '-c+[fully resolved species tree for placement or scoring]:tree:_files' \
  '-g+[candidate species trees as hints]:tree:_files' \
  '-i+[input gene tree file]:input:_files' \
  '-o+[output file for results]:output:_files' \
  '-n+[minimum support value threshold]:value' \
  '-x+[maximum support value threshold]:value' \
  '-r+[number of initial search rounds]:rounds' \
  '-s+[number of subsampling rounds]:rounds' \
  '-t+[number of threads]:threads' \
  '-u+[output detail level]:level:(0 1 2)' \
  '-B[local Bayesian support shorthand]' \
  '-C[scoring mode with single taxon placement]' \
  '-L[probability/likelihood support shorthand]' \
  '-R[run more rounds for optimality]' \
  '-S[bootstrap support shorthand]' \
  '--mode=[weighting scheme]:mode:(2 3)' \
  '--root=[root tree at outgroup taxon]:taxon' \
  '*:gene tree file:_files' && ret=0

return ret
