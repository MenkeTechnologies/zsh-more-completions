#compdef http-server
# _http-server-cli — Node.js zero-config static HTTP server (Charlie Robbins / http-party); commonly used for local file hosting
# upstream: https://github.com/http-party/http-server

_http-server-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-p --port)'{-p,--port}'+[port]:port:' \
        '(-a)-a+[bind address]:host:_hosts' \
        '(-d)-d+[show directory listing]:bool:(true false)' \
        '(-i)-i+[show autoIndex]:bool:(true false)' \
        '(-g --gzip)'{-g,--gzip}'[serve .gz when available]' \
        '(-b --brotli)'{-b,--brotli}'[serve .br when available]' \
        '(-e --ext)'{-e,--ext}'+[default extension]:ext:' \
        '(-s --silent)'{-s,--silent}'[silent]' \
        '--cors+[Access-Control-Allow-Origin]:str:' \
        '(-o --open)'{-o,--open}'+[open URL]:url:_urls' \
        '(-c)-c+[cache TTL seconds]:n:' \
        '-c-1[disable cache]' \
        '-P+[proxy URL]:url:_urls' \
        '--proxy-options.secure+[proxy secure]:bool:(true false)' \
        '-S[serve over HTTPS]' \
        '--ssl[serve over HTTPS]' \
        '-C+[TLS cert]:file:_files' \
        '-K+[TLS key]:file:_files' \
        '-r[robots.txt enabled]' \
        '--no-dotfiles[hide dotfiles]' \
        '--username+[basic auth user]:user:' \
        '--password+[basic auth password]:pw:' \
        '--logIp[log ip]' \
        '--tls[serve over HTTPS]' \
        '--mimetypes+[mime types file]:file:_files' \
        '*:dir:_files -/'
}

_http-server-cli "$@"
