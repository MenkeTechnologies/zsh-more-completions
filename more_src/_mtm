#compdef mtm
# Documentation: https://github.com/deadpixi/mtm/blob/master/mtm.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mtm: the micro terminal multiplexer. Only three documented flags: -T, -t, -c.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-T+[assume host terminal is of type HOST]:host terminal type:' \
  '-t+[set the TERM advertised within the mtm session]:terminal type:' \
  '-c+[command prefix character (default g, used with Ctrl)]:character:' \
  '*:command:_command_names -e' && ret=0

return ret
