#compdef mtm
# Documentation: https://github.com/deadpixi/mtm/blob/master/mtm.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for mtm - micro terminal multiplexer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-m[set command key]:key' \
  '-T[set terminal type]:terminal type:(mtm mtm-256color eterm-color screen screen-256color xterm xterm-256color)' \
  '-c[set default shell]:shell:_command_names -e' \
  '-t[set terminal emulation]:terminal type' \
  '-b[set scrollback size]:lines' \
  '*:command:_command_names -e' && ret=0

return ret
