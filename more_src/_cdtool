#compdef cdtool cdir cdeject cdadd cdplay cdpause cdstop cdresume cdslot cdvolume
# Documentation: https://manpages.debian.org/bullseye/cdtool/cdir.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-\\?[show help]' \
  '(- *)-V[print version and build information]' \
  '-d+[cdrom device by name]:dev:_files -g "/dev/{cdrom,sr*,cdrw*,scd*}"' \
  '-0[open /dev/scd0]' \
  '-1[open /dev/scd1]' \
  '-2[open /dev/scd2]' \
  '-3[open /dev/scd3]' \
  '-4[open /dev/scd4]' \
  '-5[open /dev/scd5]' \
  '-6[open /dev/scd6]' \
  '-7[open /dev/scd7]' \
  '-n[do not query database files (cdir)]' \
  '-s[short / abbreviated output (cdir)]' \
  '-t[output a template for the CD (cdir)]' \
  '-D[enable runtime debugging]' \
  '*:track_or_arg:' && ret=0

return ret
