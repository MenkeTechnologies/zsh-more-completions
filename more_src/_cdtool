#compdef cdtool cdir cdeject cdir cdadd cdplay cdpause cdstop cdresume cdslot cdvolume
# Documentation: https://man.archlinux.org/search?q=cdtool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-d+[device]:dev:_files -g "/dev/{cdrom,sr*,cdrw*}"' \
  '*:track_or_arg:' && ret=0

return ret
