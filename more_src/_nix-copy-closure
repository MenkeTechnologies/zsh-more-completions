#compdef nix-copy-closure

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--to=[copy to remote]:host' \
  '--from=[copy from remote]:host' \
  '--sign[sign paths]' \
  '--gzip[use gzip compression]' \
  '--include-outputs[include outputs of store derivations]' \
  '--use-substitutes[download from binary caches]' \
  '-s[download from binary caches]' \
  '-v[verbose output]' \
  '*:store paths:_files' && ret=0

return ret
