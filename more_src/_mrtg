#compdef mrtg

_arguments -s \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '--lock-file=[lock file]:file:_files' \
  '--confcache-file=[config cache file]:file:_files' \
  '--logging=[log destination]:dest:' \
  '--pid-file=[PID file]:file:_files' \
  '--debug=[debug categories]:cats:' \
  '--daemon[run as daemon]' \
  '--fhs[use FHS layout]' \
  '--check[check config and exit]' \
  ':cfgfile:_files'
