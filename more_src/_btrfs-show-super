#compdef btrfs-show-super
# Documentation: https://man.archlinux.org/search?q=btrfs-show-super
# Reference accessed: 2026-05-16

_arguments -s \
  '-f[print full superblock info]' \
  '-a[print info from all superblocks]' \
  '-i+[mirror to display]:n:(0 1 2)' \
  '-F[force]' \
  '-s+[non-standard byte offset]:bytenr:' \
  ':device:_files'
