#compdef btrfs-show-super
# Documentation: https://manpages.debian.org/unstable/btrfs-progs/btrfs-show-super.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-f[print full superblock info]' \
  '-a[print info from all superblocks]' \
  '-i+[mirror to display]:n:(0 1 2)' \
  '-F[force]' \
  '-s+[non-standard byte offset]:bytenr:' \
  ':device:_files'
