#compdef picom-trans
# Documentation: https://man.archlinux.org/man/picom-trans.1
# Reference accessed: 2026-05-20
# Verified: upstream picom-trans(1) man page.

# picom-trans: set opacity on a window for picom (transset replacement)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(-c --current)'{-c,--current}'[target the currently active window]' \
  '(-s --select)'{-s,--select}'[select target window with mouse]' \
  '(-w --window)'{-w+,--window=}'[target window id]:wid:' \
  '(-n --name)'{-n+,--name=}'[match window by name]:name:' \
  '(-o --opacity)'{-o+,--opacity=}'[set opacity 1-100 (prefix + or - to inc/dec)]:opacity:' \
  '(-g --get)'{-g,--get}'[print opacity instead of setting it]' \
  '(-d --delete)'{-d,--delete}'[delete opacity of target window]' \
  '(-t --toggle)'{-t,--toggle}'[toggle opacity of target window]' \
  '(-r --reset)'{-r,--reset}'[reset opacity for all windows]' \
  '*::picom-trans args:_default' && ret=0
return ret
