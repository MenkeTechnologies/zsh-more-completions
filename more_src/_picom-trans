#compdef picom-trans
# Documentation: https://man.archlinux.org/search?q=picom-trans
# Reference accessed: 2026-05-16

# picom-trans: set opacity on a window for picom (transset replacement)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[current window opacity]' \
  '--current[current window opacity]' \
  '-s[select with mouse]' \
  '--select[select with mouse]' \
  '-w[target window id]:wid:' \
  '--window=[target window id]:wid:' \
  '-n[window name]:name:' \
  '--name=[window name]:name:' \
  '-p[partial match name]:name:' \
  '--partial[partial match name]' \
  '-r[delete opacity (reset)]' \
  '--delete[delete opacity (reset)]' \
  '-t[toggle opacity]' \
  '--toggle[toggle opacity]' \
  '-i[inverse direction]:opacity:' \
  '--increment=[inverse direction]:opacity:' \
  '-o[set opacity 0-100]:opacity:' \
  '--opacity=[set opacity 0-100]:opacity:' \
  '*::picom-trans args:_files' && ret=0
return ret
