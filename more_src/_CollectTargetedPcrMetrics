#compdef CollectTargetedPcrMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectTargetedPcrMetrics
# Picard: collect metrics for targeted PCR (amplicon) sequencing experiments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[aligned SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  '--AMPLICON_INTERVALS=[interval list of bait/amplicon locations]:interval_list:_files -g "*.interval_list"' \
  '--CUSTOM_AMPLICON_SET_NAME=[custom amplicon set name]:name:' \
  '*--TARGET_INTERVALS=[interval list of target locations]:interval_list:_files -g "*.interval_list"' \
  '--METRIC_ACCUMULATION_LEVEL=[level at which to accumulate metrics]:level:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '--PER_TARGET_COVERAGE=[optional per-target coverage output file]:file:_files' \
  '--PER_BASE_COVERAGE=[optional per-base coverage output file]:file:_files' \
  '--NEAR_DISTANCE=[max distance between a read and nearest probe]:int:' \
  '--MINIMUM_MAPPING_QUALITY=[minimum mapping quality threshold]:int:' \
  '--MINIMUM_BASE_QUALITY=[minimum base quality threshold]:int:' \
  '--CLIP_OVERLAPPING_READS=[clip overlapping reads]:bool:(true false)' \
  '--COVERAGE_CAP=[maximum coverage limit for sensitivity calculations]:int:' \
  '--SAMPLE_SIZE=[sample size for theoretical heterozygote sensitivity]:int:' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
