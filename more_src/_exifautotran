#compdef exifautotran
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/exifautotran.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exifautotran: shell script that transforms EXIF images to Orientation=1
# (libjpeg / jpegexiforient + jpegtran). Takes only filenames; no flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:file:_files -g "*.{jpg,jpeg}"' && ret=0

return ret
