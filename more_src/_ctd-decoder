#compdef ctd-decoder
# Documentation: https://github.com/containerd/imgcrypt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ctd-decoder: stream decoder helper for containerd encrypted images
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--decryption-keys-path=[decryption keys path]:dir:_files -/' \
  '*::ctd-decoder args:_files' && ret=0
return ret
