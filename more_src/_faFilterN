#compdef faFilterN
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# get rid of sequences with too many Ns

local ret=1

_arguments -s -S \
  '-out=[output file name]:out file:_files' \
  '-uniq=[PSL file for uniqueness filtering]:psl file:_files -g "*.psl"' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:out fa:_files' \
  '3:max percent N' && ret=0

return ret
