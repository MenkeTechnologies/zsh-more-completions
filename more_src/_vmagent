#compdef vmagent

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--promscrape.config=[Prometheus scrape config file]:config file:_files' \
  '--promscrape.configCheckInterval=[config check interval]:duration' \
  '--promscrape.maxScrapeSize=[max scrape response size]:bytes' \
  '--promscrape.cluster.membersCount=[number of cluster members]:count' \
  '--promscrape.cluster.memberNum=[member number in cluster]:number' \
  '--promscrape.cluster.replicationFactor=[cluster replication factor]:factor' \
  '--remoteWrite.url=[remote write endpoint URL]:url' \
  '--remoteWrite.tmpDataPath=[temp data path for remote write]:path:_files -/' \
  '--remoteWrite.maxDiskUsagePerURL=[max disk usage per remote write URL]:bytes' \
  '--remoteWrite.queues=[number of remote write queues]:count' \
  '--remoteWrite.maxBlockSize=[max block size for remote write]:bytes' \
  '--remoteWrite.maxRowsPerBlock=[max rows per block]:count' \
  '--remoteWrite.label=[extra label for remote write]:label' \
  '--remoteWrite.relabelConfig=[relabel config file]:config file:_files' \
  '--remoteWrite.sendTimeout=[send timeout]:duration' \
  '--remoteWrite.bearerToken=[bearer token for remote write]:token' \
  '--remoteWrite.basicAuth.username=[basic auth username]:username' \
  '--remoteWrite.basicAuth.password=[basic auth password]:password' \
  '--httpListenAddr=[HTTP listen address]:address' \
  '--loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '--loggerFormat=[log format]:format:(default json)' \
  '--loggerOutput=[log output]:output:(stderr stdout)' \
  '--tls[enable TLS for incoming requests]' \
  '--tlsCertFile=[TLS certificate file]:cert file:_files' \
  '--tlsKeyFile=[TLS key file]:key file:_files'
