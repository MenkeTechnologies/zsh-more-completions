#compdef byobu-select-backend
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/byobu-select-backend.1.html
# byobu: select the window manager backend (screen or tmux)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:backend:(screen tmux)' && ret=0

return ret
