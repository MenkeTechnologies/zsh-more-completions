#compdef quota
# Documentation: man quota(1) (BSD)
# Source: BSD quota — display disk usage and limits.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-g[print group quotas for the user]' \
    '-u[print user quotas (default)]' \
    '(-v -q)-v[show filesystems with no allocation]' \
    '(-v -q)-q[terse: only over-quota filesystems]' \
    '*:user or group:_users' \
    && ret=0

return ret
