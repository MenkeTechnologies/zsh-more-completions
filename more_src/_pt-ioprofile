#compdef pt-ioprofile
# Documentation: https://man.archlinux.org/search?q=pt-ioprofile
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--aggregate=[aggregation function]:fn:(sum mean median min max count)' \
  '--cell=[cell content]:cell:(times sizes errors)' \
  '--group-by=[group by]:by:(filename pid all)' \
  '--profile-pid=[profile PID]:pid:' \
  '--profile-process=[profile process name]:name:' \
  '--run-time=[run time seconds]:sec:' \
  '--save-samples=[save samples file]:file:_files' \
  '*:trace_file:_files' && ret=0

return ret
