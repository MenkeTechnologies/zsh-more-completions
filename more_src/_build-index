#compdef build-index
# Documentation: https://astrometry.net/doc/build-index.html
# Source: dstndstn/astrometry.net solver/build-index-main.c — build an astrometry quad-index from a FITS star catalogue.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-i+[input FITS catalog]:file:_files -g "*.(fits|fit|fts)(-.)"' \
    '-e+[input FITS extension]:n:_default' \
    '-1+[share another index'\''s stars]:file:_files' \
    '-o+[output index file]:file:_files' \
    '-P+[preset (-N -l -u from scale number)]:n:_default' \
    '-N+[healpix Nside for quad-building]:n:_default' \
    '-l+[min quad size (arcmin)]:value:_default' \
    '-u+[max quad size (arcmin)]:value:_default' \
    '-S+[sort column]:column:_default' \
    '-f[sort descending (default ascending)]' \
    '-A+[RA column name (default RA)]:name:_default' \
    '-D+[Dec column name (default Dec)]:name:_default' \
    '-B+[cut entries whose sort-column < val]:value:_default' \
    '-K[keep original RA,Dec in tag-along table]' \
    '-U+[healpix Nside for uniformization]:n:_default' \
    '-H+[big-healpix index (default all-sky)]:n:_default' \
    '-s+[big-healpix Nside (default 1)]:n:_default' \
    '-m+[margin in healpixels (default 0)]:n:_default' \
    '-n+[stars per fine healpix cell (default 10)]:n:_default' \
    '-r+[dedup radius (arcsec, default none)]:value:_default' \
    '-j+[positional error (arcsec, default 1)]:value:_default' \
    '-d+[stars per quad (default 4)]:n:_default' \
    '-p+[rounds of quad-building (default 16)]:n:_default' \
    '-R+[max times a star can be reused (default 8)]:n:_default' \
    '-L+[extra passes with relaxed reuse limit]:n:_default' \
    '-E[scan catalog for occupied healpixes]' \
    '-I+[set unique ID of this index]:id:_default' \
    '-M[in-memory (no temp files)]' \
    '-T[do not delete temp files]' \
    '-t+[temp directory (default /tmp)]:dir:_directories' \
    '*-v[verbose (stackable)]' \
    && ret=0

return ret
