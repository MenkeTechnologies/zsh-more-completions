#compdef scil_viz_bundle
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_viz_bundle.html
# Scilpy: visualize tractography bundles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--shape=[streamline render shape]:shape:(line tube)' \
  '--width=[streamline width]:width' \
  '--subsample=[subsample bundles]:n' \
  '--downsample=[downsample streamline points]:n' \
  '--background=[background RGB color]:rgb' \
  '(--random_coloring --uniform_coloring --local_coloring --color_dict --color_from_streamlines --color_from_points)--random_coloring=[random coloring seed]:seed' \
  '(--random_coloring --uniform_coloring --local_coloring --color_dict --color_from_streamlines --color_from_points)--uniform_coloring=[uniform RGB color]:rgb' \
  '(--random_coloring --uniform_coloring --local_coloring --color_dict --color_from_streamlines --color_from_points)--local_coloring[color by local orientation]' \
  '(--random_coloring --uniform_coloring --local_coloring --color_dict --color_from_streamlines --color_from_points)--color_dict=[JSON color dictionary]:file:_files' \
  '(--random_coloring --uniform_coloring --local_coloring --color_dict --color_from_streamlines --color_from_points)--color_from_streamlines=[data_per_streamline key]:key' \
  '(--random_coloring --uniform_coloring --local_coloring --color_dict --color_from_streamlines --color_from_points)--color_from_points=[data_per_point key]:key' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '*:in_bundles:_files' && ret=0

return ret
