#compdef ksql-cli ksql ksqldb-cli
# _ksql-cli — Confluent ksql-cli CLI command-line frontend wrapping the ksqlDB streaming SQL engine for Apache Kafka providing interactive shell-mode SET UNSET DESCRIBE PRINT SHOW LIST EXPLAIN RUN SCRIPT EXIT KEY KEY-FORMAT VALUE-FORMAT EARLIEST LATEST PUSH PULL queries push-stream-output materialized-aggregates (Confluent team, Java); custom argparse
# upstream: https://ksqldb.io/

_ksql-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--output-format=+[fmt]:f:(JSON TABULAR)' \
        '-c+[config file]:file:_files -g "*.properties *.config"' \
        '--config-file=+[file]:file:_files -g "*.properties *.config"' \
        '-f+[command file]:file:_files -g "*.sql *.ksql"' \
        '--command-file=+[file]:file:_files -g "*.sql *.ksql"' \
        '--user=+[user]:str:' \
        '-u+[user]:str:' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--server=+[url]:str:' \
        '--query-row-limit=+[N]:n:' \
        '--query-timeout-millis=+[ms]:n:' \
        '--variable=+[k=v]:str:' \
        '--keep-alive[keep alive]' \
        '--basic-auth-credentials-source=+[s]:s:(URL USER_INFO)' \
        '--auth-server=+[url]:str:' \
        '--auth-method=+[m]:m:(BASIC BEARER)' \
        '--ssl-enabled[enable SSL]' \
        '--ssl-keystore-location=+[file]:file:_files -g "*.jks *.p12"' \
        '--ssl-keystore-password=+[password]:str:' \
        '--ssl-truststore-location=+[file]:file:_files -g "*.jks *.p12"' \
        '--ssl-truststore-password=+[password]:str:' \
        '*:ksql url:'
}

_ksql-cli "$@"
