#compdef imposm
# OpenStreetMap data importer for PostGIS databases

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'import:import OSM data'
      'diff:update imported data from diff files'
      'deploy:deploy production tables from import'
      'revert:revert production tables to previous import'
      'run:run continuous diff import'
    )
    _describe -t commands 'imposm command' commands && ret=0
    ;;
  args)
    _arguments \
      '-mapping[mapping configuration file]:file:_files' \
      '-read[read OSM data file]:file:_files' \
      '-write[write to database]' \
      '-connection[PostGIS connection string]:connstr:' \
      '-srid[target SRID]:srid:' \
      '-dbschema-import[database schema for import]:schema:' \
      '-dbschema-production[database schema for production]:schema:' \
      '-dbschema-backup[database schema for backup]:schema:' \
      '-diff[enable diff support]' \
      '-diffdir[directory for diff files]:dir:_files -/' \
      '-cachedir[directory for cache files]:dir:_files -/' \
      '-overwritecache[overwrite existing cache]' \
      '-limitto[limit import to geometry]:file:_files' \
      '-config[config file]:file:_files' \
      '-log-level[log level]:level:(debug info warn error)' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
