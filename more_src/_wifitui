#compdef wifitui
# Documentation: https://github.com/shazow/wifitui
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wifitui - WiFi terminal UI (NetworkManager/iwd backend)

local curcontext="$curcontext" state line ret=1

local -a _wt_cmds
_wt_cmds=(
  'list:display available wifi networks'
  'show:display details about a specific wifi network'
  'connect:connect to a wifi network'
  'radio:manage wifi radio (on|off|toggle)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--theme=[load a custom color/theme TOML file]:file:_files -g "*.toml"' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'wifitui command' _wt_cmds && ret=0
    ;;
  args)
    case $words[1] in
      show)
        _arguments \
          '--json[output details as JSON]' \
          '1:SSID' && ret=0
        ;;
      connect)
        _arguments '1:SSID' && ret=0
        ;;
      radio)
        _arguments '1:state:(on off toggle)' && ret=0
        ;;
    esac
    ;;
esac

return ret
