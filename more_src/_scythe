#compdef scythe
# Documentation: https://github.com/vsbuffalo/scythe
# bayesian adapter trimmer for sequencing reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --adapter-file)'{-a,--adapter-file}'[adapter sequence FASTA file]:fasta:_files' \
  '(-o --output-file)'{-o,--output-file}'[output file for trimmed sequences]:file:_files' \
  '(-p --prior)'{-p,--prior}'[prior contamination rate]:rate:' \
  '(-q --quality-type)'{-q,--quality-type}'[quality encoding scheme]:scheme:(solexa illumina sanger)' \
  '(-m --matches-file)'{-m,--matches-file}'[output detailed match information]:file:_files' \
  '(-n --min-match)'{-n,--min-match}'[minimum match length]:length:' \
  '(-M --min-keep)'{-M,--min-keep}'[retain only sequences longer than this after trimming]:length:' \
  '--quiet[suppress standard output messages]' \
  '*:input fastq:_files' && ret=0

return ret
