#compdef sphobjinv
# _sphobjinv — Brian Skinn sphobjinv Sphinx objects.inv inventory CLI for converting reading and querying Sphinx intersphinx inventory files (bskinn team, Python); argparse
# upstream: https://github.com/bskinn/sphobjinv

_sphobjinv() {
    local -a sub=(
        'convert:convert inventory between formats'
        'suggest:suggest objects matching query'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sphobjinv subcommand' sub ;;
        args)
            case $words[1] in
                convert) _arguments \
                    '-e[expand uri]' \
                    '--expand[expand uri]' \
                    '-c[contract uri]' \
                    '--contract[contract uri]' \
                    '-u+[url]:str:' \
                    '--url=+[url]:str:' \
                    '1:format:(plain zlib json)' \
                    '*:file:_files -g "*.inv *.txt *.json"' ;;
                suggest) _arguments \
                    '-a[show all results]' \
                    '--all[show all results]' \
                    '-i[case-insensitive]' \
                    '--insensitive[case-insensitive]' \
                    '-s+[score threshold]:n:' \
                    '--score=+[score threshold]:n:' \
                    '-t+[threshold]:n:' \
                    '--thresh=+[threshold]:n:' \
                    '-u+[url]:str:' \
                    '--url=+[url]:str:' \
                    '-l[show longer output]' \
                    '--long[show longer output]' \
                    '-n+[N results]:n:' \
                    '*:inv file query:_files -g "*.inv *.txt *.json"' ;;
            esac
            ;;
    esac
}

_sphobjinv "$@"
