#compdef pkfillnodata
# Documentation: https://pktools.nongnu.org/html/pkfillnodata.html
# interpolate nodata values in raster

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input raster dataset]:file:_files' \
  '(-b --band)'{-b,--band}'[band(s) to process (Default is -1\: process all bands)]:value:' \
  '(-o --output)'{-o,--output}'[Output image file]:file:_files' \
  '(-m --mask)'{-m,--mask}'[Mask raster dataset indicating pixels to be interpolated (zero valued)]:file:_files' \
  '(-d --distance)'{-d,--distance}'[Maximum number of pixels to search in all directions to find values to]:value:' \
  '(-it --iteration)'{-it,--iteration}'[Number of 3x3 smoothing filter passes to run (default 0)]:value:' \
  '*:file:_files' && ret=0

return ret
