#compdef nnslog
# Documentation: https://core.tcl-lang.org/tcllib/doc/trunk/embedded/md/tcllib/files/modules/nns/nns_intro.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Tcllib nameserv logging client — wraps the nameserv connection and
# prints events to stdout. No canonical CLI flags beyond positional log
# arg. STUB.

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:log file:_files' && ret=0

return ret
