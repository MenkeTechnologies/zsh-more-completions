#compdef keda-admission-webhooks keda-webhooks
# _keda-admission-webhooks — KEDA admission webhook server
# upstream: https://github.com/kedacore/keda
# Flags from cmd/webhooks/main.go pflag bindings on tip.

_keda-admission-webhooks() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--profiling-bind-address=[profiling bind host\:port]:host\:port:' \
        '--kube-api-qps=[K8s API QPS]:f:' \
        '--kube-api-burst=[K8s API burst]:n:' \
        '--cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--port=[webhook bind port]:port:' \
        '--cache-miss-to-direct-client=[fall back to direct client on cache miss]:bool:(true false)' \
        '--zap-devel[enable development zap logging]' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_keda-admission-webhooks "$@"
