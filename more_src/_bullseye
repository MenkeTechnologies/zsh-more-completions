#compdef bullseye
# Documentation: https://crux.ms/commands/bullseye.html
# Crux bullseye: assign high-resolution precursor masses to spectra.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--max-persist=[ignore PPIDs persisting longer than this]:time' \
  '--persist-tolerance=[mass tolerance (ppm) across consecutive MS1 scans]:ppm' \
  '--gap-tolerance=[allowed gap size across consecutive MS1 scans]:n' \
  '--scan-tolerance=[number of MS1 scans a PPID must span]:n' \
  '--bullseye-max-mass=[maximum mass threshold (Da) for PPIDs]:mass' \
  '--bullseye-min-mass=[minimum mass threshold (Da) for PPIDs]:mass' \
  '--exact-match=[require exact match to base isotopic peak]:bool:(T F)' \
  '--exact-tolerance=[tolerance (ppm) for exact matching]:ppm' \
  '--retention-tolerance=[RT tolerance for matching PPIDs to MS2]:tol' \
  '--spectrum-format=[output spectra format]:fmt:(ms2 bms2 cms2 mgf)' \
  '--fileroot=[prefix for output filenames]:prefix' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[replace existing files]:bool:(T F)' \
  '--parameter-file=[configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:input:_files' && ret=0

return ret
