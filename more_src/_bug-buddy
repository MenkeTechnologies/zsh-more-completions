#compdef bug-buddy
# Documentation: https://man.archlinux.org/search?q=bug-buddy
# Reference accessed: 2026-05-16

# bug-buddy: legacy GNOME bug reporting tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--include=[include file]:file:_files' \
  '--package=[package]:pkg:' \
  '--package-ver=[package version]:ver:' \
  '--appname=[app name]:name:' \
  '--pid=[crashed process pid]:pid:' \
  '*::bug-buddy args:_files' && ret=0
return ret
