#compdef selenium-cli2 selenium2 selenium-side-runner
# _selenium-cli2 — Software Freedom Conservancy SeleniumHQ selenium-cli2 CLI command-line frontend wrapping the Selenium open-source umbrella project for a range of tools and libraries that enable and support web browser automation written in Java by Jason Huggins ThoughtWorks now Software Freedom Conservancy WebDriver Selenium Server Grid Selenium IDE Selenium WebDriver runs locally and through Sauce Labs BrowserStack server hub node standalone distribute event-bus session-queue session-map router video manager info completion-script print-options Java JVM JAR options driver-version sessions test (Software Freedom Conservancy SeleniumHQ team Jason Huggins, Java); custom argparse
# upstream: https://www.selenium.dev/

_selenium-cli2() {
    local -a sub=(
        'distributor:run as Distributor node'
        'event-bus:run as Event Bus'
        'hub:start a Selenium Hub'
        'info:show server info'
        'node:run as Node'
        'router:run as Router'
        'session-map:run as Session Map'
        'session-queue:run as Session Queue'
        'standalone:run as Standalone'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--bind-host=+[host]:_hosts' \
        '--bind-port=+[port]:n:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--external-url=+[url]:str:' \
        '--max-sessions=+[N]:n:' \
        '--session-timeout=+[sec]:n:' \
        '--session-request-timeout=+[sec]:n:' \
        '--session-retry-interval=+[sec]:n:' \
        '--reject-unsupported-caps[reject unsupported caps]' \
        '--register-cycle=+[sec]:n:' \
        '--register-period=+[sec]:n:' \
        '--heartbeat-period=+[sec]:n:' \
        '--draining[mark as draining]' \
        '--allow-cors[allow CORS]' \
        '--detect-drivers=+[v]:v:(true false)' \
        '--detect-cdp=+[v]:v:(true false)' \
        '--enable-managed-downloads=+[v]:v:(true false)' \
        '--max-managed-downloads-content-length=+[N]:n:' \
        '--node-implementation=+[class]:str:' \
        '--node-status-check-interval=+[sec]:n:' \
        '--driver-implementation=+[name]:str:' \
        '--driver-configuration=+[file]:file:_files -g "*.toml *.json"' \
        '*--driver-configuration=+[file]:file:_files' \
        '--config=+[file]:file:_files -g "*.toml *.json"' \
        '-c+[config]:file:_files -g "*.toml *.json"' \
        '--username=+[name]:_users' \
        '--password=+[password]:str:' \
        '--register-username=+[name]:_users' \
        '--register-password=+[password]:str:' \
        '--tracing=+[v]:v:(true false)' \
        '--log-level=+[l]:l:(SEVERE WARNING INFO CONFIG FINE FINER FINEST ALL)' \
        '--log-file=+[file]:file:_files' \
        '--log-encoding=+[enc]:str:' \
        '--rate-limit=+[N]:n:' \
        '--detect-drivers=+[v]:v:(true false)' \
        '--default-session-timeout=+[sec]:n:' \
        '--healthcheck-interval=+[sec]:n:' \
        '--enable-cdp=+[v]:v:(true false)' \
        '--enable-bidi=+[v]:v:(true false)' \
        '--vnc=+[v]:v:(true false)' \
        '--use-internet=+[v]:v:(true false)' \
        '--video=+[v]:v:(true false)' \
        '--storage-path=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'selenium subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_selenium-cli2 "$@"
