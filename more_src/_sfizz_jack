#compdef sfizz_jack
# _sfizz_jack — SFZ sampler JACK client (sfztools/sfizz)
# upstream: https://github.com/sfztools/sfizz
# Flags from clients/jack_client.cpp (Abseil flags).

_sfizz_jack() {
    local -a args
    args=(
        '(- *)--help[show help]'
        '(- *)--version[show version]'
        '--client_name=[JACK client name]:name:'
        '--oversampling=[internal oversampling factor]:factor:(x1 x2 x4 x8 1x 2x 4x 8x)'
        '--preload_size=[preloaded sample size (bytes)]:bytes:'
        '--num_voices=[max polyphony / number of voices]:n:'
        '--jack_autoconnect[auto-connect audio outputs to system ports]'
        '--state[print the synth state inside the JACK loop]'
        '1:SFZ file:_files -g "*.sfz"'
    )
    _arguments -s $args
}

_sfizz_jack "$@"
