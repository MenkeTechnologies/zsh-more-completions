#compdef evemu-record
# Documentation: https://man.archlinux.org/search?q=evemu-record
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --autorestart)'{-a,--autorestart}'+[auto restart after N seconds idle]:sec:' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '*:device:_files -g "/dev/input/event*"' && ret=0

return ret
