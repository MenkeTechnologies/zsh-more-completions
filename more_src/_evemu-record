#compdef evemu-record
# Documentation: https://manpages.debian.org/testing/evemu-tools/evemu-record.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --autorestart)'{-a,--autorestart}'+[auto restart after N seconds idle]:sec:' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '*:device:_files -g "/dev/input/event*"' && ret=0

return ret
