#compdef mri_label2vol
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_label2vol
# mri_label2vol - convert a label or set of labels into a volume

local ret=1

_arguments -s -S \
  '*--label[label file (may be repeated)]:file:_files' \
  '--annot[annotation file]:file:_files' \
  '--seg[path to segmentation]:file:_files' \
  '--temp[template volume]:file:_files' \
  '--reg[tkregister-style registration matrix file]:file:_files' \
  '--identity[use identity matrix as registration]' \
  '--fillthresh[relative threshold for voxel candidacy]:thresh:' \
  '--proj[project label along surface normal (type start stop delta)]:proj:' \
  '--subject[subject identifier (required with --proj)]:subject:' \
  '--hemi[hemisphere lh or rh (required with --proj)]:hemi:(lh rh)' \
  '--o[output volume file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
