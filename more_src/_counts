#compdef counts

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '--top[show top N results]:count' \
  '--bottom[show bottom N results]:count' \
  '--reverse[reverse sort order]' \
  '--alpha[sort alphabetically]' \
  '--no-sort[do not sort output]' \
  '--delimiter[field delimiter]:delimiter' \
  '--field[field number to count]:field number'
