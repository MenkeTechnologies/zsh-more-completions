#compdef vtctlclient
# _vtctlclient — Vitess vtctld gRPC client (legacy command set)
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtctlclient/main.go on tip.

_vtctlclient() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--server=[vtctld server host\:port]:host\:port:' \
        '--action-timeout=[per-action timeout]:dur:' \
        '--alsologtostderr=[also log to stderr]:bool:(true false)' \
        '-v[verbosity level]:n:' \
        '*: :_files'
}

_vtctlclient "$@"
