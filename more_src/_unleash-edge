#compdef unleash-edge

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'edge:run in edge mode (connects to upstream Unleash)'
  'offline:run in offline mode using a bootstrap file'
  'health:run a health check against a running edge'
  'ready:run a ready check against a running edge'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '(-p --port)'{-p+,--port=}'[server port]:port:' \
  '(-i --interface)'{-i+,--interface=}'[bind interface]:interface:_hosts' \
  '--base-path=[URL base path]:path:' \
  '--tls-enable[enable TLS]' \
  '--tls-server-key=[TLS key file]:file:_files' \
  '--tls-server-cert=[TLS cert file]:file:_files' \
  '--tls-server-port=[TLS server port]:port:' \
  '--redirect-http-to-https[redirect HTTP to HTTPS]' \
  '*--cors-origin=[allowed CORS origin]:origin:' \
  '--cors-allowed-headers=[CORS allowed headers]:headers:' \
  '--cors-max-age=[CORS max age (sec)]:n:' \
  '--cors-exposed-headers=[CORS exposed headers]:headers:' \
  '--cors-methods=[CORS allowed methods]:methods:' \
  '--allow-list=[IP allow list]:list:' \
  '--deny-list=[IP deny list]:list:' \
  '--trust-proxy[trust X-Forwarded-* headers]' \
  '--proxy-trusted-servers=[trusted proxy IPs/CIDRs]:list:' \
  '--instance-id=[instance id]:id:' \
  '--app-name=[application name]:name:' \
  '--disable-all-endpoint[disable /all endpoint]' \
  '--edge-request-timeout=[request timeout]:seconds:' \
  '--edge-keepalive-timeout=[keepalive timeout]:seconds:' \
  '--edge-auth-header=[auth header for edge]:header:' \
  '--upstream-auth-header=[auth header for upstream]:header:' \
  '--token-header=[token header name]:header:' \
  '(-l --log-format)'{-l+,--log-format=}'[log format]:format:(plain json pretty)' \
  '--sentry-dsn=[Sentry DSN]:url:' \
  '--datadog-url=[Datadog URL]:url:' \
  '--otel-collector-url=[OpenTelemetry collector URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'unleash-edge command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (edge)
        _arguments \
          '(-u --upstream-url)'{-u+,--upstream-url=}'[upstream Unleash URL]:url:' \
          '(-b --backup-folder)'{-b+,--backup-folder=}'[backup folder]:dir:_files -/' \
          '(-m --metrics-interval-seconds)'{-m+,--metrics-interval-seconds=}'[metrics interval (s)]:n:' \
          '(-f --features-refresh-interval-seconds)'{-f+,--features-refresh-interval-seconds=}'[feature refresh interval (s)]:n:' \
          '--token-revalidation-interval-seconds=[token revalidation (s)]:n:' \
          '(-t --tokens)*'{-t+,--tokens=}'[client API tokens]:token:' \
          '(-p --pretrusted-tokens)*'{-p+,--pretrusted-tokens=}'[pretrusted tokens]:token:' \
          '(-H --custom-client-headers)*'{-H+,--custom-client-headers=}'[custom client header]:header:' \
          '(-s --skip-ssl-verification)'{-s,--skip-ssl-verification}'[skip SSL verify]' \
          '--pkcs8-client-certificate-file=[client cert PEM]:file:_files' \
          '--pkcs8-client-key-file=[client key PEM]:file:_files' \
          '--pkcs12-identity-file=[PKCS12 identity file]:file:_files' \
          '--pkcs12-passphrase=[PKCS12 passphrase]:pass:' \
          '--pem-cert-file=[PEM cert file]:file:_files' \
          '--upstream-certificate-file=[upstream cert file]:file:_files' \
          '--upstream-request-timeout=[upstream request timeout]:n:' \
          '--upstream-socket-timeout=[upstream socket timeout]:n:' \
          '--redis-url=[Redis URL]:url:' \
          '--redis-mode=[Redis mode]:mode:(single cluster)' \
          '--redis-host=[Redis host]:host:_hosts' \
          '--redis-port=[Redis port]:port:' \
          '--redis-username=[Redis username]:user:' \
          '--redis-password=[Redis password]:pass:' \
          '--redis-secure[Redis TLS]' \
          '--redis-scheme=[Redis scheme]:scheme:(rediss redis)' \
          '--s3-bucket-name=[S3 bucket name]:bucket:' \
          '--client-keepalive-timeout=[client keepalive (s)]:n:' \
          '--prometheus-remote-write-url=[Prometheus remote write URL]:url:' \
          '--prometheus-push-interval=[Prometheus push interval]:n:' \
          '--prometheus-username=[Prometheus username]:user:' \
          '--prometheus-password=[Prometheus password]:pass:' \
          '--prometheus-user-id=[Prometheus user id]:id:' && ret=0 ;;
      (offline)
        _arguments \
          '(-b --bootstrap-file)'{-b+,--bootstrap-file=}'[bootstrap file]:file:_files -g "*.json"' \
          '(-c --client-tokens)*'{-c+,--client-tokens=}'[client tokens]:token:' \
          '(-f --frontend-tokens)*'{-f+,--frontend-tokens=}'[frontend tokens]:token:' \
          '(-r --reload-interval)'{-r+,--reload-interval=}'[reload interval (s)]:n:' && ret=0 ;;
      (health|ready)
        _arguments \
          '(-e --edge-url)'{-e+,--edge-url=}'[edge URL]:url:' \
          '(-c --ca-certificate-file)'{-c+,--ca-certificate-file=}'[CA cert file]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
