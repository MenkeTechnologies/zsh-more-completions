#compdef mmime
# Documentation: https://hexmos.com/freedevtools/man-pages/user-commands/file-management/mmime/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c -r)-c[check mode: validate MIME encoding only]' \
  '(-c -r)-r[raw mode: plain text output]' \
  '-t+[override top-level Content-Type]:content type:' \
  '*:file:_files' && ret=0

return ret
