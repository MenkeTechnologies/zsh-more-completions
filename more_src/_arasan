#compdef arasan arasanx-64 arasanx

# Arasan chess engine: speaks UCI on stdin/stdout; CLI is sparse
local curcontext="$curcontext" ret=1

_arguments -C \
  '-c[set hash table size in MB]:hash MB:' \
  '-H[set persistent hash file path]:file:_files' \
  '-t[number of search threads]:threads:' \
  '--logfile=[write engine log to file]:file:_files' \
  '*:UCI book/EGTB path:_files' && ret=0

return ret
