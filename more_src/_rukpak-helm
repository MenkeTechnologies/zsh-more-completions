#compdef rukpak-helm
# _rukpak-helm — Rukpak Helm provisioner (reconciles helm Bundles/BundleDeployments via go.helm action)
# upstream: https://github.com/operator-framework/rukpak
# Flags from cmd/helm/main.go on tip + controller-runtime/zap.Options.

_rukpak-helm() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[displays rukpak version information]' \
        '--http-bind-address=[address the http bundle-content server binds to]:addr:' \
        '--http-external-address=[external address at which the http server is reachable]:url:_urls' \
        '--bundle-ca-file=[CA file for bundle content servers]:file:_files' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--unpack-cache-dir=[directory used to unpack and cache Bundle contents]:dir:_files -/' \
        '--system-namespace=[namespace for system resources]:ns:' \
        '--leader-elect[enable leader election]' \
        '--storage-dir=[directory used to store Bundle contents]:dir:_files -/' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)'
}

_rukpak-helm "$@"
