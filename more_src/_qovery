#compdef qovery
# _qovery — Qovery qovery DevOps automation platform CLI for cloud-native deployments (Qovery team, Rust); clap-derive
# upstream: https://github.com/Qovery/qovery-cli

_qovery() {
    local -a sub=(
        'auth:login or signup'
        'logout:logout'
        'context:show or change context'
        'demo:create a demo project'
        'env:environment variable subcommands'
        'service:service subcommands'
        'application:application subcommands'
        'container:container subcommands'
        'lifecycle:lifecycle subcommands'
        'cronjob:cronjob subcommands'
        'database:database subcommands'
        'helm:helm chart subcommands'
        'cluster:cluster subcommands'
        'organization:organization subcommands'
        'project:project subcommands'
        'environment:environment subcommands'
        'deploy:deploy a service'
        'cancel:cancel deployment'
        'redeploy:redeploy a service'
        'stop:stop a service'
        'log:show logs'
        'logs:show logs alias'
        'status:show service status'
        'shell:open shell in service'
        'port-forward:port-forward'
        'token:CLI token subcommands'
        'webhook:webhook subcommands'
        'completion:generate completion'
        'version:show version'
        'upgrade:upgrade CLI'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--organization=+[organization]:str:' \
        '--project=+[project]:str:' \
        '--environment=+[environment]:str:' \
        '--service=+[service]:str:' \
        '--no-color[disable color]' \
        '--debug[debug logs]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qovery subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments '1:auth cmd:(login signup browser headless)' ;;
                env) _arguments '1:env cmd:(create update delete list import export alias override)' ;;
                service|application|container|lifecycle|cronjob|database|helm) _arguments '1:cmd:(list logs status deploy stop restart redeploy cancel update describe)' ;;
                cluster) _arguments '1:cluster cmd:(create get list update delete deploy stop logs credentials)' ;;
                organization|project|environment) _arguments '1:cmd:(create get list update delete)' ;;
                token) _arguments '1:token cmd:(create list delete)' ;;
                webhook) _arguments '1:webhook cmd:(create list delete)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_qovery "$@"
