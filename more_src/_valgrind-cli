#compdef valgrind
# _valgrind-cli — Valgrind instrumentation framework (Julian Seward et al, C); memcheck/cachegrind/callgrind/massif/helgrind/drd
# upstream: https://valgrind.org

_valgrind-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--tool+[tool name]:tool:(memcheck cachegrind callgrind massif helgrind drd exp-sgcheck exp-bbv none lackey)' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--trace-children+[follow execve]:bool:(yes no)' \
        '--child-silent-after-fork+[silent children]:bool:(yes no)' \
        '--track-fds+[track fd]:bool:(yes no)' \
        '--time-stamp+[timestamps]:bool:(yes no)' \
        '--log-fd+[log fd]:fd:' \
        '--log-file+[log file]:file:_files' \
        '--log-socket+[log socket]:addr:' \
        '--error-limit+[error limit]:bool:(yes no)' \
        '--error-exitcode+[exit code]:n:' \
        '--exit-on-first-error+[exit first error]:bool:(yes no)' \
        '--show-error-list+[show error list]:bool:(yes no)' \
        '--num-callers+[max callers]:n:' \
        '--gen-suppressions+[gen suppressions]:mode:(yes no all)' \
        '--suppressions+[suppressions file]:file:_files' \
        '--db-attach+[attach debugger]:bool:(yes no)' \
        '--db-command+[debugger command]:cmd:' \
        '--input-fd+[input fd]:fd:' \
        '--max-stackframe+[max stack frame size]:n:' \
        '--main-stacksize+[main stack size]:n:' \
        '--track-origins+[origin tracking]:bool:(yes no)' \
        '--leak-check+[leak check]:mode:(no summary yes full)' \
        '--leak-resolution+[leak res]:res:(low med high)' \
        '--show-leak-kinds+[leak kinds]:kinds:' \
        '--errors-for-leak-kinds+[error kinds]:kinds:' \
        '--show-reachable+[show reachable]:bool:(yes no)' \
        '--xml+[xml output]:bool:(yes no)' \
        '--xml-file+[xml file]:file:_files' \
        '--xml-socket+[xml socket]:addr:' \
        '--xml-user-comment+[xml user comment]:str:' \
        '--smc-check+[smc check]:mode:(none stack all all-non-file)' \
        '*::command:_command_names -e'
}

_valgrind-cli "$@"
