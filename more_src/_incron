#compdef incrond incrontab
# inotify-based cron

local ret=1

if [[ $service == incrontab ]]; then
  _arguments -s -S \
    '-l[list current table]' \
    '-r[remove current table]' \
    '-e[edit current table]' \
    '-t[list supported event types]' \
    '-d[reload daemon]' \
    '-u[specify user]:user:_users' \
    '-f[specify config file]:file:_files' \
    '-h[show help]' \
    '--help[show help]' \
    '--version[show version]' \
    '1:table file:_files' && ret=0
else
  _arguments -s -S \
    '-f[specify config file]:file:_files' \
    '-n[do not fork to background]' \
    '-k[terminate running instance]' \
    '-h[show help]' \
    '--help[show help]' \
    '--version[show version]' && ret=0
fi

return ret
