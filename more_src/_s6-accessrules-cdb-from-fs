#compdef s6-accessrules-cdb-from-fs s6-accessrules-fs-from-cdb
# Documentation: source-direct extraction from upstream skarnet/s6
# src/conn-tools/s6-accessrules-{cdb-from-fs,fs-from-cdb}.c USAGE
# strings + subgetopt_long table extraction (--mode long option).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 accessrules R122b — 2-stem multi-binary harvest of the
# s6 access-rules db conversion utilities. Sister tools to the
# `-i RULESDIR` xor `-x RULESFILE` flag mutex in s6-ipcserver-access
# (R121) and s6-fdholder-daemon/s6-fdholderd (R120). Convert
# bidirectionally between a filesystem-tree access-rules database
# (one file per rule, easy to edit) and a packed CDB file (single
# atomic file, fast to query at server-runtime).

case $service in

  s6-accessrules-cdb-from-fs)
    # Compile a filesystem-tree access-rules database into a packed
    # CDB file. The CDB is what production s6 servers query at
    # connection time via the -x RULESFILE flag.
    _arguments -s -S \
      '(-m --mode)'{-m+,--mode=}'[octal permissions on the output CDB file]:mode (octal):' \
      '1:output CDB file:_files' \
      '2:input rules directory tree:_directories'
    ;;

  s6-accessrules-fs-from-cdb)
    # Expand a packed CDB access-rules file back into a filesystem
    # tree (one file per rule). Useful for inspecting / editing a
    # production CDB. No CLI flags.
    _arguments -s -S \
      '1:output rules directory tree:_directories' \
      '2:input CDB file:_files'
    ;;

esac
