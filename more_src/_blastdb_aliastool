#compdef blastdb_aliastool
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK279684/
# Documentation: https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/LATEST/ (ncbi-blast-2.17.0+-src)
# Reference accessed: 2026-05-27
# Verified: upstream c++/src/app/blastdb/blastdb_aliastool.cpp (BLAST+ 2.17.0)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-gi_file_in=[text file with one GI per line to convert to binary]:file:_files' \
  '-gi_file_out=[output file for converted GI list]:file:_files' \
  '-db=[BLAST database name]:dbname:' \
  '-dbtype=[molecule type stored in BLAST database]:type:(nucl prot)' \
  '-title=[title for BLAST database]:title:' \
  '-gilist=[text or binary GI list to restrict the BLAST database]:file:_files' \
  '-seqidlist=[seq id or accession file to restrict the BLAST database]:file:_files' \
  '-taxidlist=[taxonomy id file to restrict the BLAST database]:file:_files' \
  '-oid_masks=[create alias db with pre-built oid masks]:oid_masks:' \
  '-out=[name of BLAST database alias to be created]:name:' \
  '-dblist=[space-separated list of BLAST database names to aggregate]:dbs:' \
  '-dblist_file=[file with list of BLAST database names to aggregate]:file:_files' \
  '-vdblist=[space-separated list of VDB names to aggregate]:vdbs:' \
  '-vdblist_file=[file with list of VDB names to aggregate]:file:_files' \
  '-num_volumes=[number of volumes to aggregate]:n:' \
  '-seqid_file_in=[seq id file to convert to binary]:file:_files' \
  '-seqid_title=[title for seqid list]:title:' \
  '-seqid_file_out=[output file for converted seqid list]:file:_files' \
  '-seqid_db=[BLAST database for seqidlist]:dbname:' \
  '-seqid_dbtype=[molecule type of seqid BLAST database]:type:(nucl prot)' \
  '-seqid_file_info=[display seqidlist file info]:file:_files' && ret=0

return ret
