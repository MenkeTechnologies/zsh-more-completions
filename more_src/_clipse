#compdef clipse
# Documentation: https://github.com/savedra1/clipse
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[show help]' \
  '-v[show version]' \
  '-a+[add content to clipboard history without copying to system clipboard]:content:' \
  '-c+[copy content to system clipboard]:content:' \
  '-p[print current clipboard content to console]' \
  '-listen[run background listener process]' \
  '--listen-shell[run listener in current terminal for debugging]' \
  '-clear[remove all history except pinned items]' \
  '-clear-all[wipe entire clipboard history]' \
  '-clear-images[remove all images from history]' \
  '-clear-text[remove all text entries]' \
  '-clean[sanitize text entries and remove orphaned images]' \
  '-keep[keep TUI open after selecting an item]' \
  '-kill[terminate existing background processes]' \
  '-pause+[pause clipboard monitoring]:duration:' \
  '-output-all[print entire history to stdout]' \
  '-enable-real-time[enable real-time TUI updates]' && ret=0

return ret
