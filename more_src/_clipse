#compdef clipse

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --add)'{-a,--add}'[add item to clipboard from stdin]' \
  '(-c --copy)'{-c,--copy}'[copy an item]:item' \
  '(-p --paste)'{-p,--paste}'[paste the current clipboard item]' \
  '--clear[clear clipboard history]' \
  '--config-dir=[config directory]:directory:_directories' \
  '--listen[start listening daemon]' \
  '--keep=[number of items to keep]:number' && ret=0

return ret
