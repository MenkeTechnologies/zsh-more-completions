#compdef mason

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'init:initialize mason in the current directory'
      'make:generate code from a brick'
      'new:create a new brick'
      'add:add a brick'
      'remove:remove a brick'
      'list:list installed bricks'
      'get:get all bricks'
      'login:log in to brickhub.dev'
      'logout:log out of brickhub.dev'
      'publish:publish a brick to brickhub.dev'
      'search:search published bricks'
      'update:update mason'
      'bundle:create a bundle from a brick'
      'unbundle:generate a brick from a bundle'
    )
    _describe -t commands 'mason command' commands && ret=0
    ;;
  args)
    case $line[1] in
      make)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory]:dir:_directories' \
          '--on-conflict[conflict resolution strategy]:strategy:(prompt skip overwrite append)' \
          '--set-exit-if-changed[exit with error if files changed]' \
          '1:brick name:' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--hooks[generate hooks]' \
          '1:brick name:' && ret=0
        ;;
      add|remove)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:brick name:' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
