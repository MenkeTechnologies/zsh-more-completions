#compdef rr
# Documentation: https://man.archlinux.org/search?q=rr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'record:record an execution'
  'replay:replay a recorded execution'
  'pack:pack a recording (self-contained)'
  'rerun:re-run replay deterministically'
  'ps:list traces in trace dir'
  'sources:list source files in trace'
  'help:show help on a command'
  'trace-info:print trace metadata'
  'dump:dump events in trace'
  'cpufeatures:show CPU features used'
  'redirect:redirect stdio'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*--check-cached-mmaps[check cached mmaps]' \
  '*--cpu-unbound[no CPU binding]' \
  '*--disable-cpuid-features=[disable cpuid features]:f:' \
  '*--dump-syscalls=[dump syscalls]:f:_files' \
  '*--mark-stdio[mark stdio]' \
  '*--microarch=[microarch]:m:' \
  '*--non-interactive[non-interactive]' \
  '*--pid-namespace[use pid namespace]' \
  '*--resource-path=[resource path]:dir:_files -/' \
  '*--suppress-environment-warnings[suppress env warnings]' \
  '*--syscall-buffer-size=[syscall buf MB]:mb:' \
  '*--ttl-mb=[ttl mb]:mb:' \
  '*-A[bind to one CPU]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rr command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (record)
        _arguments \
          '(-h --help)'{-h,--help}'[help]' \
          '(-b --force-syscall-buffer)'{-b,--force-syscall-buffer}'[force syscall buf]' \
          '(-n --no-syscall-buffer)'{-n,--no-syscall-buffer}'[no syscall buf]' \
          '(-c --num-cpu-ticks)'{-c+,--num-cpu-ticks=}'[ticks per buf]:n:' \
          '(-i --ignore-signal)*'{-i+,--ignore-signal=}'[ignore signal]:sig:' \
          '(-u --cpu-unbound)'{-u,--cpu-unbound}'[CPU unbound]' \
          '(--scarce-fds)--scarce-fds[scarce fds]' \
          '(-w --wait)'{-w,--wait}'[wait for child to exit]' \
          '(-S --setuid-sudo)'{-S,--setuid-sudo}'[setuid sudo]' \
          '(--continue-through-signal)*--continue-through-signal=[continue through]:sig:' \
          '(--print-trace-dir)*--print-trace-dir=[print trace dir]:n:(0 1 2)' \
          '(-o --output-trace-dir)'{-o+,--output-trace-dir=}'[trace dir]:dir:_files -/' \
          '(-h --chaos)--chaos[chaos mode]' \
          '*: :_command_names -e' && ret=0 ;;
      (replay)
        _arguments \
          '(-h --help)'{-h,--help}'[help]' \
          '(-a --autopilot)'{-a,--autopilot}'[run to completion]' \
          '(-d --debugger)'{-d+,--debugger=}'[debugger]:cmd:_command_names -e' \
          '(-g --goto)'{-g+,--goto=}'[goto event]:n:' \
          '(-p --onprocess)'{-p+,--onprocess=}'[on process]:p:' \
          '(-x --gdb-x)'{-x+,--gdb-x=}'[gdb command file]:file:_files' \
          '(--stats)*--stats=[print stats]:n:' \
          '(--share-private-mappings)--share-private-mappings[share priv mappings]' \
          '(-f --onfork)'{-f+,--onfork=}'[on fork]:p:' \
          '(-h --dont-launch-debugger)'{-h,--dont-launch-debugger}'[no debugger]' \
          '(--keep-listening)*--keep-listening[keep listening]' \
          '*: :_files -/' && ret=0 ;;
      (pack)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (ps|trace-info|dump)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
