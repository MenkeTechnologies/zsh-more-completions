#compdef gum

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'choose:choose from options'
  'confirm:confirm yes/no'
  'file:file picker'
  'filter:filter list with fuzzy match'
  'format:format text/markdown/code'
  'input:single-line input'
  'join:join text horizontally/vertically'
  'pager:scroll content'
  'spin:show spinner while running command'
  'style:apply styles to text'
  'table:table input/picker'
  'write:multi-line input'
  'log:log structured messages'
  'version-check:check for new version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'gum subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (choose)
        _arguments -s \
          '--ordered[preserve order]' \
          '--height=[height]:n:' \
          '--cursor=[cursor]:str:' \
          '--header=[header]:header:' \
          '--cursor-prefix=[prefix]:str:' \
          '--selected-prefix=[prefix]:str:' \
          '--unselected-prefix=[prefix]:str:' \
          '--selected=[preselected]:list:' \
          '--input-delimiter=[delim]:str:' \
          '--output-delimiter=[delim]:str:' \
          '--label-delimiter=[delim]:str:' \
          '--limit=[n]:n:' \
          '--no-limit[no limit]' \
          '--select-if-one[auto-select if one]' \
          '--timeout=[duration]:duration:' \
          '--strip-ansi[strip ANSI]' \
          '*:choice:' && ret=0 ;;
      (confirm)
        _arguments -s \
          '--default[default yes]' \
          '--show-output[show output]' \
          '--affirmative=[yes label]:label:' \
          '--negative=[no label]:label:' \
          '--timeout=[duration]:duration:' \
          '*:prompt:' && ret=0 ;;
      (file)
        _arguments -s \
          '(-c --cursor)'{-c,--cursor}'=[cursor]:str:' \
          '(-a --all)'{-a,--all}'[show hidden]' \
          '(-p --permissions)'{-p,--permissions}'[show permissions]' \
          '(-s --size)'{-s,--size}'[show size]' \
          '--file[allow files]' \
          '--directory[allow dirs]' \
          '--header=[header]:header:' \
          '--height=[height]:n:' \
          '--timeout=[duration]:duration:' \
          '*:path:_files' && ret=0 ;;
      (filter)
        _arguments -s \
          '--indicator=[indicator]:str:' \
          '--selected=[preselected]:list:' \
          '--selected-prefix=[prefix]:str:' \
          '--unselected-prefix=[prefix]:str:' \
          '--header=[header]:header:' \
          '--placeholder=[placeholder]:str:' \
          '--prompt=[prompt]:str:' \
          '--width=[width]:n:' \
          '--height=[height]:n:' \
          '--value=[initial value]:str:' \
          '--reverse[reverse]' \
          '--fuzzy[fuzzy]' \
          '--no-fuzzy[no fuzzy]' \
          '--fuzzy-sort[sort by score]' \
          '--no-fuzzy-sort[no fuzzy sort]' \
          '--limit=[n]:n:' \
          '--no-limit[no limit]' \
          '--select-if-one[auto-select if one]' \
          '--strict[strict]' \
          '--no-strict[no strict]' \
          '--timeout=[duration]:duration:' \
          '--strip-ansi[strip ANSI]' \
          '--input-delimiter=[delim]:str:' \
          '--output-delimiter=[delim]:str:' && ret=0 ;;
      (format)
        _arguments -s \
          '--theme=[theme]:theme:' \
          '(-l --language)'{-l,--language}'=[language]:lang:' \
          '--strip-ansi[strip ANSI]' \
          '(-t --type)'{-t,--type}'=[type]:type:(markdown template code emoji)' \
          '*:template:' && ret=0 ;;
      (input)
        _arguments -s \
          '--placeholder=[placeholder]:str:' \
          '--prompt=[prompt]:str:' \
          '--cursor.mode=[cursor mode]:mode:(blink static hide)' \
          '--value=[initial value]:str:' \
          '--char-limit=[limit]:n:' \
          '--width=[width]:n:' \
          '--password[password mode]' \
          '--header=[header]:header:' \
          '--timeout=[duration]:duration:' && ret=0 ;;
      (join)
        _arguments -s \
          '--align=[alignment]:align:(left center right top middle bottom)' \
          '--horizontal[horizontal]' \
          '--vertical[vertical]' \
          '*:text:' && ret=0 ;;
      (pager)
        _arguments -s \
          '--show-line-numbers[line numbers]' \
          '--soft-wrap[soft wrap]' \
          '--no-soft-wrap[no soft wrap]' \
          '--timeout=[duration]:duration:' \
          '*:content:' && ret=0 ;;
      (spin)
        _arguments -s \
          '--show-output[show output]' \
          '--show-error[show error]' \
          '--show-stdout[show stdout]' \
          '--show-stderr[show stderr]' \
          '(-s --spinner)'{-s,--spinner}'=[spinner]:spinner:(line dot minidot jump pulse points globe moon monkey meter hamburger)' \
          '--title=[title]:title:' \
          '(-a --align)'{-a,--align}'=[align]:align:(left center right)' \
          '--timeout=[duration]:duration:' \
          '*:command:_command_names' && ret=0 ;;
      (style)
        _arguments -s \
          '--trim[trim]' \
          '--strip-ansi[strip ANSI]' \
          '--foreground=[color]:color:' \
          '--background=[color]:color:' \
          '--border=[border]:border:(none normal rounded thick double hidden)' \
          '--align=[align]:align:' \
          '--width=[width]:n:' \
          '--height=[height]:n:' \
          '--margin=[margin]:m:' \
          '--padding=[padding]:p:' \
          '--bold[bold]' \
          '--faint[faint]' \
          '--italic[italic]' \
          '--strikethrough[strikethrough]' \
          '--underline[underline]' \
          '*:text:' && ret=0 ;;
      (table)
        _arguments -s \
          '(-s --separator)'{-s,--separator}'=[separator]:char:' \
          '(-c --columns)'{-c,--columns}'=[columns]:list:' \
          '(-w --widths)'{-w,--widths}'=[widths]:list:' \
          '--height=[height]:n:' \
          '(-p --print)'{-p,--print}'[print]' \
          '(-f --file)'{-f,--file}'=[CSV file]:file:_files' \
          '(-b --border)'{-b,--border}'=[border]:border:(none rounded normal thick double hidden)' \
          '--hide-count[hide count]' \
          '--lazy-quotes[lazy quotes]' \
          '--fields-per-record=[n]:n:' \
          '(-r --return-column)'{-r,--return-column}'=[col]:n:' \
          '--timeout=[duration]:duration:' && ret=0 ;;
      (write)
        _arguments -s \
          '--width=[width]:n:' \
          '--height=[height]:n:' \
          '--header=[header]:header:' \
          '--placeholder=[placeholder]:str:' \
          '--prompt=[prompt]:str:' \
          '--show-cursor-line[show cursor line]' \
          '--show-line-numbers[line numbers]' \
          '--value=[initial]:str:' \
          '--char-limit=[n]:n:' \
          '--max-lines=[n]:n:' \
          '--cursor.mode=[cursor]:mode:(blink static hide)' \
          '--timeout=[duration]:duration:' \
          '--strip-ansi[strip ANSI]' && ret=0 ;;
      (log)
        _arguments -s \
          '(-o --file)'{-o,--file}'=[log file]:file:_files' \
          '(-f --format)'{-f,--format}'[printf format]' \
          '--formatter=[formatter]:fmt:(text json logfmt)' \
          '(-l --level)'{-l,--level}'=[level]:level:(none debug info warn error fatal)' \
          '--prefix=[prefix]:prefix:' \
          '(-s --structured)'{-s,--structured}'[structured]' \
          '(-t --time)'{-t,--time}'=[time format]:fmt:(kitchen layout ansic unixdate rubydate rfc822 rfc822z rfc850 rfc1123 rfc1123z rfc3339 rfc3339nano stamp stampmilli stampmicro stampnano datetime dateonly timeonly)' \
          '--min-level=[min level]:level:(none debug info warn error fatal)' \
          '*:text:' && ret=0 ;;
    esac
    ;;
esac

return ret
