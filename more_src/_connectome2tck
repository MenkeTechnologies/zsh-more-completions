#compdef connectome2tck
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/connectome2tck.html
# Source: MRtrix3/mrtrix3 cmd/connectome2tck.cpp — extract streamlines per connectome edge (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-nodes+[only select tracks involving these comma-separated node IDs]:nodes:_default' \
    '-exclusive[only select tracks exclusive to nodes of interest]' \
    '-files+[grouping mode for output streamlines]:mode:(per_edge per_node single)' \
    '-exemplars+[generate mean connection exemplar per edge]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-keep_unassigned[keep streamlines not assigned to any node]' \
    '-keep_self[output streamlines that connect to the same node at both ends]' \
    '-tck_weights_in+[input streamline weight text file]:file:_files -g "*.txt"' \
    '-prefix_tck_weights_out+[prefix for output streamline weight files]:prefix:_default' \
    '1:tracks_in:_files -g "*.{tck,trk}"' \
    '2:assignments_in:_files -g "*.txt"' \
    '3:prefix_out:_default' \
    && ret=0

return ret
