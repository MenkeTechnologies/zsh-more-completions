#compdef orblcd
# Documentation: https://github.com/orbcode/orbuculum
# orbuculum orblcd — host-side LCD emulator rendering display data from ITM channels

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --channel)'{-c,--channel}'=[first channel in pair containing display data]:channel:' \
  '(-f --input-file)'{-f,--input-file}'=[take input from specified file]:file:_files' \
  '(-n --itm-sync)'{-n,--itm-sync}'[enforce sync requirement for ITM]' \
  '(-s --server)'{-s,--server}'=[server:port to use]:server:' \
  '(-S --sbcolour)'{-S,--sbcolour}'=[colour for single-bit renders]:colour:' \
  '(-t --tag)'{-t,--tag}'=[decode specified tag (normally 1)]:tag:' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2 3)' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-z --size)'{-z,--size}'=[set relative output window size]:scale:' && ret=0

return ret
