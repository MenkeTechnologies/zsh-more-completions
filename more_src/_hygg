#compdef hygg
# Documentation: https://github.com/kruseio/hygg
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hygg — minimalistic Vim-like TUI document reader (PDF/EPUB/DOCX via pandoc)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--ocr=[enable OCR for scanned documents]:bool:(true false)' \
  '*:file:_files' && return 0
