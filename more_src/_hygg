#compdef hygg
# Documentation: https://man.archlinux.org/search?q=hygg
# Reference accessed: 2026-05-16

# https://github.com/kruseio/hygg — terminal reading pipeline (PDF/EPUB → text UI)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
