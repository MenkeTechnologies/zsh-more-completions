#compdef mob_recon
# mob_recon — MOB-suite plasmid reconstruction from draft genome assemblies

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '(-i --infile)'{-i,--infile}'[input assembly FASTA file]:input file:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory]:output dir:_files -/' \
  '(-n --num_threads)'{-n,--num_threads}'[number of threads]:threads' \
  '(-f --force)'{-f,--force}'[force overwrite of output directory]' \
  '--run_typer[run MOB-typer on reconstructed plasmids]' \
  '--debug[enable debug logging]' \
  '(-d --database)'{-d,--database}'[path to MOB-suite database]:database dir:_files -/' \
  '--unicycler_contigs[input is from Unicycler with contig graph info]' \
  '--primary_cluster_dist=[primary cluster distance threshold]:distance' \
  '--secondary_cluster_dist=[secondary cluster distance threshold]:distance' \
  '--filter_db=[path to filter database]:filter db:_files' \
  && ret=0

return ret
