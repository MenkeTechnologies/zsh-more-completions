#compdef tenable-cli tenable t.io-cli
# _tenable-cli — Tenable tenable-cli CLI command-line frontend wrapping the Tenable Tenable.io Tenable.sc formerly SecurityCenter Nessus Pro Tenable.cs Cloud Security Tenable.ot Operational Technology Tenable.ad Active Directory Lumin vulnerability management exposure management platform CLI providing login logout whoami scan policy asset vulnerability tag access-group user role agent scanner network credential plugin remediation-projects compliance report export attachment workbench (Tenable Inc team, Python); custom argparse
# upstream: https://www.tenable.com/

_tenable-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'scan:scan operations'
        'policy:policy operations'
        'asset:asset operations'
        'vulnerability:vulnerability operations'
        'tag:tag operations'
        'access-group:access group operations'
        'user:user operations'
        'role:role operations'
        'agent:agent operations'
        'scanner:scanner operations'
        'network:network operations'
        'credential:credential operations'
        'plugin:plugin operations'
        'remediation-project:remediation project ops'
        'compliance:compliance operations'
        'report:report operations'
        'export:export operations'
        'attachment:attachment operations'
        'workbench:workbench operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-key=+[key]:str:' \
        '--secret-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu au ap fed-us)' \
        '-c+[config file]:file:_files -g "*.ini *.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.ini *.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table csv nessus html)' \
        '--output=+[format]:f:(json yaml table csv nessus html)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tenable subcommand' sub ;;
        args)
            case $words[1] in
                scan|policy|asset|vulnerability|tag|access-group|user|role|agent|scanner|network|credential|plugin|remediation-project|compliance|report|export|attachment) _arguments '1:op:(list get create update delete launch pause resume stop schedule download)' '*:id:' ;;
                workbench) _arguments '1:op:(assets vulnerabilities filters)' '*:arg:' ;;
            esac
            ;;
    esac
}

_tenable-cli "$@"
