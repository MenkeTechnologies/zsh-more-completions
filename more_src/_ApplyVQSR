#compdef ApplyVQSR
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/vqsr/ApplyVQSR.java
# GATK4: apply a score cutoff to filter variants based on a recalibration table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'[input VCF file]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[output filtered and recalibrated VCF]:file:_files' \
  '--recal-file[input recal file used by ApplyVQSR]:file:_files' \
  '--tranches-file[input tranches file describing where to cut the data]:file:_files' \
  '(-mode --mode)'{-mode,--mode}'[recalibration mode]:mode:(SNP INDEL BOTH)' \
  '(-ts-filter-level --truth-sensitivity-filter-level)'{-ts-filter-level,--truth-sensitivity-filter-level}'[truth sensitivity level at which to start filtering]:level:' \
  '--lod-score-cutoff[VQSLOD score below which to start filtering]:score:' \
  '(-AS --use-allele-specific-annotations)'{-AS,--use-allele-specific-annotations}'[use allele-specific recalibration]' \
  '--ignore-filter[apply recalibration to variants marked by this filter name]:name:' \
  '--ignore-all-filters[ignore all input filters]' \
  '--exclude-filtered[do not output filtered loci]' \
  '*:options:_files' && ret=0

return ret
