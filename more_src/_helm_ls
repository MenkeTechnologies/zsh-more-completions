#compdef helm_ls

# Zsh completion for helm_ls (mrjosh/helm-ls, cobra)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'serve:start LSP on stdio'
      'lint:lint a Helm chart directory or file'
      'version:print build metadata'
    )
    _describe -t commands 'helm_ls command' commands && ret=0
    ;;
  args)
    case $words[1] in
      serve)
        _arguments -s -S \
          '--stdio[use stdio transport]' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '*:chart path or directory:_files -/' && ret=0
        ;;
      version) ;;
    esac
    ;;
esac

return ret
