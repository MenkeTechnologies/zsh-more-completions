#compdef gprbuild

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-aP+[project search path]:dir:_files -/' \
  '-b[bind only]' \
  '-c[compile only]' \
  '-cs[compile sources only]' \
  '-d[show progress]' \
  '-eL[follow symbolic links]' \
  '-f[force]' \
  '-F[full path errors]' \
  '-h[help]' \
  '-j+[parallel jobs]:n:' \
  '-k[keep going on errors]' \
  '-l[link only]' \
  '-m[minimum recompilation]' \
  '-m2[generate hash for sources]' \
  '-n[do nothing]' \
  '-o+[output executable]:file:_files' \
  '-p[create missing dirs]' \
  '-P+[project file]:file:_files -g "*.gpr"' \
  '-q[quiet]' \
  '-r[recursive build]' \
  '-R[no run after build]' \
  '-s[recompile if compile switches changed]' \
  '-u[unique compilation]' \
  '-U[unique build]' \
  '-v[verbose]' \
  '-vP+[project verbosity]:level:(0 1 2)' \
  '-w[warn about output files]' \
  '-x[disable required source check]' \
  '-X+[scenario var]:var=val:' \
  '--no-indirect-imports[no indirect imports]' \
  '--no-object-check[no object check]' \
  '--no-split-units[no split units]' \
  '--restricted-to-languages=+[only these languages]:langs:' \
  '--unchecked-shared-lib-imports[unchecked shared lib imports]' \
  '--target=+[target]:target:' \
  '--RTS=+[Ada runtime]:rts:' \
  '--db=+[knowledge base file]:file:_files' \
  '--db-[ignore default knowledge base]' \
  '--config=+[config file]:file:_files' \
  '--autoconf=+[auto-generated config file]:file:_files' \
  '--single-compile-per-obj-dir[single compile per object dir]' \
  '--build-script=+[build script file]:file:_files' \
  '--complete-output[complete output]' \
  '--no-complete-output[no complete output]' \
  '--no-sal-binding[no SAL binding]' \
  '*:source:_files' && ret=0

return ret
