#compdef blat
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# BLAST-like alignment tool

local ret=1

_arguments -s -S \
  '-t=[database sequence type]:type:(dna prot dnax)' \
  '-q=[query type]:type:(dna rna prot dnax rnax)' \
  '-prot[shorthand for target and query as protein]' \
  '-tileSize=[match trigger size]:n' \
  '-stepSize=[spacing between tiles]:n' \
  '-minMatch=[number of tile matches required]:n' \
  '-minScore=[minimum alignment score (default 30)]:n' \
  '-minIdentity=[minimum percent identity]:n' \
  '-maxGap=[maximum gap between tiles (default 2)]:n' \
  '-oneOff=[allow one mismatch in tile if set to 1]:n' \
  '-ooc=[load overused tile file for speed]:ooc file:_files -g "*.ooc"' \
  '-repMatch=[repetition threshold before marking tiles overused]:n' \
  '-mask=[mask repeats]:type:(lower upper out)' \
  '-qMask=[apply masking to query sequence]:type:(lower upper out)' \
  '-noSimpRepMask[suppress simple repeat masking]' \
  '-out=[output format]:type:(psl pslx axt maf blast blast8 blast9 wublast sim4 pslx)' \
  '-noHead[omit PSL header]' \
  '-dots=[print progress dot every N sequences]:n' \
  '-trimT[remove leading poly-T sequences]' \
  '-trimHardA[remove poly-A tail from query size]' \
  '-fastMap[fast DNA-to-DNA remapping mode]' \
  '1:database:_files -g "*.(fa|fasta|nib|2bit)"' \
  '2:query:_files -g "*.(fa|fasta|nib|2bit)"' \
  '3:output psl:_files' && ret=0

return ret
