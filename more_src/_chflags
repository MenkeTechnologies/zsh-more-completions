#compdef chflags
# _chflags — OpenBSD chflags (set file flags from chmod(2); flags include arch/dump/sappnd/schg/uappnd/uchg and the no/un prefixes; -R recurses; -H/-L/-P set symlink traversal mode)
# upstream: https://github.com/openbsd/src (bin/chmod)
# Flags from bin/chmod/chflags.1 on tip.

_chflags() {
    _arguments \
        '-h[change flags of symlink itself]' \
        '-R[recurse]' \
        '(-L -P)-H[follow symlinks only on cmdline (with -R)]' \
        '(-H -P)-L[follow all symlinks (with -R)]' \
        '(-H -L)-P[no symlink follow (default with -R)]' \
        '1:flags:(arch noarch dump nodump sappnd nosappnd schg noschg sunlnk nosunlnk uappnd nouappnd uchg nouchg uunlnk nouunlnk)' \
        '*:file:_files'
}

_chflags "$@"
