#compdef CollectHsMetrics
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/analysis/directed/CollectHsMetrics.java
# Picard: collect hybrid-selection (capture) metrics from a SAM/BAM/CRAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[aligned SAM/BAM/CRAM file]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '*'{-BI,--BAIT_INTERVALS}'=[interval list of bait locations]:file:_files' \
  '(-N --BAIT_SET_NAME)'{-N,--BAIT_SET_NAME}'=[bait set name]:name:' \
  '*'{-TI,--TARGET_INTERVALS}'=[interval list of target locations]:file:_files' \
  '--PER_TARGET_COVERAGE=[per-target coverage output file]:file:_files' \
  '--PER_BASE_COVERAGE=[per-base coverage output file]:file:_files' \
  '--NEAR_DISTANCE=[max distance for near-probe classification]:n:' \
  '--MINIMUM_MAPPING_QUALITY=[min mapping quality to contribute coverage]:n:' \
  '(-Q --MINIMUM_BASE_QUALITY)'{-Q,--MINIMUM_BASE_QUALITY}'=[min base quality to contribute coverage]:n:' \
  '--CLIP_OVERLAPPING_READS=[clip overlapping reads]:b:(true false)' \
  '--INCLUDE_INDELS=[count inserted/deleted bases as on-target]:b:(true false)' \
  '--COVERAGE_CAP=[max coverage for sensitivity calculations]:n:' \
  '--SAMPLE_SIZE=[sample size for het sensitivity sampling]:n:' \
  '(-LEVEL --METRIC_ACCUMULATION_LEVEL)'{-LEVEL,--METRIC_ACCUMULATION_LEVEL}'=[metric accumulation level]:lvl:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
