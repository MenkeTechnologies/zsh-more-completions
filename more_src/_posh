#compdef posh
# Documentation: https://man.archlinux.org/search?q=posh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[execute command]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-s[read from stdin]' \
  '-o+[set option]:option:(allexport errexit ignoreeof monitor noclobber noexec noglob nolog notify nounset verbose xtrace)' \
  '+o+[unset option]:option:' \
  '-a[export all variables]' \
  '-e[exit on error]' \
  '-f[disable globbing]' \
  '-h[hash commands]' \
  '-m[enable job control]' \
  '-n[read commands without executing]' \
  '-u[error on unset variables]' \
  '-v[print input lines as read]' \
  '-x[print commands before execution]' \
  '*:script:_files' && ret=0

return ret
