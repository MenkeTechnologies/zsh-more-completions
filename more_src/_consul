#compdef consul

# Zsh completion for HashiCorp Consul

local curcontext="$curcontext" state line ret=1

local -a consul_commands
consul_commands=(
  'acl:interact with the ACL system'
  'agent:runs a Consul agent'
  'catalog:interact with the catalog'
  'config:interact with Consul config entries'
  'connect:interact with Consul Connect'
  'debug:record debugging information'
  'event:fire a new event'
  'exec:execute a command on Consul nodes'
  'force-leave:force a member into the left state'
  'info:provides debugging information'
  'intention:interact with Connect service intentions'
  'join:tell Consul agent to join cluster'
  'keygen:generates a new encryption key'
  'keyring:manages gossip layer encryption keys'
  'kv:interact with the key-value store'
  'leave:gracefully leave the Consul cluster'
  'lock:execute a command holding a lock'
  'login:login to Consul using an auth method'
  'logout:destroy a Consul token created with login'
  'maint:controls node or service maintenance mode'
  'members:lists the members of a Consul cluster'
  'monitor:stream logs from a Consul agent'
  'operator:provides cluster-level tools for operators'
  'peering:interact with cluster peering'
  'reload:triggers the agent to reload configuration files'
  'resource:interact with Consul resources'
  'rtt:estimates network round trip time'
  'services:interact with services'
  'snapshot:saves, restores and inspects snapshots'
  'tls:builtin helpers for creating CAs and certificates'
  'troubleshoot:provides tools for troubleshooting Consul'
  'validate:validate config files'
  'version:prints the Consul version'
  'watch:watch for changes in Consul'
)

local -a consul_global_flags
consul_global_flags=(
  '-http-addr=[address of the Consul agent]:address:_urls'
  '-datacenter=[name of the datacenter to query]:datacenter:'
  '-stale[permit any Consul server to service the request]'
  '-token=[ACL token to use]:token:'
  '-token-file=[path to a file containing the ACL token]:token file:_files'
  '-ca-file=[path to a CA file]:ca file:_files'
  '-ca-path=[path to a CA directory]:ca path:_directories'
  '-client-cert=[path to a client cert file]:client cert:_files'
  '-client-key=[path to a client key file]:client key:_files'
  '-tls-server-name=[server name to use for SNI]:server name:'
)

_arguments -s -S \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '1:command:_describe -t commands command consul_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      agent)
        _arguments -s -S \
          '-advertise=[sets the advertise address]:address:' \
          '-advertise-wan=[sets the WAN advertise address]:address:' \
          '-allow-write-http-from=[allows write endpoint from these networks]:cidr:' \
          '-bind=[sets the bind address]:address:' \
          '-bootstrap[sets server to bootstrap mode]' \
          '-bootstrap-expect=[sets server to expect bootstrap mode]:number:' \
          '-check_output_max_size=[max size of a check output]:size:' \
          '-client=[sets the client address]:address:' \
          '-config-dir=[path to a configuration directory]:directory:_directories' \
          '-config-file=[path to a configuration file]:file:_files' \
          '-config-format=[config files are in this format]:format:(json hcl)' \
          '-data-dir=[path to a data directory]:directory:_directories' \
          '-datacenter=[datacenter of the agent]:datacenter:' \
          '-dev[starts the agent in development mode]' \
          '-disable-host-node-id[disable using hostname as the node ID]' \
          '-dns-port=[DNS port to listen on]:port:' \
          '-domain=[domain to use for DNS interface]:domain:' \
          '-enable-local-script-checks[enable health checks using local scripts]' \
          '-enable-script-checks[enable health checks using scripts]' \
          '-encrypt=[provides the gossip encryption key]:key:' \
          '-grpc-port=[gRPC port to listen on]:port:' \
          '-hcl=[HCL configuration to add]:hcl:' \
          '-http-port=[HTTP port to listen on]:port:' \
          '-join=[address of an agent to join]:address:' \
          '-log-file=[path to the log file]:log file:_files' \
          '-log-json[output logs in JSON format]' \
          '-log-level=[log level]:level:(trace debug info warn error)' \
          '-log-rotate-bytes=[max bytes before log rotation]:bytes:' \
          '-log-rotate-duration=[time before log rotation]:duration:' \
          '-log-rotate-max-files=[max number of log files]:number:' \
          '-node=[name of this node]:node:' \
          '-node-id=[unique ID for this node]:id:' \
          '-node-meta=[metadata key/value pairs]:key=value:' \
          '-non-voting-server[deprecated: use -read-replica instead]' \
          '-pid-file=[path for the PID file]:pid file:_files' \
          '-primary-gateway=[address of a mesh gateway in the primary DC]:address:' \
          '-protocol=[sets the protocol version]:version:' \
          '-raft-protocol=[sets the raft protocol version]:version:(1 2 3)' \
          '-read-replica[run server as a non-voting read replica]' \
          '-recursor=[address of a DNS recursor]:address:' \
          '-rejoin[ignores a previous leave and attempts to rejoin]' \
          '-retry-interval=[time between join attempts]:interval:' \
          '-retry-interval-wan=[time between WAN join attempts]:interval:' \
          '-retry-join=[address of an agent to join with retries]:address:' \
          '-retry-join-wan=[address of an agent to WAN join with retries]:address:' \
          '-retry-max=[max join attempts]:number:' \
          '-retry-max-wan=[max WAN join attempts]:number:' \
          '-serf-lan-bind=[address to bind Serf LAN]:address:' \
          '-serf-lan-port=[Serf LAN port]:port:' \
          '-serf-wan-bind=[address to bind Serf WAN]:address:' \
          '-serf-wan-port=[Serf WAN port]:port:' \
          '-server[run in server mode]' \
          '-server-port=[server RPC port]:port:' \
          '-ui[enable the built-in web UI]' \
          '-ui-content-path=[HTTP path the web UI is served at]:path:' \
          '-ui-dir=[path to the web UI resources directory]:directory:_directories' && ret=0
        ;;
      kv)
        local -a kv_commands
        kv_commands=(
          'delete:removes data from the KV store'
          'export:exports a tree from the KV store as JSON'
          'get:retrieves or lists data from the KV store'
          'import:imports a tree stored as JSON to the KV store'
          'put:sets or updates data in the KV store'
        )
        _arguments -s -S \
          '1:kv command:_describe -t commands command kv_commands' \
          '*:args:' && ret=0
        ;;
      acl)
        local -a acl_commands
        acl_commands=(
          'auth-method:manage ACL auth methods'
          'binding-rule:manage ACL binding rules'
          'bootstrap:bootstrap the ACL system'
          'policy:manage ACL policies'
          'role:manage ACL roles'
          'set-agent-token:assign tokens for the agents use'
          'token:manage ACL tokens'
          'translate-rules:translate legacy rule syntax'
        )
        _arguments -s -S \
          '1:acl command:_describe -t commands command acl_commands' \
          '*:args:' && ret=0
        ;;
      catalog)
        local -a catalog_commands
        catalog_commands=(
          'datacenters:list known datacenters'
          'nodes:list all known nodes'
          'services:list all known services'
        )
        _arguments -s -S \
          '1:catalog command:_describe -t commands command catalog_commands' \
          '*:args:' && ret=0
        ;;
      config)
        local -a config_commands
        config_commands=(
          'delete:delete a config entry'
          'list:list config entries'
          'read:read a config entry'
          'write:create or update a config entry'
        )
        _arguments -s -S \
          '1:config command:_describe -t commands command config_commands' \
          '*:args:' && ret=0
        ;;
      intention)
        local -a intention_commands
        intention_commands=(
          'check:check whether a connection would be allowed'
          'create:create a Connect intention'
          'delete:delete a Connect intention'
          'get:show information about an intention'
          'list:list Connect intentions'
          'match:show intentions that match a source or destination'
        )
        _arguments -s -S \
          '1:intention command:_describe -t commands command intention_commands' \
          '*:args:' && ret=0
        ;;
      operator)
        local -a operator_commands
        operator_commands=(
          'autopilot:provides tools for Autopilot'
          'raft:provides tools for Raft'
          'usage:provides cluster-level usage information'
        )
        _arguments -s -S \
          '1:operator command:_describe -t commands command operator_commands' \
          '*:args:' && ret=0
        ;;
      snapshot)
        local -a snapshot_commands
        snapshot_commands=(
          'agent:periodically saves snapshots locally'
          'decode:converts snapshot to JSON'
          'inspect:inspect a snapshot'
          'restore:restore a snapshot'
          'save:save a snapshot'
        )
        _arguments -s -S \
          '1:snapshot command:_describe -t commands command snapshot_commands' \
          '*:args:' && ret=0
        ;;
      services)
        local -a services_commands
        services_commands=(
          'deregister:deregister services with the local agent'
          'register:register services with the local agent'
        )
        _arguments -s -S \
          '1:services command:_describe -t commands command services_commands' \
          '*:args:' && ret=0
        ;;
      tls)
        local -a tls_commands
        tls_commands=(
          'ca:helpers for CAs'
          'cert:helpers for certificates'
        )
        _arguments -s -S \
          '1:tls command:_describe -t commands command tls_commands' \
          '*:args:' && ret=0
        ;;
      members)
        _arguments -s -S \
          $consul_global_flags \
          '-detailed[provides detailed member information]' \
          '-segment=[filter by network segment]:segment:' \
          '-status=[filter by status]:status:(alive leaving left failed)' \
          '-wan[list WAN members]' && ret=0
        ;;
      join)
        _arguments -s -S \
          $consul_global_flags \
          '-wan[join a WAN agent]' \
          '*:address:' && ret=0
        ;;
      watch)
        _arguments -s -S \
          $consul_global_flags \
          '-type=[watch type]:type:(key keyprefix services nodes service checks event)' \
          '-key=[watch key]:key:' \
          '-name=[event name]:name:' \
          '-prefix=[key prefix]:prefix:' \
          '-service=[service name]:service:' \
          '-tag=[service tag]:tag:' \
          '-passingonly=[only passing checks]:passingonly:(true false)' \
          '-state=[check state]:state:(any passing warning critical)' \
          '*:command:_cmdstring' && ret=0
        ;;
      event)
        _arguments -s -S \
          $consul_global_flags \
          '-name=[event name]:name:' \
          '-node=[filter by node name regex]:regex:' \
          '-service=[filter by service]:service:' \
          '-tag=[filter by tag]:tag:' \
          ':payload:' && ret=0
        ;;
      exec)
        _arguments -s -S \
          $consul_global_flags \
          '-node=[filter by node name regex]:regex:' \
          '-prefix=[prefix in KV store for request data]:prefix:' \
          '-service=[filter by service]:service:' \
          '-shell[use shell to run command]' \
          '-tag=[filter by service tag]:tag:' \
          '-verbose[enable verbose output]' \
          '-wait=[period to wait for responses]:wait:' \
          '-wait-repl=[period to wait for child process replication]:wait:' \
          '*:command:_cmdstring' && ret=0
        ;;
      monitor)
        _arguments -s -S \
          $consul_global_flags \
          '-log-level=[log level]:level:(trace debug info warn error)' \
          '-log-json[output logs in JSON format]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '-config-format=[config format]:format:(json hcl)' \
          '-quiet[suppress output]' \
          '*:config file:_files' && ret=0
        ;;
      force-leave)
        _arguments -s -S \
          $consul_global_flags \
          '-prune[remove agent completely from the list]' \
          '-wan[force leave from WAN pool]' \
          '1:node:' && ret=0
        ;;
      debug)
        _arguments -s -S \
          $consul_global_flags \
          '-archive[enable/disable archive]:bool:(true false)' \
          '-duration=[duration to run debug]:duration:' \
          '-interval=[interval for captures]:interval:' \
          '-output=[output path for debug bundle]:path:_files' \
          '-capture=[specific capture targets]:target:' && ret=0
        ;;
      *)
        _arguments -s -S \
          $consul_global_flags \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
