#compdef svd2rust
# _svd2rust — generate Rust register-access crates from CMSIS-SVD (rust-embedded/svd2rust)
# upstream: https://github.com/rust-embedded/svd2rust
# Flags from src/main.rs (clap builder).

_svd2rust() {
    local -a args
    args=(
        '(-i --input)'{-i+,--input=}'[input SVD file]:file:_files -g "*.svd"'
        '(-o --output-dir)'{-o+,--output-dir=}'[directory for generated files]:dir:_files -/'
        '(-c --config)'{-c+,--config=}'[config TOML file]:file:_files -g "*.toml"'
        '--settings=[target-specific settings YAML file]:file:_files -g "*.(yaml|yml)"'
        '--edition=[Rust edition of generated code]:edition:(2015 2018 2021 2024)'
        '--target=[target architecture]:target:(cortex-m msp430 riscv mips xtensa-lx none)'
        '--atomics[generate atomic register modification API]'
        '--atomics-feature=[feature gate the atomic register API]:feature:'
        '--ignore-groups[do not prefix register names with alternateGroup]'
        '--keep-list[keep registers/peripherals from the kept list]'
        '(-g --generic-mod)'{-g,--generic-mod}'[emit generic mod in a separate file]'
        '--feature-group[use peripheral group_name as feature flag]'
        '--feature-peripheral[independent cfg feature flag per peripheral]'
        '(-f --ident-format)'{-f+,--ident-format=}'[identifier-format setting]:spec:'
        '--ident-formats-theme=[ident_format preset]:theme:(new legacy)'
        '--field-names-for-enums[use field name for enumeratedValues even when named]'
        '--max-cluster-size[use array increment for cluster size]'
        '--impl-debug[implement Debug for readable blocks/registers]'
        '--impl-debug-feature=[feature gate Debug implementation]:feature:'
        '--impl-defmt=[feature for automatic defmt impl on enums]:feature:'
        '(-m --make-mod)'{-m,--make-mod}'[create mod.rs instead of lib.rs (no inner attrs)]'
        '--skip-crate-attributes[do not generate crate attributes]'
        '--skip-peripherals-struct[do not generate the Peripherals struct]'
        '(-s --strict)'{-s,--strict}'[enable advanced SVD-parsing checks]'
        '--source-type=[input file/stream format]:format:(xml json yaml)'
        '--reexport-core-peripherals[Cortex-M: re-export peripherals from cortex-m]'
        '--reexport-interrupt[re-export interrupt macro from cortex-m-rt-like crates]'
        '--add-cortex-m-int-num[emit cortex-m InterruptNumber trait impls]'
        '(-b --base-address-shift)'{-b+,--base-address-shift=}'[offset added to every peripheral base address]:offset:'
        '(-l --log)'{-l+,--log=}'[log level]:level:(off error warn info debug trace)'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )
    _arguments -s -S $args
}

_svd2rust "$@"
