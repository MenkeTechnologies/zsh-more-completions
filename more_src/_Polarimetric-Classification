#compdef Polarimetric-Classification
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/rstb/rstb-op-classification/src/main/java/org/csa/rstb/classification/gpf/PolarimetricClassificationOp.java
# ESA SNAP gpt Polarimetric-Classification operator - classify polarimetric SAR data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-Pclassification=[classification type]:type' \
  '-PwindowSize=[the sliding window size]:size' \
  '-PmaxIterations=[maximum number of iterations]:num' \
  '-PnumInitialClasses=[initial number of classes]:num' \
  '-PnumFinalClasses=[desired number of classes]:num' \
  '-PmixedCategoryThreshold=[threshold for classifying pixels to mixed category]:threshold' \
  '-Pdecomposition=[decomposition type]:type' \
  '*:graph xml:_files' && ret=0

return ret
