#compdef torify
# Documentation: https://manpages.debian.org/bookworm/tor/torify.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# torify is a wrapper that calls torsocks; it has no flags of its own,
# arguments are passed through to the wrapped application.

local -a arguments

arguments=(
    '(-):command:_command_names -e'
    '*::arguments:_normal'
)

_arguments -s -S $arguments
