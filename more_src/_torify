#compdef torify

local -a arguments

arguments=(
    '-h[show help]'
    '--help[show help]'
    '-v[verbose mode]'
    '--verbose[verbose mode]'
    '-d[enable torsocks debugging]'
    '--debug[enable torsocks debugging]'
    '-i[enable isolation (new Tor circuit per process)]'
    '--isolate[enable isolation (new Tor circuit per process)]'
    '-p[SOCKS port to use]:port' \
    '--port=[SOCKS port to use]:port'
    '(-):command:_command_names -e'
    '*::arguments:_normal'
)

_arguments -s -S $arguments
