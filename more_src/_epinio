#compdef epinio

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'app:manage applications'
  'configuration:manage configurations'
  'env:manage application environment variables'
  'gitconfig:manage git configurations'
  'info:show Epinio environment info'
  'login:log in to an Epinio cluster'
  'logout:log out from Epinio'
  'namespace:manage namespaces'
  'push:push an application'
  'server:start the Epinio API server'
  'service:manage services'
  'settings:show current settings'
  'target:set target namespace'
  'completion:generate shell completions'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-c,--config-file}'[config file path]:config:_files' \
  '--output/-o[output format]:format:(json yaml)' \
  '--skip-ssl-verification[skip SSL verification]' \
  '--verbosity[log verbosity]:level:(0 1 2 3)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'epinio command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (push)
        _arguments \
          '--name[application name]:name:' \
          '--path[application source path]:path:_files -/' \
          '--git[git repository URL]:url:' \
          '--container-image-url[container image]:image:' \
          '--builder-image[builder image]:image:' \
          '--env[environment variables]:key=value:' \
          '--instances/-i[number of instances]:count:' \
          '--route[application route]:route:' && ret=0
        ;;
      (app)
        local -a app_cmds=(
          'create:create an application'
          'delete:delete an application'
          'env:manage app env vars'
          'list:list applications'
          'logs:show app logs'
          'manifest:show app manifest'
          'push:push an application'
          'restage:restage an application'
          'restart:restart an application'
          'show:show application details'
          'update:update an application'
        )
        _describe -t commands 'app command' app_cmds && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
