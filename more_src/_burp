#compdef burp
# Documentation: https://burp.grke.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# burp — network BackUp and Restore Program (Graham Keeling).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-a[action: b=backup r=restore v=verify l=list e=estimate t=timer T=test_server_connect d=delete s=server_initiated_action]:action:(b r v l e t T d s)' \
  '-b[backup number]:number:' \
  '-c[path to config file]:file:_files' \
  '-d[directory to restore to]:dir:_directories' \
  '-f[allow overwrite during restore]' \
  '-g[list match terms]:term:' \
  '-i[print index of symbols]' \
  '-l[path to log file]:file:_files' \
  '-n[don'\''t use the Cygwin conversion for absolute paths]' \
  '-q[randomised delay (seconds)]:seconds:' \
  '-r[regex to match paths]:regex:' \
  '-s[number of leading path components to strip]:n:' \
  '-t[dry run]' \
  '-v[print extra debug information]' \
  '-x[don'\''t use the configured exclusions]' \
  '*:args:_files'
