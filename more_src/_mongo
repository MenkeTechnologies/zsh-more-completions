#compdef mongo
# Documentation: https://www.mongodb.com/docs/manual/reference/program/mongo/
# Source: MongoDB legacy `mongo` shell (deprecated 5.0+; mongosh is the modern replacement).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--verbose[verbose logging]' \
    '--shell[force shell start after script]' \
    '--nodb[do not connect to a database]' \
    '--norc[do not load .mongorc.js]' \
    '--quiet[do not print intro and prompts]' \
    '--eval=[evaluate JS expression and exit]:expression:' \
    '--retryWrites[enable retryable writes]' \
    '--host=[server hostname or replSet/host:port,...]:host:_hosts' \
    '--port=[server port]:port:' \
    '--username=[auth username]:user:_users' \
    '--password=[auth password]:password:' \
    '--authenticationDatabase=[auth DB]:db:' \
    '--authenticationMechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 PLAIN GSSAPI MONGODB-AWS)' \
    '--gssapiServiceName=[GSSAPI service name]:name:' \
    '--gssapiHostName=[GSSAPI host name]:host:_hosts' \
    '--ipv6[allow IPv6]' \
    '--tls[use TLS]' \
    '--tlsCertificateKeyFile=[TLS client cert+key]:file:_files' \
    '--tlsCertificateKeyFilePassword=[TLS client cert+key password]:password:' \
    '--tlsCAFile=[TLS CA cert]:file:_files' \
    '--tlsAllowInvalidCertificates[do not validate server cert]' \
    '--tlsAllowInvalidHostnames[do not validate server hostname]' \
    '--apiVersion=[API version]:version:(1)' \
    '--apiStrict[apply API strict mode]' \
    '--apiDeprecationErrors[error on deprecated API features]' \
    '--disableImplicitSessions[disable implicit client sessions]' \
    '*:script.js / connection-string:_files' \
    && ret=0

return ret
