#compdef notung Notung
# Notung: gene tree / species tree reconciliation, rooting and rearrangement

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--reconcile[reconcile a gene tree with a species tree]' \
  '--rearrange[rearrange the gene tree (requires --threshold)]' \
  '--root[root the gene tree, saving top scoring rootings]' \
  '--resolve[resolve non-binary nodes in the gene tree]' \
  '--savepng[save a PNG image of the result]' \
  '-g[gene tree file]:file:_files' \
  '-s[species tree file]:file:_files' \
  '-b[batch file listing inputs]:file:_files' \
  '-absfilenames[treat batch file paths as absolute]' \
  '-gu[gene tree URL location]:url:' \
  '-su[species tree URL location]:url:' \
  '--costdup[duplication cost]:cost:' \
  '--costconddup[conditional duplication cost]:cost:' \
  '--costloss[lost gene cost]:cost:' \
  '--speciestag[format of species tags in the gene tree]:format:(prefix postfix nhx)' \
  '--threshold[edge weight threshold or percentage preserved during rearrangement]:value:' \
  '--edgeweights[source of edge weights]:source:(name length nhx)' \
  '--bootstraps[source of bootstrap values]:source:(name length nhx)' \
  '--annotationfile[annotation file]:file:_files' \
  '--imagemap[image map output file]:file:_files' \
  '--treeoutput[output tree format]:format:(newick notung nhx)' \
  '--nolosses[suppress gene loss predictions in the output]' \
  '--maxtrees[maximum number of rooted trees to save]:n:' \
  '--outputdir[directory for output files]:dir:_files -/' \
  '--usegenedir[write output to the gene tree directory]' \
  '--log[write a log file]' \
  '--info[generate additional info output]' \
  '--treestats[output tree statistics]' \
  '--stpruned[output the pruned species tree]' \
  '--rootscores[output rooting scores]' \
  '--silent[suppress progress output]' \
  '--progressbar[show a progress bar]' \
  '--homologtablecsv[output a homolog table in CSV]' \
  '--homologtabletabs[output a homolog table in tab-delimited form]' \
  '--homologtablehtml[output a homolog table in HTML]' \
  '--show-species-tree[display the species tree]' \
  '--homologgui[launch the homolog GUI]' \
  '--exact-losses[compute exact losses for non-binary trees]' \
  '--polytomy-cutoff[maximum polytomy size]:n:' \
  '--report-heuristic-losses[report heuristic losses]' \
  '*:gene tree file:_files' && ret=0

return ret
