#compdef movmetaedit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '-t[set timecode]:timecode:' \
  '-r[set reel name]:reel:' \
  '-n[set name]:name:' \
  '-l[set location]:location:' \
  '-c[set comment]:comment:' \
  '-s[simulate without modifying]' \
  '-f[force processing]' \
  '--mdump[dump metadata]' \
  '--adump[dump atoms]' \
  '--udta-remove[remove user data atom]:type:' \
  '--free-remove[remove free atoms]' \
  '--stco-update[update chunk offsets]' \
  '*:files:_files -g "*.mov(|.mp4|.m4v)"' \
  && ret=0

return ret
