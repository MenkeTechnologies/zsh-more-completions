#compdef subsync
# Documentation: https://github.com/sc0ty/subsync/wiki/Command-line-options
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sync:specify a synchronization task'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --cli)'{-c,--cli}'[enable headless mode]' \
  '--verbose=[verbosity level (0-3)]:level:(0 1 2 3)' \
  '--offline[skip remote server contact]' \
  '--batch[open batch processing window (GUI)]' \
  '--import=[load tasks from YAML]:file:_files -g "*.{yml,yaml}"' \
  '--dump-words=[dump words SRC[:PATH]]:spec:' \
  '--logfile=[log file path]:file:_files' \
  '--loglevel=[logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--effort=[matching effort (0.0-1.0)]:f:' \
  '--max-point-dist=[maximum error in seconds]:f:' \
  '--min-points-no=[minimum sync points required]:n:' \
  '--window-size=[max correction in seconds]:n:' \
  '--min-word-prob=[min word probability (0.0-1.0)]:f:' \
  '--min-word-len=[minimum word length]:n:' \
  '--min-correlation=[minimum correlation (0.0-1.0)]:f:' \
  '--min-words-sim=[minimum words similarity (0.0-1.0)]:f:' \
  '--out-time-offset=[output timestamp offset (seconds)]:f:' \
  '(-j --jobs)'{-j+,--jobs=}'[concurrent threads]:n:' \
  '--overwrite[overwrite existing files]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'subsync command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sync)
        _arguments \
          '--sub=[subtitle file]:file:_files -g "*.{srt,ass,ssa,sub,vtt}"' \
          '--sub-file=[subtitle file]:file:_files -g "*.{srt,ass,ssa,sub,vtt}"' \
          '--sub-stream=[subtitle stream number]:n:' \
          '--sub-stream-by-lang=[subtitle language stream]:lang:' \
          '--sub-lang=[subtitle ISO 639-3 language]:lang:' \
          '--sub-enc=[subtitle character encoding]:enc:' \
          '--sub-fps=[subtitle framerate]:fps:' \
          '--ref=[reference file]:file:_files -g "*.{mkv,mp4,avi,m4v,webm,mov,srt,ass}"' \
          '--ref-file=[reference file]:file:_files' \
          '--ref-stream=[reference stream number]:n:' \
          '--ref-stream-by-lang=[ref language stream]:lang:' \
          '--ref-stream-by-type=[ref stream type]:type:(sub audio)' \
          '--ref-lang=[reference ISO 639-3 language]:lang:' \
          '--ref-enc=[reference character encoding]:enc:' \
          '--ref-fps=[reference framerate]:fps:' \
          '--ref-channels=[audio channels to listen to]:channels:' \
          '--out=[output file]:file:_files' \
          '--out-file=[output file]:file:_files' \
          '--out-fps=[output framerate]:fps:' \
          '--out-enc=[output encoding]:enc:' && ret=0 ;;
    esac ;;
esac

return ret
