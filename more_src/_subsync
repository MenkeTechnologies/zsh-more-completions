#compdef subsync

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sync:perform a sync task'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cli[run in CLI (headless) mode]' \
  '--debug[debug output]' \
  '--debug-log=[debug log file]:file:_files' \
  '--debug-level=[debug level]:level:(error warning info debug)' \
  '--import=[load tasks from YAML]:file:_files -g "*.{yml,yaml}"' \
  '--dump-words=[dump words SRC[:PATH]]:spec:' \
  '--logfile=[regular log file]:file:_files' \
  '--no-language-check[skip language verification]' \
  '--effort=[matching effort]:n:' \
  '--max-point-dist=[max sync point distance]:f:' \
  '--min-point-no=[min sync points required]:n:' \
  '--start-load-margin=[start margin sec]:n:' \
  '--end-load-margin=[end margin sec]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'subsync command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sync)
        _arguments \
          '--sub=[subtitle file]:file:_files -g "*.{srt,ass,ssa,sub,vtt}"' \
          '--sub-stream-by-lang=[subtitle language stream]:lang:' \
          '--sub-stream-id=[subtitle stream id]:id:' \
          '--ref=[reference file]:file:_files -g "*.{mkv,mp4,avi,m4v,webm,mov,srt,ass}"' \
          '--ref-stream-by-lang=[ref language stream]:lang:' \
          '--ref-stream-id=[ref stream id]:id:' \
          '--out=[output file]:file:_files' \
          '--sub-lang=[subtitle language]:lang:' \
          '--ref-lang=[reference language]:lang:' \
          '--lang=[both languages]:lang:' \
          '--encoding=[subtitle encoding]:enc:' \
          '--fps=[force FPS]:fps:' \
          '--use-translation[use translation memory]' \
          '--no-fix-overlap[do not fix overlaps]' \
          '--overwrite[overwrite output]' && ret=0 ;;
    esac ;;
esac

return ret
