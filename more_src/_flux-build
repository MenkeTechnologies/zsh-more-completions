#compdef flux-build
# Documentation: https://fluxcd.io/flux/cmd/flux_build/
# FluxCD build: construct artifacts and kustomizations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' \
  '*::subcommand:(artifact kustomization)' && ret=0

return ret
