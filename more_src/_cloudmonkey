#compdef cloudmonkey
# Documentation: https://github.com/apache/cloudstack-cloudmonkey/wiki/Getting-Started
# CloudMonkey command line interface for Apache CloudStack

local ret=1

_arguments -s -S \
  '-h[show help message or API doc when specified after an API]' \
  '-v[print version]' \
  '-o+[API response output format]:format:(json text table column csv)' \
  '-p+[server profile]:profile' \
  '-d[enable debug mode]' \
  '-c+[different config file path]:file:_files' \
  '-u+[CloudStack API endpoint URL]:url' \
  '-s+[CloudStack user secret key]:secret key' \
  '-k+[CloudStack user API key]:api key' \
  '*:command:((sync\:"discover and update APIs" set\:"configure options for cmk" version\:"version info" help\:"help" exit\:"exit"))' && ret=0

return ret
