#compdef merge_unicharsets
# Documentation: https://github.com/tesseract-ocr/tesseract/blob/main/doc/merge_unicharsets.1.asc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)'{-v,--version}'[show version]' \
  '*:unicharset (in/out):_files' && ret=0

return ret
