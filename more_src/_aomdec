#compdef aomdec
# Documentation: aomdec --help (libaom AV1 decoder)
# Source: Alliance for Open Media AV1 reference decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--codec=[codec to use]:codec:(av1)' \
    '(--yv12 --i420 --rawvideo)--yv12[output raw YV12 frames]' \
    '(--yv12 --i420 --rawvideo)--i420[output raw I420 frames]' \
    '(--yv12 --i420 --rawvideo)--rawvideo[output raw YUV frames]' \
    '--flipuv[flip chroma planes]' \
    '--noblit[do not process decoded frames]' \
    '--progress[progress after each frame]' \
    '--limit=[stop after N frames]:n:' \
    '--skip=[skip first N frames]:n:' \
    '--summary[show timing summary]' \
    '(-o --output)'{-o+,--output=}'[output file pattern]:file:_files' \
    '(-t --threads)'{-t+,--threads=}'[max threads]:n:' \
    '--row-mt=[row-based multi-threading 0/1]:n:(0 1)' \
    '(-v --verbose)'{-v,--verbose}'[show version]' \
    '(-S --scale)'{-S,--scale}'[scale output uniformly]' \
    '--frame-buffers=[frame buffers to use]:n:' \
    '--md5[compute MD5 of decoded frames]' \
    '--framestats=[per-frame stats CSV]:file:_files' \
    '(-k --keep-going)'{-k,--keep-going}'[continue after errors]' \
    '--output-bit-depth=[output bit depth]:bits:(8 10 12)' \
    '--annexb[bitstream in Annex-B]' \
    '--oppoint=[operating point for scalable bitstream]:n:' \
    '--all-layers[output all scalable layers]' \
    '--skip-film-grain[skip film-grain application]' \
    '1:input file:_files' \
    && ret=0

return ret
