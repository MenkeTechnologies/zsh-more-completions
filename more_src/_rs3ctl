# WHAT IT IS
#   rs3gw is an **S3-compatible object-storage gateway** —
#   architecturally similar to MinIO Gateway (now deprecated)
#   or s3proxy (Java) but rewritten in Rust for native Apple
#   Silicon + x86_64 performance.  It exposes:
#
#     • An **S3 REST API** on the configured HTTP/HTTPS port
#       (typed: AWS Signature V4 + V2 authentication, multipart
#       upload, server-side encryption, bucket lifecycle,
#       object tagging, bucket versioning, replication, object
#       locking, CORS) — every AWS SDK / `aws s3 cp` / `s3cmd` /
#       `rclone` / `Cyberduck` / `WinSCP` / `Mountain Duck`
#       client works against it unchanged
#
#     • A **typed GraphQL admin API** built on async-graphql —
#       this is what rs3ctl talks to.  Mutations cover bucket
#       create/delete/policy management; queries cover metrics,
#       lifecycle, replication status, dataset-preprocessing
#       pipeline state, observability metrics (per-bucket / per-
#       tenant request volume, latency percentiles, error rates,
#       AI-driven anomaly detection signals, custom business
#       metrics).
#
#     • A **typed WASM plugin layer** — the rs3gw workspace
#       ships example WASM plugins (rust-uppercase, json-filter)
#       that demonstrate how to register typed object-transform
#       handlers that fire on PUT/GET requests for content
#       transformation, content filtering, content enrichment,
#       or content validation
#
#     • **Multiple storage backends** plugged via a typed
#       `StorageBackend` trait — local filesystem, NFS, S3
#       (AWS / Wasabi / B2 / R2 / DO Spaces / MinIO / Ceph
#       RGW / SeaweedFS / Garage), NATS object store, IPFS,
#       etcd
#
#   `rs3ctl` is the dedicated operator-facing CLI that talks to
#   the rs3gw gateway's GraphQL admin endpoint over HTTPS.  It
#   provides:
#
#     • bucket          — bucket CRUD + policy management
#     • object          — object CRUD + multipart upload + info
#     • replication     — replication-policy CRUD + status
#     • metrics         — query Prometheus-style metrics
#     • maintenance     — vacuum, compact, verify, repair
#     • versioning      — enable/suspend bucket versioning
#     • observability   — profiling, anomaly detection, business
#                         metrics (a unique rs3gw differentiator
#                         — AI-driven anomaly detection on the
#                         request pattern)
#     • transform       — submit object-transform pipelines
#     • batch           — bulk operations across many objects
#     • lifecycle       — bucket lifecycle policy CRUD (Glacier-
#                         style transitions, expiration, MFA
#                         delete)
#     • preprocessing   — dataset preprocessing pipeline
#                         (designed for ML training data prep)
#     • health          — liveness/readiness probe
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/bin/rs3ctl.rs
#                       clap-derive `Cli` / `Commands` /
#                       `BucketAction` / `ObjectAction` etc.
#                       structs;  extracted via
#                       gh api repos/cool-japan/rs3gw/contents/
#                       src/bin/rs3ctl.rs)
#
#   rs3ctl [GLOBAL OPTIONS] <COMMAND> [SUBCOMMAND] [ARGS...]
#
#   Global options:
#     -h, --help                     Show help
#     -V, --version                  Print version
#     -e, --endpoint <URL>           rs3gw server endpoint
#                                    [default: http://localhost:
#                                              9000]
#     -a, --access-key <KEY>         Access key for authentication
#     -s, --secret-key <KEY>         Secret key for authentication
#
#   Commands:
#     bucket <ACTION>                Bucket management
#         list                       List all buckets
#         create <NAME> [-r REGION]  Create a new bucket
#         delete <NAME> [-f]         Delete a bucket (-f to
#                                    force-delete non-empty)
#         info <NAME>                Get bucket information
#         get-policy <NAME>          Get bucket policy
#         set-policy <NAME> <FILE>   Set bucket policy from JSON
#                                    file
#     object <ACTION>                Object management
#         list <BUCKET> [-p PREFIX] [-m MAX]
#                                    List objects (with prefix
#                                    + max-keys filters)
#         upload <BUCKET> <KEY> <FILE> [-t CONTENT_TYPE]
#                                    Upload a file as an object
#         download <BUCKET> <KEY> <OUTPUT>
#                                    Download an object
#         delete <BUCKET> <KEY>      Delete an object
#         info <BUCKET> <KEY>        Get object info
#     replication <ACTION>           Replication management
#         get-config <BUCKET>        Get replication config
#         (additional sub-actions for setting + status)
#     metrics <ACTION>               Metrics and monitoring
#     maintenance <ACTION>           Maintenance operations
#     versioning <ACTION>            Versioning management
#     observability <ACTION>         Profiling, anomalies,
#                                    business metrics
#     transform <ACTION>             Object-transform pipeline
#     batch <ACTION>                 Bulk operations
#     lifecycle <ACTION>             Lifecycle policy management
#     preprocessing <ACTION>         Dataset preprocessing
#                                    pipeline
#     health                         Health check
#
# AXIS / CORPUS POSITION
#   `cool-japan/rs3gw` declares **direct** workspace dependencies
#   on `async-graphql` + `async-graphql-axum` (for the gateway
#   daemon's GraphQL admin surface) in its workspace `Cargo.toml`
#   (verified via `gh api repos/cool-japan/rs3gw/contents/
#   Cargo.toml`).  The `rs3ctl` binary at `src/bin/rs3ctl.rs`
#   submits typed GraphQL queries + mutations to the gateway's
#   admin endpoint over HTTPS via reqwest, leveraging the
#   workspace-wide `async-graphql` types for response
#   deserialization.
#
#   `async-graphql/async-graphql` (the `async-graphql` crate) is
#   **THE canonical Rust GraphQL server library** — sunli829's
#   reference pure-Rust implementation of the GraphQL
#   specification, in continuous active development since 2020
#   with 3,800+ ★ on GitHub and millions of all-time crates.io
#   downloads.  It is the **only mature feature-complete Rust
#   GraphQL server**: the older alternatives `juniper` (graphql-
#   rust/juniper) is still maintained but with a much smaller
#   feature set and slower async support; `apollo-router-core`
#   targets the Apollo Router gateway use case but isn't a
#   general-purpose server library.
#
#   async-graphql ships:
#
#     • Typed `#[derive(SimpleObject)]` /  `#[derive(InputObject)]`
#       /  `#[derive(Interface)]` /  `#[derive(Union)]` /
#       `#[derive(Enum)]` /  `#[derive(Scalar)]` derive macros
#       for typed GraphQL schema definition
#     • Typed `Schema::new(query, mutation, subscription).finish()`
#       /  `Schema::build(...)` typed schema builder
#     • Typed `#[Object] impl QueryRoot { async fn ...(&self, ctx:
#       &Context<'_>, arg: T) -> Result<R> }` typed resolver
#       method definitions with full async + error-handling
#       support
#     • Typed `#[Subscription] impl SubscriptionRoot { async fn
#       ...(...) -> impl Stream<Item = T> }` typed GraphQL
#       subscription resolvers (the canonical real-time-update
#       primitive in GraphQL)
#     • Typed `Context<'_>` with `ctx.data::<T>() -> Result<&T>`
#       /  `ctx.look_ahead() -> Lookahead` (for typed dataloader
#       n+1 elimination) /  `ctx.add_error(err)` typed accessor
#     • Typed `Request` / `Response` / `Variables` /
#       `ServerError` / `ErrorExtensions` / `PathSegment` typed
#       request/response envelope
#     • Typed `dataloader::DataLoader<L>` typed Facebook DataLoader
#       pattern implementation for batched-query optimization
#     • Typed `BatchRequest` / `BatchResponse` typed batched-
#       query support (Apollo Federation-style batched queries)
#     • Typed extensions framework with built-in tracing
#       (`extensions::Tracing`), Apollo tracing
#       (`extensions::ApolloTracing`), opentelemetry
#       (`extensions::OpenTelemetry`), Apollo Studio reporting
#       (`extensions::ApolloStudio`), Apollo persisted queries
#       (`extensions::ApolloPersistedQueries`), and custom
#       extension hooks
#     • Typed integrations — `async-graphql-axum`,
#       `async-graphql-actix-web`, `async-graphql-warp`,
#       `async-graphql-rocket`, `async-graphql-poem`,
#       `async-graphql-tide`, `async-graphql-tower` typed
#       transport adapters for every major Rust web framework
#     • Apollo Federation v1 + v2 subgraph support
#       (`#[graphql(extends, key)]` directives)
#     • Apollo Federation v2 entity resolution
#       (`#[graphql(entity)]` resolvers)
#     • GraphQL WebSocket subscription transports — both the
#       canonical Apollo `subscriptions-transport-ws` and the
#       newer `graphql-ws` protocols
#     • Schema validation rules, depth limit, complexity limit,
#       custom validators
#     • Server-Sent Events (SSE) subscription transport
#     • Schema introspection + schema export
#       (`schema.sdl()`)
#
#   `async-graphql` is the GraphQL library behind **every modern
#   Rust GraphQL server** in production:
#
#     • **MystenLabs/sui** — the Sui blockchain's GraphQL RPC
#       API (7,694+ ★; covered as `_sui`)
#     • **linera-io/linera-protocol** — the Linera high-throughput
#       blockchain's GraphQL service (32,112+ ★; covered as
#       `_linera`)
#     • **left-curve/left-curve** — decentralized perpetual-
#       futures exchange's admin GraphQL (138+ ★)
#     • **polytope-labs/omnihedron** — Polkadot crosschain
#       messaging
#     • **EntSP/artemis** — artifact distribution service
#     • **cool-japan/rs3gw** (this very project; the rs3ctl
#       admin client)
#     • **PrintSpool/PrintSpool** — 3D-printing-over-WiFi
#       backend
#     • **letsdecrypt/telegrab** — Telegram archiver
#     • **bnicholson/QView** — quality view server
#     • **Stenstromen/bright**
#     • **respeer-ai/linera-protocol** examples
#     • Plus dozens of community blockchains, IoT gateways,
#       AI inference backends, admin consoles, and BFF
#       servers.
#
#   GraphQL itself was invented at **Facebook** in 2012 by Lee
#   Byron, Nick Schrock, and Daniel Schafer to solve the
#   classical REST API over-fetching + under-fetching + endpoint
#   proliferation problems.  Open-sourced in 2015 + standardized
#   as the **GraphQL Specification** in 2018 by the GraphQL
#   Foundation (a Linux Foundation member organization).
#   Architecture:
#
#     • **Schema** — typed `.graphql` schema files defining
#       Query / Mutation / Subscription root types + their
#       typed nested ObjectType / InputType / Interface /
#       Union / Enum / Scalar primitives
#     • **Resolvers** — typed per-field resolver functions
#       that fetch data on demand (the canonical solution to
#       REST over-fetching)
#     • **Single endpoint** — typically `/graphql` over POST
#       (HTTP/1.1, HTTP/2, HTTP/3) carrying the GraphQL query
#       document in the request body
#     • **Subscriptions** — bidirectional real-time updates
#       over WebSocket (`graphql-ws` or the legacy
#       `subscriptions-transport-ws` protocol)
#     • **Fragments** — composable query reuse
#     • **Directives** — `@include(if: ...)`, `@skip(if: ...)`,
#       `@deprecated(reason: ...)`, plus custom directives
#     • **Introspection** — typed `__schema` query for runtime
#       schema discovery (powers GraphiQL, Apollo Sandbox,
#       Insomnia, Postman, Banana Cake Pop, every modern
#       GraphQL IDE)
#     • **Apollo Federation** — Apollo's standardized service-
#       composition layer for splitting a single supergraph
#       across multiple subgraph services (the dominant
#       GraphQL gateway pattern; powers GitHub's, Shopify's,
#       Atlassian's, Netflix's, Uber's, and Airbnb's GraphQL
#       gateways)
#
#   GraphQL is the protocol underlying:
#     • **GitHub API v4** (entirely GraphQL-based since 2017)
#     • **Shopify Storefront + Admin APIs**
#     • **Atlassian Jira + Confluence Cloud APIs**
#     • **Netflix's StudioOS** internal platform
#     • **Uber's Schemaless** internal microservices
#     • **Airbnb's Niagara** internal service mesh
#     • **PayPal's Braintree GraphQL Gateway**
#     • **The New York Times Open APIs**
#     • Every **Apollo GraphOS** customer's supergraph
#     • Tens of thousands of public + private GraphQL APIs
#       across every industry
#
#   Verified via:
#     gh api repos/cool-japan/rs3gw/contents/Cargo.toml
#       → [workspace] members = [".", "examples/wasm-plugins/..."]
#       → [workspace.package] name = "rs3gw"  version = "0.2.1"
#       → [workspace.package] license = "Apache-2.0"
#       → workspace.dependencies includes async-graphql  (DIRECT)
#       → workspace.dependencies includes async-graphql-axum
#         (DIRECT)
#       → [[bin]] name = "testdata-generator"
#                  path = "src/bin/testdata_generator.rs"
#       → [[bin]] name = "s3-migrate"
#                  path = "src/bin/s3_migrate.rs"
#       → [[bin]] name = "rs3ctl"  path = "src/bin/rs3ctl.rs"
#     gh api repos/cool-japan/rs3gw/contents/src/bin/rs3ctl.rs
#       → //! rs3ctl - Command-line tool for managing rs3gw
#         S3-compatible object storage
#       → use clap::{Parser, Subcommand};
#       → use reqwest::Client;
#       → #[derive(Parser)] struct Cli {
#           #[arg(short, long,
#                 default_value = "http://localhost:9000")]
#           endpoint: String,
#           #[arg(short, long)] access_key: Option<String>,
#           #[arg(short, long)] secret_key: Option<String>,
#           #[command(subcommand)] command: Commands }
#       → enum Commands { Bucket, Object, Replication, Metrics,
#                          Maintenance, Versioning, Observability,
#                          Transform, Batch, Lifecycle,
#                          Preprocessing, Health }
#       → enum BucketAction { List, Create { name, region },
#                              Delete { name, force }, Info,
#                              GetPolicy, SetPolicy }
#       → enum ObjectAction { List { bucket, prefix, max_keys },
#                              Upload, Download, Delete, Info }
#
#   This entry is the Rust=178 leader bump that **OPENS Axis 123
#   (GraphQL / Facebook RFC GraphQL specification + GraphQL HTTP
#   transport + GraphQL Subscriptions)** at 1/0/0 following
#   R1066 _dt-skill (TS-Node=177 CLOSED Axis 122 gRPC at 1/1/1
#   triple-177 + 115th axis closed).  Go=178 continuation on
#   deck for R1068 via the canonical Go GraphQL library
#   `99designs/gqlgen` (the dominant Go GraphQL server library,
#   used by Netflix, Microsoft, Twitch, Booking.com, AppsFlyer,
#   and thousands of production Go GraphQL APIs).  TS-Node=178
#   closing pair at R1069 via the canonical TS/JS GraphQL
#   library `graphql/graphql-js` (the Facebook-authored
#   reference JavaScript implementation, the substrate of
#   Apollo Server, Yoga, Mercurius, Hot Chocolate's JS bridge,
#   GitHub's GraphQL gateway, every Relay-driven React app, and
#   essentially every TypeScript GraphQL server in production).
#
#   No completion for `rs3ctl` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_rs3ctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-e --endpoint)'{-e,--endpoint}'=[rs3gw server endpoint (default http://localhost:9000)]:url:' \
        '(-a --access-key)'{-a,--access-key}'=[access key]:key:' \
        '(-s --secret-key)'{-s,--secret-key}'=[secret key]:key:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _r3_cmds=(
                'bucket:bucket management commands'
                'object:object management commands'
                'replication:replication management commands'
                'metrics:metrics and monitoring commands'
                'maintenance:maintenance operations'
                'versioning:versioning management commands'
                'observability:profiling, anomalies, business metrics'
                'transform:transformation operations'
                'batch:batch operations'
                'lifecycle:lifecycle policy management'
                'preprocessing:dataset preprocessing pipeline management'
                'health:health check'
            )
            _describe -t commands 'rs3ctl command' _r3_cmds && ret=0
            ;;
        args)
            case $words[1] in
                bucket)
                    if (( CURRENT == 2 )); then
                        local -a _b=(
                            'list:list all buckets'
                            'create:create a new bucket'
                            'delete:delete a bucket'
                            'info:get bucket information'
                            'get-policy:get bucket policy'
                            'set-policy:set bucket policy from file'
                        )
                        _describe -t sub 'bucket action' _b && ret=0
                    elif [[ $words[2] == create ]]; then
                        _arguments \
                            '1:bucket name:' \
                            '(-r --region)'{-r,--region}'=[bucket region (default us-east-1)]:region:' && ret=0
                    elif [[ $words[2] == delete ]]; then
                        _arguments \
                            '1:bucket name:' \
                            '(-f --force)'{-f,--force}'[force delete even if bucket is not empty]' && ret=0
                    elif [[ $words[2] == (info|get-policy) ]]; then
                        _arguments '1:bucket name:' && ret=0
                    elif [[ $words[2] == set-policy ]]; then
                        _arguments \
                            '1:bucket name:' \
                            '2:policy JSON file:_files -g "*.json"' && ret=0
                    fi
                    ;;
                object)
                    if (( CURRENT == 2 )); then
                        local -a _o=(
                            'list:list objects in a bucket'
                            'upload:upload a file as an object'
                            'download:download an object to a file'
                            'delete:delete an object'
                            'info:get object information'
                        )
                        _describe -t sub 'object action' _o && ret=0
                    elif [[ $words[2] == list ]]; then
                        _arguments \
                            '1:bucket name:' \
                            '(-p --prefix)'{-p,--prefix}'=[prefix filter]:prefix:' \
                            '(-m --max-keys)'{-m,--max-keys}'=[maximum keys to return (default 1000)]:n:' && ret=0
                    elif [[ $words[2] == upload ]]; then
                        _arguments \
                            '1:bucket:' \
                            '2:key:' \
                            '3:local file:_files' \
                            '(-t --content-type)'{-t,--content-type}'=[content type]:mime:' && ret=0
                    elif [[ $words[2] == download ]]; then
                        _arguments \
                            '1:bucket:' \
                            '2:key:' \
                            '3:output path:_files' && ret=0
                    elif [[ $words[2] == (delete|info) ]]; then
                        _arguments \
                            '1:bucket:' \
                            '2:key:' && ret=0
                    fi
                    ;;
                replication)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'replication action' '(get-config:get-replication-config)' && ret=0
                    elif [[ $words[2] == get-config ]]; then
                        _arguments '1:bucket name:' && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_rs3ctl "$@"
