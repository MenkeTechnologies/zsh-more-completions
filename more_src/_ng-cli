#compdef ng
# _ng-cli — Angular CLI (Google); scaffolds + builds + tests Angular apps
# upstream: https://github.com/angular/angular-cli

_ng-cli() {
    local -a sub=(
        'add:add a library to the workspace'
        'analytics:configure CLI analytics'
        'build:build the app'
        'cache:configure cache'
        'completion:generate shell completion'
        'config:retrieve or set workspace config'
        'deploy:deploy via a deploy builder'
        'doc:open Angular docs'
        'e2e:run end-to-end tests'
        'extract-i18n:extract i18n messages'
        'generate:generate code'
        'help:show help'
        'lint:lint workspace'
        'new:create a new workspace'
        'run:run an architect target'
        'serve:run dev server'
        'test:run unit tests'
        'update:update Angular and deps'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--collection+[schematic collection]:name:' \
        '--defaults[use defaults]' \
        '--interactive[force interactive prompts]' \
        '--no-interactive[no prompts]' \
        '--dry-run[show changes without writing]' \
        '--force[force overwrite]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ng subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments '1:schematic:(application class component config directive enum environments guard interceptor interface library module pipe resolver service service-worker web-worker)' '*:name:' ;;
                serve|build|test|e2e|lint|extract-i18n|deploy|run) _arguments '1:project:' ;;
                new) _arguments '1:name:' \
                    '--prefix+[component prefix]:str:' \
                    '--routing[add routing]' \
                    '--style+[style]:style:(css scss sass less)' \
                    '--skip-git[skip git init]' \
                    '--skip-install[skip npm install]' \
                    '--strict[strict mode]' \
                    '--standalone[standalone components]' ;;
            esac
            ;;
    esac
}

_ng-cli "$@"
