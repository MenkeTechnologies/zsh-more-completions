#compdef cert
# _cert — fastlane cert iOS code-signing certificate manager (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_cert() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--development[development cert]' \
        '-d[development cert]' \
        '--type=+[type]:t:(development distribution enterprise developer_id_application developer_id_installer mac_installer_distribution mac_app_distribution)' \
        '-t+[type]:t:(development distribution enterprise developer_id_application developer_id_installer mac_installer_distribution mac_app_distribution)' \
        '--force=+[force]:b:(true false)' \
        '-r+[force]:b:(true false)' \
        '--generate-apple-certs=+[generate apple certs]:b:(true false)' \
        '-y+[generate apple certs]:b:(true false)' \
        '--username=+[apple ID username]:str:_users' \
        '-u+[apple ID username]:str:_users' \
        '--team-id=+[team id]:str:' \
        '-b+[team id]:str:' \
        '--team-name=+[team name]:str:' \
        '-l+[team name]:str:' \
        '--filename=+[filename]:str:' \
        '-q+[filename]:str:' \
        '--output-path=+[output path]:dir:_files -/' \
        '-o+[output path]:dir:_files -/' \
        '--keychain-path=+[keychain path]:file:_files' \
        '-k+[keychain path]:file:_files' \
        '--keychain-password=+[keychain password]:str:' \
        '-p+[keychain password]:str:' \
        '--platform=+[platform]:p:(macos ios catalyst)' \
        '*:arg:'
}

_cert "$@"
