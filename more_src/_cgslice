#compdef cgslice
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/cgslice.html
# MIRIAD: display an image and extract 1-D slices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'type=[image type]:type:(contour pixel)' \
  'region=[region of interest]:region:' \
  'xybin=[spatial increment and binning]:xybin:' \
  'chan=[channel increment and averaging]:chan:' \
  'slev=[contour level scaling]:slev:' \
  'levs=[contour levels]:levs:' \
  'range=[intensity range and lookup table]:range:' \
  'xrange=[x-axis slice range]:xrange:' \
  'yrange=[y-axis slice range]:yrange:' \
  'device=[PGPLOT device]:device:' \
  'nxy=[subplots in x and y]:nxy:' \
  'labtyp=[coordinate label types]:labtyp:' \
  'options=[accumulate,baseline,fiddle,fit,grid]:options:' \
  '3format=[third-axis label format]:3format:' \
  'csize=[character sizes]:csize:' \
  'posin=[slice endpoints input file]:posin:_files' \
  'posout=[slice coordinates output file]:posout:_files' \
  'valout=[slice values output file]:valout:_files' \
  'modout=[Gaussian model output file]:modout:_files' \
  '*:image:_files' && ret=0

return ret
