#compdef arrow-tools
# _arrow-tools — Apache Arrow utility executables (Apache Software Foundation, C++); arrow-cat/-dump/-stream/-validate
# upstream: https://github.com/apache/arrow

_arrow-tools() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--input=+[input file]:file:_files -g "*.(arrow|feather|parquet)"' \
        '--output=+[output file]:file:_files' \
        '--format=+[format]:fmt:(arrow ipc feather parquet csv json)' \
        '--columns=+[columns to project]:cols:' \
        '--schema[print schema only]' \
        '--metadata[print metadata]' \
        '--compression=+[compression]:c:(snappy gzip zstd lz4 brotli uncompressed)' \
        '--batch-size=+[batch size]:n:' \
        '--no-header[no header for csv]' \
        '--limit=+[row limit]:n:' \
        '*:file:_files'
}

_arrow-tools "$@"
