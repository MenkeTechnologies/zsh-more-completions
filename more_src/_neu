#compdef neu

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new Neutralino app'
  'build:build the application'
  'run:run the application'
  'update:update Neutralino binaries and client'
  'version:show version information'
  'plugins:manage Neutralino plugins'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'neu command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (create)
        _arguments \
          '--template=[project template]:template' \
          '1:project name' && ret=0
        ;;
      (build)
        _arguments \
          '--release[build for production]' \
          '--copy-storage[copy storage directory]' && ret=0
        ;;
      (run)
        _arguments \
          '--frontend-lib-dev[enable frontend dev server]' \
          '--arch=[target architecture]:arch:(x64 arm64 armhf ia32)' \
          '-- :extra arguments' && ret=0
        ;;
      (update)
        _arguments \
          '--latest[use latest version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
