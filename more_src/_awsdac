#compdef awsdac

# awslabs/diagram-as-code — cmd/awsdac/main.go

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-o+,--output=}'[output image path]:file:_files' \
  '*'{-v,--verbose}'[verbose logging]' \
  '(-c)'{-c,--cfn-template}'[input is CloudFormation template (beta)]' \
  '(-d)'{-d,--dac-file}'[(with -c) emit dac YAML from CloudFormation (beta)]' \
  '--override-def-file=[override definition file URL/path]:path:_files' \
  '--allow-untrusted-definitions[allow untrusted definition URLs]' \
  '(-t)'{-t,--template}'[run text/template on input file]' \
  '(-f)'{-f,--force}'[overwrite output without confirmation]' \
  '--width=[output width; 0=no resize]:pixels:' \
  '--height=[output height; 0=no resize]:pixels:' \
  '1:input file:_files' && ret=0

return ret
