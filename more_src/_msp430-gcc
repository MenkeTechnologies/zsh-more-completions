#compdef msp430-gcc msp430-elf-gcc msp430-g++ msp430-elf-g++
# _msp430-gcc — Texas Instruments msp430-elf-gcc CLI for the TI MSP430 cross-GCC compiler supporting C C++ msp430 msp430x large/small model interrupts ROM data placement (TI team, C); getopt
# upstream: https://www.ti.com/tool/MSP430-GCC-OPENSOURCE

_msp430-gcc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c[compile only]' \
        '-S[assembly only]' \
        '-E[preprocess only]' \
        '-o+[output file]:file:_files' \
        '-I+[include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-D+[define]:str:' \
        '-U+[undefine]:str:' \
        '-O+[opt level]:O:(0 1 2 3 s g fast)' \
        '-g[debug info]' \
        '-W+[warning]:str:' \
        '-pedantic[pedantic]' \
        '-mmcu=+[MCU]:m:(msp430g2553 msp430f1611 msp430f5529 msp430f5438a msp430fr5969 msp430fr5994 msp430fr6989 msp430g2231 msp430g2452 msp430g2553 msp430g2755 msp430fg6626 msp430fr2433 msp430fr2476 msp430fr5969)' \
        '-mlarge[large model]' \
        '-msmall[small model]' \
        '-mcpu=+[cpu]:c:(msp430 msp430x msp430xv2)' \
        '-mhwmult=+[mult]:m:(auto 16bit 32bit f5series none)' \
        '-mcode-region=+[r]:r:(upper lower either none)' \
        '-mdata-region=+[r]:r:(upper lower either none)' \
        '-msilicon-errata=+[errata]:str:' \
        '-msilicon-errata-warn=+[errata]:str:' \
        '-Wl,+[linker option]:str:' \
        '-T+[linker script]:file:_files -g "*.ld *.x"' \
        '-nostdlib[no standard libraries]' \
        '-ffunction-sections[function sections]' \
        '-fdata-sections[data sections]' \
        '-flto[link-time optimization]' \
        '*:source file:_files -g "*.c *.cc *.cpp *.s *.S *.o *.a"'
}

_msp430-gcc "$@"
