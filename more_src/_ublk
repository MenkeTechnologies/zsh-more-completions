#compdef ublk
# _ublk — Linux kernel ublk-tool CLI command-line frontend to the ublk_drv kernel driver creating destroying listing /dev/ublkb* userspace block devices over io_uring shared queues for backing loopback null-zero qcow2 nbd ceph rbd targets at user-space (Ming Lei team, C); custom argparse
# upstream: https://github.com/ublk-org/ublksrv

_ublk() {
    local -a sub=(
        'add:add a new ublk device'
        'del:delete a ublk device'
        'list:list ublk devices'
        'recover:recover ublk device'
        'features:show kernel features'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-n+[number]:n:' \
        '--number=+[number]:n:' \
        '-q+[queue depth]:n:' \
        '--queue-depth=+[depth]:n:' \
        '-d+[depth]:n:' \
        '--depth=+[depth]:n:' \
        '-t+[type]:t:(null loop qcow2 nbd rbd zoned virtio_blk)' \
        '--type=+[type]:t:(null loop qcow2 nbd rbd zoned virtio_blk)' \
        '-z[zero copy]' \
        '--zero-copy[zero copy]' \
        '-r+[recover]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ublk subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '-t+[type]:t:(null loop qcow2 nbd rbd zoned)' \
                    '-f+[file]:file:_files' \
                    '-q+[queue]:n:' \
                    '-d+[depth]:n:' \
                    '-n+[dev id]:n:' \
                    '-s+[size]:str:' ;;
                del|recover) _arguments '1:dev id:' ;;
            esac
            ;;
    esac
}

_ublk "$@"
