#compdef tanstack
# Documentation: https://www.npmjs.com/package/@tanstack/cli
# Reference accessed: 2026-05-23
# Verified: npx @tanstack/cli --help.

# Zsh completion for tanstack - TanStack CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new TanStack Start application'
  'dev:create sandbox app and watch templates'
  'libraries:list TanStack libraries'
  'doc:fetch TanStack documentation page'
  'search-docs:search TanStack documentation'
  'ecosystem:list TanStack ecosystem partners'
  'pin-versions:pin TanStack library versions'
  'clean-demos:remove demo files from scaffolded project'
  'telemetry:telemetry settings'
  'add:add add-ons to project'
  'add-on:add-on management'
  'template:template management'
  'starter:starter management'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'tanstack command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
