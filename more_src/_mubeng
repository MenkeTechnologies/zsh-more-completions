#compdef mubeng
# Documentation: https://github.com/kitabisa/mubeng
# proxy IP rotator and proxy checker

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --file)'{-f,--file}'=[proxy file to use]:file:_files' \
  '(-a --address)'{-a,--address}'=[run proxy server on address:port]:addr:' \
  '(-A --auth)'{-A,--auth}'=[proxy server auth user:pass]:auth:' \
  '(-d --daemon)'{-d,--daemon}'[daemonize proxy server]' \
  '(-c --check)'{-c,--check}'[check proxy availability]' \
  '(-g --goroutine)'{-g,--goroutine}'=[max goroutines]:n:' \
  '--only-cc=[filter by ISO-3166 country codes]:codes:' \
  '(-t --timeout)'{-t,--timeout}'=[max time allowed]:duration:' \
  '(-r --rotate)'{-r,--rotate}'=[rotate IP every N requests]:n:' \
  '--rotate-on-error[rotate IP and retry failed requests]' \
  '--remove-on-error[remove failed proxy from pool]' \
  '--max-errors=[max allowed errors]:n:' \
  '--max-redirs=[max redirects allowed]:n:' \
  '--max-retries=[retry attempts for failed requests]:n:' \
  '(-m --method)'{-m,--method}'=[rotation method]:method:(sequential random)' \
  '(-s --sync)'{-s,--sync}'[wait for previous request completion]' \
  '(-v --verbose)'{-v,--verbose}'[show detailed HTTP request/response]' \
  '(-o --output)'{-o,--output}'=[save output to file]:file:_files' \
  '(-u --update)'{-u,--update}'[update mubeng to latest version]' \
  '(-w --watch)'{-w,--watch}'[watch proxy file for live reload]' && ret=0

return ret
