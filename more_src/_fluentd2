#compdef fluentd2
# _fluentd2 — Treasure Data Fluent Project fluentd2 CLI command-line frontend wrapping the Fluentd CNCF open-source unified logging layer Ruby-based providing in-tail in-forward in-http in-tcp in-udp in-syslog in-monitor-agent in-debug-agent in-dummy out-forward out-stdout out-file out-elasticsearch out-mongodb out-s3 out-kafka2 out-loki out-opensearch filter-grep filter-parser filter-record-transformer filter-stdout buffer-memory-file (Fluent CNCF team Treasure Data, Ruby); custom argparse
# upstream: https://www.fluentd.org/

_fluentd2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "fluent.conf *.conf"' \
        '--config=+[file]:file:_files -g "fluent.conf *.conf"' \
        '-p+[plugin dir]:dir:_files -/' \
        '--plugin=+[dir]:dir:_files -/' \
        '-I+[load path]:dir:_files -/' \
        '-r+[require lib]:str:' \
        '-d+[pid file]:file:_files -g "*.pid"' \
        '--daemon=+[file]:file:_files -g "*.pid"' \
        '--under-supervisor[run under supervisor]' \
        '--no-supervisor[no supervisor]' \
        '-l+[log file]:file:_files' \
        '--log=+[file]:file:_files' \
        '--log-rotate-age=+[N]:n:' \
        '--log-rotate-size=+[N]:n:' \
        '--log-event-verbose[verbose log event]' \
        '-i+[inline config]:str:' \
        '--inline-config=+[str]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-qq[more quiet]' \
        '-vv[more verbose]' \
        '--suppress-repeated-stacktrace[no repeat trace]' \
        '--without-source[without source]' \
        '--use-v1-config[v1 config]' \
        '--strict-config-check[strict check]' \
        '-g+[gemfile]:file:_files -g "Gemfile"' \
        '--gemfile=+[file]:file:_files -g "Gemfile"' \
        '-G+[gem path]:dir:_files -/' \
        '--gem-path=+[dir]:dir:_files -/' \
        '-s[disable shared socket]' \
        '--no-supervisor-socket[no supervisor socket]' \
        '-x+[plugin config]:str:' \
        '--show-plugin-config=+[name]:str:' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '--group=+[group]:_groups' \
        '--root-dir=+[dir]:dir:_files -/' \
        '*:args:'
}

_fluentd2 "$@"
