#compdef goldendict
# Documentation: https://man.archlinux.org/search?q=goldendict
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--datadir=[data directory]:dir:_files -/' \
  '--logfile=[log file]:file:_files' \
  '--readline-cmds=[readline command]:cmd:' \
  '--no-tray[disable tray icon]' \
  '--show-window[show main window]' \
  '--query=[run a query]:query:' \
  '*:word:' && ret=0

return ret
