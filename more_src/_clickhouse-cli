#compdef clickhouse-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-h --host)'{-h+,--host=}'[server host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[server HTTP port]:port:' \
  '(-u --user)'{-u+,--user=}'[username]:user:' \
  '(-P --password)'{-P+,--password=}'[password]:password:' \
  '(-d --database)'{-d+,--database=}'[database]:database:' \
  '(-s --settings)'{-s+,--settings=}'[query string appended to every query]:settings:' \
  '(-f --format)'{-f+,--format=}'[interactive output format]:format:(PrettyCompact Pretty Vertical TSV CSV JSON JSONEachRow)' \
  '(-F --format-stdin)'{-F+,--format-stdin=}'[data format for stdin/file queries]:format:(TSV CSV JSON JSONEachRow Native)' \
  '(-m --multiline)'{-m,--multiline}'[multiline shell mode]' \
  '--stacktrace[print stacktraces from server]' \
  '(-q --query)'{-q+,--query=}'[query string]:query:' \
  '--cookie=[HTTP cookie]:cookie:' \
  '*::file:_files -g "*.sql"' && ret=0

return ret
