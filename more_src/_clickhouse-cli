#compdef clickhouse-cli
# Documentation: https://github.com/hatarist/clickhouse-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  {-h+,--host=}'[server host]:host:_hosts' \
  {-p+,--port=}'[server HTTP port]:port:' \
  {-u+,--user=}'[username]:user:' \
  {-P+,--password}'[prompt for password]' \
  {-d+,--database=}'[database]:database:' \
  {-s+,--settings=}'[query string appended to every query]:settings:' \
  {-f+,--format=}'[interactive output format]:format:(PrettyCompact Pretty Vertical TSV CSV JSON JSONEachRow)' \
  {-F+,--format-stdin=}'[data format for stdin/file queries]:format:(TSV CSV JSON JSONEachRow Native)' \
  '(-m --multiline)'{-m,--multiline}'[multiline shell mode]' \
  '(-k --insecure)'{-k,--insecure}'[allow insecure SSL connections]' \
  '--stacktrace[print stacktraces from server]' \
  {-c+,--cookie=}'[HTTP cookie]:cookie:' \
  '*::file:_files -g "*.sql"' && ret=0

return ret
