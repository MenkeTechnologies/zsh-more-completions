#compdef xfproduct
# Documentation: https://bio3d.colorado.edu/imod/doc/man/xfproduct.html
# Multiply or concatenate transforms

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-in1 -InputFile1)'{-in1,-InputFile1}'[File with transforms applied first. If this option is n]:file:_files' \
  '(-in2 -InputFile2)'{-in2,-InputFile2}'[File with transforms applied second. If this option is ]:file:_files' \
  '(-output -OutputFile)'{-output,-OutputFile}'[Output file C for product transforms. If this option is]:file:_files' \
  '(-scale -ScaleShifts)'{-scale,-ScaleShifts}'[Factors by which to scale X/Y translations of the first]:value:' \
  '(-one -OneXformToMultiply)'{-one,-OneXformToMultiply}'[When one file has multiple transforms and the other has]:value:' \
  '-StandardInput[Read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
