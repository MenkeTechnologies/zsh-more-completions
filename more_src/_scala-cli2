#compdef scala-cli2 scala-cli2-runner
# _scala-cli2 — VirtusLab Scala Center scala-cli2 CLI command-line frontend wrapping the Scala CLI tool to interact with Scala lightweight tool to develop and ship Scala applications open-source written in Scala originally VirtusLab now Scala Center the new official tool to compile run test and package Scala code intended to be a thin wrapper around Scala build tools such as scalac SBT Mill new clean compile run test package config setup-ide bsp directives doc dependency-update install publish completion shebang export uninstall version help fmt format using-directive watch (VirtusLab Scala Center team Krzysztof Romanowski Alex Archambault Tomasz Pasternak, Scala); case-app
# upstream: https://scala-cli.virtuslab.org/

_scala-cli2() {
    local -a sub=(
        'about:show about info'
        'browse:open Scala browser docs'
        'bsp:start BSP server'
        'clean:clean caches'
        'compile:compile Scala code'
        'completion:generate shell completion'
        'config:configuration ops'
        'console:open Scala REPL'
        'default-file:emit default file'
        'dependency-update:update dependencies'
        'directives:list directives'
        'doc:generate Scaladoc'
        'export:export to sbt/mill/etc'
        'fix:fix code style'
        'fmt:format code'
        'format:format code'
        'help:show help'
        'install:install completions'
        'install-home:install scala-cli'
        'metabrowse:start metabrowse server'
        'new:create a new project'
        'package:package Scala project'
        'pgp-create:create PGP key'
        'pgp-pull:pull PGP keys'
        'pgp-push:push PGP keys'
        'pgp-sign:sign with PGP'
        'pgp-verify:verify PGP signature'
        'publish:publish to Maven Central'
        'publish-setup:set up publishing'
        'repl:open Scala REPL'
        'run:run Scala code'
        'setup-ide:set up IDE config'
        'shebang:shebang Scala'
        'test:run tests'
        'uninstall:uninstall scala-cli'
        'update:update scala-cli'
        'using-directive:add using directive'
        'version:show version'
        'watch:run in watch mode'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--cli-default[CLI default scope]' \
        '--cli-extra-jars=+[jars]:str:' \
        '--bloop-version=+[v]:str:' \
        '--scala=+[v]:str:' \
        '-S+[Scala version]:str:' \
        '--scala-version=+[v]:str:' \
        '--scala-binary-version=+[v]:str:' \
        '--platform=+[p]:p:(jvm js native)' \
        '--js[Scala.js]' \
        '--native[Scala Native]' \
        '--jvm=+[v]:str:' \
        '-j+[jvm]:str:' \
        '--javac-plugin=+[opt]:str:' \
        '--javac-option=+[opt]:str:' \
        '--javac-options=+[opts]:str:' \
        '--javac-plugin-option=+[opt]:str:' \
        '--java-opt=+[arg]:str:' \
        '-J+[java arg]:str:' \
        '*-J+[java arg]:str:' \
        '--java-option=+[arg]:str:' \
        '*--java-option=+[arg]:str:' \
        '--scalac-option=+[opt]:str:' \
        '*-O+[scalac opt]:str:' \
        '*--scalac-option=+[opt]:str:' \
        '--dependency=+[dep]:str:' \
        '*--dep=+[dep]:str:' \
        '*--dependency=+[dep]:str:' \
        '--repository=+[uri]:str:' \
        '*--repo=+[uri]:str:' \
        '--exclude=+[name]:str:' \
        '*--exclude=+[name]:str:' \
        '--compilation-output=+[dir]:dir:_files -/' \
        '-d+[compilation output]:dir:_files -/' \
        '--server=+[v]:v:(true false)' \
        '--workspace=+[dir]:dir:_files -/' \
        '--bloop-bsp-protocol=+[p]:str:' \
        '--main-class=+[name]:str:' \
        '-M+[main class]:str:' \
        '--jar=+[file]:file:_files -g "*.jar"' \
        '*--jar=+[file]:file:_files -g "*.jar"' \
        '--classpath[print classpath]' \
        '-p[print classpath]' \
        '--print[print classpath]' \
        '--print-classpath[print classpath]' \
        '--watch[watch mode]' \
        '-w[watch]' \
        '--restart[restart]' \
        '--interactive[interactive mode]' \
        '-i[interactive]' \
        '--script-snippet=+[code]:str:' \
        '*--script-snippet=+[code]:str:' \
        '--scala-snippet=+[code]:str:' \
        '*--scala-snippet=+[code]:str:' \
        '--java-snippet=+[code]:str:' \
        '*--java-snippet=+[code]:str:' \
        '--markdown=+[code]:str:' \
        '*--markdown=+[code]:str:' \
        '--input=+[file]:_files' \
        '*--input=+[file]:_files' \
        '-I+[input]:_files' \
        '--with-resource-dir=+[dir]:dir:_files -/' \
        '*--with-resource-dir=+[dir]:dir:_files -/' \
        '--with-compiler-classpath=+[cp]:str:' \
        '--list-main-classes[list main classes]' \
        '--list-completions[list completions]' \
        '--check[check only]' \
        '--respect-project-filters[respect project filters]' \
        '--check-format[check format]' \
        '--save-project-config[save project config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scala-cli subcommand' sub ;;
        args) _arguments '*:source:_files -g "*.scala *.sc *.java *.md"' ;;
    esac
}

_scala-cli2 "$@"
