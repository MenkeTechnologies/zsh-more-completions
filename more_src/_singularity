#compdef singularity

# Zsh completion for singularity - container platform for HPC

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a Singularity Image File (SIF) from a definition file'
  'cache:manage the local cache'
  'capability:manage Linux capabilities for users and groups'
  'config:manage various singularity configuration (root user only)'
  'delete:deletes requested image from the library'
  'exec:run a command within a container'
  'inspect:show metadata for an image'
  'instance:manage containers running as services'
  'key:manage OpenPGP keys'
  'keys:manage OpenPGP keys'
  'oci:manage OCI containers'
  'plugin:manage Singularity plugins'
  'pull:pull an image from a URI'
  'push:upload image to the provided URI'
  'remote:manage singularity remote endpoints'
  'run:run the user-defined default command within a container'
  'run-help:show the runscript help'
  'search:search a Container Library for images'
  'shell:run a shell within a container'
  'sif:manipulate Singularity Image Format (SIF) files'
  'sign:attach a cryptographic signature to an image'
  'test:run the user-defined tests within a container'
  'verify:verify cryptographic signatures attached to an image'
  'version:show the version of singularity'
  'help:help about any command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[help for singularity]' \
  '(-c --config)'{-c,--config}'[specify a configuration file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[print debugging information (highest verbosity)]' \
  '(-q --quiet)'{-q,--quiet}'[suppress normal output]' \
  '(-s --silent)'{-s,--silent}'[only print errors]' \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '--nocolor[print without color output]' \
  '--version[version for singularity]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'singularity command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (exec|run|shell|test)
        _arguments -s -S \
          '(-B --bind)'{-B,--bind}'[bind directory paths]:bind spec:' \
          '(-e --cleanenv)'{-e,--cleanenv}'[clean environment before running container]' \
          '(-c --contain)'{-c,--contain}'[use minimal /dev and empty other directories]' \
          '(-C --containall)'{-C,--containall}'[contain plus also contain env, PID, and IPC]' \
          '(-f --fakeroot)'{-f,--fakeroot}'[run container in new user namespace as uid 0]' \
          '--no-home[do not mount user home directory]' \
          '--no-privs[drop all privileges from root in container]' \
          '--nv[enable experimental NVIDIA support]' \
          '--rocm[enable experimental AMD ROCm support]' \
          '(-H --home)'{-H,--home}'[a home directory specification]:spec:' \
          '(-w --writable)'{-w,--writable}'[by default all Singularity containers are available as read only]' \
          '--pwd[initial working directory for payload process inside the container]:directory:' \
          '*:image:_files' && ret=0
        ;;
      (pull)
        _arguments -s -S \
          '--arch[architecture]:arch:' \
          '--dir[download images to the specified directory]:directory:_files -/' \
          '--force[overwrite image file if it exists]' \
          '--library[the library to pull from]:library:' \
          '--no-cleanup[do not clean up partial download]' \
          '*:uri:' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-F --force)'{-F,--force}'[overwrite existing image]' \
          '(-s --sandbox)'{-s,--sandbox}'[build image as sandbox format (chroot directory structure)]' \
          '(-T --notest)'{-T,--notest}'[build without running tests in %test section]' \
          '(-u --update)'{-u,--update}'[run definition over existing container (requires --sandbox)]' \
          '(-e --encrypt)'{-e,--encrypt}'[build an image with encryption]' \
          '--fakeroot[build using user namespace]' \
          '--library[container Library URL]:url:' \
          '--nv[inject host NVIDIA libraries]' \
          '--writable[build image as writable (SIF only)]' \
          '*:files:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
