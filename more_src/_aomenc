#compdef aomenc
# Documentation: aomenc --help (libaom AV1 encoder)
# Source: Alliance for Open Media AV1 reference encoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-c --cfg)'{-c+,--cfg=}'[config file]:file:_files' \
    '(-D --debug)'{-D,--debug}'[debug (deterministic output)]' \
    '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
    '--codec=[codec to use]:codec:(av1)' \
    '(-p --passes)'{-p+,--passes=}'[number of passes 1/2/3]:n:(1 2 3)' \
    '--pass=[which pass to execute]:n:(1 2 3)' \
    '--fpf=[first-pass stats file]:file:_files' \
    '--limit=[stop after N input frames]:n:' \
    '--skip=[skip first N input frames]:n:' \
    '(--good --rt --allintra)--good[Good Quality deadline]' \
    '(--good --rt --allintra)--rt[Realtime Quality deadline]' \
    '(--good --rt --allintra)--allintra[all-intra mode]' \
    '(-q --quiet)'{-q,--quiet}'[no encode progress]' \
    '(-v --verbose)'{-v,--verbose}'[show encoder parameters]' \
    '--psnr=[PSNR status line]:mode:(0 1 2)' \
    '(--webm --ivf --obu)--webm[WebM output]' \
    '(--webm --ivf --obu)--ivf[IVF output]' \
    '(--webm --ivf --obu)--obu[OBU output]' \
    '--q-hist=[show quantizer histogram (n-buckets)]:n:' \
    '--rate-hist=[show rate histogram (n-buckets)]:n:' \
    '--disable-warnings[disable warnings]' \
    '(-y --disable-warning-prompt)'{-y,--disable-warning-prompt}'[no warning prompt]' \
    '--test-decode=[test encode/decode mismatch]:mode:(off fatal warn)' \
    '1:source file:_files' \
    && ret=0

return ret
