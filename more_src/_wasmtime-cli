#compdef wasmtime

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run a wasm module'
  'compile:precompile a wasm module'
  'serve:serve a wasm http handler'
  'config:config commands'
  'explore:explore wasm module'
  'wast:run wast script'
  'help:show help'
  'objdump:dump wasm objects'
  'settings:show config settings'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wasmtime command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--invoke=[function]:fn:' \
          '--allow-precompiled[allow precompiled]' \
          '*--dir=[mapped dir]:m:_files -/' \
          '*--env=[env var]:e:' \
          '*-S+[wasi option]:s:' \
          '*-W+[wasm option]:w:' \
          '*-O+[opts]:o:' \
          '*-D+[debug option]:d:' \
          '*-C+[codegen option]:c:' \
          '--profile=[profile]:p:(perfmap jitdump vtune)' \
          '--allow-unknown-exports[allow unknown exports]' \
          '--module-name=[module name]:n:' \
          '--preload=[preload module]:m:' \
          '*: :_files -g "*.wasm *.wat *.cwasm"' && ret=0 ;;
      (compile)
        _arguments \
          '-o+[output]:file:_files' \
          '--target=[target triple]:t:' \
          '--cranelift[Cranelift]' \
          '--winch[Winch]' \
          '--asm[output asm]' \
          '*: :_files -g "*.wasm *.wat"' && ret=0 ;;
      (serve)
        _arguments \
          '--addr=[address]:addr:' \
          '*--env=[env]:e:' \
          '*--dir=[dir]:m:_files -/' \
          '*: :_files -g "*.wasm *.wat *.cwasm"' && ret=0 ;;
      (objdump)
        _arguments \
          '--all[all]' \
          '--dwarf-dump[dwarf dump]' \
          '*: :_files' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(new clear)' \
          '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
