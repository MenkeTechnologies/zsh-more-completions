#compdef 2masstofits
# Documentation: http://astrometry.net/doc/build-index.html
# convert the 2MASS PSC catalog to healpixed FITS binary tables

local ret=1

_arguments -s \
  '-h[show help]' \
  '-o+[output filename template]:output:_files' \
  '-N+[healpix nside (default 8)]:nside:' \
  '*:input file (gzipped 2MASS PSC, eg psc_aaa.gz):_files' && ret=0

return ret
