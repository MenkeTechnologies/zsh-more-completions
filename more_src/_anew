#compdef anew
# Documentation: https://man.archlinux.org/search?q=anew
# Reference accessed: 2026-05-16

# Zsh completion for anew - append lines to a file but only if they are not already in the file

_arguments -s -S \
  '-q[quiet mode - do not print new lines]' \
  '-d[do not write new items to the file, only print them]' \
  ':file:_files'
