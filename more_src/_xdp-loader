#compdef xdp-loader
# _xdp-loader — load and manage XDP programs on a network interface (xdp-project/xdp-tools)
# upstream: https://github.com/xdp-project/xdp-tools
# Subcommands + per-command flags from xdp-loader/xdp-loader.8.

_xdp-loader() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_xdp-loader_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                load)
                    _arguments \
                        '(-m --mode)'{-m+,--mode=}'[XDP attach mode]:mode:(native skb hw unspecified)' \
                        '(-p --pin-path)'{-p+,--pin-path=}'[bpffs root path under which to pin maps]:path:_files -/' \
                        '(-s --section)'{-s+,--section=}'[ELF section name to load]:section:' \
                        '(-n --prog-name)'{-n+,--prog-name=}'[BPF program name within the file]:name:' \
                        '(-P --prio)'{-P+,--prio=}'[program load priority (default from metadata or 50)]:n:' \
                        '(-A --actions)'{-A+,--actions=}'[chain-call actions]:actions:' \
                        '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
                        '1:ifname:_net_interfaces' \
                        '*:program file:_files -g "*.(o|bpf)"' && ret=0 ;;
                unload)
                    _arguments \
                        '(-i --id)'{-i+,--id=}'[program id to unload]:id:' \
                        '(-a --all)'{-a,--all}'[unload all XDP programs on the interface]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                status)
                    _arguments \
                        '*'{-v,--verbose}'[increase verbosity]' && ret=0 ;;
                features)
                    _arguments \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                clean)
                    _arguments \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:ifname (optional):_net_interfaces' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xdp-loader_commands] )) ||
_xdp-loader_commands() {
    local -a commands
    commands=(
        'load:load an XDP program on an interface'
        'unload:unload an XDP program from an interface'
        'status:show current XDP program status across interfaces'
        'features:show XDP features supported by the NIC'
        'clean:clean detached program links under the bpffs XDP directory'
        'help:show available commands'
    )
    _describe -t commands 'xdp-loader command' commands
}

_xdp-loader "$@"
