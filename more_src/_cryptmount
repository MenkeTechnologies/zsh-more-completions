#compdef cryptmount
# Documentation: https://manpages.debian.org/bookworm/cryptmount/cryptmount.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-m --mount)'{-m,--mount}'[mount target]' \
  '(-u --unmount)'{-u,--unmount}'[unmount target]' \
  '(-l --list)'{-l,--list}'[list available targets]' \
  '(-S --status)'{-S,--status}'[show mount status]' \
  '(-c --change-password)'{-c,--change-password}'[change key password]' \
  '(-g --generate-key)'{-g,--generate-key}'+[generate key of given size]:size_kb:' \
  '(-a --all)'{-a,--all}'[act on all targets]' \
  '(-B --system-boot)'{-B,--system-boot}'[setup targets with bootaction parameter]' \
  '(-Q --system-shutdown)'{-Q,--system-shutdown}'[close-down bootaction targets]' \
  '(-n --safetynet)'{-n,--safetynet}'[close-down mounted targets during shutdown]' \
  '(-w --passwd-fd)'{-w,--passwd-fd}'+[read password from FD]:fd:' \
  '(-p --prepare)'{-p,--prepare}'[prepare device-mapper and loopback devices]' \
  '(-r --release)'{-r,--release}'[release device-mapper and loopback devices]' \
  '(-e --reuse-key)'{-e,--reuse-key}'[reuse existing key]' \
  '(-f --config-fd)'{-f,--config-fd}'+[read configuration from FD]:fd:' \
  '(-k --key-managers)'{-k,--key-managers}'[list available key protection formats]' \
  '(-s --swapon)'{-s,--swapon}'[enable target for paging/swapping]' \
  '(-x --swapoff)'{-x,--swapoff}'[disable target for paging/swapping]' \
  '*:target:' && ret=0

return ret
