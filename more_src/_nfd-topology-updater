#compdef nfd-topology-updater
# _nfd-topology-updater — NFD per-node topology updater (kubernetes-sigs/node-feature-discovery)
# upstream: https://github.com/kubernetes-sigs/node-feature-discovery
# Flags from cmd/nfd-topology-updater/main.go on tip.

_nfd-topology-updater() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-oneshot[run once and exit instead of looping]' \
        '-no-publish[disable NodeResourceTopology publishing]' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-port=[gRPC server bind port]:port:' \
        '-sleep-interval=[topology refresh interval]:dur:' \
        '-watch-namespace=[watched pod namespace (* = all)]:ns:' \
        '-kubelet-config-uri=[kubelet config URI for podresources discovery]:uri:' \
        '-api-auth-token-file=[bearer token file for kubelet API]:file:_files' \
        '-podresources-socket=[kubelet PodResources Unix socket path]:path:_files' \
        '-config=[nfd-topology-updater configuration file]:file:_files' \
        '-pods-fingerprint=[emit Pod-set fingerprint]:bool:(true false)' \
        '-kubelet-state-dir=[kubelet state directory to watch]:dir:_files -/' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]'
}

_nfd-topology-updater "$@"
