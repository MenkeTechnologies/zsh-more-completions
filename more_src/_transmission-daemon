#compdef transmission-daemon
# _transmission-daemon — Transmission BitTorrent daemon (transmission/transmission)
# upstream: https://github.com/transmission/transmission
# Flags from daemon/daemon.cc (tr_option array).

_transmission-daemon() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '(- *)'{-V,--version}'[show version]'
        '(-a --allowed)'{-a+,--allowed=}'[allowed IP list]:list:'
        '(-b --blocklist)'{-b,--blocklist}'[enable peer blocklists]'
        '(-B --no-blocklist)'{-B,--no-blocklist}'[disable peer blocklists]'
        '(-c --watch-dir)'{-c+,--watch-dir=}'[watch directory for new torrent files]:dir:_files -/'
        '(-C --no-watch-dir)'{-C,--no-watch-dir}'[disable the watch-dir]'
        '--incomplete-dir=[store incomplete torrents here]:dir:_files -/'
        '--no-incomplete-dir[do not use a separate incomplete dir]'
        '(-d --dump-settings)'{-d,--dump-settings}'[dump settings and exit]'
        '--default-trackers=[default tracker list for public torrents]:list:'
        '(-e --logfile)'{-e+,--logfile=}'[write log messages to file]:file:_files'
        '(-f --foreground)'{-f,--foreground}'[run in foreground (no daemonize)]'
        '(-g --config-dir)'{-g+,--config-dir=}'[configuration directory]:dir:_files -/'
        '(-p --port)'{-p+,--port=}'[RPC port (default 9091)]:port:'
        '(-t --auth)'{-t,--auth}'[require RPC authentication]'
        '(-T --no-auth)'{-T,--no-auth}'[do not require RPC authentication]'
        '(-u --username)'{-u+,--username=}'[RPC username]:user:'
        '(-v --password)'{-v+,--password=}'[RPC password]:password:'
        '--log-level=[log level]:level:(critical error warn info debug trace)'
        '(-w --download-dir)'{-w+,--download-dir=}'[default download directory]:dir:_files -/'
        '--paused[pause all torrents on startup]'
        '(-o --dht)'{-o,--dht}'[enable DHT]'
        '(-O --no-dht)'{-O,--no-dht}'[disable DHT]'
        '(-y --lpd)'{-y,--lpd}'[enable local peer discovery]'
        '(-Y --no-lpd)'{-Y,--no-lpd}'[disable local peer discovery]'
        '(-P --peerport)'{-P+,--peerport=}'[port for incoming peers (default 51413)]:port:'
        '(-m --portmap)'{-m,--portmap}'[enable NAT-PMP / UPnP portmapping]'
        '(-M --no-portmap)'{-M,--no-portmap}'[disable portmapping]'
        '(-L --peerlimit-global)'{-L+,--peerlimit-global=}'[overall peer limit (default 200)]:n:'
        '(-l --peerlimit-torrent)'{-l+,--peerlimit-torrent=}'[per-torrent peer limit (default 50)]:n:'
        '--encryption-required[encrypt all peer connections]'
        '--encryption-preferred[prefer encrypted peer connections]'
        '--encryption-tolerated[prefer unencrypted peer connections]'
        '(-r --rpc-bind-address)'{-r+,--rpc-bind-address=}'[RPC bind address]:addr:'
        '--sequential-download[enable sequential download by default]'
        '--no-sequential-download[disable sequential download by default]'
        '(-x --pid-file)'{-x+,--pid-file=}'[write PID file]:file:_files'
    )
    _arguments -s $args
}

_transmission-daemon "$@"
