#compdef ax
# Documentation: https://github.com/egnyte/ax/blob/master/README.md
# ax - query structured logs (Kibana, Cloudwatch, Stackdriver, Docker, JSON files)

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '(-f --follow)'{-f,--follow}'[keep running and show new results as they come in]' \
  '--env=[environment to use]:env' \
  '--docker=[query logs for Docker containers matching pattern]:pattern' \
  '*--where=[filter logs by attribute value]:filter' \
  '*--where-exists=[filter for logs containing a field]:field' \
  '*--where-not-exists=[filter for logs without a field]:field' \
  '*--where-one-of=[filter for logs matching any value in a set]:values' \
  '*--where-not-one-of=[exclude logs matching values in a set]:values' \
  '*--select=[choose specific attributes to display]:attribute' \
  '--output=[output format]:format:(text json pretty-json yaml)' \
  '--completion-script-bash[generate bash completion script]' \
  '--completion-script-zsh[generate zsh completion script]' \
  '1:command:(query env upgrade)' \
  '*::arg:_files' && ret=0

return ret
