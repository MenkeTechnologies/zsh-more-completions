#compdef express

# Zsh completion for Express.js generator

_express-generator() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-e[add ejs engine support]' \
    '--ejs[add ejs engine support]' \
    '--pug[add pug engine support]' \
    '--hbs[add handlebars engine support]' \
    '-H[add hogan.js engine support]' \
    '--hogan[add hogan.js engine support]' \
    '-v+[add view engine support]:engine:(ejs hbs hjs jade pug twig vash dust)' \
    '--view=[add view engine support]:engine:(ejs hbs hjs jade pug twig vash dust)' \
    '--no-view[generate without view engine]' \
    '-c+[add stylesheet support]:engine:(less stylus compass sass)' \
    '--css=[add stylesheet support]:engine:(less stylus compass sass)' \
    '--git[add .gitignore]' \
    '-f[force on non-empty directory]' \
    '--force[force on non-empty directory]' \
    '-h[display help]' \
    '--help[display help]' \
    '1:destination:_files -/' \
    && ret=0

  return ret
}

_express-generator "$@"
