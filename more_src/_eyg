#compdef eyg
# ============================================================================
# _eyg — zsh completion for EYG (Edit Your Genuine), Peter Saxton's
#        capability-secure scripting language for humans and agents
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/CrowdHailer/eyg-lang
#   Author     : Peter Saxton  (CrowdHailer / midas.run)
#   License    : Apache-2.0
#   Language   : Gleam (CLI + compiler) / EYG (source files / IR)
#   Package    : packages/gleam_cli  → npm `eyg_cli` v0.0.2
#   Binary     : eyg  (install.sh downloads platform-native binary
#                from GitHub releases as `eyg-{linux,macos}-{x64,arm64}`
#                and installs to `~/.local/bin/eyg`)
#   Last push  : 2026-06-02
#   Website    : https://eyg.run
#
# WHAT IT IS
#   EYG (Edit Your Genuine) is "the safest scripting language for you,
#   or your agent" — a capability-secure, content-addressed,
#   structurally-typed scripting language with a hub-mediated package
#   ecosystem.  Source files (`.eyg` text or `.json` IR) are parsed
#   into an immutable AST, typechecked, and either evaluated under a
#   sandbox with explicit handler capabilities, or compiled to
#   JavaScript for deployment.  Modules are content-addressed via CID
#   (referenced as `#<cid>`) and may be published to the EYG hub
#   under a human-readable package name (referenced as `@<pkg>`).
#   The CLI also exposes a hub-aware REPL (`eyg shell`) and signatory
#   key management for publishing modules.
#
# CLI ARGUMENT GRAMMAR  (verbatim from packages/gleam_cli/src/eyg_cli.gleam
#                       main + packages/gleam_cli/src/eyg/cli/args.gleam
#                       pure pattern-match parser)
#   eyg [<COMMAND> [<ARGS>]]
#
#   Source-input forms (accepted wherever <SOURCE> appears below):
#     <FILE>                Read source from filesystem path
#     -, --stdin            Read source from stdin
#     -c, --code <CODE>     Inline source code
#     #<CID>                Module referenced by content id
#     @<PKG>                Module referenced by published package
#
#   Commands:
#     (no args)             Start the interactive shell
#     shell [<SOURCE>]      Start shell with given file/module as config
#     run <SOURCE>          Run EYG source under the default runtime
#     script <SOURCE> [ARGS...]
#                           Run as a script with positional CLI args
#                           (also implicit when first arg is <FILE>,
#                            #<CID>, or @<PKG>)
#     eval <SOURCE>         Evaluate an expression (no side effects)
#     check <SOURCE>        Type-check a script
#     compile <SOURCE>      Compile a script to JavaScript
#     share <FILE>          Share an IR module with the hub
#     fetch <CID>           Fetch a module by content id
#     publish <PKG> <FILE>  Publish a module under a package name
#     signatory initial <NAME>
#                           Create a signatory principal called <NAME>
#     help, --help, -h      Show the usage banner
#     version, --version, -V
#                           Show the eyg version
#
#   Environment variable:
#     EYG_ORIGIN            Override the hub origin
#                           (default: https://eyg.run)
#
# LANGUAGE-CORPUS POSITION
#   EYG is the 150th programming language entry in this completion
#   corpus — round-number language milestone! — closing the 3+1
#   micro-cycle that began at R869 (_wrpc-wasmtime / async-nats 0.49
#   Rust=125 OPENS Axis 70 NATS.io Client Library) and continued
#   through R870 (_remoteAudio / nats.go v1.41.2 Go=125) and R871
#   (_soketi / nats.js ^2.7.1 TS-Node=125 CLOSES Axis 70 at 1/1/1
#   three-language symmetry — triple-125 landmark and 63rd axis
#   closed).  EYG joins Roto (R868 149th), Pipefish (R864 148th),
#   Mochi (R860 147th), Oden (R856 146th), Hop (R852 145th), Lustre
#   via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ (R840 142nd),
#   Granule (R836 141st), Sixten (R832 140th — round-number language
#   milestone), Imba (R828 139th), Tao (R824 138th), Dada (R820
#   137th), Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `eyg` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_eyg() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help,help}'[show help]' \
        '(- *)'{-V,--version,version}'[show version]' \
        '1: :_eyg_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                shell|run|eval|check|compile|script)
                    _eyg_source_then_rest && ret=0 ;;
                share)
                    _arguments \
                        ':IR module file:_files' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                fetch)
                    _arguments \
                        ':content id (CID):' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                publish)
                    _arguments \
                        ':package name:' \
                        ':module file:_files' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                signatory)
                    _arguments \
                        '1:signatory subcommand:(initial)' \
                        ':signatory name:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_eyg_source_then_rest] )) ||
_eyg_source_then_rest() {
    _arguments \
        '(-c --code)'{-c+,--code=}'[inline EYG source code]:code:' \
        '(- 1)--stdin[read source from stdin]' \
        '(- 1)-[read source from stdin]' \
        '(- *)'{-h,--help}'[help]' \
        '*:source (file / #CID / @pkg / script args):_files -g "*.{eyg,json}"'
}

(( $+functions[_eyg_commands] )) ||
_eyg_commands() {
    local -a commands
    commands=(
        'shell:start the interactive EYG shell'
        'run:run EYG source under the default runtime'
        'script:run as a script with positional CLI args'
        'eval:evaluate an expression with no side effects'
        'check:type check a script or module'
        'compile:compile a script to JavaScript'
        'share:share an IR module with the EYG hub'
        'fetch:fetch a module by content id (CID)'
        'publish:publish a module under a package name'
        'signatory:manage signatory principals (subcommand: initial)'
    )
    _describe -t commands 'eyg command' commands
}

_eyg "$@"
