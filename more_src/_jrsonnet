#compdef jrsonnet
# Documentation: https://github.com/CertainLach/jrsonnet
# jrsonnet - a Rust implementation of the Jsonnet data templating language

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version]' \
  '(-e --exec)'{-e,--exec}'[treat input as code, evaluate it instead of reading a file]' \
  '(-o --output-file)'{-o+,--output-file=}'[write to the output file rather than stdout]:file:_files' \
  '(-y --yaml-stream)'{-y,--yaml-stream}'[write output as a YAML stream of JSON documents]' \
  '(-S --string)'{-S,--string}'[expect a string, manifest as plain text]' \
  '(-s --max-stack)'{-s+,--max-stack=}'[maximal allowed number of stack frames]:n:' \
  '(-t --max-trace)'{-t+,--max-trace=}'[max length of stack trace before cropping]:n:' \
  '*'{-J+,--jpath=}'[library search dirs (right-most wins)]:path:_files -/' \
  '*'{-V+,--ext-str=}'[provide external variable as a string]:var\=val:' \
  '*--ext-str-file=[provide external variable as a string from file]:var\=file:' \
  '*--ext-code=[provide external variable as Jsonnet code]:var\=code:' \
  '*--ext-code-file=[provide external variable as code from file]:var\=file:' \
  '*'{-A+,--tla-str=}'[provide top-level argument as a string]:var\=val:' \
  '*--tla-str-file=[provide top-level argument as a string from file]:var\=file:' \
  '*--tla-code=[provide top-level argument as Jsonnet code]:var\=code:' \
  '*--tla-code-file=[provide top-level argument as code from file]:var\=file:' \
  '--gc-collect-on-exit[do not skip the garbage collector on exit]' \
  '--gc-print-stats[print garbage collector stats before exit]' \
  '1:jsonnet file:_files -g "*.jsonnet *.libsonnet"' && ret=0

return ret
