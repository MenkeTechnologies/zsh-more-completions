#compdef arti
# _arti — Tor Project arti CLI for the Rust implementation of Tor providing SOCKS5 proxy hidden services onion services running clients with configurable circuits guards directory cache (torproject team, Rust); clap
# upstream: https://gitlab.torproject.org/tpo/core/arti

_arti() {
    local -a sub=(
        'proxy:run SOCKS proxy'
        'config:show config'
        'hsc:hidden service client'
        'hss:hidden service server'
        'keys:key management'
        'rpc:RPC operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l+[log level]:l:(off error warn info debug trace)' \
        '--log-level=+[log level]:l:(off error warn info debug trace)' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '-o+[option=value]:str:' \
        '--option=+[option=value]:str:' \
        '--disable-fs-permission-checks[disable fs perm checks]' \
        '--no-trustworthy-permissions[no trustworthy permissions]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--state-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arti subcommand' sub ;;
        args)
            case $words[1] in
                proxy) _arguments \
                    '-p+[socks port]:n:' \
                    '--socks-port=+[socks port]:n:' \
                    '--dns-port=+[dns port]:n:' ;;
                hsc) _arguments \
                    '1:action:(prepare-stealth-client-restricted-discovery list)' ;;
                hss) _arguments \
                    '1:action:(onion-name get-key list)' \
                    '--nickname=+[name]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_arti "$@"
