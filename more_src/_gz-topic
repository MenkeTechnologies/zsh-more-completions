#compdef gz-topic
# Documentation: https://gazebosim.org/docs
# Gazebo Transport topic introspection tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-l --list)'{-l,--list}'[list all topics]' \
  '(-i --info)'{-i,--info}'[get info about a topic]' \
  '(-e --echo)'{-e,--echo}'[output topic data to screen]' \
  '(-f --frequency)'{-f,--frequency}'[calculate topic publishing frequency]' \
  '--json-output[output messages in JSON format]' \
  '(-t --topic)'{-t,--topic}'=[name of a topic]:topic' \
  '(-m --msgtype)'{-m,--msgtype}'=[type of message to publish]:type' \
  '(-d --duration -n --num)'{-d,--duration}'=[duration in seconds to run]:seconds' \
  '(-n --num -d --duration)'{-n,--num}'=[number of messages to echo before exit]:count' \
  '(-p --pub)'{-p,--pub}'=[publish a message with provided data]:data' && ret=0

return ret
