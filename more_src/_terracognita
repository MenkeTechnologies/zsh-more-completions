#compdef terracognita
# Documentation: https://github.com/cycloidio/terracognita
# terracognita - read from existing cloud providers and generate IaC for Terraform

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--hcl=[output file for the HCL]:file:_files' \
  '--tfstate=[output file for Terraform state]:file:_files' \
  '--module=[generate Terraform modules when importing]:path:_files -/' \
  '--module-variables=[attributes to convert to module variables]:file:_files' \
  '*--include=[include specific resources by Terraform name]:resource' \
  '*--exclude=[exclude specific resources by Terraform name]:resource' \
  '1:command:(aws google azurerm vsphere version)' \
  '*::arg:_default' && ret=0

return ret
