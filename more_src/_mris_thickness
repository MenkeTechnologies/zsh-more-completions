#compdef mris_thickness
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_thickness
# FreeSurfer compute cortical thickness from white and pial surfaces

local ret=1

_arguments -s -S \
  '-max[maximum threshold for thickness (default 5mm)]:max:' \
  '1:subject name:' \
  '2:hemisphere:(lh rh)' \
  '3:thickness file:_files' && ret=0

return ret
