#compdef env0

# env0 CLI completion

_env0_subcommands() {
  local -a subcmds=(
    'deploy:Deploy an environment'
    'destroy:Destroy an environment'
    'approve:Approve a deployment'
    'cancel:Cancel a deployment'
    'configure:Configure the CLI'
    'init:Initialize a new project'
    'plan:Run a plan'
    'status:Show deployment status'
    'login:Log in to env0'
    'whoami:Show current identity'
    'version:Show version'
  )
  _describe -t commands 'env0 subcommand' subcmds
}

_env0() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--api-key=[API key]:api key' \
    '--api-secret=[API secret]:api secret' \
    '--project-id=[project ID]:project id' \
    '--template-id=[template ID]:template id' \
    '--environment-id=[environment ID]:environment id' \
    '1:subcommand:_env0_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        deploy)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--api-key=[API key]:api key' \
            '--api-secret=[API secret]:api secret' \
            '--project-id=[project ID]:project id' \
            '--template-id=[template ID]:template id' \
            '--environment-id=[environment ID]:environment id' \
            '--revision=[git revision]:revision' \
            '--requires-approval[require approval before deploy]'
          ;;
        destroy)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--api-key=[API key]:api key' \
            '--api-secret=[API secret]:api secret' \
            '--environment-id=[environment ID]:environment id'
          ;;
        approve|cancel)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--api-key=[API key]:api key' \
            '--api-secret=[API secret]:api secret' \
            '--deployment-id=[deployment ID]:deployment id'
          ;;
        plan)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--api-key=[API key]:api key' \
            '--api-secret=[API secret]:api secret' \
            '--project-id=[project ID]:project id' \
            '--template-id=[template ID]:template id' \
            '--environment-id=[environment ID]:environment id'
          ;;
        status)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--api-key=[API key]:api key' \
            '--api-secret=[API secret]:api secret' \
            '--environment-id=[environment ID]:environment id'
          ;;
        login)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        configure)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        init)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_env0 "$@"
