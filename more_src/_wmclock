#compdef wmclock
# Documentation: https://man.archlinux.org/search?q=wmclock
# Reference accessed: 2026-05-16

# wmclock: simple Window Maker dockapp clock
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-display[X display]:display:' \
  '-bg[background color]:color:' \
  '-fg[foreground color]:color:' \
  '-position[geometry]:WxH+X+Y:' \
  '-version[show version]' \
  '*::wmclock args:_files' && ret=0
return ret
