#compdef wmclock
# Documentation: https://manpages.debian.org/bookworm/wmclock/wmclock.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian bookworm wmclock(1) man page OPTIONS list.

# wmclock: simple Window Maker dockapp clock
local curcontext="$curcontext" ret=1
_arguments -C \
  '-12[display time in 12-hour format with am/pm]' \
  '-24[display time in 24-hour format (default)]' \
  '-year[show current year in LED display instead of time]' \
  '-noblink[disable blinking separator between hours and minutes]' \
  '-interval[blink cycle in seconds (default 2)]:seconds' \
  '-version[display wmclock version]' \
  '-exe[execute command on mouse button press]:command:_command_names' \
  '-led[LED display foreground color]:color' \
  '-monthxpm[load month abbreviations from XPM file]:file:_files -g "*.xpm(-.)"' \
  '-weekdayxpm[load weekday abbreviations from XPM file]:file:_files -g "*.xpm(-.)"' \
  '-shape[obsolete, accepted but has no effect]' \
  '-iconic[obsolete, accepted but has no effect]' && ret=0
return ret
