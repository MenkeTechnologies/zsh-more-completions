#compdef ratpoison
# Minimalist window manager

local ret=1

_arguments -s -S \
  '-c[send command to running instance]:command:' \
  '-d[specify display]:display:' \
  '-s[specify screen]:screen number:' \
  '-f[specify config file]:config file:_files' \
  '-i[interactive command mode]' \
  '-v[show version]' \
  '--version[show version]' \
  '-h[show help]' \
  '--help[show help]' && ret=0

return ret
