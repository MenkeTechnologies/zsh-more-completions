#compdef wg-meshconf
# Documentation: https://github.com/k4yt3x/wg-meshconf
# wg-meshconf - WireGuard full mesh configuration generator

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --database)'{-d,--database}'=[database file path]:file:_files' \
  '1:command:(init addpeer updatepeer delpeer showpeers genconfig)' \
  '*::arg:->args' && ret=0

return ret
