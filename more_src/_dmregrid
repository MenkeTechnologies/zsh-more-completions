#compdef dmregrid
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmregrid.html
# Regrid (rebin, rotate, shift) a stack of images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input dataset or stack of images]:infile:_files' \
  'outfile=[output file name]:outfile:_files' \
  'bin=[binning specification]:bin:' \
  'rotangle=[CCW rotation angle in degrees]:rotangle:' \
  'rotxcenter=[x-coordinate of rotation center]:rotxcenter:' \
  'rotycenter=[y-coordinate of rotation center]:rotycenter:' \
  'xoffset=[x-offset of regridded image]:xoffset:' \
  'yoffset=[y-offset of regridded image]:yoffset:' \
  'npts=[subgrid sample points or 0 for exact]:npts:' \
  'coord_sys=[logical or physical coordinates]:coord_sys:(logical physical)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
