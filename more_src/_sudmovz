#compdef sudmovz
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/dip_moveout/sudmovz.c
# DMO for V(Z) media for common-offset gathers

local ret=1

_arguments -s -S \
  'cdpmin=[minimum cdp for which to apply DMO]:cdpmin' \
  'cdpmax=[maximum cdp for which to apply DMO]:cdpmax' \
  'dxcdp=[distance between adjacent cdp bins (m)]:dxcdp' \
  'noffmix=[number of offsets to mix]:noffmix' \
  'vfile=[binary file containing interval velocities (m/s)]:file:_files' \
  'tdmo=[times corresponding to interval velocities in vdmo (s)]:tdmo' \
  'vdmo=[interval velocities corresponding to times in tdmo (m/s)]:vdmo' \
  'fmax=[maximum frequency in input traces (Hz)]:fmax' \
  'smute=[stretch mute used for NMO correction]:smute' \
  'speed=[twist this knob for speed]:speed' \
  'verbose=[=1 for diagnostic print]:verbose' \
  '*:file:_files' && ret=0


return ret
