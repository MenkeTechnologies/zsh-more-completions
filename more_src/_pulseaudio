#compdef pulseaudio

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dump-conf[dump merged config]' \
  '--dump-modules[list loadable modules]' \
  '--dump-resample-methods[list resamplers]' \
  '--cleanup-shm[remove stale SHM segments]' \
  '--start[start daemon if not running]' \
  '(-k --kill)'{-k,--kill}'[kill running daemon]' \
  '--check[exit-code probe for liveness]' \
  '--system=[run as system instance]:bool:(true false)' \
  '(-D --daemonize)'{-D,--daemonize=}'[detach from terminal]:bool:(true false)' \
  '--fail=[fail on script error]:bool:(true false)' \
  '--high-priority=[try elevated nice]:bool:(true false)' \
  '--realtime=[try realtime scheduling]:bool:(true false)' \
  '--disallow-module-loading=[block module loads]:bool:(true false)' \
  '--disallow-exit=[block user exit]:bool:(true false)' \
  '--exit-idle-time=[idle exit secs]:secs:' \
  '--scache-idle-time=[scache idle secs]:secs:' \
  '--log-level=[log level]:level:(0 1 2 3 4)' \
  '*'{-v,--verbose}'[bump verbosity]' \
  '--log-target=[log destination]:target:(auto syslog journal stderr file: newfile:)' \
  '--log-meta=[include source location]:bool:(true false)' \
  '--log-time=[include timestamps]:bool:(true false)' \
  '--log-backtrace=[log stack frames]:n:' \
  '(-p --dl-search-path)'{-p,--dl-search-path=}'[plugin search path]:dir:_files -/' \
  '--resample-method=[default resampler]:method:' \
  '--use-pid-file=[write PID file]:bool:(true false)' \
  '--no-cpu-limit=[disable CPU limiter]:bool:(true false)' \
  '--disable-shm=[disable SHM transport]:bool:(true false)' \
  '--enable-memfd=[enable memfd transport]:bool:(true false)' \
  '*'{-L,--load=}'[load module]:module args:' \
  '(-F --file)'{-F,--file=}'[run script]:file:_files' \
  '-C[command interpreter on stdin/stdout]' \
  '-n[no default script]'
