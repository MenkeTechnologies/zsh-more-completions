#compdef calligraflow
# Documentation: https://calligra.org/flow/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Calligra Flow: flowchart/diagram editor (Qt/KDE/Calligra suite)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help and exit]' \
  '(- *)--help-all[show all Qt/KF help options]' \
  '(- *)--help-kde[show KDE specific options]' \
  '(- *)--help-qt[show Qt specific options]' \
  '(- *)--help-calligra[show Calligra specific options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '*:document:_files -g "*(.odg|.odp|.svg|.vsd)"' && ret=0
return ret
