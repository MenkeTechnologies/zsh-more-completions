#compdef IonQuant
# Documentation: https://github.com/Nesvilab/IonQuant/blob/master/README.md
# IonQuant: label-free MS1 quantification tool for proteomics

local ret=1

_arguments -s -S \
  '*--specdir[directory containing spectral files (d/mzml/mzxml/raw/quantindex)]:dir:_files -/' \
  '*--psm[path to Philosopher psm.tsv]:file:_files' \
  '--filelist[file containing flags]:file:_files' \
  '--perform-ms1quant[perform MS1 quantification (0/1)]:flag:(0 1)' \
  '--perform-isoquant[perform isobaric labeling quantification (0/1)]:flag:(0 1)' \
  '--isotol[MS2 tolerance in ppm]:ppm:' \
  '--isolevel[isobaric quant level (2=MS2 3=MS3 4=ZOOM-HR)]:level:(2 3 4)' \
  '--isotype[isobaric quant type (iTRAQ/TMT/...)]:type:' \
  '--annotation[annotation file for isobaric quantification]:file:_files' \
  '--site-reports[generate site reports (0/1)]:flag:(0 1)' \
  '--msstats[generate MSstats input files (0/1)]:flag:(0 1)' \
  '--threads[number of threads (0=all)]:n:' \
  '--mztol[MS1 tolerance in PPM]:ppm:' \
  '--imtol[1/K0 tolerance]:tol:' \
  '--rttol[retention time tolerance (min)]:min:' \
  '--multidir[output directory for multi-experimental result]:dir:_files -/' \
  '--normalization[normalize intensities across runs (0/1)]:flag:(0 1)' \
  '--minisotopes[minimum isotopes in feature extraction]:n:' \
  '--minscans[minimum MS1 scans in feature extraction]:n:' \
  '--minions[minimum ions for MaxLFQ protein quant]:n:' \
  '--excludemods[excluded modifications]:mods:' \
  '--maxlfq[calculate MaxLFQ intensity (0/1)]:flag:(0 1)' \
  '--ibaq[calculate iBAQ intensity (0/1)]:flag:(0 1)' \
  '--minexps[minimum experiments to pick an ion]:n:' \
  '--minfreq[minimum ion frequency for protein quant]:f:' \
  '--tp[number of ions per protein (0=all)]:n:' \
  '--mbr[perform match-between-runs (0/1)]:flag:(0 1)' \
  '--mbrrttol[match-between-runs RT tolerance (min)]:min:' \
  '--mbrimtol[match-between-runs 1/K0 tolerance]:tol:' \
  '--mbrtoprun[max donor runs per acceptor run]:n:' \
  '--mbrmincorr[min donor/acceptor correlation]:corr:' \
  '--ionmobility[data has ion mobility (0/1)]:flag:(0 1)' \
  '--ionfdr[transferred ion FDR threshold]:fdr:' \
  '--peptidefdr[transferred peptide FDR threshold]:fdr:' \
  '--proteinfdr[transferred protein FDR threshold]:fdr:' \
  '--light[light labelling mass]:mass:' \
  '--medium[medium labelling mass]:mass:' \
  '--heavy[heavy labelling mass]:mass:' \
  '--formula[formula of the modifications used]:formula:' \
  '--requantify[re-quantify unidentified features (0/1)]:flag:(0 1)' \
  '--writeindex[write indexed file to disk (0/1)]:flag:(0 1)' \
  '--locprob[localization probability threshold]:p:' \
  '--uniqueness[peptide-protein uniqueness (0/1/2)]:mode:(0 1 2)' \
  '--intensitymode[intensity calc mode (0=apex 1=area 2=auto)]:mode:(0 1 2)' \
  '--modlist[file listing modification masses]:file:_files' \
  '*:psm file:_files' && ret=0

return ret
