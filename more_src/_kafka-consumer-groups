#compdef kafka-consumer-groups

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--list[List all consumer groups]'
    '--describe[Describe consumer group and list offset lag]'
    '--delete[Delete consumer group]'
    '--group[Consumer group ID]:group:'
    '--all-groups[Apply to all consumer groups]'
    '--topic[Topic name]:topic:'
    '--all-topics[Apply to all topics]'
    '--members[Describe members of the group]'
    '--offsets[Describe the group and list all topic partitions and their offsets]'
    '--verbose[Provide additional information if available]'
    '--state[Describe the group state]:state:(Stable Empty Dead PreparingRebalance CompletingRebalance)'
    '--reset-offsets[Reset offsets of consumer group]'
    '--delete-offsets[Delete offsets of consumer group]'
    '--to-datetime[Reset offsets to offset from datetime]:datetime:'
    '--by-duration[Reset offsets by duration from current timestamp]:duration:'
    '--to-earliest[Reset offsets to earliest offset]'
    '--to-latest[Reset offsets to latest offset]'
    '--to-current[Reset offsets to current offset]'
    '--to-offset[Reset offsets to a specific offset]:offset:'
    '--shift-by[Reset offsets shifting by n]:n:'
    '--from-file[Reset offsets from a CSV file]:file:_files'
    '--execute[Execute operation (needed with --reset-offsets)]'
    '--export[Export operation results to a CSV file]'
    '--dry-run[Display results without executing (default for --reset-offsets)]'
    '--type[Group type]:type:(consumer classic)'
    '--timeout[Timeout in ms for operations]:ms:'
)

_arguments -s -S $arguments
