#compdef ar
# Documentation: ar usage (BSD / Darwin ar(1))
# Source: ar — create / modify / extract from archives (libfoo.a).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d -m -p -q -r -t -x)-d[delete files from archive]' \
    '(-d -m -p -q -r -t -x)-m[move files within archive]' \
    '(-d -m -p -q -r -t -x)-p[print archive contents to stdout]' \
    '(-d -m -p -q -r -t -x)-q[quickly append files to archive]' \
    '(-d -m -p -q -r -t -x)-r[replace or add files to archive]' \
    '(-d -m -p -q -r -t -x)-t[print table of contents]' \
    '(-d -m -p -q -r -t -x)-x[extract files from archive]' \
    '(-a -b -i)-a[place file after positioning member]' \
    '(-a -b -i)-b[place file before positioning member]' \
    '(-a -b -i)-i[same as -b]' \
    '-c[suppress diagnostic when creating archive]' \
    '-o[preserve original mtime when extracting]' \
    '-T[use truncated 14-char filenames]' \
    '-L[follow symlinks when archiving]' \
    '-s[update archive symbol table (run ranlib)]' \
    '-u[only newer files when replacing]' \
    '-v[verbose]' \
    '*:archive then files:_files -g "*.{a,o}"' \
    && ret=0

return ret
