#compdef openrct2
# Documentation: https://github.com/OpenRCT2/OpenRCT2/blob/develop/src/openrct2-cli/CommandLine.cpp
# Reference accessed: 2026-05-16
# Verified: upstream OpenRCT2/OpenRCT2 src/openrct2/cmdline/ command
# definitions (RootCommands table) and CommandLineArgEnumerator.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --all-clients, --no-network-broadcast,
# --silent-breakpoints flags (not in upstream).

# openrct2: open-source RollerCoaster Tycoon 2
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'edit:open scenario editor'
  'intro:play intro video'
  'sprite:sprite manipulation'
  'screenshot:take screenshot of save'
  'benchgfx:benchmark rendering'
  'benchsprite:benchmark sprite drawing'
  'simulate:simulate a saved game'
  'join:join a network server'
  'host:host a network server'
  'set-rct1:set rct1 path'
  'set-rct2:set rct2 path'
  'register-server:register server with master list'
  'convert:convert SV4/SC4/SV6/SC6 save'
  'scan-objects:scan custom objects'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--port=[network port]:port:' \
  '--address=[bind address]:addr:' \
  '--password=[server password]:pw:' \
  '--user-data-path=[user data path]:dir:_files -/' \
  '--openrct-data-path=[openrct2 data path]:dir:_files -/' \
  '--rct1-data-path=[RCT1 data path]:dir:_files -/' \
  '--rct2-data-path=[RCT2 data path]:dir:_files -/' \
  '--headless[run with no GUI]' \
  '--silent-breakpoints[silent breakpoints]' \
  '--verbose[increase log verbosity]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'openrct2 command' commands && ret=0 ;;
  (args)
    _arguments \
      '*:file:_files -g "*.(sv4|sc4|sv6|sc6|park)(-.)"' && ret=0
    ;;
esac

return ret
