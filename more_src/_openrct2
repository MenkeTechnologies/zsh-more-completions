#compdef openrct2

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'edit:open scenario editor'
  'intro:play intro video'
  'sprite:sprite manipulation'
  'screenshot:take screenshot'
  'simulate:simulate a saved game'
  'set-rct1:set rct1 path'
  'set-rct2:set rct2 path'
  'register-server:register server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--password=+[server password]:pw:' \
  '--port=+[server port]:port:' \
  '--all-clients[all clients allowed]' \
  '--no-network-broadcast[no broadcast]' \
  '--silent-breakpoints[silent breakpoints]' \
  '--user-data-path=+[user data path]:dir:_files -/' \
  '--openrct-data-path=+[openrct data path]:dir:_files -/' \
  '--rct2-data-path=+[rct2 data path]:dir:_files -/' \
  '--rct1-data-path=+[rct1 data path]:dir:_files -/' \
  '--verbose[verbose]' \
  '--headless[no display]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'openrct2 command' commands && ret=0 ;;
esac

return ret
