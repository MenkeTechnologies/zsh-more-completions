#compdef dnscache
# _dnscache — djbdns dnscache (recursive DNS resolver: walks from the root servers down, caches answers in RAM, listens for queries from configured clients)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from dnscache.c on tip.

_dnscache() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '-c+[config file path]:file:_files' \
        '-d+[debug level]:n:' \
        '-D[daemonize]' \
        '-l+[log file path]:file:_files' \
        '-p+[pid file path]:file:_files' \
        '-P+[server port (default 53)]:port:'
}

_dnscache "$@"
