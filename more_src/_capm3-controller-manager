#compdef capm3-controller-manager
# _capm3-controller-manager — Cluster API Metal3 provider controller manager (CAPM3)
# upstream: https://github.com/metal3-io/cluster-api-provider-metal3
# Flags from main.go (pflag) on tip.

_capm3-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--enable-bmh-name-based-preallocation[allocate Metal3Data by BMH name]' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--sync-period=[informer resync period]:dur:' \
        '--clustercache-client-qps=[clustercache client QPS]:f:' \
        '--clustercache-client-burst=[clustercache client burst]:n:' \
        '--metal3machine-concurrency=[Metal3Machine concurrent reconciles]:n:' \
        '--metal3cluster-concurrency=[Metal3Cluster concurrent reconciles]:n:' \
        '--metal3datatemplate-concurrency=[Metal3DataTemplate concurrent reconciles]:n:' \
        '--metal3data-concurrency=[Metal3Data concurrent reconciles]:n:' \
        '--metal3labelsync-concurrency=[Metal3LabelSync concurrent reconciles]:n:' \
        '--metal3machinetemplate-concurrency=[Metal3MachineTemplate concurrent reconciles]:n:' \
        '--metal3remediation-concurrency=[Metal3Remediation concurrent reconciles]:n:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '*--skip-crd-migration-phases=[CRD migration phases to skip]:list:' \
        '--webhook-port=[webhook server port]:port:' \
        '--webhook-cert-dir=[webhook serving cert dir]:dir:_files -/' \
        '--health-addr=[health probe bind address]:host\:port:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capm3-controller-manager "$@"
