#compdef cargo-runner
# Documentation: https://github.com/cargo-runner/cargo-runner
# Source: cargo-runner unified Rust build engine; auto-detects Cargo/Bazel/Dioxus/Leptos/Tauri.
# Reference accessed: 2026-06-01
# Cargo subcommand; invoke as `cargo runner` or `cargo-runner`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _cr_cmds
_cr_cmds=(
    'run:execute code with automatic build-system detection'
    'runnables:list all valid execution targets in workspace'
    'context:show JSON introspection of project environment'
    'init:scaffold or sync workspace setup'
    'override:create per-function command customisations'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'cargo-runner command' _cr_cmds && ret=0
        ;;
    args)
        case $line[1] in
            run)
                _arguments -s -S '*:path:_files' && ret=0
                ;;
            init)
                _arguments -s -S \
                    '--bazel[scaffold a Bazel workspace setup]' \
                    && ret=0
                ;;
            override)
                _arguments -s -S '*:override args:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
