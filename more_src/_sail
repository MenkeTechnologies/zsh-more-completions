#compdef sail
# Documentation: https://laravel.com/docs/sail
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Laravel Sail (Docker dev environment wrapper)

local curcontext="$curcontext" state line ret=1

local -a sail_commands
sail_commands=(
  'up:start all Docker containers'
  'down:stop and remove all containers'
  'build:build all Docker images'
  'stop:stop all containers'
  'restart:restart all containers'
  'ps:display the status of all containers'
  'shell:open a shell session in the app container'
  'root-shell:open a root shell session'
  'tinker:start a Laravel Tinker session'
  'artisan:run an Artisan command'
  'debug:run an Artisan command with Xdebug enabled'
  'test:run feature and unit tests'
  'dusk:run Laravel Dusk browser tests'
  'share:share the application via tunnel'
  'composer:run a Composer command'
  'npm:run an npm command'
  'yarn:run a Yarn command'
  'node:run a Node command'
  'php:run a PHP command'
  'open:open the project in a browser'
)

_arguments -s -S \
  '1: :->cmd' \
  '*::args:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'sail command' sail_commands && ret=0 ;;
  args)
    case "${line[1]}" in
      up)
        _arguments -s -S \
          '-d[detached mode]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--no-cache[build without cache]' && ret=0
        ;;
      share)
        _arguments -s -S \
          '--subdomain=[choose a subdomain]:subdomain:' && ret=0
        ;;
      artisan|composer|npm|yarn|node|php|tinker|debug|test|dusk|shell|root-shell)
        _arguments -s -S \
          '*:arguments:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
