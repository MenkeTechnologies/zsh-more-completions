#compdef sail

# Zsh completion for Laravel Sail

local curcontext="$curcontext" state line ret=1

local -a sail_commands
sail_commands=(
  'up:start all Docker containers'
  'down:stop all Docker containers'
  'build:build all Docker images'
  'start:start all Docker containers'
  'stop:stop all Docker containers'
  'restart:restart all Docker containers'
  'ps:display the status of all containers'
  'shell:start a shell session in the app container'
  'bash:start a bash session in the app container'
  'root-shell:start a root shell session'
  'root-bash:start a root bash session'
  'tinker:start a Laravel Tinker session'
  'artisan:run an Artisan command'
  'test:run PHPUnit tests'
  'pest:run Pest tests'
  'dusk:run Laravel Dusk tests'
  'share:share the application via a public URL'
  'composer:run a Composer command'
  'npm:run an npm command'
  'npx:run an npx command'
  'yarn:run a Yarn command'
  'node:run a Node command'
  'php:run a PHP command'
  'mysql:start a MySQL CLI session'
  'mariadb:start a MariaDB CLI session'
  'psql:start a PostgreSQL CLI session'
  'redis:start a Redis CLI session'
  'bin:run a vendor bin command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:_describe -t commands command sail_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      up)
        _arguments -s -S \
          '-d[detached mode]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--no-cache[build without cache]' && ret=0
        ;;
      artisan)
        _arguments -s -S \
          '*:artisan arguments:' && ret=0
        ;;
      composer)
        _arguments -s -S \
          '*:composer arguments:' && ret=0
        ;;
      npm|npx|yarn|node)
        _arguments -s -S \
          '*:arguments:' && ret=0
        ;;
      php)
        _arguments -s -S \
          '*:php arguments:_files -g "*.php"' && ret=0
        ;;
      bin)
        _arguments -s -S \
          '*:binary and arguments:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
