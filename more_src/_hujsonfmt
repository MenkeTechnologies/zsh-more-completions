#compdef hujsonfmt
# Documentation: https://github.com/tailscale/hujson
# format HuJSON (JWCC) files, gofmt-style

local ret=1

_arguments -s -S \
  '-d[display diffs instead of rewriting files]' \
  '-l[list files whose formatting differs]' \
  '-m[minify results]' \
  '-s[standardize results to plain JSON]' \
  '-w[write result to source file instead of stdout]' \
  '*:file:_files' && ret=0

return ret
