#compdef tic80
# Fantasy computer for making, playing, and sharing tiny games

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--fullscreen[start in fullscreen mode]' \
  '--vsync[enable vertical sync]' \
  '--soft[use software rendering]' \
  '--volume[set volume level]:volume:' \
  '--scale[set window scale]:scale:' \
  '--cmd[execute console command]:command:' \
  '--keepcmd[run command and keep console open]' \
  '--skip[skip startup animation]' \
  '--cli[run in CLI mode without graphics]' \
  '*:cart file:_files -g "*.(tic|lua|js|moon|fennel|ruby|wasm|janet|python|scheme)"' \
  && return 0
