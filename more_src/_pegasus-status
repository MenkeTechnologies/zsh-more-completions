#compdef pegasus-status
# Documentation: https://pegasus.isi.edu/documentation/manpages/pegasus-status.html
# pegasus-status - show the current state of a running Pegasus workflow

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display concise help information]' \
  '(-V --version)'{-V,--version}'[show version details]' \
  '(-w --watch)'{-w,--watch}'=[enable watch mode with polling interval in seconds]:seconds' \
  '(-L --legend)'{-L,--legend}'[display column legend for output]' \
  '(-Q --noqueue)'{-Q,--noqueue}'[disable Condor Q parsing output]' \
  '(-d --debug)'{-d,--debug}'[internal debugging mode showing Condor Q expressions]' \
  '(-l --long)'{-l,--long}'[show one line per sub-DAG with additional job columns]' \
  '(-D --dirs)'{-D,--dirs}'[display relative directories under dagnames]' \
  '(-j --jsonrv)'{-j,--jsonrv}'[return workflow status as a JSON structure]' \
  '*:rundir:_files -/' && ret=0

return ret
