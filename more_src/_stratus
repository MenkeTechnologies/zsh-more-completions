#compdef stratus

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list available attack techniques'
  'show:show details for a technique'
  'warmup:prepare prerequisites for a technique'
  'detonate:execute a technique against a live environment'
  'revert:cancel the detonation of a technique'
  'cleanup:remove resources created by a technique'
  'status:show technique state'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[Stratus config file]:file:_files -g "*.{yaml,yml}"' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'stratus command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '--platform=[filter by platform]:platform:(aws azure gcp kubernetes ec2 entra-id)' \
          '--mitre-attack-tactic=[MITRE tactic filter]:tactic:(initial-access execution persistence privilege-escalation defense-evasion credential-access discovery lateral-movement collection exfiltration impact)' && ret=0 ;;
      (warmup|detonate|revert|cleanup|show|status)
        _arguments \
          '--cleanup[also run cleanup after detonate]' \
          '--force[skip confirmation]' \
          '*::technique:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
