#compdef lutread
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss103.html
# KAPPA: read a colour lookup table from an NDF into the current image display

local ret=1

_arguments -s \
  'LUT=[NDF containing the lookup table]:NDF:_files' \
  'DEVICE=[graphics device whose colour table is changed]:device' \
  '*:NDF:_files' && ret=0

return ret
