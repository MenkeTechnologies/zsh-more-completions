#compdef suanalytic
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suanalytic.c
# use the Hilbert transform to generate an ANALYTIC

local ret=1

_arguments -s -S \
  'phaserot=[phaserot]:phaserot:' \
  'mode=[mode]:mode:' \
  '*:file:_files' && ret=0

return ret
