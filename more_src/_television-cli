#compdef tv television
# Documentation: https://alexpasmantier.github.io/television/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream Television CLI reference.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--config-file=[config file path]:file:_files -g "*.toml"' \
  '--cable-dir=[channels dir]:dir:_files -/' \
  '(-i --input)'{-i+,--input=}'[input string]:s:' \
  '--input-header=[input header]:h:' \
  '--input-prompt=[input prompt]:p:' \
  '--input-border=[input border]:b:(none plain rounded thick)' \
  '--ansi[parse ANSI codes from source command]' \
  '--no-help-panel[disable help panel entirely]' \
  '--hide-help-panel[hide help panel on startup]' \
  '--show-help-panel[show help panel on startup]' \
  '--no-preview[disable preview entirely]' \
  '--hide-preview[hide preview on startup]' \
  '--show-preview[show preview on startup]' \
  '--no-status-bar[disable status bar entirely]' \
  '--hide-status-bar[hide status bar on startup]' \
  '--show-status-bar[show status bar on startup]' \
  '--no-remote[disable remote control entirely]' \
  '--hide-remote[hide remote on startup]' \
  '--show-remote[show remote on startup]' \
  '--keybindings=[keybindings]:k:' \
  '--ui-scale=[UI scale]:n:' \
  '--inline[inline mode]' \
  '--height=[height]:h:' \
  '--width=[width]:w:' \
  '--global-history[cross-channel history (channel mode)]' \
  '--watch=[watch interval s]:s:' \
  '(-t --tick-rate)'{-t+,--tick-rate=}'[tick rate]:n:' \
  '(-e --exact)'{-e,--exact}'[exact match]' \
  '(-s --select-1)'{-s,--select-1}'[auto-select if one]' \
  '(--take-1 --take-1-fast)--take-1[select first entry after loading]' \
  '(--take-1 --take-1-fast)--take-1-fast[select first entry immediately]' \
  '(-p --preview-command)'{-p+,--preview-command=}'[preview command]:c:' \
  '--preview-offset=[preview offset]:n:' \
  '--preview-size=[preview size]:n:' \
  '--preview-header=[preview header]:h:' \
  '--preview-footer=[preview footer]:f:' \
  '--preview-border=[preview border]:b:(none plain rounded thick)' \
  '--results-border=[results border]:b:(none plain rounded thick)' \
  '--source-command=[source command]:c:' \
  '--source-display=[source display]:c:' \
  '--source-output=[source output]:c:' \
  '--source-entry-delimiter=[source entry delimiter]:d:' \
  '--layout=[layout]:l:(landscape portrait)' \
  '1:channel:' \
  '*: :' && ret=0

local -a commands
commands=(
  'list-channels:list available channels'
  'init:init configuration files'
  'update-channels:update channel definitions'
)
_describe -t cmds 'television command' commands && ret=0

return ret
