#compdef gds3d GDS3D
# GDS3D - render IC GDSII layouts in real-time 3D using a process definition file
# Source: https://github.com/trilomix/GDS3D/blob/master/README.md
# Reference accessed: 2026-06-21

local ret=1

_arguments -s \
  '-h[show command-line help]' \
  '-p+[process definition file (3D layer parameters)]:process file:_files' \
  '-i+[input GDSII layout file]:gds file:_files -g "*.(gds|GDS|gds2|gdsii)"' \
  '-a+[assembly definition file (alternative to -p/-i)]:assembly file:_files' \
  '-t+[top cell to render]:topcell:' \
  '-f[launch in full-screen mode]' \
  '-u[disable GDS file monitoring (no auto-update on change)]' \
  '-v[verbose console output]' \
  '*:gds file:_files -g "*.(gds|GDS)"' && ret=0

return ret
