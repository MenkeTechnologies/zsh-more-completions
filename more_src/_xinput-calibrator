#compdef xinput-calibrator xinput_calibrator
# Documentation: https://manpages.debian.org/buster/xinput-calibrator/xinput_calibrator.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian buster xinput_calibrator(1) manpage OPTIONS section.

# xinput-calibrator: touchscreen calibration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[print debug messages]' \
  '--list[list calibratable input devices]' \
  '--device=[select device]:device:' \
  '--precalib=[manual current calibration]:spec:' \
  '--misclick=[misclick threshold pixels (0=off, default 15)]:pixels:' \
  '--no-timeout[turn off timeout]' \
  '--output-type=[config output type]:type:(auto xorg.conf.d xinput hal udev)' \
  '--fake[emulate fake driver (testing)]' \
  '--geometry=[manual width and height]:WxH:' && ret=0
return ret
