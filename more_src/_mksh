#compdef mksh
# _mksh — MirBSD Korn Shell (Thorsten "mirabilos" Glaser); POSIX-compatible ksh derived from pdksh
# upstream: https://www.mirbsd.org/mksh.htm

_mksh() {
    _arguments \
        '-c+[command]:code:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[read from stdin]' \
        '-r[restricted shell]' \
        '-T+[redirect to tty]:tty:' \
        '-X[mksh extension]' \
        '+X[no mksh extension]' \
        '-A+[array assignment]:array:' \
        '+A+[set array]:array:' \
        '-o+[option]:option:(allexport bgnice braceexpand emacs gmacs ignoreeof markdirs monitor noclobber noexec noglob nolog notify nounset physical posix pipefail restricted sh stdin trackall verbose vi xtrace)' \
        '+o+[unset option]:option:' \
        '-a[allexport]' \
        '+a[no allexport]' \
        '-e[errexit]' \
        '+e[no errexit]' \
        '-f[no glob]' \
        '+f[glob]' \
        '-h[hashall]' \
        '+h[no hashall]' \
        '-k[keywords]' \
        '+k[no keywords]' \
        '-m[monitor]' \
        '+m[no monitor]' \
        '-n[noexec]' \
        '+n[exec]' \
        '-t[exit after one command]' \
        '-u[nounset]' \
        '+u[unset ok]' \
        '-v[verbose]' \
        '+v[no verbose]' \
        '-x[xtrace]' \
        '+x[no xtrace]' \
        '*:script:_files'
}

_mksh "$@"
