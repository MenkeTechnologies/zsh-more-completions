#compdef dendrite-demo-pinecone
# _dendrite-demo-pinecone — P2P Dendrite demo over Pinecone overlay (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/dendrite-demo-pinecone/main.go.

_dendrite-demo-pinecone() {
    _arguments \
        '-name=[instance name]:name:' \
        '-port=[client API port]:port:' \
        '-peer=[comma-separated static Pinecone peers]:peers:' \
        '-listen=[Pinecone peer listen addr]:addr:' \
        '-dir=[directory for databases]:dir:_files -/' \
        '-relay[enable store & forward relaying]' \
        '-config=[Dendrite config file]:file:_files -g "*.{yml,yaml}"'
}

_dendrite-demo-pinecone "$@"
