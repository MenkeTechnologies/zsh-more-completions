#compdef logtop
# Documentation: https://github.com/JulienPalard/logtop
# logtop - real-time top-like count of strings received from stdin

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-s --size)'{-s+,--size=}'[number of log lines to keep in memory]:num:' \
  '(-q --quiet)'{-q,--quiet}'[quiet, only display a top 10 at exit]' \
  '(-l --line-by-line)'{-l+,--line-by-line=}'[print result line by line]:num:' \
  '(-i --interval)'{-i+,--interval=}'[interval between graphical updates]:num:' && ret=0

return ret
