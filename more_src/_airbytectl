#compdef airbytectl airbyte-cli2
# _airbytectl — Airbyte airbytectl airbyte-cli CLI command-line frontend wrapping the Airbyte open-source data integration platform managing sources destinations connections workspaces operations syncs jobs check discover read write providing source-actor-source-versions configuration health airbyte-config-management custom-connector (Airbyte team, Go); cobra
# upstream: https://airbyte.com/

_airbytectl() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'workspace:workspace management'
        'source:source operations'
        'destination:destination operations'
        'connection:connection operations'
        'job:job operations'
        'sync:trigger a sync'
        'reset:reset connection state'
        'check:check connection'
        'discover:discover schema'
        'source-definition:source definition'
        'destination-definition:destination definition'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--token=+[token]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--workspace-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'airbytectl subcommand' sub ;;
        args)
            case $words[1] in
                workspace|source|destination|connection|job|source-definition|destination-definition) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                sync|reset|check|discover) _arguments '*:connection id:' ;;
            esac
            ;;
    esac
}

_airbytectl "$@"
