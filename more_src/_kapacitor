#compdef kapacitor

# Zsh completion for Kapacitor (InfluxDB alerting engine)

_kapacitor() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'record:record the result of a query or snapshot of live data'
    'define:create or update a task'
    'define-template:create or update a template'
    'define-topic-handler:create or update a topic handler'
    'replay:replay a recording to a task'
    'replay-live:replay live data to a task'
    'enable:enable and start a task running'
    'disable:stop and disable a task'
    'reload:reload a task'
    'push:publish a task to another Kapacitor instance'
    'delete:delete tasks, recordings, replays, templates, or topic-handlers'
    'list:list tasks, recordings, replays, templates, or topic-handlers'
    'show:display detailed information about a task'
    'show-template:display detailed information about a template'
    'show-topic:display detailed information about a topic'
    'show-topic-handler:display detailed information about a topic handler'
    'level:set the logging level on the Kapacitor server'
    'stats:display various stats about Kapacitor'
    'version:display the Kapacitor version'
    'vars:display the Kapacitor variables'
    'service-tests:execute service tests'
    'backup:backup the Kapacitor database'
    'watch:watch for alerts on a topic'
    'flux:manage Flux tasks'
  )

  _arguments -s -S \
    '-url=[Kapacitor URL]:URL:' \
    '-skipVerify[skip TLS verification]' \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'kapacitor command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        define)
          _arguments -s -S \
            '-name=[task name]:name:' \
            '-tick=[TICKscript file]:file:_files -g "*.tick"' \
            '-template=[template ID]:template:' \
            '-type=[task type]:type:(stream batch)' \
            '-dbrp=[database and retention policy]:dbrp:' \
            '-vars=[task variables]:JSON file:_files -g "*.json"' \
            '-no-reload[do not reload the task]' \
            && ret=0
          ;;
        define-template)
          _arguments -s -S \
            '-name=[template name]:name:' \
            '-tick=[TICKscript file]:file:_files -g "*.tick"' \
            '-type=[task type]:type:(stream batch)' \
            && ret=0
          ;;
        record)
          _arguments -s -S \
            '1:record type:(batch stream query)' \
            '-task=[task ID]:task:' \
            '-query=[InfluxQL query]:query:' \
            '-type=[stream type]:type:(stream batch)' \
            '-duration=[recording duration]:duration:' \
            '-past=[record past data]:duration:' \
            '-no-wait[do not wait for recording]' \
            && ret=0
          ;;
        replay)
          _arguments -s -S \
            '-recording=[recording ID]:recording:' \
            '-task=[task ID]:task:' \
            '-rec-time[use recording time]' \
            '-replay-id=[replay ID]:ID:' \
            '-no-wait[do not wait for replay]' \
            '-fast[replay as fast as possible]' \
            && ret=0
          ;;
        enable|disable|reload|show)
          _arguments -s -S \
            '1:task ID:' \
            && ret=0
          ;;
        delete)
          _arguments -s -S \
            '1:type:(tasks recordings replays templates topic-handlers topics)' \
            '*:IDs:' \
            && ret=0
          ;;
        list)
          _arguments -s -S \
            '1:type:(tasks recordings replays templates topic-handlers topics service-tests)' \
            '-pattern=[filter by pattern]:pattern:' \
            '-limit=[limit results]:limit:' \
            '-offset=[offset results]:offset:' \
            && ret=0
          ;;
        level)
          _arguments -s -S \
            '1:log level:(debug info warn error)' \
            && ret=0
          ;;
        backup)
          _arguments -s -S \
            '1:output file:_files' \
            && ret=0
          ;;
        watch)
          _arguments -s -S \
            '1:topic:' \
            && ret=0
          ;;
        *)
          _arguments -s -S '--help[display help]' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_kapacitor "$@"
