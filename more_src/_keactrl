#compdef keactrl
# Documentation: https://kea.readthedocs.io/en/kea-2.2.0/man/keactrl.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# keactrl: legacy startup helper for Kea daemons
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[keactrl config file]:file:_files' \
  '-s[server list]:list:' \
  '1:action:(start stop reload status)' \
  '*::keactrl args:_files' && ret=0
return ret
