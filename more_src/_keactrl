#compdef keactrl

# keactrl: legacy startup helper for Kea daemons
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[keactrl config file]:file:_files' \
  '-s[server list]:list:' \
  '1:action:(start stop reload status)' \
  '*::keactrl args:_files' && ret=0
return ret
