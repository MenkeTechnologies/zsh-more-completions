#compdef keactrl
# Documentation: https://kea.readthedocs.io/en/kea-2.6.1/man/keactrl.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# keactrl: startup helper for Kea daemons. Corrected from prior file:
# added long options --ctrl-config/--server, -V extended version, -v
# version; -s server enum is dhcp4|dhcp6|dhcp_ddns|ctrl_agent|netconf|all.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --ctrl-config)'{-c,--ctrl-config}'[keactrl configuration file]:file:_files' \
  '(-s --server)'{-s,--server}'[subset of servers to receive the command]:server:_values -s , server dhcp4 dhcp6 dhcp_ddns ctrl_agent netconf all' \
  '(-v --version)'{-v,--version}'[display the Kea version]' \
  '-V[display the extended Kea version]' \
  '1:action:(start stop reload status)' \
  '*::keactrl args:_files' && ret=0
return ret
