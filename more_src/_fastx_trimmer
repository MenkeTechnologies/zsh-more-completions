#compdef fastx_trimmer
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_trimmer.1.en.html
# FASTX-Toolkit: extract sub-sequences (trim) from FASTA/Q reads

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-f+[first base to keep (default 1)]:base' \
  '-l+[last base to keep (default entire read)]:base' \
  '-t+[trim N nucleotides from the end of the read]:bases' \
  '-m+[with -t, discard reads shorter than MINLEN]:minlen' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
