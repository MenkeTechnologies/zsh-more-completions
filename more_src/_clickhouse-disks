#compdef clickhouse-disks

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'list:list available disks'
  'list-disks:list registered disks'
  'list-files:list files in a directory on disk'
  'copy:copy file/directory between disks or within a disk'
  'move:move file/directory between disks or within a disk'
  'remove:remove file/directory'
  'remove-recursive:recursively remove directory'
  'mkdir:create directory'
  'link:create a hard link'
  'switch-disk:switch active disk'
  'current-disk-with-path:print current disk and path'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-C+,--config-file=}'[ClickHouse config file]:file:_files -g "*.(xml|yaml|yml)"' \
  '--disk=[active disk]:disk:' \
  '--save-logs[save command logs]' \
  '--log-level=[log level]:level:(trace debug information warning error fatal none)' \
  '--query=[execute query string]:query:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'clickhouse-disks subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (copy|move)
        _arguments \
          '--disk-from=[source disk]:disk:' \
          '--disk-to=[destination disk]:disk:' \
          '*:path:_files' && ret=0
        ;;
      (list|list-files|remove|remove-recursive|mkdir|link|switch-disk)
        _arguments \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
