#compdef clickhouse-disks
# Documentation: https://clickhouse.com/docs/operations/utilities/clickhouse-disks
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cd:change directory'
  'list:list files in a directory on disk'
  'list-disks:list registered disks'
  'copy:copy file/directory between disks or within a disk'
  'move:move file/directory between disks or within a disk'
  'remove:remove file/directory'
  'mkdir:create directory'
  'link:create a hard link'
  'read:read file contents'
  'write:write file contents'
  'switch-disk:switch active disk'
  'current_disk_with_path:print current disk and path'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-C+,--config-file=}'[ClickHouse config file]:file:_files -g "*.(xml|yaml|yml)"' \
  '--disk=[active disk]:disk:' \
  '--save-logs[save command logs]' \
  '--log-level=[log level]:level:(trace debug information warning error fatal none)' \
  '--query=[execute query string]:query:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'clickhouse-disks subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (copy|move)
        _arguments \
          '--disk-from=[source disk]:disk:' \
          '--disk-to=[destination disk]:disk:' \
          '*:path:_files' && ret=0
        ;;
      (cd|list|remove|mkdir|link|switch-disk|read|write)
        _arguments \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
