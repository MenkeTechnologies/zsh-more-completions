#compdef cellsnp-lite
# Documentation: https://cellsnp-lite.readthedocs.io/en/latest/main/manual.html
# cellsnp-lite - genotype/pileup of SNPs from single-cell BAM data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-s --samFile)'{-s,--samFile}'=[indexed BAM/CRAM file(s), comma separated]:bam:_files' \
  '(-S --samFileList)'{-S,--samFileList}'=[file listing BAM/CRAM files]:file:_files' \
  '(-O --outDir)'{-O,--outDir}'=[output directory]:dir:_files -/' \
  '(-R --regionsVCF)'{-R,--regionsVCF}'=[VCF of candidate SNPs]:vcf:_files' \
  '(-T --targetsVCF)'{-T,--targetsVCF}'=[VCF of targets via streaming]:vcf:_files' \
  '(-b --barcodeFile)'{-b,--barcodeFile}'=[file of effective cell barcodes]:file:_files' \
  '(-i --sampleList)'{-i,--sampleList}'=[file of sample IDs]:file:_files' \
  '(-I --sampleIDs)'{-I,--sampleIDs}'=[comma-separated sample IDs]:ids:' \
  '(-f --refseq)'{-f,--refseq}'=[faidx-indexed reference sequence]:fasta:_files' \
  '(-p --nproc)'{-p,--nproc}'=[number of threads]:threads:' \
  '--chrom=[chromosomes to use, comma separated]:chrom:' \
  '--cellTAG=[tag for cell barcodes]:tag:' \
  '--UMItag=[tag for UMI: UB, Auto, None]:tag:(UB Auto None)' \
  '--minCOUNT=[minimum aggregated UMI/read count]:count:' \
  '--minMAF=[minimum minor allele frequency]:maf:' \
  '--genotype[do genotyping in addition to counting]' \
  '--gzip[bgzip the output VCF files]' \
  '--printSkipSNPs[print SNPs skipped when loading VCF]' \
  '--doubletGL[keep doublet genotype likelihoods]' \
  '--inclFLAG=[required flags filter]:flag:' \
  '--exclFLAG=[exclude flags filter]:flag:' \
  '--minLEN=[minimum mapped length]:len:' \
  '--minMAPQ=[minimum MAPQ]:mapq:' \
  '--maxDEPTH=[max reads per position per file]:depth:' \
  '--countORPHAN[do not skip anomalous read pairs]' \
  '*:file:_files' && ret=0

return ret
