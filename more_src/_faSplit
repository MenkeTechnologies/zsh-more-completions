#compdef faSplit
# split an fa file into several files

local ret=1

_arguments -s -S \
  '-maxN=[suppress pieces with more than N Ns (size only)]:n' \
  '-oneFile[put output in one file (size only)]' \
  '-extra=[add N extra bytes at end to form overlapping pieces (size only)]:n' \
  '-out=[get masking from outfile (size only)]:out file:_files' \
  '-lift=[reconstruction info for pieces (size and gap only)]:lift file:_files -g "*.lft"' \
  '-minGapSize=[treat block of Ns as gap if size >= X (gap only)]:x' \
  '-noGapDrops[include all Ns when splitting by gap]' \
  '-outDirDepth=[create N levels of output directory]:n' \
  '-prefixLength=[create separate file per name prefix group (byname)]:n' \
  '1:how:(about byname base gap sequence size)' \
  '2:input fa:_files -g "*.(fa|fasta)"' \
  '3:count' \
  '4:out root' && ret=0

return ret
