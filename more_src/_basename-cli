#compdef basename-cli
# _basename-cli — GNU coreutils basename strip directory and suffix from filenames CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_basename-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[multiple args treated as names]' \
        '--multiple[multiple args treated as names]' \
        '-s+[suffix]:str:' \
        '--suffix=+[suffix]:str:' \
        '-z[NUL terminator]' \
        '--zero[NUL terminator]' \
        '*:name suffix:_files'
}

_basename-cli "$@"
