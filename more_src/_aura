#compdef aura

# Zsh completion for aura (AUR helper for Arch Linux)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--noconfirm[do not ask for any confirmation]' \
  '--hotedit[prompt to edit PKGBUILD before building]' \
  '--dryrun[show what would be done without doing it]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1:operation:->operations' \
  '*:: :->args' && ret=0

case $state in
  operations)
    local -a operations=(
      '-A:install packages from AUR'
      '-B:manage saved package state'
      '-C:manage package cache'
      '-L:view pacman log'
      '-O:manage orphan packages'
      '-Q:query installed packages'
      '-R:remove packages'
      '-S:sync packages from official repos'
      '-U:upgrade local packages'
    )
    _describe -t operations 'aura operation' operations && ret=0
    ;;
  args)
    case ${words[1]} in
      -A*)
        _arguments -s -S \
          '-a[install from AUR]' \
          '-u[upgrade AUR packages]' \
          '-s[search AUR]' \
          '-i[show AUR package info]' \
          '-p[show PKGBUILD]' \
          '-d[list dependencies]' \
          '--abc[sort alphabetically]' \
          '--hotedit[edit PKGBUILD before building]' \
          '--diff[show PKGBUILD diffs]' \
          '--dryrun[show what would be done]' \
          '--skipdepcheck[skip dependency check]' \
          '*:package' && ret=0
        ;;
      -B*)
        _arguments -s -S \
          '-s[save current package state]' \
          '-r[restore saved state]' \
          '-c[clean saved states]' && ret=0
        ;;
      -C*)
        _arguments -s -S \
          '-s[search cache]' \
          '-c[clean cache]:count' \
          '-b[backup cache]:directory:_directories' && ret=0
        ;;
      -L*)
        _arguments -s -S \
          '-i[show package install info]' \
          '-s[search log]' && ret=0
        ;;
      -O*)
        _arguments -s -S \
          '-j[remove orphans]' \
          '--adopt[mark as explicitly installed]' \
          '*:package' && ret=0
        ;;
    esac
    ;;
esac

return ret
