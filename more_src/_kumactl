#compdef kumactl

# Zsh completion for kumactl - Kuma service mesh CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--config-file=[path to config file]:config file:_files' \
  '--mesh=[mesh to use]:mesh' \
  '--api-timeout=[API server timeout]:timeout' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:Create or update resources'
      'completion:Generate shell completions'
      'config:Manage kumactl configuration'
      'delete:Delete resources'
      'generate:Generate resources'
      'get:List resources'
      'inspect:Inspect resources'
      'install:Install components'
      'uninstall:Uninstall components'
      'version:Print version'
    )
    _describe -t commands 'kumactl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      completion)
        local -a subcmds=(
          'bash:Generate bash completions'
          'zsh:Generate zsh completions'
          'fish:Generate fish completions'
        )
        _describe -t subcmds 'completion subcommand' subcmds && ret=0
        ;;
      config)
        local -a subcmds=(
          'control-planes:Manage control plane connections'
          'view:View current configuration'
        )
        _describe -t subcmds 'config subcommand' subcmds && ret=0
        ;;
      generate)
        local -a subcmds=(
          'dataplane-token:Generate dataplane token'
          'zone-token:Generate zone token'
          'user-token:Generate user token'
          'signing-key:Generate signing key'
          'tls-certificate:Generate TLS certificate'
          'public-key:Generate public key'
        )
        _describe -t subcmds 'generate subcommand' subcmds && ret=0
        ;;
      get)
        local -a subcmds=(
          'dataplanes:List dataplanes'
          'meshes:List meshes'
          'traffic-permissions:List traffic permissions'
          'traffic-routes:List traffic routes'
          'traffic-logs:List traffic logs'
          'health-checks:List health checks'
          'proxy-templates:List proxy templates'
          'fault-injections:List fault injections'
          'circuit-breakers:List circuit breakers'
          'retries:List retries'
          'timeouts:List timeouts'
          'rate-limits:List rate limits'
          'external-services:List external services'
          'zones:List zones'
          'zone-ingresses:List zone ingresses'
          'zone-egresses:List zone egresses'
          'secrets:List secrets'
          'global-secrets:List global secrets'
        )
        _describe -t subcmds 'get subcommand' subcmds && ret=0
        ;;
      inspect)
        local -a subcmds=(
          'dataplanes:Inspect dataplanes'
          'meshes:Inspect meshes'
          'zones:Inspect zones'
          'zone-ingresses:Inspect zone ingresses'
          'zone-egresses:Inspect zone egresses'
          'services:Inspect services'
        )
        _describe -t subcmds 'inspect subcommand' subcmds && ret=0
        ;;
      install)
        local -a subcmds=(
          'control-plane:Install Kuma control plane'
          'observability:Install observability components'
          'metrics:Install metrics components'
          'tracing:Install tracing components'
          'logging:Install logging components'
          'dns:Install DNS components'
          'transparent-proxy:Install transparent proxy'
          'demo:Install demo application'
        )
        _describe -t subcmds 'install subcommand' subcmds && ret=0
        ;;
      apply)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[path to resource file]:file:_files' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[path to resource file]:file:_files' \
          '1:resource type' \
          '2:resource name' && ret=0
        ;;
    esac
    ;;
esac

return ret
