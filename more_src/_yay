#compdef yay

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --database)'{-D,--database}'[operate on the package database]' \
  '(-F --files)'{-F,--files}'[query the files database]' \
  '(-G --getpkgbuild)'{-G,--getpkgbuild}'[get PKGBUILD from ABS or AUR]' \
  '(-P --show)'{-P,--show}'[show various information]' \
  '(-Q --query)'{-Q,--query}'[query the package database]' \
  '(-R --remove)'{-R,--remove}'[remove packages]' \
  '(-S --sync)'{-S,--sync}'[synchronize packages]' \
  '(-U --upgrade)'{-U,--upgrade}'[upgrade or add packages]' \
  '(-Y --yay)'{-Y,--yay}'[yay specific operations]' \
  '-c[remove unneeded dependencies]' \
  '--clean[remove unneeded dependencies]' \
  '-g[generate development package database]' \
  '--gendb[generate development package database]' \
  '-l[list installed packages]' \
  '-i[show package information]' \
  '-n[ignore foreign packages]' \
  '-s+[search for packages]:query' \
  '-u[upgrade installed packages]' \
  '-w[download packages without installing]' \
  '-y[refresh package databases]' \
  '--aur[only operate on AUR packages]' \
  '--repo[only operate on repository packages]' \
  '--devel[check for development package updates]' \
  '--nocleanmenu[do not show clean menu]' \
  '--nodiffmenu[do not show diff menu]' \
  '--noeditmenu[do not show edit menu]' \
  '--noupgrademenu[do not show upgrade menu]' \
  '--provides[look for matching providers when searching]' \
  '--noprovides[do not look for matching providers]' \
  '--pgpfetch[ask to import PGP keys]' \
  '--nopgpfetch[do not ask to import PGP keys]' \
  '--useask[automatically resolve conflicts using pacman ask flag]' \
  '--nouseask[do not use pacman ask flag]' \
  '--combinedupgrade[combine repo and AUR upgrades]' \
  '--nocombinedupgrade[separate repo and AUR upgrades]' \
  '--batchinstall[batch AUR package installs]' \
  '--nobatchinstall[do not batch AUR package installs]' \
  '--rebuild[always build target packages]' \
  '--norebuild[skip build if package exists]' \
  '--redownload[always download PKGBUILDs]' \
  '--noredownload[skip download if PKGBUILD exists]' \
  '--removemake[remove make dependencies after install]' \
  '--noremovemake[do not remove make dependencies]' \
  '--sudoloop[loop sudo in the background]' \
  '--nosudoloop[do not loop sudo]' \
  '--topdown[show repo packages first]' \
  '--bottomup[show AUR packages first]' \
  '--sortby=[sort results by field]:field:(votes popularity id baseid name base submitted modified)' \
  '--searchby=[search by field]:field:(name name-desc maintainer depends makedepends optdepends checkdepends)' \
  '--mflags=[pass arguments to makepkg]:flags' \
  '--gpgflags=[pass arguments to gpg]:flags' \
  '--gitflags=[pass arguments to git]:flags' \
  '--builddir=[directory for building packages]:dir:_directories' \
  '--editor=[editor to use]:editor:_command_names' \
  '--editorflags=[pass arguments to editor]:flags' \
  '--makepkg=[makepkg command]:command:_command_names' \
  '--pacman=[pacman command]:command:_command_names' \
  '--git=[git command]:command:_command_names' \
  '--gpg=[gpg command]:command:_command_names' \
  '--sudo=[sudo command]:command:_command_names' \
  '--noconfirm[do not ask for confirmation]' \
  '--needed[do not reinstall up to date packages]' \
  '*:package:' && ret=0

return ret
