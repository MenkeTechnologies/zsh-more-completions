#compdef prettyping

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--nolegend[do not show the legend]' \
  '--legend[show the legend (default)]' \
  '--nogrid[do not show the grid]' \
  '--grid[show the grid (default)]' \
  '--noterminal[do not use terminal codes]' \
  '--terminal[use terminal codes (default)]' \
  '--nocolor[do not use colors]' \
  '--color[use colors (default)]' \
  '--nomulticolor[do not use multiple colors]' \
  '--multicolor[use multiple colors (default)]' \
  '--nolast[do not show last response time]' \
  '--last[show last response time (default)]' \
  '--columns=[override auto-detected terminal width]:columns' \
  '--awkbin=[path to awk binary]:file:_files' \
  '--pingbin=[path to ping binary]:file:_files' \
  '*:host:_hosts' && ret=0

return ret
