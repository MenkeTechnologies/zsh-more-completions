#compdef lfec
# Documentation: https://github.com/lfe/lfe/blob/develop/bin/lfec
# LFE (Lisp Flavoured Erlang) compiler

local ret=1

_arguments -s \
  '-h[show usage help]' \
  '*-I+[add include directory]:dir:_files -/' \
  '-o+[set output directory]:dir:_files -/' \
  '*-pa+[prepend directory to code path]:dir:_files -/' \
  '*-pz+[append directory to code path]:dir:_files -/' \
  '-v[enable verbose compiler output]' \
  '-Werror[turn warnings into errors]' \
  '-W+[set warning level]:level' \
  '-D[activate debug printing]' \
  '-E[output expanded forms]' \
  '-L[activate linting mode]' \
  '-A[output Erlang code]' \
  '-S[output assembly code]' \
  '-P[ignored (no LFE equivalent)]' \
  '*:lfe file:_files -g "*.lfe"' && ret=0

return ret
