#compdef bluetuith

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--adapter=[set Bluetooth adapter]:adapter' \
  '--connect=[connect to device on startup]:device address' \
  '--gsm-apn=[GSM APN for DUN]:apn' \
  '--gsm-number=[GSM number for DUN]:number' \
  '--list-adapters[list available adapters]' \
  '--no-warning[disable warnings]' \
  '--receive-dir=[directory for received files]:directory:_directories' \
  '--theme=[set UI theme]:theme:_files' && ret=0

return ret
