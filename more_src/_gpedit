#compdef gpedit
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpedit.html
# Edit the gain table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'select=[select keyword]:select:' \
  'feeds=[feeds keyword]:feeds:' \
  'gain=[gain keyword]:gain:' \
  'options=[options keyword]:options:' \
  'width=[width keyword]:width:' \
  '*:visibility dataset:_files' && ret=0

return ret
