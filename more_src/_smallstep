#compdef step

# Zsh completion for Smallstep step CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ca:initialize and manage the step CA'
      'certificate:create, inspect, and manage certificates'
      'crypto:cryptographic key and token operations'
      'ssh:manage SSH certificates'
      'path:print the configured step path'
      'version:print version'
      'context:manage step contexts'
      'completion:print shell completion script'
    )
    _describe -t commands 'step command' commands && ret=0
    ;;
  args)
    case $line[1] in
      ca)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->ca_cmds' \
          '*::arg:->ca_args' && ret=0
        case $state in
          ca_cmds)
            local -a ca_commands=(
              'certificate:generate a certificate signing request'
              'renew:renew a certificate'
              'revoke:revoke a certificate'
              'bootstrap:initialize the environment'
              'roots:download root certificates'
              'provisioner:manage provisioners'
              'health:check CA health'
              'token:generate an OTT'
            )
            _describe -t commands 'ca subcommand' ca_commands && ret=0
            ;;
          ca_args)
            case $line[1] in
              provisioner)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '1:action:(add remove list)' && ret=0
                ;;
              bootstrap)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--ca-url=[CA URL]:url' \
                  '--fingerprint=[root certificate fingerprint]:fingerprint' \
                  '--install[install the root certificate]' \
                  '--force[force overwrite]' && ret=0
                ;;
              certificate|renew)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--force[force overwrite]' \
                  '--expires-in=[renew if expiring within this duration]:duration' \
                  '*:certificate file:_files' && ret=0
                ;;
              revoke)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--serial=[certificate serial number]:serial' \
                  '--cert=[certificate file]:file:_files' \
                  '--key=[key file]:file:_files' \
                  '--reason=[revocation reason]:reason' && ret=0
                ;;
              *)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      certificate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->cert_cmds' \
          '*::arg:->cert_args' && ret=0
        case $state in
          cert_cmds)
            local -a cert_commands=(
              'create:create a certificate or CSR'
              'inspect:inspect a certificate'
              'verify:verify a certificate'
              'format:reformat a certificate'
              'fingerprint:print the fingerprint of a certificate'
              'install:install a root certificate'
              'uninstall:uninstall a root certificate'
              'needs-renewal:check if a certificate needs renewal'
            )
            _describe -t commands 'certificate subcommand' cert_commands && ret=0
            ;;
          cert_args)
            case $line[1] in
              create)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--csr[create a CSR instead]' \
                  '--profile=[certificate profile]:profile:(leaf intermediate root self-signed)' \
                  '--kty=[key type]:type:(EC OKP RSA)' \
                  '--size=[key size]:size' \
                  '--crv=[elliptic curve]:curve:(P-256 P-384 P-521 Ed25519)' \
                  '--not-before=[not before time]:time' \
                  '--not-after=[not after time or duration]:time' \
                  '--san=[subject alternative name]:san' \
                  '--ca=[issuer certificate]:file:_files' \
                  '--ca-key=[issuer key]:file:_files' \
                  '--no-password[do not ask for a password]' \
                  '--insecure[use insecure options]' \
                  '1:subject name' \
                  '2:certificate file:_files' \
                  '3:key file:_files' && ret=0
                ;;
              inspect)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--format=[output format]:format:(text json pem)' \
                  '--roots=[root certificate]:file:_files' \
                  '--short[print short info]' \
                  '1:certificate file:_files' && ret=0
                ;;
              install|uninstall)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--all[apply to all trust stores]' \
                  '1:certificate file:_files' && ret=0
                ;;
              needs-renewal)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '--expires-in=[time threshold]:duration' \
                  '1:certificate file:_files' && ret=0
                ;;
              *)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '1:certificate file:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      crypto)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->crypto_cmds' \
          '*::arg:->crypto_args' && ret=0
        case $state in
          crypto_cmds)
            local -a crypto_commands=(
              'key:manage cryptographic keys'
              'jwe:encrypt and decrypt JWE tokens'
              'jwt:sign and verify JWT tokens'
              'nacl:NaCl crypto operations'
            )
            _describe -t commands 'crypto subcommand' crypto_commands && ret=0
            ;;
          crypto_args)
            case $line[1] in
              key)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '1:action:(create inspect format)' && ret=0
                ;;
              jwe)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '1:action:(encrypt decrypt)' && ret=0
                ;;
              jwt)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '1:action:(sign verify inspect)' && ret=0
                ;;
              nacl)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '1:action:(box secretbox auth sign)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      ssh)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->ssh_cmds' && ret=0
        case $state in
          ssh_cmds)
            local -a ssh_commands=(
              'certificate:sign an SSH public key'
              'config:configure SSH client'
              'hosts:list SSH certificate-enabled hosts'
              'login:add an SSH certificate to the agent'
              'logout:remove SSH certificates from the agent'
              'list:list SSH certificates in the agent'
              'check-host:check if a host is configured for SSH certificates'
            )
            _describe -t commands 'ssh subcommand' ssh_commands && ret=0
            ;;
        esac
        ;;
      context)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->ctx_cmds' && ret=0
        case $state in
          ctx_cmds)
            local -a ctx_commands=(
              'current:show the current context'
              'list:list available contexts'
              'select:select a context'
              'remove:remove a context'
            )
            _describe -t commands 'context subcommand' ctx_commands && ret=0
            ;;
        esac
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
