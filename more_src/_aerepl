# Documentation: source-direct extraction from upstream
# aeternity/aerepl `aerepl` (escript)
# (**Erlang**; uses **stdlib `argparse` module** —
# Erlang/OTP's stdlib CLI argument parser,
# introduced in OTP 26 (June 2023).  Corpus's
# **first documented Erlang stdlib `argparse`
# library** + **second documented Erlang CLI
# library** (joining R292 _emqtt jcomellas/getopt
# third-party library).  Pivots from R327 _watib
# (Bigloo Scheme args-parse) into the Erlang/OTP
# ecosystem to document Erlang's modern stdlib
# CLI parser):
#   aerepl line 1
#     (`#!/usr/bin/env escript` — ESCRIPT SHEBANG.
#     escript is Erlang's standalone-script
#     execution mode — uses the Erlang VM to
#     interpret/compile the file.  `-mode(compile)`
#     on line 6 forces escript to COMPILE the
#     module before running (vs interpret).
#     Distinct from R317 Forth/Gforth shebang
#     (`#! /usr/bin/env gforth`), R324 Chicken
#     `#! /usr/bin/env csi -s`, R311 Guile `#!
#     /usr/bin/env guile`.  Erlang's escript is a
#     unique RUNTIME-COMPILE shebang model)
#   aerepl line 2
#     (`%% -*- erlang -*-` — Emacs file-local-
#     variables comment marker, instructing Emacs
#     to use erlang-mode for this file.  Standard
#     Erlang convention for escript files)
#   aerepl line 3
#     (`%%! -smp enable -setcookie aerepl_cookie
#       -mnesia debug verbose` — escript ARGUMENTS
#     LINE (escript-specific syntax).  Lines
#     starting with `%%!` are passed as ARGS to
#     the Erlang VM when running the escript.
#     `-smp enable` enables SMP (symmetric multi-
#     processing); `-setcookie` sets the
#     distributed-Erlang cookie; `-mnesia` configs
#     Mnesia.  Distinct from R290 Racket / R311
#     Guile / R324 Chicken which use shebang args
#     only.  Corpus's **first documented escript-
#     `%%!`-VM-args-line CLI pattern**)
#   aerepl line 7
#     (`-mode(compile).` — Erlang module attribute
#     forcing escript COMPILE mode (vs interpret).
#     The escript is compiled before execution for
#     speed)
#   aerepl line 9
#     (`main(Args) ->
#        load_paths(),
#        argparse:run(Args, cli(), #{progname =>
#                                    "aerepl"}).`
#     — ENTRY POINT.  `argparse:run/3` takes the
#     ARGS list, a COMMAND SPEC (returned by
#     `cli/0`), and an OPTIONS MAP `#{progname =>
#     "aerepl"}`.  Distinct from R292 emqtt
#     (jcomellas/getopt third-party library:
#     `getopt:parse(OptSpecList, Args)` returning
#     `{ok, {[ParsedOpts], [Remaining]}}`), R325
#     OCaml `Arg.parse_argv`, R270 Haskell
#     `getOpt`.  Erlang stdlib `argparse:run/3`
#     handles BOTH parsing AND dispatch to the
#     handler function in ONE CALL — corpus's
#     **first documented run-with-dispatch
#     argparse CLI pattern**)
#   aerepl lines 13-32
#     (`cli() ->
#       #{
#         handler => {?MODULE, aerepl},
#         arguments =>
#             [ #{name => accounts, long =>
#                 "account", short => $a, nargs =>
#                 2, action => append, default =>
#                 [], type => {custom, fun parse_
#                 account/1}}
#             , #{name => call_gas, long =>
#                 "call_gas", type => {integer,
#                 [{min, 0}]}}
#             , #{name => call_value, long =>
#                 "call_value", type => {integer,
#                 [{min, 0}]}}
#             ...
#             ]}.` — COMMAND SPEC as Erlang MAP
#     `#{handler => HANDLER, arguments => [...],
#     commands => #{}, help => "..."}`.  `handler`
#     is `{Module, Function}` 2-tuple specifying
#     the dispatch target.  `arguments` is a list
#     of OPTION SPEC MAPS, each with `name`/`long`/
#     `short`/`type`/`default`/`action`/`nargs`
#     fields.  Distinct from R292 Erlang getopt
#     (different lib, list-of-tuples spec), R322
#     JCommander `@Parameter` annotation, R311
#     Guile `((NAME (single-char #\X) (value
#     #t/#f)))` quoted alist.  Erlang stdlib
#     argparse's approach: NESTED-MAPS SPEC — every
#     command and option is an Erlang MAP.
#     Corpus's **first documented map-of-maps spec
#     argparse CLI pattern**)
#   aerepl line 16-19
#     (`#{name => accounts, long => "account",
#       short => $a, nargs => 2, action => append,
#       default => [], type => {custom, fun parse_
#       account/1}}` — DETAILED OPTION SPEC fields:
#       `name => accounts`       Erlang ATOM key
#                                used to lookup
#                                in the parsed-args
#                                map
#       `long => "account"`      string for
#                                `--account`
#       `short => $a`            Erlang CHAR LITERAL
#                                `$a` for `-a`
#                                (sister to R291
#                                CL `#\h`, R298
#                                Pony `'p'`, R315
#                                Eiffel `'V'`,
#                                R317 Forth `s"...";"`)
#       `nargs => 2`             consume 2 argv
#                                tokens per occurrence
#       `action => append`       APPEND to a list
#                                (vs default
#                                replace) for
#                                repeatable opts
#       `default => []`          default value
#       `type => {custom, fun
#         parse_account/1}`      custom parser
#                                function reference
#     Distinct from R292 emqtt getopt's
#     `{name, $a, "account", string}` 4-tuple,
#     R322 JCommander `@Parameter(names = arrayOf
#     ("-a", "--account"))` annotation, R311 Guile
#     `(NAME (single-char #\a) (value #t))`.
#     Argparse's approach: NAMED MAP FIELDS for
#     each spec attribute — corpus's **first
#     documented named-map-field argparse CLI
#     pattern**)
#   aerepl line 27
#     (`#{name => print_format, long =>
#       "print_format", type => {atom, [sophia,
#       json, fate]}}` — `type => {atom, [LIST]}`
#     declares an ATOM-CHOICE TYPE.  The parser
#     CONVERTS the argv string to an Erlang atom
#     AND VALIDATES it's in the allowed list.
#     Distinct from R315 Eiffel Gobo `tool_option.
#     extend("ge")` (method-chain extend), R295
#     CL clingon `:option-type :choice :choices`,
#     R304 Ada `Define_Alias` enum aliases.
#     Erlang argparse's approach: `{atom, [list]}`
#     TYPE-WITH-CONSTRAINT — corpus's **first
#     documented type-with-choice-constraint CLI
#     pattern**)
#   aerepl line 19
#     (`type => {custom, fun parse_account/1}` —
#     CUSTOM TYPE via function reference.
#     `parse_account/1` is an Erlang FUNCTION
#     REFERENCE — `fun ModuleName:Function/Arity`
#     or `fun Function/Arity` if local.  The
#     parser calls it with the argv string and
#     uses its return value.  Distinct from R322
#     JCommander `converter = X.class`, R325 OCaml
#     `Arg.String FN` callback, R323 Java args4j
#     `handler = X.class`.  Erlang's approach:
#     FUNCTION REFERENCE in spec map — corpus's
#     **first documented function-reference-as-
#     custom-type argparse CLI pattern**)
#   aerepl line 14
#     (`handler => {?MODULE, aerepl}` — `{Module,
#     Function}` 2-TUPLE specifying the dispatch
#     handler.  `?MODULE` is an Erlang PREPROCESSOR
#     macro that expands to the current module
#     name atom.  The function `aerepl/1` is called
#     with the PARSED ARGS MAP when this command
#     is matched.  Distinct from R311 Guile
#     `(args:make-option ... BODY)` (embedded
#     thunk), R324 Chicken `(args:make-option (h
#     help) #:none HELP BODY)` (embedded body
#     thunk), R322 JCommander main-method (no
#     explicit handler binding).  Erlang's
#     approach: 2-TUPLE Module-Function reference
#     for dispatch — corpus's **first documented
#     2-tuple-mfa-handler CLI dispatch pattern**)
# Reference accessed: 2026-05-31 via gh api.
#
# aerepl CLI surface (decoded from `arguments`
# list at aerepl:15-32):
#   -a / --account PUBKEY-OR-BALANCE PUBKEY-OR-BALANCE
#                       account (nargs=2, repeatable)
#   --call_gas N        call gas amount (integer min=0)
#   --call_value N      call value (integer min=0)
#   --call_gas_price N  call gas price (integer min=0)
#   --call_origin VAL   call origin (string)
#   --call_contract_creator VAL
#                       call contract creator (string)
#   --call_fee N        call fee (integer min=0)
#   --call_height N     call height (integer min=1)
#   --print_gas         print gas (boolean)
#   --print_format VAL  print format: sophia | json | fate
#   --print_unit        print unit (boolean)
#   --print_type        print type (boolean)
#   --loc_forwards N    forward source-location count (integer min=0)
#   --loc_backwards N   backward source-location count (integer min=0)
#
# Plus argparse-auto-injected:
#   -h / --help         display help
#
# aerepl is a sophisticated Read-Eval-Print Loop
# for Sophia — the smart-contract language of the
# Æternity blockchain.  Allows interactive
# evaluation of Sophia expressions, function-
# calls, and stateful contract simulations.
# Authored by Radosław Rowicki (radrow) for the
# Æternity blockchain project.  6 GH stars
# (specialized blockchain dev tool).  Sister
# tools: aesophia (the Sophia compiler — escript),
# aeternity_node (the Æternity blockchain node).
#
# Critical extraction note: aerepl uses **Erlang
# stdlib `argparse` module** at aerepl:10 —
# corpus's **first documented Erlang stdlib
# `argparse` library** + **second documented
# Erlang CLI library** (joining R292 _emqtt
# jcomellas/getopt third-party library).  Erlang
# stdlib `argparse` was introduced in OTP 26 (June
# 2023) — a relatively new addition.  Distinct
# from R292 jcomellas/getopt (third-party
# `getopt:parse(OptSpecList, Args)` returning
# `{ok, {[ParsedOpts], [Remaining]}}`, list-of-
# tuples spec), Apache Commons-CLI Erlang ports.
# stdlib argparse adds: NESTED-MAP SPEC, subcommand
# tree support, type-with-constraint (`{integer,
# [{min, 0}]}`, `{atom, [enum]}`), `nargs`/`action`
# fields, `{Module, Function}` handler dispatch,
# automatic `--help` generation, `argparse:run/3`
# single-call entry point.  Extends cross-language
# CLI taxonomy to SIXTY-SEVEN library variants:
# Rust (6), Go (4), Python (3), Crystal 1
# OptionParser (R269), Haskell (R270), OCaml 1
# Cmdliner (R271), C (R272), Java 1 picocli (R276),
# Kotlin (R277), Scala (R278), Dart (R279),
# Ruby (R280), Perl (R281), PHP (R282),
# Swift (R283), F# (R284), Lua (R285), C# (R286),
# Nim 1 parseopt (R287), Zig (R288), D (R289),
# Racket (R290), Common Lisp 1 (R291),
# **Erlang 1 getopt (R292)**, Tcl (R293), Pharo
# Smalltalk (R294), Common Lisp 2 clingon (R295),
# Julia (R296), SWI-Prolog optparse (R297), Pony
# stdlib cli (R298), Crystal 2 Admiral (R299),
# V stdlib `flag` (R300), Nim 2 cligen (R301),
# Clojure 1 babashka.cli (R302), Gleam Glint
# (R303), Ada GNAT.Command_Line (R304), C++ 1
# CLI11 (R305), Elixir Optimus (R306), Vala
# GLib.OptionContext (R307), Hare stdlib getopt
# (R308), Standard ML stdlib GetOpt (R309),
# Fortran M_CLI2 (R310), Guile (ice-9 getopt-
# long) (R311), Free Pascal TCustomApplication
# (R312), Idris 2 System.GetOpts (R313), Mercury
# stdlib getopt_io (R314), Eiffel Gobo AP_PARSER
# (R315), C++ 2 boost::program_options (R316),
# Forth/Gforth `next-arg` (R317), Clojure 2
# org.clojure/tools.cli (R318), Roc weaver (R319),
# Chapel `config` keyword (R320), Mojo `alias`-
# as-spec (R321), Java 2 JCommander (R322), Java 3
# args4j (R323), Chicken Scheme `args` egg (R324),
# OCaml 2 stdlib Arg (R325), Lean 4 Cli (R326),
# Bigloo Scheme `args-parse` macro (R327),
# **Erlang 2 stdlib argparse** (R328 — NEW).
# **MAJOR PATTERN MILESTONE**: 67 cross-language
# CLI library variants documented.  Erlang
# expands to 2 documented libraries (getopt +
# argparse) joining the multi-library club with
# Rust 6, Go 4, Python 3, Crystal 2, Common Lisp 2,
# Nim 2, Clojure 2, C++ 2, Java 3, OCaml 2, Scheme
# 4 dialects.
#
# Critical extraction note: aerepl uses **Erlang
# stdlib `argparse:run(Args, Cmd, Opts)` run-with-
# dispatch CLI pattern** at aerepl:10 — `argparse:
# run(Args, cli(), #{progname => "aerepl"})`
# handles BOTH parsing AND dispatch to the handler
# function in ONE CALL.  The handler function
# (specified in the command map as `handler =>
# {Module, Function}`) is called with the parsed
# args map AFTER successful parsing.  Distinct
# from R292 Erlang getopt (`getopt:parse/2`
# returns parsed-result tuple; caller dispatches),
# R322 JCommander `parse(*argv)` + manual
# dispatch, R325 OCaml `Arg.parse_argv` (mutates
# refs).  Erlang stdlib argparse's approach:
# UNIFIED PARSE-AND-DISPATCH — corpus's **first
# documented run-with-dispatch argparse CLI
# pattern**.
#
# Critical extraction note: aerepl uses **Erlang
# stdlib argparse map-of-maps spec CLI pattern**
# at aerepl:13-32 — `#{handler => {?MODULE,
# aerepl}, arguments => [#{name => accounts, long
# => "account", short => $a, nargs => 2, action
# => append, default => [], type => {custom, fun
# parse_account/1}}, ...]}`.  The COMMAND SPEC is
# an Erlang MAP `#{handler => H, arguments => L,
# commands => SUB, help => "..."}` and each
# OPTION SPEC is also a MAP `#{name => N, long =>
# "L", short => $C, type => T, ...}`.  Distinct
# from R292 Erlang getopt (list-of-4-tuples
# spec), R322 JCommander `@Parameter` annotation,
# R311 Guile `((NAME (single-char #\X) (value
# #t/#f)))` quoted alist.  Erlang stdlib
# argparse's approach: NESTED-MAPS SPEC — every
# command and option is an Erlang MAP.  Corpus's
# **first documented map-of-maps spec argparse
# CLI pattern**.
#
# Critical extraction note: aerepl uses **Erlang
# stdlib argparse type-with-constraint CLI
# pattern** at aerepl:20-27 — `type => {integer,
# [{min, 0}]}` (integer with minimum), `type =>
# {atom, [sophia, json, fate]}` (atom with
# allowed-values choice list), `type => boolean`
# (presence-only flag), `type => {custom, fun
# parse_account/1}` (custom parser function).
# The type spec can be a bare atom or a 2-tuple
# `{TYPE, CONSTRAINTS}`.  Distinct from R322
# JCommander reflection-based type detection,
# R325 OCaml `Arg.Set_int` / `Arg.Set_string`
# (type-named variants), R324 Chicken `#:required`
# (keyword arg-shape only).  Erlang stdlib
# argparse's approach: `{TYPE, [CONSTRAINTS]}`
# TUPLE for both type AND validation — corpus's
# **first documented type-with-constraint
# argparse CLI pattern**.
#
# Critical extraction note: aerepl uses **Erlang
# stdlib argparse `{Module, Function}` 2-tuple
# handler dispatch CLI pattern** at aerepl:14 —
# `handler => {?MODULE, aerepl}` specifies the
# dispatch target as a 2-TUPLE.  `?MODULE` is an
# Erlang PREPROCESSOR macro expanding to the
# current module name atom; `aerepl` is the
# function name atom.  argparse calls `apply
# (Module, Function, [ParsedArgsMap])` after
# parsing.  Distinct from R311 Guile `(args:make-
# option ... BODY)` (embedded thunk), R324
# Chicken `(args:make-option (h help) #:none
# HELP BODY)` (embedded body thunk), R322
# JCommander main-method (no explicit handler
# binding).  Erlang stdlib argparse's approach:
# 2-TUPLE Module-Function-name dispatch — corpus's
# **first documented 2-tuple-mfa-handler CLI
# dispatch pattern**.
#
# Critical extraction note: aerepl uses **Erlang
# escript `%%!`-VM-args-line CLI pattern** at
# aerepl:3 — `%%! -smp enable -setcookie aerepl_
# cookie -mnesia debug verbose`.  Lines starting
# with `%%!` are passed as ARGS to the Erlang VM
# when running the escript.  This allows the
# script to configure SMP, distributed-Erlang
# cookies, application environments, etc., at
# the VM level before the escript's `main/1`
# function runs.  Distinct from R290 Racket /
# R311 Guile / R324 Chicken shebang-only args.
# Corpus's **first documented escript-`%%!`-VM-
# args-line CLI pattern**.
#
# Critical extraction note: aerepl uses **Erlang
# `$a` char-literal short flag** at aerepl:16 —
# `short => $a` uses Erlang's `$X` CHAR LITERAL
# syntax.  Sister to R291 CL `#\h`, R298 Pony
# `'p'`, R300 V `` `n` ``, R308 Hare `'1'`, R311
# Guile `#\X`, R315 Eiffel `'V'`, R324 Chicken
# Scheme `(h help)` (UNQUOTED-SYMBOL pair).  This
# is corpus's NINTH character-literal CLI cluster
# language documentation: CL `#\X` (R291, R295),
# Erlang `$X` (R292 emqtt + R328 aerepl), Pony
# `'X'` (R298), V `` `X` `` (R300), Hare `'X'`
# (R308), Guile `#\X` (R311), Eiffel `'X'` (R315),
# Chicken `h` UNQUOTED-SYMBOL (R324 — DIFFERENT
# convention), **Erlang stdlib argparse `$X`
# (R328 — reaffirms Erlang convention with new
# library)**.  Erlang stdlib argparse uses the
# SAME `$X` convention as R292 emqtt getopt
# library — reaffirms Erlang language convention
# across different CLI libraries.
#
# Critical extraction note: aerepl uses **Erlang
# escript `#!/usr/bin/env escript` shebang +
# `-mode(compile).` attribute** at aerepl:1, 7 —
# escript is Erlang's standalone-script execution
# mode: the script is read by the Erlang VM and
# either INTERPRETED (default) or COMPILED
# (`-mode(compile).` attribute).  Distinct from
# R317 Forth Gforth shebang (`#! /usr/bin/env
# gforth`), R324 Chicken `#! /usr/bin/env csi -s`,
# R311 Guile `#! /usr/bin/env guile`.  Erlang's
# approach: ESCRIPT RUNTIME-COMPILE shebang with
# explicit mode attribute — corpus's **first
# documented escript-with-compile-mode-attribute
# CLI pattern**.
#
# Hunt-skip notes: skipped `_erlang` (Erlang
# language, in corpus + blacklisted), `_escript`
# (Erlang escript runner, in corpus), `_emqtt`
# (R292 — already documented as Erlang's first
# CLI library, jcomellas/getopt), `_edb` (in
# corpus as Evan's Debugger — different binary
# than WhatsApp/edb Erlang debugger that ALSO
# uses argparse:run; naming collision), `_unison`
# (DUP with stock zsh).  Probed `WhatsApp/edb`
# (107 stars but binary `edb` collides with
# Evan's Debugger in corpus), `duncanatt/paterl`
# (2 stars, Erlang-to-Pat transpiler — niche),
# `haruki7049/hoblisp.erl` (0 stars, hobby Lisp
# implementation), `happening-oss/kafcod` (6
# stars, Kafka codecs — library not CLI).  Chose
# aerepl: 6 GH stars (Æternity blockchain Sophia
# REPL by radrow), 14 named options in single
# 40-line cli/0 function exercising EVERY MAJOR
# Erlang stdlib argparse PATTERN (escript
# shebang + `%%!`-VM-args-line + `-mode(compile)`
# attribute, `argparse:run(Args, cli(), #{progname
# => "aerepl"})` run-with-dispatch, map-of-maps
# spec `#{handler => {Module, Function}, arguments
# => [#{name, long, short, type, nargs, action,
# default} ...]}`, type-with-constraint `{integer,
# [{min, 0}]}`/`{atom, [sophia, json, fate]}`,
# `{custom, fun parse_account/1}` function-
# reference custom type, Erlang `$a` char-literal
# short flag, `?MODULE` preprocessor macro,
# `{Module, Function}` 2-tuple handler dispatch),
# real escript binary distributed via Æternity's
# blockchain release.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# print_format enum values from type => {atom,
# [sophia,json,fate]} at aerepl:27
local -a print_formats=(
  'sophia:Sophia-language output format'
  'json:JSON output format'
  'fate:FATE (Fast Æternity Transaction Engine) bytecode format'
)

# 14 options decoded source-direct from argparse
# `arguments` list at aerepl:15-32.
_arguments -s -S \
  '(- *)'{-h,--help}'[display argparse-generated help]' \
  '*'{-a+,--account=}'[account specification (nargs=2, repeatable; pubkey-or-balance)]:pubkey/balance:' \
  '--call_gas=[call gas amount (integer, min: 0)]:gas:' \
  '--call_value=[call value (integer, min: 0)]:value:' \
  '--call_gas_price=[call gas price (integer, min: 0)]:price:' \
  '--call_origin=[call origin]:origin:' \
  '--call_contract_creator=[call contract creator]:creator:' \
  '--call_fee=[call fee (integer, min: 0)]:fee:' \
  '--call_height=[call height (integer, min: 1)]:height:' \
  '--print_gas[print gas information]' \
  '--print_format=[print format]:format:->print_formats' \
  '--print_unit[print unit information]' \
  '--print_type[print type information]' \
  '--loc_forwards=[forward source-location count (integer, min: 0)]:count:' \
  '--loc_backwards=[backward source-location count (integer, min: 0)]:count:' && ret=0

case $state in
  print_formats)
    _describe -t print_formats 'output format' print_formats && ret=0
    ;;
esac

return ret
