#compdef ledis-cli
# Documentation: https://github.com/ledisdb/ledisdb/blob/master/cmd/cli.go
# Command-line client for LedisDB, a Redis-protocol NoSQL database

local ret=1

_arguments -s -S \
  '-h+[ledisdb server ip]:host:_hosts' \
  '-p+[ledisdb server port]:port:' \
  '-s+[ledisdb server socket, overwrites ip and port]:socket:_files' \
  '-n+[ledisdb database number]:db:' && ret=0

return ret
