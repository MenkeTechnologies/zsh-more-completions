#compdef widelands
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man6/widelands.6.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy widelands(6) manpage. Accepts generic
# --<config-entry-name>=value form for any setting in the config
# file; runtime --help shows the full list.
# Removed from prior file: bogus man.archlinux.org search URL.

# widelands: real-time strategy game inspired by Settlers II
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*--*=[overwrite config setting]:key=value:' \
  '*:savegame:_files -g "*.wgf(-.)"' && ret=0
return ret
