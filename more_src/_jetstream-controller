#compdef jetstream-controller
# _jetstream-controller — NATS NACK JetStream controller (reconciles Stream / Consumer / KeyValue / ObjectStore custom resources)
# upstream: https://github.com/nats-io/nack
# Flags from cmd/jetstream-controller/main.go on tip.

_jetstream-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--namespace=[restrict to a namespace]:ns:' \
        '--creds=[NATS credentials file]:file:_files' \
        '--nkey=[NATS NKey seed]:nkey:' \
        '--tlscert=[NATS TLS public certificate]:file:_files' \
        '--tlskey=[NATS TLS private key]:file:_files' \
        '--tlsca=[NATS TLS CA chain]:file:_files' \
        '--tlsfirst[force explicit TLS before Server INFO]' \
        '-s+[NATS server URL]:url:' \
        '--crd-connect[connect using CRD config rather than global config]' \
        '--cleanup-period=[object cleanup interval]:duration:' \
        '--read-only[do not mutate NATS resources]' \
        '--cache-dir=[directory for cached credential + TLS files]:dir:_files -/' \
        '--control-loop[run controller with a full reconciliation loop (experimental)]' \
        '--sync-interval=[scheduled reconcile interval]:duration:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)'
}

_jetstream-controller "$@"
