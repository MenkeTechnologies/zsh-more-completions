#compdef mpcchap
# Documentation: https://www.musepack.net/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (verified locally via `mpcchap`
#   built-in usage string: "mpcchap <infile.mpc> <chapterfile.ini / cuefile>").

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input file:_files -g "*.mpc"' \
  '2:chapter file:_files -g "*.(ini|cue)"' && ret=0

return ret
