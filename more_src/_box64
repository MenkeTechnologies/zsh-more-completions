#compdef box64
# Documentation: https://github.com/ptitSeb/box64/blob/main/src/core.c
# Reference accessed: 2026-05-16
# Verified: src/core.c initialize() (lines 794-870). box64 is primarily
# env-driven via BOX64_* variables; CLI surface is minimal.

# box64: x86_64 (64-bit) Linux binary translator on ARM64
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show box64 version and exit]' \
  '(-k --kill-all)'{-k,--kill-all}'[kill box64 instances + clean dynarec cache]' \
  '(-t --test)'{-t,--test}'[test mode]' \
  '--dynacache-list[list dynarec cache entries]:dir:_files -/' \
  '--dynacache-clean[clean dynarec cache]' \
  '*:x86_64 ELF binary:_files' && ret=0
return ret
