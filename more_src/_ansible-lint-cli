#compdef ansible-lint-cli
# _ansible-lint-cli — Will Thames ansible-lint best-practices checker CLI alias (ansible team, Python); argparse
# upstream: https://github.com/ansible/ansible-lint

_ansible-lint-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[even more verbose]' \
        '-L[list rules]' \
        '--list-rules[list rules]' \
        '-T[list tags]' \
        '--list-tags[list tags]' \
        '-c+[config file]:file:_files -g ".ansible-lint*"' \
        '--config-file=+[config file]:file:_files -g ".ansible-lint*"' \
        '-r+[rules dir]:dir:_files -/' \
        '--rules-dir=+[rules dir]:dir:_files -/' \
        '-R[use default rules with extra]' \
        '-t+[tag csv]:str:' \
        '--tags=+[tag csv]:str:' \
        '-x+[skip rule csv]:str:' \
        '--skip-list=+[skip rule csv]:str:' \
        '-w+[warn list csv]:str:' \
        '--warn-list=+[warn list csv]:str:' \
        '--enable-list=+[enable list csv]:str:' \
        '--show-relpath[show relpath]' \
        '-p[parsable output]' \
        '--parseable[parsable output]' \
        '--parseable-severity[parsable severity]' \
        '-f+[format]:f:(rich plain rst codeclimate quiet pep8 sarif json)' \
        '--format=+[format]:f:(rich plain rst codeclimate quiet pep8 sarif json)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--profile=+[profile]:p:(min basic moderate safety shared production)' \
        '--strict[strict mode]' \
        '--write[autofix]' \
        '--exclude=+[paths]:str:' \
        '--no-progressive[no progressive]' \
        '--progressive[progressive]' \
        '--project-dir=+[dir]:dir:_files -/' \
        '--offline[offline]' \
        '--nocolor[no color]' \
        '--force-color[force color]' \
        '--generate-ignore[generate ignore file]' \
        '--ignore-file=+[file]:file:_files' \
        '--mock-modules=+[modules]:str:' \
        '--mock-roles=+[roles]:str:' \
        '--show-traceback[show traceback]' \
        '*:files:_files -g "*.{yml,yaml}"'
}

_ansible-lint-cli "$@"
