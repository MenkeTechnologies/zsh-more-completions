#compdef kafka-transactions
# Documentation: https://kafka.apache.org/documentation/ (kafka-transactions.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    {-v,--version}'[Show the version of this Kafka distribution and exit]'
    '--command-config[Property file containing configs to be passed to admin client]:file:_files'
    '--bootstrap-server[Hostname and port for the broker to connect to (host:port)]:host\:port:'
    '1:command:(list describe describe-producers abort find-hanging forceTerminateTransaction)'
    '--transactional-id[Transactional ID (describe/forceTerminateTransaction)]:id:'
    '--broker-id[Broker id (describe-producers/find-hanging)]:id:'
    '--topic[Topic name (describe-producers/abort/find-hanging)]:topic:'
    '--partition[Partition number (describe-producers/abort/find-hanging)]:partition:'
    '--start-offset[Start offset (abort)]:offset:'
    '--producer-id[Producer ID (abort)]:id:'
    '--producer-epoch[Producer epoch (abort)]:epoch:'
    '--coordinator-epoch[Transaction coordinator epoch (abort)]:epoch:'
    '--max-transaction-timeout[Max transaction timeout (find-hanging)]:ms:'
)

_arguments -s -S $arguments
