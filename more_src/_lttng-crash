#compdef lttng-crash
# Documentation: https://lttng.org/man/1/lttng-crash/v2.13/
# Reference accessed: 2026-05-30
# lttng-crash — recover and view tracing data from a crashed system (recovers traces from shared memory).
# Required positional: SHMDIR — directory specified via --shm-path when creating the recording session.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help (via manual pager)]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(- *)--list-options[list available command options]' \
  '(-x --extract)'{-x,--extract=}'[extract recovered traces to directory (skip executing reader)]:dir:_directories' \
  '*'{-v,--verbose}'[increase verbosity (up to 3 times)]' \
  '(-e --viewer)'{-e,--viewer=}'[trace reader to read the trace buffers]:reader:(babeltrace babeltrace2)' \
  '1:SHMDIR (shared-memory dir set via --shm-path):_directories' \
  && ret=0

return ret
