#compdef ggc
# Documentation: https://man.archlinux.org/search?q=ggc
# Reference accessed: 2026-05-16

# bmf-san/ggc — Git helper / TUI (`docs` registry)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'ggc command' compadd -- add bisect branch checkout cherry-pick clean clone commit diff fetch grep log merge pull push rebase reset revert rm stash status submodule switch tag remote doctor help
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
