#compdef envrc direnv-envrc
# _envrc — direnv .envrc bash dialect helper CLI alias (Zimbatm / direnv community, Bash); custom argparse via stdlib functions
# upstream: https://github.com/direnv/direnv

_envrc() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dotenv[load dotenv]' \
        '--strict_env[strict env]' \
        '--source_up=+[source up envrc]:file:_files' \
        '--source_env=+[source another envrc]:file:_files' \
        '--path_add=+[add to PATH]:dir:_files -/' \
        '--PATH_add=+[add to PATH]:dir:_files -/' \
        '--MANPATH_add=+[add to MANPATH]:dir:_files -/' \
        '--use=+[use shim]:str:(asdf flake nix node python venv ruby rvm rbenv nodenv pyenv)' \
        '--layout=+[layout]:str:(node python ruby haskell perl conda)' \
        '--watch_file=+[watch file]:file:_files' \
        '--watch_dir=+[watch dir]:dir:_files -/' \
        '--export=+[export var]:str:' \
        '--load_prefix=+[load prefix]:dir:_files -/' \
        '*:arg:'
}

_envrc "$@"
