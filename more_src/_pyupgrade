#compdef pyupgrade

# Zsh completion for pyupgrade - automatically upgrade Python syntax to newer versions

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--py3-plus[enable Python 3+ rewrites]' \
  '--py36-plus[enable Python 3.6+ rewrites]' \
  '--py37-plus[enable Python 3.7+ rewrites]' \
  '--py38-plus[enable Python 3.8+ rewrites]' \
  '--py39-plus[enable Python 3.9+ rewrites]' \
  '--py310-plus[enable Python 3.10+ rewrites]' \
  '--py311-plus[enable Python 3.11+ rewrites]' \
  '--py312-plus[enable Python 3.12+ rewrites]' \
  '--py313-plus[enable Python 3.13+ rewrites]' \
  '--keep-percent-format[keep percent format strings]' \
  '--keep-mock[keep mock imports as mock]' \
  '--keep-runtime-typing[keep runtime typing imports]' \
  '*:files:_files -g "*.py"'
