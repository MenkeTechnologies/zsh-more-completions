#compdef ssh-keyscan
# _ssh-keyscan-cli — OpenSSH host-key collector; gather host keys without ssh handshake
# upstream: https://github.com/openssh/openssh-portable

_ssh-keyscan-cli() {
    _arguments \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-c[scan only client cert]' \
        '-D[print public keys in SSHFP DNS format]' \
        '-f+[hosts file]:file:_files' \
        '-H[hash output]' \
        '-O+[option]:str:' \
        '-p+[port]:port:' \
        '-q[silent]' \
        '-T+[timeout]:n:' \
        '-t+[key types]:types:(rsa dsa ecdsa ed25519)' \
        '-v[verbose]' \
        '*:hostname:_hosts'
}

_ssh-keyscan-cli "$@"
