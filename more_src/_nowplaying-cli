#compdef nowplaying-cli
# Documentation: https://github.com/kirtan-shah/nowplaying-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nowplaying-cli: macOS Now Playing CLI
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'get:retrieve now playing media properties'
  'get-raw:obtain all non-nil now playing media properties as a dictionary'
  'play:play the currently playing media'
  'pause:pause the currently playing media'
  'togglePlayPause:toggle play/pause based on current state'
  'seek:seek to a specific time in the current media'
  'next:skip to next track'
  'previous:go to previous track'
)
_arguments -C \
  '1:command:->cmd' \
  '*::arg:_default' && ret=0
case $state in
  cmd) _describe -t commands 'nowplaying-cli command' commands && ret=0 ;;
esac
return ret
