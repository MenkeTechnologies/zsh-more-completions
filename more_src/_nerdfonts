#compdef nerdfonts font-patcher

# Zsh completion for nerdfonts font-patcher - Nerd Fonts patcher

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --complete)'{-c,--complete}'[add all available glyphs]' \
  '(-s --mono --use-single-width-glyphs)'{-s,--mono,--use-single-width-glyphs}'[use single-width glyphs (monospaced)]' \
  '--use-double-width-glyphs[use double-width glyphs]' \
  '(-l --adjust-line-height)'{-l,--adjust-line-height}'[adjust line height]' \
  '(-q --quiet --shutup)'{-q,--quiet,--shutup}'[suppress output]' \
  '(-w --windows)'{-w,--windows}'[limit internal name to 31 chars (Windows)]' \
  '--fontawesome[add Font Awesome glyphs]' \
  '--fontawesomeextension[add Font Awesome Extension glyphs]' \
  '--fontlogos[add Font Logos glyphs]' \
  '--octicons[add Octicons glyphs]' \
  '--codicons[add Codicons glyphs]' \
  '--powersymbols[add IEC Power Symbols]' \
  '--pomicons[add Pomicons glyphs]' \
  '--powerline[add Powerline glyphs]' \
  '--powerlineextra[add Powerline Extra glyphs]' \
  '--material[add Material Design Icons]' \
  '--weather[add Weather Icons]' \
  '--custom=[specify custom symbol font]:file:_files' \
  '--postprocess=[specify post-processing script]:file:_files' \
  '--removeligatures[remove ligatures from the font]' \
  '--configfile=[specify config file]:file:_files' \
  '(-ext --extension)'{-ext,--extension}'=[change output file extension]:extension' \
  '(-out --outputdir)'{-out,--outputdir}'=[specify output directory]:dir:_directories' \
  '--glyphdir=[specify glyph directory]:dir:_directories' \
  '--makegroups[use alternative grouping of glyphs]' \
  '--variable-width-glyphs[do not adjust advance width]' \
  '--has-no-italic[font does not have italic]' \
  '--progressbars[show progress bars]' \
  '--no-progressbars[disable progress bars]' \
  '--careful[do not overwrite existing glyphs]' \
  '1:font file:_files -g "*.{ttf,otf,woff,woff2}"' \
  && return 0
