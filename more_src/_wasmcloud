#compdef wasmcloud wash

local curcontext="$curcontext" state line ret=1

_wash_commands() {
  local -a commands=(
    'up:Start a local wasmCloud host'
    'down:Stop a local wasmCloud host'
    'build:Build a wasmCloud component or provider'
    'dev:Start a developer loop'
    'new:Create a new project from template'
    'inspect:Inspect a component or provider'
    'claims:Interact with claims'
    'keys:Manage keys'
    'par:Create and manage provider archives'
    'ctl:Interact with a wasmCloud control interface'
    'app:Manage applications via wadm'
    'config:Manage wash configuration'
    'completions:Generate shell completions'
    'spy:Spy on invocations to a component'
    'ui:Launch the wasmCloud dashboard'
  )
  _describe -t commands 'wash command' commands
}

_wash_new_commands() {
  local -a subcmds=(
    'component:Create a new component project'
    'provider:Create a new provider project'
  )
  _describe -t commands 'new subcommand' subcmds
}

_wash_claims_commands() {
  local -a subcmds=(
    'inspect:Inspect the claims of a component or provider'
    'sign:Sign a component'
    'token:Generate a signed JWT'
  )
  _describe -t commands 'claims subcommand' subcmds
}

_wash_keys_commands() {
  local -a subcmds=(
    'gen:Generate a new key pair'
    'get:Get a key pair'
    'list:List key pairs'
  )
  _describe -t commands 'keys subcommand' subcmds
}

_wash_ctl_commands() {
  local -a subcmds=(
    'start:Start a component or provider'
    'stop:Stop a component or provider'
    'update:Update a component'
    'link:Manage links'
    'get:Get information about hosts, inventory, or claims'
    'label:Manage host labels'
  )
  _describe -t commands 'ctl subcommand' subcmds
}

_wash_app_commands() {
  local -a subcmds=(
    'deploy:Deploy an application'
    'undeploy:Undeploy an application'
    'put:Put an application manifest'
    'get:Get application details'
    'list:List applications'
    'delete:Delete an application'
    'history:View application history'
    'status:Get application status'
  )
  _describe -t commands 'app subcommand' subcmds
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  {-o,--output}'[Output format]:format:(json text)' \
  '--experimental[Enable experimental features]' \
  '--context[Path to context configuration]:context file:_files' \
  '1:command:_wash_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      up)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--host-seed[Host seed key]:seed' \
          '--rpc-host[RPC host]:host' \
          '--rpc-port[RPC port]:port' \
          '--rpc-timeout-ms[RPC timeout in ms]:ms' \
          '--ctl-host[Control interface host]:host' \
          '--ctl-port[Control interface port]:port' \
          '--lattice[Lattice name]:lattice' \
          '--wasmcloud-version[wasmCloud version to use]:version' \
          '--nats-port[NATS port]:port' \
          '--nats-websocket-port[NATS websocket port]:port' \
          '--detached[Run in detached mode]' \
          '--wadm-version[wadm version to use]:version' \
          && ret=0
        ;;
      down)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--all[Stop all hosts]' \
          '--host-id[Stop a specific host]:host-id' \
          '--lattice[Lattice name]:lattice' \
          && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--config-path[Path to wasmcloud.toml]:config:_files' \
          '--sign-only[Only sign the component]' \
          && ret=0
        ;;
      dev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--host-seed[Host seed key]:seed' \
          '--nats-port[NATS port]:port' \
          '--leave-host-running[Leave host running on exit]' \
          && ret=0
        ;;
      new)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '--template-name[Template name]:template' \
          '--path[Output path]:path:_files -/' \
          '1:subcommand:_wash_new_commands' \
          '*:name' \
          && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--jwt-only[Only inspect JWT]' \
          '--wit[Inspect WIT]' \
          '*:file:_files' \
          && ret=0
        ;;
      claims)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_wash_claims_commands' \
          '*:file:_files' \
          && ret=0
        ;;
      keys)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_wash_keys_commands' \
          && ret=0
        ;;
      ctl)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_wash_ctl_commands' \
          && ret=0
        ;;
      app)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[Show help]' \
          '1:subcommand:_wash_app_commands' \
          '*:file:_files' \
          && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          && ret=0
        ;;
      completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '1:shell:(bash zsh fish powershell elvish)' \
          && ret=0
        ;;
      spy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--ctl-host[Control interface host]:host' \
          '--ctl-port[Control interface port]:port' \
          '--lattice[Lattice name]:lattice' \
          '*:component-id' \
          && ret=0
        ;;
      ui)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '--open[Open the UI in a browser]' \
          && ret=0
        ;;
      par)
        _arguments -s -S \
          '(- *)'{-h,--help}'[Show help]' \
          '*:file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
