#compdef vcfevenregions
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfevenregions.md
# vcflib: generate evenly-sized regions across a VCF for downstream processing

local ret=1

_arguments -s -S \
  '(-f --fasta-reference)'{-f,--fasta-reference}'[FASTA reference file to obtain primer sequences]:reference:_files' \
  '(-n --number-of-regions)'{-n,--number-of-regions}'[the number of desired regions]:N' \
  '(-p --number-of-positions)'{-p,--number-of-positions}'[the number of positions per region]:N' \
  '(-o --offset)'{-o,--offset}'[add an offset to region positioning]:N' \
  '(-l --overlap)'{-l,--overlap}'[the number of sites to overlap between regions (default 0)]:N' \
  '(-s --separator)'{-s,--separator}'[string to use to separate region output (default -)]:separator' \
  '*:vcf file:_files' && ret=0

return ret
