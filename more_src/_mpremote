#compdef mpremote

# Zsh completion for mpremote - MicroPython remote control tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'connect:connect to a device via the given transport'
  'disconnect:disconnect current device'
  'resume:resume a previous mpremote session'
  'soft-reset:perform a soft-reset of the device'
  'reset:perform a hard-reset of the device'
  'repl:enter the REPL on the connected device'
  'eval:evaluate and print result of a Python expression'
  'exec:execute Python code'
  'run:run a local Python script on the remote device'
  'fs:execute file system commands on the device'
  'ls:list files on the device (shortcut for fs ls)'
  'cat:output contents of files on the device'
  'cp:copy files between host and device'
  'rm:remove files on the device'
  'mkdir:create a directory on the device'
  'rmdir:remove a directory from the device'
  'touch:create a new file on the device'
  'edit:edit files on the device'
  'df:show disk space usage on the device'
  'mount:mount a local directory on the remote device'
  'umount:unmount the local directory'
  'mip:install packages via mip (MicroPython package manager)'
  'bootloader:enter bootloader mode'
  'help:print help information'
  'version:print mpremote version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show mpremote version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mpremote command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (connect)
        _arguments \
          '1:target:(auto list id: port: rfc2217:)' && ret=0
        ;;
      (fs)
        _arguments \
          '1:fs command:(ls cat cp rm mkdir rmdir touch tree sha256sum)' \
          '*:path:_files' && ret=0
        ;;
      (cp)
        _arguments \
          '-r[recursive copy]' \
          '*:file:_files' && ret=0
        ;;
      (run)
        _arguments '1:script:_files -g "*.py"' && ret=0
        ;;
      (mount)
        _arguments \
          '-l[enable unsafe listing of host directories]' \
          '1:directory:_files -/' && ret=0
        ;;
      (mip)
        _arguments \
          '1:subcommand:(install list)' \
          '--target[installation target directory]:dir:' \
          '--index[package index URL]:url:' \
          '--no-mpy[do not compile to .mpy]' \
          '*:package:' && ret=0
        ;;
      (exec|eval)
        _arguments '*:code:' && ret=0
        ;;
      (edit|cat|rm)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
