#compdef infoseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/infoseq.html
# infoseq - Display basic information about sequences

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input sequence(s) (USA)]:file:_files' \
  '-outfile[write sequence details to file]:file:_files' \
  '-html[format output as HTML table]' \
  '-columns[print information in aligned columns]' \
  '-delimiter[delimiter between records]:delimiter:' \
  '-only[display only selected fields]' \
  '-heading[display column headings]' \
  '-usa[show Uniform Sequence Address]' \
  '-database[display database column]' \
  '-name[display sequence name column]' \
  '-accession[display accession number column]' \
  '-gi[display GI column]' \
  '-seqversion[display version column]' \
  '-type[display sequence type (N/P)]' \
  '-length[display sequence length]' \
  '-pgc[display percent GC content]' \
  '-organism[display organism information]' \
  '-description[display sequence description]' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-die[report program messages]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
