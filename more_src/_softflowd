#compdef softflowd
# Documentation: https://man.archlinux.org/search?q=softflowd
# Reference accessed: 2026-05-16

_arguments -s \
  '-i[interface (or if_ndx:iface)]:iface:_net_interfaces' \
  '-r[pcap file]:file:_files' \
  '-p[pid file]:file:_files' \
  '-c[control socket]:socket:_files' \
  '-m[max flows]:n:' \
  '-t[timeout NAME=SECS]:timeout:' \
  '-d[debug, no daemonize]' \
  '-D[debug]' \
  '-N[no promisc]' \
  '-6[force IPv6]' \
  '-B[libpcap buffer size]:bytes:' \
  '-b[bidirectional IPFIX]' \
  '-a[adjust pcap time]' \
  '-l[load balance to multiple collectors]' \
  '-x[MPLS label depth]:n:' \
  '(- *)-h[show help]' \
  '-L[IP hoplimit]:n:' \
  '-T[track level]:level:(ether vlan full proto ip)' \
  '*-n[collector host:port]:host:port:' \
  '-v[NetFlow version]:version:(1 5 9 10 psamp)' \
  '-P[transport protocol]:proto:(udp tcp sctp)' \
  '-A[timestamp resolution]:res:(sec milli micro nano)' \
  '-s[sampling rate]:n:' \
  '-C[capture length]:n:' \
  '-R[receive port]:port:' \
  '-S[send interface]:iface:_net_interfaces' \
  '-e[exporter IP]:ip:'
