#compdef gmtregress
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtregress.html
# Source: GenericMappingTools/gmt classic-mode gmtregress — robust linear regression (x/y/orthogonal/RMA × L1/L2/LMS/RLS).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[scan slope angles / restrict angle range]:opts:_default' \
    '-C+[confidence-band level (%)]:pct:_default' \
    '-E+[regression direction]:direction:(x y o r)' \
    '-F+[output cols (x/y/model/residual/conf/z/weight/params)]:cols:_default' \
    '-N+[misfit norm]:norm:(1 2 r w)' \
    '-S+[exclude outliers or show only outliers]:opts:_default' \
    '-T+[evaluate at equidistant points or coords]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[weighted regression with uncertainties]:opts:_default' \
    '-Z+[outlier z-score threshold]:value:_default' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '-s+[NaN-record handling]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
