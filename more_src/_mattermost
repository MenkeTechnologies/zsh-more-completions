#compdef mmctl mattermost

# Zsh completion for Mattermost CLI (mmctl)

_mattermost() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'auth:manage the credentials of the remote Mattermost instances'
    'bot:manage bots'
    'channel:manage channels'
    'command:manage slash commands'
    'completion:generate autocompletion scripts'
    'config:manage the configuration'
    'export:manage exports'
    'extract:manage content extraction'
    'group:manage groups'
    'import:manage imports'
    'integrity:check database integrity'
    'ldap:manage LDAP'
    'license:manage the server license'
    'logs:display server logs'
    'oauth:manage OAuth2 apps'
    'permissions:manage permissions'
    'plugin:manage plugins'
    'post:manage posts'
    'roles:manage user roles'
    'saml:manage SAML'
    'system:manage the system'
    'team:manage teams'
    'token:manage personal access tokens'
    'user:manage users'
    'version:print the version'
    'webhook:manage webhooks'
    'workspace:manage workspaces'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'mmctl command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        auth)
          _arguments -s -S \
            '1:subcommand:(clean current delete list login renew set)' \
            && ret=0
          ;;
        channel)
          _arguments -s -S \
            '1:subcommand:(archive create delete list make-read-only modify move rename restore search unarchive users)' \
            && ret=0
          ;;
        config)
          _arguments -s -S \
            '1:subcommand:(edit get migrate patch reload reset set show subpath)' \
            && ret=0
          ;;
        export)
          _arguments -s -S \
            '1:subcommand:(create delete download job list)' \
            && ret=0
          ;;
        import)
          _arguments -s -S \
            '1:subcommand:(job list process upload validate)' \
            && ret=0
          ;;
        plugin)
          _arguments -s -S \
            '1:subcommand:(add delete disable enable install-url list marketplace)' \
            && ret=0
          ;;
        team)
          _arguments -s -S \
            '1:subcommand:(archive create delete list modify rename restore search users)' \
            && ret=0
          ;;
        user)
          _arguments -s -S \
            '1:subcommand:(activate change-password convert create deactivate delete demote email invite list migrate-auth preference promote reset-password resetmfa search update)' \
            && ret=0
          ;;
        webhook)
          _arguments -s -S \
            '1:subcommand:(create-incoming create-outgoing delete list modify-incoming modify-outgoing show)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--config=[path to config file]:config file:_files -g "*.json"' \
            '--config-path=[path to config directory]:directory:_files -/' \
            '--format=[output format]:format:(plain json)' \
            '--insecure-sha1-intermediate[allow SHA-1 certificates]' \
            '--insecure-tls-version[allow TLS versions below 1.2]' \
            '--local[communicate through the local socket]' \
            '--strict[fail on warnings]' \
            '--suppress-warnings[suppress warnings]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_mattermost "$@"
