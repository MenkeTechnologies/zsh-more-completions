#compdef airshipctl
# Documentation: https://docs.airshipit.org/airshipctl/cli/airshipctl.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Print version]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--airshipconfdir=[airship config dir]:dir:_directories' \
  '1: : _default' \
  '*::args: _default'
