#compdef airshipctl
# Documentation: https://man.archlinux.org/search?q=airshipctl
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Print version]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--airshipconfdir=[airship config dir]:dir:_directories' \
  '1: : _default' \
  '*::args: _default'
