#compdef readahead readahead-bpfcc
# _readahead — show fs page-cache read-ahead usage / efficiency (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/readahead.py (argparse).

_readahead() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-d --duration)'{-d+,--duration=}'[total monitoring duration (seconds)]:seconds:'
    )
    _arguments $args
}

_readahead "$@"
