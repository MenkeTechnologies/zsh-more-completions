#compdef dipy_denoise_patch2self
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_denoise_patch2self.html
# DIPY: Patch2Self self-supervised denoising

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[algorithm for solving linear equations]:model:(ols ridge lasso)' \
  '--b0_threshold=[threshold for identifying b0 volumes]:thr' \
  '--alpha=[regularization parameter for ridge regression]:alpha' \
  '--verbose[display progress and timing information]' \
  '--patch_radius=[radius of local patch around each voxel]:radius' \
  '--skip_b0_denoising[bypass b0 volume denoising]' \
  '--clip_negative_vals[set negative post-denoising values to zero]' \
  '--skip_shift_intensity[skip intensity distribution shifting per volume]' \
  '--ver=[algorithm version]:ver:(1 3)' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_denoised=[output filename]:file:_files' \
  '*:input (volumes bval):_files' && ret=0

return ret
