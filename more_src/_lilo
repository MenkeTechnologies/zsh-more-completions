#compdef lilo
# Documentation: https://manpages.debian.org/buster/lilo/lilo.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A+[activate/show active partition]:device:_files -g "/dev/*"' \
  '-b+[set boot device for loader install]:device:_files -g "/dev/*"' \
  '-B+[bitmap file for boot-time graphics]:file:_files' \
  '-C+[config file]:file:_files' \
  '-c[enable map compaction]' \
  '-d+[delay (deciseconds)]:n:' \
  '-D+[default label]:label:' \
  '-F[override boot sector filesystem checks]' \
  '-f+[disk geometry file]:file:_files' \
  '-g[generate CHS geometric addresses]' \
  '-H[override halt for inactive RAID arrays]' \
  '-I+[inquire path of kernel/related files]:label:' \
  '-i+[boot loader file]:file:_files' \
  '-l[generate 24-bit linear sector addresses]' \
  '-L[use LBA32]' \
  '-m+[alternate map file]:file:_files' \
  '-M+[install master boot record to device]:device:_files -g "/dev/*"' \
  '-P+[fix or ignore corrupt partition tables]:opt:(fix ignore)' \
  '-p[require interactive password entry]' \
  '-q[query mode (show config)]' \
  '-Q[print install boot loader to stdout]' \
  '-R+[default command line for next reboot]:cmd:' \
  '-r+[chroot]:dir:_files -/' \
  '-S+[force overwriting existing backup]:file:_files' \
  '-s+[backup save file]:file:_files' \
  '-T+[print system information]:topic:' \
  '-t[test only - do not write]' \
  '-U+[unconditionally uninstall MBR]:device:_files -g "/dev/*"' \
  '-u+[uninstall MBR from device]:device:_files -g "/dev/*"' \
  '-v[verbose (multiple allowed)]' \
  '-w[suppress warnings]' \
  '-X[display LILO internal information]' \
  '-x+[RAID-specific boot device options]:opts:' \
  '-Z+[BIOS device code handling]:code:' \
  '-z[clear Volume-ID]' && ret=0

return ret
