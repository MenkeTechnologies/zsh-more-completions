#compdef krfb-virtualmonitor

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--resolution=+[WxH]:res:' \
  '--scale=+[scale factor]:n:' \
  '--name=+[monitor name]:name:' \
  '--connect[connect via]' \
  '--port=+[port]:port:' \
  '--password=+[password]:pw:' && ret=0

return ret
