#compdef krfb-virtualmonitor
# Documentation: https://invent.kde.org/network/krfb/-/blob/master/krfb/main-virtualmonitor.cpp
# Reference accessed: 2026-05-19
# Verified: upstream krfb/main-virtualmonitor.cpp QCommandLineParser.
# Removed fabricated --connect option.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--resolution=[logical resolution of the new monitor]:resolution:' \
  '--name=[name of the monitor]:name:' \
  '--password=[password for the client to connect]:password:' \
  '--scale=[device-pixel-ratio / scaling factor]:dpr:' \
  '--port=[the port we will be listening to]:number:' && ret=0

return ret
