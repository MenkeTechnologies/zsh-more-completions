#compdef mafFrag
# UCSC kent: extract maf for a region from a database maf track

local ret=1

_arguments -s -S \
  '-outName=[use this instead of database.chrom for the name]:name' \
  '1:database:' \
  '2:maf track:' \
  '3:chrom:' \
  '4:start:' \
  '5:end:' \
  '6:strand:(+ -)' \
  '7:output maf:_files -g "*.maf"' && ret=0

return ret
