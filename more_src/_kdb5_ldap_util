#compdef kdb5_ldap_util
# _kdb5_ldap_util — MIT Kerberos kdb5_ldap_util CLI administration utility for Kerberos KDC databases stored in LDAP backends OpenLDAP 389-DS creating destroying modifying ldap-realm container DN service-account credentials destroy stash master key list view subtree (MIT team, C); getopt
# upstream: https://web.mit.edu/kerberos/

_kdb5_ldap_util() {
    local -a sub=(
        'create:create realm container'
        'modify:modify realm attributes'
        'view:view realm attributes'
        'destroy:destroy realm container'
        'list:list realms'
        'stashsrvpw:stash service password'
        'create_policy:create ticket policy'
        'modify_policy:modify ticket policy'
        'get_policy:view policy'
        'destroy_policy:destroy policy'
        'list_policy:list policies'
    )
    _arguments -C \
        '-h[show help]' \
        '-D+[bind DN]:str:' \
        '-w+[bind password]:str:' \
        '-H+[LDAP URI]:str:' \
        '-y+[password file]:file:_files' \
        '-r+[realm]:str:' \
        '-P+[principal]:str:' \
        '-k+[kvno]:n:' \
        '-K+[krb5 keysalt]:str:' \
        '-t+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kdb5_ldap_util subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '-subtrees+[dn]:str:' \
                    '-sscope+[scope]:s:(one sub)' \
                    '-containerref+[dn]:str:' \
                    '-k+[keysalt]:str:' \
                    '-m[stash master key]' \
                    '-r+[realm]:str:' ;;
            esac
            ;;
    esac
}

_kdb5_ldap_util "$@"
