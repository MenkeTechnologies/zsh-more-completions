#compdef ssl-cert-check

_ssl-cert-check() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(-h --help)'{-h,--help}'[show help message and exit]' \
        '(-V --version)'{-V,--version}'[show version and exit]' \
        '(-s --server)'{-s,--server}'[server hostname and port to check]:hostname\:port:_hosts' \
        '(-p --port)'{-p,--port}'[port number]:port:' \
        '(-f --file)'{-f,--file}'[certificate file to check]:certificate file:_files' \
        '(-c --check)'{-c,--check}'[file containing list of servers to check]:check file:_files' \
        '(-d --days)'{-d,--days}'[warn if certificate expires within N days]:days:' \
        '(-e --email)'{-e,--email}'[send email alerts to this address]:email address:' \
        '(-q --quiet)'{-q,--quiet}'[suppress output, only set exit code]' \
        '(-a --all)'{-a,--all}'[check all certificates in chain]' \
        '(-x --proxy)'{-x,--proxy}'[use HTTP proxy]:proxy:_urls' \
        '(-n --nagios)'{-n,--nagios}'[output in Nagios plugin format]' \
        '(-t --timeout)'{-t,--timeout}'[connection timeout in seconds]:seconds:' \
        '(-i --issuer)'{-i,--issuer}'[display certificate issuer]' && ret=0

    return ret
}

_ssl-cert-check "$@"
