#compdef raToTab
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert ra file to table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-cols=[comma-separated columns to output in order]:cols:' \
  '-head[put column names in header]' \
  ':in ra:_files' \
  ':out tab:_files' && ret=0

return ret
