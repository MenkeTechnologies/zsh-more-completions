#compdef cargo-test

# Zsh completion for cargo test

_arguments -s -S \
  '1:test name filter:' \
  '--no-run[compile but do not run tests]' \
  '--no-fail-fast[run all tests regardless of failure]' \
  '(-p --package)'{-p+,--package=}'[package to test]:package:' \
  '--all[alias for --workspace]' \
  '--workspace[test all packages in workspace]' \
  '--exclude=[exclude packages]:package:' \
  '--lib[test only library]' \
  '--bin=[test only specified binary]:binary:' \
  '--bins[test all binaries]' \
  '--example=[test only specified example]:example:' \
  '--examples[test all examples]' \
  '--test=[test only specified test target]:test:' \
  '--tests[test all tests]' \
  '--bench=[test only specified bench target]:bench:' \
  '--benches[test all benches]' \
  '--all-targets[test all targets]' \
  '--doc[test only library documentation]' \
  '--release[test in release mode]' \
  '--profile=[test with specified profile]:profile:(dev release test bench)' \
  '--features=[space or comma separated list of features]:features:' \
  '--all-features[activate all available features]' \
  '--no-default-features[do not activate default feature]' \
  '--target=[test for target triple]:target triple:' \
  '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs]:jobs:' \
  '--manifest-path=[path to Cargo.toml]:manifest path:_files -g "*.toml"' \
  '--message-format=[error format]:format:(human json short)' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock and cache are up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without accessing the network]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '-- :test binary arguments:' \
  '*::args:_default'
