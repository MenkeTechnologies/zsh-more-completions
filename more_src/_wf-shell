#compdef wf-shell wf-panel wf-background wf-dock
# Documentation: https://github.com/WayfireWM/wf-shell
# Reference accessed: 2026-05-16
# Verified: README only documents -c/--config flag; main.cpp parses no other
# documented flags. wf-shell ships several binaries (wf-panel, wf-background,
# wf-dock) sharing this completion.

# wf-shell: Wayfire panel/dock/background
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --config)'{-c,--config=}'[custom configuration file]:file:_files' && ret=0
return ret
