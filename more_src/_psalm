#compdef psalm

# Zsh completion for Psalm - PHP static analysis tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--show-info=[show non-error information]:show:(true false)' \
  '--diff[only analyze changed files]' \
  '--output-format=[output format]:format:(console json xml text emacs pylint checkstyle sonarqube github phpstorm codeclimate by-issue-level count)' \
  '--find-dead-code[detect dead code]' \
  '--find-unused-code[detect unused code]' \
  '--find-unused-variables[detect unused variables]' \
  '--find-references-to=[find references to a symbol]:symbol:' \
  '--threads=[number of threads to use]:threads:' \
  '(-c --config)'{-c,--config}'=[path to config file]:config file:_files -g "*.xml"' \
  '(-r --root)'{-r,--root}'=[project root directory]:directory:_directories' \
  '--no-cache[run without cache]' \
  '--clear-cache[clear local cache]' \
  '--clear-global-cache[clear global cache]' \
  '--no-progress[disable progress bar]' \
  '--long-progress[display a progress bar with more detail]' \
  '--stats[show analysis stats]' \
  '--alter[allow Psalm to alter code]' \
  '--language-server[start language server]' \
  '--set-baseline=[set error baseline file]:file:_files' \
  '--use-baseline=[use error baseline file]:file:_files' \
  '--update-baseline[update the error baseline]' \
  '--ignore-baseline[ignore the error baseline]' \
  '--generate-json-map=[generate type map JSON]:file:_files' \
  '--generate-stubs=[generate stubs file]:file:_files' \
  '--php-version=[PHP version to target]:version:(7.0 7.1 7.2 7.3 7.4 8.0 8.1 8.2 8.3)' \
  '*--plugin=[path to plugin file]:plugin file:_files' \
  '--init[initialize a psalm config]' \
  '--debug[enable debug output]' \
  '--debug-by-line[debug output per line]' \
  '--debug-emitted-issues[debug emitted issues]' \
  '--no-suggestions[hide suggestions]' \
  '--taint-analysis[enable taint analysis]' \
  '--security-analysis[enable security analysis]' \
  '*--report=[generate a report file]:file:_files' \
  '--report-show-info=[show info in report]:show:(true false)' \
  '--no-file-cache[disable file-based cache]' \
  '--memory-limit=[memory limit]:limit:' \
  '*--disable-extension=[disable a PHP extension]:extension:' \
  '--error-level=[error level to report]:level:(1 2 3 4 5 6 7 8)' \
  '*:files or directories:_files'
