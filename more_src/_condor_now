#compdef condor_now
# _condor_now — HTCondor condor_now (administrative pre-empt-and-start helper: kicks the negotiator to immediately stop a victim job and start a beneficiary one against the freed slot; -name schedd name, -pool collector address, -debug; positional argument is the beneficiary jobID followed by victim jobIDs)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_now on tip.

_condor_now() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-debug[debug]' \
        '-name+[schedd]:name:' \
        '-pool+[collector]:host:_hosts' \
        '1:beneficiary jobID:' \
        '*:victim jobID:'
}

_condor_now "$@"
