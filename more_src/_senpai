#compdef senpai
# Documentation: https://git.sr.ht/~delthas/senpai (doc/senpai.1.scd)
# Reference accessed: 2026-05-21
# Verified: senpai man page OPTIONS section.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-config[config file path]:file:_files' \
  '-nickname[connection nickname override]:nick:' \
  '-debug[show all IRC messages received/sent]' \
  '-version[show version]' && ret=0

return ret
