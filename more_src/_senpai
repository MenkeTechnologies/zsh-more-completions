#compdef senpai
# Documentation: https://man.archlinux.org/search?q=senpai
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  '-config=[config file]:file:_files -g "*.scfg"' \
  '-debug[debug logging]' \
  '-nickname=[nickname override]:nick:' \
  '-username=[username override]:user:' \
  '-realname=[realname override]:name:' \
  '-channel=[channel override]:chan:' \
  '-password=[server password]:pw:' \
  '-address=[server address]:host:' \
  '-tls=[use TLS]:bool:(true false)' \
  '-pane=[start pane]:pane:(home network)' && ret=0

return ret
