#compdef cryptominisat cryptominisat5
# Documentation: https://github.com/msoos/cryptominisat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# SAT solver. Full option list via `cryptominisat5 --help`; only stable flags wired here.

_arguments -s -S \
  '--help[show help]' \
  '--hhelp[show extended help]' \
  '--version[show version]' \
  '--verb=[verbosity level]:level:' \
  '--threads=[number of threads]:n:' \
  '--maxtime=[time budget in seconds]:seconds:' \
  '--maxconfl=[max conflicts]:n:' \
  '--input=[input DIMACS file]:file:_files -g "*.cnf*"' \
  '--polar=[polarity]:mode:(true false rnd auto stable)' \
  '--maxmatrixrows=[max gauss matrix rows]:n:' \
  '--minmatrixrows=[min gauss matrix rows]:n:' \
  '--autodisablegauss=[auto-disable poor gauss matrices]:bool:(0 1)' \
  '--iterreduce=[iteratively reduce matrices]:bool:(0 1)' \
  '--savematrix=[save matrix every Nth decision]:n:' \
  '--maxnummatrixes=[max matrices to process]:n:' \
  '*:cnf file:_files -g "*.cnf*"'
