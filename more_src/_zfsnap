#compdef zfsnap
# Documentation: https://www.zfsnap.org/zfsnap_manpage.html
# zfsnap: portable ZFS snapshot creation and expiry tool

local ret=1

_arguments -C \
  '-h[print a summary of command-line options and exit]' \
  '-V[display version information and exit]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'snapshot:create ZFS snapshots with a configurable TTL'
      'destroy:remove expired or specified zfsnap snapshots'
      'recurseback:rollback datasets and children to a snapshot'
    )
    _describe -t commands 'zfsnap command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      snapshot)
        _arguments \
          '-a[how long the snapshots should be kept (TTL)]:ttl' \
          '-p[apply a naming prefix to snapshots]:prefix' \
          '-P[omit any prefix from snapshot names]' \
          '-r[create snapshots recursively]' \
          '-R[create non-recursive snapshots only]' \
          '-s[skip pools that are resilvering]' \
          '-S[skip pools that are scrubbing]' \
          '-v[verbose output]' \
          '-z[round creation timestamp to 00 seconds]' \
          '-n[dry-run mode]' \
          '-h[show command help]' \
          '*:dataset:' && ret=0
        ;;
      destroy)
        _arguments \
          '-D[delete all zfsnap snapshots regardless of TTL]' \
          '-F[force-delete snapshots exceeding age]:age' \
          '-p[only consider snapshots matching this prefix]:prefix' \
          '-P[disable prefix filtering]' \
          '-r[operate recursively across datasets]' \
          '-R[do not operate recursively]' \
          '-s[skip resilvering pools]' \
          '-S[skip scrubbing pools]' \
          '-v[verbose output]' \
          '-n[dry-run mode]' \
          '-h[show command help]' \
          '*:dataset:' && ret=0
        ;;
      recurseback)
        _arguments \
          '-d[limit recursion depth]:depth' \
          '-f[force unmount clones]' \
          '-r[destroy snapshots/bookmarks more recent than specified]' \
          '-R[destroy newer snapshots/bookmarks including clones]' \
          '-v[verbose output]' \
          '-n[dry-run mode]' \
          '-h[show command help]' \
          '*:snapshot:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
