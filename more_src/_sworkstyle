#compdef sworkstyle
# Documentation: https://man.archlinux.org/search?q=sworkstyle
# Reference accessed: 2026-05-16

# Zsh completion for sworkstyle (Lyr-7D1h/swayest_workstyle).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-l --log-level)'{-l,--log-level=}'[log filter]:level:(error warn info debug off)' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-d --deduplicate)'{-d,--deduplicate}'[dedupe repeated workspace icons]'
