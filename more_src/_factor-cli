#compdef factor-cli factor2
# _factor-cli — Factor Project factor-cli CLI launcher around the Factor Language a concatenative stack-based programming language with image-based development like Smalltalk Forth-inspired syntax compile-image run-script user-init-file noinit-bootstrap-image-deploy modes for the factor binary image-based shell-pipeline (Factor team, C++); custom argparse
# upstream: https://factorcode.org/

_factor-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-quiet[quiet]' \
        '-script[run file as script]' \
        '-run+[vocabulary]:str:' \
        '-shell+[words]:str:' \
        '-e+[code]:str:' \
        '-image+[image]:file:_files -g "*.image"' \
        '-bootstrap[bootstrap image]' \
        '-no-user-init[skip user-init.factor]' \
        '-deploy=+[vocab]:str:' \
        '-i+[input]:file:_files' \
        '-ui-text-input[text-based UI]' \
        '-pic[show pic for word]' \
        '-no-strict[non-strict mode]' \
        '-ui-tools[start UI tools]' \
        '-listener[start listener]' \
        '-trace[trace]' \
        '*:script file:_files -g "*.factor *.factor-rc"'
}

_factor-cli "$@"
