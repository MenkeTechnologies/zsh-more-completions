#compdef uu-groups
# Documentation: https://man.archlinux.org/search?q=uu-groups
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-groups() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::USERNAME:_users' \
&& ret=0
}

(( $+functions[_uu-groups_commands] )) ||
_uu-groups_commands() {
    local commands; commands=()
    _describe -t commands 'uu-groups commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-groups" ]; then
    _uu-groups "$@"
else
    compdef _uu-groups uu-groups
fi
