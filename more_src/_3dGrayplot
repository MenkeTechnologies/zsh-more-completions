#compdef 3dGrayplot
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dGrayplot.html
# AFNI make a grayscale carpet plot from a 3D+time dataset

local ret=1

_arguments -s -S \
  '-mask[mask dataset; values 1-255 partition voxels]:mask:_files' \
  '-input[input dataset]:dataset:_files' \
  '-prefix[output image filename (.png/.jpg/.pgm)]:prefix:_files' \
  '-dimen[output image dimensions X Y in pixels]:x:' \
  '-oldresam[use original resampling method]' \
  '-polort[polynomial order for detrending]:p:' \
  '-fwhm[spatial blur FWHM in mm]:f:' \
  '-pvorder[order voxels by principal component]' \
  '-LJorder[order voxels by Ljung-Box statistics]' \
  '-peelorder[order voxels by distance from boundary]' \
  '-ijkorder[order voxels by 3D dataset indexing]' \
  '-range[scale data with +/-X mapping to white/black]:x:' \
  '-percent[convert time series to percent signal change]' \
  '-raw_with_bounds[map values <=A black, >=B white]:a:' \
  '*:dataset:_files' && ret=0

return ret
