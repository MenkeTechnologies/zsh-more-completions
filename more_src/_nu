#compdef nu
# _nu — Jonathan Turner + Sophia Turner + WindSoilder + nushell collective Nushell modern data-shell (nushell team, Rust); custom argparse
# upstream: https://github.com/nushell/nushell

_nu() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[run command]:cmd:' \
        '--commands=+[run command]:cmd:' \
        '-e+[expression]:expr:' \
        '--execute=+[expression]:expr:' \
        '-i[interactive mode]' \
        '--interactive[interactive mode]' \
        '-l[login shell]' \
        '--login[login shell]' \
        '-n[no config]' \
        '--no-config-file[no config]' \
        '-s[stdin]' \
        '--stdin[stdin]' \
        '-t[table mode]' \
        '--table-mode=+[mode]:m:(rounded reinforced heavy compact compact_double light thin with_love rounded basic)' \
        '--config=+[config file]:file:_files -g "*.nu"' \
        '--env-config=+[env file]:file:_files -g "*.nu"' \
        '--plugin-config=+[plugin file]:file:_files' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--log-target=+[target]:t:(stderr file)' \
        '--log-include=+[include]:str:' \
        '--log-exclude=+[exclude]:str:' \
        '--testbin=+[test binary]:str:' \
        '--threads=+[n]:n:' \
        '--ide-check=+[lsp check]:str:' \
        '--ide-complete=+[lsp complete]:str:' \
        '--ide-goto-def=+[lsp goto]:str:' \
        '--ide-hover=+[lsp hover]:str:' \
        '--ide-ast[print ast]' \
        '--no-history[no history]' \
        '--no-newline[no trailing newline]' \
        '--no-std-lib[no stdlib]' \
        '--lsp[lsp server mode]' \
        '*:file:_files -g "*.nu"'
}

_nu "$@"
