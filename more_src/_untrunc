#compdef untrunc
# Documentation: https://github.com/ponchio/untrunc/blob/master/main.cpp
# Restore a truncated/corrupt mp4/mov using a known-good reference file

local ret=1

_arguments -s -S \
  '-o[output filename when repairing]:output:_files' \
  '-i[print info about codecs and mov structure]' \
  '-a[test the ok video]' \
  '-s[simulate recovering the ok video for debugging]' \
  '-t[analyze the given track]:track:' \
  '-m[use the same offset for mdat beginning]' \
  '-M[search for probable packet starts for mdat]' \
  '-b[specify initial byte for mdat content]:byte:' \
  '-B[do not skip zeros (useful for pcm audio)]' \
  '-d[attempt to fix audio/video drifting]' \
  '-S[search for a hex string in the file]:hex:' \
  '-q[silent]' \
  '-e[error log level]' \
  '-v[verbose]' \
  '-w[debug info]' \
  '1:ok reference file:_files' \
  '2:corrupt file:_files' && ret=0

return ret
