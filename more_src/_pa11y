#compdef pa11y

# Zsh completion for pa11y - automated accessibility testing

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --standard)'{-s,--standard}'[accessibility standard to use]:standard:(WCAG2A WCAG2AA WCAG2AAA Section508)' \
  '(-r --reporter)'{-r,--reporter}'[reporter to use]:reporter:(cli csv html json)' \
  '(-l --level)'{-l,--level}'[level of issues to report]:level:(error warning notice)' \
  '(-T --threshold)'{-T,--threshold}'[number of errors to permit before failing]:count' \
  '(-i --ignore)'{-i,--ignore}'[types or codes to ignore]:rule' \
  '--include-notices[include notices in the report]' \
  '--include-warnings[include warnings in the report]' \
  '(-E --hide-elements)'{-E,--hide-elements}'[CSS selector for elements to hide]:selector' \
  '--root-element=[CSS selector for root element]:selector' \
  '(-R --runner)'{-R,--runner}'[test runner to use]:runner:(axe htmlcs)' \
  '(-t --timeout)'{-t,--timeout}'[timeout in milliseconds]:milliseconds' \
  '(-w --wait)'{-w,--wait}'[time to wait before running tests]:milliseconds' \
  '--launch-options=[options for launching Puppeteer]:JSON options' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-S --screen-capture)'{-S,--screen-capture}'[save a screenshot]:file:_files' \
  '(-A --add-rule)'{-A,--add-rule}'[WCAG rule to add]:rule' \
  '(-c --config)'{-c,--config}'[JSON configuration file]:file:_files -g "*.json"' \
  '--chromium-path=[path to Chromium executable]:file:_files' \
  '--chromium-arg=[argument to pass to Chromium]:argument' \
  '1:URL or file:_urls'
