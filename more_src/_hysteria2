#compdef hysteria2
# _hysteria2 — censorship-resistant proxy v2 (apernet/hysteria)
# upstream: https://github.com/apernet/hysteria
# Flags from app/cmd/root.go (cobra). Same binary handles client/server modes.

_hysteria2() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(yml|yaml|json)"' \
        '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(debug info warn error)' \
        '(-f --log-format)'{-f+,--log-format=}'[log format]:fmt:(console json)' \
        '--disable-update-check[disable update check]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'client:run in client mode'
                'server:run in server mode'
                'cert:generate a self-signed TLS cert'
                'ping:ping an address through hysteria'
                'speedtest:run a speed test'
                'share:produce a sharing URL/QR'
                'update:check for updates'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_hysteria2 "$@"
