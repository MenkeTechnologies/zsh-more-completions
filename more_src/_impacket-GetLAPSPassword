#compdef impacket-GetLAPSPassword
# Documentation: https://github.com/fortra/impacket/blob/master/examples/GetLAPSPassword.py
# Extract LAPS passwords from LDAP

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-computer=[target a specific computer by its name]:computer' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '(-outputfile -o)'{-outputfile,-o}'=[outputs to a file]:file:_files' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-dc-ip=[IP address of the domain controller]:ip' \
  '-dc-host=[hostname of the domain controller to use]:hostname' \
  '-ldaps[enable LDAPS (LDAP over SSL)]' \
  '1:target (domain\[/username\[:password\]\]):' && ret=0

return ret
