#compdef novoalign
# Documentation: http://www.novocraft.com/documentation/novoalign-2/novoalign-user-guide/novoalign-command-options/
# Novoalign: short-read aligner against a novoindex reference

local ret=1

_arguments -s -S \
  '-d+[indexed reference sequence pathname]:index:_files' \
  '-f+[read file(s) for single or paired-end processing]:reads:_files' \
  '-F+[read file format]:format:(FA SLXFQ STDFQ ILMFQ PRB QSEQ CSFASTA CSFASTQ)' \
  '-l+[minimum number of quality bases required]:int:' \
  '-n+[truncate reads to specified length]:int:' \
  '-s+[enable trimming for single-end reads]:step:' \
  '-a+[strip adapter sequences from 3prime end]:adapter:' \
  '-h+[homopolymer/dinucleotide filter scores]:scores:' \
  '-5+[strip 5prime primer sequences]:primer:' \
  '-\#+[limit number of reads to process]:int:' \
  '-p+[polyclonal read filter thresholds]:thresholds:' \
  '-H[hard clipping of low-quality bases]' \
  '--Q2Off[disable Q=2 quality indicator treatment]' \
  '-t+[maximum acceptable alignment score]:int:' \
  '-g+[gap opening penalty]:int:' \
  '-x+[gap extend penalty]:int:' \
  '-u+[unconverted cytosine penalty for bisulfite mode]:int:' \
  '-b+[bisulfite alignment mode]:mode:' \
  '-N+[bp of unmapped source DNA]:int:' \
  '-o+[output format]:format:(Native Pairwise SAM Extended)' \
  '-R+[score difference for repeat calling]:int:' \
  '-r+[repeat reporting strategy]:strategy:(None Random All Exhaustive)' \
  '-Q+[minimum alignment quality threshold]:int:' \
  '-e+[limit alignments per read]:int:' \
  '-q+[decimal places for quality scores]:int:' \
  '-K+[collect mismatch statistics into file]:file:_files' \
  '--3Prime[report 3prime alignment location]' \
  '-i+[fragment length and standard deviation]:params:' \
  '-v+[structural variation penalty]:int:' \
  '-m+[miRNA mode]:mode:' \
  '-k[enable quality calibration]' \
  '-c+[maximum number of threads]:int:' \
  '*:read file:_files' && ret=0

return ret
