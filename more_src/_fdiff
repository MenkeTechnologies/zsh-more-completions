#compdef fdiff
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fdiff.txt
# Display differences between pairs of FITS files

local ret=1

_arguments -s \
  "file1=[first FITS file]:file:_files" \
  "file2=[second FITS file]:file:_files" \
  "exclude=[keywords to exclude from comparison]:" \
  "cmpnum=[compare number of HDUs]:bool:(yes no)" \
  "tolerance=[numerical tolerance]:" \
  "reltol=[relative tolerance]:" \
  "cmpdata=[compare data values]:bool:(yes no)" \
  "numdiffs=[max number of differences to report]:" \
  "verbose=[verbose output]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
