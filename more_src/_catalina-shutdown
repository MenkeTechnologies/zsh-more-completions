#compdef catalina-shutdown catalina-shutdown.sh shutdown.sh
# Documentation: https://github.com/apache/tomcat/blob/main/bin/shutdown.sh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Tomcat shutdown.sh is a thin wrapper that exec's `catalina.sh stop "$@"`,
# so it forwards the same trailing args catalina stop accepts:
# an optional integer "seconds to wait" and an optional -force flag.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1::seconds to wait before forcing shutdown:' \
  '-force[forcibly kill the Tomcat process if it does not stop in time]' \
  && ret=0

return ret
