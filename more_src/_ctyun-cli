#compdef ctyun-cli
# Documentation: https://github.com/fengyucn/ctyun-cli
# CTyun (China Telecom eCloud) command line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[configuration file]:file:_files' \
  '--region=[region specification]:region:' \
  '--output=[output format]:format:(table json yaml)' \
  '--access-key=[access key for authentication]:key:' \
  '--secret-key=[secret key for authentication]:key:' \
  '*:command:(configure ecs monitor redis audit ims billing security iam ebs cda vpc cce elb kafka css emr aone)' && ret=0

return ret
