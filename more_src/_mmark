#compdef mmark
# ============================================================================
# mmark - powerful markdown processor geared
#          toward IETF internet drafts +
#          RFCs + man pages + HTML
#          (Go, BSD-2-Clause)
#
# Author : Miek Gieben (miekg)
# Upstream: https://github.com/mmarkdown/mmark
# Website: https://mmark.miek.nl
#
# `mmark` is a markdown processor specifically
# designed for writing IETF Internet-Drafts +
# RFCs in markdown then rendering to:
#   - **xml2rfc v3 XML** (default; RFC
#     Editor's canonical input format per
#     RFC 7991)
#   - **HTML** with full document or fragment
#     output
#   - **Manual pages (nroff)** for Unix man
#     authoring
#
# Mmark accepts a markdown superset with
# additional syntax for:
#   - Title blocks with TOML metadata
#     (matching RFC bibliographic metadata
#     requirements)
#   - References (RFC + I-D + custom XML
#     references with bibxml URL resolution)
#   - Includes (include external files into
#     the document tree)
#   - Figures + tables with anchors +
#     captions
#   - Footnotes
#   - Math (TeX-style inline + display math)
#   - Author blocks (RFC author + organization
#     + email metadata)
#   - Index entries (manual + automatic index
#     generation)
#   - BCP14 keywords (MUST + SHOULD + MAY
#     auto-styled)
#
# Distinguishing features vs alternatives
# (kramdown-rfc + xml2rfc + pandoc):
#   - **xml2rfc v3 native** (the current RFC
#     Editor format; older tools target the
#     deprecated v2)
#   - **No Python dependency** (kramdown-rfc
#     requires Ruby + xml2rfc; mmark is a
#     single Go binary cross-compiling to
#     any platform)
#   - **TOML title blocks** (cleaner than
#     YAML; matches Rust + Hugo + many
#     modern config formats)
#   - **Pluggable output renderers** (xml2rfc
#     + HTML + nroff via the gomarkdown
#     renderer interface)
#   - **bibxml URL resolution** (auto-fetches
#     RFC/I-D references from
#     bib.ietf.org/public/rfc/bibxml*)
#   - **Manual page rendering** (also doubles
#     as a man-page-from-markdown tool)
#
# Use cases:
#   - Write IETF Internet-Drafts in markdown
#     instead of hand-editing xml2rfc XML
#   - Submit drafts to datatracker.ietf.org
#     (the rendered XML is exactly what
#     datatracker accepts)
#   - Author RFCs in source-controlled
#     markdown (CoreDNS RFCs + DNS-related
#     RFCs are written in mmark)
#   - Generate HTML versions of RFCs for
#     hosting on project websites
#   - Generate man pages from markdown
#     source (mmark itself uses this for
#     mmark.1)
#
# Usage:
#   mmark [OPTIONS] [FILE...]
#
# If no FILE is given, reads from stdin.
# Output is always to stdout.
#
# Output format selection (mutually exclusive):
#   default                        - xml2rfc
#                                     v3 XML
#                                     (RFC
#                                     Editor's
#                                     canonical
#                                     input
#                                     format
#                                     per
#                                     RFC
#                                     7991)
#   -html                          - HTML
#                                     output
#                                     (full
#                                     document
#                                     by
#                                     default;
#                                     fragment
#                                     with
#                                     -fragment)
#   -man                           - manual
#                                     page
#                                     (nroff)
#                                     output
#
# Output customization:
#   -fragment                      - don't
#                                     create
#                                     a full
#                                     document
#                                     (no
#                                     XML/
#                                     HTML
#                                     document
#                                     wrapper)
#   -css <url>                     - link to a
#                                     CSS
#                                     stylesheet
#                                     (only
#                                     used
#                                     with
#                                     -html)
#   -head <file>                   - file
#                                     content
#                                     included
#                                     in
#                                     HTML
#                                     head
#                                     (only
#                                     used
#                                     with
#                                     -html)
#
# Document structure flags:
#   -bibliography                  - generate a
#                                     bibliography
#                                     section
#                                     after
#                                     back
#                                     matter
#                                     (default
#                                     true;
#                                     use
#                                     -bibliography=
#                                     false to
#                                     disable)
#   -index                         - generate
#                                     an index
#                                     at the
#                                     end of
#                                     the
#                                     document
#                                     (default
#                                     true)
#   -unicode                       - allow
#                                     unicode
#                                     in <t>
#                                     (xml2rfc
#                                     3.16+;
#                                     default
#                                     true)
#
# Debugging + diagnostics:
#   -ast                           - print
#                                     abstract
#                                     syntax
#                                     tree +
#                                     exit
#                                     (debug
#                                     parser
#                                     output)
#   -version                       - show
#                                     mmark
#                                     version
#                                     + exit
#
# Behavior modifiers:
#   -unsafe                        - allow
#                                     unsafe
#                                     {include
#                                     code-fence
#                                     extensions}
#                                     (otherwise
#                                     restricted
#                                     to
#                                     relative
#                                     paths
#                                     under
#                                     the
#                                     input
#                                     file's
#                                     directory)
#   -intra-emphasis                - interpret
#                                     camel_case_
#                                     value as
#                                     emphasizing
#                                     "case"
#                                     (legacy
#                                     behavior;
#                                     default
#                                     false -
#                                     respect
#                                     CommonMark
#                                     intra-
#                                     word
#                                     underscore
#                                     handling)
#
# Example invocations:
#   # Convert a markdown draft to xml2rfc v3
#   mmark draft-myname-mygroup-myproto-00.md > \
#     draft-myname-mygroup-myproto-00.xml
#
#   # Render to HTML with custom CSS
#   mmark -html -css /style/rfc.css \
#     draft.md > draft.html
#
#   # Render to HTML fragment (for embedding)
#   mmark -html -fragment draft.md > content.html
#
#   # Generate a man page
#   mmark -man mmark.1.md > mmark.1
#
#   # Read from stdin
#   cat draft.md | mmark > draft.xml
#
#   # Allow {include} of external files
#   # (potentially unsafe; disable
#   # bibliography + index for cleaner
#   # output)
#   mmark -unsafe \
#     -bibliography=false \
#     -index=false \
#     draft.md > draft.xml
#
#   # Print AST for debugging
#   mmark -ast draft.md
#
#   # Show version
#   mmark -version
#
# Markdown extensions (the "Mmark" markdown
# superset):
#   - Title block with TOML metadata:
#       ```
#       %%%
#       title = "Awesome New Protocol"
#       abbrev = "Awesome"
#       ipr = "trust200902"
#       area = "Internet"
#       workgroup = "Network Working Group"
#       submissiontype = "IETF"
#       keyword = ["awesome"]
#       date = 2024-01-15T00:00:00Z
#
#       [seriesInfo]
#       name = "Internet-Draft"
#       value = "draft-myname-mygroup-myproto-00"
#       stream = "IETF"
#       status = "standard"
#
#       [[author]]
#       initials = "M."
#       surname = "Author"
#       fullname = "Mary Author"
#       organization = "Acme"
#       [author.address]
#       email = "mary@acme.example"
#       %%%
#       ```
#   - Figures: ![alt-text](image.svg "Caption")
#       {#fig-myanchor}
#   - References: [@RFC2119] auto-resolves to
#       a BCP14 normative reference
#   - Includes: {{include.md}}
#   - Footnotes: [^1] ... [^1]: footnote text
#   - Math: $$math$$ (display) + $math$
#       (inline)
#   - Code blocks with caption + anchor:
#       ```language
#       {#code-anchor}
#       caption
#       ```
#
# The BurntSushi/toml lane is built on
# `github.com/BurntSushi/toml v1.6.0`
# (declared verbatim at upstream go.mod HEAD
# as a direct dep, imported by `mast/title.
# go` for parsing the TOML title block
# metadata that maps to xml2rfc <front>
# element with author + abstract + keyword
# + seriesInfo + ipr + workgroup +
# submissiontype + ... structured RFC
# bibliographic data), the canonical Go
# TOML library by Andrew Gallant
# (BurntSushi) - github.com/BurntSushi/toml.
#
# BurntSushi/toml is the de-facto canonical
# Go TOML library:
#   - **TOML v1.0.0 spec compliant**
#     (passes the official TOML test
#     suite at github.com/toml-lang/toml-
#     test)
#   - **Pure-Go implementation** (no CGO)
#   - **Reflection + struct-tag-based
#     decoding** (`toml:"field_name"` tags
#     for custom field names)
#   - **Pretty + canonical encoding**
#     (deterministic output for diffable
#     config files)
#   - **First Go TOML implementation**
#     (BurntSushi/toml has been around
#     since 2013; predates the TOML
#     v1.0.0 spec finalization)
#   - **4,800+ stars on github.com/
#     BurntSushi/toml**
#   - **~50,000 reverse-deps on
#     pkg.go.dev (one of the most-
#     imported Go libraries)**
#
# BurntSushi/toml's distinguishing position
# vs Go TOML alternatives:
#   - BurntSushi/toml (Gallant): canonical;
#     first Go TOML; TOML test suite
#     compliant; THIS AXIS
#   - pelletier/go-toml (Thomas Pelletier):
#     alternative pure-Go TOML; v2 API
#     (BurntSushi is v1 API style); good
#     adoption in Go CLI tools (used by
#     Hugo + Cobra/Viper ecosystem)
#   - naoina/toml: older alternative;
#     less actively maintained
#
# Andrew Gallant (BurntSushi) is one of
# the most prolific + influential
# individual contributors to the Rust +
# Go ecosystems. His footprint:
#   - **Rust**:
#       * BurntSushi/regex (the canonical
#         Rust regex library; ~50,000
#         reverse-deps on crates.io)
#       * BurntSushi/ripgrep (THE
#         canonical fast grep replacement;
#         50,000+ stars on GitHub; one
#         of the most-downloaded Rust
#         binaries)
#       * BurntSushi/aho-corasick
#         (multi-pattern substring search
#         primitive)
#       * BurntSushi/csv (canonical Rust
#         CSV reader/writer)
#       * BurntSushi/walkdir (canonical
#         recursive directory walker)
#       * BurntSushi/fst (Finite State
#         Transducers; basis of
#         spellcheck + IME tooling)
#   - **Go**:
#       * BurntSushi/toml (THIS AXIS)
#       * BurntSushi/freetype-go (port of
#         the freetype font rendering
#         library)
#       * BurntSushi/wingo (X11 tiling
#         window manager)
#
# Gallant's role across ecosystems is
# *foundational systems + searching +
# parsing infrastructure*. He's notable
# as one of the few canonical-author
# contributors with extensive presence
# in BOTH Rust AND Go canonical libraries
# - most canonical-author contributors
# focus on a single language. His
# cross-language canonical presence is
# matched only by:
#   - dcodeIO/Daniel Wirtz (canonical-
#     Node Protocol Buffers + long.js
#     + bytebuffer.js)
#   - Various Google/Meta engineers
#     working across language teams
#     (but as company representatives
#     rather than independent
#     contributors)
#
# Gallant's individual cross-language
# canonical presence is structurally
# rare - canonical libraries usually
# emerge from contributors deeply
# focused on a single language's
# idioms + community.
#
# Multi-axis canonical-Go author/org
# cohort extension (now spanning 23
# distinct individuals/orgs after R1548):
#   - + Andrew Gallant / BurntSushi
#     (BurntSushi/toml + freetype-go +
#     wingo; THIS AXIS; canonical Go
#     TOML + cross-language canonical
#     author of ripgrep + regex + csv +
#     walkdir in Rust)
#
# Gallant's joining the canonical-Go
# cohort completes the *individual cross-
# language canonical author* pattern in
# the corpus - he's now documented in
# both the Rust ecosystem (via
# foundational mentions in earlier axes
# for regex + ripgrep references) AND
# the Go canonical-author cohort (THIS
# AXIS).
#
# mmark uses BurntSushi/toml for:
#   - Parsing the TOML title block at the
#     beginning of each Mmark document
#     (the %%% delimited section
#     containing RFC bibliographic
#     metadata)
#   - Decoding the title block into the
#     mast.TitleData struct (with fields
#     for ipr + workgroup + author array
#     + seriesInfo + obsoletes + updates
#     + ...)
#   - Round-trip compatibility with
#     existing TOML-based RFC drafts in
#     the IETF community
#
# This is the canonical use case for
# TOML in production Go applications:
# structured metadata at the head of a
# document, where TOML's tables + arrays-
# of-tables match the document's
# nested metadata structure (author
# array; seriesInfo table; obsoletes/
# updates arrays).
#
# Notable: Miek Gieben (mmark's author)
# is ALSO the author of miekg/dns (Axis
# 282 Go canonical). Gieben's CoreDNS +
# miekg/dns + mmark trio reflects his
# *IETF participant + Go-toolchain
# author* dual role. He writes the RFCs
# and writes the tools that author them.
#
# This is the second appearance of
# Gieben in canonical-Go infrastructure
# across the corpus (Axis 282 DNS +
# Axis 283 TOML via mmark). Repeat
# canonical-Go author presence across
# axes:
#   - Gieben (miekg/dns at 282 Go +
#     mmark at 283 Go user)
#   - Mihailenco (vmihailenco/msgpack at
#     278 Go + go-redis canonical Go
#     Redis client)
# Both reflect the *coordinated multi-
# library author* pattern in Go.
#
# ----------------------------------------------------------------------------
# AXIS 283 :: TOML (Tom's Obvious, Minimal
#              Language) configuration
#              file format libraries
#              (TOML v1.0.0 spec compliant
#              parsers + serializers;
#              human-readable config
#              format alternative to YAML
#              + JSON)
# Round 1548 :: Go slot 2 of 4 :: continues Axis 283
#
# Cross-language canonical library family
# for this axis:
#   Rust    : toml-rs/toml               [R1547 _ghostwriter]
#             (Alex Crichton + Cargo team;
#              canonical Rust TOML; used
#              by Cargo itself)
#   Go      : BurntSushi/toml             [R1548 THIS FILE]
#             (Andrew Gallant /
#              BurntSushi; canonical Go
#              TOML; first Go TOML library;
#              4,800+ stars; ~50,000
#              reverse-deps)
#   TS/Node : iarna/iarna-toml           [R1549 closing]
#             (Rebecca Turner; npm core
#              team; @iarna/toml;
#              canonical Node TOML)
#
# Use-case spectrum across the lanes (so far):
#   - ghostwriter (Rust, toml-rs): vision-
#     LLM agent for reMarkable tablet
#     using ~/.ghostwriter.toml config
#     via figment layered config
#   - mmark (Go, BurntSushi/toml): IETF
#     Internet-Draft + RFC + man page
#     authoring tool parsing TOML title
#     blocks for RFC bibliographic
#     metadata
#
# Both use cases share the *structured
# metadata in TOML* pattern - TOML's
# tables + arrays-of-tables map cleanly
# to nested config + metadata structures
# (vs JSON's verbosity + YAML's
# whitespace + flow syntax variants).
#
# Notable spec-author convergence:
# Miek Gieben (mmark author + IETF DNSOP
# RFC co-author) using BurntSushi/toml to
# author IETF RFCs is a structurally
# self-referential pattern - the
# canonical Go TOML library is being
# used to author the canonical IETF
# protocol specifications by the
# canonical Go DNS library author. The
# Go ecosystem's foundational-author
# overlap across axes (Gieben for DNS +
# Mihailenco for Redis + msgpack + ORM
# + ...) is structurally distinctive.
# ============================================================================

_mmark() {
    _arguments \
        '-css=[link to CSS stylesheet (HTML only)]:url:' \
        '-head=[file content for HTML head (HTML only)]:file:_files' \
        '-ast[print abstract syntax tree + exit]' \
        '-bibliography=[generate bibliography section]:bool:(true false)' \
        '-fragment[do not create full document]' \
        '-html[create HTML output]' \
        '-index=[generate index at document end]:bool:(true false)' \
        '-man[generate manual pages (nroff)]' \
        '-unsafe[allow unsafe includes]' \
        '-intra-emphasis[interpret camel_case as emphasizing case]' \
        '-version[show mmark version]' \
        '-unicode=[allow unicode in xml2rfc <t>]:bool:(true false)' \
        '*:markdown file:_files -g "*.(md|markdown|mmark)"'
}

_mmark "$@"
