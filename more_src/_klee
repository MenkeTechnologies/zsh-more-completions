#compdef klee
# Documentation: https://man.archlinux.org/search?q=klee
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--help-list[show option list]' \
  '--version[show version]' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--use-forked-solver[use forked solver]' \
  '--use-cex-cache[use counterexample cache]' \
  '--use-query-loggers=[query loggers csv]:list:(all kqueryAll smt2All)' \
  '--simplify-sym-indices[simplify symbolic indices]' \
  '--max-memory=[max memory MB]:mb:' \
  '--max-memory-inhibit[disable allocations on memory limit]' \
  '--max-time=[max execution time]:dur:' \
  '--max-instruction-time=[max time per instruction]:dur:' \
  '--max-instructions=[max instructions to execute]:n:' \
  '--max-static-fork-pct=[fork percentage limit]:pct:' \
  '--max-static-solve-pct=[solve percentage limit]:pct:' \
  '--max-fork-tries=[max fork attempts]:n:' \
  '--max-static-cpfork-pct=[cpfork pct]:pct:' \
  '--max-loop-time=[max loop time]:dur:' \
  '--max-sym-array-size=[max symbolic array size]:n:' \
  '--watchdog[run with watchdog]' \
  '--write-cov[write coverage info]' \
  '--write-cvcs[write CVC queries]' \
  '--write-kqueries[write KQuery files]' \
  '--write-paths[write path info]' \
  '--write-pcs[write program counter trace]' \
  '--write-smt2s[write SMT-LIB queries]' \
  '--write-states[write state info]' \
  '--write-sym-paths[write symbolic path info]' \
  '--write-test-info[write test info]' \
  '--write-traces[write traces]' \
  '--write-no-tests[do not write test files]' \
  '--solver-backend=[SMT solver]:s:(stp z3 metasmt dummy)' \
  '--use-merge[merging branches at exit]' \
  '--symbolic-extra-args[symbolic extra args]' \
  '--posix-runtime[use POSIX runtime]' \
  '--libc=[libc model]:m:(none klee uclibc)' \
  '--libcxx[link libcxx]' \
  '--external-calls=[external calls]:m:(none concrete all)' \
  '--allocate-determ[deterministic allocation]' \
  '--allocate-determ-size=[determ alloc size MB]:mb:' \
  '--allocate-determ-start-address=[start address hex]:hex:' \
  '--use-merge-merge[allow merging on exit]' \
  '--readable-posix-inputs[POSIX inputs readable]' \
  '--silent-klee-assume[silent assume]' \
  '--write-test-info[write test info]' \
  '--debug-print-instructions=[print instr]:m:(none src compact compact:src all)' \
  '--debug-validate-solver[validate solver answers]' \
  '--debug-z3-dump-queries=[dump z3 queries]:file:_files' \
  '--debug-stp-dump-queries=[dump stp queries]:file:_files' \
  '--exit-on-error[exit on first error]' \
  '--only-output-states-covering-new[only states with new coverage]' \
  '--optimize[optimize bitcode before exec]' \
  '--use-batching-search[batch state]' \
  '--use-call-paths[detect repeated calls]' \
  '--search=[exploration strategy]:s:(dfs bfs random-state random-path nurs:covnew nurs:md2u nurs:depth nurs:icnt nurs:cpicnt nurs:qc)' \
  '--seed-out=[seed file out]:file:_files' \
  '--seed-out-dir=[seed dir]:dir:_files -/' \
  '--seed-only[only execute seeded paths]' \
  '--always-output-seeds[always output seeds]' \
  '--zero-seed-extension[zero-extend seeds]' \
  '--switch-type=[switch type]:t:(internal simple llvm)' \
  '--use-iv-prinst-ass=[iv print]:bool:(true false)' \
  '*: :_files -g "*.bc"' && ret=0

return ret
