#compdef katenary
# Documentation: https://github.com/katenary/katenary
# Convert docker-compose files into a Helm chart

local ret=1
local -a subcmds

subcmds=(
  'convert:converts a docker-compose file to a Helm Chart'
  'schema:print the schema of the katenary file'
  'help-labels:print the labels help for all or a specific label'
  'hash-composefiles:print the hash of the composefiles'
  'completion:generate completion scripts'
  'version:print the version number of Katenary'
  'help:help about any command'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[help for katenary]' \
  '(-v --version)'{-v,--version}'[version for katenary]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'katenary command' subcmds && ret=0
    ;;
esac

return ret
