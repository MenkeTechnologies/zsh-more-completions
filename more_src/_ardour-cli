#compdef ardour-cli
# _ardour-cli — Paul Davis Ardour professional DAW CLI alias (Ardour team, C++); custom argparse
# upstream: https://github.com/Ardour/ardour

_ardour-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--bypass-plugins[disable plugin processing]' \
        '-b[disable plugin processing]' \
        '--disable-plugins[disable plugins]' \
        '-D[disable plugins]' \
        '--keybindings=+[file]:file:_files' \
        '-k+[file]:file:_files' \
        '--menus=+[file]:file:_files' \
        '-m+[file]:file:_files' \
        '--no-splash[no splash]' \
        '-n[no splash]' \
        '--save-suffix=+[suffix]:str:' \
        '-S+[suffix]:str:' \
        '--curvetest=+[file]:file:_files' \
        '-c+[file]:file:_files' \
        '--lua-script=+[file]:file:_files -g "*.lua"' \
        '-T+[file]:file:_files -g "*.lua"' \
        '--new=+[session name]:str:' \
        '-N+[session name]:str:' \
        '--template=+[template]:str:' \
        '-t+[template]:str:' \
        '--osc-port=+[port]:port:' \
        '-O+[port]:port:' \
        '--server=+[server name]:str:' \
        '-J[just show version info]' \
        '--logo=+[file]:file:_files' \
        '--no-connect-ports[no connect ports]' \
        '-d[debug logging]' \
        '--debug-log=+[file]:file:_files' \
        '*:session file:_files -g "*.{ardour,ardour-template}"'
}

_ardour-cli "$@"
