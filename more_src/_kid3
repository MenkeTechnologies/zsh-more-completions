#compdef kid3 kid3-qt kid3-cli
# _kid3 — Kid3 audio tag editor (Qt); KDE-native ID3/Vorbis/APE/FLAC/MP4 tag editor with CLI batch mode
# upstream: https://kid3.kde.org

_kid3() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --command)'{-c,--command}'+[batch command]:cmd:' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '*:music dir or file:_files'
}

_kid3 "$@"
