#compdef objconv

# objconv: object file converter (Agner Fog)
# Documentation: https://www.agner.org/optimize/objconv-instructions.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-fcof[output COFF]' \
  '-felf[output ELF]' \
  '-fmacho[output Mach-O]' \
  '-fomf[output OMF]' \
  '-fasm[disassemble to MASM]' \
  '-fnasm[disassemble to NASM]' \
  '-fyasm[disassemble to YASM]' \
  '-fgas[disassemble to GAS]' \
  '-d[dump only]' \
  '-l[list contents]' \
  '-v[verbose]' \
  '-wd[warning disable]:n:' \
  '-we[warning as error]:n:' \
  '-na[NASM syntax]' \
  '-y[no underscore prefix]' \
  '-u[add underscore]' \
  '*:input output:_files' && ret=0
return ret
