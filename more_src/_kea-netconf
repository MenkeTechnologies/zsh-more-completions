#compdef kea-netconf
# Documentation: https://man.archlinux.org/search?q=kea-netconf
# Reference accessed: 2026-05-16

# kea-netconf: Kea NETCONF agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[print version]' \
  '-V[print extended version]' \
  '-W[print extended version with file list]' \
  '-d[debug mode (foreground)]' \
  '-c[config file]:file:_files -g "*.(conf|json)"' \
  '-t[test config file, do not start]:file:_files -g "*.(conf|json)"' \
  '-X[debug exit]' \
  '*::kea-netconf args:_files' && ret=0
return ret
