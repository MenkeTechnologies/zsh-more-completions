#compdef arpoison
# Documentation: https://b4lt0.github.io/arpoison/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[interface]:iface:_net_interfaces' \
  '-d+[destination IP]:ip:' \
  '-s+[source IP]:ip:' \
  '-t+[target MAC]:mac:' \
  '-r+[source MAC]:mac:' \
  '-a[ARP reply (default)]' \
  '-w+[delay seconds between packets]:sec:' \
  '-n+[number of packets]:n:' \
  '-v[verbose]' && ret=0

return ret
