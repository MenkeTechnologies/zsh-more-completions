#compdef create-tailwind-type
# Documentation: https://www.npmjs.com/package/create-tailwind-type
# Reference accessed: 2026-05-24
# Verified: npm view create-tailwind-type bin; npm readme CLI Options table.

# Zsh completion for create-tailwind-type - Tailwind CSS TypeScript type generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-b --base)'{-b,--base=}'[base directory for @tailwindcss/node package]:directory:_directories' \
  '(-f --filename)'{-f,--filename=}'[output filename for generated types]:file:_files' \
  '(-d --docs)'{-d,--docs}'[enable documentation comments in generated types]' \
  '(-D --no-docs)'{-D,--no-docs}'[disable documentation comments]' \
  '(-a --arbitrary-value)'{-a,--arbitrary-value}'[allow arbitrary value types]' \
  '(-A --no-arbitrary-value)'{-A,--no-arbitrary-value}'[disable arbitrary value types]' \
  '(-s --soft-variants)'{-s,--soft-variants}'[enable soft variant generation]' \
  '(-S --no-soft-variants)'{-S,--no-soft-variants}'[disable soft variant generation]' \
  '(-k --string-kind-variants-only)'{-k,--string-kind-variants-only}'[limit types to string-kind variants]' \
  '(-o --optional-property)'{-o,--optional-property}'[generate optional properties in types]' \
  '(-N --disable-variants)'{-N,--disable-variants}'[disable variant generation]' \
  '(-v --arbitrary-variant)'{-v,--arbitrary-variant}'[enable arbitrary variant keys]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' && ret=0

return ret
