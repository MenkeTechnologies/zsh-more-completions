#compdef nucmer
# Documentation: https://manpages.debian.org/testing/mummer/nucmer.1.en.html
# MUMmer nucleotide alignment of two multi-FASTA sequences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '--mum[use anchor matches unique in both reference and query]' \
  '--mumreference[use anchor matches unique in reference only]' \
  '--mumcand[same as --mumreference]' \
  '--maxmatch[use all anchor matches regardless of uniqueness]' \
  '(-b --breaklen)'{-b,--breaklen}'+[alignment extension distance before giving up]:dist' \
  '(-c --mincluster)'{-c,--mincluster}'+[minimum cluster length]:len' \
  '(-d --diagfactor)'{-d,--diagfactor}'+[clustering diagonal difference factor]:factor' \
  '(-g --maxgap)'{-g,--maxgap}'+[maximum gap between adjacent matches]:gap' \
  '(-l --minmatch)'{-l,--minmatch}'+[minimum single match length]:len' \
  '(-f --forward)'{-f,--forward}'[forward strand only]' \
  '(-r --reverse)'{-r,--reverse}'[reverse complement only]' \
  '--delta[create delta file]' \
  '--nodelta[do not create delta file]' \
  '--extend[enable cluster extension step]' \
  '--noextend[disable cluster extension step]' \
  '--optimize[enable alignment score optimization]' \
  '--nooptimize[disable alignment score optimization]' \
  '--simplify[remove shadowed clusters]' \
  '--nosimplify[do not simplify alignments]' \
  '(-p --prefix)'{-p,--prefix}'+[output file prefix]:prefix' \
  '(-o --coords)'{-o,--coords}'[generate NUCmer 1.1 coords output]' \
  '--depend[print dependency information]' \
  ':reference:_files' \
  ':query:_files' && ret=0

return ret
