#compdef cargo-list
# Documentation: https://crates.io/crates/cargo-list
# list and update installed crates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-f[output format]:format:(json json-pretty md rust rust-pretty)' \
  '-k[kind(s) of crate to list]:kind:(local git external)' \
  '-a[all kinds]' \
  '(-o --outdated)'{-o,--outdated}'[hide up-to-date crates]' \
  '-I[ignore version requirements]' \
  '-R[outdated if compiled with a different Rust version]' \
  '(-u --update)'{-u,--update}'[update outdated crates]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
  '-c[cargo install metadata file]:file:_files' \
  '(-r --readme)'{-r,--readme}'[print readme]' \
  '*:pattern:' && ret=0

return ret
