#compdef appimage-builder
# Documentation: https://appimage-builder.readthedocs.io/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--recipe[recipe file path]:file:_files -g "*.yml"' \
  '--skip-build[skip build step]' \
  '--skip-appimage[skip AppImage generation]' \
  '--skip-tests[skip test step]' \
  '--generate[generate recipe from existing AppDir]' \
  '--log-level[set log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' && ret=0

return ret
