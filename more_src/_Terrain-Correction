#compdef Terrain-Correction
# Documentation: https://github.com/senbox-org/s1tbx/blob/master/s1tbx-op-sar-processing/src/main/java/org/esa/s1tbx/sar/gpf/geometric/RangeDopplerGeocodingOp.java
# ESA SNAP gpt Terrain-Correction operator - Range-Doppler terrain correction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PsourceBandNames=-[the list of source bands]:bands' \
  '-PdemName=-[the digital elevation model]:dem' \
  '-PexternalDEMFile=-[external DEM]:file:_files' \
  '-PexternalDEMNoDataValue=-[external DEM no data value]:value' \
  '-PexternalDEMApplyEGM=-[external DEM apply EGM]:bool:(true false)' \
  '-PdemResamplingMethod=-[DEM resampling method]:method' \
  '-PimgResamplingMethod=-[image resampling method]:method' \
  '-PpixelSpacingInMeter=-[pixel spacing in meters]:meters' \
  '-PpixelSpacingInDegree=-[pixel spacing in degrees]:degrees' \
  '-PmapProjection=-[target CRS in WKT or authority code]:crs' \
  '-PalignToStandardGrid=-[force the image grid alignment]:bool:(true false)' \
  '-PstandardGridOriginX=-[x-coordinate of standard grid origin]:x' \
  '-PstandardGridOriginY=-[y-coordinate of standard grid origin]:y' \
  '-PnodataValueAtSea=-[mask out areas with no elevation]:bool:(true false)' \
  '-PsaveDEM=-[save DEM as band]:bool:(true false)' \
  '-PsaveLatLon=-[save latitude and longitude as bands]:bool:(true false)' \
  '-PsaveIncidenceAngleFromEllipsoid=-[save incidence angle from ellipsoid]:bool:(true false)' \
  '-PsaveLocalIncidenceAngle=-[save local incidence angle]:bool:(true false)' \
  '-PsaveProjectedLocalIncidenceAngle=-[save projected local incidence angle]:bool:(true false)' \
  '-PsaveSelectedSourceBand=-[save selected source band]:bool:(true false)' \
  '-PsaveLayoverShadowMask=-[save layover shadow mask]:bool:(true false)' \
  '-PoutputComplex=-[output complex data]:bool:(true false)' \
  '-PapplyRadiometricNormalization=-[apply radiometric normalization]:bool:(true false)' \
  '-PsaveSigmaNought=-[save Sigma0 as a band]:bool:(true false)' \
  '-PsaveGammaNought=-[save Gamma0 as a band]:bool:(true false)' \
  '-PsaveBetaNought=-[save Beta0 as a band]:bool:(true false)' \
  '-PincidenceAngleForSigma0=-[incidence angle source for Sigma0]:angle' \
  '-PincidenceAngleForGamma0=-[incidence angle source for Gamma0]:angle' \
  '-PauxFile=-[the auxiliary file]:aux' \
  '-PexternalAuxFile=-[antenna elevation pattern gain auxiliary data file]:file:_files' \
  '*:source product:_files' && ret=0

return ret
