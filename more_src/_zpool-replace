#compdef zpool-replace
# _zpool-replace — OpenZFS zpool replace (atomically replace a failed/aging vdev with a new device while keeping pool online; -f force activation even if device is in use, -s allow replacement of a spare, -o sets ashift/cachefile, -w wait until resilver done; positional pool, old_device, optional new_device)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_replace) on tip.

_zpool-replace() {
    _arguments \
        '-f[force]' \
        '-s[allow spare replacement]' \
        '-w[wait until resilver done]' \
        '*-o+[property=value]:property=value:(ashift= cachefile=)' \
        '1:pool:' \
        '2:old device:' \
        '3:new device:'
}

_zpool-replace "$@"
