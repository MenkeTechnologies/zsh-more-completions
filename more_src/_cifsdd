#compdef cifsdd
# Documentation: https://manpages.debian.org/cifsdd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cifsdd: dd-like tool for SMB/CIFS shares (Samba)
local curcontext="$curcontext" ret=1
_arguments -C \
  'bs=[read/write up to BYTES bytes at a time]:bytes:' \
  'ibs=[read up to BYTES bytes at a time]:bytes:' \
  'obs=[write BYTES bytes at a time]:bytes:' \
  'if=[input file or share]:src:' \
  'of=[output file or share]:dst:' \
  'count=[copy only N input blocks]:n:' \
  'seek=[skip N obs-sized blocks at start of output]:n:' \
  'skip=[skip N ibs-sized blocks at start of input]:n:' \
  'direct[use direct I/O for data]' \
  'sync[use synchronous writes]' \
  'oplock[take oplocks on the input and output files]' \
  '*::cifsdd args:_files' && ret=0
return ret
