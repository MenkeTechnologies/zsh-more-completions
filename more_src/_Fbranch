#compdef Fbranch
# Documentation: https://github.com/millanek/Dsuite
# Dsuite Fbranch: heuristic interpretation of correlated f4-ratio results.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --pthresh)'{-p+,--pthresh=}'[p-value threshold (default 0.01)]:p:' \
  '(-Z --Zb-matrix)'{-Z,--Zb-matrix}'[output Z-score equivalents]' \
  '*:file:_files' && ret=0

return ret
