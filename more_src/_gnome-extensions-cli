#compdef gnome-extensions-cli gext
# Documentation: https://github.com/essembeh/gnome-extensions-cli
# Reference accessed: 2026-05-16
# Verified: README + argparse subcommands.

# gnome-extensions-cli (gext): GNOME Shell extension manager
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'list:list installed extensions'
  'search:search extensions in store'
  'install:install extensions'
  'update:update extensions'
  'uninstall:uninstall extensions'
  'show:show extension details'
  'enable:enable extensions'
  'disable:disable extensions'
  'preferences:open extension preferences'
)
_arguments -C \
  '(- *)--help[show help]' \
  '--no-color[disable terminal colors]' \
  '--dbus[use DBus communication with GNOME Shell]' \
  '--filesystem[use filesystem-based installation]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'gext command' commands && ret=0 ;;
esac
return ret
