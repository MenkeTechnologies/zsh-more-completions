#compdef prime95 mprime
# Documentation: https://github.com/rudimeier/mprime/blob/master/prime95/hlp/CommandLine.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# prime95/mprime: Great Internet Mersenne Prime Search torture/test tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[contact the PrimeNet server, then exit]' \
  '-d[print detailed information to stdout]' \
  '-m[menu to configure mprime]' \
  '-s[display status]' \
  '-t[run the torture test]' \
  '-v[print the version number]' \
  '-A+[alternate set of INI/output files (obsolete)]:n:' \
  '-W+[working directory]:dir:_files -/' \
  '*::prime95 args:_files' && ret=0
return ret
