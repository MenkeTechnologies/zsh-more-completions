#compdef prime95

# Prime95: Mersenne prime search and stress test
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-c[show CPU info]' \
  '-d[run as daemon]' \
  '-m[run in menu mode]' \
  '-t[run torture test]' \
  '-T[stop torture test]' \
  '-A[auto-recover from saves]' \
  '-W[working directory]:dir:_files -/' \
  '*::prime95 args:_files' && ret=0
return ret
