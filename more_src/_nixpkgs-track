#compdef nixpkgs-track
# Documentation: https://github.com/uncenter/nixpkgs-track
# track where Nixpkgs pull requests have reached across release branches

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--token=[GitHub API token to avoid rate limiting]:token:' \
  '1:command:((
    add\:"add pull request(s) to the tracked list"
    remove\:"remove pull request(s) from the tracked list"
    list\:"list tracked pull requests and their metadata"
    check\:"check each tracked pull request"
  ))' \
  '*::arg:_default' && ret=0

return ret
