#compdef PlotDenoisedCopyRatios
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/plotting/PlotDenoisedCopyRatios.java
# GATK4: plot standardized and denoised copy ratios

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--standardized-copy-ratios=[input standardized copy ratios from DenoiseReadCounts]:file:_files' \
  '--denoised-copy-ratios=[input denoised copy ratios from DenoiseReadCounts]:file:_files' \
  '(-SD --sequence-dictionary)'{-SD,--sequence-dictionary}'=[sequence dictionary determining contig order in plots]:file:_files -g "*.dict"' \
  '--minimum-contig-length=[minimum contig length for inclusion in plots]:len:' \
  '--maximum-copy-ratio=[maximum copy ratio value to display on plots]:val:' \
  '--point-size-copy-ratio=[size of data points in copy ratio plots]:size:' \
  '--output-prefix=[prefix for output filenames]:prefix:' \
  '(-O --output)'{-O,--output}'=[output directory, created if it does not exist]:dir:_files -/' \
  '*:options:_files' && ret=0

return ret
