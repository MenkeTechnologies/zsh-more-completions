#compdef certsync
# Documentation: https://github.com/zblurx/certsync
# Dump NTDS via DC certificate forging without DRSUAPI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ca-pfx+[path to CA certificate (PFX/P12 file)]:file:_files' \
  '-ca-ip+[IP address of the certificate authority]:ip:' \
  '(-d -domain)'{-d,-domain}'+[domain name]:domain:' \
  '(-u -username)'{-u,-username}'+[username]:user:' \
  '(-p -password)'{-p,-password}'+[password]:password:' \
  '-hashes+[NTLM hashes LMHASH:NTHASH]:hashes:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos authentication]' \
  '-aesKey+[AES key for Kerberos]:hex key:' \
  '-kdcHost+[FQDN of domain controller]:host:' \
  '-scheme+[LDAP scheme]:scheme:(ldap ldaps)' \
  '-ns+[nameserver for DNS resolution]:ip:' \
  '-dns-tcp[use TCP instead of UDP for DNS]' \
  '-dc-ip+[IP address of domain controller]:ip:' \
  '-ldap-filter+[custom LDAP filter for user selection]:filter:' \
  '-template+[base template certificate for forging]:template:' \
  '-timeout+[timeout between PKINIT connections]:seconds:' \
  '-jitter+[jitter between PKINIT connections]:jitter:' \
  '-randomize[randomize certificate generation]' \
  '-outputfile+[base output filename]:file:_files' && ret=0

return ret
