#compdef repomix

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files' \
  '--style=[output style]:style:(plain xml markdown)' \
  '--include=[include patterns]:patterns' \
  '--ignore=[ignore patterns]:patterns' \
  '--config=[config file path]:file:_files' \
  '--copy[copy output to clipboard]' \
  '--no-file-summary[skip file summary section]' \
  '--no-directory-structure[skip directory structure section]' \
  '--remove-comments[remove code comments]' \
  '--remove-empty-lines[remove empty lines]' \
  '--header-text=[custom header text]:text' \
  '--instruction=[custom instruction text]:text' \
  '--top-files-len=[number of top files to show]:count' \
  '--output-show-line-numbers[show line numbers in output]' \
  '--token-count[show token count]' \
  '--remote=[process remote repository]:url' \
  '--init[create config file]' \
  '*:directory:_directories'
