#compdef repomix
# Documentation: https://github.com/yamadashy/repomix/blob/main/README.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files' \
  '--style=[output style]:style:(xml markdown json plain)' \
  '--stdout[write output to stdout]' \
  '--stdin[read file paths from stdin]' \
  '--include=[include patterns (comma-separated globs)]:patterns' \
  '(-i --ignore)'{-i,--ignore}'=[additional ignore patterns]:patterns' \
  '--no-gitignore[disable .gitignore handling]' \
  '--no-default-patterns[disable built-in ignore patterns]' \
  '(-c --config)'{-c,--config}'=[path to repomix.config.json]:file:_files' \
  '--global[with --init, write config to home directory]' \
  '--init[create a repomix.config.json with defaults]' \
  '--copy[copy output to clipboard]' \
  '--quiet[suppress console output except errors]' \
  '--verbose[enable detailed debug logging]' \
  '--no-file-summary[skip file summary section]' \
  '--no-directory-structure[skip directory structure section]' \
  '--no-files[exclude file contents from output]' \
  '--remove-comments[remove code comments]' \
  '--remove-empty-lines[remove empty lines]' \
  '--truncate-base64[truncate long base64 strings]' \
  '--header-text=[custom header text]:text' \
  '--instruction-file-path=[path to a file with custom instructions]:file:_files' \
  '--top-files-len=[number of top files to show]:count' \
  '--output-show-line-numbers[show line numbers in output]' \
  '--compress[extract essential code structure via Tree-sitter]' \
  '--token-count-tree=[show file tree with token counts (optional threshold)]:threshold' \
  '--token-count-encoding=[tokenizer encoding]:encoding:(o200k_base cl100k_base p50k_base r50k_base)' \
  '--remote=[clone and pack remote repository]:url' \
  '--remote-branch=[branch, tag, or commit for --remote]:ref' \
  '--remote-trust-config[load config files from remote repositories]' \
  '--split-output=[split output into multiple files (e.g. 500kb, 2mb)]:size' \
  '--no-security-check[disable sensitive-data scanning]' \
  '--parsable-style[escape special characters for valid output]' \
  '--include-diffs[include git diffs]' \
  '--include-logs[include git commit history]' \
  '--include-logs-count=[number of commits to include]:count' \
  '--include-empty-directories[include empty directories]' \
  '--include-full-directory-structure[include the full directory tree]' \
  '--no-git-sort-by-changes[do not sort files by git change frequency]' \
  '--mcp[run as Model Context Protocol server]' \
  '(-f --force)'{-f,--force}'[skip confirmation prompts]' \
  '*:directory:_directories'
