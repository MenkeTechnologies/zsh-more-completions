#compdef dpkg-deb

_arguments -s \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --build)'{-b,--build}'[build a deb package]' \
  '(-c --contents)'{-c,--contents}'[list contents]' \
  '(-I --info)'{-I,--info}'[show info]' \
  '(-W --show)'{-W,--show}'[show package metadata]' \
  '(-f --field)'{-f,--field}'[show specific control fields]' \
  '--ctrl-tarfile[output control tar file]' \
  '--fsys-tarfile[output filesystem tar file]' \
  '(-e --control)'{-e,--control}'[extract control directory]' \
  '(-x --extract)'{-x,--extract}'[extract files]' \
  '(-X --vextract)'{-X,--vextract}'[verbosely extract files]' \
  '(-R --raw-extract)'{-R,--raw-extract}'[raw extract files and control]' \
  '(-D --debug)'{-D,--debug}'[debug output]' \
  '--showformat=[format string]:format:' \
  '(-z --compress-level)'{-z,--compress-level=}'[compression level]:n:' \
  '(-Z --compress-type)'{-Z,--compress-type=}'[compression]:type:(gzip xz zstd none)' \
  '-S=[compress strategy]:strategy:(extreme filtered huffman rle fixed)' \
  '--threads-max=[max compression threads]:n:' \
  '--root-owner-group[force ownership root:root]' \
  '--uniform-compression[uniform compression]' \
  '--nocheck[skip control file checks]' \
  '*:archive:_files -g "*.deb"'
