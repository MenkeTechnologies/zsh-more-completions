#compdef userinfo
# _userinfo — OpenBSD userinfo (low-level binary behind user info; prints passwd-style summary or with -e returns only exit status indicating account existence)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Flags from usr.sbin/user/userinfo.8 on tip.

_userinfo() {
    _arguments \
        '-e[exit-status only (check existence)]' \
        '1:user:_users'
}

_userinfo "$@"
