#compdef speedtest_exporter
# Documentation: https://github.com/nlamirault/speedtest_exporter
# Prometheus exporter for Speedtest.net metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-version[print version information]' \
  '-web.listen-address=[address to listen on for web interface and telemetry]:address' \
  '-web.telemetry-path=[path under which to expose metrics]:path' \
  '-speedtest.config-url=[Speedtest configuration URL]:url' \
  '-speedtest.server-url=[Speedtest server URL]:url' \
  '*:arg:_default' && ret=0

return ret
