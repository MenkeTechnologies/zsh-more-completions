#compdef prometheus

# Zsh completion for Prometheus - monitoring system and time series database

_arguments -s -S \
  '--config.file=[config file]:file:_files -g "*.yml"' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.config.file=[TLS config file]:file:_files -g "*.yml"' \
  '--web.read-timeout=[read timeout]:duration:' \
  '--web.max-connections=[max simultaneous connections]:count:' \
  '--web.external-url=[external URL]:url:' \
  '--web.route-prefix=[prefix for internal routes]:prefix:' \
  '--web.user-assets=[path to static asset directory]:directory:_files -/' \
  '--web.enable-lifecycle[enable shutdown and reload via HTTP]' \
  '--web.enable-admin-api[enable admin control actions via HTTP]' \
  '--web.enable-remote-write-receiver[enable remote write receiver]' \
  '--web.console.templates=[path to console template directory]:directory:_files -/' \
  '--web.console.libraries=[path to console library directory]:directory:_files -/' \
  '--web.page-title=[document title]:title:' \
  '--web.cors.origin=[regex for CORS origin]:regex:' \
  '--storage.tsdb.path=[base path for metrics storage]:directory:_files -/' \
  '--storage.tsdb.retention.time=[retention time]:duration:' \
  '--storage.tsdb.retention.size=[retention size]:size:' \
  '--storage.tsdb.no-lockfile[do not create lockfile]' \
  '--storage.tsdb.allow-overlapping-blocks[allow overlapping blocks]' \
  '--storage.tsdb.wal-compression[compress WAL]' \
  '--storage.remote.flush-deadline=[deadline for flushing data]:duration:' \
  '--storage.remote.read-sample-limit=[max samples in a remote read]:limit:' \
  '--storage.remote.read-concurrent-limit=[max concurrent remote reads]:limit:' \
  '--rules.alert.for-outage-tolerance=[alerting rule outage tolerance]:duration:' \
  '--rules.alert.for-grace-period=[alerting rule grace period]:duration:' \
  '--rules.alert.resend-delay=[alerting rule resend delay]:duration:' \
  '--alertmanager.notification-queue-capacity=[alertmanager notification queue]:capacity:' \
  '--alertmanager.drain-notification-queue-on-shutdown[drain queue on shutdown]' \
  '--query.lookback-delta=[lookback delta]:duration:' \
  '--query.timeout=[max query timeout]:duration:' \
  '--query.max-concurrency=[max concurrent queries]:count:' \
  '--query.max-samples=[max samples per query]:count:' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
