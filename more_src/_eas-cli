#compdef eas
# _eas-cli — Expo Application Services CLI (Expo); cloud builds, submit, update, credentials for Expo/React Native apps
# upstream: https://github.com/expo/eas-cli

_eas-cli() {
    local -a sub=(
        'account:account info'
        'analytics:opt-in/out analytics'
        'autocomplete:print shell autocomplete'
        'branch:manage update branches'
        'build:start a cloud build'
        'channel:manage update channels'
        'config:show resolved EAS config'
        'credentials:manage app credentials'
        'device:manage internal-distribution devices'
        'diagnostics:print env diagnostics'
        'env:manage environment variables'
        'help:show help'
        'init:initialize EAS in the project'
        'login:authenticate to Expo'
        'logout:log out'
        'metadata:manage app metadata'
        'open:open project on expo.dev'
        'project:project commands'
        'secret:manage secret values'
        'submit:submit a build to App Store / Play Store'
        'update:publish an over-the-air update'
        'webhook:manage build webhooks'
        'whoami:print current user'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--non-interactive[no prompts]' \
        '--json[JSON output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'eas subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '(-p --platform)'{-p,--platform}'+[platform]:platform:(android ios all)' \
                    '(-e --profile)'{-e,--profile}'+[build profile]:profile:' \
                    '--local[run build locally]' \
                    '--wait[wait for build to finish]' \
                    '--no-wait[do not wait]' \
                    '--clear-cache[clear cache]' \
                    '--auto-submit[auto submit after build]' ;;
                submit) _arguments \
                    '(-p --platform)'{-p,--platform}'+[platform]:platform:(android ios all)' \
                    '(-e --profile)'{-e,--profile}'+[submit profile]:profile:' \
                    '--path+[archive path]:file:_files' \
                    '--url+[archive url]:url:_urls' \
                    '--id+[build id]:str:' \
                    '--latest[submit latest build]' \
                    '--wait[wait for submission]' ;;
                update) _arguments \
                    '(-p --platform)'{-p,--platform}'+[platform]:platform:(android ios all)' \
                    '(-b --branch)'{-b,--branch}'+[branch]:branch:' \
                    '--channel+[channel]:channel:' \
                    '--message+[message]:str:' \
                    '--republish[republish previous update]' \
                    '--auto[auto detect branch]' ;;
                credentials) _arguments \
                    '(-p --platform)'{-p,--platform}'+[platform]:platform:(android ios)' ;;
                channel) _arguments '1:channel cmd:(create list pause rollout update view)' ;;
                branch) _arguments '1:branch cmd:(create delete list rename view)' ;;
                env) _arguments '1:env cmd:(create delete list pull push)' ;;
                webhook) _arguments '1:webhook cmd:(create delete list update view)' ;;
            esac
            ;;
    esac
}

_eas-cli "$@"
