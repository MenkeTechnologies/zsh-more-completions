#compdef tsbs_generate_queries
# Documentation: https://github.com/timescale/tsbs#generate-queries
# Time Series Benchmark Suite query generator

local ret=1

_arguments -s -S \
  '--format=[format to generate]:format:(cassandra clickhouse influx mongo siridb timescaledb akumuli cratedb prometheus victoriametrics timestream questdb)' \
  '--use-case=[use case to generate]:use case:(devops iot cpu-only devops-generic)' \
  '--queries=[number of queries to generate]:count' \
  '--query-type=[query type (choices in the use case matrix)]:query type' \
  '--db-name=[database name to query]:db name' \
  '--scale=[scaling value specific to use case]:scale' \
  '--timestamp-start=[beginning timestamp (RFC3339)]:timestamp' \
  '--timestamp-end=[ending timestamp (RFC3339)]:timestamp' \
  '--seed=[PRNG seed (0 uses current timestamp)]:seed' \
  '--debug=[control level of debug output]:level' \
  '--file=[write the output to this path]:file:_files' \
  '--clickhouse-use-tags[ClickHouse only: use separate tags table when querying]' \
  '--mongo-use-naive[MongoDB only: generate queries for the naive data storage format]' \
  '--timescale-use-json[TimescaleDB only: use separate JSON tags table when querying]' \
  '--timescale-use-tags[TimescaleDB only: use separate tags table when querying]' \
  '--timescale-use-time-bucket[TimescaleDB only: use time bucket]' \
  '--interleaved-generation-group-id=[group to perform round-robin serialization within]:id' \
  '--interleaved-generation-groups=[number of round-robin serialization groups]:count' && ret=0

return ret
