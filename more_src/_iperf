#compdef iperf
# Documentation: iperf --help
# Source: ESnet iperf2 — TCP/UDP bandwidth measurement tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-b --bandwidth)'{-b,--bandwidth=}'[bandwidth bits/sec or packets/sec]:bw:' \
    '(-e --enhanced)'{-e,--enhanced}'[enhanced reporting]' \
    '(-f --format)'{-f,--format=}'[report format]:fmt:(k m g K M G)' \
    '--hide-ips[hide IP addresses and hostnames]' \
    '--histograms[enable histograms]' \
    '(-i --interval)'{-i,--interval=}'[seconds between bandwidth reports]:seconds:' \
    '(-l --len)'{-l,--len=}'[buffer length in bytes]:bytes:' \
    '(-m --print_mss)'{-m,--print_mss}'[print TCP max segment size]' \
    '(-o --output)'{-o,--output=}'[output report/error to file]:file:_files' \
    '(-p --port)'{-p,--port=}'[client/server port]:port:_ports' \
    '--permit-key=[permit key for client+server validation]:key:' \
    '--tcp-tx-delay=[TCP_TX_DELAY ms]:ms:' \
    '--sum-only[output sum-only reports]' \
    '(-u --udp)'{-u,--udp}'[use UDP rather than TCP]' \
    '--utc[use UTC time]' \
    '(-w --window)'{-w,--window=}'[TCP window size (socket buffer)]:size:' \
    '(-B --bind)'{-B,--bind=}'[bind to host[\:port][%dev]]:host:_hosts' \
    '(-C --compatibility)'{-C,--compatibility}'[older-iperf wire compatibility]' \
    '--NUM_REPORT_STRUCTS=[shared-mem reporter entries]:n:' \
    '(-M --mss)'{-M,--mss=}'[TCP_MAXSEG]:bytes:' \
    '(-N --nodelay)'{-N,--nodelay}'[set TCP_NODELAY (disable Nagle)]' \
    '(-S --tos)'{-S,--tos=}'[set IP_TOS byte]:tos:' \
    '(-Z --tcp-congestion)'{-Z,--tcp-congestion=}'[TCP congestion algorithm]:algo:(cubic reno bbr vegas westwood)' \
    '(-s --server -c --client)'{-s,--server}'[run in server mode]' \
    '(-s --server -c --client)'{-c,--client=}'[run in client mode (host)]:host:_hosts' \
    '(-1 --singleclient)'{-1,--singleclient}'[run one server at a time]' \
    '--jitter-histograms[enable jitter histograms]' \
    '--permit-key-timeout=[permit-key timeout (s)]:s:' \
    '--skip-rx-copy[MSG_TRUNC to avoid kernel copy]' \
    '--tcp-rx-window-clamp=[TCP recv window clamp]:bytes:' \
    '--test-exchange-timeout=[test exchange timeout (0=none)]:s:' \
    '--tap-dev=[use TAP device for L2 receive]:dev:' \
    '(-t --time)'{-t,--time=}'[time to listen / receive (s)]:s:' \
    '(-U --single_udp)'{-U,--single_udp}'[single-threaded UDP mode]' \
    '--sum-dstip[sum threads by destination IP]' \
    '(-D --daemon)'{-D,--daemon}'[run server as a daemon]' \
    '(-V --ipv6_domain)'{-V,--ipv6_domain}'[enable IPv6 reception]' \
    '--bounceback[bounceback test]' \
    '--bounceback-hold=[bounceback delay ms]:ms:' \
    '--bounceback-no-quickack[do not set TCP_QUICKACK]' \
    '--bounceback-period=[bounceback send period ms]:ms:' \
    '--bounceback-reply=[bounceback reply size]:bytes:' \
    '--bounceback-txdelay=[bounceback request/reply delay (s)]:s:' \
    '--connect-only[run connect-only test]' \
    '--connect-retry-timer=[min retry interval s]:s:' \
    '--connect-retry-time=[total retry time s]:s:' \
    '--dscp=[DSCP field]:dscp:' \
    '(-d --dualtest)'{-d,--dualtest}'[bidirectional simultaneous test]' \
    '--fq-rate=[socket pacing bandwidth]:bw:' \
    && ret=0

return ret
