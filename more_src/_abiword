#compdef abiword

# Zsh completion for abiword - AbiWord document converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--to+[output format]:format:(abw doc docx html odt pdf rtf txt latex)' \
  '--to-name+[output filename]:file:_files' \
  '--import-extension+[force import filter by extension]:extension' \
  '--print[print document]' \
  '--plugin+[plugin name]:plugin' \
  '--geometry+[window geometry]:geometry (WxH+X+Y)' \
  '--merge+[mail merge data file]:file:_files' \
  '--template+[template file]:file:_files' \
  '*:files:_files -g "*.{abw,doc,docx,html,odt,rtf,txt}"'
