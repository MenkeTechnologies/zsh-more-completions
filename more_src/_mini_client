#compdef mini_client
# Documentation: https://man.archlinux.org/search?q=mini_client
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'server_name=:server name'
  'server_addr=:server address'
  'server_port=:server port'
  'debug_level=:debug level'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    _describe -t params 'param' params -S '' && ret=0
    ;;
esac

return ret
