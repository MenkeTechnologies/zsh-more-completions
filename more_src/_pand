#compdef pand

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '--listen[server mode]' \
  '--connect=+[bdaddr]:bdaddr:' \
  '--search[search for servers]' \
  '--kill=+[kill matching]:bdaddr:' \
  '--killall[kill all]' \
  '--show[show connections]' \
  '--service=+[service]:svc:(NAP GN PANU)' \
  '--role=+[role]:role:(NAP GN PANU)' \
  '--ethernet=+[ethernet device]:dev:' \
  '--device=+[device]:dev:' \
  '--nodetach[no fork]' \
  '--persist=+[persist interval]:sec:' \
  '--auth[require auth]' \
  '--encrypt[require encryption]' \
  '--secure[require secure auth]' \
  '--master[become master]' \
  '--cache[cache PIN]' \
  '--up=+[up command]:cmd:' \
  '--down=+[down command]:cmd:' \
  '--devup=+[devup command]:cmd:' \
  '--devdown=+[devdown command]:cmd:' && ret=0

return ret
