#compdef stiff
# Documentation: https://github.com/astromatic/stiff/blob/master/src/main.c
# STIFF - convert FITS images to TIFF format for visualisation

local ret=1

_arguments -s -S \
  '-h[show syntax/help]' \
  '-v[show version information]' \
  '-d[dump a default configuration file]' \
  '-dd[dump an extended default configuration file]' \
  '-c+[use the given configuration file]:config file:_files' \
  '*:FITS image:_files -g "*.(fits|fit|FITS|FIT|fz)"' && ret=0

return ret
