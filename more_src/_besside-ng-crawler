#compdef besside-ng-crawler kstats airodump-ng-oui-update dcrack versuck-ng
# Documentation: upstream aircrack-ng man pages and source at
# github.com/aircrack-ng/aircrack-ng
# Reference accessed: 2026-05-30 via WebFetch of
# manpages.debian.org/bookworm/aircrack-ng/{besside-ng-crawler,kstats,
# airodump-ng-oui-update}.1/8.en.html and gh api inspection of
# scripts/dcrack.py + scripts/versuck-ng/versuck-ng argparse calls.
# aircrack-ng family R87 — 5-stem multi-binary harvest covering
# small aircrack-ng utilities not previously covered. Existing
# coverage in src/: _aircrack-ng/_airbase-ng/_airdecap-ng/
# _airdecloak-ng/_aireplay-ng/_airodump-ng/_airolib-ng/_airserv-ng/
# _airtun-ng/_airventriloquist-ng/_besside-ng/_buddy-ng/_easside-ng/
# _makeivs-ng/_packetforge-ng/_tkiptun-ng/_wesside-ng and in
# man_src/: _airmon-ng/_ivstools and in more_src/: _airdrop-ng/
# _airgraph-ng/_wpaclean — so the suite is now near-complete.

local curcontext="$curcontext" state line ret=1

case $service in

  besside-ng-crawler)
    # Recursively scan pcap dumpfiles for WPA beacons and EAPOL
    # frames, filter into a single output file.
    # Just 2 positional args; no documented flags.
    _arguments \
      '1:input directory:_directories' \
      '2:output file:_files' && ret=0
    ;;

  kstats)
    # Display FMS algorithm vote distribution for a captured WEP
    # IVS file against a known 104-bit key.
    # Just 2 positional args; no documented flags.
    _arguments \
      '1:IVS file:_files -g "*.ivs"' \
      '2:104-bit key (hex):' && ret=0
    ;;

  airodump-ng-oui-update)
    # Download and parse the IEEE OUI list for airodump-ng.
    # No documented CLI options per upstream man page.
    _arguments \
      '(- *)'{-h,--help}'[show help]' && ret=0
    ;;

  dcrack)
    # Distributed WEP/WPA cracking coordinator (dcrack.py from
    # aircrack-ng/scripts/). 3 top-level modes.
    local -a _modes _cmd_subs
    _modes=(
      'server:run the coordination server'
      'client:connect to a server as a cracking worker'
      'cmd:send an administrative command to a running server'
    )
    _cmd_subs=(
      'dict:upload and register a wordlist file'
      'cap:submit a wireless capture file'
      'crack:initiate cracking on a specific BSSID'
      'remove:delete a network from the queue'
      'status:display progress and connected clients'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-): :->mode' \
      '(-)*:: :->mode_args' && ret=0
    case $state in
      mode) _describe -t commands 'dcrack mode' _modes && ret=0 ;;
      mode_args)
        case $words[1] in
          server)
            # No further args (default port 1337).
            _arguments && ret=0
            ;;
          client)
            _arguments '1:server address (host\:port, default port 1337):' && ret=0
            ;;
          cmd)
            _arguments -C \
              '1:server address (host\:port):' \
              '2:cmd subcommand:->cmd_sub' \
              '*:: :->cmd_sub_args' && ret=0
            case $state in
              cmd_sub) _describe -t commands 'dcrack cmd subcommand' _cmd_subs && ret=0 ;;
              cmd_sub_args)
                case $words[1] in
                  dict|cap)
                    _arguments '1:file:_files' && ret=0
                    ;;
                  crack|remove)
                    _arguments '1:BSSID (MAC address):' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;

  versuck-ng)
    # Calculate default WEP key for Verizon-issued Actiontec routers.
    _arguments -s -S \
      '(-m --mac)'{-m,--mac}'=[MAC address (e.g. 001801xxxxxx)]:mac:' \
      '(-e --essid)'{-e,--essid}'=[ESSID]:essid:' \
      '(- *)'{-h,--help}'[show help]' && ret=0
    ;;

esac

return ret
