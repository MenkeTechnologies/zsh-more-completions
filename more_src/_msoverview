#compdef msoverview
# Documentation: https://support.astron.nl/LOFARImagingCookbook/datainspection.html
# Summarize the contents of a casacore MeasurementSet (raw or processed).

local ret=1

_arguments -s -S \
  '*in=[input MeasurementSet]:ms:_files -/' \
  '*verbose=[show detailed observation information]:verbose:(T F)' && ret=0

return ret
