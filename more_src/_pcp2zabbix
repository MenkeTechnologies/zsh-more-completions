#compdef pcp2zabbix
# Documentation: https://man.archlinux.org/man/pcp2zabbix.1.en
# Performance Co-Pilot metrics exporter to Zabbix

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display version and exit]' \
  '(-g --zabbix-server)'{-g+,--zabbix-server=}'[destination Zabbix server]:server:_hosts' \
  '(-p --zabbix-port)'{-p+,--zabbix-port=}'[Zabbix server port]:port' \
  '(-X --zabbix-host)'{-X+,--zabbix-host=}'[agent hostname as registered in Zabbix]:hostname' \
  '(-E --zabbix-interval)'{-E+,--zabbix-interval=}'[interval to send metrics to server]:interval' \
  '(-x --zabbix-prefix)'{-x+,--zabbix-prefix=}'[metrics prefix for measurements]:prefix' \
  '(-l --zabbix-lld)'{-l,--zabbix-lld}'[add low-level discovery (LLD) metrics]' \
  '(-c --config)'{-c+,--config=}'[configuration file or directory]:config:_files' \
  '(-s --samples)'{-s+,--samples=}'[number of samples to report]:samples' \
  '(-t --interval)'{-t+,--interval=}'[reporting interval]:interval' \
  '(-P --precision)'{-P+,--precision=}'[decimal places for numeric output]:precision' \
  '(-h --host)'{-h+,--host=}'[remote host for metric collection]:host:_hosts' \
  '(-a --archive)'{-a+,--archive=}'[PCP archive source]:archive:_files' \
  '(-L --local-PMDA)'{-L,--local-PMDA}'[use local DSO PMDAs]' \
  '(-C --check)'{-C,--check}'[exit before reporting any values]' \
  '*:metric:_default' && ret=0

return ret
