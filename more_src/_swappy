#compdef swappy
# Documentation: https://github.com/jtheoof/swappy (swappy.1.scd)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swappy - Wayland native snapshot editing tool

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[load file]:file:_files -g "*.(png|jpg|jpeg|ppm)"' \
  '(-o --output-file)'{-o,--output-file}'[save to file]:file:_files'
