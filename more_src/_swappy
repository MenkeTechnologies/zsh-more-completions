#compdef swappy

# Zsh completion for swappy - Wayland native snapshot editing tool

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[load file]:file:_files -g "*.(png|jpg|jpeg|ppm)"' \
  '(-o --output-file)'{-o,--output-file}'[save to file]:file:_files'
