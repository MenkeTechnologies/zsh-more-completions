#compdef nats-pub

# nats-pub: simple NATS message publisher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[NATS servers]:servers:' \
  '-r[reply subject]:subj:' \
  '-c[count]:n:' \
  '-q[queue group]:group:' \
  '-i[interval ms]:ms:' \
  '-tls[use TLS]' \
  '-creds[credentials file]:file:_files' \
  '-nkey[nkey file]:file:_files' \
  '-name[client name]:name:' \
  '-user[user]:user:_users' \
  '-pass[password]:password:' \
  '-headers[set header key=value]:kv:' \
  '1:subject:' \
  '2:message:' && ret=0
return ret
