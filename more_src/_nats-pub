#compdef nats-pub
# Documentation: https://github.com/nats-io/go-nats-examples/blob/main/tools/nats-pub/nats-pub.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nats-pub: simple NATS message publisher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[NATS servers (comma separated)]:servers:' \
  '-creds[user credentials file]:file:_files' \
  '1:subject:' \
  '2:message:' && ret=0
return ret
