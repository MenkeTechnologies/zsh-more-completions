#compdef portmap
# Documentation: https://manpages.debian.org/testing/rpcbind/rpcbind.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug mode (no fork)]' \
  '-f[foreground]' \
  '-v[verbose]' \
  '-l[only listen on loopback]' \
  '-i+[bind interface IP]:ip:' \
  '-u+[user to run as]:user:_users' \
  '-g+[group to run as]:group:_groups' \
  '-t+[chroot directory]:dir:_files -/' && ret=0

return ret
