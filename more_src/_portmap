#compdef portmap
# Documentation: https://man7.org/linux/man-pages/man8/rpcbind.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# portmap on modern Linux is provided by rpcbind; flags follow rpcbind(8).

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[abort on errors when used with -d]' \
  '-d[run in debug mode]' \
  '-f[do not fork into background]' \
  '*-h+[bind to specific IP address]:ip:' \
  '-i[insecure mode, allow SET/UNSET from any host]' \
  '-l[turn on libwrap connection logging]' \
  '-s[switch to user daemon as soon as possible]' \
  '-w[warm start, read state file]' \
  '-6[bind to IPv6 addresses only]' && ret=0

return ret
