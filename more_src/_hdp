#compdef hdp
# Documentation: https://manpages.debian.org/testing/hdf4-tools/hdp.1.en.html
# HDF dumper: display contents of HDF objects (SDS, vdata, vgroup, RIG)

local ret=1

_arguments -s \
  '-H+[display usage about specified command or all commands]:command:(list dumpsds dumpvd dumpvg dumprig)' \
  '1:command:(list dumpsds dumpvd dumpvg dumprig)' \
  '*:hdf file:_files -g "*.(hdf|h4)"' && ret=0

return ret
