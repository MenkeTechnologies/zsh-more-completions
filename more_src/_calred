#compdef calred
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/calred.html
# Analyse flux densities of sources with poor phase stability

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'select=[select keyword]:select:' \
  'line=[line keyword]:line:' \
  'stokes=[stokes keyword]:stokes:' \
  'interval=[interval keyword]:interval:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
