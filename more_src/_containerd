#compdef containerd
# _containerd — containerd daemon (CRI-compatible OCI container runtime)
# upstream: https://github.com/containerd/containerd
# Flags + subcommands from cmd/containerd/command/{main,config,publish,oci-hook}.go on tip (urfave/cli/v2).

_containerd() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print the version]' \
        '--config=[path to the configuration file]:file:_files' \
        '--log-level=[logging level]:level:(trace debug info warn error fatal panic)' \
        '--address=[containerd gRPC server address]:socket:_files' \
        '--root=[containerd root directory]:dir:_files -/' \
        '--state=[containerd state directory]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                config:'inspect or migrate the containerd config'
                publish:'publish an event to containerd'
                oci-hook:'base implementation for OCI runtime hooks'
            )
            _describe -t commands 'containerd subcommand' subs
            ;;
        args)
            case $line[1] in
                config)
                    _arguments \
                        '1:subcommand:(default dump migrate)'
                    ;;
                publish)
                    _arguments \
                        '--namespace=[namespace to publish to]:ns:' \
                        '--topic=[topic of the event]:topic:'
                    ;;
            esac
            ;;
    esac
}

_containerd "$@"
