#compdef luxcoreconsole
# Documentation: https://github.com/LuxCoreRender/LuxCore/blob/master/samples/luxcoreconsole/luxcoreconsole.cpp
# LuxCoreRender command-line renderer

local ret=1

_arguments -s \
  '-h[display help message and exit]' \
  '-o[configuration file]:config:_files' \
  '-f[scene file]:scene:_files' \
  '-w[film width]:width' \
  '-e[film height]:height' \
  '-D[set property: name value]:name' \
  '-d[change current directory]:dir:_files -/' \
  '-c[remove unused meshes, materials, textures and image maps]' \
  '-s[enable device statistics display]' \
  '*:scene:_files -g "*.(cfg|lxs|bcf|rsm)"' && ret=0

return ret
