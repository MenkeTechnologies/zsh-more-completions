#compdef brev
# Documentation: https://docs.nvidia.com/brev/cli/cli-overview
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# brev - NVIDIA Brev CLI (formerly brev.dev)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate with Brev'
  'logout:remove stored credentials'
  'ssh-key:show your SSH public key'
  'search:search GPU and CPU instance types'
  'create:create instances with smart defaults'
  'ls:list instances in current org'
  'list:list instances in current org'
  'start:start stopped instances'
  'stop:stop running instances'
  'delete:delete an instance permanently'
  'refresh:sync instances from web console'
  'shell:open interactive SSH shell on instance'
  'exec:run command non-interactively on instance'
  'copy:transfer files to/from instance'
  'cp:transfer files (alias of copy)'
  'scp:transfer files (alias of copy)'
  'open:launch instance in editor (VS Code, Cursor, Windsurf)'
  'port-forward:forward remote ports to localhost'
  'org:organization commands (ls)'
  'set:switch active organization'
  'invite:generate an invite link'
  'agent-skill:install/uninstall the Brev skill for AI agents'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd) _describe -t cmds 'brev command' commands && ret=0 ;;
  (rest)
    case $line[1] in
      (stop)
        _arguments '--all[stop all instances]' && ret=0 ;;
      (org)
        _values 'org subcommand' 'ls' && ret=0 ;;
      (*) _normal && ret=0 ;;
    esac ;;
esac

return ret
