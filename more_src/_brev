#compdef brev
# Documentation: https://man.archlinux.org/search?q=brev
# Reference accessed: 2026-05-16

# brev.dev CLI (cobra); Homebrew: Formula/b/brev.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '*--namespace=[Kubernetes namespace]:namespace:' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'brev command' compadd -- healthcheck shell copy vscode ssh tasks create delete list activate capi cluster port-forward org open configure update version
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
