#compdef jalv jalv.gtk3 jalv.qt5 jalv.qt6 jalv.console
# _jalv — host an LV2 plugin as a JACK application (drobilla/jalv)
# upstream: https://github.com/drobilla/jalv
# Flags from src/console/jalv_console.c.

_jalv() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '(- *)-V[show version]'
        '-b+[plugin<->UI communication buffer size (bytes)]:size:'
        '*-c+[set control value (sym=value)]:sym=value:'
        '-d[dump plugin<->UI communication]'
        '-i[ignore keyboard input, run non-interactively]'
        '-n+[JACK client name]:name:'
        '-p[print control output changes to stdout]'
        '-s[show plugin UI if possible]'
        '-t[print debug trace messages]'
        '-U+[load the UI with this URI]:uri:'
        '-x[exit if requested JACK client name is taken]'
        '1:plugin/preset URI or path:_files'
    )
    _arguments -s $args
}

_jalv "$@"
