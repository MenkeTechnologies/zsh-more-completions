#compdef flang flang-new

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[compile and assemble, but do not link]' \
  '-S[compile only; do not assemble or link]' \
  '-E[preprocess only]' \
  '-o+[write output to file]:output file:_files' \
  '-I+[add include directory]:include dir:_files -/' \
  '-L+[add library search directory]:library dir:_files -/' \
  '-l+[link with library]:library name:' \
  '-D+[define macro]:macro definition:' \
  '-U+[undefine macro]:macro name:' \
  '-g[generate debug information]' \
  '-O-[optimization level]:level:(0 1 2 3 s z)' \
  '-std=[specify Fortran standard]:standard:(f2003 f2008 f2018 gnu legacy)' \
  '-ffixed-form[use fixed-form source layout]' \
  '-ffree-form[use free-form source layout]' \
  '-fdefault-integer-8[set default integer to 8 bytes]' \
  '-fdefault-real-8[set default real to 8 bytes]' \
  '-fdefault-double-8[set default double precision to 8 bytes]' \
  '-fimplicit-none[disable implicit typing]' \
  '-fbackslash[interpret backslash as escape character]' \
  '-fno-backslash[do not interpret backslash as escape character]' \
  '-fintrinsic-modules-path=[path to intrinsic modules]:module path:_files -/' \
  '-fcolor-diagnostics[enable colored diagnostics]' \
  '-fno-color-diagnostics[disable colored diagnostics]' \
  '-flarge-sizes[use 64-bit integers for sizes]' \
  '-fopenacc[enable OpenACC]' \
  '-fopenmp[enable OpenMP]' \
  '-fppc-native-double[use PowerPC native double precision]' \
  '-fconvert=[specify byte order for unformatted I/O]:endianness:(big-endian little-endian native swap)' \
  '-fpass-plugin=[load plugin for the optimizer]:plugin:_files' \
  '-fstack-arrays[allocate automatic arrays on the stack]' \
  '-fno-stack-arrays[allocate automatic arrays on the heap]' \
  '-funderscoring[append underscores to external names]' \
  '-fno-underscoring[do not append underscores to external names]' \
  '-ffast-math[enable fast-math optimizations]' \
  '-module-dir=[directory for module files]:module dir:_files -/' \
  '-module-suffix=[suffix for module files]:suffix:' \
  '-pedantic[issue warnings for non-standard code]' \
  '-Wall[enable all warnings]' \
  '-Werror[treat warnings as errors]' \
  '-Wextra[enable extra warnings]' \
  '-w[suppress all warnings]' \
  '-v[show commands to run and use verbose output]' \
  '--version[display version information]' \
  '--help[display help information]' \
  '-target=[specify target triple]:target triple:' \
  '-march=[specify target architecture]:architecture:' \
  '-mcpu=[specify target CPU]:cpu:' \
  '-mtune=[specify target CPU for tuning]:cpu:' \
  '-fpic[generate position-independent code]' \
  '-fPIC[generate position-independent code (large model)]' \
  '-shared[create shared library]' \
  '-static[do not link with shared libraries]' \
  '-pthread[enable pthreads support]' \
  '*:Fortran source files:_files -g "*.{f,f90,f95,f03,f08,F,F90,F95,F03,F08,for,fpp}"' \
  && ret=0

return ret
