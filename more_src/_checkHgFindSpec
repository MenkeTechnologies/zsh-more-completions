#compdef checkHgFindSpec
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# test and describe search specs in hgFindSpec tables

local ret=1

_arguments -s -S \
  '-showSearches[print out the order in which searches are performed]' \
  '-checkTermRegex[check the search terms against the term regex]' \
  '-checkIndexes[check that fields searched are indexed]' \
  '-noHtml[do not print HTML output]' \
  '*:database termToSearch:_files' && ret=0

return ret
