#compdef antibody

# Zsh completion for antibody - zsh plugin manager

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'bundle:Download and apply plugins from stdin or arguments'
  'init:Print the antibody source command'
  'list:List installed plugins'
  'update:Update all installed plugins'
  'purge:Remove a plugin'
  'home:Print the antibody home directory'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'antibody subcommand' subcommands
    ;;
  args)
    case $words[1] in
      purge)
        _arguments '1:plugin name'
        ;;
      bundle)
        _arguments '*:plugin spec'
        ;;
    esac
    ;;
esac

return ret
