#
# WHAT IS simplelog AND WHY IS IT THE 59TH RUST CLI LIBRARY?
#
# simplelog (https://github.com/Drakulix/simplelog.rs, 760+ stars)
# is **Victoria Brekenfeld's "simplelog.rs"** — a minimal combinator-
# style logger built on the `log` crate facade.  Where env_logger
# uses env-var filters, slog uses structured macros, tracing uses
# spans, fern uses chained builders, and log4rs uses XML/YAML config
# — simplelog provides the SIMPLEST possible idiom: construct a
# Vec of logger targets, call ::init() once, done.
#
# simplelog's distinguishing characteristics:
#
#   1. COMBINATOR-STYLE MULTI-TARGET INIT — simplelog's central
#      API is `CombinedLogger::init(vec![...])`:
#
#          use simplelog::*;
#          use std::fs::File;
#
#          CombinedLogger::init(vec![
#              TermLogger::new(
#                  LevelFilter::Warn,
#                  Config::default(),
#                  TerminalMode::Mixed,
#                  ColorChoice::Auto,
#              ),
#              WriteLogger::new(
#                  LevelFilter::Info,
#                  Config::default(),
#                  File::create("my_rust_bin.log").unwrap(),
#              ),
#          ]).unwrap();
#
#          log::info!("hello world");
#          log::warn!("warning text");
#          // Above logs go to BOTH stderr (Warn+ filter) AND
#          // the log file (Info+ filter) in parallel.
#
#      Each logger target implements SharedLogger.  Built-in
#      target types:
#         * SimpleLogger — stdout, no fancy features
#         * TermLogger — stderr/stdout with ANSI colors +
#                         TerminalMode (Stdout/Stderr/Mixed)
#         * WriteLogger<W: Write> — any writer (file, socket,
#                                    custom)
#         * CombinedLogger — composite of multiple loggers
#         * TestLogger — for use in tests (suppresses output)
#      Compare:
#         * env_logger: single backend, env-var filtered
#         * fern: Dispatch::new().level().chain(...) builder
#         * tracing: spans + subscribers + layers
#         * slog: Drain trait + drain chains
#         * log4rs: XML/YAML config file
#         * simplelog: Vec<Box<dyn SharedLogger>> init()
#      FIRST documented Rust Axis 9 logger with combinator-
#      style multi-target initialization.
#
#   2. ZERO ENV-VAR DEPENDENCY — simplelog deliberately AVOIDS
#      env-var parsing.  All configuration is via the Config
#      struct passed to ::new():
#
#          let cfg = ConfigBuilder::new()
#              .set_time_level(LevelFilter::Off)        // hide time stamps
#              .set_thread_level(LevelFilter::Off)      // hide thread IDs
#              .set_target_level(LevelFilter::Off)      // hide module path
#              .set_location_level(LevelFilter::Error)  // file:line on errors
#              .set_time_format_custom(format_description!(
#                  "[hour]:[minute]:[second]"
#              ))
#              .set_time_offset_to_local()
#              .unwrap()
#              .build();
#
#          TermLogger::init(LevelFilter::Info, cfg,
#              TerminalMode::Stderr, ColorChoice::Auto).unwrap();
#
#      Compare:
#         * env_logger: env::var("RUST_LOG") parsed at init
#         * pretty_env_logger: thin wrapper over env_logger
#         * tracing-subscriber: env-filter layer optional but
#                                expected
#         * simplelog: NO env-var reading anywhere in the
#                       library
#      FIRST documented Rust Axis 9 logger with explicit
#      env-var-free philosophy.
#
#   3. PARALLEL DISPATCH TO MULTIPLE BACKENDS — CombinedLogger
#      dispatches each log call to every SharedLogger in its
#      vector IN PARALLEL (no head-of-line blocking):
#
#          log::info!("event");
#          // → TermLogger filters (Warn+ rejects info)
#          // → WriteLogger filters (Info+ accepts)
#          // Both filters evaluated independently, no
#          // ordering or coupling between backends.
#
#      Compare:
#         * fern: chains pass messages sequentially through
#                  filters
#         * slog: AsyncDrain wraps a drain for parallel
#                  dispatch but requires explicit setup
#         * tracing: layered subscribers but layering is
#                     ordered
#         * simplelog: parallel by construction
#      FIRST documented Rust Axis 9 logger with parallel
#      multi-backend dispatch as the default design.
#
#   4. ANSI-COLOR-AWARE TerminalMode + ColorChoice — TermLogger
#      takes both:
#         * TerminalMode::Stdout — only stdout
#         * TerminalMode::Stderr — only stderr
#         * TerminalMode::Mixed — split by level
#                                  (warn/error → stderr,
#                                   info/debug → stdout)
#         * ColorChoice::Auto — detect TTY
#         * ColorChoice::Always — force colors
#         * ColorChoice::Never — disable colors
#      The Mixed mode is unique among Rust loggers — solving
#      the "I want progress on stdout but errors on stderr"
#      pattern without manual filter setup.
#      FIRST documented Rust Axis 9 logger with explicit
#      TerminalMode::Mixed split-by-level routing.
#
#   5. VICTORIA-BREKENFELD / WAYLAND-COSMIC ECOSYSTEM PROVENANCE —
#      simplelog is maintained by Victoria Brekenfeld (Drakulix
#      on GitHub), known for the Cosmic desktop / Wayland
#      compositor work + Smithay (Wayland-in-Rust framework).
#      simplelog has been adopted across Wayland-Rust ecosystem
#      tools + 600+ unrelated Rust CLIs needing a "I just want
#      logs, don't make me think" API.  Notable users:
#         * mozilla/grcov (code coverage)
#         * tag1consulting/goose (load testing)
#         * agersant/polaris (music server)
#         * Isona/dirble (THIS — directory scanner)
#         * everx-labs/ever-cli (Everscale blockchain)
#         * Revertron/Alfis (decentralized DNS)
#         * 600+ more
#      FIRST documented Rust Axis 9 logger with this specific
#      Wayland-Rust-ecosystem maintainership provenance.
#
# simplelog's relationship to other documented Rust Axis 9 libraries:
#
#   * Unlike env_logger (R582) — env_logger reads RUST_LOG env-var;
#                                  simplelog requires explicit Config
#   * Unlike slog (R586) — slog is structured-data drains;
#                            simplelog is plain log-crate facade
#   * Unlike tracing (R590) — tracing is span-based async-aware;
#                               simplelog is sync flat events
#   * Unlike fern (R594) — fern uses chained filter dispatch;
#                            simplelog uses Vec combinator init
#   * Closest cross-language analogs:
#         * Go: golang.org/x/exp/slog (stdlib) — both prefer flat
#                                                  facade API
#         * TS-Node: winston (R580) — both support multi-transport
#                                       parallel dispatch
#         * Java: SLF4J + Logback — similar facade+backend split
#     simplelog is the FIRST documented Rust logger providing
#     combinator-style multi-target initialization with no
#     env-var dependency.
#
# -----------------------------------------------------------------------------
#
# THE dirble CLI — clap 4.x builder + simplelog dual-target logging
#
# dirble's CLI is in src/arg_parse.rs.  Uses clap 4.x builder API:
#
#     use clap::{Arg, ArgAction, ArgGroup, Command,
#                ValueEnum, builder::EnumValueParser,
#                crate_version, value_parser};
#     use simplelog::LevelFilter;
#
#     let mut args = app().get_matches_from(args);
#
# Logging setup uses simplelog to dispatch ALL log messages to BOTH
# terminal (with ANSI colors) AND a log file simultaneously,
# verbosity controlled by -v/--verbose count + -S/--silent flag.
#
# Five-axis distinctness from every other documented Rust Axis 9
# logger:
#
#   1. COMBINATOR-STYLE VEC INIT — Every other documented Rust
#      logger uses either env-var filters (env_logger),
#      structured drains (slog), spans (tracing), chained builders
#      (fern), or XML/YAML config (log4rs).  simplelog uses
#      Vec<Box<dyn SharedLogger>> + CombinedLogger::init.
#
#   2. ZERO ENV-VAR PHILOSOPHY — Every other documented Rust
#      Axis 9 logger either reads env-vars natively or expects
#      env-filter layers.  simplelog refuses to touch env-vars.
#
#   3. TerminalMode::Mixed SPLIT-BY-LEVEL — Every other documented
#      Rust Axis 9 logger requires manual filter setup to split
#      warn/error→stderr from info/debug→stdout.  simplelog has
#      TerminalMode::Mixed as a primitive.
#
#   4. PARALLEL MULTI-BACKEND DISPATCH BY DEFAULT — Every other
#      documented Rust Axis 9 logger either dispatches
#      sequentially (fern chains) or requires explicit async
#      wrappers (slog AsyncDrain).  simplelog parallelizes by
#      construction.
#
#   5. VICTORIA-BREKENFELD / WAYLAND-COSMIC PROVENANCE — Every
#      other documented Rust Axis 9 logger has different
#      maintainership.  simplelog is by Victoria Brekenfeld
#      with Cosmic/Smithay ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/Isona/dirble/blob/master/src/arg_parse.rs
# clap 4.x builder definitions in fn app().)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dirble_verbs
_dirble_verbs=(
    'get:HTTP GET requests (default)'
    'head:HTTP HEAD requests'
    'post:HTTP POST requests'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:host URI:_urls' \
    '*'{-u+,--uri=}'[additional host to scan]:uri:_urls' \
    '*--url=[additional host to scan (alias for --uri)]:url:_urls' \
    '*'{-U+,--uri-file=}'[file with list of URIs to scan]:uri file:_files' \
    '*--url-file=[file with list of URIs to scan (alias)]:url file:_files' \
    '--verb=[HTTP verb to use]:verb:(get head post)' \
    '*'{-w+,--wordlist=}'[wordlist file to use]:wordlist:_files' \
    '*'{-x+,--extensions=}'[comma-separated extensions to extend queries with]:extensions:_default' \
    '*'{-X+,--extension-file=}'[file with extensions to extend queries with]:extension file:_files' \
    '--ext-sub[substitute %EXT% in wordlist with current extension]' \
    '(-f --force-extension)'{-f,--force-extension}'[only scan with provided extensions]' \
    '*'{-p+,--prefixes=}'[comma-separated prefixes to extend queries with]:prefixes:_default' \
    '*'{-P+,--prefix-file=}'[file with prefixes to extend queries with]:prefix file:_files' \
    '(-o --output-file)'{-o+,--output-file=}'[report output file (txt)]:output file:_files' \
    '--oN=[report output file (nmap-style alias for --output-file)]:output file:_files' \
    '--json-file=[JSON output file]:json file:_files -g "*.json"' \
    '--oJ=[JSON output file (alias for --json-file)]:json file:_files -g "*.json"' \
    '--xml-file=[XML output file]:xml file:_files -g "*.xml"' \
    '--oX=[XML output file (alias for --xml-file)]:xml file:_files -g "*.xml"' \
    '--output-all=[write txt+json+xml outputs to filename.{txt,json,xml}]:output base:_files' \
    '--oA=[output all formats (alias for --output-all)]:output base:_files' \
    '--proxy=[proxy address (http://user:pass@host:port)]:proxy URL:_urls' \
    '--burp[shortcut for --proxy http://localhost:8080]' \
    '--no-proxy[disable proxy even if system proxy is set]' \
    '(-t --max-threads)'{-t+,--max-threads=}'[max number of request threads]:threads:_default' \
    '(-T --wordlist-split)'{-T+,--wordlist-split=}'[threads per folder/extension combo (default 3)]:count:_default' \
    '(-z --throttle)'{-z+,--throttle=}'[milliseconds between requests per thread]:ms:_default' \
    '--username=[basic auth username]:username:_users' \
    '--password=[basic auth password]:password:_default' \
    '(-r --disable-recursion)'{-r,--disable-recursion}'[disable discovered subdirectory scanning]' \
    '--max-recursion-depth=[maximum recursion depth (0 to disable)]:depth:_default' \
    '(-l --scan-listable)'{-l,--scan-listable}'[scan listable directories]' \
    '--scrape-listable[scrape URLs from listable directories]' \
    '*'{-c+,--cookie=}'[cookie name=value (repeatable)]:cookie:_default' \
    '*'{-H+,--header=}'[arbitrary HTTP header header:value]:header:_default' \
    '(-a --user-agent)'{-a+,--user-agent=}'[User-Agent string]:user agent:_default' \
    '*'{-v,--verbose}'[increase verbosity (use twice for full verbosity)]' \
    '(-S --silent)'{-S,--silent}'[suppress per-request output]' \
    '*'{-W+,--code-whitelist=}'[comma-separated response codes to allow only]:codes:_default' \
    '*'{-B+,--code-blacklist=}'[comma-separated response codes to hide]:codes:_default' \
    '--disable-validator[disable automatic detection of not-found codes]' \
    '--scan-401[scan folders even if they return 401 Unauthorized]' \
    '--scan-403[scan folders even if they return 403 Forbidden]' \
    '(-k --ignore-cert)'{-k,--ignore-cert}'[ignore HTTPS certificate validity]' \
    '--show-htaccess[show .ht items returning 403]' \
    '--timeout=[response timeout seconds (default 5)]:seconds:_default' \
    '--max-errors=[max errors before giving up (default 5; 0 disables)]:count:_default' \
    '--no-color[disable colored terminal output]' \
    '*--hide-lengths=[hide response lengths (e.g. 348,500-700)]:lengths:_default' \
    && ret=0

return ret
