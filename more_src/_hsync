#compdef hsync
# Documentation: https://github.com/monteslu/hsync
# hsync - expose local services through an hsync relay server

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --port)'{-p,--port}'=[port for local webserver]:port:' \
  '(-d --dynamic-host)'{-d,--dynamic-host}'=[host to get a dynamic connection from]:url:' \
  '(-s --hsync-server)'{-s,--hsync-server}'=[hsync-server location]:url:' \
  '(-hs --hsync-secret)'{-hs,--hsync-secret}'=[password to connect to hsync-server]:secret:' \
  '(-llp --listener-local-port)'{-llp,--listener-local-port}'=[local port to open for listener]:port:' \
  '(-lth --listener-target-host)'{-lth,--listener-target-host}'=[target host for listener]:host:' \
  '(-ltp --listener-target-port)'{-ltp,--listener-target-port}'=[target port for listener]:port:' \
  '(-rip --relay-inbound-port)'{-rip,--relay-inbound-port}'=[inbound port for remote relay requests]:port:' \
  '(-rth --relay-target-host)'{-rth,--relay-target-host}'=[target host for relay]:host:' \
  '(-rtp --relay-target-port)'{-rtp,--relay-target-port}'=[target port for relay]:port:' && ret=0

return ret
