#compdef caddy2
# Documentation: https://man.archlinux.org/search?q=caddy2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'adapt:adapt config from one format to another'
  'add-package:install plugin (xcaddy build)'
  'build-info:show build info'
  'completion:generate shell completion'
  'environ:print environment'
  'fmt:format a Caddyfile'
  'file-server:run a static file server'
  'hash-password:hash a password for the basicauth directive'
  'help:show help'
  'list-modules:list installed Caddy modules'
  'manpage:generate manpages'
  'remove-package:uninstall plugin (xcaddy build)'
  'reload:reload running config'
  'respond:run a basic responder'
  'reverse-proxy:run a reverse proxy'
  'run:run Caddy with a config'
  'start:start Caddy in background'
  'stop:stop running Caddy'
  'storage:storage operations'
  'trust:install root CA into local trust store'
  'untrust:remove root CA from local trust store'
  'upgrade:upgrade Caddy to latest version'
  'validate:validate config'
  'version:print version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'caddy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|start)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "Caddyfile* *.json *.yaml *.yml"' \
          '(-a --adapter)'{-a+,--adapter=}'[config adapter]:adapter:(caddyfile json yaml)' \
          '--envfile=[env file]:file:_files' \
          '--environ[print env on start]' \
          '--resume[resume from last config]' \
          '--watch[watch config for changes]' \
          '--pidfile=[pid file]:file:_files' \
          '--pingback=[notify URL on start]:url:' \
          '*: :' && ret=0 ;;
      (stop|reload)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "Caddyfile* *.json"' \
          '(-a --adapter)'{-a+,--adapter=}'[config adapter]:adapter:(caddyfile json)' \
          '--address=[admin API address]:addr:' \
          '*: :' && ret=0 ;;
      (adapt)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[adapter]:adapter:(caddyfile json yaml)' \
          '(-p --pretty)'{-p,--pretty}'[pretty-print output]' \
          '--validate[validate after adapt]' \
          '*: :_files' && ret=0 ;;
      (validate)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[adapter]:adapter:(caddyfile json yaml)' \
          '--envfile=[env file]:file:_files' \
          '*: :' && ret=0 ;;
      (fmt)
        _arguments \
          '(-w --overwrite)'{-w,--overwrite}'[overwrite source]' \
          '(-d --diff)'{-d,--diff}'[print diff]' \
          '*: :_files -g "Caddyfile*"' && ret=0 ;;
      (file-server)
        _arguments \
          '(-d --domain)'{-d+,--domain=}'[domain to serve over HTTPS]:domain:' \
          '(-r --root)'{-r+,--root=}'[root directory]:dir:_files -/' \
          '(-l --listen)'{-l+,--listen=}'[bind address]:addr:' \
          '--access-log[enable access log]' \
          '--browse[enable directory browsing]' \
          '--reveal-symlinks[reveal symlinks]' \
          '--templates[enable template engine]' \
          '*: :' && ret=0 ;;
      (reverse-proxy)
        _arguments \
          '(-f --from)'{-f+,--from=}'[upstream from]:addr:' \
          '(-t --to)'{-t+,--to=}'[upstream to]:addr:' \
          '--change-host-header[set Host header to upstream]' \
          '--insecure[skip TLS verify on upstream]' \
          '--internal-certs[use Caddy-issued internal certs]' \
          '--access-log[enable access log]' \
          '--debug[enable debug log]' \
          '--disable-redirects[disable HTTP-to-HTTPS redirects]' \
          '--header-down=[downstream header]:h:' \
          '--header-up=[upstream header]:h:' \
          '*: :' && ret=0 ;;
      (respond)
        _arguments \
          '(-s --status)'{-s+,--status=}'[HTTP status]:n:' \
          '(-H --header)*'{-H+,--header=}'[response header]:h:' \
          '(-l --listen)'{-l+,--listen=}'[bind address]:addr:' \
          '(-b --body)'{-b+,--body=}'[response body]:b:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*: :' && ret=0 ;;
      (hash-password)
        _arguments \
          '(-a --algorithm)'{-a+,--algorithm=}'[algorithm]:a:(bcrypt scrypt)' \
          '(-p --plaintext)'{-p+,--plaintext=}'[plaintext password]:p:' \
          '*: :' && ret=0 ;;
      (storage)
        _arguments '1:subcommand:(import export)' '*: :_files' && ret=0 ;;
      (trust|untrust)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
