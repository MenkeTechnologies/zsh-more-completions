#compdef hbase

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'shell:run interactive HBase shell'
  'hbck:HBase consistency check and repair'
  'hbck2:HBase 2.x consistency check and repair'
  'wal:write-ahead log inspection tool'
  'hfile:HFile format inspection'
  'snapshot:export and manage snapshots'
  'master:start HMaster server'
  'regionserver:start RegionServer'
  'thrift:start Thrift API server'
  'thrift2:start Thrift2 API server'
  'rest:start REST API server'
  'zookeeper:start standalone ZooKeeper'
  'zkcli:run ZooKeeper command-line client'
  'pe:performance evaluation tool'
  'ltt:LoadTestTool'
  'canary:cluster canary tool'
  'completebulkload:complete a bulk load operation'
  'copytable:copy a table to another cluster'
  'export:export a table to HDFS'
  'import:import a previously exported table'
  'importtsv:import TSV files into HBase'
  'verifyrep:verify replication'
  'classpath:dump HBase classpath'
  'mapredcp:dump MapReduce classpath'
  'pre-upgrade:pre-upgrade compatibility check'
  'replication:replication validation tool'
  'rowcounter:count rows in a table'
  'cellcounter:count cells in a table'
  'org.apache.hadoop.hbase.util.LoadIncrementalHFiles:bulk load'
  'org.apache.hadoop.hbase.util.HBaseFsckRepair:fsck repair'
  'version:print HBase version'
)

_arguments -C \
  '--config[Hadoop config dir]:dir:_files -/' \
  '--debug[debug output]' \
  '--loglevel[log level]:level:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--hosts[hosts file]:file:_files' \
  '--internal-classpath[use HBase internal classpath]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hbase subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (shell)
        _arguments \
          '-d[show debug-level messages]' \
          '-n[do not display banner]' \
          '--noninteractive[non-interactive mode]' \
          '--format=[output format]:format:(console html xml)' \
          '*:script file:_files' && ret=0
        ;;
      (hbck|hbck2)
        _arguments \
          '-h[show help]' \
          '-details[detailed report]' \
          '-summary[summary report]' \
          '-metaonly[metadata-only check]' \
          '-sidelineCorruptHFiles[sideline corrupt HFiles]' \
          '-checkCorruptHFiles[check corrupt HFiles]' \
          '-checkRegionBoundaries[check region boundaries]' \
          '-ignorePreCheckPermission[ignore permission pre-check]' \
          '-fix[fix issues]' \
          '-fixAssignments[fix region assignments]' \
          '-fixMeta[fix meta]' \
          '-fixHdfsHoles[fix HDFS holes]' \
          '-fixHdfsOrphans[fix HDFS orphans]' \
          '-fixHdfsOverlaps[fix HDFS overlaps]' \
          '-fixVersionFile[fix version file]' \
          '-fixReferenceFiles[fix reference files]' \
          '-fixHFileLinks[fix HFile links]' \
          '-fixEmptyMetaCells[fix empty meta cells]' \
          '-fixSplitParents[fix split parents]' \
          '-removeParents[remove parent regions]' \
          '-fixReplication[fix replication]' \
          '-noHdfsChecking[skip HDFS checking]' \
          '-timelag+[time lag (ms)]:ms:' \
          '-sleepBeforeRerun+[sleep before rerun (ms)]:ms:' \
          '-summary[summary report]' \
          '-exclusive[exclusive lock]' \
          '*:table:' && ret=0
        ;;
      (wal)
        _arguments \
          '-h[show help]' \
          '-p[print WAL]' \
          '-j[output as JSON]' \
          '-w[scan a single WAL file]' \
          '-r+[only show entries for region]:region:' \
          '-s+[scan path]:path:' \
          '*:WAL file:_files' && ret=0
        ;;
      (hfile)
        _arguments \
          '-h[show help]' \
          '-a[print all stats]' \
          '-b[print blocks]' \
          '-e[print key value]' \
          '-f+[file path]:file:_files' \
          '-r+[region]:region:' \
          '-k[print key only]' \
          '-m[print meta data]' \
          '-p[print key/value pairs]' \
          '-s[print stats]' \
          '-v[verbose]' \
          '-w+[width]:n:' && ret=0
        ;;
      (importtsv)
        _arguments \
          '-Dimporttsv.columns=[column mapping]:cols:' \
          '-Dimporttsv.skip.bad.lines=[skip bad lines]:flag:(true false)' \
          '-Dimporttsv.separator=[field separator]:sep:' \
          '-Dimporttsv.timestamp=[timestamp]:ts:' \
          '-Dimporttsv.bulk.output=[bulk output]:dir:' \
          '*:table file:' && ret=0
        ;;
      (export)
        _arguments \
          '*:table outputDir [versions [starttime [endtime]]]:' && ret=0
        ;;
      (import)
        _arguments \
          '*:table inputDir:' && ret=0
        ;;
      (canary)
        _arguments \
          '-help[show help]' \
          '-daemon[run as daemon]' \
          '-interval+[interval (ms)]:ms:' \
          '-e[regex namespaces]' \
          '-t+[timeout (ms)]:ms:' \
          '-writeSniffing[write sniffing]' \
          '-writeTable+[write table]:table:' \
          '-readTableTimeouts+[read timeouts]:timeouts:' \
          '-permittedZookeeperFailures+[permitted ZK failures]:n:' \
          '-allRegions[all regions]' \
          '-zookeeper[ZK monitor]' \
          '-regionserver[regionserver monitor]' \
          '*:table:' && ret=0
        ;;
      (pe)
        _arguments \
          '-h[show help]' \
          '--nomapred[do not use MapReduce]' \
          '--rows=[rows per client]:n:' \
          '--size=[total size]:gb:' \
          '--sampleRate=[sample rate]:rate:' \
          '--traceRate=[trace rate]:rate:' \
          '--table=[table name]:table:' \
          '--multiGet=[multi-get count]:n:' \
          '--compress=[compression]:codec:(NONE LZO GZ SNAPPY LZ4 BZIP2 ZSTD)' \
          '--encryption=[encryption]:type:(NONE AES)' \
          '--inMemoryEncoding=[in-memory encoding]:encoding:' \
          '--bloomFilter=[bloom filter type]:type:(NONE ROW ROWCOL)' \
          '--writeToWAL=[write to WAL]:flag:(true false)' \
          '--cacheBlocks=[cache blocks]:flag:(true false)' \
          '*:command:(filterScan increment append randomRead randomSeekScan randomWrite scan sequentialRead sequentialWrite scanRange10 scanRange100 scanRange1000 scanRange10000 checkAndDelete checkAndPut checkAndMutate)' && ret=0
        ;;
      (rowcounter)
        _arguments \
          '*:tablename [column [column ...]]:' && ret=0
        ;;
      (cellcounter)
        _arguments \
          '*:tablename outputDir [column [column ...]]:' && ret=0
        ;;
    esac
    ;;
esac

return ret
