#compdef findex
# Create an index for a column in a FITS table extension

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "column=[column to index]:" \
  "outfile=[output index file]:file:_files" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
