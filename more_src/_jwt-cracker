#compdef jwt-cracker
# Documentation: https://github.com/lmammino/jwt-cracker
# jwt-cracker - brute-force cracker for HS256-512 JWT tokens

local ret=1

_arguments -s -S \
  '-t[the JWT token string to crack]:token:' \
  '-a[character set (alphabet) for brute force]:alphabet:' \
  '--max[maximum string length during brute force]:length:' \
  '-d[path to dictionary file to use instead of brute force]:file:_files' \
  '-f[force script execution when token is not valid]' && ret=0

return ret
