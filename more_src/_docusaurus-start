#compdef docusaurus-start
# Documentation: https://www.npmjs.com/package/docusaurus
# Reference accessed: 2026-05-23
# Verified: unpkg docusaurus@1.14.7 lib/start-server.js.

# Zsh completion for docusaurus-start - Docusaurus v1 development server

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--port=[port number]:port:' \
  '--no-watch[disable live reload file watching]' \
  '--host=[host to bind]:host:_hosts' && ret=0

return ret
