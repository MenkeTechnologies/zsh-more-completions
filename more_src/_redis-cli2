#compdef redis-cli2
# Documentation: https://redis.io/docs/latest/develop/tools/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(--version)--version[show version]' \
  '-h+[host]:host:_hosts' \
  '-p+[port]:port:' \
  '-s+[unix socket]:file:_files' \
  '-a+[password]:p:' \
  '--user=[username]:u:_users' \
  '--pass=[password]:p:' \
  '--askpass[prompt password]' \
  '-u+[URI]:url:' \
  '--cluster=[cluster cmd]:c:(create check info fix reshard rebalance add-node del-node call set-timeout import backup help)' \
  '-c[cluster mode]' \
  '-e[exit on error]' \
  '-r+[repeat command]:n:' \
  '-i+[interval s]:s:' \
  '-x[read last arg from stdin]' \
  '-X+[set arg name from stdin]:n:' \
  '-d+[delimiter]:d:' \
  '-D+[delimiter for multibulk]:d:' \
  '-n+[db number]:n:' \
  '-3[RESP3 protocol]' \
  '-2[RESP2 protocol]' \
  '--cacert=[CA cert]:file:_files' \
  '--cacertdir=[CA dir]:dir:_files -/' \
  '--cert=[client cert]:file:_files' \
  '--key=[client key]:file:_files' \
  '--tls[use TLS]' \
  '--sni=[SNI]:s:' \
  '--insecure[insecure TLS]' \
  '--tls-ciphers=[ciphers]:c:' \
  '--tls-ciphersuites=[ciphersuites]:c:' \
  '-t+[timeout]:s:' \
  '--no-auth-warning[no auth warning]' \
  '--no-raw[no raw output]' \
  '--raw[raw output]' \
  '--csv[CSV output]' \
  '--json[JSON output]' \
  '--quoted-json[quoted JSON]' \
  '--show-pushes=[show pushes]:b:(yes no)' \
  '--no-cmds[no command list]' \
  '--scan[SCAN db]' \
  '--pattern=[keys pattern for --scan/--bigkeys/--memkeys/--hotkeys]:pattern:' \
  '--quoted-pattern=[same as --pattern, quoted]:pattern:' \
  '--count=[scan count]:n:' \
  '--quoted-input[quoted input]' \
  '--latency[continuous latency]' \
  '--latency-history[latency history]' \
  '--latency-dist[latency distribution]' \
  '--lru-test=[lru test n keys]:n:' \
  '--replica[connect as replica]' \
  '--rdb=[file]:file:_files' \
  '--functions-rdb=[file]:file:_files' \
  '--pipe[pipe mode]' \
  '--pipe-timeout=[pipe timeout]:s:' \
  '--bigkeys[scan big keys]' \
  '--memkeys[scan memory usage]' \
  '--memkeys-samples=[samples]:n:' \
  '--hotkeys[scan hot keys]' \
  '--stat[continuous stats]' \
  '--ldb[lua debugger]' \
  '--ldb-sync-mode[lua debugger sync]' \
  '--cluster-replicas=[replicas]:n:' \
  '--cluster-from=[migrate from]:n:' \
  '--cluster-to=[migrate to]:n:' \
  '--cluster-from-user=[user]:u:' \
  '--cluster-from-pass=[pass]:p:' \
  '--cluster-from-askpass[prompt]' \
  '--cluster-copy[copy mode]' \
  '--cluster-replace[replace mode]' \
  '--cluster-yes[auto-confirm]' \
  '--cluster-search-multiple-owners[multi owners]' \
  '--cluster-fix-with-unreachable-masters[fix with unreachable]' \
  '--cluster-only-masters[only masters]' \
  '--cluster-only-replicas[only replicas]' \
  '--cluster-use-empty-masters[use empty masters]' \
  '--cluster-pipeline=[pipeline]:n:' \
  '--cluster-threshold=[threshold]:n:' \
  '*: :' && ret=0

return ret
