#compdef znapzendzetup
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=znapzendzetup&sektion=1
# znapzendzetup: set up and manage znapzend backup plans on ZFS datasets

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable diagnostic output for troubleshooting]' \
  '--recursive[process datasets and their children hierarchically]' \
  '--inherited[include datasets that inherit a backup plan]' \
  '--mbuffer=[path to the mbuffer utility for network buffering]:path:_files' \
  '--mbuffersize=[buffer memory allocation (b|k|M|G)]:size' \
  '--features=[enable enhanced ZFS module features]:feature' \
  '--donotask[apply changes immediately without confirmation]' \
  '--tsformat=[snapshot naming format (strftime-like)]:format' \
  '--write[apply changes when importing]' \
  '--dst=[target a specific destination key]:key' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'create:create a backup configuration for a dataset'
      'delete:remove a backup configuration from a dataset'
      'edit:modify an existing dataset configuration'
      'enable:activate backup operations for a source dataset'
      'disable:deactivate backup operations for a source dataset'
      'enable-dst:enable an individual destination'
      'disable-dst:disable an individual destination'
      'enable-dst-autocreation:enable automatic destination dataset creation'
      'disable-dst-autocreation:disable automatic destination dataset creation'
      'list:display configured backup plans'
      'export:output the backup configuration for a dataset'
      'import:read configuration from a file or stdin'
    )
    _describe -t commands 'znapzendzetup command' cmds && ret=0
    ;;
esac

return ret
