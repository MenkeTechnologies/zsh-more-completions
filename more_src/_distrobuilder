#compdef distrobuilder
# _distrobuilder — system container-image builder for LXC and Incus (lxc/distrobuilder)
# upstream: https://github.com/lxc/distrobuilder
# Subcommands from distrobuilder/main*.go (cobra).

_distrobuilder() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a globals
    globals=(
        '--cleanup=[clean up working directory after the build]:bool:(true false)'
        '--cache-dir=[directory to use as a build cache]:dir:_files -/'
        '*'{-o+,--options=}'[image option (key=value, repeatable)]:option:'
        '(-t --timeout)'{-t+,--timeout=}'[build timeout in seconds]:seconds:'
        '--debug[enable debug output]'
        '--disable-overlay[disable the use of filesystem overlays]'
    )

    _arguments -C \
        $globals \
        '(- *)--version[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_distrobuilder_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build-lxc|pack-lxc)
                    _arguments $globals \
                        '--compression=[compression algorithm]:algo:(bzip2 gzip lzip lzma lzo lzop xz zstd)' \
                        '1:YAML image definition (or -):_files -g "*.(yaml|yml)"' \
                        '*:directories:_files -/' && ret=0 ;;
                build-incus|pack-incus)
                    _arguments $globals \
                        '--type=[image layout]:type:(split unified)' \
                        '--compression=[compression algorithm]:algo:(bzip2 gzip lzip lzma lzo lzop xz zstd)' \
                        '--import-into-incus[import the resulting image into Incus]' \
                        '1:YAML image definition (or -):_files -g "*.(yaml|yml)"' \
                        '*:directories:_files -/' && ret=0 ;;
                build-dir)
                    _arguments $globals \
                        '1:YAML image definition:_files -g "*.(yaml|yml)"' \
                        '2:target directory:_files -/' && ret=0 ;;
                repack-windows)
                    _arguments $globals \
                        '--drivers=[VirtIO driver ISO]:file:_files -g "*.iso"' \
                        '--name=[output image name]:name:' \
                        '1:source ISO:_files -g "*.iso"' \
                        '2:target ISO:_files -g "*.iso"' && ret=0 ;;
                validate)
                    _arguments $globals \
                        '1:YAML image definition:_files -g "*.(yaml|yml)"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_distrobuilder_commands] )) ||
_distrobuilder_commands() {
    local -a commands
    commands=(
        'build-lxc:build an LXC image from a YAML image definition'
        'pack-lxc:create an LXC image from an existing rootfs'
        'build-incus:build an Incus image from a YAML image definition'
        'pack-incus:create an Incus image from an existing rootfs'
        'build-dir:build a directory tree (rootfs) from a YAML image definition'
        'repack-windows:repack a Windows ISO with VirtIO drivers'
        'validate:validate a YAML image definition'
    )
    _describe -t commands 'distrobuilder command' commands
}

_distrobuilder "$@"
