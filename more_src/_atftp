#compdef atftp

# Zsh completion for atftp (advanced TFTP client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--get[get file]:remote file' \
  '--put[put file]:local file:_files' \
  '--mget[get multiple files]:remote files' \
  '--mput[put multiple files]:local files:_files' \
  '--option[set TFTP option]:option (e.g. blksize 1024)' \
  '--server-port[server port]:port' \
  '--local-port[local port]:port' \
  '--password[set password]:password' \
  '--verbose[verbose output]' \
  '--trace[trace packets]' \
  '--no-source-port-checking[disable source port checking]' \
  '--prevent-sas[prevent server address spoofing]' \
  '--mtftp[use multicast TFTP]:ip\:port' \
  '--delay[delay between packets]:microseconds' \
  '--tftp-timeout[TFTP timeout]:seconds' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:host:_hosts' && ret=0

return ret
