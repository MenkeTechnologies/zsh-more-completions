#compdef llvm-ml64
# Documentation: https://llvm.org/docs/CommandGuide/
# LLVM MASM assembler (64-bit, ml64.exe compatible)

local ret=1

_arguments -s \
  '/?[display available options]' \
  '/help[display available options]' \
  '/c[assemble only; do not link]' \
  '/D[define macro to value]:macro=value' \
  '/Fo[name the output file]:output:_files' \
  '/I[set path for include files]:include dir:_files -/' \
  '/safeseh[mark object files for safe exception handling (32-bit only)]' \
  '/Ta[assemble source file with the given name]:source:_files' \
  '/X[ignore the INCLUDE environment variable]' \
  '/Zs[run a syntax-check only]' \
  '--as-lex[lex tokens from a file without assembling]' \
  '--fatal-warnings[treat warnings as errors]' \
  '--filetype=[emit a file with the given type]:type:(asm null obj)' \
  '--output-att-asm[use AT&T syntax for output assembly]' \
  '--preserve-comments[preserve comments in output assembly]' \
  '--print-imm-hex[prefer hex format for immediate values]' \
  '--save-temp-labels[do not discard temporary labels]' \
  '--show-encoding[show instruction encodings in output assembly]' \
  '--show-inst-operands[show instruction operands as parsed]' \
  '--show-inst[show internal instruction representation]' \
  '--timestamp=[specify the assembly timestamp]:value' \
  '--utc[render @Date and @Time built-ins in GMT/UTC]' \
  '*:source file:_files' && ret=0

return ret
