#compdef conan
# _conan — JFrog Conan C/C++ package manager v2 CLI (JFrog / Conan Center, Python); custom argparse
# upstream: https://github.com/conan-io/conan

_conan() {
    local -a sub=(
        'audit:audit dependency vulnerabilities'
        'build:build conanfile'
        'cache:cache commands'
        'config:config commands'
        'create:create package'
        'download:download package'
        'editable:editable mode'
        'export:export recipe'
        'export-pkg:export pre-built package'
        'graph:graph commands'
        'inspect:inspect recipe'
        'install:install dependencies'
        'list:list references'
        'lock:lockfile commands'
        'new:scaffold recipe'
        'pkglist:package list helpers'
        'profile:profile commands'
        'remote:remote commands'
        'remove:remove package'
        'report:generate reports'
        'search:search package'
        'source:run source step'
        'test:test package recipe'
        'upload:upload to remote'
        'version:show version'
        'workspace:workspace commands'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose=+[verbosity]:level:(quiet error warning notice status info trace debug verbose vverbose vvverbose)' \
        '-vv[verbose level 2]' \
        '-vvv[verbose level 3]' \
        '--logger[use logger]' \
        '--core-conf=+[core conf]:list:' \
        '-cc+[core conf]:list:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conan subcommand' sub ;;
        args)
            case $words[1] in
                install|create|build|export|export-pkg|test|source) _arguments \
                    '--name=+[reference name]:str:' \
                    '--version=+[reference version]:str:' \
                    '--user=+[user]:str:' \
                    '--channel=+[channel]:str:' \
                    '--remote=+[remote]:str:' \
                    '-r+[remote]:str:' \
                    '--no-remote[no remote]' \
                    '-nr[no remote]' \
                    '--update[update]' \
                    '-u[update]' \
                    '--profile=+[profile]:list:' \
                    '-pr+[profile]:list:' \
                    '--profile:host=+[host profile]:list:' \
                    '--profile:build=+[build profile]:list:' \
                    '-pr:h+[host profile]:list:' \
                    '-pr:b+[build profile]:list:' \
                    '--settings=+[setting]:list:' \
                    '-s+[setting]:list:' \
                    '--options=+[option]:list:' \
                    '-o+[option]:list:' \
                    '--conf=+[conf]:list:' \
                    '-c+[conf]:list:' \
                    '--build=+[build mode]:b:(missing never always cascade)' \
                    '-b+[build mode]:b:(missing never always cascade)' \
                    '--lockfile=+[lockfile]:file:_files' \
                    '-l+[lockfile]:file:_files' \
                    '--lockfile-out=+[lockfile out]:file:_files' \
                    '--lockfile-partial[lockfile partial]' \
                    '--lockfile-clean[lockfile clean]' \
                    '--lockfile-overrides=+[lockfile overrides]:file:_files' \
                    '--format=+[output format]:fmt:(json html compact deps_info)' \
                    '-f+[output format]:fmt:(json html compact deps_info)' \
                    '--out-file=+[output file]:file:_files' \
                    '*:reference:_files' ;;
                remove|search|list|inspect|upload|download) _arguments \
                    '--remote=+[remote]:str:' \
                    '-r+[remote]:str:' \
                    '--package-query=+[query]:str:' \
                    '-p+[query]:str:' \
                    '--confirm[confirm]' \
                    '-c[confirm]' \
                    '--graph[print graph]' \
                    '--dry-run[dry run]' \
                    '--metadata=+[metadata]:list:' \
                    '*:reference:' ;;
                config) _arguments \
                    '1:cmd:(home install list reset show home)' \
                    '*:arg:' ;;
                profile) _arguments \
                    '1:cmd:(detect list new path show)' \
                    '*:arg:' ;;
                remote) _arguments \
                    '1:cmd:(add auth disable enable list list-users login logout remove rename set-user update)' \
                    '*:arg:' ;;
                cache) _arguments \
                    '1:cmd:(backup-upload clean path save restore)' \
                    '*:arg:' ;;
                lock) _arguments \
                    '1:cmd:(add create merge remove update)' \
                    '*:arg:' ;;
                workspace) _arguments \
                    '1:cmd:(add init install root open)' \
                    '*:arg:' ;;
                new) _arguments \
                    '*:template:' ;;
            esac
            ;;
    esac
}

_conan "$@"
