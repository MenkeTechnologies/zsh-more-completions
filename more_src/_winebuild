#compdef winebuild
# Wine DLL/EXE build tool

local ret=1

_arguments -s -S \
  '--dll[build a DLL]' \
  '--exe[build an EXE]' \
  '--def[build a .def file]' \
  '--implib[build an import library]' \
  '-d[delay-load DLL]:DLL name:' \
  '-D[define preprocessor symbol]:symbol:' \
  '-e[specify entry point]:entry point:' \
  '-E[specify .spec or .def file]:file:_files -g "*.(spec|def)"' \
  '-f[specify compiler flag]:flag:' \
  '-F[specify output file name]:name:' \
  '-i[ignore unresolved symbols]' \
  '-I[specify include path]:directory:_files -/' \
  '-k[kill-at (remove @nn)]' \
  '-K[specify compiler flag]:flag:' \
  '-l[link library]:library:' \
  '-L[specify library path]:directory:_files -/' \
  '-m[specify architecture]:arch:(32 64 arm arm64)' \
  '-M[generate Makefile rules]' \
  '-N[set DLL name]:name:' \
  '-o[specify output file]:file:_files' \
  '-r[specify resource file]:file:_files -g "*.res"' \
  '-u[add undefined symbol]:symbol:' \
  '-v[verbose mode]' \
  '-w[suppress warnings]' \
  '--as-cmd=[specify assembler]:assembler:_command_names -e' \
  '--cc-cmd=[specify C compiler]:compiler:_command_names -e' \
  '--ld-cmd=[specify linker]:linker:_command_names -e' \
  '--nm-cmd=[specify nm]:nm:_command_names -e' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:source files:_files -g "*.(c|o|spec|def|res)"' && ret=0

return ret
