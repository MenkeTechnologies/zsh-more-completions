#compdef topmorph
# generate insertion rules from frequent character chains in a dictionary

local ret=1

_arguments -s -S \
  '1:dictionary:_files' \
  '2:depth (top N frequent chains):' \
  '3:width (max chain length per rule):' \
  '4:pos_min (earliest insertion position):' \
  '5:pos_max (latest insertion position):' && ret=0

return ret
