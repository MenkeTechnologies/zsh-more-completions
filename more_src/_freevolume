#compdef freevolume gmx-freevolume
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-freevolume.html
# gmx freevolume: calculate free volume

local ret=1

_arguments -s \
  '-f[input trajectory or single configuration]:file:_files' \
  '-s[input structure]:file:_files' \
  '-n[extra index groups]:file:_files' \
  '-o[computed free volume]:file:_files' \
  '-b[first frame (ps) to read]:time:' \
  '-e[last frame (ps) to read]:time:' \
  '-dt[only use frame if t MOD dt == first time (ps)]:time:' \
  '-tu[unit for time values]:unit:(fs ps ns us ms s)' \
  '-fgroup[atoms stored in trajectory file]:selection:' \
  '-xvg[plot formatting]:format:(xmgrace xmgr none)' \
  '-rmpbc[make molecules whole for each frame]' \
  '-sf[provide selections from files]:file:_files' \
  '-selrpos[selection reference positions]:enum:' \
  '-select[atoms considered as part of excluded volume]:selection:' \
  '-radius[radius of probe to be inserted (nm)]:real:' \
  '-seed[seed for random number generator]:int:' \
  '-ninsert[probe insertions per cubic nm per frame]:int:' && ret=0

return ret
