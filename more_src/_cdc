#compdef cdc
# _cdc — TiCDC (TiDB Change Data Capture) server / CLI (pingcap/tiflow)
# upstream: https://github.com/pingcap/tiflow
# Subcommands from pkg/cmd/cmd.go (cobra).

_cdc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_cdc_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                server)
                    _arguments \
                        '--addr=[bind address (default 127.0.0.1:8300)]:addr:' \
                        '--advertise-addr=[advertised address]:addr:' \
                        '--pd=[PD endpoints (comma-separated)]:urls:' \
                        '--data-dir=[runtime data directory]:dir:_files -/' \
                        '--log-file=[log file path]:file:_files' \
                        '--log-level=[log level]:level:(debug info warn error)' \
                        '--gc-ttl=[GC TTL in seconds]:seconds:' \
                        '--cert=[TLS certificate path]:file:_files -g "*.pem"' \
                        '--key=[TLS private key path]:file:_files -g "*.pem"' \
                        '--ca=[TLS CA path]:file:_files -g "*.pem"' \
                        '--cluster-id=[cluster id]:id:' && ret=0 ;;
                cli)
                    _arguments \
                        '1: :_cdc_cli_commands' \
                        '--pd=[PD endpoints (comma-separated)]:urls:' \
                        '--server=[CDC server URL]:url:' \
                        '*::cli arg:_files' && ret=0 ;;
                redo)
                    _arguments \
                        '1: :(apply meta)' \
                        '--storage=[redo log storage URI]:uri:' \
                        '--tmp-dir=[temporary directory]:dir:_files -/' && ret=0 ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cdc_commands] )) ||
_cdc_commands() {
    local -a commands
    commands=(
        'server:run the TiCDC server'
        'cli:TiCDC CLI for capture / changefeed / processor / tso / unsafe'
        'redo:apply / inspect redo logs'
        'version:print version information'
    )
    _describe -t commands 'cdc command' commands
}

(( $+functions[_cdc_cli_commands] )) ||
_cdc_cli_commands() {
    local -a commands
    commands=(
        'capture:manage CDC captures'
        'changefeed:manage CDC changefeeds (create / list / pause / resume / remove / query / update)'
        'processor:manage / inspect CDC processors'
        'tso:print or query a TSO from PD'
        'unsafe:unsafe operations for advanced operators'
    )
    _describe -t commands 'cdc cli command' commands
}

_cdc "$@"
