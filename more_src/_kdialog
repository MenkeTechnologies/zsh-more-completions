# Zsh completion for kdialog - KDE dialog utility

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  '--msgbox[display message box]:text' \
  '--sorry[display sorry message]:text' \
  '--detailedsorry[display detailed sorry message]:text:details' \
  '--error[display error message]:text' \
  '--detailederror[display detailed error message]:text:details' \
  '--warningyesno[display warning with yes/no buttons]:text' \
  '--warningcontinuecancel[display warning with continue/cancel buttons]:text' \
  '--warningyesnocancel[display warning with yes/no/cancel buttons]:text' \
  '--yesno[display yes/no dialog]:text' \
  '--yesnocancel[display yes/no/cancel dialog]:text' \
  '--inputbox[display input box]:text:default value' \
  '--imgbox[display image box]:file:_files' \
  '--imginputbox[display image input box]:file:_files' \
  '--password[display password dialog]:text' \
  '--newpassword[display new password dialog]:text' \
  '--textbox[display text box]:file:_files' \
  '--textinputbox[display text input box]:text:initial text' \
  '--combobox[display combo box]:text:items' \
  '--menu[display menu]:text:items' \
  '--checklist[display checklist]:text:items' \
  '--radiolist[display radio list]:text:items' \
  '--passivepopup[display passive popup]:text:timeout (seconds)' \
  '--getopenfilename[display open file dialog]:start directory:_directories' \
  '--getsavefilename[display save file dialog]:start directory:_directories' \
  '--getexistingdirectory[display directory dialog]:start directory:_directories' \
  '--getopenurl[display open URL dialog]:start directory' \
  '--getsaveurl[display save URL dialog]:start directory' \
  '--geticon[display icon chooser]' \
  '--progressbar[display progress bar]:text:max value' \
  '--slider[display slider]:text' \
  '--calendar[display calendar]:text' \
  '--title[set dialog title]:title' \
  '--default[set default value]:default' \
  '--multiple[allow multiple selections]' \
  '--separate-output[output selected items separately]' \
  '--print-winid[print window ID on stdout]' \
  '--embed[embed dialog in given window]:window ID' \
  '--dontagain[do not show again configuration]:config file:entry' \
  '--geometry[set dialog geometry]:WxH+X+Y'
