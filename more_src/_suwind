#compdef suwind
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/suwind.c
# SUWIND - window traces by key word

local ret=1

_arguments -s -S \
  'verbose=[=1 for verbose]:v:(0 1)' \
  'key=[key header word to window on]:key:' \
  'min=[min value of key header word to pass]:min:' \
  'max=[max value of key header word to pass]:max:' \
  'abs=[=1 to take absolute value of key]:a:(0 1)' \
  'j=[pass every j-th trace]:j:' \
  's=[base for j (if ((key - s)%j)==0)]:s:' \
  'skip=[skip the initial N traces]:n:' \
  'count=[pass up to count traces]:c:' \
  'reject=[skip traces with these key values]:r:' \
  'accept=[pass traces with these key values]:a:' \
  'ordered=[=1 increasing, =-1 decreasing keyword]:o:(0 1 -1)' \
  'dt=[time sampling interval (sec)]:dt:' \
  'f1=[first sample]:f1:' \
  'tmin=[min time to pass]:tmin:' \
  'tmax=[max time to pass]:tmax:' \
  'itmin=[min time sample to pass]:i:' \
  'itmax=[max time sample to pass]:i:' \
  'nt=[number of time samples to pass]:n:' \
  '*:SU file:_files' && ret=0

return ret
