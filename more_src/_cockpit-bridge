#compdef cockpit-bridge
# Documentation: https://man.archlinux.org/search?q=cockpit-bridge
# Reference accessed: 2026-05-16

# cockpit-bridge: per-user backend bridge for Cockpit web console
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--packages[list installed Cockpit packages]' \
  '--bridges[list available bridges]' \
  '--privileged[run as privileged bridge]' \
  '--rules[print known channel rules]' \
  '--interact=[interactive prompt mode]:tag:' \
  '*::extra args:_files' && ret=0
return ret
