#compdef cockpit-bridge

# cockpit-bridge: Cockpit per-user bridge (D-Bus / system ops)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--privileged[run as privileged user]' \
  '--rules[list cockpit-bridge rules]' \
  '--packages[list cockpit packages]' \
  '--bridges[list configured bridges]' \
  '--interact=[run interactive control channel]:protocol:' \
  '*::cockpit-bridge args:_files' && ret=0
return ret
