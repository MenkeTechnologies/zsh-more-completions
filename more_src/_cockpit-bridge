#compdef cockpit-bridge
# Documentation: https://cockpit-project.org/guide/latest/cockpit-bridge.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cockpit-bridge: per-user backend bridge for Cockpit web console

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help options]' \
  '--version[show Cockpit version information]' \
  '--packages[list all available Cockpit packages and exit]' \
  '--interact=[interact with raw cockpit1 protocol (boundary)]:boundary:' \
  '*::extra args:_files' && ret=0
return ret
