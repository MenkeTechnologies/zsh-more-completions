#compdef dmlist
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmlist.html
# List the contents of a Data Model file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input virtual file specification]:infile:_files' \
  'opt=[options to display]:opt:(blocks keys comments cols subspace data header struct full array all clean raw)' \
  'outfile=[output ASCII file]:outfile:_files' \
  'rows=[range of table rows to print min:max]:rows:' \
  'cells=[range of array indices to print]:cells:' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
