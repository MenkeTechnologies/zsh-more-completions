#compdef api-documenter
# _api-documenter — generate API reference from api-extractor JSON (microsoft/rushstack)
# upstream: https://github.com/microsoft/rushstack/tree/main/apps/api-documenter
# Subcommands from apps/api-documenter/src/cli/.

_api-documenter() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'markdown:render API docs as Markdown'
                'yaml:render API docs as Docusaurus / DocFX YAML'
                'generate:render API docs using a user template'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments \
                '(-i --input-folder)'{-i+,--input-folder=}'[input folder with .api.json files]:dir:_files -/' \
                '(-o --output-folder)'{-o+,--output-folder=}'[output folder]:dir:_files -/'
            ;;
    esac
}

_api-documenter "$@"
