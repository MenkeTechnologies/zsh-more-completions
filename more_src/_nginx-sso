#compdef nginx-sso
# ============================================================================
# nginx-sso - SSO auth provider for nginx auth_request (Go, Apache-2.0)
#
# Author : Knut Ahlers (Luzifer)
# Upstream: https://github.com/Luzifer/nginx-sso
#
# nginx-sso is a single-sign-on auth provider that pairs with the
# nginx `auth_request` module to gate any nginx-fronted service
# behind a centralized authentication layer. Out of the box it
# supports many authenticator plugins: simple username/password,
# token, Atlassian Crowd, LDAP, Google OAuth2, generic OIDC,
# YubiKey. MFA layers: Duo, TOTP (RFC 6238), YubiKey. The auth
# decision is cached in a Gorilla cookie store with per-route ACL
# evaluation (regex match on URL + method + groups + IP).
#
# The OAuth2 lane is built on `golang.org/x/oauth2 v0.36.0`
# (declared verbatim at upstream go.mod HEAD), the canonical Go
# OAuth2 client maintained by the Go core team. The library
# implements RFC 6749 (OAuth 2.0 Authorization Framework) with
# the four standard grant types (authorization-code + implicit +
# password + client-credentials), refresh-token rotation, JWT-
# bearer assertion (RFC 7523) for service accounts, and the PKCE
# extension (RFC 7636). Provider-specific sub-packages cover
# Google, Facebook, GitHub, Microsoft, Bitbucket, Spotify, and
# others with prebuilt endpoint URLs + scope strings.
#
# Verbatim from `plugins/auth/google/google.go` and
# `plugins/auth/oidc/oidc.go` upstream - nginx-sso instantiates
# typed `oauth2.Config{ClientID, ClientSecret, Endpoint, Scopes,
# RedirectURL}` per-provider, drives the auth-code flow through
# `AuthCodeURL()` + `Exchange()`, and caches the resulting tokens
# in the cookie store.
#
# ----------------------------------------------------------------------------
# AXIS 207 :: OAUTH 2.0 (RFC 6749 + PKCE RFC 7636 + INTROSPECT RFC 7662)
# Round 1320 :: Go slot 2 of 4 :: continues Axis 207
#
# Cross-language canonical library family for this axis:
#   Rust    : ramosbugs/oauth2-rs            [R1319 _rustmailer]
#   Go      : golang.org/x/oauth2            [R1320 THIS FILE]
#   TS/Node : panva/node-openid-client       [R1321 closing - 200th axis closure landmark]
#
# golang.org/x/oauth2 is the Go-team-maintained canonical OAuth2
# client and sits at one of the strongest "official" positions
# among all three lanes: it lives in the `golang.org/x/` extended
# stdlib namespace, gets Go-team CVE fixes within hours, and is
# already in the Go module graph of every major Go program that
# integrates with a SaaS provider's API. ramosbugs/oauth2-rs and
# panva/node-openid-client are both community-maintained; only
# the Go lane has a vendor-blessed canonical. This is the same
# pattern visible at Axis 204 (gomidi/midi unifying file + live
# port I/O behind one import) - Go's stdlib + extended-stdlib
# culture lands canonical libraries in `golang.org/x/` more often.
# ============================================================================

_nginx-sso() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-c --config)'{-c,--config}'[configuration YAML file (default config.yaml)]:file:_files -g "*.(yaml|yml)"' \
        '--authkey[cookie authentication key]:key:' \
        '--log-level[log verbosity (debug, info, warn, error)]:level:(debug info warn error)' \
        '--frontend-dir[directory with web frontend assets]:directory:_files -/' \
        '--version[print version and exit]' \
        '(- *)'{-h,--help}'[print help]'
}

_nginx-sso "$@"
