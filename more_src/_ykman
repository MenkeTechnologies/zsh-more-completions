#compdef ykman

local curcontext="$curcontext" state line ret=1

_ykman_commands() {
  local -a commands=(
    'config:enable or disable applications'
    'fido:manage the FIDO applications'
    'info:show general information'
    'list:list connected YubiKeys'
    'oath:manage the OATH application'
    'openpgp:manage the OpenPGP application'
    'otp:manage the OTP application'
    'piv:manage the PIV application'
    'script:run a python script'
  )
  _describe -t commands 'ykman command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d,--device}'=[specify YubiKey by serial number]:serial' \
  '(-r --reader)'{-r,--reader}'=[specify smart card reader]:reader' \
  '-l[list available readers]' \
  '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--log-file=[write logs to file]:file:_files' \
  '--diagnose[show diagnostics information]' \
  '1: :_ykman_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      oath)
        local -a oath_cmds=(
          'accounts:manage OATH accounts'
          'access:manage access to the OATH application'
          'code:generate OTP codes'
          'delete:delete an account'
          'info:display general status'
          'list:list all accounts'
          'reset:reset the OATH application'
        )
        _describe -t oath-commands 'oath command' oath_cmds
        ;;
      otp)
        local -a otp_cmds=(
          'calculate:perform a challenge-response operation'
          'chalresp:program a challenge-response credential'
          'delete:delete the configuration of a slot'
          'hotp:program an HMAC-SHA1 OATH-HOTP credential'
          'info:display general status'
          'settings:update the settings for a slot'
          'static:configure a static password'
          'swap:swap the two slot configurations'
          'yubiotp:program a Yubico OTP credential'
        )
        _describe -t otp-commands 'otp command' otp_cmds
        ;;
      fido)
        local -a fido_cmds=(
          'access:manage the PIN for FIDO'
          'config:manage FIDO configuration'
          'credentials:manage discoverable credentials'
          'fingerprints:manage fingerprints'
          'info:display general status'
          'reset:reset the FIDO applications'
          'verify-pin:verify the FIDO PIN'
        )
        _describe -t fido-commands 'fido command' fido_cmds
        ;;
      piv)
        local -a piv_cmds=(
          'access:manage PIN, PUK, and management key'
          'certificates:manage certificates'
          'info:display general status'
          'keys:manage keys'
          'objects:manage PIV objects'
          'reset:reset the PIV application'
        )
        _describe -t piv-commands 'piv command' piv_cmds
        ;;
      openpgp)
        local -a openpgp_cmds=(
          'access:manage PINs for OpenPGP'
          'certificates:manage certificates'
          'info:display general status'
          'keys:manage keys'
          'reset:reset the OpenPGP application'
        )
        _describe -t openpgp-commands 'openpgp command' openpgp_cmds
        ;;
      config)
        _arguments -s -S \
          '--enable=[enable an application]:app:(OTP U2F FIDO2 OATH PIV OPENPGP HSMAUTH)' \
          '--disable=[disable an application]:app:(OTP U2F FIDO2 OATH PIV OPENPGP HSMAUTH)' \
          '--enable-all[enable all applications]' \
          '--list[list enabled applications]' \
          '--lock-code=[set a lock code]:code' \
          '--nfc[configure NFC interface]' \
          '--usb[configure USB interface]' \
          '-f[confirm without prompting]' \
          '--force[confirm without prompting]' && ret=0
        ;;
    esac
    ;;
esac

return ret
