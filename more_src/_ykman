#compdef ykman
# Documentation: https://docs.yubico.com/software/yubikey/tools/ykman/Using_the_ykman_CLI.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (Base_Commands.html).

local curcontext="$curcontext" state line ret=1

_ykman_commands() {
  local -a commands=(
    'apdu:run APDU commands'
    'config:enable or disable applications'
    'fido:manage the FIDO applications'
    'hsmauth:manage YubiHSM Auth application'
    'info:show general information'
    'list:list connected YubiKeys'
    'oath:manage the OATH application'
    'openpgp:manage the OpenPGP application'
    'otp:manage the OTP application'
    'piv:manage the PIV application'
    'script:run a python script'
    'securitydomain:manage Security Domain'
  )
  _describe -t commands 'ykman command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d,--device}'=[YubiKey serial number]:serial' \
  '(-r --reader)'{-r,--reader}'=[smart card reader name]:reader' \
  '(-l --log-level)'{-l,--log-level}'=[log level]:level:(error warning info debug traffic)' \
  '--log-file=[write log to file]:file:_files' \
  '--diagnose[show diagnostics information]' \
  '--full-help[show extended help including hidden commands]' \
  '(-s --scp)'{-s,--scp}'=[SCP private key and cert chain]:cred' \
  '(-p --scp-password)'{-p,--scp-password}'=[SCP password]:password' \
  '(-t --scp-ca)'{-t,--scp-ca}'=[SCP11 CA file]:file:_files' \
  '1: :_ykman_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      oath)
        local -a oath_cmds=(
          'accounts:manage OATH accounts'
          'access:manage access to OATH'
          'info:display general status'
          'reset:reset OATH application'
        )
        _describe -t oath-commands 'oath command' oath_cmds
        ;;
      otp)
        local -a otp_cmds=(
          'calculate:perform challenge-response'
          'chalresp:program challenge-response credential'
          'delete:delete slot configuration'
          'hotp:program OATH-HOTP credential'
          'info:display general status'
          'settings:update slot settings'
          'static:configure static password'
          'swap:swap slot configurations'
          'yubiotp:program Yubico OTP credential'
        )
        _describe -t otp-commands 'otp command' otp_cmds
        ;;
      fido)
        local -a fido_cmds=(
          'access:manage FIDO PIN'
          'config:manage FIDO configuration'
          'credentials:manage discoverable credentials'
          'fingerprints:manage fingerprints'
          'info:display general status'
          'reset:reset FIDO applications'
        )
        _describe -t fido-commands 'fido command' fido_cmds
        ;;
      piv)
        local -a piv_cmds=(
          'access:manage PIN, PUK, management key'
          'certificates:manage certificates'
          'info:display general status'
          'keys:manage keys'
          'objects:manage PIV objects'
          'reset:reset PIV application'
        )
        _describe -t piv-commands 'piv command' piv_cmds
        ;;
      openpgp)
        local -a openpgp_cmds=(
          'access:manage PINs for OpenPGP'
          'certificates:manage certificates'
          'info:display general status'
          'keys:manage keys'
          'reset:reset OpenPGP application'
        )
        _describe -t openpgp-commands 'openpgp command' openpgp_cmds
        ;;
      config)
        _arguments -s -S \
          '--enable=[enable an application]:app:(OTP U2F FIDO2 OATH PIV OPENPGP HSMAUTH)' \
          '--disable=[disable an application]:app:(OTP U2F FIDO2 OATH PIV OPENPGP HSMAUTH)' \
          '--list[list enabled applications]' \
          '--lock-code=[set a lock code]:code' \
          '(-f --force)'{-f,--force}'[confirm without prompting]' && ret=0
        ;;
    esac
    ;;
esac

return ret
