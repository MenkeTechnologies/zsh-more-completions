#compdef grdinfo
# Documentation: https://docs.generic-mapping-tools.org/latest/grdinfo.html
# Source: GenericMappingTools/gmt classic-mode grdinfo — print summary information about a grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[tab-separated single-line report]' \
    '-D+[tile the grid domain (optional overlap)]:opts:_default' \
    '-E+[extreme values per column or row]:axis:_default' \
    '-F[domain + increments in world-mapping format]' \
    '-G[download all tiles of remote grids first]' \
    '-I+[min/max rounded to multiple, or grid inc]:opts:_default' \
    '-L+[statistical report]:stat:(0 1 2 a)' \
    '-M[find min/max locations + NaN count]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T+[min/max data values (with optional rounding)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-o+[output column selection]:cols:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
