#compdef models
# Documentation: https://man.archlinux.org/search?q=models
# Reference accessed: 2026-05-16

# Zsh completion for models (github.com/arimxyer/models — AI model browser)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--no-color[disable color]' \
  '*:: :_files' && ret=0

return ret
