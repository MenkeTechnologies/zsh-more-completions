#compdef nvidia-docker
# Documentation: https://man.archlinux.org/search?q=nvidia-docker
# Reference accessed: 2026-05-16

# nvidia-docker: legacy CLI wrapper around docker exposing NVIDIA GPUs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::docker args:_files' && ret=0
return ret
