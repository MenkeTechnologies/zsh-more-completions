#compdef keyctl

# Zsh completion for keyctl (Linux key management facility control)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:Add a key to the keyring'
  'padd:Add a key to the keyring (from stdin)'
  'request:Request a key from the kernel'
  'request2:Request a key with callout info'
  'prequest2:Request a key with callout info (from stdin)'
  'update:Update a key'
  'pupdate:Update a key (from stdin)'
  'newring:Create a new keyring'
  'revoke:Revoke a key'
  'clear:Clear a keyring'
  'link:Link a key to a keyring'
  'unlink:Unlink a key from a keyring'
  'search:Search a keyring'
  'restrict_keyring:Apply a restriction to a keyring'
  'read:Read a key'
  'pipe:Read a key (raw to stdout)'
  'print:Read a key (printable)'
  'list:List the contents of a keyring'
  'rlist:List the contents of a keyring (recursive)'
  'describe:Describe a key'
  'rdescribe:Describe a key (raw format)'
  'chown:Change key ownership'
  'chgrp:Change key group'
  'setperm:Set key permissions'
  'session:Start a new session keyring'
  'instantiate:Instantiate a key'
  'pinstantiate:Instantiate a key (from stdin)'
  'negate:Negate a key'
  'reject:Reject a key'
  'timeout:Set a key timeout'
  'security:Get key security info'
  'reap:Reap revoked/expired keys'
  'purge:Purge matching keys from a keyring'
  'invalidate:Invalidate a key'
  'show:Show keys in session keyring tree'
  'watch:Watch for key changes'
  'watch_add:Add a watch on a key'
  'watch_rm:Remove a watch on a key'
  'watch_session:Watch for session keyring changes'
  'watch_key:Watch a specific key'
)

_arguments -s -S -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'keyctl command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add|padd)
        _arguments '1:type:(user keyring logon big_key)' '2:description' '3:data' '4:keyring' && ret=0
        ;;
      newring)
        _arguments '1:name' '2:keyring' && ret=0
        ;;
      revoke|invalidate|read|pipe|print|describe|rdescribe|list|rlist|clear|security)
        _arguments '1:key' && ret=0
        ;;
      link|unlink)
        _arguments '1:key' '2:keyring' && ret=0
        ;;
      chown)
        _arguments '1:key' '2:uid' && ret=0
        ;;
      chgrp)
        _arguments '1:key' '2:gid' && ret=0
        ;;
      setperm)
        _arguments '1:key' '2:mask' && ret=0
        ;;
      timeout)
        _arguments '1:key' '2:timeout (seconds)' && ret=0
        ;;
      search)
        _arguments '1:keyring' '2:type' '3:description' '4:destination keyring' && ret=0
        ;;
      session)
        _arguments '1:name' '*:command:_command_names -e' && ret=0
        ;;
      show)
        _arguments '-x[Display hex]' && ret=0
        ;;
    esac
    ;;
esac

return ret
