#compdef uhubctl
# Documentation: https://github.com/mvp/uhubctl
# Reference accessed: 2026-05-21
# Verified: upstream long_options table in uhubctl.c.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-l --location)'{-l,--location}'[limit hub by location]:location' \
  '(-n --vendor)'{-n,--vendor}'[limit hub by vendor id]:vendor\:product' \
  '(-s --search)'{-s,--search}'[limit hub by attached device description]:search string' \
  '(-H --searchhub)'{-H,--searchhub}'[limit hub by hub description]:hub desc' \
  '(-L --level)'{-L,--level}'[limit hub by location level]:level' \
  '(-p --ports)'{-p,--ports}'[ports to operate on]:ports' \
  '(-a --action)'{-a,--action}'[action for specified ports]:action:(off on cycle toggle flash)' \
  '(-d --delay)'{-d,--delay}'[delay for cycle/flash action in seconds]:seconds' \
  '(-r --repeat)'{-r,--repeat}'[repeat power off count]:count' \
  '(-w --wait)'{-w,--wait}'[wait time before repeating in milliseconds]:milliseconds' \
  '(-e --exact)'{-e,--exact}'[exact location matching without USB3 duality handling]' \
  '(-f --force)'{-f,--force}'[force operation on unsupported hubs]' \
  '(-N --nodesc)'{-N,--nodesc}'[skip querying device descriptions]' \
  '(-S --nosysfs)'{-S,--nosysfs}'[disable sysfs port interface (Linux only)]' \
  '(-y --sysdev)'{-y,--sysdev}'[open system device node]:sysdev' \
  '(-R --reset)'{-R,--reset}'[reset hub after power-on actions]' \
  '(-v --version)'{-v,--version}'[display program version]' \
  '(-h --help)'{-h,--help}'[display help text]' && ret=0

return ret
