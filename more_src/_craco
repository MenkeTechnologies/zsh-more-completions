local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _craco_cmds
_craco_cmds=(
    'build:wrap react-scripts build with config overrides'
    'start:wrap react-scripts start with config overrides'
    'test:wrap react-scripts test with config overrides'
)

_arguments -C \
    '--verbose[log every config-override application]' \
    '--config=[override auto-discovered config path]:config file:_files -g "*.{js,ts,cjs,mjs}"' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'craco subcommand' _craco_cmds && ret=0
        ;;
    args)
        # All other args are passed through to react-scripts
        # (build / start / test)
        ;;
esac

return ret
