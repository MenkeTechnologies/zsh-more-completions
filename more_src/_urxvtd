#compdef urxvtd
# _urxvtd — rxvt-unicode daemon mode (single long-running process that serves multiple urxvtc clients; -q quiet, -o open per-instance pty error log, -d /dev/null detach, -f no-fork stay foreground; reads same X resource defaults as urxvt)
# upstream: https://sources.debian.org/src/rxvt-unicode (urxvtd.C)
# Flags from rxvt-unicode src/urxvtd.C on tip.

_urxvtd() {
    _arguments \
        '-help[show help]' \
        '-q[quiet]' \
        '-f[stay foreground]' \
        '-o[per-instance pty error log]' \
        '-d+[fd dev null mode]:dev:_files'
}

_urxvtd "$@"
