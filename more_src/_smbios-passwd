#compdef smbios-passwd

# smbios-passwd: change BIOS/Setup passwords via SMBIOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  "--get-system-pass-properties[show system password properties]" "--current-password=[current password]:pass:" "--new-password=[new password]:pass:" "--password-type=[password type]:type:(setup system hdd master)" \
  '*::smbios-passwd args:_files' && ret=0
return ret
