#compdef remotion
# _remotion — Remotion React video rendering framework CLI
# upstream: https://github.com/remotion-dev/remotion

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'studio:Start the Remotion Studio'
  'render:Render a video or still image'
  'still:Render a still image'
  'compositions:List available compositions'
  'lambda:AWS Lambda rendering commands'
  'cloudrun:GCP Cloud Run rendering commands'
  'upgrade:Upgrade Remotion packages'
  'versions:Show installed Remotion package versions'
  'gpu:Probe for available GPUs'
  'browser:Manage headless browser'
  'help:Show help for a command'
)

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'remotion command' commands && ret=0
    ;;
  args)
    case $words[1] in
      studio)
        _arguments -s -S \
          '--port=[port for the studio]:port' \
          '--props=[pass input props as JSON]:json' \
          '--log=[log level]:level:(error warn info verbose)' \
          '--config=[custom config file]:file:_files' \
          '--env-file=[.env file path]:file:_files' \
          '--disable-keyboard-shortcuts[disable keyboard shortcuts]' \
          '--browser=[browser to use]:browser:(chrome firefox)' && ret=0
        ;;
      render)
        _arguments -s -S \
          '--props=[input props as JSON]:json' \
          '--concurrency=[frames to render in parallel]:number' \
          '--pixel-format=[pixel format]:format:(yuv420p yuv422p yuv444p yuv420p10le yuv422p10le)' \
          '--image-format=[intermediate image format]:format:(jpeg png none)' \
          '--frames=[frame range to render]:range' \
          '--sequence[render as image sequence]' \
          '--codec=[output codec]:codec:(h264 h265 vp8 vp9 mp3 aac wav prores gif)' \
          '--audio-codec=[audio codec]:codec:(aac mp3 wav pcm-16 opus)' \
          '--crf=[constant rate factor]:crf' \
          '--output=[output file path]:file:_files' \
          '--overwrite[overwrite existing output]' \
          '--quality=[JPEG quality]:quality' \
          '--scale=[output scale factor]:scale' \
          '--muted[disable audio]' \
          '--enforce-audio-track[force include audio track]' \
          '--every-nth-frame=[render every nth frame]:number' \
          '--number-of-gif-loops=[GIF loop count]:count' \
          '--log=[log level]:level:(error warn info verbose)' \
          '--config=[custom config file]:file:_files' \
          '--env-file=[.env file path]:file:_files' \
          '--timeout=[timeout per frame in ms]:ms' \
          '--browser=[browser to use]:browser:(chrome firefox)' \
          '--gl=[OpenGL renderer]:renderer:(angle egl swiftshader swangle)' \
          '--height=[override composition height]:pixels' \
          '--width=[override composition width]:pixels' \
          '1:composition-id' \
          '2:output-location:_files' && ret=0
        ;;
      still)
        _arguments -s -S \
          '--props=[input props as JSON]:json' \
          '--image-format=[output image format]:format:(jpeg png pdf webp)' \
          '--output=[output file path]:file:_files' \
          '--overwrite[overwrite existing output]' \
          '--quality=[JPEG quality]:quality' \
          '--scale=[output scale factor]:scale' \
          '--frame=[frame to render]:frame' \
          '--log=[log level]:level:(error warn info verbose)' \
          '--config=[custom config file]:file:_files' \
          '--env-file=[.env file path]:file:_files' \
          '--timeout=[timeout in ms]:ms' \
          '--browser=[browser to use]:browser:(chrome firefox)' \
          '--gl=[OpenGL renderer]:renderer:(angle egl swiftshader swangle)' \
          '--height=[override composition height]:pixels' \
          '--width=[override composition width]:pixels' \
          '1:composition-id' \
          '2:output-location:_files' && ret=0
        ;;
      compositions)
        _arguments -s -S \
          '--props=[input props as JSON]:json' \
          '--log=[log level]:level:(error warn info verbose)' \
          '--config=[custom config file]:file:_files' \
          '--env-file=[.env file path]:file:_files' \
          '--timeout=[timeout in ms]:ms' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '--package-manager=[package manager to use]:pm:(npm yarn pnpm bun)' && ret=0
        ;;
    esac
    ;;
esac

return ret
