#compdef broctl
# _broctl — Zeek formerly Bro broctl management shell legacy CLI for controlling Bro IDS cluster nodes start stop status install deploy and configuration update across manager workers proxies and loggers (zeek team, Python); cmd
# upstream: https://github.com/zeek/zeek-aux

_broctl() {
    local -a sub=(
        'start:start nodes'
        'stop:stop nodes'
        'restart:restart nodes'
        'status:show status'
        'check:check config'
        'install:install config'
        'deploy:deploy config'
        'config:print config'
        'cleanup:cleanup state'
        'cron:run hourly cron tasks'
        'capstats:show interface stats'
        'top:top-style monitoring'
        'diag:run diagnostics'
        'attachgdb:attach gdb to node'
        'df:show disk free'
        'process:reprocess trace'
        'update:update running policy'
        'peerstatus:show peer status'
        'netstats:show network stats'
        'exec:exec command on each node'
        'scripts:list scripts'
        'print:print Bro variable'
        'help:show help'
        'quit:quit'
        'exit:exit'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config=+[file]:file:_files -g "*.cfg broctl.cfg"' \
        '--prefix=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'broctl subcommand' sub ;;
        args)
            case $words[1] in
                start|stop|restart|status|check) _arguments '*:node name:' ;;
                exec) _arguments '*:command:_command_names -e' ;;
                process) _arguments '*:trace file:_files -g "*.pcap *.cap *.pcapng"' ;;
            esac
            ;;
    esac
}

_broctl "$@"
