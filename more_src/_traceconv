#compdef traceconv
# Documentation: https://perfetto.dev/docs/quickstart/traceconv
# traceconv - convert Perfetto protobuf traces to other formats

local ret=1
local -a modes=(
  'text:protobuf text format'
  'json:Chrome JSON format'
  'systrace:ftrace text/HTML systrace format'
  'ctrace:compressed systrace format'
  'profile:aggregated pprof profile data'
  'firefox:Firefox profiler format'
  'bundle:package trace with symbols into a TAR'
  'symbolize:emit symbol packets to output'
  'deobfuscate:emit deobfuscation mapping packets'
  'binary:convert text-format trace back to binary'
  'decompress_packets:decompress compressed TracePackets'
)

_arguments -s -S \
  '--truncate=[keep only start or end of trace]:where:(start end)' \
  '--full-sort[force full trace sorting]' \
  '--skip-unknown[skip unknown proto fields]' \
  '--output-dir=[output directory for generated pprof files]:dir:_files -/' \
  '--alloc[restrict to allocation profiles]' \
  '--perf[restrict to perf profiles]' \
  '--java-heap[restrict to Java heap profiles]' \
  '--no-annotations[omit derived frame annotations]' \
  '--pid=[filter by process]:pid:' \
  '--timestamps=[filter by sample timestamps]:timestamps:' \
  '--symbol-paths=[additional symbol search directories]:paths:' \
  '--no-auto-symbol-paths[disable automatic symbol discovery]' \
  '--proguard-map=[ProGuard/R8 mapping file]:map:_files' \
  '--no-auto-proguard-maps[disable automatic mapping discovery]' \
  '--verbose[detailed output]' \
  '1:mode:(($modes))' \
  '*:file:_files' && ret=0

return ret
