#compdef anyenv

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:set up anyenv in the shell'
  'install:install an env manager'
  'uninstall:remove an installed env manager'
  'commands:list all anyenv commands'
  'completions:list completions for a command'
  'exec:exec command using current env'
  'global:set global env version'
  'help:show help'
  'hooks:list hook scripts for a command'
  'local:set local env version'
  'prefix:show prefix for a version'
  'rehash:rehash shims'
  'root:show anyenv root path'
  'shell:set shell env version'
  'version:show current env version'
  'versions:list installed versions'
  'which:show full path to executable'
  'whence:list versions with a given command'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'anyenv subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--init[initialize install manifest]' \
          '(-l --list)'{-l,--list}'[list installable env managers]' \
          '(-u --update)'{-u,--update}'[update manifest]' \
          ':manager:' && ret=0
        ;;
    esac
    ;;
esac

return ret
