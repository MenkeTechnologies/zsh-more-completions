#compdef brutaldon
# _brutaldon — Brutaldon brutalist non-JavaScript Mastodon/Pleroma web client (Django, Python); local web app proxying to fediverse
# upstream: https://git.sr.ht/~biotanical/brutaldon

_brutaldon() {
    local -a sub=(
        'runserver:start Django dev server'
        'migrate:run database migrations'
        'createsuperuser:create admin user'
        'collectstatic:collect static files'
        'shell:open Django shell'
        'check:run system checks'
        'changepassword:change user password'
    )
    _arguments -C \
        '--settings+[settings module]:module:' \
        '--pythonpath+[python path]:path:_files -/' \
        '--verbosity+[verbosity]:n:(0 1 2 3)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brutaldon subcommand' sub ;;
        args)
            case $words[1] in
                runserver) _arguments '1:bind:' ;;
                createsuperuser) _arguments \
                    '--username+[username]:user:_users' \
                    '--email+[email]:email:' ;;
            esac
            ;;
    esac
}

_brutaldon "$@"
