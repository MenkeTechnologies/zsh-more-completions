#compdef ip-sr
# Documentation: https://man.archlinux.org/man/ip-sr.8.en
# ip sr - IPv6 segment routing configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip sr command' \
      'hmac[manage HMAC key mappings]' 'tunsrc[manage tunnel source address]' \
      'show[display configuration]' 'set[configure mapping]' \
      'help[show help]' && ret=0
    ;;
esac

return ret
