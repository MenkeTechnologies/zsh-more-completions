#compdef briss
# Documentation: https://github.com/mbaeuerle/Briss-2.0
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# PDF cropper (Briss-2.0)
_arguments -s -S \
  '-s+[source PDF file]:source:_files -g "*.pdf"' \
  '-d+[destination PDF file]:destination:_files -g "*.pdf"' \
  '--split-col[split the pdf into two columns]' \
  '--split-row[split the pdf into two parts by cutting pages in half]' \
  '*:args:_files'
