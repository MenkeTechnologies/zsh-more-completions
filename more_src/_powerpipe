#compdef powerpipe

# Zsh completion for Powerpipe - dashboards for DevOps (Turbot)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'benchmark:run benchmarks'
      'control:run controls'
      'dashboard:manage dashboards'
      'detection:run detections'
      'login:log in to Turbot Pipes'
      'mod:manage mods'
      'query:execute a query'
      'server:start dashboard server'
      'variable:manage variables'
      'completion:generate shell completions'
    )
    _describe -t commands 'powerpipe command' commands && ret=0
    ;;
  args)
    case $line[1] in
      benchmark)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list run)' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port to listen on]:port' \
          '--listen=[listen address]:address:(local network)' \
          '--database=[database connection string]:connection' \
          '--mod-location=[mod location]:directory:_directories' \
          '--var=[set variable]:KEY=VALUE' \
          '--var-file=[variable file]:file:_files -g "*.ppvars"' \
          '--output=[output format]:format:(none snapshot)' && ret=0
        ;;
      query)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--output=[output format]:format:(csv json table line)' \
          '--separator=[field separator]:separator' \
          '--header=[include header]:bool:(true false)' \
          '--database=[database connection string]:connection' \
          '--search-path=[search path]:path' \
          '--search-path-prefix=[search path prefix]:prefix' \
          '1:query or file:_files -g "*.sql"' && ret=0
        ;;
      mod)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(init install list show uninstall update)' && ret=0
        ;;
    esac
    ;;
esac

return ret
