#compdef render

# Zsh completion for render - Render cloud CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output}'[output format]:format:(json yaml table text)' \
  '--profile=[profile to use]:profile' \
  '--region=[region]:region' \
  '--confirm[skip confirmation prompts]' \
  '--verbose[verbose output]' \
  '--workspace=[workspace]:workspace' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'blueprint:manage blueprints'
      'services:manage services'
      'deploys:manage deploys'
      'jobs:manage jobs'
      'custom-domains:manage custom domains'
      'env-groups:manage environment groups'
      'regions:manage regions'
      'login:log in to Render'
      'logout:log out of Render'
      'whoami:show current user'
      'repo:manage repositories'
    )
    _describe -t commands 'render command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      blueprint)
        local -a blueprint_cmds=(
          'launch:launch a blueprint'
          'list:list blueprints'
        )
        _describe -t commands 'blueprint subcommand' blueprint_cmds && ret=0
        ;;
      services)
        local -a services_cmds=(
          'list:list services'
          'show:show service details'
          'create:create a service'
          'delete:delete a service'
          'restart:restart a service'
          'suspend:suspend a service'
          'resume:resume a service'
          'scale:scale a service'
          'ssh:SSH into a service'
        )
        _describe -t commands 'services subcommand' services_cmds && ret=0
        ;;
      deploys)
        local -a deploys_cmds=(
          'list:list deploys'
          'show:show deploy details'
          'create:create a deploy'
        )
        _describe -t commands 'deploys subcommand' deploys_cmds && ret=0
        ;;
      jobs)
        local -a jobs_cmds=(
          'list:list jobs'
          'show:show job details'
          'create:create a job'
        )
        _describe -t commands 'jobs subcommand' jobs_cmds && ret=0
        ;;
      custom-domains)
        local -a domains_cmds=(
          'list:list custom domains'
          'show:show domain details'
          'create:create a custom domain'
          'delete:delete a custom domain'
          'verify:verify a custom domain'
        )
        _describe -t commands 'custom-domains subcommand' domains_cmds && ret=0
        ;;
      env-groups)
        local -a envgroups_cmds=(
          'list:list environment groups'
          'show:show environment group'
          'create:create an environment group'
          'update:update an environment group'
          'delete:delete an environment group'
        )
        _describe -t commands 'env-groups subcommand' envgroups_cmds && ret=0
        ;;
      regions)
        local -a regions_cmds=(
          'list:list available regions'
        )
        _describe -t commands 'regions subcommand' regions_cmds && ret=0
        ;;
      repo)
        local -a repo_cmds=(
          'list:list repositories'
        )
        _describe -t commands 'repo subcommand' repo_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
