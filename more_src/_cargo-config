#compdef cargo-config
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-config.html

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'get:display a config value'
    )
    _describe -t subcmds 'cargo config subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      get)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(toml json json-value)' \
          '--show-origin[display where the config value is defined]' \
          '--merged=[whether to merge config values]:merged:(yes no)' \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
          '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
          '*'{-v,--verbose}'[use verbose output]' \
          '--color=[coloring]:when:(auto always never)' \
          '*--config=[override cargo configuration]:KEY=VALUE_or_path' \
          '*-Z+[unstable cargo flag]:flag' \
          '*:config key' && ret=0
        ;;
    esac
    ;;
esac

return ret
