#compdef booster
# Documentation: https://github.com/anatol/booster/blob/master/docs/manpage.md
# Reference accessed: 2026-05-16
# Verified: upstream anatol/booster manpage. Subcommand dispatch with
# 4 commands (build/cat/ls/unpack); only `build` takes flags.
# Removed from prior file: bogus man.archlinux.org search URL.

# booster: fast initramfs generator (Go-based mkinitcpio alternative)
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'build:build a new initramfs image'
  'cat:print a file from an image to stdout'
  'ls:list files in an image'
  'unpack:unpack an image into a directory'
)
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'booster command' commands && ret=0 ;;
  args)
    case ${words[1]} in
      build)
        _arguments \
          '(-f --force)'{-f,--force}'[overwrite existing image]' \
          '--init-binary=[path to init binary]:file:_files' \
          '--compression=[compression algorithm]:algo:(zstd gzip xz lz4 none)' \
          '--kernel-version=[kernel version]:version:' \
          '--config=[booster config file]:file:_files' \
          '--universal[universal image (all kernel modules)]' \
          '--strip[strip ELF binaries]' \
          '--crypttab=[crypttab file]:file:_files' \
          '*:output image:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac
return ret
