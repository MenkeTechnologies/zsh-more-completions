#compdef lvmdbus lvmdbusd
# Documentation: https://man7.org/linux/man-pages/man8/lvmdbusd.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lvmdbusd: LVM2 D-Bus daemon (python service)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--debug[enable debug statements]' \
  '--udev[use udev events to trigger updates]' \
  '*::lvmdbus args:_files' && ret=0
return ret
