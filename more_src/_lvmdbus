#compdef lvmdbus lvmdbusd

# lvmdbusd: LVM2 DBus daemon (python service)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '--use-json[use JSON protocol with lvm]' \
  '--use-lvm-shell[use persistent lvm shell process]' \
  '--blackbox=[dump blackbox to file]:file:_files' \
  '*::lvmdbus args:_files' && ret=0
return ret
