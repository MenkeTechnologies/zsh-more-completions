#compdef lvmdbus lvmdbusd

# lvmdbusd: LVM D-Bus daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[debug mode]' \
  '--blackbox[blackbox mode]' \
  '--udev[react to udev events]' \
  '--use-json[output internal data as JSON]' \
  '--no-json[do not output JSON]' \
  '*::lvmdbusd args:_files' && ret=0
return ret
