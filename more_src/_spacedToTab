#compdef spacedToTab
# UCSC kent: convert fixed width space separated fields to tab separated

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-sizes=[force columns of the given comma-separated widths]:widths:' \
  ':in txt:_files' \
  ':out tab:_files' && ret=0

return ret
