#compdef rbnrmf
# Physically compresses (rebins) an RMF dataset in channel and/or energy space

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[FITS RMF file to be compressed]:input file:_files' \
  'ebdfile=[FITS EBD input file]:ebd file:_files' \
  'binfile=[ASCII file specifying channel binning]:bin file:_files' \
  'fchan=[output first channel number]:channel:(% 0 1)' \
  'nchan=[number of channels in compressed dataset]:count:' \
  'cmpmode=[channel compression mode]:mode:(LINEAR FAINT2BRIGHT BRIGHT2LINEAR)' \
  'ebinfile=[ASCII file specifying energy binning]:ebin file:_files' \
  'ebfact=[compression factor for energy binning]:factor:' \
  'outfile=[output FITS file with compressed RMF]:output file:_files' \
  'chatter=[verbosity level]:level:' \
  'clobber=[overwrite pre-existing output files]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
