#compdef emsdk
# Emscripten SDK manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install an SDK version or tool'
      'uninstall:uninstall an SDK version or tool'
      'activate:activate an SDK version or tool'
      'list:list available and installed SDKs'
      'update:update the emsdk repository'
      'update-tags:fetch latest tags from remote'
      'construct_env:print environment variables for active SDK'
    )
    _describe -t commands 'emsdk command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '--shallow[perform shallow clone]' \
          '--build[build from source]' \
          '--global[install globally]' \
          '*:sdk version:(latest tot upstream)' && ret=0
        ;;
      activate)
        _arguments \
          '--permanent[write to shell config]' \
          '--system[install systemwide]' \
          '*:sdk version:(latest)' && ret=0
        ;;
      *)
        _arguments '*:sdk version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
