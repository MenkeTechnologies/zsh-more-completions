#compdef lrs2lrf
# Documentation: https://manual.calibre-ebook.com/generated/en/lrs2lrf.html
# Compile an LRS file into an LRF file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message and exit]' \
  '--version[show program version number and exit]' \
  '--verbose[verbose processing]' \
  '--lrs[convert LRS to LRS, useful for debugging]' \
  '(-o --output)'{-o,--output}'=[path to output file]:lrf file:_files -g "*.lrf"' \
  '*:lrs file:_files -g "*.lrs"' && ret=0

return ret
