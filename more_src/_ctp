#compdef ctp catppuccin
# Documentation: https://github.com/catppuccin/cli (internal/cli/{root,install,uninstall,update,search,new,lint}.go cobra)
# Reference accessed: 2026-05-29
# Catppuccin theme installer/manager CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'install:install Catppuccin theme packages'
  'uninstall:uninstall Catppuccin theme packages'
  'update:check repos for any updates to installed packages'
  'search:search for repositories matching a package name'
  'new:initialize a new Catppuccin theme project (interactive)'
  'lint:lint a .catppuccin.yaml port config against the schema'
  'completion:generate shell completion scripts'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'ctp subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '(-f --flavour)'{-f,--flavour=}'[custom flavour (default all)]:flavour:(all latte frappe macchiato mocha)' \
          '(-m --mode)'{-m,--mode=}'[custom mode (default default)]:mode:' \
          '(-F --Force)'{-F,--Force}'[force-remove existing cloned repository before reinstalling]' \
          '*:package:' && ret=0
        ;;
      uninstall)
        _arguments \
          '(-F --Force)'{-F,--Force}'[force-remove cloned repository directory in addition to config files]' \
          '*:package:' && ret=0
        ;;
      update|search)
        _arguments \
          '*:package:' && ret=0
        ;;
      new)
        _arguments \
          ':template name:' \
          ':project name:' \
          ':author:' \
          ':description:' \
          ':license:' && ret=0
        ;;
      lint)
        _arguments \
          ':port config file:_files -g ".catppuccin.(yaml|yml)"' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
