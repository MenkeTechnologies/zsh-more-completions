#compdef tlsh
# _tlsh — Trend Micro Locality Sensitive Hash CLI; fuzzy hash useful for malware similarity scoring
# upstream: https://github.com/trendmicro/tlsh

_tlsh() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-f+[file to hash]:file:_files' \
        '-r+[recursive dir]:dir:_files -/' \
        '-l+[input list file]:file:_files' \
        '-c+[compare to hash]:hex:' \
        '-d+[compare hash to second hash]:hex:' \
        '-T+[distance threshold]:n:' \
        '-xref+[cross-reference list mode]:file:_files' \
        '-t+[threads]:n:' \
        '-force[hash files even if too small]' \
        '-conservative[require min size to hash]' \
        '-version1[force TLSH version 1]' \
        '-version[print version]'
}

_tlsh "$@"
