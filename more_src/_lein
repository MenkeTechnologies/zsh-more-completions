#compdef lein leiningen
# Documentation: https://leiningen.org/
# Source: technomancy/leiningen src/leiningen/*.clj — Clojure project automation tool (Clojure).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '-o[run in offline mode]' \
    '-U[force snapshot update]' \
    '1:task:(change check classpath clean compile deploy deps do help install jar javac new plugin pom release repl retest run search show-profiles static-classpath test trampoline uberjar update-in upgrade vcs version with-profile)' \
    '*::task args:_default' \
    && ret=0

return ret
