#compdef cvsconvert
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/cvsconvert.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cvsconvert: wrapper around cvs-fast-export(1) that converts a CVS
# repository to Git and verifies tree contents at branch tips and tags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-v[verbose: show subcommands and debug messages]' \
  '-n[test only, do not keep Git conversion]' \
  '-p[enable progress reports from cvs-fast-export]' \
  '-q[run cvs-fast-export quietly]' \
  '-k+[keyword-expansion spec passed to cvs-fast-export/cvs]:expandspec:' \
  '-A+[author map for cvs-fast-export]:authormap:_files' \
  '*:cvs repo or repo/module:_files -/' && ret=0

return ret
