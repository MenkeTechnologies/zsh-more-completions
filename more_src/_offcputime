#compdef offcputime offcputime-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/offcputime.py argparse)
# Reference accessed: 2026-05-29
# offcputime — sample off-CPU time with stack traces (BCC/eBPF). Output suitable for flame graphs.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace these PIDs only (comma-separated)]:pids:' \
  '(-t --tid)'{-t,--tid=}'[trace these TIDs only (comma-separated)]:tids:' \
  '(-u --user-threads-only -k --kernel-threads-only)'{-u,--user-threads-only}'[user threads only (no kernel threads)]' \
  '(-u --user-threads-only -k --kernel-threads-only)'{-k,--kernel-threads-only}'[kernel threads only (no user threads)]' \
  '(-U --user-stacks-only -K --kernel-stacks-only)'{-U,--user-stacks-only}'[show stacks from user space only (no kernel space stacks)]' \
  '(-U --user-stacks-only -K --kernel-stacks-only)'{-K,--kernel-stacks-only}'[show stacks from kernel space only (no user space stacks)]' \
  '(-d --delimited)'{-d,--delimited}'[insert delimiter between kernel/user stacks]' \
  '(-f --folded)'{-f,--folded}'[output folded format (for flame graphs)]' \
  '(-s --offset)'{-s,--offset}'[show address offsets]' \
  '--stack-storage-size=[number of unique stack traces stored/displayed]:N (default 16384):' \
  '(-m --min-block-time)'{-m,--min-block-time=}'[min time in microseconds over which to store traces]:us (default 1):' \
  '(-M --max-block-time)'{-M,--max-block-time=}'[max time in microseconds under which to store traces]:us:' \
  '--state=[filter on this thread state bitmask (eg, 2 == TASK_UNINTERRUPTIBLE)]:mask:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:duration (seconds, default unlimited):' \
  && ret=0

return ret
