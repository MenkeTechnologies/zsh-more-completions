#compdef arptables-save arptables-restore
# _arptables-save — netfilter arptables-save / arptables-restore (dump or reload the kernel ARP table firewall rules in arptables-restore syntax; -c include counters, -t TABLE limit to one table (filter is the only one in mainline), -n no flush (restore only), -h help, -V version; positional argument is the input/output file (default stdin/stdout))
# upstream: https://git.netfilter.org/arptables
# Flags from netfilter/arptables arptables-save.c on tip.

_arptables-save() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[include counters]' \
        '-t+[table]:table:(filter)' \
        '-n[no flush (restore)]' \
        '*:file:_files'
}

_arptables-save "$@"
