#compdef createtree
# _createtree — Trillian admin helper: create a Merkle log/Map tree
# upstream: https://github.com/google/trillian
# Flags from cmd/createtree/main.go on tip.

_createtree() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-admin_server=[Trillian Admin Server host\:port]:host\:port:' \
        '-rpc_deadline=[RPC request deadline]:dur:' \
        '-tree_state=[initial tree state]:state:(ACTIVE FROZEN DRAINING)' \
        '-tree_type=[tree type]:type:(LOG PREORDERED_LOG MAP)' \
        '-display_name=[tree display name]:name:' \
        '-description=[tree description]:text:' \
        '-max_root_duration=[interval after which a new signed root is produced]:dur:' \
        '-config=[config file]:file:_files'
}

_createtree "$@"
