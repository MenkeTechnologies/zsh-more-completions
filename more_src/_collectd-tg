#compdef collectd-tg
# Documentation: https://man.archlinux.org/search?q=collectd-tg
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-n+[number of hosts]:n:' \
  '-p+[number of plugins]:n:' \
  '-i+[interval sec]:sec:' \
  '-t+[number of plugin instances]:n:' \
  '-T+[number of TS per plugin]:n:' \
  '-v+[number of values per TS]:n:' \
  '-d+[destination host]:host:_hosts' \
  '-D+[destination port]:port:' && ret=0

return ret
