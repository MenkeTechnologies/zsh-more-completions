#compdef collectd-tg
# Documentation: https://www.collectd.org/documentation/manpages/collectd-tg.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help and exit]' \
  '-n+[number of value lists to generate]:value lists:' \
  '-H+[number of hosts to emulate]:hosts:' \
  '-p+[number of plugins to emulate]:plugins:' \
  '-i+[interval used to generate values, in seconds]:interval seconds:' \
  '-d+[destination address of network packets]:destination host:_hosts' \
  '-D+[destination port of network packets]:port:' && ret=0

return ret
