#compdef tiny-agents
# Documentation: https://github.com/huggingface/huggingface_hub
# Reference accessed: 2026-05-23
# Verified: tiny-agents --help (huggingface_hub MCP CLI).

# Zsh completion for tiny-agents - Hugging Face lightweight MCP agent squad CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'tiny-agents command' \
      'run[run agent in the CLI]' && ret=0
    ;;
esac

return ret
