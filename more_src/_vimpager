#compdef vimpager
# Documentation: https://github.com/rkitover/vimpager
# Reference accessed: 2026-05-21
# Verified: upstream README.
# Removed from prior file: --debug, --debug-vim, --vimcat, --no-vimcat
# (none present in upstream README option list).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help,--usage}'[print summary of options]' \
  '(- *)'{-v,--version}'[print version information]' \
  '+[start at end of file (like less +G)]' \
  '+G[start at end of file]' \
  '+F[follow file, like tail -f or less +F]' \
  '(-N --LINE-NUMBERS)'{-N,--LINE-NUMBERS}'[turn on line numbers]' \
  '*-c+[run vim command after opening file]:cmd:' \
  '*--cmd+[run vim command before initialization]:cmd:' \
  '-u+[use alternate vimrc or vimpagerrc file]:file:_files' \
  '-s[squeeze blank lines into a single blank line]' \
  '--passthrough[use vimcat for highlighting if content fits on screen]' \
  '--force-passthrough[always use vimcat for syntax highlighting]' \
  '--no-passthrough[never use vimcat, always invoke pager]' \
  '-x[enable debugging output for the vimpager shell script]' \
  '*:file:_files' && ret=0

return ret
