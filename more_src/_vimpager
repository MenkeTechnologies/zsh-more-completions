#compdef vimpager

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[debug mode]' \
  '--debug-vim[debug vim]' \
  '--passthrough[passthrough to less]' \
  '--force-passthrough[force passthrough]' \
  '--no-passthrough[no passthrough]' \
  '--no-vimcat[disable vimcat]' \
  '--vimcat[use vimcat]' \
  '*:file:_files' && ret=0

return ret
