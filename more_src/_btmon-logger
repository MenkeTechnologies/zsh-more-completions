#compdef btmon-logger
# Documentation: https://github.com/bluez/bluez/blob/master/tools/btmon-logger.c
# Source: BlueZ tools/btmon-logger.c — rotating HCI trace logger (.btsnoop ring file emitter).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-b --basename)'{-b+,--basename=}'[save traces in given path]:path:_files' \
    '(-p --parents)'{-p,--parents}'[create basename parent directories]' \
    '(-l --limit)'{-l+,--limit=}'[per-file size limit (rotate)]:size:' \
    '(-c --count)'{-c+,--count=}'[number of rotated files]:n:' \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
