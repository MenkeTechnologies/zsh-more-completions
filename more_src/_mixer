#compdef mixer
# Documentation: https://csound.com/docs/manual/
# Csound utility to mix and rescale soundfiles together

local ret=1

_arguments -s -S \
  '-F+[gain applied to following input (numeric or breakpoint file)]:gain' \
  '-S+[sample position to start mixing next file]:sample' \
  '-T+[time in seconds to start mixing next file]:seconds' \
  '-1[mix channel 1 from next file]' \
  '-2[mix channel 2 from next file]' \
  '-3[mix channel 3 from next file]' \
  '-4[mix channel 4 from next file]' \
  '-A[AIFF output format]' \
  '-W[WAV output format]' \
  '-h[no header on output]' \
  '-c[8-bit signed char samples]' \
  '-a[A-law samples]' \
  '-u[U-law samples]' \
  '-s[short integer samples]' \
  '-l[long (32-bit) integer samples]' \
  '-f[floating point samples]' \
  '-R[continuously rewrite header during writing]' \
  '-H+[progress indicator style]:style:(1 2 3)' \
  '-N[notify when complete]' \
  '-v[verbose mode]' \
  '-o+[output filename]:output:_files' \
  '*:soundfile:_files' && ret=0

return ret
