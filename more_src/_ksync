#compdef ksync
# Sync local files to Kubernetes pods

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace:' \
  '--context[Kubernetes context]:context:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:create a new sync spec'
      'delete:delete a sync spec'
      'get:list sync specs'
      'init:install ksync components on cluster'
      'watch:start watching for file changes'
      'clean:remove ksync components from cluster'
    )
    _describe -t commands 'ksync command' commands && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '--selector[pod selector]:selector:' \
          '--container[container name]:container:' \
          '--name[spec name]:name:' \
          '--reload[reload on sync]' \
          ':local path:_files -/' \
          ':remote path:' && ret=0
        ;;
      delete)
        _arguments '*:spec name:' && ret=0
        ;;
      *)
        _arguments '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
