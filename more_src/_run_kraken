#compdef run_kraken.py run_kraken kraken
# _run_kraken — Krkn Kubernetes/OpenShift chaos orchestrator entrypoint (krkn-chaos/krkn)
# upstream: https://github.com/krkn-chaos/krkn
# Flags from run_kraken.py (optparse).

_run_kraken.py() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[config file location]:file:_files -g "*.yaml"' \
        '(-o --output)'{-o+,--output=}'[output report location]:file:_files' \
        '--junit-testcase=[junit test case description]:desc:' \
        '--junit-testcase-path=[junit test case path]:file:_files' \
        '--junit-testcase-version=[junit test case version]:ver:' \
        '(-r --run_uuid)'{-r+,--run_uuid=}'[run UUID for rollback]:uuid:' \
        '(-s --scenario_type)'{-s+,--scenario_type=}'[scenario type for rollback]:type:'
}

_run_kraken.py "$@"
