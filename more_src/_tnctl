#compdef tnctl
# Documentation: https://terranetes.appvia.io/terranetes-controller/developer/tnctl/
# Terranetes CLI for managing Terraform Configurations and CloudResources on Kubernetes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[target namespace]:namespace' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '*:command:((
    search\:"search sources for modules and generate a Configuration CRD"
    describe\:"retrieve cost, policy and status details for resources"
    approve\:"approve a Configuration or CloudResource"
    retry\:"retry a cloud resource or configuration"
    logs\:"monitor the logs of a configuration execution"
    workflow\:"generate a skeleton CI pipeline"
    state\:"manage the Terraform Configuration state secrets"
    config\:"manage tnctl configuration and sources"
    completion\:"generate shell autocompletion script"
    version\:"print the version of tnctl"
  ))' && ret=0

return ret
