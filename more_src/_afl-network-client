#compdef afl-network-client
# Documentation: https://github.com/AFLplusplus/AFLplusplus/blob/stable/utils/afl_network_proxy/README.md
# AFL++ network proxy client run as the fuzz target, forwarding to a remote server

local ret=1

_arguments -s -S \
  '1:target ip (IPv4, IPv6 or hostname)' \
  '2:port' && ret=0

return ret
