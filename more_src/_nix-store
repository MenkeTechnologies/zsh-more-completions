#compdef nix-store

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--add-fixed[add fixed-output paths]:hash algo:(md5 sha1 sha256 sha512)' \
  '-v[increase verbosity level]' \
  '--option[set a Nix option]:name: :value' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      '--realise:build or fetch store paths'
      '-r:build or fetch store paths'
      '--gc:run garbage collector'
      '--delete:delete specific store paths'
      '--query:query store path info'
      '-q:query store path info'
      '--add:add paths to Nix store'
      '--verify:verify store integrity'
      '--dump:dump a store path to NAR format'
      '--restore:restore a path from NAR format'
      '--export:export store paths'
      '--import:import store paths'
      '--optimise:optimise Nix store by hard-linking identical files'
      '--read-log:show build log of a store path'
      '-l:show build log of a store path'
      '--dump-db:dump Nix database'
      '--load-db:load Nix database'
      '--print-env:print the build environment of a derivation'
      '--generate-binary-cache-key:generate key pair for binary cache signing'
      '--serve:provide access to Nix store over stdin/stdout'
    )
    _describe -t commands 'nix-store command' commands
    ;;
  args)
    case $words[1] in
      --realise|-r)
        _arguments -s -S \
          '--dry-run[show what would be done]' \
          '--ignore-unknown[ignore unknown paths]' \
          '--check[rebuild and compare output]' \
          '--keep-going[keep going on failure]' \
          '--max-jobs[maximum parallel build jobs]:jobs' \
          '--cores[CPU cores per build]:cores' \
          '*:store path:_files -/' && ret=0
        ;;
      --gc)
        _arguments -s -S \
          '--print-roots[print GC roots]' \
          '--print-live[print live paths]' \
          '--print-dead[print dead paths]' \
          '--delete[delete dead paths]' \
          '--max-freed[stop after freeing this much space]:bytes' && ret=0
        ;;
      -q|--query)
        _arguments -s -S \
          '--outputs[print output paths]' \
          '--requisites[print closure of dependencies]' \
          '-R[print closure of dependencies]' \
          '--references[print immediate dependencies]' \
          '--referrers[print paths that depend on this]' \
          '--referrers-closure[print transitive referrers]' \
          '--deriver[print deriver of path]' \
          '--graph[print dependency graph in dot format]' \
          '--tree[print dependency tree]' \
          '--binding[print a specific build attribute]:attribute' \
          '-b[print a specific build attribute]:attribute' \
          '--hash[print hash of path contents]' \
          '--size[print size of path]' \
          '--roots[print GC roots for path]' \
          '--valid[check whether path is valid]' \
          '*:store path:_files -/' && ret=0
        ;;
      --verify)
        _arguments -s -S \
          '--check-contents[verify contents against hashes]' \
          '--repair[repair invalid paths]' && ret=0
        ;;
      --dump|--restore)
        _arguments '1:path:_files -/' && ret=0
        ;;
      --export|--import)
        _arguments '*:store path:_files -/' && ret=0
        ;;
      --serve)
        _arguments -s -S \
          '--write[allow writing to the store]' && ret=0
        ;;
    esac
    ;;
esac

return ret