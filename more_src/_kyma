#compdef kyma
# Documentation: https://github.com/kyma-project/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kyma (kyma-project/cli) v3. Top-level subcommands taken from
# internal/cmd: alpha, app, module, version (plus help, completion).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'alpha:experimental commands'
  'app:deploy and manage applications'
  'completion:generate shell autocompletion script'
  'help:help about any command'
  'module:manage Kyma modules'
  'version:print CLI version'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  (cmds)
    _describe -t commands 'kyma command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (app)
        _arguments '1:subcommand:(push)' && ret=0
        ;;
      (module)
        _arguments '1:subcommand:(add delete list manage unmanage)' && ret=0
        ;;
      (alpha)
        _arguments '1:subcommand:(provision hana)' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
