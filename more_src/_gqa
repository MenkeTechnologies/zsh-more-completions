#compdef gqa
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=gqa&sektion=1
# BRL-CAD geometry quality analysis (weight, volume, overlaps, gaps)

local ret=1

_arguments -s \
  '-A[computations to perform/report]:analyses' \
  '-a[azimuth rotation about Z axis]:azimuth' \
  '-e[elevation rotation from XY plane]:elevation' \
  '-d[enable debugging mode]' \
  '-f[external density file]:density file:_files' \
  '-g[grid spacing limits [init,]limit]:spacing' \
  '-G[create assembly combinations for overlap pairs]' \
  '-n[minimum ray intersections per region]:hits' \
  '-N[limit computation to first N views]:views' \
  '-p[plot file prefix for analysis output]:prefix' \
  '-P[number of CPUs for parallel computation]:cpus' \
  '-q[suppress "was not hit" reporting]' \
  '-r[print per-region weight/volume statistics]' \
  '-S[minimum samples per model axis]:samples' \
  '-t[overlap detection tolerance]:tolerance' \
  '-U[retain air regions boolean]:value' \
  '-u[distance,volume,weight reporting units]:units' \
  '-V[volumetric convergence tolerance]:tolerance' \
  '-v[verbose progress reporting]' \
  '-W[weight convergence tolerance]:tolerance' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
