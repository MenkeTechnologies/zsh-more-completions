#compdef soldeer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new Soldeer project'
  'install:install dependencies'
  'update:update dependencies'
  'login:login to Soldeer registry'
  'push:push a package to the registry'
  'uninstall:remove a dependency'
  'version:show version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'soldeer command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '--dependency[dependency name~version]:dependency:' \
          '--remote-url[custom remote URL]:url:' \
          '--rev[git revision]:rev:' \
          '--regenerate-remappings[regenerate remappings]' \
          '--recursive-deps[install recursive dependencies]' \
          '--help[show help]' && ret=0
        ;;
      push)
        _arguments -s -S \
          '--dry-run[simulate push]' \
          '1:package-name:' \
          '2:version:' \
          '--help[show help]' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '1:dependency:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
