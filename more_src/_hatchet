#compdef hatchet
# Documentation: https://man.archlinux.org/search?q=hatchet
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'token:create/manage tokens'
  'worker:run/manage workers'
  'workflow:manage workflows'
  'task:list/cancel/replay tasks'
  'event:emit/list events'
  'tenant:manage tenants'
  'admin:admin commands'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-url=[Hatchet API base URL]:url:' \
  '--token=[API token]:token:' \
  '--tenant=[tenant id]:id:' \
  '--output=[output format]:format:(table json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hatchet command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (token)
        _arguments '*::sub:(create list revoke)' && ret=0 ;;
      (worker)
        _arguments \
          '*::sub:(run start status list)' \
          '--name=[worker name]:name:' \
          '--max-runs=[max concurrent runs]:n:' \
          '*--label=[worker label k=v]:kv:' \
          '--hot-reload[hot reload on code changes]' && ret=0 ;;
      (workflow)
        _arguments \
          '*::sub:(list trigger get cancel replay)' && ret=0 ;;
      (task)
        _arguments \
          '*::sub:(list cancel replay get logs)' && ret=0 ;;
      (event)
        _arguments \
          '*::sub:(emit list)' \
          '--key=[event key]:key:' \
          '--payload=[JSON payload]:json:' && ret=0 ;;
      (tenant)
        _arguments '*::sub:(create list get update delete)' && ret=0 ;;
      (admin)
        _arguments '*::sub:(migrate seed reset)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
