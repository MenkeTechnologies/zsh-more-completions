#compdef OpenSwathWorkflow
# Documentation: https://www.openms.org/documentation/html/TOPP_OpenSwathWorkflow.html
# OpenMS: complete OpenSWATH DIA/SWATH-MS targeted analysis workflow

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '*-in[input files (mzML, mzXML, sqMass, d)]:file:_files' \
  '-tr[transition file (TraML, tsv, pqp)]:file:_files' \
  '-tr_type[transition input file type]:type:(tsv mrm pqp TraML)' \
  '-swath_windows_file[tab-separated SWATH windows file]:file:_files' \
  '-out_features[feature output file]:file:_files' \
  '-out_features_type[feature output file type]:type:(featureXML osw oswpq)' \
  '-out_tsv[tsv output file]:file:_files' \
  '-out_osw[osw output file]:file:_files' \
  '-out_chrom[extracted chromatograms output]:file:_files' \
  '-out_mobilogram[ion mobilograms output (.xim)]:file:_files' \
  '-out_qc[QC metadata output (.json)]:file:_files' \
  '-rt_extraction_window[RT extraction window]:double:' \
  '-mz_extraction_window[m/z extraction window]:double:' \
  '-mz_extraction_window_unit[m/z extraction window unit]:unit:(Th ppm)' \
  '-mz_extraction_window_ms1[MS1 m/z window]:double:' \
  '-ion_mobility_window[ion mobility window]:double:' \
  '-im_extraction_window_ms1[MS1 ion mobility window]:double:' \
  '-enable_ms1[extract precursor (MS1) traces]' \
  '-enable_ipf[enable IPF scoring]' \
  '-pasef[data is PASEF format]' \
  '-matching_window_only[PRM-like extraction mode]' \
  '-split_file_input[separate SWATH window files]' \
  '-min_upper_edge_dist[distance to SWATH edge]:double:' \
  '-ms1_isotopes[number of MS1 isotopes]:int:' \
  '-readOptions[memory handling mode]:mode:(normal cache cacheWorkingDirOnly workingInMemory)' \
  '-tempDirectory[temporary directory location]:dir:_files -/' \
  '-batchSize[compound batch size]:int:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
