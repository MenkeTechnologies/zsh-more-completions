#compdef exenv

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'commands:list all available exenv commands'
  'completions:list completions for a command'
  'global:set or show the global Elixir version'
  'help:show help for a command'
  'init:configure the shell environment for exenv'
  'install:install an Elixir version'
  'local:set or show the local directory Elixir version'
  'prefix:show the path to an Elixir version'
  'rehash:rehash exenv shims'
  'root:show the root directory of exenv'
  'shell:set or show the shell-specific Elixir version'
  'shims:list existing exenv shims'
  'uninstall:uninstall an Elixir version'
  'version:show the current Elixir version and its origin'
  'version-file:detect the version file in the current directory'
  'version-name:show the current Elixir version name'
  'version-origin:explain how the current Elixir version was set'
  'versions:list all installed Elixir versions'
  'whence:list versions that contain the given command'
  'which:show the full path for a command'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'exenv command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        local -a available_versions
        if _cache_invalid exenv_install_versions || ! _retrieve_cache exenv_install_versions; then
          available_versions=(${(f)"$(exenv install --list 2>/dev/null | sed 's/^[[:space:]]*//')"})
          _store_cache exenv_install_versions available_versions
        fi
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--list[list all available versions]' \
          '1:version:compadd -a available_versions' && ret=0
        ;;
      uninstall)
        local -a installed_versions
        installed_versions=(${(f)"$(exenv versions --bare 2>/dev/null)"})
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:version:compadd -a installed_versions' && ret=0
        ;;
      global|local|shell)
        local -a installed_versions
        installed_versions=(${(f)"$(exenv versions --bare 2>/dev/null)"})
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:version:compadd system -a installed_versions' && ret=0
        ;;
      which)
        local -a shim_commands
        shim_commands=(${(f)"$(exenv shims --short 2>/dev/null)"})
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:command:compadd -a shim_commands' && ret=0
        ;;
      whence)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:command name' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:compadd -a - commands' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:command:compadd -a - commands' && ret=0
        ;;
      prefix)
        local -a installed_versions
        installed_versions=(${(f)"$(exenv versions --bare 2>/dev/null)"})
        _arguments -s -S \
          '1:version:compadd -a installed_versions' && ret=0
        ;;
    esac
    ;;
esac

return ret
