#compdef cargo-count
# Documentation: https://man.archlinux.org/search?q=cargo-count
# Reference accessed: 2026-05-16

# https://github.com/kbknapp/cargo-count — `cargo count` line-count helper

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-a --all)'{-a,--all}'[do not honor .gitignore rules]' \
  '(-S --follow-symlinks)'{-S,--follow-symlinks}'[follow symlinks while scanning]' \
  '--unsafe-statistics[count unsafe blocks in Rust sources]' \
  '(-l --language)'{-l,--language}'*[restrict to file extensions]:ext:' \
  '(-e --exclude)'{-e,--exclude}'*[exclude paths or globs]:path:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-s --separator)'{-s,--separator}'=[single-char thousands separator]:char:' \
  '--utf8-rule=[UTF-8 decode policy]:rule:(strict lossy ignore)' \
  '*:paths:_files' && return 0
