#compdef keystone
# _keystone — KeystoneJS headless CMS CLI (keystonejs/keystone)
# upstream: https://github.com/keystonejs/keystone
# Flags from packages/core/src/scripts/cli.ts (meow).

_keystone() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--frozen[do not build graphql/prisma schemas, only validate]' \
        '--no-db-push[do not push prisma schema to db]' \
        '--no-prisma[do not build/validate prisma schema]' \
        '--no-server[do not start the express server]' \
        '--no-ui[do not build/serve AdminUI]' \
        '--with-migrations[run prisma migrations on start]' \
        '--quiet[quiet output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'dev:start project in development mode (default)'
                'migrate:run prisma migrations (create / apply)'
                'postinstall:build project for development (postinstall hook)'
                'build:build project for production'
                'start:start the production server'
                'prisma:run prisma commands in keystone context'
                'telemetry:enable/disable/status telemetry preference'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                migrate) _arguments '1:action:(create apply)' ;;
                telemetry) _arguments '1:action:(enable disable status)' ;;
                prisma) _arguments '*:: :_command_names -e' ;;
            esac
            ;;
    esac
}

_keystone "$@"
