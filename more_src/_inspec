#compdef inspec

# Zsh completion for Chef InSpec - infrastructure compliance testing

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-l+[log level]:level:(debug info warn error fatal)' \
  '--log-level=[log level]:level:(debug info warn error fatal)' \
  '--log-location=[location of log file]:file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'archive:archive a profile to tar.gz or zip'
      'automate:communication commands for Chef Automate'
      'check:verify all tests at the specified path'
      'compliance:Chef Compliance commands'
      'detect:detect target OS'
      'env:output shell-appropriate setup'
      'exec:run all tests at the specified path'
      'habitat:commands for Chef Habitat'
      'init:scaffolds a new project'
      'json:read all tests and generate a JSON summary'
      'schema:print the JSON schema'
      'shell:open an interactive shell'
      'supermarket:Supermarket commands'
      'vendor:download all dependencies'
      'version:print the version'
    )
    _describe -t commands 'inspec command' commands && ret=0
    ;;
  args)
    case $line[1] in
      exec)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-t+[target to run on]:target' \
          '--target=[target to run on]:target' \
          '-b+[backend to use]:backend:(ssh winrm local docker)' \
          '--backend=[backend to use]:backend:(ssh winrm local docker)' \
          '--host=[target host]:host' \
          '--port=[target port]:port' \
          '--user=[target user]:user' \
          '--password=[target password]:password' \
          '-i+[SSH key file]:key:_files' \
          '--key-files=[SSH key file]:key:_files' \
          '--sudo[use sudo]' \
          '--sudo-password=[sudo password]:password' \
          '--reporter=[reporter type]:reporter:(json json-min cli html yaml documentation junit)' \
          '--controls=[specific controls to run]:controls' \
          '--tags=[filter by tags]:tags' \
          '--input=[set inputs]:key=value' \
          '--input-file=[input file]:file:_files -g "*.{yml,yaml}"' \
          '--attrs=[attribute file]:file:_files -g "*.{yml,yaml}"' \
          '--waiver-file=[waiver file]:file:_files -g "*.{yml,yaml}"' \
          '--create-lockfile[create a lockfile]' \
          '--distinct-exit[use distinct exit codes]' \
          '--no-distinct-exit[do not use distinct exit codes]' \
          '--show-progress[show progress]' \
          '--no-color[disable color output]' \
          '*:profile path:_files' && ret=0
        ;;
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(json doc)' \
          '*:profile path:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(profile plugin resource)' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-t+[target]:target' \
          '--target=[target]:target' \
          '-c+[command to run]:command' \
          '--command=[command to run]:command' \
          '--reporter=[reporter type]:reporter' && ret=0
        ;;
      archive)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '--overwrite[overwrite existing file]' \
          '--zip[create ZIP archive]' \
          '--tar[create tar.gz archive]' \
          '*:profile path:_files' && ret=0
        ;;
      vendor)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:profile path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
