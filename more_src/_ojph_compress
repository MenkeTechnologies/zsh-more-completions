#compdef ojph_compress
# Documentation: https://github.com/aous72/OpenJPH
# Reference accessed: 2026-05-19
# Verified: local `ojph_compress` help output (/opt/homebrew/bin/ojph_compress).

local -a arguments

arguments=(
    '-i[input file (pgm/ppm/pfm/tif(f)/raw(yuv))]:input file:_files -g "*.{ppm,pgm,pfm,raw,yuv,png,tif,tiff,bmp}"'
    '-o[output file]:output file:_files -g "*.{j2c,jph,j2k}"'
    '-num_decomps[number of decompositions]:levels'
    '-qstep[quantization step (lossy only)]:step size'
    '-reversible[use reversible transform]:reversible:(true false)'
    '-colour_trans[use RGB to YUV color transform]:colour_trans:(true false)'
    '-prog_order[progression order]:order:(LRCP RLCP RPCL PCRL CPRL)'
    '-block_size[code block size {x,y}]:size'
    '-precincts[precinct sizes {x,y},...]:sizes'
    '-tile_offset[tile offset {x,y}]:offset'
    '-tile_size[tile size {x,y}]:size'
    '-image_offset[image offset {x,y}]:offset'
    '-tileparts[tilepart divisions (R, C, or RC)]:value:(R C RC)'
    '-tlm_marker[insert TLM marker]:tlm_marker:(true false)'
    '-profile[profile]:profile:(BROADCAST IMF)'
    '-com[insert COM comment marker]:comment'
    '-dims[image dimensions {x,y} (YUV)]:dimensions'
    '-num_comps[number of components (YUV)]:components'
    '-signed[signed samples per component (YUV/PFM)]:signed'
    '-bit_depth[bit depth per component (YUV/PFM)]:bit depth'
    '-downsamp[component downsampling {x,y},... (YUV)]:factor'
)

_arguments -s -S $arguments
