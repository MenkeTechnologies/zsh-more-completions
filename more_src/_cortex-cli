#compdef cortex-cli
# _cortex-cli — Cortex multi-tenant Prometheus CLI alias for cortextool (CNCF Cortex, Go); alecthomas/kingpin
# upstream: https://github.com/cortexproject/cortex-tools

_cortex-cli() {
    local -a sub=(
        'alertmanager:manage alertmanager configs'
        'alerts:check alerts'
        'rules:manage ruler rules'
        'remote-read:remote-read queries'
        'analyse:analyse metric usage'
        'commands:list all commands'
        'chunktool:manage chunks'
        'logtool:tail/inspect logs'
        'loadgen:generate load'
        'overrides-exporter:export overrides'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--address=+[cortex API address]:url:_urls' \
        '--id=+[tenant id]:str:' \
        '--key=+[api key]:str:' \
        '--user=+[user]:str:_users' \
        '--tls-ca-path=+[tls ca path]:file:_files' \
        '--tls-cert-path=+[tls cert path]:file:_files' \
        '--tls-key-path=+[tls key path]:file:_files' \
        '--log.level=+[log level]:level:(debug info warn error)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cortex subcommand' sub ;;
        args)
            case $words[1] in
                alertmanager) _arguments \
                    '1:cmd:(get load delete render verify migrate-utf8)' \
                    '*:file:_files -g "*.(yml|yaml)"' ;;
                rules) _arguments \
                    '1:cmd:(load list print get sync diff lint prepare check delete delete-namespace)' \
                    '*:file:_files -g "*.(yml|yaml)"' ;;
                analyse) _arguments \
                    '1:cmd:(prometheus grafana ruler dashboard)' \
                    '--address=+[address]:url:_urls' \
                    '--output=+[output]:file:_files' ;;
                chunktool) _arguments \
                    '1:cmd:(delete migrate clean tag clean-index)' \
                    '*:arg:' ;;
                logtool) _arguments \
                    '1:cmd:(tail query)' \
                    '*:arg:' ;;
                loadgen) _arguments \
                    '--write-concurrency=+[write concurrency]:n:' \
                    '--read-concurrency=+[read concurrency]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_cortex-cli "$@"
