#compdef doris doris-cli
# _doris — Apache Doris doris doris-cli CLI command-line frontend wrapping the Apache Doris real-time MPP-based analytical database for high-concurrency low-latency queries massively-parallel-processing managing frontends backends brokers databases tables users resources routines stream-broker-load materialized-views (Apache Doris team, Java); custom argparse
# upstream: https://doris.apache.org/

_doris() {
    local -a sub=(
        'login:authenticate'
        'sql:run SQL'
        'fe:frontend operations'
        'be:backend operations'
        'broker:broker operations'
        'database:database management'
        'table:table management'
        'user:user management'
        'role:role management'
        'resource:resource management'
        'partition:partition operations'
        'mv:materialized view management'
        'rollup:rollup operations'
        'stream-load:stream load operations'
        'broker-load:broker load operations'
        'routine-load:routine load operations'
        'export:export data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--fe-host=+[host]:_hosts' \
        '--fe-port=+[port]:n:' \
        '--user=+[user]:str:' \
        '-u+[user]:str:' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--database=+[name]:str:' \
        '-d+[database]:str:' \
        '--ssl[use SSL]' \
        '-e+[SQL]:str:' \
        '--execute=+[SQL]:str:' \
        '-f+[SQL file]:file:_files -g "*.sql"' \
        '--file=+[file]:file:_files -g "*.sql"' \
        '-o+[format]:f:(table tab csv tsv json yaml)' \
        '--output=+[format]:f:(table tab csv tsv json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doris subcommand' sub ;;
        args)
            case $words[1] in
                sql) _arguments '*:SQL:' ;;
                fe|be|broker|database|table|user|role|resource|mv|rollup|partition) _arguments '1:op:(list show add drop alter create delete enable disable)' '*:name:' ;;
            esac
            ;;
    esac
}

_doris "$@"
