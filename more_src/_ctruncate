#compdef ctruncate
# ctruncate — intensity to amplitude conversion and data statistics (CCP4)

local ret=1

_arguments -s -S \
  '-hklin[input MTZ]:file:_files -g "*.mtz"' \
  '-mtzin[input MTZ]:file:_files -g "*.mtz"' \
  '-hklout[output MTZ]:file:_files -g "*.mtz"' \
  '-mtzout[output MTZ]:file:_files -g "*.mtz"' \
  '-seqin[input sequence file]:file:_files' \
  '-colin[mean intensity column]:label:' \
  '-colano[anomalous data column]:label:' \
  '-colout[output column identifier]:label:' \
  '-nres[number of residues in ASU]:n:' \
  '-no-aniso[disable anisotropy correction]' \
  '-amplitudes[input is structure factors]' \
  '-comp[reference composition]:c:(nucleic)' \
  '-prior[force prior type]:p:(WILSON FLAT)' \
  '-freein[retain FreeR column]:label:' \
  '*:argument:_files' && ret=0

return ret
