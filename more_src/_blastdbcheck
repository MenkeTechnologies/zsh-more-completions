#compdef blastdbcheck
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK279684/
# Documentation: https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/LATEST/ (ncbi-blast-2.17.0+-src)
# Reference accessed: 2026-05-27
# Verified: upstream c++/src/app/blastdb/blastdbcheck.cpp (BLAST+ 2.17.0)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-db=[BLAST database name to check]:dbname:' \
  '-dbtype=[molecule type of database]:type:(nucl prot guess)' \
  '-dir=[directory containing one or more databases]:dir:_files -/' \
  '-recursive[recurse through all dbs in directory tree]' \
  '-logfile=[redirect output to this file]:file:_files' \
  '-verbosity=[verbosity level]:level:' \
  '-full[test every sequence (warning: may be slow)]' \
  '-stride=[check integrity of every Nth sequence]:n:' \
  '-random=[check this many randomly selected sequences]:n:' \
  '-ends=[check this many sequences at each end of the database]:n:' \
  '-no_isam[disable ISAM testing]' \
  '-legacy[enable check for existence of temporary files]' \
  '-must_have_taxids[require all sequences in the database to have taxid set]' \
  '-cdd_delta[additional tests for a CDD database for DELTA-BLAST]' && ret=0

return ret
