#compdef zoxide-cli
# Documentation: https://man.archlinux.org/search?q=zoxide-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a directory to the database'
  'edit:edit the database'
  'import:import entries from another tool'
  'init:print init script for shell'
  'query:search for a directory'
  'remove:remove a directory'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zoxide command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments '*: :_files -/' && ret=0 ;;
      (remove)
        _arguments '(-i --interactive)'{-i,--interactive}'[interactive]' '*: :_files -/' && ret=0 ;;
      (query)
        _arguments \
          '(-a --all)'{-a,--all}'[show all]' \
          '(-i --interactive)'{-i,--interactive}'[interactive selection]' \
          '(-l --list)'{-l,--list}'[list matches]' \
          '(-s --score)'{-s,--score}'[show scores]' \
          '(--exclude)*--exclude=[exclude path]:dir:_files -/' \
          '*: :' && ret=0 ;;
      (edit)
        _arguments \
          '1:subcommand:(add decrement delete increment)' \
          '*: :_files' && ret=0 ;;
      (import)
        _arguments \
          '--from=[source format]:f:(autojump z)' \
          '--merge[merge into existing db]' \
          '*: :_files' && ret=0 ;;
      (init)
        _arguments \
          '--cmd=[cmd name]:c:' \
          '--hook=[hook]:h:(none prompt pwd)' \
          '--no-aliases[no aliases]' \
          '--no-cmd[no cmd]' \
          '1:shell:(bash elvish fish nushell posix powershell xonsh zsh)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
