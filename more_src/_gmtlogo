#compdef gmtlogo
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtlogo.html
# Source: GenericMappingTools/gmt src/gmtlogo.c — plot the GMT logo (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[map projection]:projection:_default' \
    '-K[allow additional PS code later]' \
    '-O[append to existing PostScript]' \
    '-P[portrait orientation]' \
    '-R+[region]:region:_default' \
    '-S+[logo flavour]:flavour:(l n u)' \
    '-U+[plot timestamp]:options:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[shift x position]:shift:_default' \
    '-Y+[shift y position]:shift:_default' \
    '-c+[subplot panel]:panel:_default' \
    '-t+[transparency]:value:_default' \
    && ret=0

return ret
