#compdef fpm

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-s+[source type]:type:(dir rpm gem python pear deb tar npm cpan zip sh osxpkg pleaserun virtualenv empty pacman apk)' \
  '-t+[target type]:type:(deb rpm solaris freebsd tar dir sh osxpkg p5p puppet pacman apk zip cpan snap pleaserun virtualenv)' \
  '-n+[package name]:name' \
  '--name=[package name]:name' \
  '-v+[package version]:version' \
  '--version=[package version]:version' \
  '--iteration=[package iteration/release]:iteration' \
  '--epoch=[package epoch]:epoch' \
  '-a+[architecture]:arch:(native all noarch x86_64 i386 amd64 arm64 aarch64)' \
  '--architecture=[architecture]:arch:(native all noarch x86_64 i386 amd64 arm64 aarch64)' \
  '-d+[dependency]:dependency' \
  '--depends=[dependency]:dependency' \
  '--no-depends[do not list dependencies]' \
  '--no-auto-depends[do not auto-discover dependencies]' \
  '--provides=[provide capability]:capability' \
  '--conflicts=[conflict with package]:package' \
  '--replaces=[replace package]:package' \
  '--suggests=[suggest package]:package' \
  '--recommends=[recommend package]:package' \
  '-C+[change directory before searching for files]:directory:_directories' \
  '--chdir=[change directory]:directory:_directories' \
  '-p+[output package file]:file:_files' \
  '--package=[output package file]:file:_files' \
  '-f[force overwrite output]' \
  '--force[force overwrite output]' \
  '-m+[maintainer]:maintainer' \
  '--maintainer=[maintainer]:maintainer' \
  '--vendor=[vendor]:vendor' \
  '--category=[package category]:category' \
  '--license=[license]:license' \
  '--url=[package URL]:url' \
  '--description=[package description]:description' \
  '--config-files=[mark as config file]:file:_files' \
  '--directories=[mark as owned directory]:directory:_directories' \
  '--prefix=[install prefix]:prefix:_directories' \
  '--after-install=[post-install script]:file:_files' \
  '--before-install=[pre-install script]:file:_files' \
  '--after-remove=[post-remove script]:file:_files' \
  '--before-remove=[pre-remove script]:file:_files' \
  '--after-upgrade=[post-upgrade script]:file:_files' \
  '--before-upgrade=[pre-upgrade script]:file:_files' \
  '--template-scripts[use erb templates for scripts]' \
  '--template-value=[template variable]:key=value' \
  '--exclude=[exclude pattern]:pattern' \
  '--input-type=[override source type]:type' \
  '--output-type=[override target type]:type' \
  '-e[edit the spec before building]' \
  '--edit[edit the spec before building]' \
  '--workdir=[working directory]:directory:_directories' \
  '--no-dirs-permission[do not set directory permissions]' \
  '--log=[log level]:level:(error warn info debug)' \
  '--verbose[verbose output]' \
  '--debug[debug output]' \
  '*:source:_files'
