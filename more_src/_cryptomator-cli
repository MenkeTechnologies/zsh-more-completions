#compdef cryptomator-cli
# _cryptomator-cli — manage Cryptomator vaults from the command line (cryptomator/cli)
# upstream: https://github.com/cryptomator/cli
# Flags from src/main/java/org/cryptomator/cli/*.java (picocli).

_cryptomator-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose / debug logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'unlock:unlock and mount a vault'
                'create:create a new vault'
                'list-mounters:list available mount services'
                'help:show help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                unlock)
                    _arguments \
                        '--password\:stdin[read passphrase from STDIN]' \
                        '--password\:env=[env variable containing passphrase]:var:_parameters' \
                        '--password\:file=[file containing passphrase]:file:_files' \
                        '--mounter=[fully-qualified mount service class]:class:' \
                        '--mountPoint=[mount point path]:path:_files -/' \
                        '--volumeName=[virtual volume name]:name:' \
                        '--volumeId=[virtual volume id]:id:' \
                        '*'{--mountOption=,-mop+}'[additional mount option]:opt:' \
                        '--loopbackHostName=[loopback hostname]:name:' \
                        '--loopbackPort=[loopback port]:port:' \
                        '--maxCleartextNameLength=[max cleartext filename length]:n:' \
                        '1:vault directory:_files -/'
                    ;;
                create)
                    _arguments \
                        '--password\:stdin[read passphrase from STDIN]' \
                        '--password\:env=[env variable containing passphrase]:var:_parameters' \
                        '--password\:file=[file containing passphrase]:file:_files' \
                        '1:vault directory:_files -/'
                    ;;
            esac
            ;;
    esac
}

_cryptomator-cli "$@"
