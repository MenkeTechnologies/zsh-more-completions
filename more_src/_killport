#compdef killport
# Documentation: https://github.com/jkfran/killport
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for killport (jkfran/killport).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --mode)'{-m,--mode=}'[target mode]:mode:(auto process container)' \
  '(-s --signal)'{-s,--signal=}'[signal to send]:signal:' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*'{-q,--quiet}'[decrease verbosity]' \
  '--dry-run[preview what would be killed without terminating]' \
  '--no-fail[exit 0 even when nothing matches]' \
  '*:port number:'
