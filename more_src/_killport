#compdef killport

# Zsh completion for killport (jkfran/killport).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --mode)'{-m,--mode=}'[kill mode]:mode:(auto process container)' \
  '(-s --signal)'{-s,--signal=}'[signal name]:signal:(sigkill sigterm sigint sighup)' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-q --quiet)'{-q,--quiet}'[quiet logging]' \
  '--dry-run[show targets without killing]' \
  '--no-fail[succeed when nothing matches]' \
  '*:port number:'
