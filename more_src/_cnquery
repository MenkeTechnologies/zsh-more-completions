#compdef cnquery

# Zsh completion for cnquery (Mondoo infrastructure query)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'run:run an MQL query'
  'shell:interactive MQL shell'
  'scan:scan a target'
  'login:log in to Mondoo Platform'
  'logout:log out of Mondoo Platform'
  'status:show cnquery status and configuration'
  'vault:manage vault configuration'
  'providers:manage and list providers'
  'version:display version information'
)

_arguments -s -S \
  '1:subcommand:->subcommand' \
  '--config=[path to config file]:config file:_files' \
  '--log-level=[set log level]:log level:(error warn info debug trace)' \
  '(-o --output)'{-o,--output=}'[set output format]:output format:(compact full json csv yaml)' \
  '(-t --target)'{-t,--target=}'[target to query (e.g. ssh://user@host)]:target:' \
  '(-c --command)'{-c,--command=}'[MQL query string to execute]:MQL query:' \
  '--platform-id=[platform identifier]:platform id:' \
  '--sudo[elevate privileges using sudo]' \
  '--record=[record session to file]:record file:_files' \
  '*:file:_files' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
esac

return ret
