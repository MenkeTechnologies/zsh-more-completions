#compdef cargo-shuttle

_cargo-shuttle_subcommands() {
  local -a subcmds=(
    'init:Create a new Shuttle project'
    'run:Run a Shuttle service locally'
    'deploy:Deploy a Shuttle service'
    'deployment:Manage deployments'
    'status:Show status of a Shuttle service'
    'stop:Stop a running Shuttle service'
    'restart:Restart a Shuttle service'
    'delete:Delete a Shuttle project'
    'logs:View logs of a Shuttle service'
    'project:Manage Shuttle projects'
    'resource:Manage Shuttle resources'
    'secrets:Manage secrets'
    'clean:Remove Shuttle build artifacts'
    'login:Log in to Shuttle'
    'logout:Log out of Shuttle'
    'generate:Generate shell completions'
    'feedback:Open feedback page'
  )
  _describe -t commands 'cargo-shuttle subcommand' subcmds
}

_cargo-shuttle() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '--api-url[URL of the Shuttle API]:url:' \
    '--api-key[Shuttle API key]:key:' \
    '--working-directory[Set working directory]:dir:_directories' \
    '--name[Specify project name]:name:' \
    '1:subcommand:_cargo-shuttle_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        init)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--template[Template to use]:template:(actix-web axum poem poise rocket salvo serenity thruster tide tower warp none)' \
            '--no-git[Do not initialize git repository]' \
            '1:path:_directories'
          ;;
        deploy)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--allow-dirty[Deploy with uncommitted changes]' \
            '--no-test[Skip tests before deploying]' \
            '--secret[Set secrets]:secret:'
          ;;
        run)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--port[Port to run on]:port:' \
            '--external[Allow external connections]' \
            '--release[Build in release mode]' \
            '--secret[Set secrets]:secret:'
          ;;
        logs)
          _arguments \
            '(- *)'{-h,--help}'[Show help message]' \
            '--follow[Follow log output]' \
            '--latest[Show latest deployment logs]' \
            '--id[Deployment ID]:id:' \
            '--raw[Show raw log output]'
          ;;
        project)
          _arguments \
            '1:action:(start status stop restart delete list)' \
            '--idle-minutes[Idle timeout in minutes]:minutes:'
          ;;
        resource)
          _arguments \
            '1:action:(list delete)' \
            '--show-secrets[Show secret values]'
          ;;
      esac
      ;;
  esac
}

_cargo-shuttle "$@"
