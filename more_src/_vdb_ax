#compdef vdb_ax
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/vdb_ax.1.html
# OpenVDB: process OpenVDB data using AX

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output with timing details]' \
  '*-i+[append an input vdb file to be read]:vdb file:_files -g "*.vdb"' \
  '-s+[input code to execute as a string]:code' \
  '-f+[input code to execute from a file]:file:_files' \
  '-o+[write the result to a vdb file]:vdb file:_files -g "*.vdb"' \
  '--opt=[compilation optimization level]:level:(NONE O0 O1 O2 Os Oz O3)' \
  '--threads=[number of threads to use, 0 uses all]:n' \
  '--werror[treat warnings as errors]' \
  '--max-errors=[maximum error messages, 0 allows all]:n' \
  '--copy-file-metadata[copy metadata from the first input file]' \
  '--create-missing=[auto-create missing volumes or point attributes]:val:(ON OFF)' \
  '--tree-level=[node levels to process l1 or l1:l2]:levels' \
  '--node-iter=[active node types]:iter:(ON OFF ALL)' \
  '--tile-stream=[control tile streaming behavior]:val:(ON OFF AUTO)' \
  '--volume-grain=[volume threading grain size g1 or g1:g2]:grain' \
  '--group=[point group to process]:name' \
  '--points-grain=[point threading grain size]:n' \
  '--bindings=[map ax names to volume or point attribute names]:bindings' \
  '--ast-print[print the abstract syntax tree]' \
  '--re-print[re-interpreted print of the code post traversal]' \
  '--reg-print[print the attribute registry]' \
  '--try-compile=[attempt compilation]:target:(points volumes)' \
  '--list=[list functions with documentation]:filter' \
  '--list-names[list function names only]' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    _values 'command' 'execute[read, process and write VDB]' 'analyze[parse code and run analysis]' 'functions[list available AX functions]' && ret=0
    ;;
esac

return ret
