#compdef zkCli.sh zookeeper-cli zkCli
# _zookeeper-cli — Apache ZooKeeper CLI (interactive REPL talking to the ZK ensemble; -server connection host:port, -timeout seconds, -r read-only mode; once inside: ls, ls2, get, set, create, delete, rmr, stat, addauth, getAcl, setAcl, redo, history, quit)
# upstream: https://github.com/apache/zookeeper
# Subcommands from Apache ZooKeeper zookeeper-server/zkCli.sh on tip.

_zookeeper-cli() {
    _arguments \
        '-h[show help]' \
        '-server+[host:port]:server:_hosts' \
        '-timeout+[seconds]:seconds:' \
        '-r[read-only]' \
        '-jaas+[JAAS config]:file:_files' \
        '-zkconfig+[zk config file]:file:_files' \
        '-cnxn+[connection string]:string:' \
        '*::command:'
}

_zookeeper-cli "$@"
