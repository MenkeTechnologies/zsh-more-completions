#compdef region
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/region/node11.html
# Create source/background region definition files for product extraction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--eventset=[reference event file establishing the coordinate system]:file:_files' \
  '--tempset=[temporary dataset for the filtered source list]:file:_files' \
  '--srclisttab=[FITS table of sources to be processed]:table' \
  '--expression=[selection expression to filter the source list]:expr' \
  '--operationstyle=[processing mode]:mode:(single batch global)' \
  '--usersrcid=[row number for single-mode region construction]:n' \
  '--srcidcol=[column with unique source IDs for batch mode]:column' \
  '--shrinkconfused=[shrink extraction regions until non-overlapping]:bool:(yes no)' \
  '--radiusstyle=[method for region size calculation]:style:(userfixed enfrac contour)' \
  '--fixedradius=[fixed radius in arcseconds for userfixed mode]:value' \
  '--energyfraction=[energy fraction (0-1) for PSF-based radius]:value' \
  '--bkgratestyle=[method for specifying local background level]:style' \
  '--bkgratecol=[column with background flux values]:column' \
  '--bkgrateuser=[user-specified background flux value]:value' \
  '--bkgfraction=[multiplier for background flux threshold]:value' \
  '--nosrcellipse=[convert elliptical source regions to circles]:bool:(yes no)' \
  '--fovbkgannulus=[center background annuli about the optic axis]:bool:(yes no)' \
  '--outunit=[output coordinate system]:unit:(detxy xy)' \
  '--nobkgellipse=[prevent circular background annuli to ellipses]:bool:(yes no)' \
  '--regionset=[dataset for source extraction regions]:file:_files' \
  '--bkgregionset=[dataset for background extraction regions]:file:_files' \
  '*:param=value:_default' && ret=0

return ret
