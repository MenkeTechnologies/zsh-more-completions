#compdef lemurs
# Documentation: https://man.archlinux.org/search?q=lemurs
# Reference accessed: 2026-05-16

# Zsh completion for lemurs (TUI display/login manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[configuration file path]:config file:_files' \
  '--no-log[disable logging]' && ret=0

return ret
