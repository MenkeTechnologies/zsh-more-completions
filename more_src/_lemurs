#compdef lemurs
# Documentation: https://github.com/coastalwhite/lemurs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lemurs (TUI display/login manager).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[alternative configuration file]:config file:_files' \
  '--variables=[alternative variables file]:variables file:_files' \
  '--no-log[disable logging]' \
  '--show-config[print all settings including defaults in TOML]' \
  '--preview[run preview instance to test UI]' && ret=0

return ret
