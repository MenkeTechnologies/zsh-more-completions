#compdef bun-cli
# _bun-cli — Oven Bun JavaScript runtime + bundler + package manager CLI alias (Oven / Jarred Sumner, Zig); cac
# upstream: https://github.com/oven-sh/bun

_bun-cli() {
    local -a sub=(
        'add:add a dependency'
        'a:add a dependency (alias)'
        'audit:run audit'
        'bun:run bun script'
        'build:bundle for production'
        'create:scaffold from template'
        'completions:install completions'
        'discord:join discord'
        'help:show help'
        'i:install dependencies'
        'init:scaffold package.json'
        'install:install dependencies'
        'link:symlink package globally'
        'unlink:remove global symlink'
        'outdated:show outdated deps'
        'pm:package manager helpers'
        'publish:publish to npm'
        'remove:remove dependency'
        'rm:remove dependency (alias)'
        'repl:run interactive REPL'
        'run:run a script or file'
        'test:run tests'
        'update:update packages'
        'upgrade:upgrade bun itself'
        'why:explain why dependency is installed'
        'x:exec a binary (bunx)'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--revision[show revision]' \
        '--cwd=+[change cwd]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--silent[silent]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bun subcommand' sub ;;
        args)
            case $words[1] in
                add|a) _arguments \
                    '--dev[dev dependency]' \
                    '-d[dev dependency]' \
                    '--peer[peer dependency]' \
                    '--optional[optional dependency]' \
                    '--exact[exact version]' \
                    '-E[exact version]' \
                    '--global[global install]' \
                    '-g[global install]' \
                    '--registry=+[registry]:url:_urls' \
                    '*:package:' ;;
                run) _arguments \
                    '--watch[watch]' \
                    '--hot[hot reload]' \
                    '--smol[smol mode]' \
                    '--inspect=+[inspect host:port]:str:' \
                    '--bun[force run with Bun]' \
                    '*:script:_files' ;;
                build) _arguments \
                    '--entrypoints=+[entrypoints]:list:_files' \
                    '--outdir=+[output dir]:dir:_files -/' \
                    '--outfile=+[output file]:file:_files' \
                    '--minify[minify]' \
                    '--sourcemap=+[sourcemap]:m:(none linked inline external)' \
                    '--target=+[target]:t:(browser bun node)' \
                    '--format=+[format]:f:(esm cjs iife)' \
                    '--external=+[external module]:list:' \
                    '--public-path=+[public path]:str:' \
                    '--asset-naming=+[asset naming template]:str:' \
                    '--entry-naming=+[entry naming template]:str:' \
                    '--chunk-naming=+[chunk naming template]:str:' \
                    '--splitting[code splitting]' \
                    '--root=+[root dir]:dir:_files -/' \
                    '--banner=+[banner]:str:' \
                    '--footer=+[footer]:str:' \
                    '--define=+[define key=value]:list:' \
                    '*:input:_files' ;;
                test) _arguments \
                    '--watch[watch mode]' \
                    '--coverage[coverage]' \
                    '--coverage-reporter=+[coverage reporter]:r:(text lcov)' \
                    '--coverage-dir=+[coverage dir]:dir:_files -/' \
                    '--update-snapshots[update snapshots]' \
                    '--rerun-each=+[rerun each]:n:' \
                    '--reporter=+[reporter]:r:(default tap junit)' \
                    '--reporter-outfile=+[reporter outfile]:file:_files' \
                    '--bail=+[bail after N]:n:' \
                    '--only[only mode]' \
                    '--todo[todo mode]' \
                    '--timeout=+[timeout ms]:n:' \
                    '*:pattern:' ;;
                create) _arguments \
                    '1:template:' \
                    '*:project-name:' ;;
                install|i) _arguments \
                    '--frozen-lockfile[frozen lockfile]' \
                    '--no-save[no save]' \
                    '--save[save]' \
                    '--production[production]' \
                    '--no-optional[no optional]' \
                    '--no-progress[no progress]' \
                    '--registry=+[registry]:url:_urls' ;;
                pm) _arguments \
                    '1:cmd:(bin hash hash-string ls migrate cache trust untrust default-trusted whoami pack)' \
                    '*:arg:' ;;
                completions) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_bun-cli "$@"
