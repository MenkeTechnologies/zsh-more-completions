#compdef M2-binary
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/M2-binary.1.html
# M2-binary - Macaulay2 executable (algebraic geometry / commutative algebra)

local ret=1

_arguments -s -S \
  '--help[print brief help message and exit]' \
  '--version[print version number and exit]' \
  '--copyright[display full copyright message]' \
  '--script[interpret second argument as script name]' \
  '--stop[exit on error]' \
  '--silent[no startup banner]' \
  '--texmacs[TeXmacs session mode]' \
  '--no-backtrace[print no backtrace after error]' \
  '--no-debug[do not enter debugger upon error]' \
  '--debug[debug warning message n by signalling an error]:n' \
  '--int[do not handle interrupts]' \
  '--notify[notify when loading files during initialization]' \
  '--no-prompts[print no input prompts]' \
  '--no-readline[do not use readline]' \
  '--no-core[do not load the Core]' \
  '--no-threads[do not start any additional threads or tasks]' \
  '--prefix[set prefixDirectory]:dir:_files -/' \
  '--print-width[set printWidth=n]:n' \
  '-q[do not load init.m2 or use packages in home directory]' \
  "-E[evaluate expression before initialization]:expr" \
  "-e[evaluate expression after initialization]:expr" \
  '*:file:_files' && ret=0

return ret
