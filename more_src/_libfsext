#compdef fsextinfo fsextmount
# _libfsext — libfsext tools (libyal Linux ext2/ext3/ext4 parser; fsextinfo dumps superblock + group descriptors + inode tables, fsextmount FUSE-mounts the filesystem read-only; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E inode filter, -F path filter, -X exclusive; positional argument is the ext image)
# upstream: https://github.com/libyal/libfsext
# Flags from libyal/libfsext fsexttools/fsextinfo.c on tip.

_libfsext() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[inode filter]:inode:' \
        '-F+[path filter]:path:' \
        '-X[exclusive]' \
        '*:ext image:_files'
}

_libfsext "$@"
