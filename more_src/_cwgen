#compdef cwgen

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --groups)'{-n,--groups}'+[number of groups]:n:' \
  '(-g --groupsize)'{-g,--groupsize}'+[group size]:n:' \
  '(-r --groupsize-random)'{-r,--groupsize-random}'+[random groupsize]:range:' \
  '(-c --charset)'{-c,--charset}'+[character set]:set:' \
  '(-x --charsetlist)'{-x,--charsetlist}'[list character sets]' && ret=0

return ret
