#compdef airflowctl
# Documentation: https://github.com/kaxil/airflowctl
# Source: kaxil/airflowctl — Apache Airflow project manager (archived 2025-04-30).
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _afc_cmds
_afc_cmds=(
    'init:initialize a new Airflow project'
    'build:create venv and install dependencies'
    'start:launch Airflow webserver and scheduler services'
    'stop:halt running Airflow services'
    'logs:show live logs of background processes'
    'list:enumerate all tracked Airflow projects'
    'info:display project configuration details'
    'airflow:passthrough subsequent args to the underlying Airflow CLI'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'airflowctl command' _afc_cmds && ret=0
        ;;
    args)
        case $line[1] in
            airflow)
                _arguments -s -S '*:airflow args:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
