#compdef convex

# Zsh completion for convex - Convex backend platform CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--project=[project slug]:project' \
  '--team=[team slug]:team' \
  '--prod[target production deployment]' \
  '--admin-key=[admin key]:key' \
  '--url=[deployment URL]:url' \
  '--debug[enable debug output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'dev:start development server'
      'deploy:deploy to production'
      'codegen:generate code'
      'data:manage data'
      'env:manage environment variables'
      'dashboard:open dashboard'
      'auth:manage authentication'
      'init:initialize project'
      'logs:view logs'
      'run:run a function'
      'import:import data'
      'export:export data'
      'type-check:run type checking'
    )
    _describe -t commands 'convex command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      dev)
        _arguments -s -S \
          '--once[run once and exit]' \
          '--run=[function to run]:function' \
          '--tail-logs[tail logs]' \
          '--until-success[retry until success]' \
          '--clear[clear all tables]' \
          '--typecheck=[typecheck mode]:mode:(enable try disable)' \
          '--codegen=[codegen mode]:mode:(enable disable)' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '--cmd=[command to run after deploy]:command' \
          '--codegen=[codegen mode]:mode:(enable disable)' \
          '--typecheck=[typecheck mode]:mode:(enable try disable)' \
          '--dry-run[dry run without deploying]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--watch[watch for changes]' \
          '--push[push code before running]' \
          '--component=[component path]:component' \
          '1:function path' && ret=0
        ;;
      env)
        local -a env_cmds=(
          'get:get an environment variable'
          'set:set an environment variable'
          'list:list environment variables'
          'remove:remove an environment variable'
        )
        _describe -t commands 'env subcommand' env_cmds && ret=0
        ;;
      data)
        local -a data_cmds=(
          'export:export data'
          'import:import data'
        )
        _describe -t commands 'data subcommand' data_cmds && ret=0
        ;;
      auth)
        local -a auth_cmds=(
          'login:log in'
          'logout:log out'
        )
        _describe -t commands 'auth subcommand' auth_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
