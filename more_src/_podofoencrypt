#compdef podofoencrypt
# encrypt PDF files and set PDF security settings

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--rc4v1[use rc4v1 encryption]' \
  '--rc4v2[use rc4v2 encryption (default)]' \
  '--aes[use aes encryption (currently not supported)]' \
  '-u+[optional user password]:user password' \
  '-o+[required owner password]:owner password' \
  '--print[allow printing the document]' \
  '--edit[allow modification besides annotations, form fields or pages]' \
  '--copy[allow extraction of text and graphics]' \
  '--editnotes[add or modify text annotations or form fields]' \
  '--fillandsign[fill in existing form or signature fields]' \
  '--accessible[extract text and graphics for accessibility]' \
  '--assemble[insert, create, rotate, delete pages or add bookmarks]' \
  '--highprint[print a high resolution version of the document]' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
