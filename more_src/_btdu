#compdef btdu

# Zsh completion for btdu - btrfs disk usage profiler

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-r[resolution for block groups]:resolution:' \
  '--resolution[resolution for block groups]:resolution:' \
  '-s[number of samples per resolution]:samples:' \
  '--samples[number of samples per resolution]:samples:' \
  '-p[path to the btrfs filesystem root]:path:_files -/' \
  '--path[path to the btrfs filesystem root]:path:_files -/' \
  '--snap[analyze snapshots]' \
  '--no-snap[do not analyze snapshots]' \
  '1:btrfs mount point:_files -/' && return 0
