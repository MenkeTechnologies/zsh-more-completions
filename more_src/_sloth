#compdef sloth
# Documentation: https://man.archlinux.org/search?q=sloth
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '1:command:(generate validate)' \
  '(-i)'{-i}'=[Input SLO spec]:file:_files' \
  '(-o)'{-o}'=[Output rules file]:file:_files' \
  '*::args: _default'
