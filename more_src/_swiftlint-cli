#compdef swiftlint-cli
# _swiftlint-cli — Realm SwiftLint Swift style and conventions linter CLI alias (Realm, Swift); custom argparse
# upstream: https://github.com/realm/SwiftLint

_swiftlint-cli() {
    local -a sub=(
        'analyze:run analyze rules requiring compiler logs'
        'baseline:work with baseline files'
        'docs:open SwiftLint documentation'
        'generate-docs:generate docs for rules'
        'lint:lint sources (default)'
        'rules:list rules'
        'reporters:list reporters'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".swiftlint.yml *.yml"' \
        '-c+[config file]:file:_files -g ".swiftlint.yml *.yml"' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '--no-cache[no cache]' \
        '--enable-all-rules[enable all rules]' \
        '--strict[strict (warnings = errors)]' \
        '--lenient[lenient (errors = warnings)]' \
        '--quiet[quiet]' \
        '--silent[silent]' \
        '--reporter=+[reporter]:r:(xcode json csv checkstyle codeclimate emoji github-actions-logging gitlab html junit markdown relative-path sarif sonarqube summary)' \
        '--baseline=+[baseline file]:file:_files' \
        '--write-baseline=+[write baseline file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--in-process-sourcekit[use in-process sourcekit]' \
        '--use-script-input-files[use script input files]' \
        '--use-tty[use tty]' \
        '--force-exclude[force exclude]' \
        '--no-force-exclude[no force exclude]' \
        '--fix[auto-fix violations]' \
        '--format[format files]' \
        '--auto-correct[auto correct]' \
        '--use-alternative-excluding[use alternative excluding]' \
        '--use-stdin[read sources from stdin]' \
        '--progress[show progress]' \
        '--no-progress[no progress]' \
        '--legacy[legacy mode]' \
        '--working-directory=+[working dir]:dir:_files -/' \
        '--check-for-updates[check for updates]' \
        '--compiler-log-path=+[compiler log path]:file:_files' \
        '--compile-commands=+[compile commands]:file:_files -g "compile_commands.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swiftlint subcommand' sub
            _files ;;
        args)
            case $words[1] in
                lint|analyze|baseline) _arguments '*:path:_files' ;;
                rules) _arguments \
                    '--config=+[config]:file:_files' \
                    '--enabled[show enabled only]' \
                    '-e[show enabled only]' \
                    '--disabled[show disabled only]' \
                    '-d[show disabled only]' \
                    '--correctable[show correctable rules]' \
                    '-c[show correctable rules]' \
                    '*:rule:' ;;
                generate-docs) _arguments \
                    '--path=+[path]:dir:_files -/' \
                    '--rules=+[rules]:str:' ;;
                docs|reporters) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_swiftlint-cli "$@"
