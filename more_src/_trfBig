#compdef trfBig
# UCSC kent: mask tandem repeats on a big sequence file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-bed[create a bed file in current dir]' \
  '-bedAt=[create a bed file at explicit location]:file:_files' \
  '-tempDir=[where to put temp files]:dir:_files -/' \
  '-trf=[explicitly specify trf executable name]:exe:_command_names' \
  '-maxPeriod=[maximum period size of repeat]:n:' \
  '-keep[don'\''t delete tmp files]' \
  '-l=[maximum TR length expected in millions]:n:' \
  ':in file:_files' \
  ':out file:_files' && ret=0

return ret
