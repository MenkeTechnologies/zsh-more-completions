#compdef mqttwarn
# ============================================================================
#  _mqttwarn — Highly configurable MQTT message router with notification
#              plugins, written in Python
#
#  Source-direct extraction from
#    https://github.com/mqtt-tools/mqttwarn/blob/main/mqttwarn/commands.py
#    https://github.com/docopt/docopt (the docopt library)
#
#  Maintained by the mqtt-tools org (mqtt-tools/mqttwarn).  974 GH stars.
#  Subscribes to MQTT topics, routes messages to NOTIFICATION PLUGINS
#  (HTTP webhooks, Slack/Discord/Telegram, email, syslog, file writes,
#  custom user-defined functions, etc.).  Configured via INI file or
#  JSON inline.  Sister tools: home-assistant (in corpus), node-red
#  (in corpus), mosquitto (in corpus, the MQTT broker).
#
#  CLI library taxonomy update: 5th Python CLI library — Vladimir
#  Keleshev's docopt.  Python ecosystem now has 5 documented CLI
#  libraries (argparse + click + fire + cyclopts + docopt) — Python now
#  TIED with Go (7) and Rust (9) below it but ahead of Crystal/OCaml/
#  Java/TypeScript (4 each) in documented-library count.  docopt is
#  fundamentally different from every other CLI library documented:
#
#    THE CLI SPECIFICATION IS THE DOCSTRING ITSELF.
#
#  docopt parses the function's `__doc__` STRING to derive the spec,
#  then matches argv against the spec.  The docstring is FORMATTED in
#  a specific grammar inspired by classical man-page Usage: + Options:
#  conventions:
#    Usage:                          (literal header)
#      progname COMMAND [--flag]     (usage lines)
#      progname --version
#      progname (-h | --help)
#    Options:                        (literal header)
#      --flag                        (option list with descriptions)
#  Conventions: `[]` optional, `<>` positional placeholder, `|`
#  alternatives, `...` repeat, `--` end-of-options marker.
#
#  After parsing, docopt returns a DICT keyed by literal flag/command/
#  positional name from the docstring — caller accesses parsed values
#  via `options["--config"]`, `options["make-config"]`, etc.
#
#  Distinct from:
#    - R-? argparse (procedural builder, no docstring parsing)
#    - R-? click (decorator-based, no docstring parsing)
#    - R-? fire (auto-CLI from function/class signature)
#    - R345 cyclopts (PEP 593 Annotated[] + docstring help)
#  docopt is the only CLI library where the DOCSTRING IS THE PARSER
#  SPEC — caller writes Usage:/Options: in plain text and docopt
#  derives the parser from it.  Inspires implementations in many other
#  languages (docopt.go, docopt-rs, docopt-cs, etc.).  Brings cross-
#  language CLI library taxonomy variant count to 91.
#
#  Surface (verbatim from mqttwarn/commands.py `run.__doc__`):
#
#  Default action (no args):
#    mqttwarn                     Start as MQTT subscriber service
#
#  Bootstrapping commands:
#    mqttwarn make-config         Dump basic configuration blueprint
#                                 to STDOUT (redirect into mqttwarn.ini)
#    mqttwarn make-udf            Dump user-defined-functions blueprint
#                                 to STDOUT (redirect into udf.py)
#
#  Interactive flags:
#    --config=JSON                Use config settings from JSON string
#    --config-file=PATH           Use config settings from INI/JSON file
#    --plugin=NAME                Load plugin (full Python path or file)
#    --options=JSON               Configuration options for plugin entrypoint
#    --data=JSON                  Data to propagate to plugin entrypoint
#
#  Miscellaneous:
#    --version                    Show version information
#    -h, --help                   Show usage screen
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - jedi (davidhalter/jedi — IN CORPUS; uses docopt internally in
#      sith.py helper, not main CLI)
#    - mqttwarn sister tools: most other MQTT tools use argparse or click
# ============================================================================

_mqttwarn() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show usage screen]' \
    '--version[show version information]' \
    '--config=[JSON config string]:JSON config' \
    '--config-file=[INI/JSON config file]:file:_files -g "*.{ini,json,yml,yaml}"' \
    '--plugin=[plugin to load (Python path or file)]:plugin' \
    '--options=[JSON options for plugin entrypoint]:JSON options' \
    '--data=[JSON data to propagate to plugin]:JSON data' \
    '1: :->cmd'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'make-config:dump configuration blueprint to STDOUT'
        'make-udf:dump user-defined-functions blueprint to STDOUT'
      )
      _describe -t commands 'mqttwarn command' verbs
      ;;
  esac
}

_mqttwarn "$@"
