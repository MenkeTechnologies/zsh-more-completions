#compdef apfel
# Documentation: https://man.archlinux.org/search?q=apfel
# Reference accessed: 2026-05-16

# Zsh completion for apfel Apple on-device LLM server CLI

_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '--serve[run server]' \
  '--no-color[disable color]' \
  '--model-info[print model metadata]' \
  '*:: : _message "see apfel --help"' && ret=0

return ret
