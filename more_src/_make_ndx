#compdef make_ndx gmx-make_ndx
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-make_ndx.html
# Create and edit special index groups needed by GROMACS programs

local ret=1

_arguments -s -S \
  '-f+[structure file]:structure:_files -g "*.(gro|g96|pdb|brk|ent|esp|tpr)"' \
  '*-n+[index file(s)]:index file:_files -g "*.ndx"' \
  '-o+[output index file]:index file:_files -g "*.ndx"' \
  '-natoms+[number of atoms]:n:' \
  '-twin[duplicate index groups with offset for electrophysiology]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
