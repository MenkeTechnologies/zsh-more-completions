#compdef lxqt-leave
# Documentation: https://man.archlinux.org/search?q=lxqt-leave
# Reference accessed: 2026-05-16

# lxqt-leave: LXQt logout / power dialog
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '--logout[ask to logout (no dialog)]' \
  '--shutdown[ask to shutdown (no dialog)]' \
  '--reboot[ask to reboot (no dialog)]' \
  '--lockscreen[lock the screen]' \
  '--suspend[suspend the system]' \
  '--hibernate[hibernate the system]' \
  '*::lxqt-leave args:_files' && ret=0
return ret
