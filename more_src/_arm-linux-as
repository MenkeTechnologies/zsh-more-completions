#compdef arm-linux-as arm-linux-gnueabi-as arm-linux-gnueabihf-as
# _arm-linux-as — GNU binutils arm-linux-as CLI cross-arch GAS assembler for ARMv7 ARMv6 ARMv5 little-endian Linux Cortex-A Cortex-R Cortex-M producing ELF object files supporting Thumb-2 NEON VFPv3 VFPv4 mfloat-abi mfpu march mcpu syntax with macro preprocessing for ARM assembly source (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_arm-linux-as() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-J[no warnings about signed overflow]' \
        '-K[allow modify .word section]' \
        '-W[suppress warnings]' \
        '--no-warn[suppress warnings]' \
        '--fatal-warnings[treat warnings as errors]' \
        '--warn[issue warnings]' \
        '-Z[generate object file even after errors]' \
        '-I+[include path]:dir:_files -/' \
        '-L[keep local symbols]' \
        '--keep-locals[keep local symbols]' \
        '-o+[output object]:file:_files -g "*.o *.elf"' \
        '-R[fold data section into text section]' \
        '--statistics[print statistics]' \
        '-g[generate debug info]' \
        '--gen-debug[generate debug info]' \
        '--gstabs[generate stabs debug]' \
        '--gdwarf-2[generate DWARF2]' \
        '--gdwarf-3[generate DWARF3]' \
        '--gdwarf-4[generate DWARF4]' \
        '--gdwarf-5[generate DWARF5]' \
        '-mcpu=+[cpu]:c:(arm7 arm9 cortex-a5 cortex-a7 cortex-a8 cortex-a9 cortex-a15 cortex-a17 cortex-a35 cortex-a53 cortex-a55 cortex-a57 cortex-a72 cortex-a73 cortex-a75 cortex-a76 cortex-r4 cortex-r5 cortex-r7 cortex-r8 cortex-m0 cortex-m3 cortex-m4 cortex-m7 cortex-m33 cortex-m55)' \
        '-march=+[arch]:a:(armv4 armv5 armv5t armv5te armv5tej armv6 armv6-m armv7 armv7-a armv7-r armv7-m armv7e-m armv7ve armv8-a armv8.1-a armv8.2-a)' \
        '-mfpu=+[fpu]:f:(vfp vfpv3 vfpv3-d16 vfpv4 neon neon-vfpv4 neon-fp16 fpv5-sp-d16 fpv5-d16 neon-fp-armv8 none)' \
        '-mfloat-abi=+[abi]:a:(soft softfp hard)' \
        '-mthumb[assemble Thumb code]' \
        '-mno-thumb[no Thumb code]' \
        '-EL[little endian]' \
        '-EB[big endian]' \
        '-msyntax=+[syntax]:s:(unified divided)' \
        '*:assembly file:_files -g "*.s *.S *.asm"'
}

_arm-linux-as "$@"
