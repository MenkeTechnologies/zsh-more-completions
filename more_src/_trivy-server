#compdef trivy-server
# _trivy-server — Aqua Trivy client/server-mode server subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-server() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--timeout=+[timeout]:dur:' \
        '--listen=+[listen address]:addr:' \
        '--token=+[server token]:str:' \
        '--token-header=+[server token header]:str:' \
        '--cache-backend=+[cache backend]:str:' \
        '--cache-ttl=+[cache ttl]:dur:' \
        '--db-repository=+[db repo]:str:' \
        '--java-db-repository=+[java db repo]:str:' \
        '--skip-db-update[skip db update]' \
        '--skip-java-db-update[skip java db update]' \
        '--download-db-only[download db only]' \
        '--download-java-db-only[download java db only]' \
        '--no-progress[no progress]' \
        '*:arg:'
}

_trivy-server "$@"
