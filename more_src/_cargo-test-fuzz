#compdef cargo-test-fuzz
# Documentation: https://man.archlinux.org/search?q=cargo-test-fuzz
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--backtrace)--backtrace[show backtrace]' \
  '(--build-targets)--build-targets[build targets]' \
  '(--consolidate)--consolidate[consolidate corpora]' \
  '(--corpus-dir)--corpus-dir=[corpus dir]:dir:_files -/' \
  '(--cwd)--cwd[cwd]' \
  '(--display)--display=[display kind]:k:(corpus crashes hangs queue work-queue)' \
  '(--exact)--exact[exact match]' \
  '(--exit-code)--exit-code[exit code]' \
  '(--features)--features=[features csv]:list:' \
  '(--all-features)--all-features[all features]' \
  '(--no-default-features)--no-default-features[no default features]' \
  '(--list)--list[list]' \
  '(--manifest-path)--manifest-path=[manifest]:file:_files -g "*.toml"' \
  '(--no-instrumentation)--no-instrumentation[no instrumentation]' \
  '(--no-run)--no-run[no run]' \
  '(--no-ui)--no-ui[no UI]' \
  '(-p --package)*'{-p+,--package=}'[package]:p:' \
  '(--persistent)--persistent[persistent]' \
  '(--pretty-print)--pretty-print[pretty print]' \
  '(--release)--release[release]' \
  '(--replay)--replay=[replay kind]:k:(corpus crashes hangs queue)' \
  '(--reset)--reset[reset corpus]' \
  '(--resume)--resume[resume]' \
  '(--run-until-crash)--run-until-crash[run until crash]' \
  '(--target-dir)--target-dir=[target dir]:dir:_files -/' \
  '(--test)--test=[test]:t:' \
  '(--test-args)--test-args=[args]:a:' \
  '(--timeout)--timeout=[timeout s]:s:' \
  '(-v --verbose)*'{-v,--verbose}'[verbose]' \
  '*: :' && ret=0

return ret
