#compdef cargo-test-fuzz
# Documentation: https://github.com/trailofbits/test-fuzz
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--backtrace[show backtrace]' \
  '--consolidate[consolidate crashes/hangs into corpus]' \
  '--consolidate-all[consolidate all targets]' \
  '--coverage=[generate coverage metrics]:object:(corpus crashes hangs queue work-queue)' \
  '--cpus=[limit CPU usage]:n:' \
  '--display=[display object kind]:k:(corpus crashes generic-args impl-generic-args hangs work-queue)' \
  '--exact[treat target name as exact match]' \
  '--exit-code[exit 0 on time-limit, 1 on programmatic abort, 2 on error]' \
  '--features=[features csv]:list:' \
  '--all-features[enable all features]' \
  '--no-default-features[disable default features]' \
  '--list[list available fuzz targets]' \
  '--manifest-path=[Cargo.toml]:file:_files -g "*.toml"' \
  '--max-total-time=[fuzzing duration limit (s)]:s:' \
  '--no-run[compile without executing fuzzing]' \
  '--no-ui[suppress user interface]' \
  '(-p --package)'{-p+,--package=}'[package containing fuzz target]:package:' \
  '--persistent[enable persistent mode]' \
  '--pretty[pretty-print debug output]' \
  '--release[build optimized]' \
  '--replay=[replay stored test cases]:object:(corpus crashes hangs queue work-queue)' \
  '--reset[reset fuzzing data preserving corpus]' \
  '--reset-all[reset all targets]' \
  '--resume[resume previous session]' \
  '--run-until-crash[stop on first crash]' \
  '--slice=[interval for sequential target fuzzing (s)]:s:' \
  '--test=[integration test name]:t:' \
  '--timeout=[hang detection threshold (s)]:s:' \
  '--verbose[show build output]' \
  '*: :' && ret=0

return ret
