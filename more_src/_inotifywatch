#compdef inotifywatch

local -a events
events=(
  'access' 'modify' 'attrib' 'close_write' 'close_nowrite' 'close'
  'open' 'moved_to' 'moved_from' 'move' 'create' 'delete'
  'delete_self' 'unmount' 'move_self'
)

local -a arguments

arguments=(
  '(-e --event)'{-e,--event}'[watch for specific event]:event:('"${events[*]}"')'
  '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds:'
  '(-r --recursive)'{-r,--recursive}'[watch directories recursively]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '--fromfile[read filenames from file]:file:_files'
  '--exclude[exclude files matching pattern]:pattern:'
  '--excludei[exclude files matching pattern (case-insensitive)]:pattern:'
  '(-z --zero)'{-z,--zero}'[output table with zero counts]'
  '*:file or directory:_files'
)

_arguments -s -S $arguments
