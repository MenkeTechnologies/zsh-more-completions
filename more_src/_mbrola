#compdef mbrola

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h[show help]' \
  '-i[show database info]' \
  '-e[do not raise error on missing diphones]' \
  '-v+[volume ratio]:ratio:' \
  '-f+[frequency ratio]:ratio:' \
  '-t+[time ratio]:ratio:' \
  '-l+[voice frequency]:Hz:' \
  '-F+[default phoneme frequency]:Hz:' \
  '-C[generate C-style float output]' \
  '-R+[rename phoneme]:phoneme=replacement:' \
  '-I+[initialization file]:file:_files' \
  '-S+[smoothing]:samples:' \
  '-W+[output sample rate]:rate:' \
  '1:voice database file:_files' \
  '2:input phoneme file (- for stdin):_files' \
  '3:output audio file (- for stdout):_files' && ret=0

return ret
