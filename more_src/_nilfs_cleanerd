#compdef nilfs_cleanerd
# Documentation: https://man.archlinux.org/search?q=nilfs_cleanerd
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --conf)'{-c,--conf=}'[config file]:file:_files' \
  '(-p --protection-period)'{-p,--protection-period=}'[protection period seconds]:secs:' \
  ':device:_files'
