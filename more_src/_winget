#compdef winget

# Zsh completion for winget (Windows Package Manager - for WSL/cross-platform)

_winget() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'install:install the given package'
    'show:shows information about a package'
    'source:manage sources of packages'
    'search:find and show basic info of packages'
    'list:display installed packages'
    'upgrade:show and perform available upgrades'
    'uninstall:uninstall the given package'
    'hash:helper to hash installer files'
    'validate:validate a manifest file'
    'settings:open settings or set administrator settings'
    'features:show the status of experimental features'
    'export:export a list of the installed packages'
    'import:install all packages in a file'
    'pin:manage package pins'
    'configure:configure the system into a desired state'
    'download:download the installer from a given package'
    'repair:repair the given package'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'winget command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        install)
          _arguments -s -S \
            '(-q --query)'{-q,--query}'[query to search]:query:' \
            '--id=[filter by ID]:package ID:' \
            '--name=[filter by name]:name:' \
            '--moniker=[filter by moniker]:moniker:' \
            '(-v --version)'{-v,--version}'[filter by version]:version:' \
            '(-s --source)'{-s,--source}'[find package using specified source]:source:' \
            '--scope=[filter by install scope]:scope:(user machine)' \
            '(-a --architecture)'{-a,--architecture}'[select the architecture]:arch:(x64 x86 arm arm64)' \
            '(-e --exact)'{-e,--exact}'[use exact string in query]' \
            '(-i --interactive)'{-i,--interactive}'[request interactive installation]' \
            '(-h --silent)'{-h,--silent}'[request silent installation]' \
            '--locale=[locale to use]:locale:' \
            '(-o --log)'{-o,--log}'[log location]:log file:_files' \
            '--custom=[custom arguments for installer]:args:' \
            '--override=[override arguments for installer]:args:' \
            '(-l --location)'{-l,--location}'[install location]:directory:_files -/' \
            '--ignore-security-hash[ignore installer hash check]' \
            '--ignore-local-archive-malware-scan[ignore local archive malware scan]' \
            '--dependency-source=[source for dependencies]:source:' \
            '--accept-package-agreements[accept all license agreements]' \
            '--accept-source-agreements[accept all source agreements]' \
            '--header=[optional HTTP header]:header:' \
            '--rename=[rename the executable]:name:' \
            '--force[force install even if already installed]' \
            '--no-upgrade[skip upgrade if installed]' \
            '--wait[wait for installation to complete]' \
            '--disable-interactivity[disable interactive prompts]' \
            && ret=0
          ;;
        search)
          _arguments -s -S \
            '(-q --query)'{-q,--query}'[query to search]:query:' \
            '--id=[filter by ID]:ID:' \
            '--name=[filter by name]:name:' \
            '--moniker=[filter by moniker]:moniker:' \
            '--tag=[filter by tag]:tag:' \
            '--command=[filter by command]:command:' \
            '(-s --source)'{-s,--source}'[find package using specified source]:source:' \
            '(-n --count)'{-n,--count}'[show no more than specified count]:count:' \
            '(-e --exact)'{-e,--exact}'[use exact string in query]' \
            '--header=[optional HTTP header]:header:' \
            '--accept-source-agreements[accept all source agreements]' \
            '1:query:' \
            && ret=0
          ;;
        upgrade)
          _arguments -s -S \
            '(-q --query)'{-q,--query}'[query to search]:query:' \
            '--id=[filter by ID]:ID:' \
            '--name=[filter by name]:name:' \
            '(-v --version)'{-v,--version}'[filter by version]:version:' \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '(-e --exact)'{-e,--exact}'[exact match]' \
            '(-i --interactive)'{-i,--interactive}'[interactive]' \
            '(-h --silent)'{-h,--silent}'[silent]' \
            '--all[update all installed packages]' \
            '--include-unknown[include unknown version packages]' \
            '--force[force upgrade]' \
            '--accept-package-agreements[accept all license agreements]' \
            '--accept-source-agreements[accept all source agreements]' \
            '1:query:' \
            && ret=0
          ;;
        uninstall)
          _arguments -s -S \
            '(-q --query)'{-q,--query}'[query to search]:query:' \
            '--id=[filter by ID]:ID:' \
            '--name=[filter by name]:name:' \
            '(-v --version)'{-v,--version}'[filter by version]:version:' \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '(-e --exact)'{-e,--exact}'[exact match]' \
            '--scope=[filter by scope]:scope:(user machine)' \
            '(-i --interactive)'{-i,--interactive}'[interactive]' \
            '(-h --silent)'{-h,--silent}'[silent]' \
            '--purge[delete all files and directories]' \
            '--force[force uninstall]' \
            '1:query:' \
            && ret=0
          ;;
        list)
          _arguments -s -S \
            '(-q --query)'{-q,--query}'[query to filter]:query:' \
            '--id=[filter by ID]:ID:' \
            '--name=[filter by name]:name:' \
            '--tag=[filter by tag]:tag:' \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '(-n --count)'{-n,--count}'[show no more than count]:count:' \
            '(-e --exact)'{-e,--exact}'[exact match]' \
            '--upgrade-available[list packages with upgrade available]' \
            '1:query:' \
            && ret=0
          ;;
        source)
          _arguments -s -S \
            '1:subcommand:(add list update remove reset export)' \
            && ret=0
          ;;
        export)
          _arguments -s -S \
            '(-o --output)'{-o,--output}'[output file]:file:_files -g "*.json"' \
            '(-s --source)'{-s,--source}'[source]:source:' \
            '--include-versions[include package versions]' \
            '--accept-source-agreements[accept all source agreements]' \
            && ret=0
          ;;
        import)
          _arguments -s -S \
            '(-i --import-file)'{-i,--import-file}'[import file]:file:_files -g "*.json"' \
            '--ignore-unavailable[ignore unavailable packages]' \
            '--ignore-versions[ignore package versions]' \
            '--accept-package-agreements[accept all license agreements]' \
            '--accept-source-agreements[accept all source agreements]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--info[display general info]' \
            '--version[display version]' \
            '--wait[prompt before exiting]' \
            '--verbose[enable verbose logging]' \
            '--disable-interactivity[disable interactive prompts]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_winget "$@"
