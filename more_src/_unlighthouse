#compdef unlighthouse
# _unlighthouse — Scan an entire website with Google Lighthouse
# upstream: https://github.com/harlan-zw/unlighthouse

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--site=[URL of the site to scan]:url' \
  '--root=[project root directory]:directory:_directories' \
  '--config-file=[path to config file]:file:_files' \
  '--output-path=[output directory for reports]:directory:_directories' \
  '--budget=[path to Lighthouse budget JSON]:file:_files' \
  '--urls=[comma-separated URLs to scan]:urls' \
  '--exclude=[URLs to exclude from scan]:patterns' \
  '--include=[URLs to include in scan]:patterns' \
  '--samples=[number of Lighthouse runs per URL]:count' \
  '--throttle[enable network throttling]' \
  '--no-cache[disable caching of results]' \
  '--cache[enable caching of results]' \
  '--desktop[use desktop viewport]' \
  '--mobile[use mobile viewport]' \
  '--enable-javascript[scan with JavaScript enabled]' \
  '--disable-javascript[scan with JavaScript disabled]' \
  '--debug[enable debug output]' \
  '--enable-i18n-pages[enable scanning of i18n pages]' \
  '--no-dynamic-sampling[disable dynamic sampling]' && ret=0

return ret
