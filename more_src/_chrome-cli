#compdef chrome-cli

# Zsh completion for chrome-cli - control Google Chrome from the command line (macOS)

local curcontext="$curcontext" state line ret=1

_chrome-cli_commands() {
  local -a commands=(
    'open:open URL in the active tab'
    'reload:reload the active tab'
    'back:go back in the active tab'
    'forward:go forward in the active tab'
    'list:list tabs/windows/links'
    'info:print info about the active tab'
    'source:print the source of the active tab'
    'close:close the active tab'
    'activate:activate the tab with the given ID'
    'execute:execute JavaScript in the active tab'
    'version:print version and exit'
    'help:print help and exit'
  )
  _describe -t commands 'chrome-cli command' commands
}

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '1: :_chrome-cli_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      list)
        _arguments \
          '1:what:(tabs windows links)' \
          '-w[target window id]:window id' && ret=0
        ;;
      open)
        _arguments \
          '-n[open in a new tab]' \
          '-w[target window id]:window id' \
          '-t[target tab id]:tab id' \
          '*:URL' && ret=0
        ;;
      activate|reload|close|info|source)
        _arguments \
          '-t[target tab id]:tab id' && ret=0
        ;;
      execute)
        _arguments \
          '-t[target tab id]:tab id' \
          '*:JavaScript code' && ret=0
        ;;
    esac
    ;;
esac

return ret
