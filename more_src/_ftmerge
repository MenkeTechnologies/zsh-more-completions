#compdef ftmerge
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftmerge.html
# Merge multiple FITS tables by concatenating their rows

local ret=1

_arguments -s -S \
  'infile=[input tables with optional extensions]:infile:_files' \
  'outfile=[output merged table file]:outfile:_files' \
  'columns=[columns to include or exclude]:columns:' \
  'insertrow=[row in first table after which to insert]:insertrow:' \
  'lastkey=[keywords from final input to update]:lastkey:' \
  'copyall=[copy all HDUs or just the table]:copyall:(yes no)' \
  'skipbadfiles=[skip unreadable tables and continue]:skipbadfiles:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
