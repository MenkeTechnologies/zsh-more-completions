#compdef checksec checksec.sh

# Zsh completion for checksec (binary security checker)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '--file[check a single binary]:binary:_files' \
  '--proc[check a running process by PID]:pid:_pids' \
  '--proc-all[check all running processes]' \
  '--proc-libs[check libraries of a process by PID]:pid:_pids' \
  '--dir[check all binaries in a directory]:directory:_directories' \
  '--listfile[check binaries listed in a file]:file:_files' \
  '--output[set output format]:format:(cli csv xml json)' \
  '--fortify-file[check fortify for a binary]:binary:_files' \
  '--fortify-proc[check fortify for a process by PID]:pid:_pids' && ret=0

return ret
