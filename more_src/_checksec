#compdef checksec
# Documentation: https://github.com/slimm609/checksec
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (cmd/ subcommands in slimm609/checksec v3).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'file:check security properties of a single binary'
  'dir:check security properties of all binaries in a directory'
  'proc:check a running process by PID'
  'proc-all:check all running processes'
  'proc-libs:check libraries loaded by a process'
  'fortify-file:check FORTIFY_SOURCE for a binary'
  'fortify-proc:check FORTIFY_SOURCE for a running process'
  'kernel:check kernel configuration security'
)

# Persistent flags shared across subcommands.
local -a persistent=(
  '(-o --output)'{-o,--output}'=[output format]:format:(table json xml yaml)'
  '(-l --libc)'{-l,--libc}'=[libc location for offline FORTIFY checks]:file:_files'
  '--no-banner[disable banner]'
  '--no-headers[disable headers]'
  '--no-warnings[suppress warnings]'
  '--color=[color mode]:mode:(auto always never)'
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
)

_arguments -C \
  $persistent \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'checksec command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (file|fortify-file)
        _arguments $persistent '*:binary:_files' && ret=0 ;;
      (dir)
        _arguments $persistent '*:directory:_files -/' && ret=0 ;;
      (proc|proc-libs|fortify-proc)
        _arguments $persistent '*:pid:_pids' && ret=0 ;;
      (proc-all|kernel)
        _arguments $persistent && ret=0 ;;
    esac ;;
esac

return ret
