#compdef silverstripe-cli sake
# _silverstripe-cli — SilverStripe CMS sake task runner CLI alias (silverstripe team, PHP); custom argparse
# upstream: https://github.com/silverstripe/silverstripe-framework

_silverstripe-cli() {
    local -a sub=(
        'dev/build:rebuild database schema'
        'dev/check:check site health'
        'dev/cleanup:cleanup files'
        'dev/tasks:list tasks'
        'dev/tasks/MigrationTask:run migration task'
        'dev/tests:run tests'
        'flush:flush manifest cache'
        'modeladmin:show model admin'
        'installer:run installer'
        'queuedjobs:check:check queued jobs'
        'queuedjobs:processjobs:process queued jobs'
        'dev/generatesecuretoken:generate secure token'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--flush[flush manifest]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sake subcommand' sub ;;
        args)
            case $words[1] in
                dev/build) _arguments \
                    '--flush[flush]' \
                    '--quiet[quiet]' ;;
                dev/tests) _arguments \
                    '1:test class:' \
                    '--module=+[module]:str:' \
                    '--coverage[enable coverage]' ;;
            esac
            ;;
    esac
}

_silverstripe-cli "$@"
