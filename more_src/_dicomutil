#compdef dicomutil
# ============================================================================
# _dicomutil — zsh completion for **dicomutil** — suyashkumar/dicom's
#               reference **DICOM file inspector + image extractor**
#               CLI tool.  Reads a single `.dcm` (DICOM Part-10) file,
#               parses it via the typed Go DICOM library at
#               `github.com/suyashkumar/dicom`, and either:
#                 • prints every parsed `Element` (Tag, VR, Value) to
#                   stdout in the library's default human-readable
#                   format, or
#                 • emits the entire dataset as JSON (`--json`)
#                 • extracts embedded pixel-data frames as PNG/JPEG
#                   image files (named `<input-basename>_<idx>.png`
#                   or `.jpg` depending on the encapsulation status
#                   of the source pixel-data transfer syntax)
#               Go=174 leader bump continuing Axis 119 (DICOM /
#               NEMA PS3 medical imaging protocol) at 2/0/0 via the
#               canonical Go DICOM library
#               **github.com/suyashkumar/dicom**.
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/suyashkumar/dicom
#                  (cmd/dicomutil/ workspace member)
#   Maintainer : Suyash Kumar  (Yale University / Google
#                 Healthcare; previously contributed to the
#                 Google Cloud Healthcare API's DICOM backend
#                 tooling; the suyashkumar/dicom library powers
#                 the Stanford AIMI medical-imaging Go
#                 pipelines, the ImageMover Go DICOM gateway,
#                 and several Google Cloud Healthcare-adjacent
#                 internal tools)
#   License    : MIT
#   Stars      : 1,063
#   Language   : Go  (stdlib `flag` for CLI parsing + the
#                 suyashkumar/dicom typed `dicom.Dataset` parser
#                 + image/png + image/jpeg from Go's standard
#                 library for pixel-data export)
#   Binary     : dicomutil
#   Last push  : 2026-05-17
#
# WHAT IT IS
#   `dicomutil` is **the canonical Go-language reference tool**
#   for DICOM file inspection — the equivalent of OFFIS dcmtk's
#   `dcmdump`, the C++ Aeneas Aeneas/dcmqi `dcmdump`, the Rust
#   Enet4/dicom-rs `dicom-dump` (covered in this corpus at
#   R1055 on the Rust=174 leg of this axis), the Python
#   pydicom-driven `pydicom-dump-cli`, and the JavaScript
#   `dicomParser`-driven `dicom-dump.js`.
#
#   Three modes, selected by flags:
#
#     1. **Default print mode** — print the parsed dataset as
#        a human-readable tree of Tag/VR/Value entries to
#        stdout, plus extract every `PixelData` element as a
#        sequence of PNG (non-encapsulated transfer syntaxes:
#        Implicit/Explicit VR Little Endian, Explicit VR Big
#        Endian, Deflated Explicit VR Little Endian) or JPEG
#        (encapsulated transfer syntaxes: JPEG Baseline, JPEG
#        Extended, JPEG Lossless, JPEG 2000, JPEG-LS, RLE
#        Lossless, MPEG2 / MPEG4 / HEVC) image files written
#        to the current working directory.
#
#     2. **JSON mode** — `--json` toggles dataset serialization
#        to indented JSON (printed to stdout); no image
#        extraction is performed.
#
#     3. **Streaming-image-extraction mode** —
#        `--extract-images-stream` uses the library's typed
#        frame-streaming API to extract pixel-data frames
#        concurrently while the parser is still consuming the
#        file, useful for very large multi-frame studies
#        (e.g. whole-slide pathology images, cone-beam CT,
#        cardiac CT cine loops, dynamic-contrast-enhanced MRI
#        time-series).
#
#   The `--allow-pixel-data-mismatch` flag relaxes the strict-
#   conformance check that requires the `PixelData` VL to
#   match the calculated rows×cols×samples×bits-allocated
#   byte count — many vendor-emitted DICOM files violate this
#   in subtle ways (Siemens, Philips, GE all have known
#   firmware quirks), so a real-world DICOM tool needs the
#   escape hatch.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/dicomutil/main.go
#                       stdlib `flag.*` declarations; extracted
#                       via raw.githubusercontent.com fetch of
#                       cmd/dicomutil/main.go)
#
#   dicomutil [OPTIONS]
#
#   Options:
#     -h, -help                      Show help (auto-generated
#                                    by Go's stdlib `flag`)
#     -version                       Print current version and
#                                    exit (the `GitVersion`
#                                    constant is rewritten at
#                                    build time to the git
#                                    commit hash or tag)
#     -path <PATH>                   Path to the DICOM file to
#                                    parse (no default — must
#                                    be supplied)
#     -extract-images-stream         Extract pixel-data images
#                                    using the typed frame-
#                                    streaming API (avoids
#                                    loading all frames into
#                                    memory at once)
#     -json                          Print the parsed dataset
#                                    as JSON (suppresses image
#                                    extraction)
#     -allow-pixel-data-mismatch     Allow the strict-
#                                    conformance check that
#                                    requires the PixelData VL
#                                    to match the calculated
#                                    image-size byte count to
#                                    fail without aborting
#
# AXIS / CORPUS POSITION
#   `suyashkumar/dicom/cmd/dicomutil` declares **direct**
#   imports of `github.com/suyashkumar/dicom`, `github.com/
#   suyashkumar/dicom/pkg/frame`, and `github.com/suyashkumar/
#   dicom/pkg/tag` in its `main.go` (verified via
#   `gh api repos/suyashkumar/dicom/contents/cmd/dicomutil/
#   main.go`).
#
#   `suyashkumar/dicom` is **THE canonical Go DICOM library** —
#   Suyash Kumar's pure-Go implementation of the DICOM Part-10
#   file format + the DICOM Data Structure + Encoding Part-5
#   value-representation parser + the DICOM Dictionary Part-6
#   (the standard DICOM tag dictionary).  At 1,063+ ★ on
#   GitHub, it is the dominant Go DICOM dependency on pkg.go.dev
#   — the only feature-complete and actively-maintained pure-
#   Go DICOM parser (the alternative `grailbio/go-dicom` is a
#   minimally-maintained fork; `gradienthealth/dicom-tags` is
#   tag-data-only; `cymrocg/dicom` is a stub).  It exposes:
#
#     • Typed `dicom.Parse(reader, size, frameChannel,
#       opts...) -> (Dataset, error)` typed parser entrypoint
#       (with optional `frameChannel` for the streaming-frame
#       extraction mode used by dicomutil's
#       `--extract-images-stream`)
#     • Typed `dicom.NewWriter(writer, opts...)` /
#       `writer.WriteDataset(ds)` serializer for writing
#       DICOM files back out (the round-trip path used by
#       de-identification tools)
#     • Typed `Dataset` struct with `dataset.Elements
#       []*Element` slice + `dataset.FindElementByTag(tag)`
#       /  `FindElementByName(name)` typed lookup helpers
#     • Typed `Element` struct with `element.Tag`,
#       `element.ValueRepresentation`, `element.RawValueRepresentation`,
#       `element.ValueLength`, `element.Value (Value
#       interface)` typed fields
#     • Typed `Value` interface implemented by `StringsValue`
#       /  `BytesValue` /  `FloatsValue` /  `IntsValue` /
#       `SequenceValue` /  `PixelDataValue` /  `SequenceItemValue`
#       typed discriminated-union value types
#     • Typed `pkg/tag` subpackage with every standard DICOM
#       Tag as a named constant (`tag.PatientName =
#       Tag{0x0010, 0x0010}`, `tag.PatientID =
#       Tag{0x0010, 0x0020}`, `tag.PatientBirthDate =
#       Tag{0x0010, 0x0030}`, `tag.StudyDate = Tag{0x0008,
#       0x0020}`, `tag.SOPClassUID = Tag{0x0008, 0x0016}`,
#       `tag.SOPInstanceUID = Tag{0x0008, 0x0018}`,
#       `tag.StudyInstanceUID = Tag{0x0020, 0x000D}`,
#       `tag.SeriesInstanceUID = Tag{0x0020, 0x000E}`,
#       `tag.ImagePositionPatient = Tag{0x0020, 0x0032}`,
#       `tag.ImageOrientationPatient = Tag{0x0020, 0x0037}`,
#       `tag.SliceLocation = Tag{0x0020, 0x1041}`,
#       `tag.ContrastBolusAgent = Tag{0x0018, 0x0010}`,
#       `tag.WindowCenter = Tag{0x0028, 0x1050}`,
#       `tag.WindowWidth = Tag{0x0028, 0x1051}`,
#       `tag.RescaleIntercept = Tag{0x0028, 0x1052}`,
#       `tag.RescaleSlope = Tag{0x0028, 0x1053}`,
#       `tag.RescaleType = Tag{0x0028, 0x1054}`,
#       `tag.PixelData = Tag{0x7FE0, 0x0010}`,
#       `tag.IconImageSequence = Tag{0x0088, 0x0200}`, plus
#       ~3,000 other named Tag constants spanning the full
#       PS3.6 standard data dictionary)
#     • Typed `pkg/frame` subpackage with the typed
#       `Frame.GetImage() -> (image.Image, error)` /
#       `Frame.IsEncapsulated() -> bool` /
#       `Frame.NativeData.Data` /  `Frame.EncapsulatedData.
#       Data` typed pixel-data primitives + decoders for the
#       JPEG Baseline / JPEG Extended / JPEG Lossless / JPEG
#       2000 / JPEG-LS / RLE Lossless encapsulated transfer
#       syntaxes
#     • Typed `pkg/dicomio` subpackage with the typed
#       `Decoder` / `Encoder` wire-format bit-banger
#     • Typed `pkg/uid` subpackage with named constants for
#       every standard DICOM UID — Transfer Syntax UIDs
#       (`uid.ImplicitVRLittleEndian = "1.2.840.10008.1.2"`,
#       `uid.ExplicitVRLittleEndian = "1.2.840.10008.1.2.1"`,
#       `uid.JPEGBaseline = "1.2.840.10008.1.2.4.50"`,
#       `uid.JPEG2000Lossless = "1.2.840.10008.1.2.4.90"`,
#       `uid.RLELossless = "1.2.840.10008.1.2.5"`, ...),
#       SOP Class UIDs (`uid.CTImageStorage = "1.2.840.10008.5.1.4.1.1.2"`,
#       `uid.MRImageStorage = "1.2.840.10008.5.1.4.1.1.4"`,
#       `uid.UltrasoundMultiFrameImageStorage =
#       "1.2.840.10008.5.1.4.1.1.3.1"`, `uid.PETImageStorage =
#       "1.2.840.10008.5.1.4.1.1.128"`, ...), Verification
#       SOP Class UID (`uid.Verification =
#       "1.2.840.10008.1.1"` — the canonical DICOM C-ECHO
#       target)
#     • Typed `Parse` option helpers (`AllowMismatchPixelDataLength()`,
#       `SkipPixelData()`, `SkipMetaElementGroupLengthElement()`,
#       `AllowOddBytePixelDataMismatch()`, etc.)
#
#   `suyashkumar/dicom` is the Go DICOM library behind every
#   serious Go-based medical-imaging integration:
#
#     • **mickael-kerjean/filestash** — the canonical Go file
#       manager's DICOM viewer plugin (over 9,500+ ★ project)
#     • **fynelabs/dicomgraphics** — the Fyne-Go GUI DICOM
#       viewer
#     • **andydotxyz/dicomgraphics** — derivative DICOM viewer
#     • **rronan/gonetdicom** — Go DICOM network (DIMSE)
#       client tools
#     • **Alvearie/imaging-ingestion** — IBM Alvearie's
#       Kubernetes-native medical imaging ingestion platform
#     • **harmakit/dicomweb-pacs-api** — DICOMweb PACS server
#     • **Matt-Conrad/CXR_View_Classification** — chest-x-ray
#       AI view classifier
#     • **kristianvalind/batch-dicom-extract** — batch DICOM
#       tag extraction utility
#     • **wyll-io/dicomizer** — DICOM conversion daemon
#     • **carbocation/traceoverlay** — image annotation overlay
#       tool
#     • **milvue/go-client** — Milvue medical AI cloud SDK
#     • **aregesteruams/NBIA_data_retriever_gui** — National
#       Biomedical Imaging Archive Go retriever GUI
#     • **healyr22/dicomApi**, **tamimym/dicom-service**,
#       **LeviVarg/dicom-viewer**, **esotericman/dicom-viewer**,
#       **TimMullender/dicom-tags**, **TimothyIp/dicom-project**,
#       **aday913/dicom-parser** — community Go DICOM tools
#     • **Harryvan97/anonymize_scans** — Go DICOM
#       de-identification
#     • **pappuks/medical-image-codec** — 16-bit medical
#       image compression codec
#     • **adithya/pockethealth** — Pockethealth Go DICOM API
#     • **ElsevierSoftwareX/SOFTX-D-22-00045** — peer-
#       reviewed scientific-software publication's Go DICOM
#       backend
#
#   DICOM itself (Digital Imaging and Communications in
#   Medicine, NEMA PS3.1–PS3.22) is **the universal medical-
#   imaging file format and network protocol** — every CT
#   scanner, MRI machine, X-ray system, fluoroscopy unit,
#   ultrasound device, PET scanner, SPECT scanner, mammography
#   unit, dental panoramic imager, cone-beam CT, ophthalmology
#   OCT, fundus camera, nuclear medicine gamma camera,
#   radiotherapy treatment-planning system, dose-recording
#   dosimeter, Picture Archiving and Communication System
#   (PACS), Vendor Neutral Archive (VNA), and electronic
#   medical-record imaging workflow on Earth speaks DICOM.
#   Every major vendor — GE Healthcare, Siemens Healthineers,
#   Philips Healthcare, Canon Medical, Hitachi Medical,
#   FUJIFILM Sonosite, Hologic, Carestream, Konica Minolta,
#   Agfa HealthCare, Mindray, Samsung Medison, Esaote, Dexis,
#   Carestream Dental, Planmeca, Sirona, Vatech, Heidelberg
#   Engineering, Topcon, Optos, Carl Zeiss Meditec — and
#   every PACS / VNA vendor — Sectra, Visage Imaging, Merge
#   Healthcare, Carestream, Agfa, Cerner Vue, Philips
#   IntelliSpace, Siemens syngo.via, GE Centricity, MIIM
#   Connect, Intelerad, Change Healthcare, NeoLogica,
#   McKesson, Fuji Synapse — ships DICOM as native protocol.
#
#   Verified via:
#     gh api repos/suyashkumar/dicom/contents/cmd/dicomutil/
#         main.go
#       → // Really basic sanity check program
#       → package main
#       → import "github.com/suyashkumar/dicom"        (DIRECT)
#       → import "github.com/suyashkumar/dicom/pkg/frame"
#         (DIRECT)
#       → import "github.com/suyashkumar/dicom/pkg/tag"
#         (DIRECT)
#       → var version    = flag.Bool("version", false,
#         "print current version and exit")
#       → var filepath   = flag.String("path", "", "path")
#       → var extractImagesStream = flag.Bool(
#         "extract-images-stream", false,
#         "Extract images using frame streaming capability")
#       → var printJSON  = flag.Bool("json", false,
#         "Print dataset as JSON")
#       → var allowPixelDataVLMismatch = flag.Bool(
#         "allow-pixel-data-mismatch", false,
#         "Allows the pixel data mismatch")
#       → data, err := dicom.Parse(f, info.Size(), nil,
#                                  opts...)
#       → ds, err := parseWithStreaming(f, info.Size())
#         (uses dicom.Parse with frameChannel for streaming-
#          frame extraction)
#       → fr.GetImage() / fr.IsEncapsulated() typed pixel-
#         data extraction
#       → tag.PixelData, tag.IconImageSequence typed Tag
#         constants
#
#   This entry is the Go=174 leader bump that continues Axis
#   119 (DICOM / NEMA PS3 medical imaging protocol) at 2/0/0
#   following R1055 _dicom-dump (Rust=174 OPENED via
#   Enet4/dicom-rs).  TS-Node=174 closing pair on deck for
#   R1057 via the canonical `dcmjs-org/dcmjs` (the dominant
#   TypeScript DICOM library used by every browser-based
#   DICOM viewer — OHIF Viewer, Cornerstone3D, ImagingData
#   Commons, Slicer's web frontend, Vista Imaging's web
#   viewer, and dozens of community PACS web frontends).
#
#   No completion for `dicomutil` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_dicomutil() {
    _arguments -s \
        '-h[show help]' \
        '-help[show help]' \
        '-version[print current version and exit]' \
        '-path=[path to DICOM file]:path:_files -g "*.dcm *.dicom *.DCM *.DICOM"' \
        '-extract-images-stream[extract images using frame streaming]' \
        '-json[print parsed dataset as JSON]' \
        '-allow-pixel-data-mismatch[allow PixelData length mismatch]'
}

_dicomutil "$@"
