#compdef babel
# _babel-cli — Babel JavaScript compiler CLI (babel/babel)
# upstream: https://github.com/babel/babel
# Flags from packages/babel-cli/src/babel/options.ts (commander).

_babel-cli() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-f --filename)'{-f+,--filename=}'[filename to use when reading stdin]:file:_files' \
        '*--presets=[comma-separated preset names]:list:' \
        '*--plugins=[comma-separated plugin names]:list:' \
        '--config-file=[path to .babelrc]:file:_files' \
        '--env-name=[env name for configs/plugins]:name:' \
        '--root-mode=[project-root resolution]:mode:(root upward upward-optional)' \
        '--source-type=[source type]:type:(script module)' \
        '--no-babelrc[ignore .babelrc and .babelignore]' \
        '*--ignore=[glob list to NOT compile]:glob:' \
        '*--only=[glob list to ONLY compile]:glob:' \
        '--no-highlight-code[disable ANSI syntax highlighting]' \
        '--no-comments[strip comments from output]' \
        '--retain-lines[retain line numbers]' \
        '--compact=[skip whitespace and newlines]:mode:(true false auto)' \
        '--minified[minify output]' \
        '--auxiliary-comment-before=[comment before injected code]:text:' \
        '--auxiliary-comment-after=[comment after injected code]:text:' \
        '(-s --source-maps)'{-s+,--source-maps=}'[source map mode]:mode:(true false inline both)' \
        '--source-map-target=[file in source map]:name:' \
        '--source-file-name=[sources[0] in source map]:name:' \
        '--source-root=[source map root]:dir:_files -/' \
        '*'{-x+,--extensions=}'[file extensions to compile]:list:' \
        '--keep-file-extension[preserve input file extensions]' \
        '(-w --watch)'{-w,--watch}'[recompile on file changes]' \
        '--skip-initial-build[do not compile before watching]' \
        '(-o --out-file)'{-o+,--out-file=}'[output file]:file:_files' \
        '(-d --out-dir)'{-d+,--out-dir=}'[output directory]:dir:_files -/' \
        '--relative[mirror input structure under --out-dir]' \
        '(-D --copy-files)'{-D,--copy-files}'[copy non-compilable files]' \
        '--include-dotfiles[include dotfiles when copying]' \
        '--no-copy-ignored[exclude ignored files from copy]' \
        '--verbose[log everything]' \
        '--quiet[suppress logs]' \
        '--delete-dir-on-start[clean out dir before compile]' \
        '--out-file-extension=[output file extension]:ext:' \
        '*:JavaScript file:_files -g "*.(js|jsx|mjs|cjs|ts|tsx|mts|cts)"'
}

_babel-cli "$@"
