#compdef quick-lint-js
# Documentation: https://man.archlinux.org/search?q=quick-lint-js
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/quick-lint-js — JavaScript/TS linter (quick-lint-js)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
