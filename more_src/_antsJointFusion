#compdef antsJointFusion
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsJointFusion.cxx — joint-label fusion / segmentation (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '*'{-t+,--target-image=}'[target image (multiple modalities allowed)]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '*'{-g+,--atlas-image=}'[atlas image (multiple modalities/atlases)]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '*'{-l+,--atlas-segmentation=}'[atlas segmentation per atlas]:file:_files -g "*.{nii,nii.gz}"' \
    '(-a --alpha)'{-a+,--alpha=}'[alpha (regularization)]:n:_default' \
    '(-b --beta)'{-b+,--beta=}'[beta (patch metric exponent)]:n:_default' \
    '-c+[retain (1) or discard (0) atlas-vote images]:n:(0 1)' \
    '--constrain-nonnegative=[constrain nonnegative weights]:n:(0 1)' \
    '(-p --patch-radius)'{-p+,--patch-radius=}'[patch radius (e.g. 2x2x2)]:radius:_default' \
    '(-m --patch-metric)'{-m+,--patch-metric=}'[patch metric]:metric:(PC MSQ)' \
    '(-s --search-radius)'{-s+,--search-radius=}'[search radius]:radius:_default' \
    '*'{-e+,--exclusion-image=}'[exclusion image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-x --mask-image)'{-x+,--mask-image=}'[target mask]:file:_files -g "*.{nii,nii.gz}"' \
    '(-o --output)'{-o+,--output=}'[output segmentation [or list spec]]:spec:_default' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
