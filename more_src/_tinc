#compdef tinc
# Documentation: https://www.tinc-vpn.org/documentation/Runtime-options.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (global flags); subcommands
# from tinc(8) man page widely mirrored.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize a new tinc network'
  'get:get config variable'
  'set:set config variable'
  'add:add value to config variable'
  'del:delete value from config variable'
  'edit:edit config file'
  'export:export local host config'
  'export-all:export all host configs'
  'import:import host config'
  'exchange:exchange host configs interactively'
  'exchange-all:exchange all host configs'
  'invite:create invitation'
  'join:join an invited network'
  'disconnect:disconnect a node'
  'start:start tincd'
  'stop:stop running tincd'
  'restart:restart running tincd'
  'reload:reload running tincd'
  'pid:show running daemon PID'
  'generate-keys:generate RSA and Ed25519 keys'
  'generate-rsa-keys:generate RSA key'
  'generate-ed25519-keys:generate Ed25519 key'
  'dump:dump nodes/edges/subnets/connections/graph'
  'info:show info about node/subnet/address'
  'purge:purge old keys/data'
  'debug:set runtime debug level'
  'log:tail tincd log'
  'retry:force retry of all connections'
  'top:show interactive traffic stats'
  'pcap:dump packet capture'
  'network:show or change current netname'
  'fsck:check config consistency'
  'sign:sign a file'
  'verify:verify a signed file'
)

_arguments -C \
  '(-n --net)'{-n,--net}'=[network name]:name:' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '--pidfile=[PID file]:file:_files' \
  '--force[force]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tinc subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (dump)
        _values 'dump target' reachable nodes edges subnets connections graph digraph invitations && ret=0
        ;;
    esac
    ;;
esac

return ret
