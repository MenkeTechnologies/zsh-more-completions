#compdef zsolve
# Documentation: https://4ti2.github.io/zsolve.html
# zsolve (4ti2): solve linear inequality and equation systems over the integers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '--version[display version information]' \
  '(-p --precision)'{-p,--precision=}'[arithmetic precision (32, 64, gmp)]:precision:(32 64 gmp)' \
  '(-m --maxnorm)'{-m,--maxnorm}'[write vectors with maximum norm to PROJECT.maxnorm]' \
  '(-b --backup)'{-b,--backup=}'[frequently backup status to PROJECT.backup]:frequency' \
  '(-r --resume)'{-r,--resume}'[resume from backup file PROJECT.backup]' \
  '(-q --quiet)'{-q,--quiet}'[suppress standard output]' \
  '(-u --update)'{-u,--update=}'[updated output on console]:level' \
  '(-v --verbose)'{-v,--verbose=}'[verbose output during computation]:level' \
  '(-n --log)'{-n,--log=}'[logging level to PROJECT.log]:level' \
  '*:project:_files' && ret=0

return ret
