#compdef udp-sender

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--license[show license]' \
  '(- *)--ttl=[set TTL]:ttl:' \
  '(-f --file)'{-f,--file}'+[input file]:file:_files' \
  '--full-duplex[full-duplex mode]' \
  '--half-duplex[half-duplex mode]' \
  '--async[asynchronous mode]' \
  '--bcast[use broadcast]' \
  '--mcast-rdv-addr=[rendezvous multicast address]:addr:' \
  '--mcast-rdv-port=[rendezvous port]:port:' \
  '--mcast-data-address=[data multicast address]:addr:' \
  '--mcast-all-addr=[all-hosts mcast address]:addr:' \
  '--portbase=[port base]:port:' \
  '--blocksize=[block size in bytes]:bytes:' \
  '--ttl=[time-to-live]:ttl:' \
  '--interface=[network interface]:iface:_net_interfaces' \
  '--autostart=[autostart after N receivers]:n:' \
  '--min-receivers=[minimum receivers]:n:' \
  '--min-wait=[min wait seconds]:sec:' \
  '--max-wait=[max wait seconds]:sec:' \
  '--rexmit-hello-interval=[hello interval ms]:ms:' \
  '--max-bitrate=[max bitrate bps]:bps:' \
  '--pipe=[shell pipe through command]:cmd:' \
  '--no-progress[hide progress meter]' \
  '--print-seed[print FEC seed]' \
  '--fec=[forward error correction]:fec:' \
  '--log=[log file]:file:_files' \
  '--retries-until-drop=[retries before drop]:n:' \
  '--rcvbuf=[receive socket buffer]:bytes:' \
  '--sndbuf=[send socket buffer]:bytes:' \
  '--nokbd[disable keyboard control]' \
  '--start-timeout=[start timeout sec]:sec:' \
  '--receiver-timeout=[receiver timeout sec]:sec:' \
  '*:file:_files' && ret=0

return ret
