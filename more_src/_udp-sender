#compdef udp-sender
# Documentation: https://www.udpcast.linux.lu/cmd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--file=[input file]:file:_files' \
  '--pipe=[run through command before transmitting]:cmd:' \
  '--autostart=[start after N hello retransmissions]:n:' \
  '--portbase=[base UDP port (default 9000)]:port:' \
  '--interface=[network interface]:iface:_net_interfaces' \
  '--ttl=[multicast time-to-live]:ttl:' \
  '--mcast-rdv-address=[rendezvous multicast address]:addr:' \
  '--mcast-data-address=[data multicast address]:addr:' \
  '--pointopoint[unicast mode for single receiver]' \
  '--nopointopoint[disable point-to-point]' \
  '--full-duplex[full-duplex mode for switches]' \
  '--half-duplex[half-duplex mode (hub default)]' \
  '--broadcast[use Ethernet broadcast instead of multicast]' \
  '-b+[packet size (max 1456)]:bytes:' \
  '--async[asynchronous mode]' \
  '--max-bitrate=[max bitrate]:bps:' \
  '--fec=[forward error correction]:fec:' \
  '--rate-governor=[loadable rate governor]:spec:' \
  '--rexmit-hello-interval=[rebroadcast hello interval]:ms:' \
  '--retries-until-drop=[retries before drop]:n:' \
  '--streaming[allow mid-transmission receiver connections]' \
  '--min-receivers=[minimum receiver count]:n:' \
  '--min-wait=[min wait seconds]:sec:' \
  '--max-wait=[max wait seconds]:sec:' \
  '--nokbd[disable keyboard control]' \
  '--start-timeout=[start timeout sec]:sec:' \
  '--daemon-mode[run as daemon]' \
  '--pid-file=[PID file path]:file:_files' \
  '--kill[terminate via pid file]' \
  '--stat-period=[statistics interval (sec)]:sec:' \
  '--print-uncompressed-position=[show uncompressed position]:flag:(0 1)' \
  '--log=[log file]:file:_files' \
  '--no-progress[hide progress meter]' \
  '--bw-period=[bandwidth log interval (sec)]:sec:' \
  '--min-slice-size=[minimum slice size (blocks)]:n:' \
  '--max-slice-size=[maximum slice size (blocks)]:n:' \
  '--default-slice-size=[initial slice size]:n:' \
  '--rehello-offset=[hello offset before slice end]:n:' && ret=0

return ret
