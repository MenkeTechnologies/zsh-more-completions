#compdef passmass
# Documentation: https://linux.die.net/man/1/passmass
# Change a password on multiple machines at once

local ret=1

_arguments -s \
  '-user[user whose password will be changed]:user:_users' \
  '-rlogin[use rlogin to access host (default)]' \
  '-slogin[use slogin to access host]' \
  '-ssh[use ssh to access host]' \
  '-telnet[use telnet to access host]' \
  '-program[program to run to set the password]:program:_command_names -e' \
  '-prompt[prompt suffix pattern]:pattern:' \
  '-timeout[seconds to wait for responses]:seconds:' \
  '-su[1 or 0: additionally prompt for root password to su]:flag:(0 1)' \
  '*:host:_hosts' && ret=0

return ret
