#compdef xrtproducts
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/xrtproducts.html
# Extract Swift XRT products (light curves, spectra, images) from event files

local ret=1

_arguments -s -S \
  'infile=[input FITS event file]:infile:_files' \
  'outdir=[output directory]:outdir:_files -/' \
  'regionfile=[source region file or DEFAULT]:regionfile:_files' \
  'ra=[extraction region RA J2000]:ra:' \
  'dec=[extraction region DEC J2000]:dec:' \
  'radius=[circular region radius pixels]:radius:' \
  'bkgextract=[extract background products]:bkgextract:(yes no)' \
  'bkgregionfile=[background region file]:bkgregionfile:_files' \
  'stemout=[prefix for output filenames]:stemout:' \
  'lcfile=[source light curve output]:lcfile:_files' \
  'phafile=[source spectrum output]:phafile:_files' \
  'imagefile=[image output file]:imagefile:_files' \
  'binsize=[light curve bin size seconds]:binsize:' \
  'pilow=[minimum PI channel]:pilow:' \
  'pihigh=[maximum PI channel]:pihigh:' \
  'gtifile=[GTI time filter file]:gtifile:_files' \
  'arffile=[ancillary response output]:arffile:_files' \
  'rmffile=[redistribution matrix input]:rmffile:_files' \
  'expofile=[exposure map file]:expofile:_files' \
  'psfflag=[apply PSF correction in ARF]:psfflag:(yes no)' \
  'correctlc=[apply vignetting and PSF corrections]:correctlc:(yes no)' \
  'attfile=[attitude file for corrections]:attfile:_files' \
  'plotdevice=[output plot format]:plotdevice:(gif ps)' \
  'display=[show image on screen]:display:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
