#compdef gdalbuildvrt
# Documentation: https://gdal.org/programs/gdalbuildvrt.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '--long-usage[extended usage]' \
  '(- *)--version[show version]' \
  '-tileindex+[tile index field name (default location)]:name:' \
  '-resolution+[resolution selection]:type:(highest lowest average user same common)' \
  '-tr+[target resolution]:xres yres:' \
  '-tap[align extent to pixel size multiples]' \
  '-te+[target extent]:xmin ymin xmax ymax:' \
  '-addalpha[add alpha mask band]' \
  '*-b+[band number]:band:' \
  '-sd+[subdataset number]:n:' \
  '-allow_projection_difference[allow inputs with different SRS]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '-input_file_list+[file list]:file:_files' \
  '-overwrite[overwrite if exists]' \
  '-write_absolute_path[write absolute paths instead of relative]' \
  '-srcnodata+[source nodata]:value:' \
  '-vrtnodata+[VRT nodata]:value:' \
  '-hidenodata[hide nodata in VRT bands]' \
  '-nodata_max_mask_threshold+[mask threshold]:threshold:' \
  '-ignore_srcmaskband[ignore source mask band]' \
  '-a_srs+[assign output SRS]:srs:' \
  '-r+[resampling method]:resampling:(nearest bilinear cubic cubicspline lanczos average mode)' \
  '-pixel-function+[pixel function for overlap]:function:' \
  '*-pixel-function-arg+[pixel function arg]:NAME=VALUE:' \
  '*-oo+[open option]:NAME=VALUE:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-strict[strict mode (warnings -> errors)]' \
  '-non_strict[non-strict mode (default)]' \
  '-separate[place inputs as separate bands]' \
  '1:output VRT file:_files -g "*.vrt"' \
  '*:input raster file:_files -g "*.(tif|tiff|nc|hdf|grib|grb|jp2|img)"' && ret=0

return ret
