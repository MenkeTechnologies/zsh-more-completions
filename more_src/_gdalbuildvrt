#compdef gdalbuildvrt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-tileindex+[name of tileindex layer]:name:' \
  '-resolution+[resolution selection]:type:(highest lowest average user same)' \
  '-tr+[target resolution]:xres yres:' \
  '-tap[align extent to pixel size multiples]' \
  '-te+[target extent]:xmin ymin xmax ymax:' \
  '-addalpha[add alpha mask band]' \
  '-b+[band number]:band:' \
  '-sd+[subdataset number]:n:' \
  '-allow_projection_difference[allow inputs with different SRS]' \
  '-q[quiet]' \
  '-input_file_list+[file list]:file:_files' \
  '-overwrite[overwrite if exists]' \
  '-srcnodata+[source nodata]:value:' \
  '-vrtnodata+[vrt nodata]:value:' \
  '-ignore_srcmaskband[ignore source mask band]' \
  '-a_srs+[assign output SRS]:srs:' \
  '-r+[resampling method]:resampling:(nearest bilinear cubic cubicspline lanczos average mode)' \
  '-oo+[open option]:NAME=VALUE:' \
  '-strict[strict mode]' \
  '-non_strict[non-strict mode]' \
  '-separate[place inputs as separate bands]' \
  '*-hidenodata[hide nodata]' \
  '1:output VRT file:_files -g "*.vrt"' \
  '*:input raster file:_files -g "*.(tif|tiff|nc|hdf|grib|grb|jp2|img)"' && ret=0

return ret
