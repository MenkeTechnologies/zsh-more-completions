#compdef babelfish
# Documentation: https://man.archlinux.org/search?q=babelfish
# Reference accessed: 2026-05-16

# Zsh completion for babelfish
# Upstream: Translate bash scripts to fish
# Conservative fallback — run `babelfish --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
