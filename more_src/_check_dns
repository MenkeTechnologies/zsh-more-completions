#compdef check_dns

_arguments -s \
  '(-H --hostname)'{-H,--hostname}'=[host name to lookup]:host:_hosts' \
  '(-s --server)'{-s,--server}'=[DNS server]:host:_hosts' \
  '*'{-a,--expected-address}'=[expected address]:addr:' \
  '(-A --expect-authority)'{-A,--expect-authority}'[expect authoritative reply]' \
  '(-n --expect-nxdomain)'{-n,--expect-nxdomain}'[expect NXDOMAIN]' \
  '(-L --all)'{-L,--all}'[require all expected addresses]' \
  '(-w --warning)'{-w,--warning}'=[warning threshold]:threshold:' \
  '(-c --critical)'{-c,--critical}'=[critical threshold]:threshold:' \
  '(-t --timeout)'{-t,--timeout}'=[timeout]:s:' \
  '--extra-opts=[extra opts]:section:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
