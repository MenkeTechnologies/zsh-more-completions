#compdef bgenix
# Documentation: https://enkre.net/cgi-bin/code/bgen/doc/trunk/doc/wiki/bgenix.md
# bgenix: index and query BGEN format genotype files

local ret=1

_arguments -s -S \
  '-g[BGEN file to operate on]:file:_files -g "*.bgen"' \
  '-index[create an index file (.bgen.bgi)]' \
  '-list[list the variants in the index]' \
  '-vcf[transcode data to VCF format]' \
  '-v11[transcode data to BGEN v1.1 format]' \
  '-incl-rsids[include variants with specified rsids]:file:_files' \
  '-excl-rsids[exclude variants with specified rsids]:file:_files' \
  '-incl-range[include variants within genomic ranges]:range' \
  '-excl-range[exclude variants within genomic ranges]:range' \
  '-compression-level[compression level for v1.1 output]:level' \
  '-with-rowid[create index compatible with older sqlite3]' \
  '-help[display help information]' \
  '*:file:_files' && ret=0

return ret
