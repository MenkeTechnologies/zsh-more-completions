#compdef msolve
# Documentation: https://www.mankier.com/1/msolve
# msolve: polynomial system solving through algebraic methods

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-f --file)'{-f,--file}'[input file name (mandatory)]:input file:_files' \
  '(-o --output-file)'{-o,--output-file}'[name of output file]:output file:_files' \
  '(-t --threads)'{-t,--threads}'[number of threads to be used]:threads' \
  '(-v --verbose)'{-v,--verbose}'[level of verbosity 0-2]:level' \
  '(-e --elimination)'{-e,--elimination}'[define an elimination order]:eliminated vars' \
  '(-g --groebner-basis)'{-g,--groebner-basis}'[print reduced Groebner bases]:gb' \
  '(-I --isolate)'{-I,--isolate}'[isolate the real roots]:isol' \
  '(-l --linear-algebra)'{-l,--linear-algebra}'[linear algebra variant]:variant' \
  '(-n --normal-form)'{-n,--normal-form}'[compute normal form of input elements]:nf' \
  '(-p --precision)'{-p,--precision}'[precision in bits for real root isolation]:bits' \
  '(-P --parametrization)'{-P,--parametrization}'[get rational parametrization of solution set]:par' \
  '(-r --reduce-gb)'{-r,--reduce-gb}'[reduce Groebner basis]:red' \
  '-c[handle genericity via variable reordering]:gen' \
  '-d[handle genericity via normal forms]:gen' \
  '-F[file with parametrizations in binary format]:file:_files' \
  '-m[maximal number of pairs used per matrix]:mpr' \
  '-q[use signature-based algorithms]:q' \
  '-s[initial hash table size as power of two]:hts' \
  '-u[steps after which hash table is regenerated]:uht' \
  '-C[use sparse-FGLM-col algorithm]' \
  '-S[use f4sat saturation algorithm]' \
  '--random-seed[initialize the pseudo random generator]:seed' \
  '*:input file:_files' && ret=0

return ret
