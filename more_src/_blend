#compdef blend
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/blend.html
# Source: MRtrix3/mrtrix3 bin/blend — blend two sets of movie frames with overlap (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:input folder 1:_files -/' \
    '2:input folder 2:_files -/' \
    '3:overlap (number of frames):_default' \
    '4:output folder:_files -/' \
    && ret=0

return ret
