#compdef rfmix
# Documentation: https://github.com/slowkoni/rfmix/blob/master/MANUAL.md
# RFMix v2: local ancestry inference using a discriminative modeling approach

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f+[phased query VCF/BCF file]:file:_files -g "*.(vcf|bcf)*"' \
  '-r+[phased reference VCF/BCF file]:file:_files -g "*.(vcf|bcf)*"' \
  '-m+[reference sample map file]:file:_files' \
  '-g+[genetic map file]:file:_files' \
  '-o+[output basename]:basename' \
  '--chromosome=[chromosome to analyze]:chromosome' \
  '-c+[CRF spacing size (SNPs per CRF point)]:size' \
  '-w+[weighting parameter when CRF and RF window sizes differ]:value' \
  '-G+[generations since population contact]:int' \
  '-e+[enable EM optimization, max iterations]:int' \
  '--reanalyze-reference[analyze reference haplotypes as query data]' \
  '--analyze-range=[restrict analysis to genomic range]:range' && ret=0

return ret
