#compdef kibana-cli kbn
# _kibana-cli — Elastic Kibana kbn helper CLI alias (Elastic, Node.js); commander
# upstream: https://github.com/elastic/kibana

_kibana-cli() {
    local -a sub=(
        'bootstrap:install dependencies'
        'reset:wipe local state'
        'run:run a script'
        'check:check workspace'
        'watch:watch files'
        'optimize:run optimizer'
        'build:build distribution'
        'test:run tests'
        'lint:run linters'
        'typecheck:run typecheck'
        'plugin:install/list/remove plugins'
        'docs:run docs server'
        'jest:run jest'
        'gulp:run gulp'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--silent[silent]' \
        '--no-cache[no cache]' \
        '--config=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kbn subcommand' sub ;;
        args)
            case $words[1] in
                bootstrap) _arguments \
                    '--no-validate[no validate]' \
                    '--force-install[force install]' \
                    '--prefer-offline[prefer offline]' \
                    '--no-vscode[no vscode setup]' ;;
                run) _arguments \
                    '--watch[watch]' \
                    '--node-options=+[node options]:str:' \
                    '*:script:_files' ;;
                plugin) _arguments \
                    '1:cmd:(install remove list ls)' \
                    '*:arg:' ;;
                test|jest) _arguments \
                    '--config=+[config]:file:_files' \
                    '--coverage[coverage]' \
                    '--watch[watch]' \
                    '*:pattern:' ;;
                build) _arguments \
                    '--release[release build]' \
                    '--all-platforms[all platforms]' \
                    '--linux[linux build]' \
                    '--darwin[darwin build]' \
                    '--rpm[rpm package]' \
                    '--deb[deb package]' \
                    '--docker[docker image]' \
                    '--skip-archives[skip archives]' \
                    '--skip-os-packages[skip os packages]' \
                    '--skip-node-download[skip node download]' \
                    '--skip-docker-ubi[skip docker ubi]' ;;
                watch|typecheck|lint|check|optimize|docs|gulp|reset) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_kibana-cli "$@"
