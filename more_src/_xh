#compdef xh
# Documentation: https://github.com/ducaale/xh
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: --default-scheme (not documented upstream).
# Note: -h is --headers, not --help (only --help is documented short).
# Added: --debug, --format-options, --resolve, --interface, --unix-socket,
# --native-tls, --generate, --ignore-netrc.

_arguments -s -S \
  '--help[print help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--pretty=[output processing control]:style:(all colors format none)' \
  {-s+,--style=}'[output coloring style]:style:(auto solarized monokai fruity)' \
  '--format-options=[formatting options]:opts:' \
  '--response-charset=[override response encoding]:charset:' \
  '--response-mime=[override response MIME type]:mime:' \
  {-p+,--print=}'[what output to print]:what:' \
  '(-h --headers)'{-h,--headers}'[print response headers only]' \
  '(-b --body)'{-b,--body}'[print response body only]' \
  '(-m --meta)'{-m,--meta}'[print response metadata only]' \
  '*'{-v,--verbose}'[print whole request and response]' \
  '--debug[full error traces and debug logs]' \
  '--all[show intermediate redirects]' \
  {-P+,--history-print=}'[what to print for intermediate requests]:what:' \
  '*'{-q,--quiet}'[do not print to stdout]' \
  {-S,--stream}'[streaming mode]' \
  {-o+,--output=}'[save output to file]:file:_files' \
  {-d,--download}'[download mode]' \
  {-c,--continue}'[resume download]' \
  '--session=[create or reuse named session]:name:' \
  '--session-read-only=[read-only named session]:name:' \
  {-a+,--auth=}'[authentication credentials]:user\:password:' \
  {-A+,--auth-type=}'[authentication mechanism]:type:(basic bearer digest)' \
  '--ignore-netrc[skip .netrc credentials]' \
  '--raw=[pass raw request body]:body:' \
  {-j,--json}'[serialize data items as JSON]' \
  {-f,--form}'[serialize data items as form fields]' \
  '--multipart[force multipart form data]' \
  '*'{-x,--compress}'[compress request body]' \
  {-F,--follow}'[follow redirects]' \
  '--max-redirects=[maximum number of redirects]:number:' \
  '--timeout=[request timeout]:seconds:' \
  '--proxy=[use proxy]:protocol\:url:' \
  '--verify=[TLS certificate verification]:verify:' \
  '--cert=[client TLS certificate]:file:_files -g "*.pem"' \
  '--cert-key=[client TLS certificate key]:file:_files -g "*.pem"' \
  '--ssl=[desired TLS version]:version:(auto tls1 tls1.1 tls1.2 tls1.3)' \
  '--native-tls[use native TLS instead of rustls]' \
  '--https[make HTTPS request]' \
  '--http-version=[HTTP version to use]:version:(1.0 1.1 2)' \
  '--resolve=[override DNS resolution]:host\:address:' \
  '--interface=[bind to specific network interface]:name:' \
  '--unix-socket=[connect via Unix socket]:file:_files' \
  {-I,--ignore-stdin}'[do not read from stdin]' \
  '--curl[print equivalent curl command]' \
  '--curl-long[use long form curl options]' \
  '--offline[construct request but do not send it]' \
  '--check-status[exit with error on HTTP errors]' \
  '--generate=[generate completions or man pages]:kind:' \
  {-4,--ipv4}'[use IPv4]' \
  {-6,--ipv6}'[use IPv6]' \
  '1:method-or-url:' \
  '2:url:_urls' \
  '*:request-item:' \
  && return 0
