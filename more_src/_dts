#compdef dts
# Documentation: https://man.archlinux.org/search?q=dts
# Reference accessed: 2026-05-16
# Source: cargo binstall dts@0.6.14
# Probed via: --generate-completion zsh
# Repository: https://github.com/martinohmann/dts

autoload -U is-at-least

_dts() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-O+[Output sink. Can be specified multiple times. Defaults to stdout if omitted]:SINK:_files' \
'*--sink=[Output sink. Can be specified multiple times. Defaults to stdout if omitted]:SINK:_files' \
'-i+[Set the input encoding]:INPUT_ENCODING:((json\:"JavaScript Object Notation"
yaml\:"Yet Another Markup Language"
toml\:"TOML configuration format"
json5\:"ES5 JSON"
csv\:"Comma separated values"
query-string\:"URL query string"
xml\:"Extensible Markup Language"
text\:"Plaintext document"
gron\:"Gron"
hcl\:"HCL"))' \
'--input-encoding=[Set the input encoding]:INPUT_ENCODING:((json\:"JavaScript Object Notation"
yaml\:"Yet Another Markup Language"
toml\:"TOML configuration format"
json5\:"ES5 JSON"
csv\:"Comma separated values"
query-string\:"URL query string"
xml\:"Extensible Markup Language"
text\:"Plaintext document"
gron\:"Gron"
hcl\:"HCL"))' \
'-d+[Custom delimiter for CSV input]:CSV_INPUT_DELIMITER:_default' \
'--csv-input-delimiter=[Custom delimiter for CSV input]:CSV_INPUT_DELIMITER:_default' \
'-s+[Regex pattern to split text input at]:TEXT_SPLIT_PATTERN:_default' \
'--text-split-pattern=[Regex pattern to split text input at]:TEXT_SPLIT_PATTERN:_default' \
'--glob=[Glob pattern for directories]:GLOB:_default' \
'-j+[A jq expression for transforming the input data]:EXPRESSION:_default' \
'--jq=[A jq expression for transforming the input data]:EXPRESSION:_default' \
'-o+[Set the output encoding]:OUTPUT_ENCODING:((json\:"JavaScript Object Notation"
yaml\:"Yet Another Markup Language"
toml\:"TOML configuration format"
json5\:"ES5 JSON"
csv\:"Comma separated values"
query-string\:"URL query string"
xml\:"Extensible Markup Language"
text\:"Plaintext document"
gron\:"Gron"
hcl\:"HCL"))' \
'--output-encoding=[Set the output encoding]:OUTPUT_ENCODING:((json\:"JavaScript Object Notation"
yaml\:"Yet Another Markup Language"
toml\:"TOML configuration format"
json5\:"ES5 JSON"
csv\:"Comma separated values"
query-string\:"URL query string"
xml\:"Extensible Markup Language"
text\:"Plaintext document"
gron\:"Gron"
hcl\:"HCL"))' \
'--color=[Controls when to use colors]:WHEN:((always\:"Always color output even if stdout is a file"
auto\:"Automatically detect if output should be colored. Coloring is disabled if stdout is not interactive or a dumb term, or the user explicitly disabled colors via \`NO_COLOR\` environment variable"
never\:"Never color output"))' \
'--theme=[Controls the color theme to use]:THEME:_default' \
'--paging=[Controls when to page output]:WHEN:((always\:"Always page output even if you would fit on the screen"
auto\:"Automatically decide when to page output. This will page output only if it does not fit on the screen"
never\:"Never page output"))' \
'--pager=[Controls the output pager to use]:PAGER:_default' \
'-D+[Custom delimiter for CSV output]:CSV_OUTPUT_DELIMITER:_default' \
'--csv-output-delimiter=[Custom delimiter for CSV output]:CSV_OUTPUT_DELIMITER:_default' \
'-J+[Custom separator to join text output with]:TEXT_JOIN_SEPARATOR:_default' \
'--text-join-separator=[Custom separator to join text output with]:TEXT_JOIN_SEPARATOR:_default' \
'--generate-completion=[If provided, outputs the completion file for the given shell]:SHELL:(bash elvish fish powershell zsh)' \
'--csv-without-headers[Indicate that CSV input does not include a header row]' \
'-H[Use CSV headers as keys for the row columns]' \
'--csv-headers-as-keys[Use CSV headers as keys for the row columns]' \
'-P[Read input into a map keyed by file path of the origin file]' \
'--file-paths[Read input into a map keyed by file path of the origin file]' \
'-C[Continue on errors that occur while reading or deserializing input data]' \
'--continue-on-error[Continue on errors that occur while reading or deserializing input data]' \
'--simplify[Simplify input if the encoding supports it]' \
'-c[Emit output data in a compact format]' \
'--compact[Emit output data in a compact format]' \
'-n[Add a trailing newline to the output]' \
'--newline[Add a trailing newline to the output]' \
'-K[Use object keys of the first item as CSV headers]' \
'--keys-as-csv-headers[Use object keys of the first item as CSV headers]' \
'--multi-doc-yaml[Treat output arrays as multiple YAML documents]' \
'--overwrite[Overwrite output files if they exist]' \
'(--generate-completion)--list-themes[List available color themes and exit]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::SOURCE -- Input sources:_files' \
&& ret=0
}

(( $+functions[_dts_commands] )) ||
_dts_commands() {
    local commands; commands=()
    _describe -t commands 'dts commands' commands "$@"
}

if [ "$funcstack[1]" = "_dts" ]; then
    _dts "$@"
else
    compdef _dts dts
fi
