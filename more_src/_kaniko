#compdef kaniko

# Zsh completion for kaniko - container image builder (no daemon)

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--build-arg=[set build-time variables]:arg' \
  '--cache[use cache when building image]' \
  '--cache-copy-layers[cache copy layers]' \
  '--cache-dir=[directory for cached layers]:dir:_directories' \
  '--cache-repo=[repository for cached layers]:repo' \
  '--cache-run-layers[cache run layers]' \
  '--cache-ttl=[cache timeout in hours]:hours' \
  '--cleanup[clean the filesystem at the end]' \
  '--compressed-caching[compress cached layers]' \
  '--context=[path to the build context]:context:_directories' \
  '--context-sub-path=[sub path within the given context]:path' \
  '(-d --destination)'{-d,--destination}'=[registry to push image to]:destination' \
  '--digest-file=[write image digest to file]:file:_files' \
  '(-f --dockerfile)'{-f,--dockerfile}'=[path to the Dockerfile]:file:_files' \
  '--force[force building outside of a container]' \
  '--git=[git spec for remote build context]:spec' \
  '--ignore-path=[ignore these paths when taking snapshot]:path:_files' \
  '--ignore-var-run[ignore /var/run directory when snapshotting]' \
  '--image-name-tag-with-digest[add digest to image tag]' \
  '--image-name-with-digest-file=[write image name with digest to file]:file:_files' \
  '--insecure[push to insecure registry using plain HTTP]' \
  '--insecure-pull[pull from insecure registry using plain HTTP]' \
  '--insecure-registry=[insecure registry using plain HTTP]:registry' \
  '--label=[set metadata for an image]:label' \
  '--log-format=[log format]:format:(text json color)' \
  '--log-timestamp[timestamp in log output]' \
  '--no-push[do not push the image to the registry]' \
  '--no-push-cache[do not push cache layers to registry]' \
  '--oci-layout-path=[path to save OCI image layout]:path:_directories' \
  '--registry-certificate=[registry certificate key pair]:cert' \
  '--registry-mirror=[registry mirror to use]:mirror' \
  '--reproducible[strip timestamps for reproducible builds]' \
  '--single-snapshot[take a single snapshot at the end]' \
  '--skip-tls-verify[skip TLS certificate verification for push]' \
  '--skip-tls-verify-pull[skip TLS certificate verification for pull]' \
  '--skip-tls-verify-registry=[skip TLS verify for given registry]:registry' \
  '--skip-unused-stages[build only used stages]' \
  '--snapshot-mode=[set snapshot mode]:mode:(full redo time)' \
  '--tar-path=[save image as tarball at path]:file:_files' \
  '--target=[set the target build stage]:stage' \
  '--use-new-run[use new run implementation]' \
  '(-v --verbosity)'{-v,--verbosity}'=[log level]:level:(trace debug info warn error fatal panic)' \
  && return 0
