#compdef isolinux
# Documentation: https://wiki.syslinux.org/wiki/index.php?title=ISOLINUX
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# STUB: isolinux is the syslinux ISO 9660 bootloader file (isolinux.bin),
# not a command-line executable. It has no CLI options.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::file:_files' && ret=0
return ret
