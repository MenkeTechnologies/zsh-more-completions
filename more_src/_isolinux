#compdef isolinux
# Documentation: https://man.archlinux.org/search?q=isolinux
# Reference accessed: 2026-05-16

# isolinux: ISO 9660 bootloader stub (from syslinux project)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::isolinux args:_files' && ret=0
return ret
