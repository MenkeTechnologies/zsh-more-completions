#compdef porsmo
# Documentation: https://man.archlinux.org/search?q=porsmo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'pomodoro:start a pomodoro timer'
      'timer:start a countdown timer'
      'stopwatch:start a stopwatch'
    )
    _describe -t commands 'porsmo command' commands && ret=0
    ;;
esac

return ret
