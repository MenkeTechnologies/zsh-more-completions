#compdef cargo-insta

local -a subcommands
subcommands=(
  'review:Review pending snapshots'
  'accept:Accept all pending snapshots'
  'reject:Reject all pending snapshots'
  'pending-snapshots:List pending snapshots'
  'test:Run tests and review snapshots'
  'show:Show a snapshot file'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '--color=[Coloring]:when:(auto always never)' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      review)
        _arguments \
          '--workspace-root=[Workspace root]:dir:_directories' \
          '(-p --package)'{-p,--package}'[Package to review]:package:' \
          '--snapshot-type=[Filter snapshot type]:type:(inline file)' \
          '--include-hidden[Include hidden snapshots]' \
          '--include-ignored[Include ignored snapshots]'
        ;;
      accept|reject)
        _arguments \
          '--workspace-root=[Workspace root]:dir:_directories' \
          '(-p --package)'{-p,--package}'[Package]:package:' \
          '--snapshot-type=[Filter snapshot type]:type:(inline file)' \
          '--include-hidden[Include hidden snapshots]' \
          '--include-ignored[Include ignored snapshots]'
        ;;
      test)
        _arguments \
          '--review[Review after test]' \
          '--accept[Accept all new snapshots]' \
          '--accept-unseen[Accept unseen snapshots]' \
          '--force-update-snapshots[Update all snapshots]' \
          '--delete-unreferenced-snapshots[Delete unreferenced snapshots]' \
          '--check[Fail if snapshots are pending]' \
          '(-p --package)'{-p,--package}'[Package to test]:package:' \
          '--workspace-root=[Workspace root]:dir:_directories' \
          '--release[Test in release mode]' \
          '--features=[Features to enable]:features:' \
          '--all-features[Enable all features]' \
          '--no-default-features[Disable default features]' \
          '--test-runner=[Test runner]:runner:(auto cargo nextest)' \
          '*:test filter:'
        ;;
      show)
        _arguments '1:snapshot file:_files'
        ;;
    esac
    ;;
esac
