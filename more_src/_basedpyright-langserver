#compdef basedpyright-langserver
# Documentation: https://docs.basedpyright.com/latest/installation/command-line-and-language-server/
# basedpyright-langserver - basedpyright Language Server Protocol server

local ret=1

_arguments -s -S \
  '--stdio[communicate over standard input/output]' \
  '--node-ipc[communicate using node IPC]' \
  '--socket=[communicate over a TCP socket on the given port]:port' \
  '--pipe=[communicate over the given named pipe]:pipe' \
  '--clientProcessId=[exit if the given client process id terminates]:pid' && ret=0

return ret
