#compdef flyctl fly

# Zsh completion for flyctl (Fly.io CLI)

local curcontext="$curcontext" state line ret=1

local -a global_flags=(
  '(-t --access-token)'{-t,--access-token}'[Fly API access token]:token'
  '(-j --json)'{-j,--json}'[JSON output]'
  '--verbose[Verbose output]'
  '--app[Application name]:app:_flyctl_apps'
  '(-c --config)'{-c,--config}'[Path to application configuration file]:config file:_files'
  '(-o --org)'{-o,--org}'[Organization slug]:org:_flyctl_orgs'
  '(-r --region)'{-r,--region}'[Fly.io region]:region'
  '--help[Show help]'
)

_flyctl_apps() {
  local -a apps
  apps=(${(f)"$(fly apps list --json 2>/dev/null | jq -r '.[].Name' 2>/dev/null)"})
  compadd -a apps
}

_flyctl_orgs() {
  local -a orgs
  orgs=(${(f)"$(fly orgs list --json 2>/dev/null | jq -r '.[].Slug' 2>/dev/null)"})
  compadd -a orgs
}

_flyctl_machines() {
  local -a machines
  machines=(${(f)"$(fly machine list --json 2>/dev/null | jq -r '.[].id' 2>/dev/null)"})
  compadd -a machines
}

_flyctl_volumes() {
  local -a volumes
  volumes=(${(f)"$(fly volumes list --json 2>/dev/null | jq -r '.[].id' 2>/dev/null)"})
  compadd -a volumes
}

_flyctl_secrets() {
  local -a secrets
  secrets=(${(f)"$(fly secrets list --json 2>/dev/null | jq -r '.[].Name' 2>/dev/null)"})
  compadd -a secrets
}

local -a commands=(
  'apps:Manage apps'
  'auth:Manage authentication'
  'certs:Manage certificates'
  'config:Manage app configuration'
  'dashboard:Open web browser on Fly Web UI for this app'
  'deploy:Deploy Fly applications'
  'destroy:Permanently destroy an app'
  'dig:Make DNS requests against Fly.io internal DNS'
  'dns-records:Manage DNS records'
  'doctor:The doctor checks for common problems'
  'domains:Manage domains'
  'extensions:Manage Fly extensions'
  'history:List app deployment history'
  'image:Manage app image'
  'ips:Manage IP addresses'
  'launch:Create and configure a new app'
  'logs:View app logs'
  'machine:Manage Fly Machines'
  'monitor:Monitor deployments'
  'open:Open browser to current deployed application'
  'orgs:Manage organizations'
  'ping:Test connectivity to Fly.io'
  'platform:Fly platform information'
  'proxy:Proxies connections to a Fly Machine'
  'regions:Manage regions'
  'releases:List app releases'
  'restart:Restart an application'
  'resume:Resume an application'
  'scale:Scale app resources'
  'secrets:Manage app secrets'
  'ssh:Use SSH'
  'status:Show app status'
  'suspend:Suspend an application'
  'tokens:Manage Fly.io API tokens'
  'version:Show version information'
  'volumes:Manage Fly Volumes'
  'wireguard:Commands that manage WireGuard peer connections'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'flyctl command' commands && ret=0
    ;;
  args)
    case $words[1] in
      apps)
        local -a apps_cmds=(
          'create:Create a new application'
          'destroy:Permanently destroy an app'
          'list:List applications'
          'move:Move an app to another organization'
          'open:Open browser to current deployed application'
          'releases:List app releases'
          'restart:Restart an application'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:apps command:->apps_cmd' \
          '*::arg:->apps_args' && ret=0
        case $state in
          apps_cmd)
            _describe -t commands 'apps command' apps_cmds && ret=0
            ;;
          apps_args)
            case $words[1] in
              create)
                _arguments -s -S \
                  $global_flags \
                  '--name[Application name]:name' \
                  '--network[Custom network]:network' \
                  '--machines[Use Machines platform]' \
                  ':app name' && ret=0
                ;;
              destroy)
                _arguments -s -S \
                  $global_flags \
                  '-y[Accept all confirmations]' \
                  ':app name:_flyctl_apps' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $global_flags && ret=0
                ;;
              move)
                _arguments -s -S \
                  $global_flags \
                  '-y[Accept all confirmations]' \
                  ':app name:_flyctl_apps' && ret=0
                ;;
              open|releases|restart)
                _arguments -s -S \
                  $global_flags \
                  ':app name:_flyctl_apps' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      auth)
        local -a auth_cmds=(
          'docker:Authenticate docker'
          'login:Log in a user'
          'logout:Logs out the currently logged in user'
          'signup:Create a new fly account'
          'token:Show the current auth token'
          'whoami:Displays the users email address'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:auth command:->auth_cmd' && ret=0
        case $state in
          auth_cmd)
            _describe -t commands 'auth command' auth_cmds && ret=0
            ;;
        esac
        ;;
      certs)
        local -a certs_cmds=(
          'add:Add a certificate for an app'
          'check:Checks DNS configuration for a certificate'
          'list:List certificates for an app'
          'remove:Removes a certificate from an app'
          'show:Shows certificate information'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:certs command:->certs_cmd' \
          '*::arg:->certs_args' && ret=0
        case $state in
          certs_cmd)
            _describe -t commands 'certs command' certs_cmds && ret=0
            ;;
          certs_args)
            _arguments -s -S \
              $global_flags \
              ':hostname' && ret=0
            ;;
        esac
        ;;
      config)
        local -a config_cmds=(
          'display:Display an app'\''s configuration'
          'env:Display an app'\''s runtime environment variables'
          'save:Save an app'\''s config file'
          'validate:Validate an app'\''s config file'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:config command:->config_cmd' && ret=0
        case $state in
          config_cmd)
            _describe -t commands 'config command' config_cmds && ret=0
            ;;
        esac
        ;;
      deploy)
        _arguments -s -S \
          $global_flags \
          '--image[Deploy using an existing image]:image' \
          '--dockerfile[Path to a Dockerfile]:dockerfile:_files' \
          '--build-arg[Set build-time variables]:arg=value' \
          '--build-secret[Set build secrets]:id=value' \
          '--build-target[Set the target build stage]:target' \
          '--ignorefile[Path to a .dockerignore file]:file:_files' \
          '--image-label[Image label to use when tagging]:label' \
          '--local-only[Only perform builds locally]' \
          '--push[Push image to registry]' \
          '--remote-only[Only perform builds remotely]' \
          '--now[Deploy immediately without confirmation]' \
          '--detach[Return immediately instead of monitoring deployment]' \
          '--strategy[Deployment strategy]:strategy:(immediate rolling canary bluegreen)' \
          '--wait-timeout[Time to wait for deployment to complete]:seconds' \
          '--release-command-timeout[Time to wait for release command]:seconds' \
          '--no-cache[Do not use build cache]' \
          '--auto-confirm[Accept all confirmations]' \
          '--ha[Create spare machines for high availability]' \
          '*:path:_files -/' && ret=0
        ;;
      destroy)
        _arguments -s -S \
          $global_flags \
          '-y[Accept all confirmations]' \
          ':app name:_flyctl_apps' && ret=0
        ;;
      launch)
        _arguments -s -S \
          $global_flags \
          '--name[Application name]:name' \
          '--copy-config[Use an existing fly.toml]' \
          '--dockerfile[Path to Dockerfile]:dockerfile:_files' \
          '--dockerignore-from-gitignore[Use .gitignore to build .dockerignore]' \
          '--generate-name[Auto-generate app name]' \
          '--image[Use existing Docker image]:image' \
          '--no-deploy[Do not deploy after configuration]' \
          '--now[Deploy immediately]' \
          '--path[Path to app source]:path:_files -/' \
          '--ha[Create spare machines for high availability]' \
          '--internal-port[Set internal port]:port' && ret=0
        ;;
      logs)
        _arguments -s -S \
          $global_flags \
          '--instance[Show logs from specific instance]:instance' \
          '--region[Show logs from specific region]:region' && ret=0
        ;;
      machine)
        local -a machine_cmds=(
          'api-proxy:Establish API proxy to app machines'
          'clone:Clone a Fly Machine'
          'cordon:Deactivate all services on a machine'
          'destroy:Destroy a Fly Machine'
          'exec:Execute a command on a machine'
          'kill:Kill (SIGKILL) a Fly Machine'
          'list:List Fly Machines'
          'restart:Restart one or more Fly Machines'
          'run:Run a machine'
          'start:Start one or more Fly Machines'
          'status:Show current status of a running machine'
          'stop:Stop one or more Fly Machines'
          'uncordon:Reactivate all services on a machine'
          'update:Update a machine'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:machine command:->machine_cmd' \
          '*::arg:->machine_args' && ret=0
        case $state in
          machine_cmd)
            _describe -t commands 'machine command' machine_cmds && ret=0
            ;;
          machine_args)
            case $words[1] in
              run)
                _arguments -s -S \
                  $global_flags \
                  '--name[Machine name]:name' \
                  '--region[Target region]:region' \
                  '--size[Preset VM size]:size:(shared-cpu-1x shared-cpu-2x shared-cpu-4x shared-cpu-8x performance-1x performance-2x performance-4x performance-8x performance-16x)' \
                  '--cpus[Number of CPUs]:cpus' \
                  '--memory[Memory in MB]:memory' \
                  '--volume[Volume to mount]:volume' \
                  '--port[Exposed port mapping]:port' \
                  '--env[Set environment variable]:key=value' \
                  '--entrypoint[Override image entrypoint]:entrypoint' \
                  '--schedule[Schedule for the machine]:schedule:(hourly daily weekly monthly)' \
                  '--autostart[Automatically start machine]' \
                  '--autostop[Automatically stop machine]' \
                  '--restart[Restart policy]:policy:(no always on-fail)' \
                  ':image' && ret=0
                ;;
              destroy)
                _arguments -s -S \
                  $global_flags \
                  '-f[Force destroy]' \
                  '*:machine id:_flyctl_machines' && ret=0
                ;;
              clone)
                _arguments -s -S \
                  $global_flags \
                  '--name[Name for the new machine]:name' \
                  '--region[Target region]:region' \
                  ':machine id:_flyctl_machines' && ret=0
                ;;
              exec)
                _arguments -s -S \
                  $global_flags \
                  ':machine id:_flyctl_machines' \
                  '*:command' && ret=0
                ;;
              status|start|stop|restart|kill|cordon|uncordon)
                _arguments -s -S \
                  $global_flags \
                  '*:machine id:_flyctl_machines' && ret=0
                ;;
              update)
                _arguments -s -S \
                  $global_flags \
                  '--image[New Docker image]:image' \
                  '--size[Preset VM size]:size' \
                  '--cpus[Number of CPUs]:cpus' \
                  '--memory[Memory in MB]:memory' \
                  '--metadata[Metadata key=value]:metadata' \
                  '-y[Accept all confirmations]' \
                  ':machine id:_flyctl_machines' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $global_flags \
                  '-q[Quiet mode, only show IDs]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      orgs)
        local -a orgs_cmds=(
          'list:List organizations'
          'show:Show organization details'
          'create:Create a new organization'
          'delete:Delete an organization'
          'invite:Invite a user to an organization'
          'revoke:Revoke a pending invitation'
          'remove:Remove a member from an organization'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:orgs command:->orgs_cmd' \
          '*::arg:->orgs_args' && ret=0
        case $state in
          orgs_cmd)
            _describe -t commands 'orgs command' orgs_cmds && ret=0
            ;;
          orgs_args)
            case $words[1] in
              create)
                _arguments -s -S \
                  $global_flags \
                  ':org name' && ret=0
                ;;
              delete|show)
                _arguments -s -S \
                  $global_flags \
                  '-y[Accept all confirmations]' \
                  ':org:_flyctl_orgs' && ret=0
                ;;
              invite)
                _arguments -s -S \
                  $global_flags \
                  ':org:_flyctl_orgs' \
                  ':email' && ret=0
                ;;
              revoke|remove)
                _arguments -s -S \
                  $global_flags \
                  ':org:_flyctl_orgs' \
                  ':email' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      scale)
        local -a scale_cmds=(
          'count:Change an app'\''s VM count'
          'memory:Set VM memory'
          'show:Show current resources'
          'vm:Change an app'\''s VM size'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:scale command:->scale_cmd' \
          '*::arg:->scale_args' && ret=0
        case $state in
          scale_cmd)
            _describe -t commands 'scale command' scale_cmds && ret=0
            ;;
          scale_args)
            case $words[1] in
              count)
                _arguments -s -S \
                  $global_flags \
                  '--max-per-region[Max machines per region]:count' \
                  '--region[Target region]:region' \
                  '-y[Accept all confirmations]' \
                  ':count' && ret=0
                ;;
              memory)
                _arguments -s -S \
                  $global_flags \
                  ':memory in MB' && ret=0
                ;;
              show)
                _arguments -s -S \
                  $global_flags && ret=0
                ;;
              vm)
                _arguments -s -S \
                  $global_flags \
                  ':size:(shared-cpu-1x shared-cpu-2x shared-cpu-4x shared-cpu-8x performance-1x performance-2x performance-4x performance-8x performance-16x)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      secrets)
        local -a secrets_cmds=(
          'deploy:Deploy staged secrets'
          'import:Import secrets from stdin'
          'list:List app secrets'
          'set:Set one or more secrets'
          'unset:Unset one or more secrets'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:secrets command:->secrets_cmd' \
          '*::arg:->secrets_args' && ret=0
        case $state in
          secrets_cmd)
            _describe -t commands 'secrets command' secrets_cmds && ret=0
            ;;
          secrets_args)
            case $words[1] in
              set)
                _arguments -s -S \
                  $global_flags \
                  '--stage[Stage the secret without deploying]' \
                  '--detach[Return immediately]' \
                  '*:name=value' && ret=0
                ;;
              unset)
                _arguments -s -S \
                  $global_flags \
                  '--stage[Stage the removal without deploying]' \
                  '--detach[Return immediately]' \
                  '*:secret name:_flyctl_secrets' && ret=0
                ;;
              import)
                _arguments -s -S \
                  $global_flags \
                  '--stage[Stage secrets without deploying]' \
                  '--detach[Return immediately]' && ret=0
                ;;
              deploy)
                _arguments -s -S \
                  $global_flags \
                  '--detach[Return immediately]' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $global_flags && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      ssh)
        local -a ssh_cmds=(
          'console:Connect to a running instance via SSH'
          'issue:Issue a new SSH credential'
          'log:Log of SSH certificates'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:ssh command:->ssh_cmd' \
          '*::arg:->ssh_args' && ret=0
        case $state in
          ssh_cmd)
            _describe -t commands 'ssh command' ssh_cmds && ret=0
            ;;
          ssh_args)
            case $words[1] in
              console)
                _arguments -s -S \
                  $global_flags \
                  '--select[Select which machine to connect to]' \
                  '--address[Address of the machine]:address' \
                  '--user[User to log in as]:user' \
                  '--command[Command to run]:command' \
                  ':machine address' && ret=0
                ;;
              issue)
                _arguments -s -S \
                  $global_flags \
                  '--email[Email address]:email' \
                  '--username[Username]:username' \
                  '--hours[Validity in hours]:hours' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      status)
        _arguments -s -S \
          $global_flags \
          '--all[Show completed instances]' \
          '--deployment[Display deployment status]' && ret=0
        ;;
      volumes)
        local -a volumes_cmds=(
          'create:Create a new volume'
          'delete:Delete a volume'
          'destroy:Destroy a volume'
          'extend:Extend a volume'
          'fork:Fork a volume'
          'list:List volumes'
          'show:Show volume details'
          'snapshots:Manage volume snapshots'
          'update:Update a volume'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:volumes command:->volumes_cmd' \
          '*::arg:->volumes_args' && ret=0
        case $state in
          volumes_cmd)
            _describe -t commands 'volumes command' volumes_cmds && ret=0
            ;;
          volumes_args)
            case $words[1] in
              create)
                _arguments -s -S \
                  $global_flags \
                  '--region[Target region]:region' \
                  '--size[Volume size in GB]:size' \
                  '--snapshot-id[Restore from snapshot]:snapshot id' \
                  '--require-unique-zone[Require unique hardware zone]' \
                  '--count[Number of volumes to create]:count' \
                  '-y[Accept all confirmations]' \
                  ':volume name' && ret=0
                ;;
              delete|destroy)
                _arguments -s -S \
                  $global_flags \
                  '-y[Accept all confirmations]' \
                  ':volume id:_flyctl_volumes' && ret=0
                ;;
              extend)
                _arguments -s -S \
                  $global_flags \
                  '--size[New size in GB]:size' \
                  ':volume id:_flyctl_volumes' && ret=0
                ;;
              fork)
                _arguments -s -S \
                  $global_flags \
                  '--name[Name for new volume]:name' \
                  '--region[Target region]:region' \
                  '--require-unique-zone[Require unique hardware zone]' \
                  ':volume id:_flyctl_volumes' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $global_flags && ret=0
                ;;
              show)
                _arguments -s -S \
                  $global_flags \
                  ':volume id:_flyctl_volumes' && ret=0
                ;;
              snapshots)
                _arguments -s -S \
                  $global_flags \
                  ':volume id:_flyctl_volumes' && ret=0
                ;;
              update)
                _arguments -s -S \
                  $global_flags \
                  '--snapshot-retention[Snapshot retention in days]:days' \
                  '--auto-backup-enabled[Enable auto backups]:enabled:(true false)' \
                  ':volume id:_flyctl_volumes' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      version)
        _arguments -s -S \
          $global_flags && ret=0
        ;;
      restart)
        _arguments -s -S \
          $global_flags \
          '--force-stop[Force stop before restart]' && ret=0
        ;;
      ips)
        local -a ips_cmds=(
          'allocate-v4:Allocate an IPv4 address'
          'allocate-v6:Allocate an IPv6 address'
          'list:List allocated IP addresses'
          'private:List private IP addresses'
          'release:Release an IP address'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:ips command:->ips_cmd' \
          '*::arg:->ips_args' && ret=0
        case $state in
          ips_cmd)
            _describe -t commands 'ips command' ips_cmds && ret=0
            ;;
          ips_args)
            case $words[1] in
              allocate-v4)
                _arguments -s -S \
                  $global_flags \
                  '--shared[Allocate a shared IP]' \
                  '--region[Target region]:region' \
                  '-y[Accept all confirmations]' && ret=0
                ;;
              allocate-v6)
                _arguments -s -S \
                  $global_flags \
                  '--region[Target region]:region' \
                  '--private[Allocate a private IPv6]' && ret=0
                ;;
              release)
                _arguments -s -S \
                  $global_flags \
                  ':ip address' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      tokens)
        _arguments -s -S \
          $global_flags \
          '1:tokens command:((create\:"Create a new token" list\:"List tokens" revoke\:"Revoke a token"))' && ret=0
        ;;
    esac
    ;;
esac

return ret
