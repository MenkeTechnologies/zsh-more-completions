#compdef madis2nc
# Documentation: https://metplus.readthedocs.io/projects/met/en/latest/Users_Guide/reformat_point.html
# madis2nc - MET tool to convert MADIS point observations to NetCDF

local ret=1

_arguments -s \
  '-type[type of MADIS observations]:type:(metar raob profiler maritime mesonet acarsProfiles)' \
  '-config[configuration file for field summaries]:file:_files' \
  '-qc_dd[comma-separated acceptable QC flag values]:list:' \
  '-lvl_dim[comma-separated vertical level dimensions to process]:list:' \
  '-rec_beg[zero-based index of first MADIS record]:n:' \
  '-rec_end[zero-based index of last MADIS record]:n:' \
  '-mask_grid[named grid or gridded file for spatial filtering]:grid:' \
  '-mask_poly[polyline masking file for spatial filtering]:file:_files' \
  '-mask_sid[station ID masking file or comma-separated list]:sid:' \
  '-log[direct output and errors to log file]:file:_files' \
  '-v[verbosity level]:level:' \
  '-compress[NetCDF compression level (0-9)]:level:' \
  '*:file:_files' && ret=0

return ret
