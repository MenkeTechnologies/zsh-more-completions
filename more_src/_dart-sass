#compdef dart-sass sass
# Documentation: https://sass-lang.com/documentation/cli/dart-sass/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local deprecation_ids
deprecation_ids='(call-string elseif moz-document relative-canonical new-global color-module-compat slash-div bogus-combinators strict-unary function-units duplicate-var-flags null-alpha abs-percent fs-importer-cwd feature-exists color-4-api color-functions legacy-js-api import global-builtin compile-string-relative-url misplaced-rest with-private if-function function-name)'

_arguments -s \
  '--stdin[read input from stdin]' \
  '--indented[indented syntax]' \
  '--no-indented[no indented syntax]' \
  '*'{-I,--load-path}'=[load path]:dir:_files -/' \
  '(-p --pkg-importer)'{-p,--pkg-importer}'=[importer]:type:(node)' \
  '(-s --style)'{-s,--style}'=[style]:style:(expanded compressed)' \
  '--no-charset[no @charset]' \
  '--charset[emit @charset]' \
  '--error-css[emit error CSS]' \
  '--no-error-css[no error CSS]' \
  '--update[only modified]' \
  '--no-source-map[no source map]' \
  '--source-map-urls=[urls]:type:(relative absolute)' \
  '--embed-sources[embed sources]' \
  '--embed-source-map[embed source map]' \
  '(-w --watch)'{-w,--watch}'[watch]' \
  '--poll[poll]' \
  '--stop-on-error[stop on error]' \
  '(-i --interactive)'{-i,--interactive}'[REPL]' \
  '(-c --color)'{-c,--color}'[color]' \
  '--no-color[no color]' \
  '--no-unicode[ASCII errors]' \
  '--unicode[unicode errors]' \
  '--verbose[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--quiet-deps[quiet deps]' \
  "--fatal-deprecation=[fatal id/version]:id:$deprecation_ids" \
  "--future-deprecation=[future id]:id:$deprecation_ids" \
  "--silence-deprecation=[silence id]:id:$deprecation_ids" \
  '--trace[stack trace]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:input:_files -g "*.(scss|sass)"'
