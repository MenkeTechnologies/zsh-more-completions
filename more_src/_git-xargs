#compdef git-xargs
# Documentation: https://man.archlinux.org/search?q=git-xargs
# Reference accessed: 2026-05-16

# https://github.com/gruntwork-io/git-xargs — urfave/cli v1 (main.go, common/common.go)
_arguments -s -S   '(-h --help)'{-h,--help}'[help]'   '-v[version]'   '--loglevel=-[logrus level]:level:(panic fatal error warn info debug trace)'   '--github-org=-[fetch all repos from org]'   '--draft[open PRs as draft]'   '--dry-run[no push / no PRs]'   '--skip-pull-requests[push branch without PRs]'   '--skip-archived-repos[exclude archived with --github-org]'   '*--repo=-[target repo owner/name]'   '--repos=-[file listing repos one per line]:file:_files'   '--branch-name=-[working branch name]'   '--base-branch-name=-[merge target branch]'   '--commit-message=-[commit message]'   '--pull-request-title=-[PR title]'   '--pull-request-description=-[PR body]'   '*--reviewers=-[GH usernames to request]'   '*--team-reviewers=-[GH team slugs to request]'   '--seconds-between-prs=-[sleep between PRs]'   '--max-pr-retries=-[retries on rate limit]'   '--seconds-to-wait-when-rate-limited=-[extra sleep when rate limited]'   '--max-concurrent-clones=-[parallel clones; 0 = unlimited]'   '--no-skip-ci[do not prepend skip-ci tag to commits]'   '--keep-cloned-repositories[keep temp clones]'   '*::script and args:_normal'
