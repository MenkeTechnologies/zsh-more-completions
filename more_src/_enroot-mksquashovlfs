#compdef enroot-mksquashovlfs
# Documentation: https://github.com/NVIDIA/enroot/blob/main/bin/enroot-mksquashovlfs.c
# enroot helper: make a squashfs from an OverlayFS lowerdir stack.
# Usage: enroot-mksquashovlfs DIR[:DIR...] DEST [options]
# Trailing options are passed through to mksquashfs.

local ret=1

_arguments -s -S \
  '1:lowerdir stack (DIR[:DIR...]):_files -/' \
  '2:destination image:_files' \
  '*:mksquashfs option:' && ret=0

return ret
