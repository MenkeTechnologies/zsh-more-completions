#compdef mollie

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'browse:open Mollie web resources in the browser'
  'captures:operations on the Captures API'
  'chargebacks:operations on the Chargebacks API'
  'customers:operations on the Customers API'
  'invoices:operations on the Invoices API'
  'methods:list/activate Mollie payment methods'
  'payments:operations on the Payments API'
  'permissions:Mollie OAuth2 permissions'
  'profiles:operations on website profiles'
  'refunds:operations on the Refunds API'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '--curl[print the curl representation of the request]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--json[output JSON response]' \
  '(-m --mode)'{-m+,--mode=}'[API target]:mode:(test live)' \
  '(-t --token)'{-t+,--token=}'[auth token type/env]:token:' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a crud_subs=(
  'list:list resources'
  'get:get a single resource'
  'create:create a resource'
  'update:update a resource'
  'cancel:cancel a resource'
)

case $state in
  (cmd) _describe -t cmds 'mollie command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (payments|customers|invoices|profiles|refunds|chargebacks|captures|methods)
        _describe -t crud 'subcommand' crud_subs && ret=0 ;;
      (browse)
        _arguments '*::resource:(dashboard customers payments orders refunds settings)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
