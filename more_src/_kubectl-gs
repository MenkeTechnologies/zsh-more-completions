#compdef kubectl-gs

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'deploy:render workload cluster manifest set'
      'get:list or fetch Giant Swarm resources'
      'gitops:gitops repository helpers'
      'login:OIDC login against management cluster'
      'template:CR templates for clusters, nodepools, apps, catalogs'
      'update:update custom resources'
      'validate:validate manifests'
      'selfupdate:update kubectl-gs'
      'credential-plugin:internal exec auth plugin'
      'version:print version'
    )
    _describe -t commands 'kubectl-gs command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '--context=[kubectl context override]:context' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
