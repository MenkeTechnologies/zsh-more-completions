#compdef kubectl-gs
# Documentation: https://docs.giantswarm.io/reference/kubectl-gs/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'login:ensure an authenticated kubectl context (OIDC)'
      'logout:remove the kubectl-gs OIDC context'
      'get:list or fetch Giant Swarm resources'
      'deploy:deploy a Helm chart in a cluster'
      'template:create manifests for clusters, nodepools, apps, catalogs, organizations'
      'update:update App or schedule a cluster update'
      'gitops:GitOps repository helpers'
      'version:print version'
      'help:help for a command'
    )
    _describe -t commands 'kubectl-gs command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '--context=[kubectl context override]:context' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
