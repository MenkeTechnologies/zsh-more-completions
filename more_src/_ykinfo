#compdef ykinfo
# Documentation: https://developers.yubico.com/yubikey-personalization/Manuals/ykinfo.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-s[show serial number in decimal]' \
  '-m[show serial number as modhex]' \
  '-H[show serial number as hex]' \
  '-v[show firmware version]' \
  '-t[show touch level]' \
  '-p[show programming sequence]' \
  '-1[show slot 1 status]' \
  '-2[show slot 2 status]' \
  '-c[show YubiKey capability information]' \
  '-a[show all information above]' \
  '-q[quiet mode (only values)]' \
  '-n+[read from nth key found]:n:' \
  '(- *)-V[print tool version]' \
  '(- *)-h[show help]' && ret=0

return ret
