#compdef ykinfo

# Zsh completion for ykinfo (YubiKey information tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-s[Show serial number in decimal]' \
  '-m[Show serial number in modhex]' \
  '-H[Show serial number in hex]' \
  '-v[Show firmware version]' \
  '-t[Show touch level]' \
  '-p[Show programming sequence]' \
  '-1[Select slot 1]' \
  '-2[Select slot 2]' \
  '-V[Show vendor/product/version]' \
  '-q[Quiet mode (only output values)]' \
  '-a[Show all information]' \
  '-h[Print help]' && ret=0

return ret
