#compdef pcb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--gui=[GUI driver]:gui:(gtk lesstif batch)' \
  '--export=[exporter]:exporter:(bom dxf eps gcode gerber lpr nelma png ps remote svg)' \
  '--action-string=[run actions]:actions:' \
  '--copy-style[copy layout style]' \
  '--debug-actions[print actions as executed]' \
  '--font-path=[font search path]:path:_files -/' \
  '--lib-newlib=[library search path]:path:_files -/' \
  '--reset-after-element[reset visibility after element actions]' \
  '--background-image=[background image]:file:_files -g "*.{png,xpm}"' \
  '--default-PCB=[default PCB template]:file:_files -g "*.pcb"' \
  '--script=[ActionScript file]:file:_files' \
  '--bug-report=[email for bug reports]:email:' \
  '--save-last-command[save last command]' \
  '*:file:_files -g "*.pcb"' && ret=0

return ret
