#compdef dvbtraffic
# _dvbtraffic — Linux-DVB dvbtraffic real-time MPEG-TS PID bandwidth analyzer for live DVB streams showing pid table sizes and bitrates (linuxtv team, C); getopt
# upstream: https://www.linuxtv.org/

_dvbtraffic() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[adapter]:n:(0 1 2 3)' \
        '-d+[demux]:n:(0 1 2 3)' \
        '-f+[frontend]:n:(0 1 2 3)' \
        '-i+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '-r+[refresh seconds]:n:' \
        '-c[CSV output]' \
        '-n[no curses]' \
        '-s[show service names]' \
        '-S[ITU-T H.222 mode]' \
        '-t+[time-out seconds]:n:' \
        '-D+[debug level]:n:' \
        '-T[trace mode]' \
        '-q[quiet]' \
        '-w[wide mode]' \
        '-x[hex PID display]'
}

_dvbtraffic "$@"
