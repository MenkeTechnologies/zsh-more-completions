#compdef pacemaker-remoted
# Documentation: https://man.archlinux.org/search?q=pacemaker-remoted
# Reference accessed: 2026-05-16

# Pacemaker remote-node executor subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-remoted args:_files' && ret=0
return ret
