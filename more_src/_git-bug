#compdef git-bug

# Zsh completion for git-bug (distributed bug tracker embedded in git)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'add:create a new bug'
      'bridge:configure and manage bridges to other trackers'
      'commands:display available commands'
      'comment:display or add comments'
      'deselect:clear the default bug'
      'label:display or modify bug labels'
      'ls:list bugs'
      'ls-id:list bug IDs'
      'ls-label:list valid labels'
      'pull:pull bugs from a remote'
      'push:push bugs to a remote'
      'rm:remove a bug'
      'select:select a default bug'
      'show:display details of a bug'
      'status:display or change a bug status'
      'termui:launch the terminal UI'
      'title:display or change a bug title'
      'user:display or change the user identity'
      'version:show version'
      'webui:launch the web UI'
    )
    _describe -t commands 'git-bug command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (add)
        _arguments \
          '(-t --title)'{-t,--title}'[bug title]:title' \
          '(-m --message)'{-m,--message}'[bug message]:message' \
          '(-F --file)'{-F,--file}'[message from file]:file:_files' && ret=0
        ;;
      (comment)
        _arguments '1:subcommand:(add edit)' && ret=0
        ;;
      (label)
        _arguments '1:subcommand:(add rm)' && ret=0
        ;;
      (ls)
        _arguments \
          '(-s --status)'{-s,--status}'[filter by status]:status:(open closed)' \
          '(-a --author)'{-a,--author}'[filter by author]:author' \
          '(-l --label)'{-l,--label}'[filter by label]:label' \
          '(-t --title)'{-t,--title}'[filter by title]:title' \
          '(-n --no)'{-n,--no}'[filter by no label]:label' \
          '--by[sort field]:field:(id creation edit)' \
          '--direction[sort direction]:direction:(asc desc)' \
          '(-f --format)'{-f,--format}'[output format]:format:(default plain json org-mode)' && ret=0
        ;;
      (show)
        _arguments \
          '(-f --format)'{-f,--format}'[output format]:format:(default plain json org-mode)' \
          '1:bug ID' && ret=0
        ;;
      (status)
        _arguments '1:subcommand:(close open)' && ret=0
        ;;
      (title)
        _arguments '1:subcommand:(edit)' && ret=0
        ;;
      (user)
        _arguments '1:subcommand:(adopt create ls)' && ret=0
        ;;
      (webui)
        _arguments \
          '--port[listen port]:port' \
          '--open[open in browser]' \
          '--read-only[read-only mode]' && ret=0
        ;;
      (pull|push)
        _arguments '1:remote:->remotes' && ret=0
        ;;
    esac
    ;;
esac

case $state in
  (remotes)
    local -a remotes
    remotes=(${(f)"$(git remote 2>/dev/null)"})
    _describe -t remotes 'remote' remotes && ret=0
    ;;
esac

return ret
