#compdef rbac_control
# Documentation: https://documentation.wazuh.com/current/user-manual/api/rbac/reference.html
# Wazuh rbac_control - manage RBAC database (passwords, factory reset)

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((change-password\:"change default user passwords" factory-reset\:"reset RBAC database to factory defaults"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      factory-reset)
        _arguments -s \
          '(-f --force)'{-f,--force}'[do not ask for confirmation]' && ret=0
        ;;
    esac
    ;;
esac

return ret
