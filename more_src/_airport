#compdef airport

# macOS Airport WiFi utility

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --scan)'{-s,--scan}'[scan for available WiFi networks]' \
  '(-I --getinfo)'{-I,--getinfo}'[print current wireless status]' \
  '(-z --disassociate)'{-z,--disassociate}'[disassociate from any network]' \
  '(-c --channel)'{-c,--channel}'=[set WiFi channel]:channel' \
  '(-p --password)'{-p,--password}'=[specify WPA password]:password' \
  '--bssid=[specify BSSID to join]:bssid' \
  '*:SSID to join' && ret=0

return ret
