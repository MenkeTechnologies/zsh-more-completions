#compdef topicctl
# Documentation: https://man.archlinux.org/search?q=topicctl
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/topicctl
local curcontext="$curcontext" state line ret=1

local -a _topicctl_cmds
_topicctl_cmds=(
  'apply:apply topic configuration'
  'bootstrap:bootstrap cluster ACLs'
  'check:validate configs against Kafka'
  'create:create topics from config'
  'delete:delete topics'
  'get:inspect topic metadata'
  'rebalance:rebalance partitions'
  'repl:interactive repl'
  'reset:reset topic data'
  'tail:tail topic messages'
  'tester:test producer/consumer setup'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '--no-spinner[disable progress spinners]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'topicctl command' _topicctl_cmds && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s -S \
          '*:topic configs:_files' \
          '--path-prefix[prefix for topic config paths]:prefix' \
          '--check-leaders[check partition leaders]' \
          '--validate-only[validate YAML only; no cluster contact]' \
          && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
