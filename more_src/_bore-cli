#compdef bore
# _bore-cli — bore TCP tunnel CLI (Rust); minimal client+server like ngrok for exposing a local port over remote host
# upstream: https://github.com/ekzhang/bore

_bore-cli() {
    local -a sub=(
        'local:expose a local port via bore server'
        'server:run a bore server'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bore subcommand' sub ;;
        args)
            case $words[1] in
                local) _arguments \
                    '(-l --local-host)'{-l,--local-host}'+[local host]:host:_hosts' \
                    '(-p --port)'{-p,--port}'+[remote port]:port:' \
                    '(-t --to)'{-t,--to}'+[bore server host]:host:_hosts' \
                    '(-s --secret)'{-s,--secret}'+[shared secret]:secret:' \
                    '1:local port:' ;;
                server) _arguments \
                    '--min-port+[min remote port]:port:' \
                    '--max-port+[max remote port]:port:' \
                    '--bind-addr+[bind address]:host:_hosts' \
                    '--bind-tunnels+[tunnels bind address]:host:_hosts' \
                    '(-s --secret)'{-s,--secret}'+[shared secret]:secret:' ;;
            esac
            ;;
    esac
}

_bore-cli "$@"
