#compdef osm2pgsql

# Zsh completion for osm2pgsql - OpenStreetMap data to PostGIS

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--verbose}'[verbose output]' \
  '(-d --database)'{-d,--database}'=[database name]:database name' \
  '(-U --username)'{-U,--username}'=[database user]:username:_users' \
  '(-H --host)'{-H,--host}'=[database host]:hostname:_hosts' \
  '(-P --port)'{-P,--port}'=[database port]:port number' \
  '-W[prompt for database password]' \
  '(-S --style)'{-S,--style}'=[style file]:style file:_files -g "*.style"' \
  '(-s --slim)'{-s,--slim}'[store temporary data in database]' \
  '--flat-nodes=[file for flat node storage]:file:_files' \
  '(-C --cache)'{-C,--cache}'=[cache size in MB]:megabytes' \
  '(--append)--create[create tables (default, removes existing data)]' \
  '(--create)--append[append data to existing tables]' \
  '(-p --prefix)'{-p,--prefix}'=[table name prefix]:prefix' \
  '(-G --multi-geometry)'{-G,--multi-geometry}'[generate multi-geometry features]' \
  '(-l --latlong -m --merc -E --proj)'{-l,--latlong}'[store coordinates in lat/long]' \
  '(-l --latlong -m --merc -E --proj)'{-m,--merc}'[store coordinates in Mercator (default)]' \
  '(-l --latlong -m --merc -E --proj)'{-E,--proj}'=[projection EPSG code]:EPSG code' \
  '(-o --output)'{-o,--output}'=[output backend]:backend:(pgsql flex gazetteer null)' \
  '--log-progress=[log progress]:value:(true false auto)' \
  '(-r --input-reader)'{-r,--input-reader}'=[input format]:format:(auto o5m xml pbf)' \
  '--middle-database-format=[middle database format]:format:(legacy new)' \
  '(-x --extra-attributes)'{-x,--extra-attributes}'[include extra attributes (user, uid, version)]' \
  '--hstore[add all tags as hstore column]' \
  '--hstore-add-index[add index to hstore column]' \
  '--hstore-match-only[only use hstore for matching]' \
  '--hstore-column=[additional hstore column for tag matching]:column prefix' \
  '--tablespace-slim-data=[tablespace for slim mode data tables]:tablespace' \
  '--tablespace-slim-index=[tablespace for slim mode index tables]:tablespace' \
  '--tablespace-main-data=[tablespace for main data tables]:tablespace' \
  '--tablespace-main-index=[tablespace for main index tables]:tablespace' \
  '(-j --number-processes)'{-j,--number-processes}'=[number of parallel processes]:count' \
  '--disable-parallel-indexing[disable parallel indexing]' \
  '--cache-strategy=[cache strategy]:strategy:(optimized dense chunk sparse)' \
  '--drop[drop slim mode tables after import]' \
  '--keep-coastlines[keep coastline data]' \
  '--tag-transform-script=[Lua tag transform script]:script:_files -g "*.lua"' \
  '(-b --bbox)'{-b,--bbox}'=[bounding box for import]:minlon,minlat,maxlon,maxlat' \
  '--expire-tiles=[zoom level(s) for tile expiry]:zoom levels' \
  '--expire-output=[file for expired tiles list]:file:_files' \
  '--expire-bbox-size=[max bbox size for tile expiry]:size' \
  '*:input file:_files -g "*.(osm|pbf|o5m)(|.gz|.bz2)"'
