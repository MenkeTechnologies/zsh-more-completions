#compdef chi gmx-chi
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-chi.html
# gmx chi: calculate everything you want to know about chi and other dihedrals

local ret=1

_arguments -s \
  '-s[structure file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-ss[secondary structure data file]:file:_files' \
  '-o[order parameter xvgr/xmgr file]:file:_files' \
  '-p[PDB file with B-factors]:file:_files' \
  '-jc[NMR coupling constants xvgr/xmgr file]:file:_files' \
  '-corr[dihedral autocorrelation xvgr/xmgr file]:file:_files' \
  '-g[log file]:file:_files' \
  '-ot[rotamer transitions xvgr/xmgr file]:file:_files' \
  '-oh[transition histogram xvgr/xmgr file]:file:_files' \
  '-rt[rotamer transitions per type xvgr/xmgr file]:file:_files' \
  '-cp[cumulative rotamer histogram xvgr/xmgr file]:file:_files' \
  '-b[first frame time (ps)]:time:' \
  '-e[last frame time (ps)]:time:' \
  '-dt[frame sampling interval (ps)]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-r0[starting residue number]:int:' \
  '-rN[ending residue number]:int:' \
  '-phi[include phi angles]' \
  '-psi[include psi angles]' \
  '-omega[include omega angles]' \
  '-rama[generate Ramachandran plots]' \
  '-viol[write Ramachandran violations]' \
  '-periodic[print angles modulo 360]' \
  '-all[output separate files per dihedral]' \
  '-rad[use radians instead of degrees]' \
  '-shift[compute chemical shifts]' \
  '-binwidth[histogram bin width (degrees)]:int:' \
  '-core_rotamer[rotamer core region fraction]:real:' \
  '-maxchi[number of chi dihedrals to calculate]:enum:' \
  '-normhisto[normalize histograms]' \
  '-ramomega[plot average omega on Ramachandran plot]' \
  '-bfact[default B-factor for PDB output]:real:' \
  '-chi_prod[calculate cumulative rotamer]' \
  '-HChi[include sidechain hydrogen dihedrals]' \
  '-bmax[maximum B-factor filter]:real:' \
  '-acflen[ACF length]:int:' \
  '-normalize[normalize ACF]' \
  '-P[order of Legendre polynomial]:order:(0 1 2 3)' \
  '-fitfn[exponential fit function type]:fn:(none exp aexp exp_exp exp5 exp7 exp9)' \
  '-beginfit[ACF fit start time]:real:' \
  '-endfit[ACF fit end time]:real:' && ret=0

return ret
