#compdef esp-coredump
# Analyze and debug ESP-IDF core dumps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--chip[target chip type]:chip:(esp32 esp32s2 esp32s3 esp32c2 esp32c3 esp32c6 esp32h2 esp32p4)' \
  '--chip-rev[chip revision]:rev:' \
  '(-p --port)'{-p,--port}'[serial port device]:port:_files' \
  '(-b --baud)'{-b,--baud}'[serial baud rate]:baud:(115200 230400 460800 921600)' \
  '--gdb-timeout-sec[GDB connection timeout in seconds]:seconds:' \
  '--version[show version]' \
  '(-d --debug)'{-d,--debug}'[debug level]:level:' \
  '(-g --gdb)'{-g,--gdb}'[path to GDB executable]:gdb:_files' \
  '--extra-gdbinit-file[additional gdbinit file]:file:_files' \
  '(-c --core)'{-c,--core}'[core dump file to analyze]:core:_files' \
  '(-t --core-format)'{-t,--core-format}'[core dump file format]:format:(auto b64 elf raw)' \
  '(-o --off)'{-o,--off}'[offset of core dump partition in flash]:offset:' \
  '--parttable-off[partition table offset]:offset:' \
  '(-s --save-core)'{-s,--save-core}'[save core to file]:file:_files' \
  '(-r --rom-elf)'{-r,--rom-elf}'[path to ROM ELF file]:file:_files -g "*.elf"' \
  '*:command:(info_corefile dbg_corefile)' && ret=0

return ret
