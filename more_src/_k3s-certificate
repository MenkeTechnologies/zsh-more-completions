#compdef k3s-certificate
# _k3s-certificate — manage k3s component certificates (k3s-io/k3s)
# upstream: https://github.com/k3s-io/k3s
# Subcommands from pkg/cli/cmds/certs.go (urfave/cli).

_k3s-certificate() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                check:'check component certificates on disk'
                rotate:'rotate component certificates on disk'
                rotate-ca:'write updated CA certificates to the datastore'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                check|rotate)
                    _arguments \
                        '--debug[turn on debug logging]' \
                        '(-c --config)'{-c+,--config=}'[k3s config file]:file:_files' \
                        '--log=[log file]:file:_files' \
                        '--alsologtostderr[also log to standard error]' \
                        '--data-dir=[data directory]:dir:_files -/' \
                        '*'{-s+,--service=}'[service to manage certificates for]:service:(admin api-server controller-manager scheduler supervisor cloud-controller etcd auth-proxy kubelet kube-proxy)' \
                        '(-o --output)'{-o+,--output=}'[output format (check only)]:format:(text table json yaml)' ;;
                rotate-ca)
                    _arguments \
                        '--data-dir=[data directory]:dir:_files -/' \
                        '(-s --server)'{-s+,--server=}'[k3s API server URL]:url:_urls' \
                        '--path=[directory containing new CA certificates]:dir:_files -/' \
                        '--force[force CA replacement even if consistency checks fail]' ;;
            esac
            ;;
    esac
}

_k3s-certificate "$@"
