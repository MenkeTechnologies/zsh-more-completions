#compdef postdrop
# _postdrop — Postfix mail-drop helper (set-gid helper used by sendmail(1) to enqueue messages into Postfix's maildrop directory; reads message from stdin)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/postdrop.1 on tip.

_postdrop() {
    _arguments \
        '-c+[config directory]:dir:_files -/' \
        '-r[use Postfix-internal protocol on stdin/stdout (currently the only supported mode)]' \
        '*-v[verbose logging (repeat for more, super-user only since 2.3)]'
}

_postdrop "$@"
