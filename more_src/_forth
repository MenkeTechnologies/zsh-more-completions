#compdef forth

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-e+[evaluate string]:str:' \
  '-i+[image file]:file:_files' \
  '-d+[dictionary size]:n:' \
  '-l+[load file]:file:_files -g "*.fs"' \
  '*:script:_files -g "*.{fs,fth,fb,f}"' && ret=0

return ret
