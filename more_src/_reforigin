#compdef reforigin
# Documentation: https://www.ccp4.ac.uk/html/reforigin.html
# CCP4: apply optimal origin shift to align a structure with a reference

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input PDB file to be re-originated]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZREF[reference PDB file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output transformed coordinates]:output:_files' \
  '*:keyword:(SPACEGROUP DMAX CAONLY END)' && ret=0

return ret
