#compdef sdlmame mame
# Documentation: https://github.com/mamedev/mame/blob/master/src/frontend/mame/clifront.cpp
# Reference accessed: 2026-05-16
# Verified: src/frontend/mame/clifront.cpp lines 53-127 (#defines + s_option_entries)
# + src/emu/emuopts.cpp lines 101-108 (window/aspect options).
# MAME has thousands of resource options via -optionname value; this completion
# lists only the verified top-level CLI commands and most common display flags.
# Removed from prior file: -V, --help, --version (real flags are -h/-? and
# -version single-dash; MAME uses single-dash long flags throughout).

# MAME / sdlmame: Multiple Arcade Machine Emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help message]' \
  '(- *)-h[show help message]' \
  '(- *)-?[show help message]' \
  '(- *)-version[show MAME version]' \
  '(-validate -valid)'{-validate,-valid}'[validate driver and device code]' \
  '(-createconfig -cc)'{-createconfig,-cc}'[create default configuration file]' \
  '(-showconfig -sc)'{-showconfig,-sc}'[display running parameters]' \
  '(-showusage -su)'{-showusage,-su}'[show usage help]' \
  '(-listxml -lx)'{-listxml,-lx}'[all driver info as XML]' \
  '(-listfull -ll)'{-listfull,-ll}'[short name + full name]' \
  '(-listsource -ls)'{-listsource,-ls}'[driver source file]' \
  '(-listclones -lc)'{-listclones,-lc}'[show clones]' \
  '(-listbrothers -lb)'{-listbrothers,-lb}'[show drivers from same source]' \
  '-listcrc[show CRC-32s]' \
  '(-listroms -lr)'{-listroms,-lr}'[list required ROMs for a driver]:driver:' \
  '-listbios[list BIOS options]:driver:' \
  '-listsamples[list optional samples]:driver:' \
  '-verifyroms[report problematic romsets]' \
  '-verifysamples[report problematic samplesets]' \
  '-romident[compare files with known MAME ROMs]:file:_files' \
  '(-listdevices -ld)'{-listdevices,-ld}'[list devices in a system]:system:' \
  '(-listslots -lslot)'{-listslots,-lslot}'[list available slots]:system:' \
  '(-listmedia -lm)'{-listmedia,-lm}'[list available media]:system:' \
  '(-listsoftware -lsoft)'{-listsoftware,-lsoft}'[list known software]:system:' \
  '(-verifysoftware -vsoft)'{-verifysoftware,-vsoft}'[verify known software]:system:' \
  '(-getsoftlist -glist)'{-getsoftlist,-glist}'[retrieve software list by name]:listname:' \
  '(-verifysoftlist -vlist)'{-verifysoftlist,-vlist}'[verify software list by name]:listname:' \
  '(-window -w)'{-window,-w}'[enable window mode]' \
  '(-maximize -max)'{-maximize,-max}'[default to maximized windows]' \
  '-nomaximize[do not default to maximized]' \
  '(-keepaspect -ka)'{-keepaspect,-ka}'[maintain aspect ratio when scaling]' \
  '-nokeepaspect[do not maintain aspect]' \
  '(-unevenstretch -ues)'{-unevenstretch,-ues}'[allow non-integer scaling]' \
  '-nounevenstretch[force integer scaling]' \
  '*:system / driver:_files' && ret=0
return ret
