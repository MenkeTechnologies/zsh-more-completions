#compdef gst-dots-viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-a+,--address=}'[server address]:address:' \
  {-p+,--port=}'[server port]:port:' \
  '*:dot file:_files -g "*.dot"' && ret=0

return ret
