#compdef gst-dots-viewer
# Documentation: https://man.archlinux.org/search?q=gst-dots-viewer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-a+,--address=}'[server address]:address:' \
  {-p+,--port=}'[server port]:port:' \
  '*:dot file:_files -g "*.dot"' && ret=0

return ret
