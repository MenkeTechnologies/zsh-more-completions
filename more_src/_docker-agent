#compdef docker-agent
# Documentation: https://github.com/docker/docker-agent
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://formulae.brew.sh/formula/docker-agent
local curcontext="$curcontext" state line ret=1

local -a _dagent_cmds
_dagent_cmds=(
  'version:print Docker Agent version metadata'
  'run:launch an agent configuration or registry reference'
  'send:send a follow-up message to the current session'
  'watch:watch remote agent activity'
  'proto:Protocol Buffer helpers'
  'new:create a new agent from a description'
  'eval:evaluate an agent against local test cases'
  'share:share an agent configuration'
  'models:list available model providers'
  'debug:inspect internal integrations'
  'alias:manage agent name shortcuts'
  'serve:expose an HTTP control plane'
)

_arguments -C -s -S \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-o --otel)'{-o,--otel}'[emit OpenTelemetry traces]' \
  '--log-file[path to debug log file]:file:_files' \
  '--cache-dir[override cache directory]:dir:_files -/' \
  '--config-dir[override config directory]:dir:_files -/' \
  '--data-dir[override data directory]:dir:_files -/' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'docker-agent command' _dagent_cmds && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(-a --agent)'{-a,--agent}'[agent name for multi-agent teams]:name' \
          '--yolo[auto-approve tool calls without prompts]' \
          '--hide-tool-results[suppress printing tool results]' \
          '--attach[attach an image to the message]:file:_files -g "*.(png|jpg|jpeg|gif|webp)(-.)"' \
          '*--prompt-file[append file contents to the prompt]:file:_files' \
          '*--model[model override agent=provider/model]:spec' \
          '--dry-run[initialize without executing tools]' \
          '--remote[remote runtime address]:addr' \
          '(-s --session-db)'{-s,--session-db}'[SQLite session store path]:file:_files' \
          '--session[resume earlier session id or relative offset]:session' \
          '--fake[replay cassette responses path]:file:_files' \
          '--fake-stream[simulate streaming delay in ms]:delay' \
          '--record[record LLM interactions to disk]:file' \
          '--lean[use minimal TUI chrome]' \
          '--sandbox[run inside Docker sandbox runtime]' \
          '--template[sandbox template image reference]:reference' \
          '--sbx[prefer sbx CLI backend when installed]' \
          '--no-sbx[force classic docker sandbox backend]' \
          '--exec[run without interactive TUI]' \
          '::agent file registry or inline message:_files' \
          '*::message words:' \
          && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
