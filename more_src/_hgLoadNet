#compdef hgLoadNet
# UCSC kent: load a generic net file into the database

local ret=1

_arguments -s -S \
  '-noBin[suppress bin field]' \
  '-oldTable[add to existing table]' \
  '-sqlTable=[create table from .sql file]:file:_files -g "*.sql"' \
  '-qPrefix=[prepend "xxx-" to query name]:xxx' \
  '-warn[load even with missing fields]' \
  '-test[suppress loading table]' \
  '1:database:' \
  '2:track:' \
  '*:net file:_files -g "*.net"' && ret=0

return ret
