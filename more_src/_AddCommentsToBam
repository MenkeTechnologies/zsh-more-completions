#compdef AddCommentsToBam
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#AddCommentsToBam
# Picard: add @CO comment lines to the header of a BAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input BAM file to add a comment to]:bam:_files -g "*.bam"' \
  {-O=,--OUTPUT=}'[output BAM file to write results]:bam:_files -g "*.bam"' \
  '*'{-C=,--COMMENT=}'[comment to add to the BAM header]:comment:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.bam"' && ret=0

return ret
