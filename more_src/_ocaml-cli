#compdef ocaml
# _ocaml-cli — OCaml interactive toplevel + script runner (OCaml team + Inria, OCaml); REPL and script driver
# upstream: https://github.com/ocaml/ocaml

_ocaml-cli() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-vnum[print only version number]' \
        '-absname[print absolute filenames]' \
        '-no-absname[print relative filenames]' \
        '-I+[include path]:dir:_files -/' \
        '-H+[hidden include path]:dir:_files -/' \
        '-init+[init file]:file:_files' \
        '-no-init[no init file]' \
        '-labels[use labels]' \
        '-no-app-funct[no applicative functors]' \
        '-no-labels[no labels]' \
        '-noassert[no assert]' \
        '-noinit[no init]' \
        '-nopromptcont[no continuation prompt]' \
        '-nostdlib[no stdlib]' \
        '-open+[open module]:mod:' \
        '-ppx+[ppx]:cmd:_command_names -e' \
        '-principal[principal mode]' \
        '-no-principal[no principal mode]' \
        '-rectypes[recursive types]' \
        '-no-rectypes[no rectypes]' \
        '-stdin[read stdin]' \
        '-strict-sequence[strict sequence]' \
        '-no-strict-sequence[no strict sequence]' \
        '-strict-formats[strict formats]' \
        '-no-strict-formats[no strict formats]' \
        '-unsafe[unsafe operations]' \
        '-version[show version]' \
        '-w+[warnings]:warnings:' \
        '-warn-error+[warn error]:warnings:' \
        '-warn-help[print warning numbers + names]' \
        '*:script:_files -g "*.ml"'
}

_ocaml-cli "$@"
