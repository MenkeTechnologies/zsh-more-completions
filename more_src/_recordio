#compdef recordio
# _recordio — DJB ucspi-tcp recordio (log every byte of child stdin/stdout to stderr with PID + direction prefix; standard wire-protocol debugger when running under tcpserver)
# upstream: https://github.com/schmonz/ucspi-tcp
# Source: recordio.c on tip; positional only.

_recordio() {
    _arguments \
        '1:program:_command_names -e' \
        '*::args:'
}

_recordio "$@"
