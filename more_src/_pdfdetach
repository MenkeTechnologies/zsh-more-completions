#compdef pdfdetach
# Documentation: https://manpages.debian.org/pdfdetach.1
# Source: poppler-utils — list / save embedded files from a PDF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-list -save -savefile -saveall)-list[list embedded files]' \
    '(-list -save -savefile -saveall)-save[save embedded file by index]:number:' \
    '(-list -save -savefile -saveall)-savefile[save embedded file by name]:filename:' \
    '(-list -save -savefile -saveall)-saveall[save all embedded files]' \
    '-o[output file (with -save) or directory (with -saveall)]:path:_files' \
    '-enc[output text encoding for filenames]:encoding:(UTF-8 UTF-16 ISO-8859-1 Latin1 ASCII)' \
    '-opw[owner password]:password:' \
    '-upw[user password]:password:' \
    '(- *)-v[print copyright + version]' \
    '(- *)-h[print usage]' \
    '*:PDF file:_files -g "*.pdf"' \
    && ret=0

return ret
