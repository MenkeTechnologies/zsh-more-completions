#compdef zrepl

# completions for zrepl - ZFS replication tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'daemon:run the zrepl daemon'
  'status:show daemon job status'
  'stdinserver:stdin server mode'
  'signal:send a signal to a job'
  'version:show version'
  'configcheck:check configuration'
  'migrate:migrate state'
  'pprof:run Go pprof'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zrepl command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (daemon)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
          '--job[filter by job name]:job name' \
          '--mode[output mode]:mode:(raw dump)' \
          '--delay[refresh delay]:delay' && ret=0
        ;;
      (signal)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
          '1:signal type:(wakeup reset)' \
          '2:job name' && ret=0
        ;;
      (configcheck)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
          '--format[config format]:format:(yaml)' && ret=0
        ;;
      (migrate)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
          '1:migration:(0.0.X:0.1:placeholder)' && ret=0
        ;;
      (pprof)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' && ret=0
        ;;
      (stdinserver)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:config file:_files' && ret=0
        ;;
      (*)
        _message 'arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
