#compdef rnx2rtkp
# Documentation: https://manpages.debian.org/bullseye/rtklib/rnx2rtkp.1.en.html
# RTKLIB post-processing positioning from RINEX files

local ret=1

_arguments -s \
  '-?[print help]' \
  '-k[input options from configuration file]:config file:_files' \
  '-o[set output file]:output file:_files' \
  '-ts[start day/time (y/m/d h:m:s)]:start date: :start time:' \
  '-te[end day/time (y/m/d h:m:s)]:end date: :end time:' \
  '-ti[time interval (sec)]:interval' \
  '-p[positioning mode]:mode:(0 1 2 3 4 5 6 7)' \
  '-m[elevation mask angle (deg)]:mask' \
  '-f[number of frequencies for relative mode]:freq:(1 2 3)' \
  '-v[validation threshold for integer ambiguity]:thres' \
  '-b[backward solutions]' \
  '-c[forward/backward combined solutions]' \
  '-i[instantaneous integer ambiguity resolution]' \
  '-h[fix and hold for integer ambiguity resolution]' \
  '-e[output x/y/z-ecef position]' \
  '-a[output e/n/u-baseline]' \
  '-n[output NMEA-0183 GGA sentence]' \
  '-g[output lat/lon in ddd mm ss.ss form]' \
  '-t[output time in yyyy/mm/dd hh:mm:ss.ss form]' \
  '-u[output time in utc]' \
  '-d[number of decimals in time]:col' \
  '-s[field separator]:sep' \
  '-r[reference (base) receiver ecef pos (m)]:x: :y: :z:' \
  '-l[reference (base) receiver lat/lon/height]:lat: :lon: :hgt:' \
  '-y[output solution status]:level:(0 1 2)' \
  '-x[debug trace level]:level' \
  '*:RINEX file:_files' && ret=0

return ret
