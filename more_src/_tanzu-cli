#compdef tanzu
# _tanzu-cli — VMware Tanzu CLI (VMware Tanzu, Go); manage Tanzu Kubernetes Grid, Tanzu Application Platform, etc.
# upstream: https://github.com/vmware-tanzu/tanzu-cli

_tanzu-cli() {
    local -a sub=(
        'apps:Application Platform commands'
        'cluster:Tanzu cluster commands'
        'completion:print shell completion'
        'config:tanzu config commands'
        'context:tanzu context commands'
        'help:show help'
        'init:initialize CLI'
        'kubernetes-release:k8s release info'
        'login:login (deprecated)'
        'management-cluster:management cluster commands'
        'package:package commands'
        'pinniped-auth:Pinniped auth helper'
        'plugin:plugin commands'
        'plugin-group:plugin group commands'
        'profile:profile commands'
        'project:project commands'
        'secret:secret commands'
        'tap:Tanzu Application Platform commands'
        'tmc:Tanzu Mission Control commands'
        'unattended:unattended commands'
        'update:update plugins'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tanzu subcommand' sub ;;
        args)
            case $words[1] in
                cluster) _arguments '1:cluster cmd:(available-upgrades create delete get kubeconfig list machinehealthcheck node-pool scale upgrade)' '*:cluster:' ;;
                plugin) _arguments '1:plugin cmd:(clean delete describe install list search source upgrade)' '*:plugin:' ;;
                package) _arguments '1:package cmd:(available installed repository)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_tanzu-cli "$@"
