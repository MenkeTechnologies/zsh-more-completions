#compdef water

# EMBOSS water: Smith-Waterman local pairwise alignment
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-asequence=[first sequence]:file:_files' \
  '-bsequence=[second sequence(s)]:file:_files' \
  '-datafile=[scoring matrix]:file:_files' \
  '-gapopen=[gap opening penalty]:score:' \
  '-gapextend=[gap extension penalty]:score:' \
  '-similarity[display similarity instead of identity]' \
  '-brief[brief output]' \
  '-aformat=[alignment output format]:fmt:(simple srspair pair markx0 markx1 markx2 markx3 markx10 srs score)' \
  '*:sequence:_files' && ret=0

return ret
