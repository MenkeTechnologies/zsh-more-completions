#compdef wxrc-3.3

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-v,--verbose}'[be verbose]' \
  {-e,--extra-cpp-code}'[output C++ header with XRC derived classes]' \
  {-c,--cpp-code}'[output C++ source rather than .rsc file]' \
  {-p,--python-code}'[output wxPython source rather than .rsc file]' \
  {-g,--gettext}'[output translatable strings]' \
  {-n+,--function=}'[function name with -c or -p]:name:' \
  {-o+,--output=}'[output file]:file:_files' \
  '--validate[check XRC correctness in addition to other processing]' \
  '--validate-only[check XRC correctness only]' \
  '--xrc-schema=[RELAX NG schema file]:file:_files' \
  '*:input XRC file:_files -g "*.xrc"' && ret=0

return ret
