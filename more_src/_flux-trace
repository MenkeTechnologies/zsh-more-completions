#compdef flux-trace
# Documentation: https://fluxcd.io/flux/cmd/flux_trace/
# FluxCD trace: follow resource dependencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--api-version=[the Kubernetes object API version, e.g. apps/v1]:version:' \
  '--kind=[the Kubernetes object kind, e.g. Deployment]:kind:' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--cluster=[name of the kubeconfig cluster to use]:cluster:' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' \
  '*:name:' && ret=0

return ret
