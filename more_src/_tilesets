#compdef tilesets
# Documentation: https://github.com/mapbox/tilesets-cli
# Mapbox Tilesets API command-line interface

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)--help[show help and exit]' \
  '--token=[Mapbox access token]:token' \
  '--indent=[JSON output indentation size]:indent' \
  '1:command:((
    upload-source\:"upload a tileset source"
    upload-raster-source\:"upload a raster tileset source"
    upload-changeset\:"upload a changeset"
    validate-source\:"validate a tileset source"
    view-source\:"view a tileset source"
    view-changeset\:"view a changeset"
    delete-changeset\:"delete a changeset"
    list-sources\:"list tileset sources for an account"
    delete-source\:"delete a tileset source"
    estimate-area\:"estimate the area of features"
    view-recipe\:"view a tileset recipe"
    validate-recipe\:"validate a tileset recipe"
    update-recipe\:"update a tileset recipe"
    create\:"create a tileset"
    publish\:"publish a tileset for processing"
    publish-changesets\:"publish changesets for a tileset"
    update\:"update tileset metadata"
    delete\:"delete a tileset"
    status\:"view the processing status of a tileset"
    job\:"view a single tileset job"
    jobs\:"list tileset jobs"
    list\:"list tilesets for an account"
    tilejson\:"view the TileJSON for a tileset"
    list-activity\:"list tileset activity for an account"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '--token=[Mapbox access token]:token' \
      '--indent=[JSON output indentation size]:indent' \
      '--force[bypass confirmation prompts]' \
      '--verbose[enable verbose output]' \
      '--quiet[suppress output]' \
      '--replace[replace existing data]' \
      '--no-validation[skip validation]' \
      '--help[show help]' \
      '*:arg:_files' && ret=0
    ;;
esac

return ret
