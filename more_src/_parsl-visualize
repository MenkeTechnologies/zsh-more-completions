#compdef parsl-visualize
# Documentation: https://parsl.readthedocs.io/en/stable/userguide/advanced/monitoring.html
# parsl-visualize - run the Parsl monitoring web dashboard

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --port)'{-p,--port}'[port to host the Viz server on (default 8080)]:port' \
  '(-l --listen)'{-l,--listen}'[address to listen for connections on (default 127.0.0.1)]:address' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '*:db path:' && ret=0

return ret
