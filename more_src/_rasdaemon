#compdef rasdaemon
# Documentation: https://man.archlinux.org/search?q=rasdaemon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --record)'{-d,--record}'[record errors to database]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-r --recordpath)'{-r,--recordpath}'+[recording path]:file:_files' \
  '(-e --enable)'{-e,--enable}'[enable RAS event tracing]' \
  '(-D --disable)'{-D,--disable}'[disable RAS event tracing]' \
  '(-S --status)'{-S,--status}'[show RAS event status]' \
  '(-p --post-processing)'{-p,--post-processing}'[post-process records and exit]' \
  '(-u --suppress-deprecation-warning)'{-u,--suppress-deprecation-warning}'[suppress deprecation warning]' \
  '(-l --record-list)'{-l,--record-list}'[list recorded events]' \
  '(-c --confirm)'{-c,--confirm}'[confirm message]:msg:' \
  '(--report)--report[generate summary report]' \
  '(--mem-error-recovery-stats)--mem-error-recovery-stats[show memory error recovery stats]' \
  '(--lazy)--lazy[lazy mode]' && ret=0

return ret
