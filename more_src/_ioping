#compdef ioping
# Documentation: https://github.com/koct9i/ioping/blob/master/ioping.1
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for ioping - simple disk I/O latency monitoring tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[ignore first <count> requests in statistics (warmup)]:count:' \
  '-b+[burst count of requests without delay]:count:' \
  '-c+[stop after <count> requests]:count:' \
  '-e+[seed for the random number generator]:seed:' \
  '-i+[interval between requests]:time:' \
  '-l+[limit load to <size>/sec]:size:' \
  '-r+[limit load to <count> IOPS]:count:' \
  '-t+[minimum valid request time]:time:' \
  '-T+[maximum valid request time]:time:' \
  '-s+[request size]:size:' \
  '-S+[working set size]:size:' \
  '-o+[starting offset in the file or device]:offset:' \
  '-w+[stop after <time> elapsed]:time:' \
  '-p+[print raw statistics every <count> requests]:count:' \
  '-P+[print raw statistics every <time>]:time:' \
  '-A[use asynchronous I/O]' \
  '-B[batch mode (quiet, raw final stats)]' \
  '-C[use cached I/O]' \
  '-D[use direct I/O]' \
  '-E[ignore request errors and continue]' \
  '-G[alternate read/write requests]' \
  '-H[set RWF_HIPRI on I/O]' \
  '-I+[print current time for each request]::strftime format:' \
  '-J[print output as JSON]' \
  '-k[keep and reuse the temporary working file]' \
  '-L[use sequential operations]' \
  '-N[set RWF_NOWAIT on I/O]' \
  '-q[quiet mode]' \
  '-R[disk seek/rapid rate test]' \
  '-W[use writes rather than reads]' \
  '-Y[use sync I/O]' \
  '-y[use data sync I/O]' \
  '-h[show help]' \
  '-v[show version]' \
  '1:file or device:_files' && ret=0

return ret
