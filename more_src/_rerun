#compdef rerun

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-w --watch)'{-w,--watch}'[path to watch]:path:_files -/' \
  '(-i --ignore)'{-i,--ignore}'[pattern to ignore]:pattern' \
  '(-e --exts)'{-e,--exts}'[file extensions to watch]:extensions' \
  '(-s --signal)'{-s,--signal}'[signal to send on change]:signal:(SIGHUP SIGINT SIGQUIT SIGTERM SIGKILL SIGUSR1 SIGUSR2)' \
  '(-c --clear)'{-c,--clear}'[clear screen before restarting]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output from rerun itself]' \
  '(-r --restart)'{-r,--restart}'[restart command on file change]' \
  '(-d --delay)'{-d,--delay}'[delay before restarting]:seconds' \
  '--no-restart[do not restart, just re-run]' \
  '--verbose[enable verbose output]' \
  '*:command:_command_names' && ret=0

return ret
