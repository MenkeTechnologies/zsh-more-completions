#compdef rerun
# _rerun — Rerun data visualization tool (rerun-io/rerun)
# upstream: https://github.com/rerun-io/rerun

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--web-viewer[open web viewer]' \
  '--web-viewer-port=[web viewer port]:port:' \
  '--ws-server-port=[WebSocket server port]:port:' \
  '--bind=[bind address]:addr:' \
  '--connect[connect to a remote viewer]' \
  '--addr=[remote viewer address]:addr:' \
  '--serve[serve a web viewer]' \
  '--memory-limit=[memory limit]:limit:' \
  '--drop-at-latency=[drop data at latency threshold]:duration:' \
  '--save=[save recording to file]:file:_files -g "*.rrd"' \
  '--screenshot-to=[save screenshot to file]:file:_files' \
  '--strict[treat warnings as errors]' \
  '--threads=[number of threads]:threads:' \
  '*:recording file:_files -g "*.rrd"'
