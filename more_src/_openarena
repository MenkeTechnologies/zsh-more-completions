#compdef openarena
# Documentation: https://manpages.debian.org/bookworm/openarena/openarena.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm openarena(6) manpage OPTIONS section.

# OpenArena: open Quake 3 derivative
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-q,--quiet}'[disable all output]' \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+connect[connect to server]:host:_hosts' \
  '+demo[play demo at startup]:name:' \
  '*::extra args:_files' && ret=0
return ret
