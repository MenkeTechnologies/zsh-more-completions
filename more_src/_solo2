#compdef solo2
# Documentation: https://github.com/solokeys/solo2-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'app:interact with installed apps'
  'bootloader:interact with the device bootloader'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase log verbosity (-v INFO, -vv DEBUG)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'solo2 command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (app)
        local -a app_subs=(
          'admin:admin app interactions'
          'ndef:NDEF app interactions'
        )
        _describe -t commands 'solo2 app subcommand' app_subs && ret=0
        ;;
      (bootloader)
        local -a bl_subs=(
          'reboot:reboot back to regular mode'
        )
        _describe -t commands 'solo2 bootloader subcommand' bl_subs && ret=0
        ;;
    esac
    ;;
esac

return ret
