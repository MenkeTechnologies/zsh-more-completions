#compdef wazuh-remoted

# Wazuh/remoted subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '-d[debug]' \
  '-f[run in foreground]' \
  '-t[test config]' \
  '-u[user]:user:_users' \
  '-g[group]:group:_groups' \
  '-D[runtime directory]:dir:_files -/' \
  '*::wazuh-remoted args:_files' && ret=0
return ret
