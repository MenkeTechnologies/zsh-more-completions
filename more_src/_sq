#compdef sq

# Zsh completion for sq (data wrangler)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a data source'
  'completion:generate shell completions'
  'diff:diff two sources'
  'driver:list or manage drivers'
  'group:manage groups'
  'inspect:inspect data source schema and metadata'
  'list:list data sources (alias: ls)'
  'move:move a data source (alias: mv)'
  'ping:ping data sources'
  'query:execute a query'
  'remove:remove a data source (alias: rm)'
  'scratch:manage scratch database'
  'sql:execute SQL against active source'
  'src:manage data sources'
  'tbl:table operations'
  'version:print version'
)

_arguments -s -S \
  '(-M --monochrome)'{-M,--monochrome}'[disable color output]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-j --json)'{-j,--json}'[output JSON]' \
  '--jsonl[output JSON Lines]' \
  '--csv[output CSV]' \
  '--tsv[output TSV]' \
  '--xml[output XML]' \
  '--xlsx[output XLSX]' \
  '--html[output HTML table]' \
  '--markdown[output Markdown table]' \
  '--raw[output raw bytes]' \
  '--text[output text table]' \
  '--yaml[output YAML]' \
  '--header[print header row]' \
  '--no-header[do not print header row]' \
  '--src[specify active source]:source:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sq command' commands && ret=0
    ;;
esac

return ret
