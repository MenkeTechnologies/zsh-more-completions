#compdef vlogger

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-a[append mode]' \
  '-e[error mode (write to stderr)]' \
  '-n[disable date in filename]' \
  '-d[do not rotate]' \
  '-s+[size limit]:bytes:' \
  '-r+[rotate seconds]:sec:' \
  '-f+[log file template]:template:' \
  '-i+[pid file]:file:_files' \
  '-u+[uid]:user:_users' \
  '-g+[gid]:group:_groups' \
  '-t+[time format]:fmt:' \
  '*:log_dir:_files -/' && ret=0

return ret
