#compdef logdissect

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[enable verbose output]' \
  '-s[silence terminal output]' \
  '--list-parsers[list available parsers]' \
  '--list-morphs[list available morphs]' \
  '--list-outputs[list available outputs]' \
  '-p[select a parser]:parser:(syslog syslogiso syslognohost tcpdump ldjson windowsrsyslog)' \
  '--grep[filter lines matching pattern]:pattern:' \
  '--rgrep[filter lines not matching pattern]:pattern:' \
  '--last[filter last time period]:time period:' \
  '--range[filter time range]:time range:' \
  '--rdhost[resolve destination hostnames]' \
  '--rshost[resolve source hostnames]' \
  '--outlog[output to a standard log file]:output file:_files' \
  '--label[add labels to log entries]:label:' \
  '--sojson[output to JSON]:output file:_files' \
  '--sohtml[output to HTML]:output file:_files' \
  '--socsv[output to CSV]:output file:_files' \
  '--linejson[output as line-delimited JSON]' \
  '-z[force gzip compressed input]' \
  '-t[force plain text input]' \
  '*:log file:_files' && ret=0

return ret
