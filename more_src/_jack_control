#compdef jack_control
# Documentation: https://github.com/jackaudio/jack2/blob/develop/dbus/jack_control
# Reference accessed: 2026-05-19
# Verified: upstream jack2 dbus/jack_control argument dispatch.
# Note: prior file invented ec/sm/lm/um as the only master ops and
# omitted the engine-parameter (ep/epd/eps/epr), driver get (dg/dl),
# internal-list (il) and ism subcommands present in the real source.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start the jack server'
  'stop:stop the jack server'
  'exit:exit jackdbus'
  'status:get jack server status'
  'dg:get selected master driver'
  'dl:get list of available drivers'
  'ds:select master driver'
  'dp:get driver parameters'
  'dpd:get long description of a driver parameter'
  'dps:set driver parameter value'
  'dpr:reset driver parameter value'
  'asd:add slave driver'
  'rsd:remove slave driver'
  'ep:get engine parameters'
  'epd:get long description of an engine parameter'
  'eps:set engine parameter value'
  'epr:reset engine parameter value'
  'il:get list of available internals'
  'ip:get internal parameters'
  'ipd:get long description of an internal parameter'
  'ips:set internal parameter value'
  'ipr:reset internal parameter value'
  'iload:load internal client'
  'iunload:unload internal client'
  'ism:server is started query'
  'sm:get list of slave drivers'
  'help:print help'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jack_control command' commands && ret=0 ;;
esac

return ret
