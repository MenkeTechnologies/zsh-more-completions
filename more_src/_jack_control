#compdef jack_control
# Documentation: https://man.archlinux.org/search?q=jack_control
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start jack server'
  'stop:stop jack server'
  'exit:terminate jackdbus'
  'status:server status'
  'ds:set driver'
  'dp:driver parameters'
  'dpd:driver parameter description'
  'dps:driver parameter set'
  'dpr:driver parameter reset'
  'asd:add slave driver'
  'rsd:remove slave driver'
  'ip:internal client parameters'
  'ipd:internal parameter description'
  'ips:internal parameter set'
  'ipr:internal parameter reset'
  'iload:load internal client'
  'iunload:unload internal client'
  'ec:engine commands'
  'sm:switch master driver'
  'lm:load master driver'
  'um:unload master driver'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jack_control command' commands && ret=0 ;;
esac

return ret
