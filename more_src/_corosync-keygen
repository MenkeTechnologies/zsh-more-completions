#compdef corosync-keygen

# corosync-keygen: generate authentication key for corosync (authkey)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-k[key file path]:file:_files' \
  '-l[use random bytes from /dev/urandom (lower entropy, faster)]' \
  '-s[key size in bytes]:bytes:(16 32 64 128 256)' \
  '*::corosync-keygen args:_files' && ret=0
return ret
