#compdef corosync-keygen

# corosync-keygen: generate Corosync authkey for secure cluster auth
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-l --less-secure)'{-l,--less-secure}'[use /dev/urandom instead of /dev/random]' \
  '(-s --size)'{-s,--size=}'[key size in bytes (32-4096)]:n:' \
  '(-k --key-file)'{-k,--key-file=}'[output key file path]:file:_files' \
  '-h[show help]' \
  '*::corosync-keygen args:_files' && ret=0
return ret
