#compdef corosync-keygen
# Documentation: https://manpages.debian.org/testing/corosync/corosync-keygen.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-k+[path to shared key to create]:file:_files' \
  '-r+[random number source file]:source:_files' \
  '-s+[key size in bytes (128-4096, default 256)]:bytes:' \
  '-l[no-op; kept for backward compatibility]' \
  '*::corosync-keygen args:_files' && ret=0
return ret
