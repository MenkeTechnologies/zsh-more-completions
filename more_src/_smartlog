#compdef smartlog
# Source: cargo binstall smartlog@0.6.4
# Probed via: completions zsh
# Repository: https://github.com/felipemorandini/smartlog

autoload -U is-at-least

_smartlog() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-f+[Path(s) to file(s) to tail (can specify multiple with repeated --file flags)]:FILE:_default' \
'*--file=[Path(s) to file(s) to tail (can specify multiple with repeated --file flags)]:FILE:_default' \
'--export-dir=[Directory for exported log files (defaults to current directory)]:DIR:_files' \
'--debug-log=[Path for the debug log file (requires --verbose)]:PATH:_files' \
'--theme=[Color theme\: dark, light, solarized, dracula (default\: dark)]:THEME:_default' \
'-v[Enable verbose debug logging to smartlog_debug.log]' \
'--verbose[Enable verbose debug logging to smartlog_debug.log]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_smartlog_commands" \
"*::: :->smartlog" \
&& ret=0
    case $state in
    (smartlog)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:smartlog-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_smartlog__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:smartlog-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_smartlog_commands] )) ||
_smartlog_commands() {
    local commands; commands=(
'completions:Generate shell completions for the specified shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'smartlog commands' commands "$@"
}
(( $+functions[_smartlog__completions_commands] )) ||
_smartlog__completions_commands() {
    local commands; commands=()
    _describe -t commands 'smartlog completions commands' commands "$@"
}
(( $+functions[_smartlog__help_commands] )) ||
_smartlog__help_commands() {
    local commands; commands=(
'completions:Generate shell completions for the specified shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'smartlog help commands' commands "$@"
}
(( $+functions[_smartlog__help__completions_commands] )) ||
_smartlog__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'smartlog help completions commands' commands "$@"
}
(( $+functions[_smartlog__help__help_commands] )) ||
_smartlog__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'smartlog help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_smartlog" ]; then
    _smartlog "$@"
else
    compdef _smartlog smartlog
fi
