#compdef bcftools-roh
# Documentation: http://www.htslib.org/doc/bcftools.html#roh
# bcftools roh: HMM model for detecting runs of autozygosity

local ret=1

_arguments -s -S \
  '(--AF-dflt)'--AF-dflt'[in case allele frequency is not known, use the FLOAT . By default, sit]:FLOAT: ' \
  '(--AF-tag)'--AF-tag'[use the specified INFO tag TAG as an allele frequency estimate instead]:TAG: ' \
  '(--AF-file)'--AF-file'[Read allele frequencies from a tab-delimited file containing the colum]:FILE:_files' \
  '(-b --buffer-size)'{-b,--buffer-size}'[when the entire many-sample file cannot fit into memory, a sliding buf]:INT: ' \
  '(-e --estimate-AF)'{-e,--estimate-AF}'[estimate the allele frequency by recalculating INFO/AC and INFO/AN on]:FILE:_files' \
  '(--exclude)'--exclude'[exclude sites for which EXPRESSION is true. For valid expressions see]:EXPRESSION: ' \
  '(-G --GTs-only)'{-G,--GTs-only}'[use genotypes (FORMAT/GT fields) ignoring genotype likelihoods (FORMAT]:FLOAT: ' \
  '(--include)'--include'[include only sites for which EXPRESSION is true. For valid expressions]:EXPRESSION: ' \
  '(-I --skip-indels)'{-I,--skip-indels}'[skip indels as their genotypes are usually enriched for errors]' \
  '(-m --genetic-map)'{-m,--genetic-map}'[genetic map in the format required also by IMPUTE2. Only the first and]:FILE:_files' \
  '(-M --rec-rate)'{-M,--rec-rate}'[constant recombination rate per bp. In combination with --genetic-map]:FLOAT: ' \
  '(-o --output)'{-o,--output}'[Write output to the FILE , by default the output is printed on stdout]:FILE:_files' \
  '(-O --output-type)'{-O,--output-type}'[Generate per-site output ( s ) or per-region output ( r ). By default]:s: ' \
  '(-r --regions)'{-r,--regions}'[see Common Options]:chr: ' \
  '(-R --regions-file)'{-R,--regions-file}'[see Common Options]:file:_files' \
  '(--regions-overlap)'--regions-overlap'[see Common Options]:0: ' \
  '(-s --samples)'{-s,--samples}'[see Common Options]:LIST: ' \
  '(-S --samples-file)'{-S,--samples-file}'[see Common Options]:FILE:_files' \
  '(-t --targets)'{-t,--targets}'[see Common Options]:chr: ' \
  '(-T --targets-file)'{-T,--targets-file}'[see Common Options]:file:_files' \
  '(--targets-overlap)'--targets-overlap'[see Common Options]:0: ' \
  '(-v --verbosity)'{-v,--verbosity}'[see Common Options]:INT: ' \
  '(-a --hw-to-az)'{-a,--hw-to-az}'[P(AZ|HW) transition probability from AZ (autozygous) to HW (Hardy-Wein]:FLOAT: ' \
  '(-H --az-to-hw)'{-H,--az-to-hw}'[P(HW|AZ) transition probability from HW to AZ state]:FLOAT: ' \
  '(-V --viterbi-training)'{-V,--viterbi-training}'[estimate HMM parameters using Baum-Welch algorithm, using the converge]:FLOAT: ' \
  '*:file:_files' && ret=0

return ret
