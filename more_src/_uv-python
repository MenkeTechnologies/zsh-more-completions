#compdef uv

# Zsh completion for uv - Python package installer (by Astral)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add dependencies to the project'
  'build:build the project into distribution archives'
  'cache:manage the cache'
  'export:export the project lockfile'
  'generate-shell-completion:generate shell completion scripts'
  'help:show help for a command'
  'init:create a new project'
  'lock:update the project lockfile'
  'pip:manage Python packages with pip interface'
  'publish:publish the project to a package index'
  'python:manage Python installations'
  'remove:remove dependencies from the project'
  'run:run a command or script'
  'self:manage uv itself'
  'sync:sync the project environment'
  'tool:run and install commands from Python packages'
  'tree:display the project dependency tree'
  'venv:create a virtual environment'
  'version:show or set the project version'
)

_arguments -s -S \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--color=[control colors]:mode:(auto always never)' \
  '--native-tls[use system TLS]' \
  '--offline[disable network access]' \
  '--no-progress[hide progress bars]' \
  '--config-file=[path to config file]:file:_files -g "*.toml"' \
  '--no-config[ignore config files]' \
  '(-n --no-cache)'{-n,--no-cache}'[avoid reading from or writing to cache]' \
  '--cache-dir=[cache directory]:directory:_files -/' \
  '--python-preference=[Python provider preference]:preference:(only-managed managed-then-system system-then-managed only-system)' \
  '--no-python-downloads[disable automatic Python downloads]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'uv command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      add)
        _arguments \
          '--dev[add as dev dependency]' \
          '--group=[dependency group]:group:' \
          '--optional=[optional dependency group]:group:' \
          '--requirements=[requirements file]:file:_files -g "*.txt"' \
          '--editable[add as editable]' \
          '--extra=[extras to enable]:extras:' \
          '--no-sync[do not sync after adding]' \
          '--frozen[do not update lockfile]' \
          '--locked[require lockfile is up to date]' \
          '--python=[Python version]:version:' \
          '--package=[package to add to]:package:' \
          '*:packages:'
        ;;
      remove)
        _arguments \
          '--dev[remove from dev dependencies]' \
          '--group=[dependency group]:group:' \
          '--optional=[optional dependency group]:group:' \
          '--no-sync[do not sync after removing]' \
          '--frozen[do not update lockfile]' \
          '--locked[require lockfile is up to date]' \
          '--python=[Python version]:version:' \
          '--package=[package to remove from]:package:' \
          '*:packages:'
        ;;
      run)
        _arguments \
          '--extra=[extras to enable]:extras:' \
          '--all-extras[enable all extras]' \
          '--no-dev[exclude dev dependencies]' \
          '--group=[include group]:group:' \
          '--only-group=[include only group]:group:' \
          '--with=[additional packages]:packages:' \
          '--with-editable=[additional editable packages]:packages:' \
          '--with-requirements=[requirements file]:file:_files -g "*.txt"' \
          '--frozen[do not update lockfile]' \
          '--locked[require lockfile is up to date]' \
          '--no-sync[do not sync environment]' \
          '--isolated[run in isolated environment]' \
          '--python=[Python version]:version:' \
          '--module[run as Python module]' \
          '--script[run as Python script]' \
          '*:command:_command_names -e'
        ;;
      pip)
        local -a pip_cmds=(
          'compile:compile requirements'
          'install:install packages'
          'list:list installed packages'
          'show:show installed package info'
          'freeze:list installed packages in requirements format'
          'check:verify installed packages'
          'tree:display dependency tree'
          'uninstall:uninstall packages'
          'sync:sync environment with requirements'
        )
        _describe -t commands 'pip command' pip_cmds && ret=0
        ;;
      python)
        local -a py_cmds=(
          'dir:show Python installation directory'
          'find:find a Python installation'
          'install:install Python versions'
          'list:list available Python versions'
          'pin:pin a Python version'
          'uninstall:uninstall Python versions'
        )
        _describe -t commands 'python command' py_cmds && ret=0
        ;;
      tool)
        local -a tool_cmds=(
          'dir:show tool directory'
          'install:install a tool'
          'list:list installed tools'
          'run:run a tool'
          'uninstall:uninstall a tool'
          'update-shell:update shell to include tool bin'
          'upgrade:upgrade installed tools'
        )
        _describe -t commands 'tool command' tool_cmds && ret=0
        ;;
      init)
        _arguments \
          '--name=[project name]:name:' \
          '--python=[Python version]:version:' \
          '--lib[create a library project]' \
          '--app[create an application project]' \
          '--script[create a single-file script]' \
          '--package[set up as a package]' \
          '--no-readme[do not create a README]' \
          '--no-pin-python[do not pin Python version]' \
          '--build-backend=[build backend]:backend:(hatch flit setuptools maturin scikit)' \
          '1:path:_files -/'
        ;;
      venv)
        _arguments \
          '--python=[Python version or path]:version:' \
          '--prompt=[virtual environment prompt]:prompt:' \
          '--system-site-packages[allow access to system packages]' \
          '--seed[seed the environment with pip]' \
          '--allow-existing[allow existing directory]' \
          '1:path:_files -/'
        ;;
      sync)
        _arguments \
          '--extra=[extras to enable]:extras:' \
          '--all-extras[enable all extras]' \
          '--no-dev[exclude dev dependencies]' \
          '--group=[include group]:group:' \
          '--only-group=[include only group]:group:' \
          '--frozen[do not update lockfile]' \
          '--locked[require lockfile is up to date]' \
          '--no-install-project[do not install project]' \
          '--no-install-workspace[do not install workspace members]' \
          '--python=[Python version]:version:'
        ;;
    esac
    ;;
esac

return ret
