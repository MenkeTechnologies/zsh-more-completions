#compdef spectral

local -a _spectral_commands
_spectral_commands=(
  'lint:lint an API description'
  'ruleset:manage rulesets'
  'help:display help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'spectral commands' _spectral_commands
    ;;
  args)
    case "$words[1]" in
      lint)
        _arguments \
          '(-e --encoding)'{-e,--encoding}'[encoding]:encoding:(utf8 ascii utf-8 utf-16 iso-8859-1)' \
          '(-f --format)'{-f,--format}'[output format]:format:(stylish json junit html text pretty teamcity)' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '(-r --ruleset)'{-r,--ruleset}'[ruleset file]:file:_files' \
          '(-F --fail-severity)'{-F,--fail-severity}'[minimum severity to fail]:severity:(error warn info hint)' \
          '(-D --show-unmatched-globs)'{-D,--show-unmatched-globs}'[show unmatched globs]' \
          '--ignore-unknown-format[ignore unknown formats]' \
          '--fail-on-unmatched-globs[fail on unmatched globs]' \
          '--resolver[resolver]:resolver:(http file)' \
          '-q[quiet mode]' \
          '--verbose[verbose output]' \
          '*:API document:_files'
        ;;
      ruleset)
        _arguments '1:subcommand:(validate)' '*:file:_files'
        ;;
    esac
    ;;
esac
