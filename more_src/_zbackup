#compdef zbackup
# Documentation: https://github.com/zbackup/zbackup
# zbackup: a globally-deduplicating backup tool

local ret=1

_arguments -s -S \
  '--non-encrypted[create an unencrypted repository]' \
  '--password-file=[read encryption password from file]:file:_files' \
  '--silent[don'\''t output progress and stats]' \
  '--threads=[number of threads to use for compression]:count' \
  '--cache-size=[amount of RAM to use for cache]:size' \
  '--exchange=[data to exchange (backups|bundles|index) for export/import]:type:(backups bundles index)' \
  '*:command:->cmds' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'init:initialize a new storage repository'
      'backup:backup a file to a repository'
      'restore:restore a backup from a repository'
      'export:export files from a repository to another'
      'import:import files into a repository from another'
      'gc:perform garbage collection'
      'passwords:change or set passwords'
      'inspect:inspect a backup or bundle'
    )
    _describe -t commands 'zbackup command' cmds && ret=0
    _files && ret=0
    ;;
esac

return ret
