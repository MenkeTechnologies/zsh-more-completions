#compdef ld
# Documentation: man ld(1) (Apple ld64)
# Source: macOS ld — Mach-O linker (Apple ld64 / new ld).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-execute[produce MH_EXECUTE (default)]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-dylib[produce MH_DYLIB]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-bundle[produce MH_BUNDLE]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-r[merge object files into MH_OBJECT]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-dylinker[produce MH_DYLINKER]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-dynamic[dynamic Mach-O (default)]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-static[no-dyld static Mach-O (kernel)]' \
    '(-execute -dylib -bundle -r -dylinker -dynamic -static -preload)-preload[firmware/embedded ROM-style image]' \
    '*-arch+[output architecture]:arch:(i386 x86_64 x86_64h arm64 arm64e ppc ppc64 armv7 armv7s)' \
    '-o+[output file]:file:_files' \
    '*-l-[link with libfoo.dylib / libfoo.a]:lib:' \
    '*-needed-l-[force link even if no symbols used]:lib:' \
    '*-reexport-l-[re-export all symbols to clients]:lib:' \
    '*-upward-l-[mark as upward dependency]:lib:' \
    '*-hidden-l-[link static lib with hidden visibility]:lib:' \
    '*-weak-l-[mark as weak import]:lib:' \
    '*-assert-weak-l-[verify all references are weak imports]:lib:' \
    '*-delay-l-[delay-initialize dylib]:lib:' \
    '*-needed_library+[path-to-dylib, force-link]:dylib:_files' \
    '*-reexport_library+[path-to-library, re-export]:lib:_files' \
    '*-upward_library+[upward dylib]:dylib:_files' \
    '*-weak_library+[weak-imported dylib]:dylib:_files' \
    '*-assert_weak_library+[verify weak imports]:dylib:_files' \
    '*-delay_library+[delay-initialized dylib]:dylib:_files' \
    '*-L-[add library search directory]:dir:_files -/' \
    '*-F-[add framework search directory]:dir:_files -/' \
    '-Z[remove standard search paths]' \
    '-syslibroot+[prepend sysroot prefix to search paths]:dir:_files -/' \
    '(-two_levelnamespace -flat_namespace)-two_levelnamespace[use two-level namespace (default)]' \
    '(-two_levelnamespace -flat_namespace)-flat_namespace[use flat namespace]' \
    '-undefined+[behavior for undefined symbols]:treatment:(error warning suppress dynamic_lookup)' \
    '*-framework+[link with FRAMEWORK]:name:' \
    '*-weak_framework+[link with weak FRAMEWORK]:name:' \
    '*-reexport_framework+[re-export FRAMEWORK]:name:' \
    '*-upward_framework+[upward FRAMEWORK dependency]:name:' \
    '*-lazy-l-[lazy-load library]:lib:' \
    '-rpath+[runtime library search path]:dir:_files -/' \
    '-install_name+[dylib install name]:path:' \
    '-compatibility_version+[dylib compatibility version]:version:' \
    '-current_version+[dylib current version]:version:' \
    '-platform_version+[platform min-OS sdk]:platform min-os sdk:' \
    '-macosx_version_min+[macOS min version]:version:' \
    '-ios_version_min+[iOS min version]:version:' \
    '-tvos_version_min+[tvOS min version]:version:' \
    '-watchos_version_min+[watchOS min version]:version:' \
    '-bridgeos_version_min+[bridgeOS min version]:version:' \
    '-sectalign+[set segment+section alignment]:segname sectname alignment:' \
    '-seg1addr+[set first segment address]:addr:' \
    '-segprot+[set segment protection]:segname max init:' \
    '-segs_read_only_addr+[set read-only segs base]:addr:' \
    '-segs_read_write_addr+[set read-write segs base]:addr:' \
    '-e+[entry symbol]:symbol:' \
    '-export_dynamic[export all global symbols]' \
    '-bind_at_load[bind all symbols at load]' \
    '-no_uuid[omit LC_UUID]' \
    '-no_eh_labels[suppress eh labels]' \
    '-no_function_starts[suppress function-starts]' \
    '-no_data_in_code_info[suppress data-in-code info]' \
    '-dead_strip[remove unused code/data]' \
    '-dead_strip_dylibs[remove unused dylibs]' \
    '-no_dead_strip_inits_and_terms[do not strip init/term]' \
    '-S[suppress debug symbol info]' \
    '-x[remove local symbols]' \
    '-map+[write linkmap to file]:file:_files' \
    '-trace[trace files as loaded]' \
    '-v[verbose]' \
    '-no_warn_duplicate_libraries[silence duplicate-library warnings]' \
    '-fatal_warnings[treat warnings as errors]' \
    '-w[suppress warnings]' \
    '-ObjC[load all .o files containing ObjC]' \
    '-all_load[load all .o files from static libraries]' \
    '-force_load+[load all .o from a specific library]:lib:_files' \
    '-noall_load[do not -all_load (default)]' \
    '-search_paths_first[search dylib then static per dir]' \
    '-search_dylibs_first[search all dylibs then all static]' \
    '-headerpad_max_install_names[reserve max header pad]' \
    '-headerpad+[reserve N hex bytes of header pad]:hex:' \
    '-pagezero_size+[size of __PAGEZERO segment]:hex:' \
    '*-Wl,*[GCC-style passthrough]:arg:' \
    '*-Xlinker+[pass option to ld]:arg:' \
    '*:object/archive/dylib file:_files -g "*.{o,a,dylib,so,framework}"' \
    && ret=0

return ret
