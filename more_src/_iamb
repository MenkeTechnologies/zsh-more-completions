#compdef iamb

# Zsh completion for iamb (Matrix TUI client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-C --config-directory)'{-C,--config-directory}'[configuration directory]:directory:_directories' \
  '(-P --profile)'{-P,--profile}'[profile to use]:profile' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
