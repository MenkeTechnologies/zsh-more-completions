#compdef cargo-play
# Documentation: https://crates.io/crates/cargo-play
# run a Rust file like a script without a Cargo project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --clean)'{-c,--clean}'[rebuild without the cache from previous run]' \
  '(-m --mode)'{-m,--mode}'[cargo subcommand to use]:mode:(run test check expand)' \
  '--test[run test code (alias to --mode test)]' \
  '--check[check errors in your code (alias to --mode check)]' \
  '--expand[expand macros (alias to --mode expand)]' \
  '(-e --edition)'{-e,--edition}'[specify Rust edition]:edition:(2015 2018 2021)' \
  '--release[build program in release mode]' \
  '(-q --quiet)'{-q,--quiet}'[disable output from Cargo]' \
  '(-v --verbose)'{-v,--verbose}'[set Cargo verbose level]' \
  '--stdin[use stdin as main.rs]' \
  '--cargo-option[customize flags passed to Cargo]:flags' \
  '--save[generate a Cargo project based on inputs]' \
  '(-i --infer)'{-i,--infer}'[automatically infer crate dependencies]' \
  '*:rust file:_files -g "*.rs"' && ret=0

return ret
