#compdef R-CMD-INSTALL R-CMD-install
# _R-CMD-INSTALL — R Core Team R CMD INSTALL build and install R packages from sources tar.gz or directory (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-INSTALL() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-l+[library path]:dir:_files -/' \
        '--library=+[library path]:dir:_files -/' \
        '-c[clean]' \
        '--clean[clean]' \
        '--preclean[preclean]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--no-configure[no configure]' \
        '--no-docs[no docs]' \
        '--no-help[no help]' \
        '--no-html[no html]' \
        '--no-libs[no libs]' \
        '--no-data[no data]' \
        '--no-demo[no demo]' \
        '--no-exec[no exec]' \
        '--no-inst[no inst]' \
        '--no-test-load[no test load]' \
        '--no-clean-on-error[no clean on error]' \
        '--no-multiarch[no multiarch]' \
        '--no-staged-install[no staged install]' \
        '--no-byte-compile[no byte compile]' \
        '--no-source-code[no source code]' \
        '--use-vanilla[use vanilla]' \
        '--use-LTO[use LTO]' \
        '--no-use-LTO[no use LTO]' \
        '--with-keep.source[keep source]' \
        '--without-keep.source[no keep source]' \
        '--with-keep.parse.data[keep parse data]' \
        '--without-keep.parse.data[no keep parse data]' \
        '--byte-compile[byte compile]' \
        '--compile-both[compile both]' \
        '--install-tests[install tests]' \
        '--md5[md5 checksums]' \
        '--strip[strip]' \
        '--strip-shared[strip shared]' \
        '--strip-static[strip static]' \
        '--latex[latex]' \
        '--lock[lock]' \
        '--no-lock[no lock]' \
        '--pkglock[pkglock]' \
        '--no-pkglock[no pkglock]' \
        '--build[build]' \
        '--install-args=+[args]:str:' \
        '--configure-args=+[args]:str:' \
        '--configure-vars=+[vars]:str:' \
        '--data-compress=+[type]:t:(none gzip bzip2 xz)' \
        '--resave-data=+[type]:t:(no gzip best)' \
        '*:package:_files -g "*.tar.gz *.tgz"'
}

_R-CMD-INSTALL "$@"
