#compdef snarkjs

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'powersoftau:powers of tau ceremony'
  'groth16:Groth16 proof system'
  'plonk:PLONK proof system'
  'fflonk:FFLonk proof system'
  'r1cs:R1CS utilities'
  'wtns:witness utilities'
  'zkey:zkSNARK key utilities'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'snarkjs command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (powersoftau)
        local -a ptau_cmds=(
          'new:start a new ceremony'
          'contribute:contribute to ceremony'
          'beacon:apply random beacon'
          'prepare:prepare for phase 2'
          'verify:verify ceremony'
          'export:export challenge/response'
          'truncate:truncate a ptau file'
          'convert:convert from old format'
        )
        _arguments '1:ptau command:_describe -t ptau-cmds "ptau command" ptau_cmds' '*:files:_files' && ret=0
        ;;
      (groth16)
        local -a g16_cmds=(
          'setup:generate proving/verification keys'
          'prove:generate a proof'
          'verify:verify a proof'
          'fullprove:calculate witness and prove'
          'exportsolidityverifier:export Solidity verifier'
          'exportsoliditycalldata:export Solidity calldata'
        )
        _arguments '1:groth16 command:_describe -t g16-cmds "groth16 command" g16_cmds' '*:files:_files' && ret=0
        ;;
      (plonk|fflonk)
        local -a plonk_cmds=(
          'setup:generate proving/verification keys'
          'prove:generate a proof'
          'verify:verify a proof'
          'fullprove:calculate witness and prove'
          'exportsolidityverifier:export Solidity verifier'
          'exportsoliditycalldata:export Solidity calldata'
        )
        _arguments '1:command:_describe -t plonk-cmds "command" plonk_cmds' '*:files:_files' && ret=0
        ;;
      (r1cs)
        local -a r1cs_cmds=(
          'info:show info about R1CS'
          'print:print R1CS constraints'
          'export:export R1CS to JSON'
        )
        _arguments '1:r1cs command:_describe -t r1cs-cmds "r1cs command" r1cs_cmds' '*:files:_files' && ret=0
        ;;
      (wtns)
        local -a wtns_cmds=(
          'calculate:calculate witness'
          'check:check witness validity'
          'export:export witness to JSON'
          'debug:debug witness calculation'
        )
        _arguments '1:wtns command:_describe -t wtns-cmds "wtns command" wtns_cmds' '*:files:_files' && ret=0
        ;;
      (zkey)
        local -a zkey_cmds=(
          'new:create initial zkey'
          'contribute:contribute to phase 2'
          'beacon:apply random beacon'
          'verify:verify a zkey'
          'export:export verification key'
        )
        _arguments '1:zkey command:_describe -t zkey-cmds "zkey command" zkey_cmds' '*:files:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
