#compdef nmeig gmx-nmeig
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-nmeig.html
# gmx nmeig: diagonalize the Hessian for normal mode analysis

local ret=1

_arguments -s \
  '-f[Hessian matrix]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-of[xvgr/xmgr file]:file:_files' \
  '-ol[xvgr/xmgr file]:file:_files' \
  '-os[xvgr/xmgr file]:file:_files' \
  '-qc[xvgr/xmgr file]:file:_files' \
  '-v[full precision trajectory]:file:_files' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-m[apply mass weighting before diagonalization]' \
  '-first[first eigenvector to output]:int:' \
  '-last[last eigenvector to output]:int:' \
  '-maxspec[highest frequency (1/cm) in spectrum]:int:' \
  '-T[temperature for thermochemistry calculations]:real:' \
  '-P[pressure (bar) for entropy computation]:real:' \
  '-sigma[symmetric copies for entropy calculation]:int:' \
  '-scale[frequency scaling factor]:real:' \
  '-linear_toler[linearity tolerance threshold]:real:' \
  '-constr[apply constraint correction factors]' \
  '-width[Gaussian peak width (1/cm)]:real:' && ret=0

return ret
