#compdef 3dTqual
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTqual.html
# AFNI compute a quality index for each sub-brick in a 3D+time dataset

local ret=1

_arguments -s -S \
  '(-spearman -quadrant)-spearman[1 minus Spearman rank correlation (default)]' \
  '(-spearman -quadrant)-quadrant[use quadrant correlation coefficient]' \
  '(-autoclip -automask)-autoclip[remove low-intensity regions from median]' \
  '(-autoclip -automask)-automask[same clipping as 3dClipLevel]' \
  '-clip[exclude values below threshold]:val:' \
  '-mask[restrict computations to mask voxels]:mset:_files' \
  '-range[output median +/-3.5*MAD bounds]' \
  '*:dataset:_files' && ret=0

return ret
