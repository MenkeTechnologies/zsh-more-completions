#compdef pdfsam pdfsam-basic
# Documentation: https://pdfsam.org/
# Reference accessed: 2026-05-20
# Verified: upstream — GUI desktop application; STUB.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:pdf file:_files -g "*.pdf"' && ret=0

return ret
