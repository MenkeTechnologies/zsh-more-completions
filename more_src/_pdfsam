#compdef pdfsam pdfsam-basic
# Documentation: https://man.archlinux.org/search?q=pdfsam
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:pdf file:_files -g "*.pdf"' && ret=0

return ret
