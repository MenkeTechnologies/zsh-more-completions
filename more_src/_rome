#compdef rome

# Zsh completion for rome - Rome Tools (linter/formatter) - deprecated, see biome

local curcontext="$curcontext" state line ret=1

_rome_commands() {
  local -a commands=(
    'init:bootstraps a new rome project'
    'start:start the Rome daemon server'
    'stop:stop the Rome daemon server'
    'format:run the formatter on a set of files'
    'check:run the linter and check formatting'
    'ci:run the linter and format checks (no fixes)'
    'lsp-proxy:act as a server for the Language Server Protocol'
    'rage:print information for bug reports'
    'version:print the version'
    'help:print help'
  )
  _describe -t commands 'rome command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--colors[color output]:when:(off force)' \
  '--use-server[connect to daemon server]' \
  '--verbose[verbose output]' \
  '1: :_rome_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      format)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--write[write formatted output to disk]' \
          '--indent-style[indent style]:style:(tab space)' \
          '--indent-size[indent size]:size' \
          '--line-width[max line width]:width' \
          '--quote-style[quote style]:style:(single double)' \
          '--quote-properties[when to quote object properties]:mode:(as-needed preserve)' \
          '--trailing-comma[trailing comma]:mode:(all es5 none)' \
          '--semicolons[semicolons]:mode:(always as-needed)' \
          '--stdin-file-path[path of file to read from stdin]:file' \
          '*:file:_files' && ret=0
        ;;
      check|ci)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--apply[apply safe fixes]' \
          '--apply-unsafe[apply unsafe fixes]' \
          '--max-diagnostics[max diagnostics to display]:count' \
          '*:file:_files' && ret=0
        ;;
      start|stop|version|rage)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      init)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
