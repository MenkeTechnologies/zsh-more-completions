#compdef cbt
# Documentation: https://cloud.google.com/bigtable/docs/cbt-reference
# Google Cloud Bigtable CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-project[GCP project ID]:project:' \
  '-instance[Bigtable instance ID]:instance:' \
  '-creds[path to credentials file]:file:_files' \
  '-admin-endpoint[admin API endpoint]:endpoint:' \
  '-data-endpoint[data API endpoint]:endpoint:' \
  '-auth-token[auth token]:token:' \
  '-timeout[timeout for requests]:duration:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'count:count rows in a table'
      'createfamily:create a column family'
      'createtable:create a table'
      'deletecolumn:delete all cells in a column'
      'deletefamily:delete a column family'
      'deleterow:delete a row'
      'deletetable:delete a table'
      'doc:print documentation for cbt'
      'help:print help text'
      'listinstances:list Bigtable instances'
      'listclusters:list clusters in an instance'
      'lookup:read a single row'
      'ls:list tables'
      'mddoc:print documentation in Markdown'
      'read:read rows'
      'set:set value of a cell'
      'setgcpolicy:set GC policy for a column family'
      'version:print the current cbt version'
      'waitforreplication:wait for all replications to finish'
      'createappprofile:create an app profile'
      'deleteappprofile:delete an app profile'
      'getappprofile:read an app profile'
      'listappprofiles:list app profiles'
      'updateappprofile:update an app profile'
    )
    _describe -t commands 'cbt command' commands && ret=0
    ;;
esac

return ret
