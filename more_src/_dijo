#compdef dijo
# Documentation: https://man.archlinux.org/search?q=dijo
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-c --command)'{-c,--command}'=[run non-interactive command]:cmd:' \
  '(-l --list)'{-l,--list}'[list tracked habits]' \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]'
