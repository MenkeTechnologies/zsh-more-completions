#compdef grafana-agent grafana-agent-flow alloy

# Zsh completion for Grafana Agent / Alloy

_grafana-agent() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'run:run Grafana Agent'
    'fmt:format configuration files'
    'convert:convert configuration files'
    'tools:additional developer tools'
    'completion:generate shell completion'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'grafana-agent command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        run)
          _arguments -s -S \
            '--server.http.listen-addr=[HTTP listen address]:address:' \
            '--server.grpc.listen-addr=[gRPC listen address]:address:' \
            '--storage.path=[storage directory]:directory:_files -/' \
            '--disable-reporting[disable anonymous usage reporting]' \
            '--cluster.enabled[enable clustering]' \
            '--cluster.join-addresses=[addresses to join]:addresses:' \
            '--cluster.advertise-address=[address to advertise]:address:' \
            '--cluster.name=[cluster name]:name:' \
            '--config.format=[configuration format]:format:(alloy otelcol prometheus static)' \
            '--config.bypass-conversion-errors[bypass config conversion errors]' \
            '--config.extra-args=[extra arguments to pass]:args:' \
            '--stability.level=[minimum stability level]:level:(experimental public-preview generally-available)' \
            '1:config file:_files -g "*.{alloy,river,yaml,yml}"' \
            && ret=0
          ;;
        fmt)
          _arguments -s -S \
            '-w[write result to source file]' \
            '--write[write result to source file]' \
            '*:config files:_files -g "*.{alloy,river}"' \
            && ret=0
          ;;
        convert)
          _arguments -s -S \
            '--source-format=[source format]:format:(prometheus promtail static otelcol)' \
            '--output=[output file]:output file:_files' \
            '--bypass-errors[bypass conversion errors]' \
            '--extra-args=[extra arguments]:args:' \
            '1:source file:_files -g "*.{yaml,yml}"' \
            && ret=0
          ;;
        *)
          _arguments -s -S '--help[display help]' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_grafana-agent "$@"
