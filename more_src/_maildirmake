#compdef maildirmake
# Documentation: https://man.archlinux.org/search?q=maildirmake
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-q+[quota size]:size:' \
  '-Q+[quota count]:n:' \
  '-S+[group/share]:share:' \
  '-f+[folder name]:name:' \
  '*:maildir path:_files -/' && ret=0

return ret
