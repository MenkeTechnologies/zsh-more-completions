#compdef oiq
# Documentation: https://openinfraquote.readthedocs.io/en/latest/getting-started/basic-usage/
# oiq - OpenInfraQuote, estimate infrastructure costs from Terraform plan/state files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--pricesheet=[pricing sheet file to map resources to pricing data]:file:_files' \
  '--output=[write matched results to a file]:file:_files' \
  '--region=[apply pricing specific to a region]:region' \
  '--format=[output style]:format:(summary text json markdown atlantis-comment)' \
  '--usage=[custom usage file for tailored cost estimates]:file:_files' \
  '--mq=[advanced selection query for pricing]:query' \
  '--input=[use previously matched data as input]:file:_files' \
  '1:command:(match price)' \
  '*::arg:_files' && ret=0

return ret
