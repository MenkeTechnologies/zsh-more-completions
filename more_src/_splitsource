#compdef splitsource
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/splitsource.html
# Split sequence(s) into original source sequences

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-sequence=[input sequence(s)]:file:_files' \
  '-outseq=[output sequence set(s)]:file:_files' \
  '-feature[retain feature information]' \
  '-auto[turn off prompts]' \
  '-stdout[write output to stdout]' \
  '-filter[read stdin write stdout]' \
  '-version[show version]' \
  '*:sequence file:_files' && ret=0

return ret
