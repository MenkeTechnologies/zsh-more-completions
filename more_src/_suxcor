#compdef suxcor
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/convolution_correlation/suxcor.c
# SUXCOR - correlation with user-supplied filter

local ret=1

_arguments -s -S \
  'sufile=[file containing SU traces to use as filter]:f:_files' \
  'filter=[user-supplied correlation filter (ascii)]:f:_files' \
  'vibroseis=[=nsout for correlating vibroseis data]:v:' \
  'first=[supplied trace is first element]:f:(0 1)' \
  'panel=[use only first trace of sufile as filter]:p:(0 1)' \
  'ftwin=[first sample on first trace of window]:f:' \
  'ltwin=[first sample on last trace of window]:l:' \
  'ntwin=[number of samples in correlation window]:n:' \
  'ntrc=[number of traces on a gather]:n:' \
  '*:SU file:_files' && ret=0

return ret
