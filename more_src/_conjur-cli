#compdef conjur-cli
# _conjur-cli — CyberArk Conjur secrets management/access control CLI alias (cyberark team, Go); cobra
# upstream: https://github.com/cyberark/conjur-cli-go

_conjur-cli() {
    local -a sub=(
        'init:initialize the Conjur configuration'
        'login:login to Conjur'
        'logout:logout'
        'whoami:show current identity'
        'authenticate:authenticate and get API token'
        'check:check user privileges on resource'
        'host:host commands'
        'host change-api-key:change host API key'
        'host rotate-api-key:rotate host API key'
        'list:list resources'
        'policy:policy commands'
        'policy load:load policy'
        'policy update:update policy'
        'policy replace:replace policy'
        'policy fetch:fetch policy'
        'resource:resource commands'
        'resource exists:check if resource exists'
        'resource permitted-roles:show permitted roles'
        'resource show:show resource'
        'resource permitted:check if permitted'
        'role:role commands'
        'role exists:check if role exists'
        'role members:list role members'
        'role memberships:list role memberships'
        'role show:show role'
        'user:user commands'
        'user change-password:change password'
        'user rotate-api-key:rotate API key'
        'variable:variable commands'
        'variable get:get variable value'
        'variable set:set variable value'
        'variable values:get variable values'
        'env:environment commands'
        'env show:show env'
        'env use:use env'
        'edge:edge commands'
        'edge install:install edge'
        'edge uninstall:uninstall edge'
        'edge status:show edge status'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--insecure[insecure]' \
        '-i[insecure]' \
        '--config-file=+[config file]:file:_files' \
        '--cert-file=+[cert file]:file:_files' \
        '--ca-bundle=+[ca bundle]:file:_files' \
        '--api-key=+[api key]:str:' \
        '--account=+[account]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--url=+[url]:url:_urls' \
        '-l+[url]:url:_urls' \
        '--service-id=+[service id]:str:' \
        '--auth-type=+[type]:t:(authn authn-iam authn-azure authn-k8s authn-oidc authn-ldap authn-jwt)' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conjur subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_conjur-cli "$@"
