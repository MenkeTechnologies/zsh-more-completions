#compdef kwalletmanager5
# Documentation: https://github.com/KDE/kwalletmanager/blob/master/src/manager/main.cpp
# Reference accessed: 2026-05-16
# Verified: upstream src/manager/main.cpp.

# kwalletmanager: KDE Wallet management GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--show[ignored (compatibility)]' \
  '--kwalletd[for use by kwalletd only]' \
  '*:wallet name:' && ret=0
return ret
