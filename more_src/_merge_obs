#compdef merge_obs
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/merge_obs.html
# Reproject and combine multiple observations into a merged event file and images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infiles=[input event files]:files:_files' \
  'outroot=[root of output files]:root:' \
  'bands=[what energy or PI band, or bands, should be used]:bands:' \
  'xygrid=[xygrid for output or filename]:xygrid:' \
  'maxsize=[maximum image width or height in pixels]:maxsize:' \
  'binsize=[image binning factor]:binsize:' \
  'asolfiles=[input aspect solutions]:files:_files' \
  'badpixfiles=[input bad pixel files]:files:_files' \
  'maskfiles=[input mask files]:files:_files' \
  'dtffiles=[input dtf files for HRC observations]:files:_files' \
  'refcoord=[reference coordinates or evt2 file]:refcoord:' \
  'units=[units for the exposure map]:units:(default area time)' \
  'expmapthresh=[remove low-exposure regions]:thresh:' \
  'background=[method for background removal (HRC-I)]:method:' \
  'bkgparams=[optional argument for background subtraction]:params:' \
  'psfecf=[if set, create PSF map with this ECF]:ecf:' \
  'psfmerge=[how are the PSF maps combined]:psfmerge:' \
  'random=[random seed for randomization]:seed:' \
  'parallel=[run processes in parallel]:parallel:(yes no)' \
  'nproc=[number of processors to use]:nproc:' \
  'tmpdir=[directory for temporary files]:dir:_files -/' \
  'cleanup=[cleanup intermediary files on exit]:cleanup:(yes no)' \
  'clobber=[overwrite existing files]:clobber:(yes no)' \
  'verbose=[output verbosity]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
