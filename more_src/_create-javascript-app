#compdef create-javascript-app
# Documentation: https://www.npmjs.com/package/create-javascript-app
# Reference accessed: 2026-05-24
# Verified: npm view create-javascript-app bin; npm readme Options section.

# Zsh completion for create-javascript-app - JavaScript application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-n --name)'{-n,--name=}'[application name]:name:' \
  '(-t --target)'{-t,--target=}'[target folder for application]:directory:_directories' \
  '(-y --yarn)'{-y,--yarn=}'[run yarn install after scaffold]:bool:(true false)' \
  '(-d --debug)'{-d,--debug}'[print debug and verbose messages]' \
  '(-h --help)'{-h,--help}'[print option list]' \
  ':project name:' && ret=0

return ret
