#compdef sfdix
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: convert RMS to interval velocity (LS + shaping regularization)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'niter=[number of iterations]:niter:' \
  'weight=[weighting file]:weight:_files' \
  'vrmsout=[output predicted RMS velocity file]:vrmsout:_files' \
  '*: :_files' && ret=0

return ret
