#compdef eopkg
# Documentation: https://man.archlinux.org/search?q=eopkg
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add-repo:add a repository'
  'ar:alias for add-repo'
  'autoremove:remove unneeded packages'
  'blame:show package changelog'
  'build:build a Solus package'
  'bi:alias for build-info'
  'build-info:show package build info'
  'check:verify installation'
  'clean:clean stale lock files'
  'configure-pending:configure pending packages'
  'cp:alias for configure-pending'
  'delete-cache:delete package cache'
  'dc:alias for delete-cache'
  'delta:create delta packages'
  'disable-repo:disable repository'
  'dr:alias for disable-repo'
  'emerge:install latest source from upstream'
  'em:alias for emerge'
  'enable-repo:enable repository'
  'er:alias for enable-repo'
  'fetch:download package(s)'
  'fc:alias for fetch'
  'graph:produce dependency graph'
  'help:show help'
  'history:show transaction history'
  'hs:alias for history'
  'index:index packages'
  'ix:alias for index'
  'info:show package info'
  'install:install package'
  'it:alias for install'
  'list-available:list available packages'
  'la:alias for list-available'
  'list-components:list components'
  'lc:alias for list-components'
  'list-installed:list installed packages'
  'li:alias for list-installed'
  'list-newest:list newest packages'
  'ln:alias for list-newest'
  'list-orphans:list orphan packages'
  'lo:alias for list-orphans'
  'list-pending:list pending packages'
  'lp:alias for list-pending'
  'list-repo:list repositories'
  'lr:alias for list-repo'
  'list-sources:list sources'
  'ls:alias for list-sources'
  'list-upgrades:list available upgrades'
  'lu:alias for list-upgrades'
  'rebuild-db:rebuild database'
  'remove:remove package'
  'rm:alias for remove'
  'remove-orphans:remove orphan packages'
  'rmo:alias for remove-orphans'
  'remove-repo:remove repository'
  'rr:alias for remove-repo'
  'reverse-dependencies:show reverse deps'
  'revdep:alias for reverse-dependencies'
  'search:search packages'
  'sr:alias for search'
  'search-file:search by file'
  'sf:alias for search-file'
  'update-repo:update repository'
  'ur:alias for update-repo'
  'upgrade:upgrade packages'
  'up:alias for upgrade'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-D --destdir)'{-D+,--destdir=}'[destination directory]:dir:_files -/' \
  '(-y --yes-all)'{-y,--yes-all}'[assume yes]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '--debug-typeset[debug typeset]' \
  '(-N --no-color)'{-N,--no-color}'[disable colors]' \
  '-L+[language]:lang:' \
  '*-c+[component]:comp:' \
  '*--component=[component]:comp:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'eopkg command' commands && ret=0 ;;
esac

return ret
