#compdef gcalccmd
# Documentation: https://manpages.debian.org/testing/gnome-calculator/gcalccmd.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' && ret=0

return ret
