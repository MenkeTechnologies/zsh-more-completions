#compdef vcz vczd
# ============================================================================
# vcz / vczd - Vincenzo BitTorrent client + daemon (Rust, MIT)
#
# Author : Gabriel Demian (gabrieldemian)
# Upstream: https://github.com/gabrieldemian/vincenzo
#
# Vincenzo is a BitTorrent v1 client with vim-like keybindings,
# split across two binaries:
#
#   vczd  - the long-running daemon that hosts the torrent engine,
#           speaks BitTorrent peer-wire protocol over TCP + uTP,
#           accepts magnet URIs + .torrent files via a TCP control
#           socket (`DaemonCodec`), and writes downloaded pieces to
#           disk in parallel via a per-torrent Disk task.
#
#   vcz   - the terminal UI client that connects to the running
#           vczd over the same DaemonCodec, displays per-torrent
#           progress + per-peer stats + per-file selection in a
#           ratatui-based TUI with vim-style navigation, and can
#           also embed the daemon for single-binary use when no
#           vczd is running.
#
# The bencode lane is built on `bendy` (workspace dep declared at
# `crates/vcz-lib/Cargo.toml` HEAD), the canonical typed bencode
# codec for Rust. bendy implements the BEP 3 (BitTorrent Protocol)
# bencode format end-to-end: integer encoding (`i<N>e`), byte
# strings (`<len>:<bytes>`), lists (`l...e`), and dictionaries
# (`d<key><value>...e`) with strict canonical-form output (sorted
# dictionary keys, no trailing whitespace) per the BitTorrent
# v1 spec. Vincenzo uses bendy to decode the per-torrent
# .torrent metainfo file's `info` dictionary into typed Rust
# structs (announce, files, pieces, piece-length, multi-file
# layout) and to compute the canonical info-hash via SHA-1 of the
# re-serialized info dictionary.
#
# ----------------------------------------------------------------------------
# AXIS 205 :: BENCODE / BITTORRENT METAINFO (BEP 3)
# Round 1313 :: Rust slot 1 of 4 :: OPENS Axis 205
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : P3KI/bendy or toby/serde_bencode             - typed bencode codec
#   Go      : zeebo/bencode                                - reflective bencode codec
#   TS/Node : webtorrent/bencode (themasch/node-bencode)   - bencode codec
#
# All three target the same BEP 3 format spec (Bram Cohen, 2002):
# the four primitives (int / bytes / list / dict), canonical-form
# encoding for round-trip stability, and SHA-1 info-hash
# computability for cross-implementation peer identification.
# The format is one of the longest-lived public binary serialization
# schemas still in active use (alongside CBOR, MessagePack, and
# Protobuf), and the BitTorrent ecosystem is the canonical
# downstream consumer.
#
# vcz/vczd is the Rust opener and exercises bendy across all the
# canonical patterns: parse a multi-MB .torrent file, validate the
# info-dict shape, compute the SHA-1 info-hash for the tracker
# announce + peer identification, decode periodic tracker
# announce responses (also bencoded), and re-encode for proxy /
# pass-through scenarios. The split-binary client+daemon shape
# mirrors transmission, qBittorrent, deluge, and most other
# canonical BitTorrent clients.
# ============================================================================

_vcz() {
    case "$service" in
        vcz)    _vcz_client_args ;;
        vczd)   _vcz_daemon_args ;;
    esac
}

_vcz_client_args() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '*:magnet URI or .torrent file:_files -g "*.torrent"'
}

_vcz_daemon_args() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '*:magnet URI or .torrent file:_files -g "*.torrent"'
}

_vcz "$@"
