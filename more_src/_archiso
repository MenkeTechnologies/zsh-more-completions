#compdef archiso
# Arch Linux ISO build tool

local ret=1

_arguments -s -S \
  '-C[specify pacman configuration]:config file:_files' \
  '-D[specify install directory]:directory name:' \
  '-L[specify ISO label]:label:' \
  '-P[specify publisher]:publisher:' \
  '-A[specify application id]:application id:' \
  '-g[use GPG for signing]:GPG key:' \
  '-o[specify output directory]:output directory:_files -/' \
  '-r[run command in airootfs]:command:' \
  '-v[verbose output]' \
  '-w[specify work directory]:work directory:_files -/' \
  '-h[show help]' \
  '--help[show help]' \
  '1:profile directory:_files -/' && ret=0

return ret
