#compdef kdash

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-t,--tick-rate}'=[tick rate in ms]:tick rate' \
  {-p,--poll-rate}'=[poll rate in ms]:poll rate' \
  {-n,--namespace}'=[namespace]:namespace' \
  {-c,--context}'=[Kubernetes context]:context' \
  {-k,--keybindings}'=[keybindings config file]:keybindings:_files' \
  {-h,--help}'[print help]' \
  {-V,--version}'[print version]' \
  && ret=0
return ret
