#compdef ccls
# Documentation: https://github.com/MaskRay/ccls/wiki/Customization
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--index=[stand-alone index mode: process project root then exit]:directory:_directories' \
  '--init=[JSON initialization options]:json' \
  '--log-file=[write log to file]:file:_files' \
  '--log-file-append=[append log to file]:file:_files' \
  '-v=[log verbosity level (1 prints compile args)]:level' \
  '--test-index=[run index test on file]:file:_files'
